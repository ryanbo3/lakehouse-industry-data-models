    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSurchargeMethod rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Method' ;
    rdfs:comment 'Method by which fuel surcharges are calculated and applied to shipments under this contract.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverage rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage' ;
    rdfs:comment 'Geographic scope of the contract, e.g., North America, USA domestic, specific state/province list.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCoverageRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Required Flag' ;
    rdfs:comment 'Indicates whether the carrier is required to maintain specific cargo insurance coverage under this contract.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceMinimumCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Minimum Coverage Amount' ;
    rdfs:comment 'Minimum cargo insurance coverage amount required from the carrier.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastModifiedByName rdf:type rdf:Property ;
    rdfs:label 'Last Modified By Name' ;
    rdfs:comment 'Name of the user who last modified this carrier contract record.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumVolumeCommitment rdf:type rdf:Property ;
    rdfs:label 'Minimum Volume Commitment' ;
    rdfs:comment 'Minimum shipment volume (in commitment unit) that Manufacturing commits to tender to the carrier during the contract period.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:negotiationDate rdf:type rdf:Property ;
    rdfs:label 'Negotiation Date' ;
    rdfs:comment 'Date when the contract terms were finalized and agreed upon by both parties.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:penaltyClauseDescription rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause Description' ;
    rdfs:comment 'Description of penalties applicable for service failures, late deliveries, or volume shortfalls.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateAdjustmentTrigger rdf:type rdf:Property ;
    rdfs:label 'Rate Adjustment Trigger' ;
    rdfs:comment 'Conditions or events that trigger a rate adjustment, e.g., fuel price change exceeding 10%, volume variance exceeding 20%.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateReviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Rate Review Frequency' ;
    rdfs:comment 'Frequency at which contract rates are reviewed and potentially adjusted.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelStandard rdf:type rdf:Property ;
    rdfs:label 'Service Level Standard' ;
    rdfs:comment 'Guaranteed service level commitment, e.g., next-day delivery, 2-day delivery, standard ground.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of days advance notice required by either party to terminate the contract.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeCommitmentUnit rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Unit' ;
    rdfs:comment 'Unit of measure for the minimum volume commitment.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsDeclarationId rdf:type rdf:Property ;
    rdfs:label 'Customs Declaration Id' ;
    rdfs:comment 'Unique identifier for the customs declaration record. Primary key.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customsBrokerId rdf:type rdf:Property ;
    rdfs:label 'Customs Broker Id' ;
    rdfs:comment 'Reference to the licensed customs broker handling the declaration and clearance process.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomsBroker .

ind:applicableRegulations rdf:type rdf:Property ;
    rdfs:label 'Applicable Regulations' ;
    rdfs:comment 'Comma-separated list of applicable export control and trade compliance regulations (e.g., EAR, ITAR, EU Dual-Use, OFAC).' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondNumber rdf:type rdf:Property ;
    rdfs:label 'Bond Number' ;
    rdfs:comment 'Customs bond or guarantee number securing payment of duties and compliance with regulations.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Date' ;
    rdfs:comment 'Date when customs authority granted clearance and released the goods.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Date' ;
    rdfs:comment 'Date when the compliance officer completed the trade compliance review.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceScreeningOutcome rdf:type rdf:Property ;
    rdfs:label 'Compliance Screening Outcome' ;
    rdfs:comment 'Final outcome of the comprehensive trade compliance screening workflow.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consignorName rdf:type rdf:Property ;
    rdfs:label 'Consignor Name' ;
    rdfs:comment 'Name of the party shipping the goods from origin.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfDestination rdf:type rdf:Property ;
    rdfs:label 'Country Of Destination' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the final destination country for the goods.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfExport rdf:type rdf:Property ;
    rdfs:label 'Country Of Export' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the country from which goods are being exported.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationNumber rdf:type rdf:Property ;
    rdfs:label 'Declaration Number' ;
    rdfs:comment 'Official customs declaration number issued by customs authority. Externally-known unique identifier for this declaration.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationStatus rdf:type rdf:Property ;
    rdfs:label 'Declaration Status' ;
    rdfs:comment 'Current lifecycle status of the customs declaration in the clearance workflow. [ENUM-REF-CANDIDATE: draft|submitted|under_review|cleared|held|rejected|released — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationType rdf:type rdf:Property ;
    rdfs:label 'Declaration Type' ;
    rdfs:comment 'Type of customs declaration indicating the nature of cross-border movement.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredValue rdf:type rdf:Property ;
    rdfs:label 'Declared Value' ;
    rdfs:comment 'Total declared customs value of the goods in the specified currency.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deniedPartyScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Denied Party Screening Result' ;
    rdfs:comment 'Outcome of screening against denied parties lists, sanctioned entities, and restricted party databases.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dualUseClassification rdf:type rdf:Property ;
    rdfs:label 'Dual Use Classification' ;
    rdfs:comment 'Classification determination for goods that have both civilian and military applications.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyAmount rdf:type rdf:Property ;
    rdfs:label 'Duty Amount' ;
    rdfs:comment 'Total customs duty assessed and payable on the imported or exported goods.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eccn rdf:type rdf:Property ;
    rdfs:label 'Eccn' ;
    rdfs:comment 'Export Control Classification Number assigned under the Commerce Control List for dual-use items.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:embargoCheckResult rdf:type rdf:Property ;
    rdfs:label 'Embargo Check Result' ;
    rdfs:comment 'Result of screening against embargoed countries and restricted destinations.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Export License Number' ;
    rdfs:comment 'Government-issued export license number authorizing the export of controlled goods.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exporterOfRecord rdf:type rdf:Property ;
    rdfs:label 'Exporter Of Record' ;
    rdfs:comment 'Legal entity responsible for ensuring exported goods comply with export regulations and licensing requirements.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReason rdf:type rdf:Property ;
    rdfs:label 'Hold Reason' ;
    rdfs:comment 'Detailed explanation of why the shipment is under regulatory hold.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsCode rdf:type rdf:Property ;
    rdfs:label 'Hs Code' ;
    rdfs:comment 'Harmonized System tariff classification code for the goods. Primary classification for customs duty calculation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Import License Number' ;
    rdfs:comment 'Government-issued import license number authorizing the import of controlled or restricted goods.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importerOfRecord rdf:type rdf:Property ;
    rdfs:label 'Importer Of Record' ;
    rdfs:comment 'Legal entity responsible for ensuring imported goods comply with local laws and for paying duties and taxes.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incoterms rdf:type rdf:Property ;
    rdfs:label 'Incoterms' ;
    rdfs:comment 'International Commercial Terms defining the responsibilities of buyer and seller for delivery, risk, and cost. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseType rdf:type rdf:Property ;
    rdfs:label 'License Type' ;
    rdfs:comment 'Type of export or import license required (e.g., individual, blanket, temporary, general).' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfPackages rdf:type rdf:Property ;
    rdfs:label 'Number Of Packages' ;
    rdfs:comment 'Total count of packages, cartons, or containers in the shipment.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packageType rdf:type rdf:Property ;
    rdfs:label 'Package Type' ;
    rdfs:comment 'Type of packaging used for the shipment (e.g., pallet, carton, crate, container).' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfEntry rdf:type rdf:Property ;
    rdfs:label 'Port Of Entry' ;
    rdfs:comment 'Customs port or border crossing where the goods entered the destination country.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfExit rdf:type rdf:Property ;
    rdfs:label 'Port Of Exit' ;
    rdfs:comment 'Customs port or border crossing where the goods exited the origin country.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Total Tax Amount' ;
    rdfs:comment 'Total of all taxes, duties, and fees assessed on this customs declaration.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vatAmount rdf:type rdf:Property ;
    rdfs:label 'Vat Amount' ;
    rdfs:comment 'Value Added Tax or Goods and Services Tax assessed on the imported goods.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dangerousGoodsDeclarationId rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Declaration Id' ;
    rdfs:comment 'Unique identifier for the dangerous goods declaration record.' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preparedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Prepared By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: DG Declaration Preparation must be signed off by a qualified employee, required for regulatory compliance and audit trails.' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicableRegulation rdf:type rdf:Property ;
    rdfs:label 'Applicable Regulation' ;
    rdfs:comment 'Primary regulatory framework governing this dangerous goods shipment (IATA DGR for air, IMDG for ocean, DOT 49 CFR for US road, ADR for European road, RID for rail).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationReference rdf:type rdf:Property ;
    rdfs:label 'Authorization Reference' ;
    rdfs:comment 'Reference number of any special authorization, approval, or exemption granted by the competent authority for this dangerous goods shipment.' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoAircraftOnlyFlag rdf:type rdf:Property ;
    rdfs:label 'Cargo Aircraft Only Flag' ;
    rdfs:comment 'Indicates whether the dangerous goods are restricted to cargo aircraft only and prohibited on passenger aircraft per IATA DGR.' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competentAuthority rdf:type rdf:Property ;
    rdfs:label 'Competent Authority' ;
    rdfs:comment 'Name of the regulatory authority that issued any special authorization or approval for this dangerous goods shipment.' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneeAddress rdf:type rdf:Property ;
    rdfs:label 'Consignee Address' ;
    rdfs:comment 'Full address of the consignee receiving the dangerous goods.' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Declaration Approved By' ;
    rdfs:comment 'Name or identifier of the authorized person who approved the dangerous goods declaration for shipment.' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationApprovedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Declaration Approved Timestamp' ;
    rdfs:comment 'Date and time when the dangerous goods declaration was approved.' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:declarationPreparedBy rdf:type rdf:Property ;
    rdfs:label 'Declaration Prepared By' ;
    rdfs:comment 'Name or identifier of the person who prepared the dangerous goods declaration.' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationPreparedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Declaration Prepared Timestamp' ;
    rdfs:comment 'Date and time when the dangerous goods declaration was prepared.' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exceptedQuantityFlag rdf:type rdf:Property ;
    rdfs:label 'Excepted Quantity Flag' ;
    rdfs:comment 'Indicates whether the dangerous goods qualify for excepted quantity provisions allowing further regulatory relief.' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flashPointCelsius rdf:type rdf:Property ;
    rdfs:label 'Flash Point Celsius' ;
    rdfs:comment 'Lowest temperature at which vapors of the substance will ignite when exposed to an ignition source, measured in degrees Celsius. Required for flammable liquids.' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:limitedQuantityFlag rdf:type rdf:Property ;
    rdfs:label 'Limited Quantity Flag' ;
    rdfs:comment 'Indicates whether the dangerous goods qualify for limited quantity exemptions allowing relaxed packaging and labeling requirements.' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marinePollutantFlag rdf:type rdf:Property ;
    rdfs:label 'Marine Pollutant Flag' ;
    rdfs:comment 'Indicates whether the dangerous goods are classified as a marine pollutant per IMDG Code.' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netQuantity rdf:type rdf:Property ;
    rdfs:label 'Net Quantity' ;
    rdfs:comment 'Net quantity of the dangerous goods excluding packaging weight.' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Net Quantity Uom' ;
    rdfs:comment 'Unit of measure for the net quantity (kilograms, liters, grams, etc.).' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingInstruction rdf:type rdf:Property ;
    rdfs:label 'Packaging Instruction' ;
    rdfs:comment 'Specific packaging instruction code from the applicable dangerous goods regulation (e.g., P001, IBC02, LP02).' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingType rdf:type rdf:Property ;
    rdfs:label 'Packaging Type' ;
    rdfs:comment 'Type of packaging used for the dangerous goods (e.g., drum, box, cylinder, IBC).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingGroup rdf:type rdf:Property ;
    rdfs:label 'Packing Group' ;
    rdfs:comment 'Degree of danger presented by the substance: I (high danger), II (medium danger), III (low danger).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:properShippingName rdf:type rdf:Property ;
    rdfs:label 'Proper Shipping Name' ;
    rdfs:comment 'Official technical name of the dangerous goods as specified in regulatory dangerous goods lists (IATA, IMDG, DOT).' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperAddress rdf:type rdf:Property ;
    rdfs:label 'Shipper Address' ;
    rdfs:comment 'Full address of the shipper of the dangerous goods.' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Shipper Certification Date' ;
    rdfs:comment 'Date on which the shipper certified the dangerous goods declaration.' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipperCertificationSignature rdf:type rdf:Property ;
    rdfs:label 'Shipper Certification Signature' ;
    rdfs:comment 'Digital signature or name of the authorized person who certified the dangerous goods declaration on behalf of the shipper.' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperCertificationStatement rdf:type rdf:Property ;
    rdfs:label 'Shipper Certification Statement' ;
    rdfs:comment 'Regulatory-required certification statement signed by the shipper attesting that the dangerous goods are properly classified, packaged, marked, and labeled.' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialProvisions rdf:type rdf:Property ;
    rdfs:label 'Special Provisions' ;
    rdfs:comment 'Special provision codes or exemptions applicable to this dangerous goods shipment as specified in the regulation.' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subsidiaryHazardClass rdf:type rdf:Property ;
    rdfs:label 'Subsidiary Hazard Class' ;
    rdfs:comment 'Secondary hazard classification if the dangerous goods exhibit multiple hazardous properties.' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalName rdf:type rdf:Property ;
    rdfs:label 'Technical Name' ;
    rdfs:comment 'Chemical or technical name of the dangerous goods constituent, required when the proper shipping name is a generic N.O.S. (not otherwise specified) entry.' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Delivery Appointment Id' ;
    rdfs:comment 'Unique identifier for the delivery appointment record. Primary key.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:driverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Driver Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Delivery Appointment Management assigns an internal driver (employee) to each appointment, needed for dispatch planning and labor costing.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Time' ;
    rdfs:comment 'Actual date and time when the carrier vehicle arrived at the facility gate or dock area. Used to calculate wait time, on-time performance, and dock utilization metrics.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDepartureTime rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Time' ;
    rdfs:comment 'Actual date and time when the carrier vehicle departed the facility after completing loading or unloading operations. Used to calculate dwell time and dock turnaround efficiency.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:appointmentCreatedBy rdf:type rdf:Property ;
    rdfs:label 'Appointment Created By' ;
    rdfs:comment 'Username or identifier of the person or system that created the appointment record. Used for audit trail and accountability.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Appointment Created Timestamp' ;
    rdfs:comment 'Date and time when the appointment record was first created in the system. Used for audit trail and appointment lead time analysis.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:appointmentModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Appointment Modified By' ;
    rdfs:comment 'Username or identifier of the person or system that last modified the appointment record. Used for audit trail and change tracking.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Appointment Modified Timestamp' ;
    rdfs:comment 'Date and time when the appointment record was last updated. Used for audit trail and tracking appointment changes or rescheduling.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:appointmentNumber rdf:type rdf:Property ;
    rdfs:label 'Appointment Number' ;
    rdfs:comment 'Business-facing unique appointment number used for scheduling and tracking. Externally visible identifier for dock scheduling systems and carrier communications.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentStatus rdf:type rdf:Property ;
    rdfs:label 'Appointment Status' ;
    rdfs:comment 'Current lifecycle status of the delivery appointment. Scheduled when initially created, confirmed when carrier acknowledges, checked-in when vehicle arrives at gate, in-progress during loading/unloading, completed when finished, missed if carrier no-show, cancelled if appointment voided. [ENUM-REF-CANDIDATE: scheduled|confirmed|checked_in|in_progress|completed|missed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentType rdf:type rdf:Property ;
    rdfs:label 'Appointment Type' ;
    rdfs:comment 'Classification of the appointment direction and purpose. Inbound for receiving materials from suppliers, outbound for shipping finished goods to customers, cross-dock for direct transfer, return for RMA processing, transfer for inter-facility movement, pickup for carrier collection.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billOfLadingNumber rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Number' ;
    rdfs:comment 'Unique identifier of the bill of lading document associated with this appointment. Legal document serving as receipt of goods and contract of carriage.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Free-text explanation for why the appointment was cancelled. Used for root cause analysis of scheduling disruptions and carrier performance issues.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkInTime rdf:type rdf:Property ;
    rdfs:label 'Check In Time' ;
    rdfs:comment 'Date and time when the carrier checked in at the facility reception or guard gate. Marks the official start of the appointment process and triggers dock assignment workflow.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customsEntryNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Entry Number' ;
    rdfs:comment 'Customs entry or declaration number for international shipments. Required for import/export compliance and duty payment tracking.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Required Flag' ;
    rdfs:comment 'Indicates whether the shipment requires customs clearance for international trade. True for cross-border shipments, false for domestic movements.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dockDoorNumber rdf:type rdf:Property ;
    rdfs:label 'Dock Door Number' ;
    rdfs:comment 'Physical dock door or bay identifier assigned to this appointment. Used by warehouse management systems and yard management systems to direct carriers to the correct loading/unloading location.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Driver License Number' ;
    rdfs:comment 'Government-issued driver license number of the vehicle operator. Required for facility access control, insurance verification, and regulatory compliance.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverName rdf:type rdf:Property ;
    rdfs:label 'Driver Name' ;
    rdfs:comment 'Full name of the driver operating the vehicle for this appointment. Captured for security, safety compliance, and delivery verification purposes.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Driver Phone Number' ;
    rdfs:comment 'Contact phone number for the driver. Used for real-time communication regarding appointment changes, dock assignments, or delivery issues.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dwellTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Dwell Time Minutes' ;
    rdfs:comment 'Total time in minutes the vehicle spent at the facility from arrival to departure. Used to measure dock turnaround efficiency and identify bottlenecks in loading/unloading operations.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilityLocationCode rdf:type rdf:Property ;
    rdfs:label 'Facility Location Code' ;
    rdfs:comment 'Business location code identifying the specific plant, distribution center, or warehouse site. Used for multi-site logistics network management and reporting.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadType rdf:type rdf:Property ;
    rdfs:label 'Load Type' ;
    rdfs:comment 'Method of loading or unloading operation. Live load/unload means driver waits while cargo is handled, drop trailer means trailer is left for later processing, drop-and-hook means simultaneous trailer exchange.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresHazmatHandlingFlag rdf:type rdf:Property ;
    rdfs:label 'Requires Hazmat Handling Flag' ;
    rdfs:comment 'Indicates whether the shipment contains hazardous materials requiring special handling, documentation, and safety protocols per DOT and OSHA regulations.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresRefrigerationFlag rdf:type rdf:Property ;
    rdfs:label 'Requires Refrigeration Flag' ;
    rdfs:comment 'Indicates whether the shipment requires temperature-controlled handling. True for cold chain logistics, false for ambient temperature cargo.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledEndTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Time' ;
    rdfs:comment 'Precise date and time when the appointment window closes. Defines the latest time by which loading or unloading operations should be completed to maintain dock schedule integrity.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Time' ;
    rdfs:comment 'Precise date and time when the appointment window begins. Defines the earliest time the carrier should arrive at the dock door for loading or unloading operations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Free-text field capturing any special requirements or instructions for the appointment such as hazardous materials handling, temperature control, security protocols, or equipment needs.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trailerNumber rdf:type rdf:Property ;
    rdfs:label 'Trailer Number' ;
    rdfs:comment 'Unique identifier of the trailer or container being loaded or unloaded. Used for yard spotting, asset tracking, and cross-docking operations.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleLicensePlate rdf:type rdf:Property ;
    rdfs:label 'Vehicle License Plate' ;
    rdfs:comment 'Government-issued license plate number of the vehicle. Used for yard management, security tracking, and facility access control.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleType rdf:type rdf:Property ;
    rdfs:label 'Vehicle Type' ;
    rdfs:comment 'Classification of the transportation vehicle used for the delivery or pickup. FTL (Full Truckload) for dedicated loads, LTL (Less Than Truckload) for consolidated shipments, specialized types for specific cargo requirements. [ENUM-REF-CANDIDATE: ftl_truck|ltl_truck|box_truck|flatbed|tanker|refrigerated|intermodal_container|van — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waitTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Wait Time Minutes' ;
    rdfs:comment 'Total time in minutes between carrier arrival and start of loading/unloading operations. Key performance indicator for dock efficiency and carrier service level agreements.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryNoteId rdf:type rdf:Property ;
    rdfs:label 'Delivery Note Id' ;
    rdfs:comment 'Unique identifier for the delivery note. Primary key for this entity.' ;
    rdfs:domain ind:DeliveryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDeliveryShipToAddressId rdf:type rdf:Property ;
    rdfs:label 'Primary Delivery Ship To Address Id' ;
    rdfs:comment 'Destination address for outbound deliveries. Links to customer site or delivery location.' ;
    rdfs:domain ind:DeliveryNote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:supplyAllocationId rdf:type rdf:Property ;
    rdfs:label 'Supply Allocation Id' ;
    rdfs:comment 'Foreign key linking to supply.allocation. Business justification: Delivery notes are generated from supply allocation records; the link supports the Allocation-to-Delivery Note audit.' ;
    rdfs:domain ind:DeliveryNote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Allocation .

ind:customsDeclarationNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Declaration Number' ;
    rdfs:comment 'Customs declaration or entry number for international shipments requiring customs clearance.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDirection rdf:type rdf:Property ;
    rdfs:label 'Delivery Direction' ;
    rdfs:comment 'Discriminator indicating whether this is an inbound delivery (goods receipt from supplier) or outbound delivery (shipment to customer).' ;
    rdfs:domain ind:DeliveryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Note Number' ;
    rdfs:comment 'Externally-known business identifier for the delivery note. Used for tracking and reference across systems and with external parties.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPriority rdf:type rdf:Property ;
    rdfs:label 'Delivery Priority' ;
    rdfs:comment 'Priority level assigned to the delivery for warehouse and transportation planning.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current lifecycle status of the delivery note in the warehouse and logistics execution workflow. [ENUM-REF-CANDIDATE: draft|planned|picking|packed|shipped|in_transit|delivered|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightCostAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Amount' ;
    rdfs:comment 'Total freight or transportation cost for the delivery.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Currency' ;
    rdfs:comment 'Currency code for freight cost amount. ISO 4217 three-letter currency code.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsIssueDate rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Date' ;
    rdfs:comment 'Date when goods were physically issued from inventory for outbound deliveries. Triggers inventory reduction.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodsIssueStatus rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Status' ;
    rdfs:comment 'Status of goods issue posting for outbound deliveries. Indicates whether inventory has been reduced.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptStatus rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Status' ;
    rdfs:comment 'Status of goods receipt posting for inbound deliveries. Indicates whether inventory has been increased.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:harmonizedTariffCode rdf:type rdf:Property ;
    rdfs:label 'Harmonized Tariff Code' ;
    rdfs:comment 'Harmonized System code for customs classification and duty calculation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterms Location' ;
    rdfs:comment 'Named place or port specified in the Incoterms agreement where risk transfers between parties.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadingDate rdf:type rdf:Property ;
    rdfs:label 'Loading Date' ;
    rdfs:comment 'Date when goods were loaded onto the carrier vehicle for transportation.' ;
    rdfs:domain ind:DeliveryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:packingDate rdf:type rdf:Property ;
    rdfs:label 'Packing Date' ;
    rdfs:comment 'Date when goods were packed and prepared for shipment.' ;
    rdfs:domain ind:DeliveryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:packingStatus rdf:type rdf:Property ;
    rdfs:label 'Packing Status' ;
    rdfs:comment 'Status of packing operations indicating readiness for shipment.' ;
    rdfs:domain ind:DeliveryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickingDate rdf:type rdf:Property ;
    rdfs:label 'Picking Date' ;
    rdfs:comment 'Date when warehouse picking operations were completed for outbound deliveries.' ;
    rdfs:domain ind:DeliveryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pickingStatus rdf:type rdf:Property ;
    rdfs:label 'Picking Status' ;
    rdfs:comment 'Status of warehouse picking operations for outbound deliveries.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Date' ;
    rdfs:comment 'Scheduled or promised delivery date communicated to the customer or expected from the supplier.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proofOfDeliveryReceived rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Received' ;
    rdfs:comment 'Indicates whether proof of delivery documentation has been received and confirmed.' ;
    rdfs:domain ind:DeliveryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routeCode rdf:type rdf:Property ;
    rdfs:label 'Route Code' ;
    rdfs:comment 'Predefined route identifier used for transportation planning and optimization.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingMethod rdf:type rdf:Property ;
    rdfs:label 'Shipping Method' ;
    rdfs:comment 'Mode of transportation used for the delivery.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingServiceLevel rdf:type rdf:Property ;
    rdfs:label 'Shipping Service Level' ;
    rdfs:comment 'Service level or speed of delivery selected for the shipment.' ;
    rdfs:domain ind:DeliveryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalGrossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Gross Weight Kg' ;
    rdfs:comment 'Total gross weight of all goods including packaging, measured in kilograms.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Net Weight Kg' ;
    rdfs:comment 'Total net weight of all goods in the delivery, measured in kilograms. Excludes packaging weight.' ;
    rdfs:domain ind:DeliveryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Volume M3' ;
    rdfs:comment 'Total volume of all goods in the delivery, measured in cubic meters.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'Carrier-provided tracking number for shipment visibility and proof of delivery.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightClaimId rdf:type rdf:Property ;
    rdfs:label 'Freight Claim Id' ;
    rdfs:comment 'Unique identifier for the freight claim record. Primary key.' ;
    rdfs:domain ind:FreightClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjusterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Adjuster Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Freight Claim processing assigns an adjuster employee, needed for claim tracking, accountability, and cost analysis.' ;
    rdfs:domain ind:FreightClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignedAdjusterEmail rdf:type rdf:Property ;
    rdfs:label 'Assigned Adjuster Email' ;
    rdfs:comment 'Email address of the carrier claims adjuster handling this claim.' ;
    rdfs:domain ind:FreightClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedAdjusterName rdf:type rdf:Property ;
    rdfs:label 'Assigned Adjuster Name' ;
    rdfs:comment 'Name of the claims adjuster or handler assigned by the carrier to review and process this claim.' ;
    rdfs:domain ind:FreightClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierResponseDate rdf:type rdf:Property ;
    rdfs:label 'Carrier Response Date' ;
    rdfs:comment 'Date when the carrier formally acknowledged or responded to the freight claim. Used to track carrier compliance with response time requirements.' ;
    rdfs:domain ind:FreightClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Number' ;
    rdfs:comment 'Externally-known unique claim reference number assigned by the claimant or carrier for tracking and correspondence.' ;
    rdfs:domain ind:FreightClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimStatus rdf:type rdf:Property ;
    rdfs:label 'Claim Status' ;
    rdfs:comment 'Current lifecycle state of the freight claim in the resolution workflow. [ENUM-REF-CANDIDATE: filed|acknowledged|under_review|pending_documentation|settled|denied|escalated|withdrawn — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FreightClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimType rdf:type rdf:Property ;
    rdfs:label 'Claim Type' ;
    rdfs:comment 'Classification of the freight claim based on the nature of the incident: loss (goods missing), damage (goods harmed), shortage (quantity discrepancy), delay (late delivery), concealed damage (damage discovered after delivery), or refused shipment.' ;
    rdfs:domain ind:FreightClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantContactName rdf:type rdf:Property ;
    rdfs:label 'Claimant Contact Name' ;
    rdfs:comment 'Name of the individual contact person representing the claimant organization for this claim.' ;
    rdfs:domain ind:FreightClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantEmail rdf:type rdf:Property ;
    rdfs:label 'Claimant Email' ;
    rdfs:comment 'Email address of the claimant contact for claim correspondence and updates.' ;
    rdfs:domain ind:FreightClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantName rdf:type rdf:Property ;
    rdfs:label 'Claimant Name' ;
    rdfs:comment 'Name of the party filing the freight claim, typically the shipper, consignee, or beneficial owner of the goods.' ;
    rdfs:domain ind:FreightClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantPhone rdf:type rdf:Property ;
    rdfs:label 'Claimant Phone' ;
    rdfs:comment 'Primary phone number of the claimant contact for claim follow-up.' ;
    rdfs:domain ind:FreightClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimedAmount rdf:type rdf:Property ;
    rdfs:label 'Claimed Amount' ;
    rdfs:comment 'Total monetary value claimed by the shipper for loss, damage, shortage, or delay, including product value, freight charges, and consequential damages where applicable.' ;
    rdfs:domain ind:FreightClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimedCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Claimed Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the claimed amount.' ;
    rdfs:domain ind:FreightClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denialReasonCode rdf:type rdf:Property ;
    rdfs:label 'Denial Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for claim denial (e.g., insufficient documentation, pre-existing damage, act of God, shipper packaging fault).' ;
    rdfs:domain ind:FreightClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denialReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Denial Reason Description' ;
    rdfs:comment 'Detailed explanation provided by the carrier for denying the freight claim.' ;
    rdfs:domain ind:FreightClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'Current escalation tier of the claim if it has moved beyond standard resolution process.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDate rdf:type rdf:Property ;
    rdfs:label 'Filing Date' ;
    rdfs:comment 'Date when the freight claim was formally filed with the carrier. Critical for statute of limitations tracking (typically 9 months under Carmack Amendment).' ;
    rdfs:domain ind:FreightClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Filing Timestamp' ;
    rdfs:comment 'Precise date and time when the freight claim was submitted, used for audit trail and SLA (Service Level Agreement) tracking.' ;
    rdfs:domain ind:FreightClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:incidentDate rdf:type rdf:Property ;
    rdfs:label 'Incident Date' ;
    rdfs:comment 'Date when the loss, damage, shortage, or delay incident occurred or was discovered.' ;
    rdfs:domain ind:FreightClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionReportNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Report Number' ;
    rdfs:comment 'Reference number of the third-party or carrier inspection report documenting the damage or loss.' ;
    rdfs:domain ind:FreightClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCompanyName rdf:type rdf:Property ;
    rdfs:label 'Insurance Company Name' ;
    rdfs:comment 'Name of the insurance company involved in subrogation or cargo insurance coverage for this claim.' ;
    rdfs:domain ind:FreightClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Limit Amount' ;
    rdfs:comment 'Maximum amount the carrier is liable for under the terms of the Bill of Lading (BOL) and applicable regulations. May be based on declared value, weight, or tariff provisions.' ;
    rdfs:domain ind:FreightClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proNumber rdf:type rdf:Property ;
    rdfs:label 'Pro Number' ;
    rdfs:comment 'Carrier-assigned progressive or tracking number for the shipment, used for tracing and claim correlation.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productDescription rdf:type rdf:Property ;
    rdfs:label 'Product Description' ;
    rdfs:comment 'Description of the goods that were lost, damaged, or delayed, including material type, SKU (Stock Keeping Unit), and quantity.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Amount' ;
    rdfs:comment 'Final agreed-upon monetary amount paid to resolve the claim. Populated when claim status reaches settled.' ;
    rdfs:domain ind:FreightClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the settlement amount.' ;
    rdfs:domain ind:FreightClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementOfferAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Offer Amount' ;
    rdfs:comment 'Monetary amount offered by the carrier to settle the claim. May be less than, equal to, or (rarely) greater than the claimed amount.' ;
    rdfs:domain ind:FreightClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subrogationFlag rdf:type rdf:Property ;
    rdfs:label 'Subrogation Flag' ;
    rdfs:comment 'Indicates whether the claim involves subrogation rights, where an insurance company has paid the claimant and is pursuing recovery from the carrier.' ;
    rdfs:domain ind:FreightClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportingDocumentationList rdf:type rdf:Property ;
    rdfs:label 'Supporting Documentation List' ;
    rdfs:comment 'Comma-separated list or structured reference to supporting documents submitted with the claim (e.g., delivery receipt, inspection report, photos, invoice, packing list, weight certificate). Critical for claim substantiation.' ;
    rdfs:domain ind:FreightClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Freight Invoice Id' ;
    rdfs:comment 'Unique identifier for the freight invoice record. Primary key.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationLocationLogisticsNodeId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Logistics Node Id' ;
    rdfs:comment 'Identifier of the shipment destination location (customer site, plant, warehouse, or distribution center).' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Node .

ind:freightOrderId rdf:type rdf:Property ;
    rdfs:label 'Freight Order Id' ;
    rdfs:comment 'Reference to the freight order that authorized this shipment. Used for three-way match validation (freight order vs BOL vs invoice).' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightOrder .

ind:primaryFreightNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Freight Node Id' ;
    rdfs:comment 'Identifier of the shipment origin location (supplier site, plant, warehouse, or distribution center).' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Node .

ind:accessorialCharges rdf:type rdf:Property ;
    rdfs:label 'Accessorial Charges' ;
    rdfs:comment 'Additional charges for special services such as liftgate, inside delivery, residential delivery, detention, storage, or redelivery.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Amount' ;
    rdfs:comment 'Final amount approved for payment after audit and dispute resolution. This is the amount that will be paid to the carrier.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Audit Completed Date' ;
    rdfs:comment 'Date the freight audit and payment (FAP) process was completed for this invoice.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditedAmount rdf:type rdf:Property ;
    rdfs:label 'Audited Amount' ;
    rdfs:comment 'Amount determined to be correct after freight audit and payment (FAP) process validation. May differ from invoiced amount due to rate discrepancies or billing errors.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsDuties rdf:type rdf:Property ;
    rdfs:label 'Customs Duties' ;
    rdfs:comment 'Customs duties and import/export fees charged for cross-border shipments. Applicable for international freight.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'Date the carrier delivered the shipment to the destination location.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distanceKm rdf:type rdf:Property ;
    rdfs:label 'Distance Km' ;
    rdfs:comment 'Total distance traveled for this shipment in kilometers. Used for mileage-based rate validation and route optimization analysis.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelSurcharge rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge' ;
    rdfs:comment 'Variable fuel surcharge applied by carrier based on current fuel prices and agreed fuel surcharge schedule.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoicedAmount rdf:type rdf:Property ;
    rdfs:label 'Invoiced Amount' ;
    rdfs:comment 'Total amount invoiced by the carrier, including line haul, fuel surcharge, accessorials, customs duties, and taxes. Gross invoice total.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineHaulCharge rdf:type rdf:Property ;
    rdfs:label 'Line Haul Charge' ;
    rdfs:comment 'Base transportation charge for moving freight from origin to destination, excluding fuel surcharges and accessorial fees.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'Date by which payment is due to the carrier per agreed payment terms.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'Payment transaction reference number or check number used for payment reconciliation and audit trail.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceType rdf:type rdf:Property ;
    rdfs:label 'Service Type' ;
    rdfs:comment 'Type of transportation service provided: Less Than Truckload (LTL), Full Truckload (FTL), parcel, intermodal, air freight, ocean freight, or rail. [ENUM-REF-CANDIDATE: LTL|FTL|parcel|intermodal|air|ocean|rail — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitDays rdf:type rdf:Property ;
    rdfs:label 'Transit Days' ;
    rdfs:comment 'Number of days in transit from pickup to delivery. Used for carrier performance evaluation and SLA compliance tracking.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceReason rdf:type rdf:Property ;
    rdfs:label 'Variance Reason' ;
    rdfs:comment 'Explanation of discrepancies identified during three-way match or freight audit process (e.g., rate mismatch, weight discrepancy, unauthorized accessorials).' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeM3 rdf:type rdf:Property ;
    rdfs:label 'Volume M3' ;
    rdfs:comment 'Total volume of the shipment in cubic meters. Used for dimensional weight calculations and capacity planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accessorialChargesAmount rdf:type rdf:Property ;
    rdfs:label 'Accessorial Charges Amount' ;
    rdfs:comment 'Total amount of accessorial charges applied to this freight order. Accessorials include additional services such as liftgate, inside delivery, residential delivery, detention, fuel surcharge, and other non-standard services.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Timestamp' ;
    rdfs:comment 'Actual date and time when the carrier delivered the goods to the destination. Null until delivery is completed. Used for on-time performance measurement and SLA compliance tracking.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualPickupTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Pickup Timestamp' ;
    rdfs:comment 'Actual date and time when the carrier picked up the goods. Null until pickup is completed. Used for on-time performance measurement and SLA compliance tracking.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:carrierAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Carrier Acceptance Status' ;
    rdfs:comment 'Status of the carrier\'s response to the freight order tender. Pending indicates awaiting response, Accepted means carrier confirmed, Rejected means carrier declined, Expired means tender window closed without response.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierAcceptanceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Carrier Acceptance Timestamp' ;
    rdfs:comment 'Date and time when the carrier accepted or rejected the freight order tender.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customsRequiredIndicator rdf:type rdf:Property ;
    rdfs:label 'Customs Required Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this freight order requires customs clearance documentation for cross-border shipment.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Delivery Window End' ;
    rdfs:comment 'Latest date and time when the carrier must deliver the goods. Defines the end of the acceptable delivery time window and may be tied to Service Level Agreement (SLA) commitments.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryWindowStart rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Start' ;
    rdfs:comment 'Earliest date and time when the carrier may deliver the goods. Defines the beginning of the acceptable delivery time window.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:equipmentType rdf:type rdf:Property ;
    rdfs:label 'Equipment Type' ;
    rdfs:comment 'Type of transportation equipment required for this freight order. Dry Van for standard enclosed trailer, Refrigerated for temperature-controlled, Flatbed for oversized or open cargo, Tanker for liquid bulk, Container for intermodal shipping, Box Truck for local delivery.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Freight Order Number' ;
    rdfs:comment 'Business-facing unique identifier for the freight order, typically generated by the Transportation Management System (TMS) or SAP TM module. Used for external communication with carriers and internal tracking.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Freight Order Status' ;
    rdfs:comment 'Current lifecycle status of the freight order. Draft indicates order is being prepared, Tendered means sent to carrier, Accepted means carrier confirmed, Rejected means carrier declined, In Transit means shipment is moving, Delivered means goods received, Cancelled means order voided, Closed means order completed and invoiced. [ENUM-REF-CANDIDATE: Draft|Tendered|Accepted|Rejected|In Transit|Delivered|Cancelled|Closed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightRateAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Rate Amount' ;
    rdfs:comment 'Agreed base freight rate amount for transporting the goods, excluding accessorial charges and taxes. Represents the core transportation cost negotiated with the carrier.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightRateCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Freight Rate Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the freight rate amount (e.g., USD, EUR, CNY).' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatIndicator rdf:type rdf:Property ;
    rdfs:label 'Hazmat Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this freight order contains hazardous materials requiring special handling, documentation, and compliance with transportation safety regulations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incotermCode rdf:type rdf:Property ;
    rdfs:label 'Incoterm Code' ;
    rdfs:comment 'Three-letter Incoterms code defining the responsibilities, costs, and risks between buyer and seller for international shipments. Examples: EXW (Ex Works), FOB (Free On Board), CIF (Cost Insurance and Freight), DDP (Delivered Duty Paid). [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'User ID or name of the person or system that last modified this freight order record. Audit field for change accountability.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageCount rdf:type rdf:Property ;
    rdfs:label 'Package Count' ;
    rdfs:comment 'Total number of individual packages or handling units included in this freight order.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:palletCount rdf:type rdf:Property ;
    rdfs:label 'Pallet Count' ;
    rdfs:comment 'Number of pallets included in this freight order. Used for handling unit tracking and warehouse space planning.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pickupWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Pickup Window End' ;
    rdfs:comment 'Latest date and time when the carrier must pick up the goods. Defines the end of the acceptable pickup time window.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickupWindowStart rdf:type rdf:Property ;
    rdfs:label 'Pickup Window Start' ;
    rdfs:comment 'Earliest date and time when the carrier may pick up the goods. Defines the beginning of the acceptable pickup time window.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sapTmFreightOrderReference rdf:type rdf:Property ;
    rdfs:label 'Sap Tm Freight Order Reference' ;
    rdfs:comment 'Reference identifier from SAP Transportation Management (TM) module linking this freight order to the source system record. Used for traceability and reconciliation with the operational TMS.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlledIndicator rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this freight order requires temperature-controlled transportation (refrigerated or heated).' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tenderMethod rdf:type rdf:Property ;
    rdfs:label 'Tender Method' ;
    rdfs:comment 'Method by which the freight order was tendered to the carrier. Spot indicates one-time market rate, Contract indicates pre-negotiated agreement rate, Auction indicates competitive bidding process, Direct Award indicates sole-source assignment.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenderTimestamp rdf:type rdf:Property ;
    rdfs:label 'Tender Timestamp' ;
    rdfs:comment 'Date and time when the freight order was tendered to the carrier. Represents the business event when the carrier was formally requested to provide transportation service.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalFreightCost rdf:type rdf:Property ;
    rdfs:label 'Total Freight Cost' ;
    rdfs:comment 'Total cost of the freight order including base freight rate, accessorial charges, and any applicable surcharges. Represents the complete contracted cost for this transportation service.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightRateId rdf:type rdf:Property ;
    rdfs:label 'Freight Rate Id' ;
    rdfs:comment 'Unique identifier for the freight rate record. Primary key.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:laneId rdf:type rdf:Property ;
    rdfs:label 'Lane Id' ;
    rdfs:comment 'Identifier of the transportation lane (origin-destination pair) for which this rate applies.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lane .

ind:accessorialChargesApplicable rdf:type rdf:Property ;
    rdfs:label 'Accessorial Charges Applicable' ;
    rdfs:comment 'Indicates whether additional accessorial charges (liftgate, inside delivery, residential delivery, etc.) may apply to shipments using this rate.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseRate rdf:type rdf:Property ;
    rdfs:label 'Base Rate' ;
    rdfs:comment 'Base freight rate amount per unit as defined by rate_basis, before surcharges and adjustments.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationPostalCodeRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Destination Postal Code Range End' ;
    rdfs:comment 'Ending postal code of the destination range for which this rate applies.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPostalCodeRangeStart rdf:type rdf:Property ;
    rdfs:label 'Destination Postal Code Range Start' ;
    rdfs:comment 'Starting postal code of the destination range for which this rate applies.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationZoneCode rdf:type rdf:Property ;
    rdfs:label 'Destination Zone Code' ;
    rdfs:comment 'Geographic zone or postal code range identifier for the shipment destination covered by this rate.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distanceMaxKm rdf:type rdf:Property ;
    rdfs:label 'Distance Max Km' ;
    rdfs:comment 'Maximum distance in kilometers for which this rate applies, used in distance-based pricing.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distanceMinKm rdf:type rdf:Property ;
    rdfs:label 'Distance Min Km' ;
    rdfs:comment 'Minimum distance in kilometers for which this rate applies, used in distance-based pricing.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelSurchargePercentage rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Percentage' ;
    rdfs:comment 'Fuel surcharge percentage applied to the base rate to account for fuel cost fluctuations.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatEligible rdf:type rdf:Property ;
    rdfs:label 'Hazmat Eligible' ;
    rdfs:comment 'Indicates whether this rate is applicable to shipments containing hazardous materials.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumCharge rdf:type rdf:Property ;
    rdfs:label 'Maximum Charge' ;
    rdfs:comment 'Maximum charge cap for a shipment under this rate, if applicable.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumCharge rdf:type rdf:Property ;
    rdfs:label 'Minimum Charge' ;
    rdfs:comment 'Minimum charge amount for a shipment under this rate, regardless of weight or distance.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originPostalCodeRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Origin Postal Code Range End' ;
    rdfs:comment 'Ending postal code of the origin range for which this rate applies.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originPostalCodeRangeStart rdf:type rdf:Property ;
    rdfs:label 'Origin Postal Code Range Start' ;
    rdfs:comment 'Starting postal code of the origin range for which this rate applies.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originZoneCode rdf:type rdf:Property ;
    rdfs:label 'Origin Zone Code' ;
    rdfs:comment 'Geographic zone or postal code range identifier for the shipment origin covered by this rate.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateBasis rdf:type rdf:Property ;
    rdfs:label 'Rate Basis' ;
    rdfs:comment 'Basis on which the rate is calculated: per hundredweight (cwt), per mile, per shipment, per pallet, per unit, or flat rate.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCode rdf:type rdf:Property ;
    rdfs:label 'Rate Code' ;
    rdfs:comment 'Business identifier or code for this freight rate, used for external reference and carrier communication.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rate Created Timestamp' ;
    rdfs:comment 'Timestamp when this freight rate record was first created in the system.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rateLastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rate Last Updated Timestamp' ;
    rdfs:comment 'Timestamp when this freight rate record was last modified in the system.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ratePublishedDate rdf:type rdf:Property ;
    rdfs:label 'Rate Published Date' ;
    rdfs:comment 'Date on which this rate was published or made available by the carrier.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Rate Source System' ;
    rdfs:comment 'Name of the source system or Transportation Management System (TMS) from which this rate was loaded or synchronized.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Status' ;
    rdfs:comment 'Current lifecycle status of the freight rate record.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateType rdf:type rdf:Property ;
    rdfs:label 'Rate Type' ;
    rdfs:comment 'Classification of the rate source: contract (negotiated agreement), spot (market rate), benchmark (industry standard), or tariff (published rate).' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevel rdf:type rdf:Property ;
    rdfs:label 'Service Level' ;
    rdfs:comment 'Service level or speed tier offered by the carrier for this rate (standard, expedited, express, economy).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitTimeDays rdf:type rdf:Property ;
    rdfs:label 'Transit Time Days' ;
    rdfs:comment 'Expected transit time in days for shipments using this rate and service level.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transportationMode rdf:type rdf:Property ;
    rdfs:label 'Transportation Mode' ;
    rdfs:comment 'Mode of transportation for this rate: Less Than Truckload (LTL), Full Truckload (FTL), parcel, air freight, ocean freight, rail, or intermodal. [ENUM-REF-CANDIDATE: LTL|FTL|parcel|air|ocean|rail|intermodal — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCommitmentRequired rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Required' ;
    rdfs:comment 'Indicates whether this rate requires a minimum volume commitment from the shipper.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weightBreakMaxKg rdf:type rdf:Property ;
    rdfs:label 'Weight Break Max Kg' ;
    rdfs:comment 'Maximum weight in kilograms for this rate tier in a weight-break pricing structure.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightBreakMinKg rdf:type rdf:Property ;
    rdfs:label 'Weight Break Min Kg' ;
    rdfs:comment 'Minimum weight in kilograms for this rate tier in a weight-break pricing structure.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inboundDeliveryId rdf:type rdf:Property ;
    rdfs:label 'Inbound Delivery Id' ;
    rdfs:comment 'Unique identifier for the inbound delivery document. Primary key for this entity.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundDelivery .

ind:replenishmentProposalId rdf:type rdf:Property ;
    rdfs:label 'Replenishment Proposal Id' ;
    rdfs:comment 'Foreign key linking to supply.replenishment_proposal. Business justification: Inbound deliveries are the physical receipt of goods proposed in a replenishment proposal; needed for the \'Proposal-to-Receipt\' tracking report.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReplenishmentProposal .

ind:blockedStockFlag rdf:type rdf:Property ;
    rdfs:label 'Blocked Stock Flag' ;
    rdfs:comment 'Indicates whether the received goods are placed in blocked stock pending quality inspection or other clearance.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Status' ;
    rdfs:comment 'Status of customs clearance for international inbound deliveries.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCompleteFlag rdf:type rdf:Property ;
    rdfs:label 'Delivery Complete Flag' ;
    rdfs:comment 'Indicates whether the inbound delivery is considered complete and no further receipts are expected for this document.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryNoteText rdf:type rdf:Property ;
    rdfs:label 'Delivery Note Text' ;
    rdfs:comment 'Free-text notes or comments related to this inbound delivery, capturing special instructions or observations.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryVarianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Delivery Variance Quantity' ;
    rdfs:comment 'Difference between quantity ordered and quantity received (positive for over-delivery, negative for under-delivery).' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsReceiptPostedBy rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Posted By' ;
    rdfs:comment 'User ID or name of the warehouse operator who posted the goods receipt transaction.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inboundDeliveryNumber rdf:type rdf:Property ;
    rdfs:label 'Inbound Delivery Number' ;
    rdfs:comment 'Business document number for the inbound delivery as generated by SAP MM. Externally visible identifier used for tracking and reference.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Inspection Required Flag' ;
    rdfs:comment 'Indicates whether quality inspection is required before the goods can be posted to unrestricted inventory.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overDeliveryTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Over Delivery Tolerance Percent' ;
    rdfs:comment 'Allowable percentage by which the received quantity may exceed the ordered quantity without triggering an exception.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packingSlipNumber rdf:type rdf:Property ;
    rdfs:label 'Packing Slip Number' ;
    rdfs:comment 'Packing slip or delivery note number provided by the supplier, listing the contents of the shipment.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityOrdered rdf:type rdf:Property ;
    rdfs:label 'Quantity Ordered' ;
    rdfs:comment 'Total quantity of material or components ordered as per the purchase order.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityReceived rdf:type rdf:Property ;
    rdfs:label 'Quantity Received' ;
    rdfs:comment 'Actual quantity of material or components received and posted to inventory via goods receipt.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivingDock rdf:type rdf:Property ;
    rdfs:label 'Receiving Dock' ;
    rdfs:comment 'Specific dock or receiving bay at the plant where the inbound delivery was unloaded.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Number' ;
    rdfs:comment 'Tracking number or shipment identifier provided by the carrier for this inbound delivery.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingPoint rdf:type rdf:Property ;
    rdfs:label 'Shipping Point' ;
    rdfs:comment 'Location or facility from which the supplier shipped the materials.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underDeliveryTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Under Delivery Tolerance Percent' ;
    rdfs:comment 'Allowable percentage by which the received quantity may fall short of the ordered quantity without triggering an exception.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loadPlanId rdf:type rdf:Property ;
    rdfs:label 'Load Plan Id' ;
    rdfs:comment 'Unique identifier for the load plan record. Primary key for the load plan entity.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationFacilityLogisticsNodeId rdf:type rdf:Property ;
    rdfs:label 'Destination Facility Logistics Node Id' ;
    rdfs:comment 'Identifier of the warehouse, plant, distribution center, or customer site to which the load is destined.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Node .

ind:plannedCarrierId rdf:type rdf:Property ;
    rdfs:label 'Planned Carrier Id' ;
    rdfs:comment 'Identifier of the carrier or logistics service provider selected to execute this load plan.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:primaryLoadEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Load Employee Id' ;
    rdfs:comment 'Identifier of the user or system that created this load plan record, used for audit trail and accountability.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryLoadNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Load Node Id' ;
    rdfs:comment 'Identifier of the warehouse, plant, or distribution center from which the load originates.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Node .

ind:actualLoadDate rdf:type rdf:Property ;
    rdfs:label 'Actual Load Date' ;
    rdfs:comment 'The actual date when the load was physically assembled and loaded, used for performance tracking against planned date.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:carrierServiceLevel rdf:type rdf:Property ;
    rdfs:label 'Carrier Service Level' ;
    rdfs:comment 'The service level agreement tier selected for this load, determining transit time commitments and handling requirements.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsRequired rdf:type rdf:Property ;
    rdfs:label 'Customs Required' ;
    rdfs:comment 'Indicates whether this load requires customs clearance due to cross-border transportation, triggering documentation and compliance workflows.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dockDoorAssignment rdf:type rdf:Property ;
    rdfs:label 'Dock Door Assignment' ;
    rdfs:comment 'The specific dock door or loading bay assigned for loading this shipment at the origin facility, used for warehouse execution coordination.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Date' ;
    rdfs:comment 'The estimated date when the load is expected to arrive at the destination facility, calculated from planned departure and transit time.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedFreightCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Freight Cost' ;
    rdfs:comment 'The estimated total freight cost for this load plan based on carrier rates, distance, weight, and service level. Used for cost planning and budget tracking.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedTransitTimeHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Transit Time Hours' ;
    rdfs:comment 'The estimated total transit time from origin to destination in hours, used for delivery promise calculation and customer communication.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:freightCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the estimated freight cost, supporting multi-currency logistics operations.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadOptimizationMethod rdf:type rdf:Property ;
    rdfs:label 'Load Optimization Method' ;
    rdfs:comment 'The method used to build and optimize this load plan, indicating the level of automation and sophistication in load planning.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadPlanNumber rdf:type rdf:Property ;
    rdfs:label 'Load Plan Number' ;
    rdfs:comment 'Business identifier for the load plan, externally visible and used for tracking and communication with carriers and warehouse teams.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Load Plan Status' ;
    rdfs:comment 'Current lifecycle status of the load plan indicating its progression through planning, execution, and completion stages.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Load Sequence Number' ;
    rdfs:comment 'The sequential order in which this load plan is scheduled within a batch of loads for the same route or time window, used for dock scheduling.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loadingEndTime rdf:type rdf:Property ;
    rdfs:label 'Loading End Time' ;
    rdfs:comment 'The scheduled or actual timestamp when loading operations were completed for this load plan, used for cycle time analysis and efficiency tracking.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loadingStartTime rdf:type rdf:Property ;
    rdfs:label 'Loading Start Time' ;
    rdfs:comment 'The scheduled or actual timestamp when loading operations began for this load plan, used for labor tracking and performance measurement.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:numberOfHandlingUnits rdf:type rdf:Property ;
    rdfs:label 'Number Of Handling Units' ;
    rdfs:comment 'The total count of handling units (cartons, crates, drums, etc.) included in this load plan, used for labor planning and tracking.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfPallets rdf:type rdf:Property ;
    rdfs:label 'Number Of Pallets' ;
    rdfs:comment 'The total count of pallets included in this load plan, used for loading sequence planning and warehouse space allocation.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfShipments rdf:type rdf:Property ;
    rdfs:label 'Number Of Shipments' ;
    rdfs:comment 'The count of individual shipment records consolidated into this load plan, used for LTL consolidation tracking and load complexity assessment.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Departure Timestamp' ;
    rdfs:comment 'The scheduled date and time when the loaded vehicle or container is planned to depart from the origin facility.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedLoadDate rdf:type rdf:Property ;
    rdfs:label 'Planned Load Date' ;
    rdfs:comment 'The scheduled date when the load is planned to be assembled and loaded onto the transport vehicle or container.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiresHazmatHandling rdf:type rdf:Property ;
    rdfs:label 'Requires Hazmat Handling' ;
    rdfs:comment 'Indicates whether this load contains hazardous materials requiring special handling, documentation, and certified carriers.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresTemperatureControl rdf:type rdf:Property ;
    rdfs:label 'Requires Temperature Control' ;
    rdfs:comment 'Indicates whether this load requires temperature-controlled transportation (refrigerated or heated) to maintain product integrity.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shipmentType rdf:type rdf:Property ;
    rdfs:label 'Shipment Type' ;
    rdfs:comment 'Classification of the shipment based on load size and carrier service type. LTL indicates consolidated shipments sharing vehicle space; FTL indicates exclusive use of vehicle capacity.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRangeMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max C' ;
    rdfs:comment 'The maximum acceptable temperature in Celsius for temperature-controlled loads, used for carrier selection and compliance monitoring.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min C' ;
    rdfs:comment 'The minimum acceptable temperature in Celsius for temperature-controlled loads, used for carrier selection and compliance monitoring.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPlannedVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Planned Volume M3' ;
    rdfs:comment 'The total planned volume of all shipments and materials consolidated into this load, measured in cubic meters, used for cube utilization optimization.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPlannedWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Planned Weight Kg' ;
    rdfs:comment 'The total planned weight of all shipments and materials consolidated into this load, measured in kilograms, used for capacity planning and compliance.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeUtilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Volume Utilization Percentage' ;
    rdfs:comment 'The percentage of vehicle or container volume capacity utilized by this load plan, calculated as (total planned volume / vehicle volume capacity) * 100. Also known as cube utilization.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightUtilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Weight Utilization Percentage' ;
    rdfs:comment 'The percentage of vehicle or container weight capacity utilized by this load plan, calculated as (total planned weight / vehicle weight capacity) * 100.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierAccessRestrictions rdf:type rdf:Property ;
    rdfs:label 'Carrier Access Restrictions' ;
    rdfs:comment 'Description of any carrier access restrictions or requirements (e.g., pre-registration, security clearance, appointment-only).' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactName rdf:type rdf:Property ;
    rdfs:label 'Contact Name' ;
    rdfs:comment 'Name of the primary contact person or site manager for the logistics node.' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockDoorCount rdf:type rdf:Property ;
    rdfs:label 'Dock Door Count' ;
    rdfs:comment 'Total number of loading/unloading dock doors available at the logistics node for capacity planning.' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:erpLocationCode rdf:type rdf:Property ;
    rdfs:label 'Erp Location Code' ;
    rdfs:comment 'Location code used in SAP S/4HANA or other ERP systems for material movement and inventory tracking.' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freeTradeZoneFlag rdf:type rdf:Property ;
    rdfs:label 'Free Trade Zone Flag' ;
    rdfs:comment 'Indicates whether the logistics node is located within a designated free trade zone or foreign trade zone.' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:handlingEquipmentAvailable rdf:type rdf:Property ;
    rdfs:label 'Handling Equipment Available' ;
    rdfs:comment 'Comma-separated list of material handling equipment types available at the node (e.g., forklift, crane, conveyor, automated_guided_vehicle).' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxVehicleLengthM rdf:type rdf:Property ;
    rdfs:label 'Max Vehicle Length M' ;
    rdfs:comment 'Maximum vehicle length in meters that can access the logistics node due to physical constraints (e.g., turning radius, gate clearance).' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxVehicleWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Vehicle Weight Kg' ;
    rdfs:comment 'Maximum gross vehicle weight in kilograms permitted at the logistics node due to road or dock weight limits.' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkTier rdf:type rdf:Property ;
    rdfs:label 'Network Tier' ;
    rdfs:comment 'Hierarchical tier classification of the node within the distribution network strategy for routing optimization.' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeCode rdf:type rdf:Property ;
    rdfs:label 'Node Code' ;
    rdfs:comment 'Business identifier code for the logistics node. Externally-known unique code used across TMS and ERP systems for network location identification.' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeName rdf:type rdf:Property ;
    rdfs:label 'Node Name' ;
    rdfs:comment 'Human-readable name of the logistics node (e.g., \'Chicago Distribution Center\', \'Port of Hamburg Entry Point\').' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeStatus rdf:type rdf:Property ;
    rdfs:label 'Node Status' ;
    rdfs:comment 'Current operational status of the logistics node in the distribution network lifecycle.' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeType rdf:type rdf:Property ;
    rdfs:label 'Node Type' ;
    rdfs:comment 'Classification of the logistics node indicating its primary function in the distribution network. [ENUM-REF-CANDIDATE: manufacturing_plant|distribution_center|cross_dock|port_of_entry|customs_warehouse|customer_site|supplier_site — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursWeekday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekday' ;
    rdfs:comment 'Standard operating hours for weekdays in format HH:MM-HH:MM (e.g., 08:00-17:00) for delivery window planning.' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursWeekend rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekend' ;
    rdfs:comment 'Standard operating hours for weekends in format HH:MM-HH:MM. Null if node does not operate on weekends.' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Port Access Flag' ;
    rdfs:comment 'Indicates whether the logistics node has direct access to maritime port facilities for ocean freight.' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:railAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Rail Access Flag' ;
    rdfs:comment 'Indicates whether the logistics node has direct rail siding access for intermodal freight operations.' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageCapacitySqm rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Sqm' ;
    rdfs:comment 'Total indoor storage capacity in square meters for inventory planning and network optimization.' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tmsLocationCode rdf:type rdf:Property ;
    rdfs:label 'Tms Location Code' ;
    rdfs:comment 'External identifier used by the Transportation Management System to reference this logistics node.' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yardCapacityTrailers rdf:type rdf:Property ;
    rdfs:label 'Yard Capacity Trailers' ;
    rdfs:comment 'Maximum number of trailers that can be staged in the yard simultaneously for yard management and detention planning.' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originNodeId rdf:type rdf:Property ;
    rdfs:label 'Origin Node Id' ;
    rdfs:comment 'Foreign key linking to logistics.node. Business justification: Replace raw origin address fields with a foreign key to node, enabling reuse of node master data.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Node .

ind:supplyPlanId rdf:type rdf:Property ;
    rdfs:label 'Supply Plan Id' ;
    rdfs:comment 'Foreign key linking to supply.plan. Business justification: Shipment creation is driven by an approved supply plan; linking enables the \'Supply Plan to Shipment\' execution traceability report.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:commercialInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Commercial Invoice Number' ;
    rdfs:comment 'Invoice number associated with the shipment for customs and billing purposes.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationGroupCode rdf:type rdf:Property ;
    rdfs:label 'Consolidation Group Code' ;
    rdfs:comment 'Identifier for the consolidation group used in load planning. Multiple shipments with the same consolidation group may be combined into a single load.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Destination Address Line1' ;
    rdfs:comment 'First line of the street address for the destination location.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCity rdf:type rdf:Property ;
    rdfs:label 'Destination City' ;
    rdfs:comment 'City name of the destination location.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the destination location (e.g., USA, DEU, CHN).' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationLocationCode rdf:type rdf:Property ;
    rdfs:label 'Destination Location Code' ;
    rdfs:comment 'Code identifying the destination location (customer site, distribution center, plant) where the shipment is delivered.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationLocationName rdf:type rdf:Property ;
    rdfs:label 'Destination Location Name' ;
    rdfs:comment 'Human-readable name of the destination location.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPostalCode rdf:type rdf:Property ;
    rdfs:label 'Destination Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the destination location.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationStateProvince rdf:type rdf:Property ;
    rdfs:label 'Destination State Province' ;
    rdfs:comment 'State or province of the destination location.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:direction rdf:type rdf:Property ;
    rdfs:label 'Direction' ;
    rdfs:comment 'Indicates whether the shipment is inbound (supplier to plant) or outbound (plant to customer or distribution center).' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceValueAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Value Amount' ;
    rdfs:comment 'Declared value of the shipment for insurance purposes. Used to determine coverage limits and premiums.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceValueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Insurance Value Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the insurance value amount.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Date' ;
    rdfs:comment 'Planned date when the shipment is scheduled to be delivered to the destination location.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledPickupDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Pickup Date' ;
    rdfs:comment 'Planned date when the carrier is scheduled to pick up the shipment from the origin location.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle status of the shipment: planned (not yet tendered), tendered (assigned to carrier), in-transit (en route), delivered (completed), exception (issue occurred), cancelled (voided).' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Max Celsius' ;
    rdfs:comment 'Maximum allowable temperature in Celsius for temperature-controlled shipments. Populated only if temperature_controlled_flag is true.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Min Celsius' ;
    rdfs:comment 'Minimum allowable temperature in Celsius for temperature-controlled shipments. Populated only if temperature_controlled_flag is true.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tmsReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Tms Reference Number' ;
    rdfs:comment 'Reference number assigned by the Transportation Management System for internal tracking and integration.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Weight Kg' ;
    rdfs:comment 'Total gross weight of the shipment in kilograms, including packaging and pallets.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipmentLegId rdf:type rdf:Property ;
    rdfs:label 'Shipment Leg Id' ;
    rdfs:comment 'Unique identifier for the shipment leg. Primary key for this entity representing a single transport segment within a multi-leg shipment journey.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationLocationNodeId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Node Id' ;
    rdfs:comment 'FK to logistics.logistics_node' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Node .

ind:operatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Operator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Leg Handling Accountability records the employee operating the vehicle or equipment for each leg, required for safety incident investigations.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:originLocationLogisticsNodeId rdf:type rdf:Property ;
    rdfs:label 'Origin Location Logistics Node Id' ;
    rdfs:comment 'FK to logistics.logistics_node' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Node .

ind:primaryShipmentNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Shipment Node Id' ;
    rdfs:comment 'Identifier of the departure location for this leg. May reference a warehouse, plant, distribution center, cross-dock facility, or transshipment hub.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Node .

ind:tertiaryShipmentTransferPointLocationNodeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Shipment Transfer Point Location Node Id' ;
    rdfs:comment 'FK to logistics.logistics_node' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Node .

ind:actualArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Timestamp' ;
    rdfs:comment 'Actual date and time when the carrier arrived at the destination location. Captured from TMS or carrier proof-of-delivery systems.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Timestamp' ;
    rdfs:comment 'Actual date and time when the carrier departed from the origin location. Captured from Transportation Management System (TMS) or carrier tracking systems.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:delayDurationHours rdf:type rdf:Property ;
    rdfs:label 'Delay Duration Hours' ;
    rdfs:comment 'Total duration of delay in hours, calculated as the difference between scheduled and actual arrival timestamps when a delay occurs.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:delayReasonCode rdf:type rdf:Property ;
    rdfs:label 'Delay Reason Code' ;
    rdfs:comment 'Standardized code indicating the primary cause of delay if the leg did not meet scheduled arrival time. Supports root cause analysis and carrier performance evaluation. [ENUM-REF-CANDIDATE: weather|traffic|mechanical|customs|loading|driver|accident|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Equipment Number' ;
    rdfs:comment 'Identifier of the specific equipment unit (truck, trailer, container, railcar) used for this leg. Enables asset tracking and utilization analysis.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Amount' ;
    rdfs:comment 'Additional fuel surcharge applied by the carrier for this leg. Typically calculated as a percentage of base freight cost and varies with fuel prices.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCrossDock rdf:type rdf:Property ;
    rdfs:label 'Is Cross Dock' ;
    rdfs:comment 'Boolean flag indicating whether this leg involves a cross-docking operation where goods are transferred directly from inbound to outbound transport without warehousing.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTransshipment rdf:type rdf:Property ;
    rdfs:label 'Is Transshipment' ;
    rdfs:comment 'Boolean flag indicating whether this leg involves transshipment where goods are transferred between different carriers or transport modes at an intermediate hub.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Leg Distance Km' ;
    rdfs:comment 'Total distance traveled for this leg measured in kilometers. Used for route optimization, cost calculation, and carbon footprint analysis.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legDistanceMiles rdf:type rdf:Property ;
    rdfs:label 'Leg Distance Miles' ;
    rdfs:comment 'Total distance traveled for this leg measured in miles. Provided for regions using imperial measurement systems.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legFreightCost rdf:type rdf:Property ;
    rdfs:label 'Leg Freight Cost' ;
    rdfs:comment 'Total freight cost charged by the carrier for this specific leg. Supports leg-level cost allocation and profitability analysis.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legFreightCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Leg Freight Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the leg freight cost (e.g., USD, EUR, CNY).' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Leg Sequence Number' ;
    rdfs:comment 'Sequential order of this leg within the parent shipment journey. Indicates the position in the multi-leg routing plan (1 for first leg, 2 for second, etc.).' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:legStatus rdf:type rdf:Property ;
    rdfs:label 'Leg Status' ;
    rdfs:comment 'Current operational status of this transport leg in its lifecycle. Tracks progression from planning through execution to completion. [ENUM-REF-CANDIDATE: planned|scheduled|in_transit|arrived|completed|cancelled|delayed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeOptimizationScore rdf:type rdf:Property ;
    rdfs:label 'Route Optimization Score' ;
    rdfs:comment 'Calculated score representing the efficiency of this leg routing based on distance, cost, transit time, and service level. Used for continuous improvement analysis.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival Timestamp' ;
    rdfs:comment 'Planned date and time when the carrier is scheduled to arrive at the destination location. Used for receiving planning and SLA commitments.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Departure Timestamp' ;
    rdfs:comment 'Planned date and time when the carrier is scheduled to depart from the origin location. Used for planning and Service Level Agreement (SLA) tracking.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transitTimeHours rdf:type rdf:Property ;
    rdfs:label 'Transit Time Hours' ;
    rdfs:comment 'Planned or actual duration of this leg measured in hours. Calculated as the difference between departure and arrival timestamps.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipmentTrackingEventId rdf:type rdf:Property ;
    rdfs:label 'Shipment Tracking Event Id' ;
    rdfs:comment 'Unique identifier for the shipment tracking event record.' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierStatusCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Status Code' ;
    rdfs:comment 'Carrier-specific status code reported for this event (e.g., X1, D1, AF, etc.).' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierStatusDescription rdf:type rdf:Property ;
    rdfs:label 'Carrier Status Description' ;
    rdfs:comment 'Human-readable description of the carrier status code.' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerNumber rdf:type rdf:Property ;
    rdfs:label 'Container Number' ;
    rdfs:comment 'ISO container number for ocean or intermodal shipments.' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsClearanceFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Flag' ;
    rdfs:comment 'Indicates whether the event represents a customs clearance checkpoint for international shipments.' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataReceivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Data Received Timestamp' ;
    rdfs:comment 'Timestamp when the tracking event data was received by the Transportation Management System (TMS) or data platform.' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedDeliveryTime rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Time' ;
    rdfs:comment 'Updated estimated delivery timestamp with time precision if available from carrier.' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventCity rdf:type rdf:Property ;
    rdfs:label 'Event City' ;
    rdfs:comment 'City where the tracking event occurred.' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventCountryCode rdf:type rdf:Property ;
    rdfs:label 'Event Country Code' ;
    rdfs:comment 'Three-letter ISO country code where the tracking event occurred.' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventLatitude rdf:type rdf:Property ;
    rdfs:label 'Event Latitude' ;
    rdfs:comment 'GPS latitude coordinate of the event location.' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventLocationName rdf:type rdf:Property ;
    rdfs:label 'Event Location Name' ;
    rdfs:comment 'Name of the facility, terminal, or location where the event occurred.' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventLongitude rdf:type rdf:Property ;
    rdfs:label 'Event Longitude' ;
    rdfs:comment 'GPS longitude coordinate of the event location.' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventNotes rdf:type rdf:Property ;
    rdfs:label 'Event Notes' ;
    rdfs:comment 'Free-text notes or comments provided by the carrier or logistics personnel regarding the event.' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventPostalCode rdf:type rdf:Property ;
    rdfs:label 'Event Postal Code' ;
    rdfs:comment 'Postal code of the location where the tracking event occurred.' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Event Sequence Number' ;
    rdfs:comment 'Sequential order of this event within the shipment lifecycle.' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventStateProvince rdf:type rdf:Property ;
    rdfs:label 'Event State Province' ;
    rdfs:comment 'State or province where the tracking event occurred.' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Exception Reason Code' ;
    rdfs:comment 'Code indicating the reason for an exception or delay event (e.g., weather, customs hold, address issue).' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Exception Reason Description' ;
    rdfs:comment 'Detailed description of the exception or delay reason.' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humidityReading rdf:type rdf:Property ;
    rdfs:label 'Humidity Reading' ;
    rdfs:comment 'Humidity percentage reading captured at the time of the event for sensitive shipments.' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onTimeFlag rdf:type rdf:Property ;
    rdfs:label 'On Time Flag' ;
    rdfs:comment 'Indicates whether the event occurred within the expected time window per the Service Level Agreement (SLA).' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recipientName rdf:type rdf:Property ;
    rdfs:label 'Recipient Name' ;
    rdfs:comment 'Name of the person who received the shipment (for delivered events).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureObtainedFlag rdf:type rdf:Property ;
    rdfs:label 'Signature Obtained Flag' ;
    rdfs:comment 'Indicates whether a signature was obtained at delivery.' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Signature Required Flag' ;
    rdfs:comment 'Indicates whether a signature was required for delivery.' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureReading rdf:type rdf:Property ;
    rdfs:label 'Temperature Reading' ;
    rdfs:comment 'Temperature reading captured at the time of the event for temperature-controlled shipments (in Celsius).' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeComplianceRecordId rdf:type rdf:Property ;
    rdfs:label 'Trade Compliance Record Id' ;
    rdfs:comment 'Unique identifier for the trade compliance record. Primary key for this entity.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditTrail rdf:type rdf:Property ;
    rdfs:label 'Audit Trail' ;
    rdfs:comment 'Comprehensive audit trail capturing all actions, decisions, and system interactions related to this compliance check. Supports regulatory audit and internal compliance reviews.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkDate rdf:type rdf:Property ;
    rdfs:label 'Check Date' ;
    rdfs:comment 'Date when the trade compliance check was performed. Principal business event timestamp for the screening activity.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:checkStatus rdf:type rdf:Property ;
    rdfs:label 'Check Status' ;
    rdfs:comment 'Current lifecycle status of the compliance check. Indicates the state of the screening process and whether the shipment can proceed. [ENUM-REF-CANDIDATE: pending|in_progress|cleared|flagged|blocked|escalated|resolved — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkTimestamp rdf:type rdf:Property ;
    rdfs:label 'Check Timestamp' ;
    rdfs:comment 'Precise date and time when the compliance screening was initiated. Provides exact timing for audit trail and regulatory reporting.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:checkType rdf:type rdf:Property ;
    rdfs:label 'Check Type' ;
    rdfs:comment 'Type of trade compliance check performed. Categorizes the nature of the screening activity conducted on the shipment.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCheckNumber rdf:type rdf:Property ;
    rdfs:label 'Compliance Check Number' ;
    rdfs:comment 'Business identifier for the trade compliance check. Externally-known reference number used for tracking and audit purposes.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceOfficerName rdf:type rdf:Property ;
    rdfs:label 'Compliance Officer Name' ;
    rdfs:comment 'Name of the compliance officer responsible for this trade compliance check. Provides accountability and audit trail.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBrokerName rdf:type rdf:Property ;
    rdfs:label 'Customs Broker Name' ;
    rdfs:comment 'Name of the customs broker or freight forwarder assisting with trade compliance and export documentation.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deniedPartyListName rdf:type rdf:Property ;
    rdfs:label 'Denied Party List Name' ;
    rdfs:comment 'Name of the denied party or restricted entity list where a match was found. Examples include OFAC SDN, BIS Entity List, EU Consolidated List.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deniedPartyMatchFlag rdf:type rdf:Property ;
    rdfs:label 'Denied Party Match Flag' ;
    rdfs:comment 'Indicates whether the end user, consignee, or any party in the transaction matched a denied party list or restricted entity list.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentationCompleteFlag rdf:type rdf:Property ;
    rdfs:label 'Documentation Complete Flag' ;
    rdfs:comment 'Indicates whether all required export control documentation, licenses, and certificates have been obtained and are complete.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dualUseFlag rdf:type rdf:Property ;
    rdfs:label 'Dual Use Flag' ;
    rdfs:comment 'Indicates whether the goods are classified as dual-use items that have both civilian and military applications, requiring special export controls.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:embargoFlag rdf:type rdf:Property ;
    rdfs:label 'Embargo Flag' ;
    rdfs:comment 'Indicates whether the destination country or end user is subject to a trade embargo or comprehensive sanctions program.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endUserName rdf:type rdf:Property ;
    rdfs:label 'End User Name' ;
    rdfs:comment 'Name of the ultimate end user or consignee of the goods. Subject to denied party screening and restricted entity checks.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endUserType rdf:type rdf:Property ;
    rdfs:label 'End User Type' ;
    rdfs:comment 'Classification of the end user entity type. Certain user types may trigger additional scrutiny or licensing requirements.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Required Flag' ;
    rdfs:comment 'Indicates whether the compliance issue requires escalation to senior management, legal counsel, or external trade compliance advisors.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'License Expiration Date' ;
    rdfs:comment 'Date when the export license expires. Shipments must be completed before this date to remain compliant.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'Official license number issued by the export control authority. Unique identifier for the export authorization granted.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'License Required Flag' ;
    rdfs:comment 'Indicates whether an export license is required for this shipment based on the compliance screening results.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:militaryEndUseFlag rdf:type rdf:Property ;
    rdfs:label 'Military End Use Flag' ;
    rdfs:comment 'Indicates whether the goods are intended for military end use, which may trigger additional licensing requirements or restrictions.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordCreatedBy rdf:type rdf:Property ;
    rdfs:label 'Record Created By' ;
    rdfs:comment 'User ID or system identifier of the person or process that created this compliance record. Provides accountability for data entry.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Record Updated By' ;
    rdfs:comment 'User ID or system identifier of the person or process that last updated this compliance record. Tracks modification responsibility.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleBNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule B Number' ;
    rdfs:comment '10-digit Schedule B classification number for export statistics. Used by U.S. Census Bureau for tracking exports.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningResult rdf:type rdf:Property ;
    rdfs:label 'Screening Result' ;
    rdfs:comment 'Outcome of the compliance screening process. Indicates whether the shipment passed, failed, or requires additional review or licensing.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningSystem rdf:type rdf:Property ;
    rdfs:label 'Screening System' ;
    rdfs:comment 'Name or identifier of the automated screening system or tool used to perform the compliance check. Examples include TMS, customs broker system, or dedicated trade compliance software.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCarrierId rdf:type rdf:Property ;
    rdfs:label 'Preferred Carrier Id' ;
    rdfs:comment 'FK to logistics.carrier' ;
    rdfs:domain ind:TransportRoute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:alternateCarrierCodes rdf:type rdf:Property ;
    rdfs:label 'Alternate Carrier Codes' ;
    rdfs:comment 'Comma-separated list of alternate carrier codes that can be used for this route if the preferred carrier is unavailable or for load balancing.' ;
    rdfs:domain ind:TransportRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonEmissionFactorKgPerKm rdf:type rdf:Property ;
    rdfs:label 'Carbon Emission Factor Kg Per Km' ;
    rdfs:comment 'Average carbon dioxide equivalent emissions per kilometer for this route, used for sustainability reporting and carbon footprint calculation.' ;
    rdfs:domain ind:TransportRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerKm rdf:type rdf:Property ;
    rdfs:label 'Cost Per Km' ;
    rdfs:comment 'Average freight cost per kilometer for this route, used for variable cost modeling and route comparison.' ;
    rdfs:domain ind:TransportRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Required' ;
    rdfs:comment 'Indicates whether customs clearance is required for this route (typically true for cross-border international routes).' ;
    rdfs:domain ind:TransportRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fuelSurchargeApplicable rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Applicable' ;
    rdfs:comment 'Indicates whether a fuel surcharge is applicable to shipments on this route, based on carrier contract terms.' ;
    rdfs:domain ind:TransportRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatApproved rdf:type rdf:Property ;
    rdfs:label 'Hazmat Approved' ;
    rdfs:comment 'Indicates whether this route is approved for transporting hazardous materials, based on carrier certification and regulatory compliance.' ;
    rdfs:domain ind:TransportRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumTransitTimeDays rdf:type rdf:Property ;
    rdfs:label 'Maximum Transit Time Days' ;
    rdfs:comment 'Maximum expected transit time in days, accounting for delays and worst-case scenarios, used for safety stock and buffer planning.' ;
    rdfs:domain ind:TransportRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumTransitTimeDays rdf:type rdf:Property ;
    rdfs:label 'Minimum Transit Time Days' ;
    rdfs:comment 'Minimum achievable transit time in days for expedited or express service on this route.' ;
    rdfs:domain ind:TransportRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optimizationPriority rdf:type rdf:Property ;
    rdfs:label 'Optimization Priority' ;
    rdfs:comment 'Primary optimization objective for route selection: cost (lowest freight cost), speed (fastest transit), reliability (on-time performance), sustainability (lowest carbon footprint), or balanced (multi-objective).' ;
    rdfs:domain ind:TransportRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originLocationCode rdf:type rdf:Property ;
    rdfs:label 'Origin Location Code' ;
    rdfs:comment 'Code identifying the origin node (plant, distribution center, supplier facility, or port) where the shipment begins. Aligns with internal location master or UN/LOCODE for ports.' ;
    rdfs:domain ind:TransportRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originLocationName rdf:type rdf:Property ;
    rdfs:label 'Origin Location Name' ;
    rdfs:comment 'Human-readable name of the origin location for reporting and operational visibility.' ;
    rdfs:domain ind:TransportRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryTransportMode rdf:type rdf:Property ;
    rdfs:label 'Primary Transport Mode' ;
    rdfs:comment 'Primary mode of transportation used for this route: road (truck), rail, air (cargo flight), ocean (container ship), inland waterway (barge), or pipeline.' ;
    rdfs:domain ind:TransportRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeCapacityConstraint rdf:type rdf:Property ;
    rdfs:label 'Route Capacity Constraint' ;
    rdfs:comment 'Description of any capacity constraints on this route (e.g., weight limits, volume limits, frequency limits, carrier capacity).' ;
    rdfs:domain ind:TransportRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeName rdf:type rdf:Property ;
    rdfs:label 'Route Name' ;
    rdfs:comment 'Descriptive name of the transport route, typically including origin and destination for human readability.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeNotes rdf:type rdf:Property ;
    rdfs:label 'Route Notes' ;
    rdfs:comment 'Free-text field for additional operational notes, special instructions, or considerations for this route.' ;
    rdfs:domain ind:TransportRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeStatus rdf:type rdf:Property ;
    rdfs:label 'Route Status' ;
    rdfs:comment 'Current operational status of the transport route in the network.' ;
    rdfs:domain ind:TransportRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeType rdf:type rdf:Property ;
    rdfs:label 'Route Type' ;
    rdfs:comment 'Classification of the route based on transportation strategy: direct (point-to-point), relay (driver handoff), intermodal (multiple transport modes), milk run (multi-stop collection/delivery), cross-dock (consolidation hub), or backhaul (return leg optimization).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalRestrictionDetails rdf:type rdf:Property ;
    rdfs:label 'Seasonal Restriction Details' ;
    rdfs:comment 'Detailed description of seasonal restrictions, including affected months, reasons, and alternative routing recommendations.' ;
    rdfs:domain ind:TransportRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Restriction Flag' ;
    rdfs:comment 'Indicates whether this route has seasonal restrictions (e.g., winter road closures, monsoon disruptions, peak season capacity limits).' ;
    rdfs:domain ind:TransportRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:secondaryTransportMode rdf:type rdf:Property ;
    rdfs:label 'Secondary Transport Mode' ;
    rdfs:comment 'Secondary or alternate mode of transportation for intermodal routes, if applicable.' ;
    rdfs:domain ind:TransportRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardFreightCost rdf:type rdf:Property ;
    rdfs:label 'Standard Freight Cost' ;
    rdfs:comment 'Standard or baseline freight cost for this route in the company\'s reporting currency, used for budgeting and cost estimation.' ;
    rdfs:domain ind:TransportRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardTransitTimeDays rdf:type rdf:Property ;
    rdfs:label 'Standard Transit Time Days' ;
    rdfs:comment 'Expected transit time in days for shipments on this route under normal conditions, used for delivery promise calculation and planning.' ;
    rdfs:domain ind:TransportRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blanketOrderId rdf:type rdf:Property ;
    rdfs:label 'Blanket Order Id' ;
    rdfs:comment 'System-generated unique identifier for the blanket order.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BlanketOrder .

ind:agreementDescription rdf:type rdf:Property ;
    rdfs:label 'Agreement Description' ;
    rdfs:comment 'Free-text description providing context or special notes about the blanket order.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blanketOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Blanket Order Status' ;
    rdfs:comment 'Current lifecycle state of the blanket order.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatusReason rdf:type rdf:Property ;
    rdfs:label 'Contract Status Reason' ;
    rdfs:comment 'Free-text explanation for the current status of the agreement.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeReleasedQuantity rdf:type rdf:Property ;
    rdfs:label 'Cumulative Released Quantity' ;
    rdfs:comment 'Total quantity that has been released to the customer to date.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeReleasedValue rdf:type rdf:Property ;
    rdfs:label 'Cumulative Released Value' ;
    rdfs:comment 'Monetary value of all released quantities to date.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionChannel rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel' ;
    rdfs:comment 'Channel through which the products will be delivered (e.g., wholesale, direct).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isJitEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Jit Enabled' ;
    rdfs:comment 'Indicates whether the agreement supports JIT delivery scheduling.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Last Release Date' ;
    rdfs:comment 'Date of the most recent call-off release.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumOrderUom rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Uom' ;
    rdfs:comment 'Unit of measure for the minimum order quantity.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReleaseDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Release Due Date' ;
    rdfs:comment 'Planned date for the next scheduled release based on the release frequency.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pricingConditions rdf:type rdf:Property ;
    rdfs:label 'Pricing Conditions' ;
    rdfs:comment 'Textual description of pricing terms, discounts, and rebates applicable to the agreement.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityUom rdf:type rdf:Property ;
    rdfs:label 'Quantity Uom' ;
    rdfs:comment 'Unit of measure for the committed quantity (e.g., each, kilogram).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseFrequency rdf:type rdf:Property ;
    rdfs:label 'Release Frequency' ;
    rdfs:comment 'Scheduled interval at which the customer may release call-offs against the blanket order.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrganization rdf:type rdf:Property ;
    rdfs:label 'Sales Organization' ;
    rdfs:comment 'Organizational unit responsible for the sales side of the agreement.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCommittedQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Committed Quantity' ;
    rdfs:comment 'Aggregate quantity of product(s) the customer has committed to purchase over the agreement period.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCommittedValue rdf:type rdf:Property ;
    rdfs:label 'Total Committed Value' ;
    rdfs:comment 'Monetary value of the total committed quantity at the agreed pricing.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blanketOrderReleaseId rdf:type rdf:Property ;
    rdfs:label 'Blanket Order Release Id' ;
    rdfs:comment 'System-generated unique identifier for the blanket order release record.' ;
    rdfs:domain ind:BlanketOrderRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blanketOrderReleaseStatus rdf:type rdf:Property ;
    rdfs:label 'Blanket Order Release Status' ;
    rdfs:comment 'Current lifecycle status of the release.' ;
    rdfs:domain ind:BlanketOrderRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseNumber rdf:type rdf:Property ;
    rdfs:label 'Release Number' ;
    rdfs:comment 'Sequential number of the release within the blanket order, used for ordering and tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Delivery Customer Account Id' ;
    rdfs:comment 'Identifier of the customer who placed the original sales order.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:deliveryEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Delivery Employee Id' ;
    rdfs:comment 'Identifier of the system user who created the delivery record.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:deliveryShipToPartyCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Delivery Ship To Party Customer Account Id' ;
    rdfs:comment 'Identifier of the party to which the goods are shipped.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:deliveryUpdatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Delivery Updated By User Employee Id' ;
    rdfs:comment 'Identifier of the system user who last modified the delivery record.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualGoodsIssueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Goods Issue Timestamp' ;
    rdfs:comment 'Timestamp when goods were actually issued from the warehouse.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:carrierCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Code' ;
    rdfs:comment 'Code of the logistics carrier responsible for transportation.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Number' ;
    rdfs:comment 'External delivery document number assigned by SAP for tracking and communication.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryState rdf:type rdf:Property ;
    rdfs:label 'Delivery State' ;
    rdfs:comment 'State or province component of the delivery destination address.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryType rdf:type rdf:Property ;
    rdfs:label 'Delivery Type' ;
    rdfs:comment 'Classification of the delivery, e.g., stock shipment, return, consignment.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Tax Amount' ;
    rdfs:comment 'Tax component applied to the freight cost.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Total Amount' ;
    rdfs:comment 'Total freight charge including taxes and surcharges.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Handling Instructions' ;
    rdfs:comment 'Special handling notes for the carrier (e.g., fragile, keep upright).' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBackorder rdf:type rdf:Property ;
    rdfs:label 'Is Backorder' ;
    rdfs:comment 'True when the delivery contains items that were previously on backorder.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
