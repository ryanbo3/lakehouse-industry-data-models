    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldUom rdf:type rdf:Property ;
    rdfs:label 'Yield Uom' ;
    rdfs:comment 'Unit of measure for yield quantities (e.g., kg, pcs).' ;
