    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentLocation rdf:type rdf:Property ;
    rdfs:label 'Incident Location' ;
    rdfs:comment 'Free-text description of the physical location where the incident occurred.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentNumber rdf:type rdf:Property ;
