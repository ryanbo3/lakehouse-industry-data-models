ind:termCode rdf:type rdf:Property ;
    rdfs:label 'Term Code' ;
    rdfs:comment 'Code representing the payment terms (e.g., NET30, EOM).' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allowedPaymentChannel rdf:type rdf:Property ;
    rdfs:label 'Allowed Payment Channel' ;
    rdfs:comment 'Channels through which payment can be made (e.g., online portal, mobile app).' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allowedPaymentMethod rdf:type rdf:Property ;
    rdfs:label 'Allowed Payment Method' ;
    rdfs:comment 'Payment instruments permitted under this term.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableInvoiceType rdf:type rdf:Property ;
    rdfs:label 'Applicable Invoice Type' ;
    rdfs:comment 'Invoice categories to which this payment term can be applied.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlyPaymentDiscountDays rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Days' ;
    rdfs:comment 'Number of days from invoice date during which the early-payment discount is available.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:earlyPaymentDiscountPercent rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Percent' ;
    rdfs:comment 'Percentage discount applied when payment is made within the early-payment window.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Grace Period Days' ;
    rdfs:comment 'Additional days after the net due date before penalties apply.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isDefault rdf:type rdf:Property ;
    rdfs:label 'Is Default' ;
    rdfs:comment 'Indicates whether this term is the default for new customers or contracts.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTaxExempt rdf:type rdf:Property ;
    rdfs:label 'Is Tax Exempt' ;
    rdfs:comment 'Indicates whether taxes are waived for transactions using this term.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Max Discount Amount' ;
    rdfs:comment 'Upper limit on the monetary value of any discount granted under this term.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Min Payment Amount' ;
    rdfs:comment 'Minimum amount that must be paid per invoice under this term.' ;
