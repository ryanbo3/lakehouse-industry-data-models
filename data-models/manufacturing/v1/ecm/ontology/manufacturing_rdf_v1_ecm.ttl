    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:immediateCorrectiveAction rdf:type rdf:Property ;
    rdfs:label 'Immediate Corrective Action' ;
    rdfs:comment 'Actions taken immediately after the incident to mitigate impact.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentDescription rdf:type rdf:Property ;
