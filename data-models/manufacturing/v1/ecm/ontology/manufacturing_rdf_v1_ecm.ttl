ind:standardSetupTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Standard Setup Time Minutes' ;
    rdfs:comment 'Standard setup or changeover time in minutes required to prepare the work center for a new production run.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
