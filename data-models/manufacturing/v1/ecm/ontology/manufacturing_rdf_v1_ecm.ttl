    rdfs:comment 'Date the regulatory report was filed.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportSubmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Submitted Flag' ;
    rdfs:comment 'True if the incident has been submitted to required regulators.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
