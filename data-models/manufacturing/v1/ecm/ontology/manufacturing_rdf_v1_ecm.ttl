    rdfs:comment 'Method used to resolve the dispute.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingScheduleId rdf:type rdf:Property ;
