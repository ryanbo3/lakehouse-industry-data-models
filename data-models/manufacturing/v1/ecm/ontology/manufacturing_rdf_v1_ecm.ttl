    rdfs:comment 'Lifecycle status of the incident investigation.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRepeatIncident rdf:type rdf:Property ;
