    rdfs:range ind:ProductionWorkOrder .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'Elapsed time the controller remained in the new mode before the next change.' ;
