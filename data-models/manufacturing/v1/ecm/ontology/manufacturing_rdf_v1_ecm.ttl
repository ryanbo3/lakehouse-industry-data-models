ind:opportunityId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Id' ;
    rdfs:comment 'Foreign key linking to sales.opportunity. Business justification: Revenue recognition ties invoices back to the originating sales opportunity for financial reporting and pipeline analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:orderIntakeId rdf:type rdf:Property ;
    rdfs:label 'Order Intake Id' ;
    rdfs:comment 'Foreign key linking to sales.order_intake. Business justification: Order-to-cash process maps each invoice to its originating order intake record for fulfillment and billing reconciliation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderIntake .

ind:permitId rdf:type rdf:Property ;
    rdfs:label 'Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: Permit fees are invoiced; linking invoice to the permit records enables compliance audit of fee collection.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:quoteId rdf:type rdf:Property ;
    rdfs:label 'Quote Id' ;
    rdfs:comment 'Foreign key linking to sales.quote. Business justification: Audit trail requires linking each invoice to the quote that defined pricing and terms after quote acceptance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Quote .

ind:regulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_filing. Business justification: Filing fees are billed; the invoice must point to the specific regulatory filing it settles.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFiling .

ind:salesRepId rdf:type rdf:Property ;
    rdfs:label 'Sales Rep Id' ;
    rdfs:comment 'Foreign key linking to sales.rep. Business justification: Commission reports need each invoice linked to the sales rep who closed the deal; essential for performance and payout calculations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:warehouseId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Id' ;
    rdfs:comment 'Foreign key linking to inventory.warehouse. Business justification: Warehouse of origin is required for logistics cost allocation, export reporting, and inventory valuation per invoice.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Warehouse .

ind:wasteRecordId rdf:type rdf:Property ;
    rdfs:label 'Waste Record Id' ;
    rdfs:comment 'Foreign key linking to compliance.waste_record. Business justification: Waste disposal services are billed; the invoice must reference the waste record for regulatory reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteRecord .

ind:billingCountry rdf:type rdf:Property ;
    rdfs:label 'Billing Country' ;
    rdfs:comment 'Three-letter country code of the billing address.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Billing Period End' ;
    rdfs:comment 'End date of the billing period covered by the invoice.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start' ;
    rdfs:comment 'Start date of the billing period covered by the invoice.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:collectionStatus rdf:type rdf:Property ;
    rdfs:label 'Collection Status' ;
    rdfs:comment 'Current status of the collection process for overdue invoices.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountRate rdf:type rdf:Property ;
    rdfs:label 'Discount Rate' ;
    rdfs:comment 'Discount rate applied to the invoice before tax.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total amount before taxes, discounts, and adjustments.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the invoice document.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSelfBilling rdf:type rdf:Property ;
    rdfs:label 'Is Self Billing' ;
    rdfs:comment 'True if the invoice is generated by the supplier on behalf of the customer (self-billing).' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issue Timestamp' ;
    rdfs:comment 'Date and time when the invoice was issued.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:number rdf:type rdf:Property ;
    rdfs:label 'Number' ;
    rdfs:comment 'Official invoice number assigned by the billing system.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current status of the payment for this invoice.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'Code representing the payment terms applied to the invoice.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'Purchase order reference supplied by the customer.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Id' ;
    rdfs:comment 'Unique surrogate key for each invoice line record.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvoiceLine .

ind:billingCycleId rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle Id' ;
    rdfs:comment 'Identifier of the billing cycle to which this line belongs.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingCycle .

ind:capaId rdf:type rdf:Property ;
    rdfs:label 'Capa Id' ;
    rdfs:comment 'Foreign key linking to quality.capa. Business justification: CAPA Expense Billing – expenses for corrective actions are tracked on invoice lines for cost allocation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Capa .

ind:inspectionLotId rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Id' ;
    rdfs:comment 'Foreign key linking to quality.inspection_lot. Business justification: Inspection Service Billing – each inspection lot performed for a customer is charged as a line item on the invoice.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionLot .

ind:ncrId rdf:type rdf:Property ;
    rdfs:label 'Ncr Id' ;
    rdfs:comment 'Foreign key linking to quality.ncr. Business justification: NCR Cost Recovery – non-conformance handling costs are billed to the customer via a dedicated invoice line.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ncr .

ind:originalInvoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Original Invoice Line Id' ;
    rdfs:comment 'Reference to the original invoice line that this credit memo line reverses.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvoiceLine .

ind:productBundleId rdf:type rdf:Property ;
    rdfs:label 'Product Bundle Id' ;
    rdfs:comment 'Foreign key linking to product.bundle. Business justification: When a bundle is sold, the invoice line must point to the bundle definition for bundle pricing, warranty, and regulatory compliance reporting.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bundle .

ind:allocationAmount rdf:type rdf:Property ;
    rdfs:label 'Allocation Amount' ;
    rdfs:comment 'Monetary amount allocated to the cost center (derived from allocation_percent).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationPercent rdf:type rdf:Property ;
    rdfs:label 'Allocation Percent' ;
    rdfs:comment 'Percentage of the line amount allocated to the specified cost center.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deferredRevenueFlag rdf:type rdf:Property ;
    rdfs:label 'Deferred Revenue Flag' ;
    rdfs:comment 'Indicates whether the line amount is deferred revenue (true) or recognized immediately (false).' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discountPercent rdf:type rdf:Property ;
    rdfs:label 'Discount Percent' ;
    rdfs:comment 'Percentage discount applied to the line gross amount.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expenseAccount rdf:type rdf:Property ;
    rdfs:label 'Expense Account' ;
    rdfs:comment 'GL account used for any expense component associated with this line.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceLineDescription rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Description' ;
    rdfs:comment 'Free-text description of the product, service, or milestone billed.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBundleLine rdf:type rdf:Property ;
    rdfs:label 'Is Bundle Line' ;
    rdfs:comment 'True if this line is part of a product bundle.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCreditMemo rdf:type rdf:Property ;
    rdfs:label 'Is Credit Memo' ;
    rdfs:comment 'True if this line represents a credit memo (negative amount).' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRoyaltyLine rdf:type rdf:Property ;
    rdfs:label 'Is Royalty Line' ;
    rdfs:comment 'True if the line represents a royalty charge.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTaxIncluded rdf:type rdf:Property ;
    rdfs:label 'Is Tax Included' ;
    rdfs:comment 'Indicates whether the unit price already includes tax.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineAmount rdf:type rdf:Property ;
    rdfs:label 'Line Amount' ;
    rdfs:comment 'Total amount for the line before tax and discount (quantity × unit_price).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current processing status of the invoice line.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineType rdf:type rdf:Property ;
    rdfs:label 'Line Type' ;
    rdfs:comment 'Classification of the line content (product, service, project milestone, fee, or other charge).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectMilestoneCode rdf:type rdf:Property ;
    rdfs:label 'Project Milestone Code' ;
    rdfs:comment 'Identifier of the project milestone or phase associated with this line.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Amount of the product or service delivered (units, hours, meters, etc.).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueAccount rdf:type rdf:Property ;
    rdfs:label 'Revenue Account' ;
    rdfs:comment 'GL account used for revenue posting of this line.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Method' ;
    rdfs:comment 'Method used to recognize revenue for this line, per accounting standards.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyRatePercent rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Percent' ;
    rdfs:comment 'Royalty rate applied to the base amount, expressed as a percentage.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceEndDate rdf:type rdf:Property ;
    rdfs:label 'Service End Date' ;
    rdfs:comment 'End date of the service period covered by this line (if applicable).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceStartDate rdf:type rdf:Property ;
    rdfs:label 'Service Start Date' ;
    rdfs:comment 'Start date of the service period covered by this line (if applicable).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxRatePercent rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Percent' ;
    rdfs:comment 'Applicable tax rate expressed as a percentage.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'Price per single unit of the product or service before taxes and discounts.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uom rdf:type rdf:Property ;
    rdfs:label 'Uom' ;
    rdfs:comment 'Unit of measure for the quantity (e.g., each, kilogram, liter, meter, hour).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentId rdf:type rdf:Property ;
    rdfs:label 'Payment Id' ;
    rdfs:comment 'System-generated unique identifier for the payment transaction.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Processed By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Payment processing audit: regulatory and internal policies require tracking which employee processed each payment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:salesOrderIntakeId rdf:type rdf:Property ;
    rdfs:label 'Sales Order Intake Id' ;
    rdfs:comment 'Foreign key linking to sales.order_intake. Business justification: Advance or partial payments are tied to a specific order intake for accurate order financing and tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderIntake .

ind:allocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount' ;
    rdfs:comment 'Total amount of the payment that has been allocated to invoices.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Date' ;
    rdfs:comment 'Timestamp when the payment was allocated.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Status of the payment allocation to invoices.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationType rdf:type rdf:Property ;
    rdfs:label 'Allocation Type' ;
    rdfs:comment 'Nature of the allocation (full, partial, advance, on-account).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amountDiscount rdf:type rdf:Property ;
    rdfs:label 'Amount Discount' ;
    rdfs:comment 'Total discount applied to the payment.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountGross rdf:type rdf:Property ;
    rdfs:label 'Amount Gross' ;
    rdfs:comment 'Total amount before any discounts, taxes, or fees.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountNet rdf:type rdf:Property ;
    rdfs:label 'Amount Net' ;
    rdfs:comment 'Final amount after discounts, taxes, and fees.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'Name of the bank handling the payment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankValueDate rdf:type rdf:Property ;
    rdfs:label 'Bank Value Date' ;
    rdfs:comment 'Date on which the bank considers the funds available.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:batchCode rdf:type rdf:Property ;
    rdfs:label 'Batch Code' ;
    rdfs:comment 'Identifier of the batch that groups this payment with others for processing.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'Channel through which the payment was submitted.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'Reference number of the clearing document generated for the payment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingStatus rdf:type rdf:Property ;
    rdfs:label 'Clearing Status' ;
    rdfs:comment 'Current status of the payment clearing process.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountTaken rdf:type rdf:Property ;
    rdfs:label 'Discount Taken' ;
    rdfs:comment 'Monetary discount amount applied to the payment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earlyPaymentDiscountApplied rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Applied' ;
    rdfs:comment 'Indicates whether an early-payment discount was applied.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalReference rdf:type rdf:Property ;
    rdfs:label 'External Reference' ;
    rdfs:comment 'Reference identifier from external payment gateway or bank.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Amount' ;
    rdfs:comment 'Any processing fees associated with the payment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isReconciled rdf:type rdf:Property ;
    rdfs:label 'Is Reconciled' ;
    rdfs:comment 'Indicates whether the payment has been reconciled to invoices.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalCurrency rdf:type rdf:Property ;
    rdfs:label 'Original Currency' ;
    rdfs:comment 'Currency code of the original payment amount.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'Timestamp when the payment was received or recorded.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDescription rdf:type rdf:Property ;
    rdfs:label 'Payment Description' ;
    rdfs:comment 'Free-form description or notes about the payment.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Number' ;
    rdfs:comment 'Business-visible reference number assigned to the payment.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'Timestamp when the payment was reconciled.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:remittanceAdviceReference rdf:type rdf:Property ;
    rdfs:label 'Remittance Advice Reference' ;
    rdfs:comment 'Reference to the remittance advice supplied by the payer.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequence rdf:type rdf:Property ;
    rdfs:label 'Sequence' ;
    rdfs:comment 'Sequence number for multiple payments within a batch or settlement.' ;
    rdfs:domain ind:Manufacturing ;
