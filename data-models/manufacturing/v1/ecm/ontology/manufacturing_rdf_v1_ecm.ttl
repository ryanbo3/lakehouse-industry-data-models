    rdfs:comment 'Network address or identifier of the PLC controlling this work center, used for SCADA and MES integration.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaTagPrefix rdf:type rdf:Property ;
    rdfs:label 'Scada Tag Prefix' ;
    rdfs:comment 'SCADA tag prefix used to identify real-time data points from this work center in the process control system.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftSequenceId rdf:type rdf:Property ;
    rdfs:label 'Shift Sequence Id' ;
    rdfs:comment 'Reference to the shift sequence or shift calendar defining operating hours for this work center.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardProcessingTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Standard Processing Time Minutes' ;
    rdfs:comment 'Standard processing or cycle time in minutes per unit for operations performed at this work center.' ;
    rdfs:domain ind:WorkCenter ;
