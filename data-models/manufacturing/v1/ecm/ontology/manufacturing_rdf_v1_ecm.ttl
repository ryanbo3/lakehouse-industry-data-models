    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productionWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Production Work Order Id' ;
    rdfs:comment 'Reference to the production order linked to the event, when applicable.' ;
