    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advancePaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Advance Payment Status' ;
    rdfs:comment 'Current lifecycle status of the advance payment.' ;
    rdfs:domain ind:AdvancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advanceType rdf:type rdf:Property ;
    rdfs:label 'Advance Type' ;
    rdfs:comment 'Classification of the advance payment purpose.' ;
    rdfs:domain ind:AdvancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'Gross amount of the advance payment received.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
