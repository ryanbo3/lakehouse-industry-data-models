    rdfs:comment 'Final date by which all corrective actions must be closed.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionSummary rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Summary' ;
    rdfs:comment 'Brief description of the corrective actions to be taken.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentsAttached rdf:type rdf:Property ;
    rdfs:label 'Documents Attached' ;
    rdfs:comment 'True if supporting photos, reports, or certificates are attached to the record.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emergencyExitAccessible rdf:type rdf:Property ;
    rdfs:label 'Emergency Exit Accessible' ;
    rdfs:comment 'True if all emergency exits were clear and unobstructed.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fireExtinguisherChecked rdf:type rdf:Property ;
    rdfs:label 'Fire Extinguisher Checked' ;
    rdfs:comment 'Indicates whether fire extinguishers were inspected and found serviceable.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Date' ;
    rdfs:comment 'Planned date by which corrective actions must be completed.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Timestamp' ;
    rdfs:comment 'Date-time when the inspection was actually performed on the facility/area.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isLotoVerified rdf:type rdf:Property ;
    rdfs:label 'Is Loto Verified' ;
    rdfs:comment 'True if lock-out/tag-out procedures were verified during the inspection.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppeCompliance rdf:type rdf:Property ;
    rdfs:label 'Ppe Compliance' ;
    rdfs:comment 'Indicates whether required PPE was observed being used by personnel.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Safety Inspection Status' ;
    rdfs:comment 'Current lifecycle state of the inspection record.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyScore rdf:type rdf:Property ;
    rdfs:label 'Safety Score' ;
    rdfs:comment 'Composite safety performance metric for the inspected area.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalItemsChecked rdf:type rdf:Property ;
    rdfs:label 'Total Items Checked' ;
    rdfs:comment 'Number of individual checklist items evaluated during the inspection.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingDueDate rdf:type rdf:Property ;
    rdfs:label 'Training Due Date' ;
    rdfs:comment 'Target date by which required safety training must be completed.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingRequired rdf:type rdf:Property ;
    rdfs:label 'Training Required' ;
    rdfs:comment 'True if the inspection identified a need for additional safety training.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relatedProductLineProductFamilyId rdf:type rdf:Property ;
    rdfs:label 'Related Product Line Product Family Id' ;
    rdfs:comment 'Identifier of the product line associated with the waste.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Family .

ind:chainOfCustodyDocument rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Document' ;
    rdfs:comment 'Reference (URL or file name) to the chain-of-custody record.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalContractor rdf:type rdf:Property ;
    rdfs:label 'Disposal Contractor' ;
    rdfs:comment 'Licensed contractor responsible for waste disposal.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalSite rdf:type rdf:Property ;
    rdfs:label 'Disposal Site' ;
    rdfs:comment 'Name of the off-site location where waste was disposed.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalSiteAddress rdf:type rdf:Property ;
    rdfs:label 'Disposal Site Address' ;
    rdfs:comment 'Street address of the disposal site.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalSiteCity rdf:type rdf:Property ;
    rdfs:label 'Disposal Site City' ;
    rdfs:comment 'City of the disposal site.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalSiteCountry rdf:type rdf:Property ;
    rdfs:label 'Disposal Site Country' ;
    rdfs:comment 'Three-letter ISO country code of the disposal site.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalSiteState rdf:type rdf:Property ;
    rdfs:label 'Disposal Site State' ;
    rdfs:comment 'State or province of the disposal site.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalSiteZip rdf:type rdf:Property ;
    rdfs:label 'Disposal Site Zip' ;
    rdfs:comment 'Postal code of the disposal site.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaWasteCode rdf:type rdf:Property ;
    rdfs:label 'Epa Waste Code' ;
    rdfs:comment 'Four-character EPA hazardous waste code (RCRA).' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generationDate rdf:type rdf:Property ;
    rdfs:label 'Generation Date' ;
    rdfs:comment 'Date the waste was generated on site.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manifestNumber rdf:type rdf:Property ;
    rdfs:label 'Manifest Number' ;
    rdfs:comment 'EPA manifest number linking the waste to transportation documentation.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedFacilityCode rdf:type rdf:Property ;
    rdfs:label 'Related Facility Code' ;
    rdfs:comment 'Identifier of the facility where the waste was generated.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transportDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Transport Distance Km' ;
    rdfs:comment 'Distance traveled for waste transport, expressed in kilometers.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportEmissionKgCo2 rdf:type rdf:Property ;
    rdfs:label 'Transport Emission Kg Co2' ;
    rdfs:comment 'Estimated CO₂ emissions from waste transport, in kilograms.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportMode rdf:type rdf:Property ;
    rdfs:label 'Transport Mode' ;
    rdfs:comment 'Mode of transportation used to move waste to the disposal site.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteCategory rdf:type rdf:Property ;
    rdfs:label 'Waste Category' ;
    rdfs:comment 'High-level category describing the waste material.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteIdentifier rdf:type rdf:Property ;
    rdfs:label 'Waste Identifier' ;
    rdfs:comment 'Business identifier such as a manifest or tracking number assigned to the waste event.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteOrigin rdf:type rdf:Property ;
    rdfs:label 'Waste Origin' ;
    rdfs:comment 'Business process that generated the waste.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Waste Record Status' ;
    rdfs:comment 'Current lifecycle status of the waste record.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteType rdf:type rdf:Property ;
    rdfs:label 'Waste Type' ;
    rdfs:comment 'Classification of waste by regulatory definition.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Account Hierarchy Id' ;
    rdfs:comment 'Unique surrogate identifier for each parent-child account hierarchy relationship record in the Salesforce CRM account hierarchy model. Serves as the primary key for this Silver Layer data product.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:childAccountCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Child Account Customer Account Id' ;
    rdfs:comment 'Identifier of the child account in the corporate hierarchy relationship. References the subsidiary, division, affiliate, or joint venture that reports up to the parent account.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:primaryCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Customer Account Id' ;
    rdfs:comment 'Identifier of the parent account in the corporate hierarchy relationship. References the account that owns or controls the child account (e.g., global OEM headquarters, holding company, or divisional parent).' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:accountTier rdf:type rdf:Property ;
    rdfs:label 'Account Tier' ;
    rdfs:comment 'Commercial tier classification of the child account within the hierarchy, reflecting strategic importance and revenue contribution. Strategic = top-tier global OEM or enterprise accounts; key = significant regional accounts; standard = regular commercial accounts; transactional = low-volume or spot-buy accounts. Drives SLA, pricing, and service prioritization.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationRequired rdf:type rdf:Property ;
    rdfs:label 'Consolidation Required' ;
    rdfs:comment 'Indicates whether the child account\'s financials must be consolidated into the parent account\'s financial statements for regulatory and management reporting purposes. Drives SAP S/4HANA FI/CO consolidation processes.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controllingInterest rdf:type rdf:Property ;
    rdfs:label 'Controlling Interest' ;
    rdfs:comment 'Indicates whether the parent account holds a controlling interest (majority ownership or effective control) over the child account. True = controlling interest exists; False = non-controlling or minority interest. Drives financial consolidation rules per IFRS 10.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditRollupEligible rdf:type rdf:Property ;
    rdfs:label 'Credit Rollup Eligible' ;
    rdfs:comment 'Indicates whether the child account\'s credit exposure should be aggregated to the parent account for enterprise-wide credit limit management. True = include in parent credit roll-up; False = manage credit independently. Critical for global OEM credit risk management in SAP S/4HANA FI.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crmHierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Crm Hierarchy Code' ;
    rdfs:comment 'The native Salesforce CRM Account Hierarchy record identifier (18-character Salesforce ID) for this relationship. Enables direct traceability back to the source system of record for reconciliation and audit purposes.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpCustomerHierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Erp Customer Hierarchy Code' ;
    rdfs:comment 'The SAP S/4HANA SD customer hierarchy node code corresponding to this parent-child relationship. Used for cross-system reconciliation between Salesforce CRM and SAP S/4HANA pricing, rebate, and revenue reporting hierarchies.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'Indicates the geographic coverage scope of the hierarchy relationship. Global = worldwide enterprise; regional = multi-country region (e.g., EMEA, APAC); national = single country; local = sub-national (city, state, or plant level). Used for territory management and global OEM account segmentation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyCategory rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Category' ;
    rdfs:comment 'Classifies the purpose or basis of the hierarchy relationship. Legal = based on legal ownership structure; commercial = based on commercial/contractual relationship; operational = based on operational reporting lines; reporting = created for management reporting consolidation purposes only.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Code' ;
    rdfs:comment 'Externally-known business identifier for the hierarchy relationship record, used for cross-system referencing and reporting. Sourced from Salesforce CRM and aligned with SAP S/4HANA customer master hierarchy codes.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyDepth rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Depth' ;
    rdfs:comment 'Total number of levels in the hierarchy subtree rooted at the parent account in this relationship. Indicates the structural complexity of the account group. Distinct from hierarchy_level (which is the child\'s absolute position); hierarchy_depth measures the span below the parent.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyName rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Name' ;
    rdfs:comment 'Human-readable descriptive name for the parent-child hierarchy relationship (e.g., \'Siemens AG → Siemens Digital Industries GmbH\'). Used in reports, dashboards, and account management interfaces for quick identification.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Path' ;
    rdfs:comment 'Full materialized path string representing the ancestry chain from the root account to the child account, using a delimiter-separated format (e.g., \'GlobalHQ/RegionEMEA/CountryDE/SubsidiaryXYZ\'). Enables efficient tree traversal queries and hierarchy visualization in analytics platforms.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyStatus rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Status' ;
    rdfs:comment 'Current lifecycle state of the parent-child hierarchy relationship. Active indicates the relationship is in force; pending indicates awaiting approval or validation; terminated indicates the relationship has ended (e.g., divestiture, dissolution); suspended indicates temporarily inactive.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industrySegment rdf:type rdf:Property ;
    rdfs:label 'Industry Segment' ;
    rdfs:comment 'The primary industry vertical or market segment of the child account within this hierarchy (e.g., Automotive OEM, Aerospace & Defense, Food & Beverage, Pharmaceuticals, Energy & Utilities). Used for market segmentation, strategic account planning, and industry-specific SLA assignment. [ENUM-REF-CANDIDATE: automotive|aerospace_defense|food_beverage|pharma|energy_utilities|electronics|heavy_industry|transportation — promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mdmHierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Mdm Hierarchy Code' ;
    rdfs:comment 'The Informatica MDM golden record hierarchy identifier for this relationship, representing the authoritative cross-system master data reference. Ensures data quality and deduplication across Salesforce CRM and SAP S/4HANA hierarchy representations.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'The percentage of equity ownership the parent account holds in the child account. Critical for IFRS 10 consolidation thresholds (>50% = subsidiary, 20-50% = associate/affiliate), financial roll-up reporting, and OEM account governance. Expressed as a decimal percentage (e.g., 75.00 = 75%).' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingRollupEligible rdf:type rdf:Property ;
    rdfs:label 'Pricing Rollup Eligible' ;
    rdfs:comment 'Indicates whether the child account\'s purchase volumes should be aggregated to the parent account for volume-based pricing, rebate calculation, and global framework agreement pricing in SAP S/4HANA SD. True = volumes consolidated at parent level; False = priced independently.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Primary Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the primary country of the child account within this hierarchy relationship. Used for geographic roll-up reporting, trade compliance, and export control screening.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'Classifies the nature of the corporate relationship between parent and child accounts. Drives legal, financial, and commercial treatment: subsidiary (majority-owned legal entity), division (internal business unit), affiliate (minority-owned or associated entity), joint_venture (co-owned entity), distributor (channel partner), franchise (licensed operator). [ENUM-REF-CANDIDATE: subsidiary|division|affiliate|joint_venture|distributor|franchise — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRollupEligible rdf:type rdf:Property ;
    rdfs:label 'Revenue Rollup Eligible' ;
    rdfs:comment 'Indicates whether the child account\'s revenue should be rolled up and attributed to the parent account for enterprise-level revenue reporting and global OEM account performance tracking. True = include in parent roll-up; False = exclude (e.g., for minority affiliates or reporting-only hierarchy nodes).' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaInherited rdf:type rdf:Property ;
    rdfs:label 'Sla Inherited' ;
    rdfs:comment 'Indicates whether the child account inherits the Service Level Agreement (SLA) terms from the parent account in this hierarchy relationship. True = child account uses parent SLA; False = child account has its own independently negotiated SLA. Drives Salesforce Service Cloud case routing and escalation logic.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountRelationshipId rdf:type rdf:Property ;
    rdfs:label 'Account Relationship Id' ;
    rdfs:comment 'Unique surrogate identifier for each account relationship record in the industrial customer domain. Serves as the primary key for the account_relationship data product.' ;
    rdfs:domain ind:AccountRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAccountEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Account Employee Id' ;
    rdfs:comment 'Identifier of the internal employee or sales representative responsible for managing and maintaining this account relationship. Maps to the Salesforce CRM relationship owner user record.' ;
    rdfs:domain ind:AccountRelationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:agreementReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Reference Number' ;
    rdfs:comment 'External contract or agreement number associated with a commercial relationship (e.g., OEM licensing agreement number, distributor contract ID, reseller agreement reference). Links to the formal legal document in the contract management system. Applicable for commercial relationship types.' ;
    rdfs:domain ind:AccountRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Maximum credit exposure authorized for the child account within this relationship, expressed in the primary currency. Used for credit risk management and order approval workflows in SAP S/4HANA SD.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crmRelationshipCode rdf:type rdf:Property ;
    rdfs:label 'Crm Relationship Code' ;
    rdfs:comment 'Native record identifier of this account relationship in Salesforce CRM. Used for cross-system reconciliation, data lineage, and integration with Salesforce Sales Cloud and Service Cloud.' ;
    rdfs:domain ind:AccountRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionChannelCode rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel Code' ;
    rdfs:comment 'SAP Distribution Channel code indicating how products and services are delivered to the child account within this relationship (e.g., direct sales, distributor, OEM channel). Drives pricing and order management rules.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'The calendar date on which the account relationship formally ends or is scheduled to end. Null for open-ended or perpetual relationships. For commercial agreements, aligns with contract expiry date.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Flag' ;
    rdfs:comment 'Indicates whether the commercial relationship includes an exclusivity clause, preventing either party from entering into similar arrangements with competitors within a defined territory or product category.' ;
    rdfs:domain ind:AccountRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governingLawCountry rdf:type rdf:Property ;
    rdfs:label 'Governing Law Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction whose laws govern the commercial relationship agreement (e.g., DEU for Germany, USA for United States). Relevant for dispute resolution and regulatory compliance.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGlobalAccount rdf:type rdf:Property ;
    rdfs:label 'Is Global Account' ;
    rdfs:comment 'Indicates whether this account relationship is part of a global enterprise account program, requiring coordinated management across multiple geographies and business units. True for multinational OEM and enterprise accounts.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStrategicPartner rdf:type rdf:Property ;
    rdfs:label 'Is Strategic Partner' ;
    rdfs:comment 'Indicates whether the account relationship is classified as a strategic partnership requiring executive sponsorship and dedicated resources. True for key OEM partners, major distributors, and preferred EPC contractors.' ;
    rdfs:domain ind:AccountRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mdmRelationshipCode rdf:type rdf:Property ;
    rdfs:label 'Mdm Relationship Code' ;
    rdfs:comment 'Informatica MDM golden record identifier for this account relationship. Serves as the cross-system master identifier for data quality, deduplication, and governance processes.' ;
    rdfs:domain ind:AccountRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Method' ;
    rdfs:comment 'Preferred communication channel for managing this account relationship, as agreed with the customer. Guides account managers on how to engage with the relationship counterpart for reviews, escalations, and business development.' ;
    rdfs:domain ind:AccountRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Primary Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the primary transactional currency of the commercial relationship (e.g., USD, EUR, GBP). Used for financial roll-up reporting and revenue attribution across the account hierarchy.' ;
    rdfs:domain ind:AccountRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipDescription rdf:type rdf:Property ;
    rdfs:label 'Relationship Description' ;
    rdfs:comment 'Free-text narrative describing the nature, context, and business purpose of the account relationship. Captures nuances not represented by structured fields, such as historical context, strategic rationale, or special commercial terms.' ;
    rdfs:domain ind:AccountRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipHealthScore rdf:type rdf:Property ;
    rdfs:label 'Relationship Health Score' ;
    rdfs:comment 'Numeric score (0.00–100.00) representing the overall health and strength of the account relationship, derived from engagement metrics, satisfaction surveys, payment behavior, and commercial activity. Used by account managers to prioritize relationship interventions.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipName rdf:type rdf:Property ;
    rdfs:label 'Relationship Name' ;
    rdfs:comment 'Human-readable descriptive name for the account relationship, typically combining the parent and child account names with the relationship subtype (e.g., \'Siemens AG — Siemens Energy GmbH (Subsidiary)\'). Used in reports and CRM displays.' ;
    rdfs:domain ind:AccountRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipNumber rdf:type rdf:Property ;
    rdfs:label 'Relationship Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the account relationship, used in correspondence, reporting, and cross-system reference. Sourced from Salesforce CRM relationship record number.' ;
    rdfs:domain ind:AccountRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipSource rdf:type rdf:Property ;
    rdfs:label 'Relationship Source' ;
    rdfs:comment 'Identifies the operational system of record from which this account relationship record originated. Supports data lineage tracking and master data governance in Informatica MDM.' ;
    rdfs:domain ind:AccountRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Relationship Status' ;
    rdfs:comment 'Current lifecycle state of the account relationship. Active indicates the relationship is in force; pending indicates awaiting approval or activation; suspended indicates temporarily paused; terminated indicates formally ended.' ;
    rdfs:domain ind:AccountRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipSubtype rdf:type rdf:Property ;
    rdfs:label 'Relationship Subtype' ;
    rdfs:comment 'Granular classification of the relationship within its type. For hierarchy relationships: parent_subsidiary, division, affiliate, joint_venture, holding_company. For commercial relationships: oem_licensing, distributor_agreement, reseller_arrangement, preferred_supplier, epc_contractor, value_added_reseller. [ENUM-REF-CANDIDATE: parent_subsidiary|division|affiliate|joint_venture|oem_licensing|distributor_agreement|reseller_arrangement|preferred_supplier|epc_contractor|value_added_reseller — promote to reference product]' ;
    rdfs:domain ind:AccountRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Percentage' ;
    rdfs:comment 'Contractually agreed percentage of revenue shared between the parent and child accounts under a commercial relationship (e.g., OEM royalty rate, distributor margin percentage). Applicable for commercial relationship types with revenue-sharing arrangements.' ;
    rdfs:domain ind:AccountRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesOrgCode rdf:type rdf:Property ;
    rdfs:label 'Sales Org Code' ;
    rdfs:comment 'SAP Sales Organization code responsible for managing the commercial aspects of this account relationship. Determines pricing, order processing, and revenue booking rules applicable to the relationship.' ;
    rdfs:domain ind:AccountRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTier rdf:type rdf:Property ;
    rdfs:label 'Sla Tier' ;
    rdfs:comment 'SLA tier assigned to this account relationship, determining the level of service, response times, and support entitlements applicable to the child account. Platinum and gold tiers receive priority support and dedicated account management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicImportanceRating rdf:type rdf:Property ;
    rdfs:label 'Strategic Importance Rating' ;
    rdfs:comment 'Qualitative rating of the strategic importance of this account relationship to the manufacturing business. Critical indicates top-tier global accounts; high indicates major regional accounts; medium indicates standard commercial accounts; low indicates transactional or minor accounts.' ;
    rdfs:domain ind:AccountRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Code' ;
    rdfs:comment 'Sales territory or geographic region code assigned to this account relationship, used for territory management, revenue attribution, and sales performance reporting. Aligns with SAP S/4HANA SD sales territory configuration.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerContactId rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Id' ;
    rdfs:comment 'Reference to the primary contact person at this site responsible for coordinating field service visits, deliveries, and maintenance activities. Links to the contact master record.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerContact .

ind:installedSkuMasterId rdf:type rdf:Property ;
    rdfs:label 'Installed Sku Master Id' ;
    rdfs:comment 'Foreign key linking to product.sku_master. Business justification: Needed for site-level asset management; links each plant site to the primary product installed for maintenance scheduling and warranty tracking.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuMaster .

ind:siteManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Site Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Site manager employee is needed for operations, maintenance scheduling and safety compliance reports.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:siteSalesRepId rdf:type rdf:Property ;
    rdfs:label 'Site Sales Rep Id' ;
    rdfs:comment 'Foreign key linking to sales.rep. Business justification: Site-level sales rep ownership is required for site-specific revenue tracking and service contract management.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:vendorSiteId rdf:type rdf:Property ;
    rdfs:label 'Vendor Site Id' ;
    rdfs:comment 'Foreign key linking to supplier.supplier_site. Business justification: Logistics scheduling links each customer site to the supplier site that delivers goods, enabling inbound receipt matching.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:accessRestrictionNotes rdf:type rdf:Property ;
    rdfs:label 'Access Restriction Notes' ;
    rdfs:comment 'Free-text notes describing access restrictions, security clearance requirements, visitor registration procedures, or special entry protocols for field service engineers and delivery personnel at this site.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address line for the site (suite, building, floor, gate number). Supplements address_line1 for precise field service and logistics routing.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmSiteCode rdf:type rdf:Property ;
    rdfs:label 'Crm Site Code' ;
    rdfs:comment 'Salesforce CRM native identifier for this account site record. Used for cross-system data lineage, reconciliation between the lakehouse silver layer and the Salesforce source system, and audit traceability.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalClassification rdf:type rdf:Property ;
    rdfs:label 'Environmental Classification' ;
    rdfs:comment 'Environmental condition classification of the site affecting product installation requirements, equipment ratings, and maintenance intervals. Informs selection of appropriate equipment IP ratings and material specifications. [ENUM-REF-CANDIDATE: standard|controlled|outdoor|corrosive|high_temperature|high_humidity — promote to reference product]' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpPlantCode rdf:type rdf:Property ;
    rdfs:label 'Erp Plant Code' ;
    rdfs:comment 'SAP S/4HANA plant code corresponding to this customer site. Used for cross-system reconciliation of delivery addresses, service orders, and inventory movements associated with this site.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installedProductCount rdf:type rdf:Property ;
    rdfs:label 'Installed Product Count' ;
    rdfs:comment 'Total number of Manufacturing products currently installed and tracked at this site. Drives installed base analytics, preventive maintenance scheduling volume, and spare parts demand forecasting.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isHeadquarters rdf:type rdf:Property ;
    rdfs:label 'Is Headquarters' ;
    rdfs:comment 'Indicates whether this site is the primary headquarters or main facility of the customer account. Used for account hierarchy reporting, executive relationship management, and primary billing address determination.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastSiteVisitDate rdf:type rdf:Property ;
    rdfs:label 'Last Site Visit Date' ;
    rdfs:comment 'Date of the most recent field service engineer or account manager visit to the site. Used for relationship management, service frequency analysis, and identifying sites overdue for preventive maintenance visits.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mesSystemPresent rdf:type rdf:Property ;
    rdfs:label 'Mes System Present' ;
    rdfs:comment 'Indicates whether a Manufacturing Execution System (MES) is installed at the site. Used to assess integration readiness for Siemens Opcenter MES connectivity and shop floor data exchange.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkConnectivityType rdf:type rdf:Property ;
    rdfs:label 'Network Connectivity Type' ;
    rdfs:comment 'Primary network connectivity type available at the site for IIoT device integration, remote monitoring, and SCADA/MES connectivity. Determines feasibility of remote diagnostics and predictive maintenance services.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Maintenance Date' ;
    rdfs:comment 'Date of the next planned preventive maintenance visit at this site. Drives field service dispatch scheduling, spare parts pre-positioning, and resource capacity planning for the service organization.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:numberOfProductionLines rdf:type rdf:Property ;
    rdfs:label 'Number Of Production Lines' ;
    rdfs:comment 'Count of active production lines at the manufacturing site. Used to estimate installed base potential, maintenance workload, and spare parts demand. Relevant for manufacturing plant site types.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operates24x7 rdf:type rdf:Property ;
    rdfs:label 'Operates 24x7' ;
    rdfs:comment 'Indicates whether the site operates continuously 24 hours a day, 7 days a week. When true, overrides operational_hours_start/end for scheduling purposes and may trigger higher SLA tier assignment.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationalHoursEnd rdf:type rdf:Property ;
    rdfs:label 'Operational Hours End' ;
    rdfs:comment 'Daily operational end time of the site in HH:MM (24-hour) format in the site\'s local time zone. Used to constrain field service scheduling, maintenance windows, and delivery cutoff times.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalHoursStart rdf:type rdf:Property ;
    rdfs:label 'Operational Hours Start' ;
    rdfs:comment 'Daily operational start time of the site in HH:MM (24-hour) format in the site\'s local time zone. Used to schedule field service visits, preventive maintenance windows, and delivery time slots within permitted hours.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantFloorAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Plant Floor Area Sqm' ;
    rdfs:comment 'Total operational floor area of the site in square meters. Used for capacity planning, equipment density analysis, and logistics resource estimation for large-scale installations.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the customer site address. Used for logistics zone mapping, field service territory assignment, and tax jurisdiction determination.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerSupplyFrequencyHz rdf:type rdf:Property ;
    rdfs:label 'Power Supply Frequency Hz' ;
    rdfs:comment 'Electrical supply frequency at the site in Hertz (50 or 60 Hz). Required for equipment compatibility validation for automation systems, drives, and electrification products.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:powerSupplyVoltage rdf:type rdf:Property ;
    rdfs:label 'Power Supply Voltage' ;
    rdfs:comment 'Primary electrical supply voltage standard at the site. Critical for ensuring compatibility of electrification solutions and automation equipment installed or to be installed at the site. [ENUM-REF-CANDIDATE: 110V|220V|380V|400V|480V|600V|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaSystemPresent rdf:type rdf:Property ;
    rdfs:label 'Scada System Present' ;
    rdfs:comment 'Indicates whether a SCADA system is installed and operational at the site. Relevant for integration planning with Aveva SCADA and for determining remote monitoring service eligibility.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:siteContactEmail rdf:type rdf:Property ;
    rdfs:label 'Site Contact Email' ;
    rdfs:comment 'Email address of the primary on-site contact for service notifications, maintenance scheduling confirmations, and delivery alerts.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteContactName rdf:type rdf:Property ;
    rdfs:label 'Site Contact Name' ;
    rdfs:comment 'Full name of the primary on-site contact person for field service coordination, delivery acceptance, and maintenance scheduling. Captured directly for operational use when the contact master record may not yet be established.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteContactPhone rdf:type rdf:Property ;
    rdfs:label 'Site Contact Phone' ;
    rdfs:comment 'Direct phone number for the primary on-site contact. Used by field service engineers and logistics teams for on-site coordination and delivery confirmation.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCriticalityRating rdf:type rdf:Property ;
    rdfs:label 'Site Criticality Rating' ;
    rdfs:comment 'Business-assigned criticality level of the site reflecting the operational impact of downtime or service disruption. Drives SLA priority, spare parts stocking strategy, and preventive maintenance frequency. Aligned with FMEA risk classification.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteStatus rdf:type rdf:Property ;
    rdfs:label 'Site Status' ;
    rdfs:comment 'Current lifecycle state of the customer site. Determines eligibility for field service dispatch, new product installations, and preventive maintenance scheduling. \'decommissioned\' sites are retained for historical installed base tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteType rdf:type rdf:Property ;
    rdfs:label 'Site Type' ;
    rdfs:comment 'Classification of the facility type indicating the primary operational purpose of the site. Drives field service routing, SLA tier assignment, and preventive maintenance scheduling. [ENUM-REF-CANDIDATE: manufacturing_plant|warehouse|distribution_center|data_center|commercial_building|substation — promote to reference product if additional types are required]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, or region of the customer site. Used for regulatory compliance jurisdiction determination (OSHA, EPA), tax zone assignment, and logistics planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the site location (e.g., \'America/Chicago\', \'Europe/Berlin\'). Used for scheduling preventive maintenance windows, field service appointments, and operational hours alignment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountTeamId rdf:type rdf:Property ;
    rdfs:label 'Account Team Id' ;
    rdfs:comment 'Unique surrogate identifier for each account team member assignment record in the Manufacturing CRM system. Primary key for the account_team data product.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountSegmentId rdf:type rdf:Property ;
    rdfs:label 'Account Segment Id' ;
    rdfs:comment 'Foreign key linking to customer.customer_segment. Business justification: Team assignments reference segment for reporting; replace string with FK.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:territoryId rdf:type rdf:Property ;
    rdfs:label 'Territory Id' ;
    rdfs:comment 'Reference to the sales territory to which this account team assignment belongs. Defines the geographic or market segment scope of the team member\'s responsibility.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:userEmployeeId rdf:type rdf:Property ;
    rdfs:label 'User Employee Id' ;
    rdfs:comment 'Reference to the internal Manufacturing employee or system user assigned to this account team role. Maps to the Salesforce CRM User record and Workday HCM employee record.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignmentReason rdf:type rdf:Property ;
    rdfs:label 'Assignment Reason' ;
    rdfs:comment 'Free-text description of the business reason for this account team assignment (e.g., new account onboarding, territory realignment, escalation coverage, strategic account expansion).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle status of the account team member assignment. Indicates whether the assignment is currently active, pending activation, temporarily suspended, or has been terminated.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentType rdf:type rdf:Property ;
    rdfs:label 'Assignment Type' ;
    rdfs:comment 'Classifies the nature of the account team assignment as permanent (long-term), temporary (project-based), interim (gap coverage), or coverage (vacation/leave backup). Supports workforce planning and continuity management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseAccess rdf:type rdf:Property ;
    rdfs:label 'Case Access' ;
    rdfs:comment 'The level of access granted to this team member for service case records associated with the customer account. Governs visibility into support tickets, NCRs, RMAs, and CAPA records.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactAccess rdf:type rdf:Property ;
    rdfs:label 'Contact Access' ;
    rdfs:comment 'The level of access granted to this team member for contact records associated with the customer account. Controls visibility into customer stakeholder information.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageCountryCode rdf:type rdf:Property ;
    rdfs:label 'Coverage Country Code' ;
    rdfs:comment 'The ISO 3166-1 alpha-3 country code representing the primary country this team member covers for the assigned account. Used for regulatory compliance, export control, and regional reporting.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmOwnerCode rdf:type rdf:Property ;
    rdfs:label 'Crm Owner Code' ;
    rdfs:comment 'The Salesforce CRM user ID of the record owner responsible for maintaining this account team member record. Used for data stewardship, governance, and audit accountability.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmTeamMemberCode rdf:type rdf:Property ;
    rdfs:label 'Crm Team Member Code' ;
    rdfs:comment 'External identifier for this account team member record as assigned by Salesforce CRM. Used for cross-system reconciliation and audit traceability back to the source system of record.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'Identifies the operational system of record from which this account team assignment record was sourced. Supports data lineage, reconciliation, and MDM governance processes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFromTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective From Timestamp' ;
    rdfs:comment 'The precise timestamp from which this account team assignment record version is valid in the Silver Layer lakehouse. Supports slowly changing dimension (SCD) Type 2 history tracking for the assignment.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:effectiveToTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective To Timestamp' ;
    rdfs:comment 'The precise timestamp until which this account team assignment record version is valid in the Silver Layer lakehouse. Null indicates the current active version. Supports SCD Type 2 history tracking.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:engagementModel rdf:type rdf:Property ;
    rdfs:label 'Engagement Model' ;
    rdfs:comment 'The customer engagement model governing how this team member interacts with the account. Determines the frequency, depth, and mode of customer engagement activities.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryVertical rdf:type rdf:Property ;
    rdfs:label 'Industry Vertical' ;
    rdfs:comment 'The industry vertical of the customer account (e.g., Automotive, Aerospace, Food & Beverage, Energy). Used for vertical-specific sales strategy alignment and application engineering expertise matching.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCurrentRecord rdf:type rdf:Property ;
    rdfs:label 'Is Current Record' ;
    rdfs:comment 'Indicates whether this row represents the current active version of the account team assignment record in the Silver Layer SCD Type 2 history table. True for the latest version, False for historical versions.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isExecutiveSponsor rdf:type rdf:Property ;
    rdfs:label 'Is Executive Sponsor' ;
    rdfs:comment 'Indicates whether this team member serves as the executive sponsor for the customer account. Executive sponsors are senior Manufacturing leaders accountable for strategic relationship health.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Indicates whether this team member is designated as the primary point of contact for the customer account. Only one team member per account should hold this designation at any given time.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTeamLead rdf:type rdf:Property ;
    rdfs:label 'Is Team Lead' ;
    rdfs:comment 'Indicates whether this team member is designated as the account team lead responsible for coordinating all team activities, internal escalations, and customer review cadences.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'The official job title of the Manufacturing employee as defined in Workday HCM. Provides context for the team member\'s seniority and functional expertise relative to their account team role.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCustomerInteractionDate rdf:type rdf:Property ;
    rdfs:label 'Last Customer Interaction Date' ;
    rdfs:comment 'The date of the most recent logged interaction between this team member and the customer account (e.g., call, meeting, site visit). Used for relationship health monitoring and engagement cadence compliance.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextScheduledReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Review Date' ;
    rdfs:comment 'The date of the next planned business review or customer engagement activity for this team member and account. Supports proactive relationship management and SLA compliance tracking.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:opportunityAccess rdf:type rdf:Property ;
    rdfs:label 'Opportunity Access' ;
    rdfs:comment 'The level of access granted to this team member for opportunity records associated with the customer account. Governs visibility into pipeline, deal stages, and revenue forecasts.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaAmount rdf:type rdf:Property ;
    rdfs:label 'Quota Amount' ;
    rdfs:comment 'The revenue quota assigned to this team member for the associated customer account, expressed in the base currency. Used for sales performance tracking, incentive compensation, and KPI reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotaCurrency rdf:type rdf:Property ;
    rdfs:label 'Quota Currency' ;
    rdfs:comment 'The ISO 4217 three-letter currency code for the quota amount assigned to this account team member (e.g., USD, EUR, GBP). Supports multi-currency reporting for global sales operations.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaPeriod rdf:type rdf:Property ;
    rdfs:label 'Quota Period' ;
    rdfs:comment 'The time period over which the assigned quota is measured (e.g., annual, quarterly). Aligns with the sales planning cycle and incentive compensation structure.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesDistrict rdf:type rdf:Property ;
    rdfs:label 'Sales District' ;
    rdfs:comment 'The sales district within the sales region to which this account team assignment is mapped. Provides sub-regional granularity for territory coverage analysis and quota assignment.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesRegion rdf:type rdf:Property ;
    rdfs:label 'Sales Region' ;
    rdfs:comment 'The geographic sales region to which this account team assignment belongs (e.g., North America, EMEA, APAC). Used for regional performance reporting and territory management.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamMemberRole rdf:type rdf:Property ;
    rdfs:label 'Team Member Role' ;
    rdfs:comment 'The functional role of the internal Manufacturing employee on this customer account team. Defines responsibilities such as commercial ownership, technical pre-sales, post-sales support, or executive relationship management. [ENUM-REF-CANDIDATE: Account Manager|Field Sales Engineer|Application Engineer|Customer Success Manager|Executive Sponsor|Inside Sales Representative|Technical Support Engineer — promote to reference product]' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressId rdf:type rdf:Property ;
    rdfs:label 'Address Id' ;
    rdfs:comment 'Unique surrogate identifier for each address record in the customer domain. Serves as the primary key for the address data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:addressStatus rdf:type rdf:Property ;
    rdfs:label 'Address Status' ;
    rdfs:comment 'Current lifecycle status of the address record. Active addresses are in current use; inactive addresses are no longer used but retained for historical reference; pending addresses are awaiting validation or approval; archived addresses are soft-deleted for audit trail purposes.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressType rdf:type rdf:Property ;
    rdfs:label 'Address Type' ;
    rdfs:comment 'Functional classification of the address indicating its business purpose. Billing addresses are used for invoicing (SAP SD), shipping/delivery addresses for logistics dispatch (SAP WM/TMS), headquarters for corporate correspondence, plant_site for manufacturing facility locations, mailing for postal communications, and field_service for on-site service dispatch. [ENUM-REF-CANDIDATE: billing|shipping|headquarters|plant_site|mailing|field_service|registered|returns — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attentionLine rdf:type rdf:Property ;
    rdfs:label 'Attention Line' ;
    rdfs:comment 'Addressee attention line specifying the department, role, or individual to whom correspondence or deliveries should be directed at this address (e.g., \'Attn: Procurement Department\', \'Attn: Receiving Dock\'). Common in B2B industrial shipping.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingName rdf:type rdf:Property ;
    rdfs:label 'Building Name' ;
    rdfs:comment 'Name of the building or facility at this address (e.g., \'Tower A\', \'Building 7 - Final Assembly\', \'North Warehouse\'). Common in large industrial campuses and multi-building manufacturing complexes. Supplements street address for precise delivery and field service dispatch.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countyDistrict rdf:type rdf:Property ;
    rdfs:label 'County District' ;
    rdfs:comment 'County, district, or sub-regional administrative unit of the address. Used for local tax jurisdiction determination, permit compliance, and field service territory mapping in industrial manufacturing contexts.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryInstructions rdf:type rdf:Property ;
    rdfs:label 'Delivery Instructions' ;
    rdfs:comment 'Free-text special instructions for deliveries to this address, such as dock access hours, security clearance requirements, forklift availability, hazardous material handling notes, or contact person for receiving. Critical for industrial manufacturing shipments to plant sites.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorNumber rdf:type rdf:Property ;
    rdfs:label 'Floor Number' ;
    rdfs:comment 'Floor or level number within a building at this address. Used for precise field service dispatch and delivery routing within multi-story industrial facilities, office buildings, and distribution centers.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geocodingAccuracy rdf:type rdf:Property ;
    rdfs:label 'Geocoding Accuracy' ;
    rdfs:comment 'Precision level of the geocoordinates assigned to this address. Rooftop indicates exact building-level precision; range_interpolated is street-level; geometric_center is centroid of a region; approximate is low-precision; ungeocoded means no coordinates assigned. Informs reliability of geospatial analytics.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatCertified rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified' ;
    rdfs:comment 'Indicates whether this address/facility is certified to receive hazardous materials shipments. Relevant for industrial manufacturing customers receiving chemicals, electrification components, or other regulated materials. Supports EPA and OSHA compliance.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Flag indicating whether this is the primary address for the associated customer account or contact. Only one address per customer per address_type should be marked as primary. Used to determine the default address for invoicing, shipping, and correspondence.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isValidated rdf:type rdf:Property ;
    rdfs:label 'Is Validated' ;
    rdfs:comment 'Indicates whether the address has been validated against a postal authority or address verification service (e.g., USPS CASS, Informatica MDM address cleansing). Validated addresses reduce delivery failures and logistics errors.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:label rdf:type rdf:Property ;
    rdfs:label 'Label' ;
    rdfs:comment 'Human-readable descriptive label or nickname for the address record (e.g., \'Stuttgart HQ\', \'Chicago Distribution Center\', \'Plant 3 - Assembly Line\'). Facilitates quick identification in Salesforce CRM and SAP S/4HANA user interfaces.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'ISO 639-1 language code for the preferred communication language at this address (e.g., \'en\', \'de\', \'zh-CN\', \'fr\'). Used to determine document language for invoices, shipping labels, and field service work orders dispatched to this location.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line1 rdf:type rdf:Property ;
    rdfs:label 'Line 1' ;
    rdfs:comment 'Primary street address line including building number, street name, and any directional qualifiers. This is the first and mandatory line of the physical or mailing address as captured in Salesforce CRM and SAP S/4HANA customer master.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line2 rdf:type rdf:Property ;
    rdfs:label 'Line 2' ;
    rdfs:comment 'Secondary address line for suite, floor, unit, building name, mail stop, or additional location qualifier. Optional field used when the primary address line is insufficient to fully identify the location.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line3 rdf:type rdf:Property ;
    rdfs:label 'Line 3' ;
    rdfs:comment 'Tertiary address line for additional location details such as industrial park name, campus identifier, or zone designation. Used primarily for complex plant site and industrial facility addresses common in manufacturing environments.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadingDockAvailable rdf:type rdf:Property ;
    rdfs:label 'Loading Dock Available' ;
    rdfs:comment 'Indicates whether a loading dock is available at this address for receiving industrial equipment, automation systems, and bulk material shipments. Affects carrier selection (LTL vs FTL) and delivery scheduling in the Transportation Management System (TMS).' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mdmAddressKey rdf:type rdf:Property ;
    rdfs:label 'Mdm Address Key' ;
    rdfs:comment 'Unique address identifier assigned by Informatica MDM during master data consolidation and deduplication. Enables cross-system address matching and golden record linkage across SAP S/4HANA, Salesforce CRM, and other operational systems.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poBox rdf:type rdf:Property ;
    rdfs:label 'Po Box' ;
    rdfs:comment 'Post Office (PO) Box number for mailing addresses where physical street delivery is not applicable. Used for billing correspondence and formal legal notices to corporate customers. Stored separately from street address lines.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poBoxPostalCode rdf:type rdf:Property ;
    rdfs:label 'Po Box Postal Code' ;
    rdfs:comment 'Postal code specific to the PO Box address, which may differ from the street address postal code. Required for accurate mail routing when a PO Box is used for billing or correspondence.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCodeExtension rdf:type rdf:Property ;
    rdfs:label 'Postal Code Extension' ;
    rdfs:comment 'Extended postal code suffix providing finer delivery point precision (e.g., ZIP+4 in the US). Improves mail delivery accuracy and carrier routing for industrial shipments.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roomNumber rdf:type rdf:Property ;
    rdfs:label 'Room Number' ;
    rdfs:comment 'Room, suite, or unit number within a building at this address. Provides the most granular level of location detail for field service technician dispatch and internal mail routing at customer facilities.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesRegionCode rdf:type rdf:Property ;
    rdfs:label 'Sales Region Code' ;
    rdfs:comment 'Sales region or territory code associated with this address, used for sales force assignment, revenue reporting, and quota management. Derived from geographic location and aligned with SAP S/4HANA SD sales organization structure.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTerritoryCode rdf:type rdf:Property ;
    rdfs:label 'Service Territory Code' ;
    rdfs:comment 'Field service territory code assigned to this address, used to route field service engineers and technicians for equipment maintenance, installation, and after-sales support. Aligns with Salesforce Service Cloud territory management and Maximo Asset Management work order dispatch.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCondition rdf:type rdf:Property ;
    rdfs:label 'Shipping Condition' ;
    rdfs:comment 'Default shipping condition or delivery method applicable to this address, indicating the preferred logistics mode. LTL (Less Than Truckload) and FTL (Full Truckload) are standard industrial shipping terms. Drives carrier selection and Transportation Management System (TMS) routing.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemAddressCode rdf:type rdf:Property ;
    rdfs:label 'Source System Address Code' ;
    rdfs:comment 'The native address identifier from the originating source system (e.g., Salesforce CRM Address ID, SAP ADRC ADDRNUMBER). Enables reverse lookup and reconciliation between the Databricks Silver Layer and operational systems during ETL and data quality processes.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Tax jurisdiction identifier for the address location, used to determine applicable sales tax, VAT, or GST rates for invoicing. Typically derived from postal code and state/province. Aligns with SAP S/4HANA tax determination and IFRS/GAAP revenue recognition requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationSource rdf:type rdf:Property ;
    rdfs:label 'Validation Source' ;
    rdfs:comment 'The system or method used to validate the address. Tracks whether validation was performed by USPS CASS certification, a geocoding API (Google Maps, HERE), Informatica MDM address cleansing, manual review, or not yet validated. Supports data quality governance.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Vat Registration Number' ;
    rdfs:comment 'Value Added Tax (VAT) registration number associated with this address, particularly for EU and international billing addresses. Required for cross-border B2B invoicing compliance and VAT reclaim processes in industrial manufacturing.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Owner Employee Id' ;
    rdfs:comment 'Reference to the internal sales representative or account manager who owns this contact record in Salesforce CRM. Drives assignment routing, quota crediting, and relationship accountability.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reportsToContactId rdf:type rdf:Property ;
    rdfs:label 'Reports To Contact Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the contact\'s organizational superior within the same account. Enables modeling of the customer-side org chart for multi-stakeholder enterprise sales and service engagement strategies.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerContact .

ind:accountSite rdf:type rdf:Property ;
    rdfs:label 'Account Site' ;
    rdfs:comment 'Specific plant, facility, or site within the parent account organization where this contact is based. Critical for industrial manufacturing customers with multiple production sites, enabling site-level service and sales targeting.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assistantName rdf:type rdf:Property ;
    rdfs:label 'Assistant Name' ;
    rdfs:comment 'Name of the contact\'s executive assistant or administrative coordinator. Used to facilitate scheduling, correspondence routing, and executive-level engagement for senior stakeholders at key accounts.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assistantPhone rdf:type rdf:Property ;
    rdfs:label 'Assistant Phone' ;
    rdfs:comment 'Phone number of the contact\'s executive assistant. Enables sales and service teams to reach senior contacts through their administrative support channel.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:birthdate rdf:type rdf:Property ;
    rdfs:label 'Birthdate' ;
    rdfs:comment 'Date of birth of the contact. Captured selectively for key account contacts where relationship management programs require it. Subject to strict GDPR data minimization principles — only collected when there is a documented lawful basis.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentRecordCode rdf:type rdf:Property ;
    rdfs:label 'Consent Record Code' ;
    rdfs:comment 'Reference identifier linking to the formal consent record in the consent management system. Provides an auditable trail of the lawful basis under which this contact\'s personal data is processed, as required by GDPR Article 7.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'Classification of the contact\'s decision-making role in the B2B buying and service process. Drives sales engagement strategy and marketing segmentation. [ENUM-REF-CANDIDATE: technical_evaluator|commercial_buyer|executive_approver|end_user|influencer|other — promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmContactCode rdf:type rdf:Property ;
    rdfs:label 'Crm Contact Code' ;
    rdfs:comment 'External identifier for this contact record as assigned by Salesforce CRM. Used for cross-system reconciliation and delta-load processing from the operational source of record.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerContactStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Status' ;
    rdfs:comment 'Current lifecycle status of the contact record. Governs whether the contact is eligible for outreach, service engagement, and data processing activities. \'do_not_contact\' enforces opt-out and regulatory suppression requirements.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotCall rdf:type rdf:Property ;
    rdfs:label 'Do Not Call' ;
    rdfs:comment 'Indicates whether the contact has requested to be excluded from telephone outreach. True = phone contact suppressed. Enforced in compliance with national do-not-call registries and GDPR consent requirements.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:email rdf:type rdf:Property ;
    rdfs:label 'Email' ;
    rdfs:comment 'Primary business email address of the contact. Used as the principal digital communication channel for sales outreach, service notifications, and marketing campaigns. Governed under GDPR and applicable privacy regulations.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailOptOut rdf:type rdf:Property ;
    rdfs:label 'Email Opt Out' ;
    rdfs:comment 'Indicates whether the contact has explicitly opted out of email communications. True = email suppressed; False = email permitted. Distinct from marketing_opt_in as it applies specifically to all email types including transactional. Enforced by Salesforce CRM email suppression lists.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fax rdf:type rdf:Property ;
    rdfs:label 'Fax' ;
    rdfs:comment 'Fax number associated with the contact or their office location. Retained for legacy B2B industrial communication workflows and regulatory document exchange in certain jurisdictions.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Given name of the individual contact as recorded in Salesforce CRM. Used for personalized communication across sales, service, and marketing channels.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprDataSubjectCode rdf:type rdf:Property ;
    rdfs:label 'Gdpr Data Subject Code' ;
    rdfs:comment 'Unique identifier assigned to this contact as a GDPR data subject. Used to process data subject rights requests (access, erasure, portability) and maintain the record of processing activities (ROPA) as required under GDPR Article 30.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDecisionMaker rdf:type rdf:Property ;
    rdfs:label 'Is Decision Maker' ;
    rdfs:comment 'Indicates whether this contact holds formal decision-making authority for purchasing or contracting at their organization. True = authorized decision maker. Used to prioritize sales engagement and opportunity progression in the CRM pipeline.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the most recent logged activity (call, email, meeting, task) associated with this contact in Salesforce CRM. Used to identify dormant contacts, trigger re-engagement workflows, and measure sales cadence effectiveness.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Family name or surname of the individual contact. Combined with first_name to form the full display name used in correspondence and CRM records.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadSource rdf:type rdf:Property ;
    rdfs:label 'Lead Source' ;
    rdfs:comment 'Channel or origin through which this contact was first acquired or identified. Used for marketing attribution, ROI analysis of demand generation programs, and sales pipeline reporting. [ENUM-REF-CANDIDATE: trade_show|web_inquiry|referral|partner|direct_sales|marketing_campaign|distributor|other — promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedinUrl rdf:type rdf:Property ;
    rdfs:label 'Linkedin Url' ;
    rdfs:comment 'URL of the contact\'s LinkedIn professional profile. Used by sales and marketing teams for social selling, account-based marketing (ABM), and contact enrichment workflows.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCity rdf:type rdf:Property ;
    rdfs:label 'Mailing City' ;
    rdfs:comment 'City component of the contact\'s mailing address. Used in geographic segmentation, territory assignment, and regional sales reporting.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Mailing Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the contact\'s mailing address (e.g., USA, DEU, CHN). Drives multi-national compliance, language preference defaults, and export control screening.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Mailing Postal Code' ;
    rdfs:comment 'Postal or ZIP code component of the contact\'s mailing address. Used for geographic routing, logistics planning, and regional analytics.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingState rdf:type rdf:Property ;
    rdfs:label 'Mailing State' ;
    rdfs:comment 'State or province component of the contact\'s mailing address. Supports territory management, tax jurisdiction determination, and regional compliance reporting.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingStreet rdf:type rdf:Property ;
    rdfs:label 'Mailing Street' ;
    rdfs:comment 'Street address line for the contact\'s mailing address. Used for physical correspondence, contract delivery, and regulatory document dispatch.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingOptIn rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In' ;
    rdfs:comment 'Indicates whether the contact has provided explicit consent to receive marketing communications. True = opted in; False = opted out or consent not obtained. Mandatory for GDPR and CAN-SPAM compliance. Must be False by default until affirmative consent is recorded.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingOptInDate rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In Date' ;
    rdfs:comment 'Date on which the contact provided or last renewed their marketing consent. Required for GDPR audit trail demonstrating lawful basis for marketing data processing.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mdmGoldenRecordCode rdf:type rdf:Property ;
    rdfs:label 'Mdm Golden Record Code' ;
    rdfs:comment 'Identifier of the golden (master) record in Informatica MDM to which this contact has been matched and merged. Enables cross-system deduplication and single-view-of-contact analytics across Salesforce CRM, SAP S/4HANA, and other operational systems.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilePhone rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone' ;
    rdfs:comment 'Mobile or cellular phone number for the contact. Used for SMS notifications, urgent service alerts, and field engineer coordination. Distinct from the primary business phone line.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:persona rdf:type rdf:Property ;
    rdfs:label 'Persona' ;
    rdfs:comment 'Functional persona label describing the contact\'s primary business role in the industrial context (e.g., Design Engineer, Procurement Manager, Plant Manager, Maintenance Supervisor, Executive Sponsor, Quality Engineer). Used for targeted content delivery and sales play alignment.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phone rdf:type rdf:Property ;
    rdfs:label 'Phone' ;
    rdfs:comment 'Primary business phone number for the contact including country code where applicable. Used for direct voice communication by field sales, inside sales, and customer service teams.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommunicationChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Channel' ;
    rdfs:comment 'The contact\'s stated preferred channel for receiving communications from the company. Drives outreach strategy for sales, service, and marketing teams to maximize engagement effectiveness.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salutation rdf:type rdf:Property ;
    rdfs:label 'Salutation' ;
    rdfs:comment 'Formal honorific or title prefix used when addressing the contact in written and verbal communication (e.g., Mr., Dr., Prof.).' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalContactFlag rdf:type rdf:Property ;
    rdfs:label 'Technical Contact Flag' ;
    rdfs:comment 'Indicates whether this contact serves as a technical point of contact for product support, engineering queries, or MES/PLC/SCADA integration activities. True = designated technical contact. Drives routing of technical service cases and engineering change notifications (ECN).' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditProfileId rdf:type rdf:Property ;
    rdfs:label 'Credit Profile Id' ;
    rdfs:comment 'Unique surrogate identifier for the customer credit profile record in the Databricks Silver Layer. Serves as the primary key for this entity.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditProfile .

ind:creditAnalystEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Credit Analyst Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Credit analysis is executed by a designated employee; needed for credit review decisions and audit logs.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:badDebtProvisionAmount rdf:type rdf:Property ;
    rdfs:label 'Bad Debt Provision Amount' ;
    rdfs:comment 'Amount provisioned for potential bad debt loss on this customer\'s receivables under the IFRS 9 Expected Credit Loss (ECL) model or GAAP ASC 310 allowance method. Maintained in SAP S/4HANA FI-AR.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankAccountVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Bank Account Verified Flag' ;
    rdfs:comment 'Indicates whether the customer\'s bank account details on file have been verified through the company\'s bank account validation process. True = verified; False = unverified. Required for direct debit and bank transfer payment methods.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collectionStrategyCode rdf:type rdf:Property ;
    rdfs:label 'Collection Strategy Code' ;
    rdfs:comment 'Code identifying the dunning and collections strategy assigned to this customer in SAP S/4HANA FI-AR (e.g., standard dunning, escalated collections, legal action track). Drives automated dunning notice generation.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAccountType rdf:type rdf:Property ;
    rdfs:label 'Credit Account Type' ;
    rdfs:comment 'Classification of the credit account based on the nature of the customer relationship. Determines applicable credit policies and risk frameworks. [ENUM-REF-CANDIDATE: domestic|export|intercompany|distributor|oem|government — promote to reference product if additional types are required]' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditControlArea rdf:type rdf:Property ;
    rdfs:label 'Credit Control Area' ;
    rdfs:comment 'SAP organizational unit (credit control area code) responsible for managing and monitoring this customer\'s credit. Defines the credit management scope and currency for credit limit enforcement in SAP S/4HANA FI-AR.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditHoldDate rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Date' ;
    rdfs:comment 'Date on which the credit hold was applied to the customer account. Used for aging analysis of credit holds and SLA compliance tracking for credit resolution processes.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Flag' ;
    rdfs:comment 'Indicates whether the customer account is currently placed on credit hold, blocking new order processing in SAP S/4HANA SD and Siemens Opcenter MES. True = credit hold active; False = no hold. Synchronized with Salesforce CRM account status.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditHoldReason rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Reason' ;
    rdfs:comment 'Reason code explaining why the customer account has been placed on credit hold. Required for audit trail and CAPA (Corrective and Preventive Action) processes. Null when credit_hold_flag is False.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditHoldReleasedDate rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Released Date' ;
    rdfs:comment 'Date on which the credit hold was lifted and normal order processing was reinstated. Null if the credit hold is still active. Used for credit resolution cycle time analysis.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditInsuranceCoverageLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Coverage Limit' ;
    rdfs:comment 'Maximum insured amount under the trade credit insurance policy for this customer, in the account currency. Represents the maximum receivable amount recoverable in case of customer default.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditInsuranceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Expiry Date' ;
    rdfs:comment 'Date on which the trade credit insurance policy for this customer expires. Triggers renewal workflow alerts to prevent uninsured credit exposure.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditInsurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Policy Number' ;
    rdfs:comment 'Reference number of the trade credit insurance policy (e.g., Euler Hermes, Coface, Atradius) covering this customer\'s receivables. Null if no credit insurance is in place. Used for insurance claim processing and risk mitigation reporting.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditInsuranceProvider rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Provider' ;
    rdfs:comment 'Name of the trade credit insurance provider covering this customer\'s receivables (e.g., Euler Hermes, Coface, Atradius, Credendo). Null if no credit insurance is in place.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditNotes rdf:type rdf:Property ;
    rdfs:label 'Credit Notes' ;
    rdfs:comment 'Free-text field for credit analyst notes, special conditions, exceptions, or contextual information relevant to this customer\'s credit profile. Supports credit review documentation and exception management.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditRatingAgency rdf:type rdf:Property ;
    rdfs:label 'Credit Rating Agency' ;
    rdfs:comment 'Source or agency that issued the credit rating for this customer. Distinguishes between internally-derived ratings and third-party agency assessments used for credit risk management. [ENUM-REF-CANDIDATE: internal|dun_bradstreet|moody|sp|fitch|coface|euler_hermes — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditReviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Credit Review Frequency' ;
    rdfs:comment 'Frequency at which formal credit reviews are scheduled for this customer. Determined by credit risk tier and customer segment. Higher-risk customers require more frequent reviews.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditSegment rdf:type rdf:Property ;
    rdfs:label 'Credit Segment' ;
    rdfs:comment 'SAP S/4HANA credit segment identifier that groups customers under a common credit management policy and credit limit pool. Enables multi-segment credit management for customers operating across multiple business units or regions.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Status' ;
    rdfs:comment 'Current lifecycle status of the customer credit profile. Drives order release decisions in SAP S/4HANA SD and MES order management. \'on_hold\' and \'blocked\' prevent new order processing until resolved.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'Credit Utilization Pct' ;
    rdfs:comment 'Percentage of the approved credit limit currently consumed by the outstanding balance (outstanding_balance / credit_limit × 100). Triggers credit hold alerts when threshold is breached. Synchronized from SAP S/4HANA FI-AR credit exposure calculation.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dsoDays rdf:type rdf:Property ;
    rdfs:label 'Dso Days' ;
    rdfs:comment 'Days Sales Outstanding — the average number of days it takes the customer to pay invoices, calculated as (outstanding_balance / total_credit_sales) × number_of_days. A key KPI for accounts receivable performance and cash flow management per IFRS/GAAP reporting.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earlyPaymentDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Pct' ;
    rdfs:comment 'Percentage discount offered to the customer for early payment within the discount period defined in the payment terms (e.g., 2.00 for a 2% early payment discount). Null if no early payment discount applies.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastCreditReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Credit Review Date' ;
    rdfs:comment 'Date on which the most recent formal credit assessment was completed for this customer. Triggers next review scheduling and is used for credit governance compliance reporting.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastDunningDate rdf:type rdf:Property ;
    rdfs:label 'Last Dunning Date' ;
    rdfs:comment 'Date on which the most recent dunning notice was issued to the customer for overdue invoices. Used to track collections activity and enforce dunning intervals in SAP S/4HANA FI-AR.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextCreditReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Credit Review Date' ;
    rdfs:comment 'Scheduled date for the next formal credit review of this customer. Drives workflow alerts in SAP S/4HANA FI-AR and Salesforce CRM for proactive credit management.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oldestOverdueDays rdf:type rdf:Property ;
    rdfs:label 'Oldest Overdue Days' ;
    rdfs:comment 'Number of days since the oldest unpaid overdue invoice became due. Used for collections aging bucket analysis and bad debt provisioning triggers in SAP S/4HANA FI-AR.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'Total open accounts receivable balance currently owed by the customer in the account currency, as synchronized from SAP S/4HANA FI-AR. Includes all open invoices, debit memos, and unapplied credits. Used for credit utilization monitoring.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overdueAmount rdf:type rdf:Property ;
    rdfs:label 'Overdue Amount' ;
    rdfs:comment 'Total value of invoices that have exceeded their due date and remain unpaid, in the account currency. A subset of outstanding_balance. Used for collections prioritization and bad debt provisioning per IFRS 9 expected credit loss model.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBehaviorScore rdf:type rdf:Property ;
    rdfs:label 'Payment Behavior Score' ;
    rdfs:comment 'Internal scoring metric (0–100) reflecting the customer\'s historical payment behavior, including on-time payment rate, frequency of late payments, and average days late. Inputs into credit rating and risk category determination.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Number of calendar days from invoice date within which payment is due under the agreed payment terms (e.g., 30 for Net 30, 60 for Net 60, 90 for Net 90). Used for DSO calculation and cash flow forecasting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesforceAccountCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Account Code' ;
    rdfs:comment 'Salesforce CRM Account record ID for this customer, used for bi-directional synchronization of credit status and credit hold flags between SAP S/4HANA FI-AR and Salesforce CRM Sales Cloud.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCustomerAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Customer Account Number' ;
    rdfs:comment 'The externally-known SAP S/4HANA FI-AR customer account number (debtor number) used to uniquely identify the customer in the ERP system. Serves as the business identifier for cross-system reconciliation.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAccountCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Account Customer Account Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent customer_account record in the corporate hierarchy. Enables multi-level account hierarchy modeling (e.g., subsidiary → division → global parent). Null for top-level accounts.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:priceBookId rdf:type rdf:Property ;
    rdfs:label 'Price Book Id' ;
    rdfs:comment 'Identifier of the SAP S/4HANA pricing condition group or price list assigned to this customer. Determines applicable pricing, discounts, and surcharges during sales order creation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceBook .

ind:primaryCustomerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Customer Employee Id' ;
    rdfs:comment 'Identifier of the internal sales or account manager responsible for managing the customer relationship. References the Salesforce CRM User or Workday HCM employee record. Used for territory management and performance reporting.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primarySalesRepId rdf:type rdf:Property ;
    rdfs:label 'Primary Sales Rep Id' ;
    rdfs:comment 'Foreign key linking to sales.rep. Business justification: Primary sales rep on an account drives quota allocation, forecasting, and territory performance metrics in industrial manufacturing.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:primaryUltimateParentAccountCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Ultimate Parent Account Customer Account Id' ;
    rdfs:comment 'Identifier of the topmost entity in the corporate hierarchy for this customer account. Supports global account consolidation, enterprise-level revenue reporting, and strategic account management.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:salesTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Sales Territory Id' ;
    rdfs:comment 'Foreign key linking to sales.territory. Business justification: Direct FK to sales territory replaces the denormalized code, supporting territory-based reporting and incentive calculations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Foreign key linking to customer.customer_segment. Business justification: Linking account to its segment enables normalization of segment data and removes redundant string field.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:accountSource rdf:type rdf:Property ;
    rdfs:label 'Account Source' ;
    rdfs:comment 'Channel or method through which this customer account was originally acquired. Used for marketing attribution, channel effectiveness analysis, and sales pipeline reporting. [ENUM-REF-CANDIDATE: direct_sales|referral|trade_show|inbound_marketing|partner|acquisition|existing_relationship — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle state of the customer account. Controls whether transactions, orders, and service requests can be processed against this account. Managed in Salesforce CRM and synchronized to SAP S/4HANA.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualRevenue rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue' ;
    rdfs:comment 'Customer organization\'s most recently reported annual revenue in the account\'s local currency. Used for customer segmentation, credit risk assessment, and strategic account classification. Currency indicated by revenue_currency_code.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Billing State Province' ;
    rdfs:comment 'State or province of the customer\'s primary billing address. Used for tax jurisdiction determination, sales territory assignment, and regional reporting.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the credit_limit field. Ensures correct interpretation of the credit limit in multi-currency environments.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmAccountCode rdf:type rdf:Property ;
    rdfs:label 'Crm Account Code' ;
    rdfs:comment 'Native Account record ID from Salesforce CRM (Account object). Used to cross-reference the master record back to the operational source system for reconciliation and lineage tracing.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Nine-digit Dun & Bradstreet DUNS number uniquely identifying the customer\'s legal entity globally. Used for credit risk assessment, supplier/customer verification, and corporate hierarchy resolution.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeCount rdf:type rdf:Property ;
    rdfs:label 'Employee Count' ;
    rdfs:comment 'Total number of employees at the customer organization as reported or estimated. Used for customer segmentation (SMB vs. enterprise), credit risk scoring, and market sizing analytics.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incotermsCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Code' ;
    rdfs:comment 'ICC Incoterms code defining the agreed delivery and risk transfer conditions for shipments to this customer. Used in SAP S/4HANA SD sales order processing and logistics planning. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryNaicsCode rdf:type rdf:Property ;
    rdfs:label 'Industry Naics Code' ;
    rdfs:comment 'Six-digit NAICS code identifying the customer\'s primary industry sector per North American classification standards. Complements SIC code for more granular industry segmentation and analytics.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industrySicCode rdf:type rdf:Property ;
    rdfs:label 'Industry Sic Code' ;
    rdfs:comment 'Four-digit Standard Industrial Classification code identifying the customer\'s primary industry sector. Used for market segmentation, regulatory reporting, and credit risk assessment.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isStrategicAccount rdf:type rdf:Property ;
    rdfs:label 'Is Strategic Account' ;
    rdfs:comment 'Indicates whether this customer is designated as a strategic account requiring executive-level relationship management and customized service agreements. Strategic accounts receive dedicated account teams and priority support.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'Full registered legal name of the B2B customer organization as recorded in official corporate filings. Used for invoicing, contracts, and regulatory compliance. Must match the name on file with the relevant tax authority.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mdmGoldenRecordFlag rdf:type rdf:Property ;
    rdfs:label 'Mdm Golden Record Flag' ;
    rdfs:comment 'Indicates whether this record has been designated as the MDM golden (master) record for the customer entity after deduplication and survivorship processing in Informatica MDM. False indicates a candidate or survivor record pending promotion.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Language Code' ;
    rdfs:comment 'ISO 639-1 language code (optionally with ISO 3166-1 region suffix) indicating the customer\'s preferred language for communications, documents, and correspondence (e.g., en-US, de-DE, fr-FR).' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Revenue Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the annual_revenue field (e.g., USD, EUR, GBP). Required to correctly interpret the revenue figure for multi-currency global accounts.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrganizationCode rdf:type rdf:Property ;
    rdfs:label 'Sales Organization Code' ;
    rdfs:comment 'SAP S/4HANA sales organization code responsible for selling to this customer. Determines the legal entity, currency, and pricing procedures applicable to sales transactions.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapBusinessPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Sap Business Partner Code' ;
    rdfs:comment 'Business Partner number assigned in SAP S/4HANA (SD/FI modules). Enables cross-system reconciliation between Salesforce CRM and SAP ERP for order-to-cash and accounts receivable processes.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusDate rdf:type rdf:Property ;
    rdfs:label 'Status Date' ;
    rdfs:comment 'Date on which the current account_status became effective. Supports lifecycle history tracking and audit compliance. Used to calculate duration in current status for account health reporting.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Number' ;
    rdfs:comment 'Government-issued tax identification number for the customer\'s legal entity (e.g., EIN in the US, CRN in the UK). Required for invoicing, tax reporting, and regulatory compliance under IFRS/GAAP.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingName rdf:type rdf:Property ;
    rdfs:label 'Trading Name' ;
    rdfs:comment 'Commercial or brand name under which the customer operates if different from the legal entity name. Used in sales communications, account management, and CRM displays.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:website rdf:type rdf:Property ;
    rdfs:label 'Website' ;
    rdfs:comment 'Official website URL of the customer organization. Used for account research, digital engagement tracking, and customer profile enrichment.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerCertificationId rdf:type rdf:Property ;
    rdfs:label 'Customer Certification Id' ;
    rdfs:comment 'Unique surrogate identifier for each customer certification record in the silver layer lakehouse. Primary key for the customer_certification data product.' ;
    rdfs:domain ind:CustomerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Auditor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Certification audits are performed by internal auditors; tracking the employee provides audit trail and compliance reporting.' ;
    rdfs:domain ind:CustomerCertification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicableProductCategories rdf:type rdf:Property ;
    rdfs:label 'Applicable Product Categories' ;
    rdfs:comment 'Comma-separated list of product categories or commodity codes to which this certification applies, as declared in the certificate scope. Used to match certification coverage against specific procurement line items and OEM qualification requirements.' ;
    rdfs:domain ind:CustomerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bodyCountry rdf:type rdf:Property ;
    rdfs:label 'Body Country' ;
    rdfs:comment 'The ISO 3166-1 alpha-3 country code of the country where the certifying body is registered and operates (e.g., \'USA\', \'DEU\', \'GBR\'). Used for jurisdictional compliance analysis and accreditation authority mapping.' ;
    rdfs:domain ind:CustomerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaDueDate rdf:type rdf:Property ;
    rdfs:label 'Capa Due Date' ;
    rdfs:comment 'The deadline by which the customer must submit or complete their Corrective and Preventive Action (CAPA) plan to the certifying body or internal compliance team. Null when capa_required is False.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaRequired rdf:type rdf:Property ;
    rdfs:label 'Capa Required' ;
    rdfs:comment 'Indicates whether a Corrective and Preventive Action (CAPA) plan is required as a condition of maintaining or renewing this certification. Set to True when non-conformances have been identified that require formal corrective action.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ceMarkingApplicable rdf:type rdf:Property ;
    rdfs:label 'Ce Marking Applicable' ;
    rdfs:comment 'Indicates whether this certification is associated with or required for CE Marking (European Conformity) compliance. Relevant for customers supplying products to the European market under EU product safety directives.' ;
    rdfs:domain ind:CustomerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificateDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Certificate Document Url' ;
    rdfs:comment 'URL or path to the scanned or digital copy of the certificate document stored in the document management system (e.g., Siemens Teamcenter or SharePoint). Enables direct access to the source certificate for audit and verification purposes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationScope rdf:type rdf:Property ;
    rdfs:label 'Certification Scope' ;
    rdfs:comment 'The declared scope of the certification as stated on the certificate, describing the products, processes, or services covered (e.g., \'Design, manufacture, and supply of industrial automation components\'). Critical for determining applicability to specific procurement categories.' ;
    rdfs:domain ind:CustomerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:country rdf:type rdf:Property ;
    rdfs:label 'Country' ;
    rdfs:comment 'The ISO 3166-1 alpha-3 country code of the country in which the certification is valid or was issued (e.g., \'USA\', \'DEU\', \'CHN\'). Relevant for multi-national customers where certifications may be jurisdiction-specific.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Initial Certification Date' ;
    rdfs:comment 'The date on which the customer first obtained this certification standard, regardless of subsequent renewals. Used to calculate total years of certified operation and assess supplier maturity in qualification processes.' ;
    rdfs:domain ind:CustomerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isMultiSite rdf:type rdf:Property ;
    rdfs:label 'Is Multi Site' ;
    rdfs:comment 'Indicates whether this certificate covers multiple customer sites under a single certificate number (multi-site certification). When True, the certification scope applies to all sites listed in the certificate annex rather than a single facility.' ;
    rdfs:domain ind:CustomerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryCertification rdf:type rdf:Property ;
    rdfs:label 'Is Primary Certification' ;
    rdfs:comment 'Indicates whether this certification is the primary or most critical certification for the customer account within its certification type. Used to prioritize compliance checks and qualification gate decisions when a customer holds multiple certifications of the same type.' ;
    rdfs:domain ind:CustomerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingBodyAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Issuing Body Accreditation Number' ;
    rdfs:comment 'The accreditation number of the certification body as granted by a national accreditation authority (e.g., ANAB, UKAS, DAkkS). Enables verification that the issuing body is formally accredited to issue the specific standard.' ;
    rdfs:domain ind:CustomerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBodyName rdf:type rdf:Property ;
    rdfs:label 'Issuing Body Name' ;
    rdfs:comment 'The name of the accredited certification body or registrar that issued the certificate (e.g., \'Bureau Veritas\', \'TÜV Rheinland\', \'SGS\', \'DNV\', \'Intertek\'). Used to validate accreditation status and credibility of the certification.' ;
    rdfs:domain ind:CustomerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastSurveillanceAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Surveillance Audit Date' ;
    rdfs:comment 'The date of the most recent surveillance audit conducted by the certifying body to verify ongoing compliance. ISO management system certifications typically require annual surveillance audits between recertification cycles.' ;
    rdfs:domain ind:CustomerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextSurveillanceAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Surveillance Audit Date' ;
    rdfs:comment 'The scheduled date for the next surveillance audit by the certifying body. Used to proactively manage audit readiness and compliance calendar for the customer account.' ;
    rdfs:domain ind:CustomerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nonconformanceCount rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Count' ;
    rdfs:comment 'The number of open or unresolved non-conformances (NCRs) identified during the most recent audit cycle for this certification. A non-zero value may affect qualification eligibility and triggers CAPA (Corrective and Preventive Action) follow-up.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualificationEligibility rdf:type rdf:Property ;
    rdfs:label 'Qualification Eligibility' ;
    rdfs:comment 'Derived qualification eligibility status of the customer based on this certification, used in OEM qualification, distributor onboarding, and procurement approval workflows. \'eligible\' = meets all certification requirements; \'ineligible\' = does not meet requirements; \'conditional\' = meets requirements with conditions; \'under_review\' = eligibility being assessed.' ;
    rdfs:domain ind:CustomerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirementReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Reference' ;
    rdfs:comment 'Reference to the specific regulatory requirement, customer contract clause, or industry mandate that necessitates this certification (e.g., \'EU Machinery Directive 2006/42/EC\', \'OSHA 29 CFR 1910\', \'CE Marking Directive\'). Links the certification to its compliance obligation.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source Record Code' ;
    rdfs:comment 'The native record identifier from the originating source system (e.g., Salesforce CRM record ID, SAP Ariba document number). Enables traceability back to the system of record for reconciliation and data quality management.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ulListingNumber rdf:type rdf:Property ;
    rdfs:label 'Ul Listing Number' ;
    rdfs:comment 'The Underwriters Laboratories (UL) listing or file number associated with this certification, if applicable. Used for product safety certification tracking for customers supplying electrical or industrial components to North American markets.' ;
    rdfs:domain ind:CustomerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'The date on which the certification was last verified for authenticity and current validity by the internal compliance or procurement team. Used to ensure certifications are periodically re-validated and not relied upon without current confirmation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'The name or employee identifier of the internal compliance officer or procurement analyst who last verified the certification. Provides an audit trail for compliance accountability.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerDocumentId rdf:type rdf:Property ;
    rdfs:label 'Customer Document Id' ;
    rdfs:comment 'System-generated unique identifier for each customer document record.' ;
    rdfs:domain ind:CustomerDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:relatedContractSalesContractId rdf:type rdf:Property ;
    rdfs:label 'Related Contract Sales Contract Id' ;
    rdfs:comment 'Identifier of the contract that references this document.' ;
    rdfs:domain ind:CustomerDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesContract .

ind:customerDocumentDescription rdf:type rdf:Property ;
    rdfs:label 'Customer Document Description' ;
    rdfs:comment 'Free-form description of the document content and purpose.' ;
    rdfs:domain ind:CustomerDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerDocumentStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Document Status' ;
    rdfs:comment 'Current lifecycle status of the document.' ;
    rdfs:domain ind:CustomerDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentCategory rdf:type rdf:Property ;
    rdfs:label 'Document Category' ;
    rdfs:comment 'High-level business category of the document.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileName rdf:type rdf:Property ;
    rdfs:label 'File Name' ;
    rdfs:comment 'Original file name as stored in the document management system.' ;
    rdfs:domain ind:CustomerDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConfidential rdf:type rdf:Property ;
    rdfs:label 'Is Confidential' ;
    rdfs:comment 'Indicates whether the document contains confidential information.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mimeType rdf:type rdf:Property ;
    rdfs:label 'Mime Type' ;
    rdfs:comment 'Internet media type of the stored file.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tags rdf:type rdf:Property ;
    rdfs:label 'Tags' ;
    rdfs:comment 'Comma-separated business tags for classification and search.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uploadTimestamp rdf:type rdf:Property ;
    rdfs:label 'Upload Timestamp' ;
    rdfs:comment 'Date and time when the document was uploaded to the system.' ;
    rdfs:domain ind:CustomerDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:versionComment rdf:type rdf:Property ;
    rdfs:label 'Version Comment' ;
    rdfs:comment 'Free-form comment describing changes in this version.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedSegmentManager rdf:type rdf:Property ;
    rdfs:label 'Assigned Segment Manager' ;
    rdfs:comment 'Full name or employee identifier of the commercial manager responsible for owning the segment strategy, reviewing segment performance, and approving account assignments. Sourced from Salesforce CRM user records and Workday HCM.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'Indicates the go-to-market channel model applicable to this segment: Direct (manufacturer sells directly to end customer), Indirect (sales through distributors or channel partners), or Hybrid (combination of direct and indirect). Drives commercial policy and commission structures.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractRequired rdf:type rdf:Property ;
    rdfs:label 'Contract Required' ;
    rdfs:comment 'Indicates whether a formal master supply agreement or framework contract is mandatory for customer accounts in this segment before order processing can commence. Enforced in SAP S/4HANA SD order entry validation.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditLimitUsd rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Usd' ;
    rdfs:comment 'Standard credit limit in USD applied to customer accounts assigned to this segment. Used as the default credit exposure ceiling in SAP S/4HANA FI-AR credit management for new account onboarding within the segment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criteria rdf:type rdf:Property ;
    rdfs:label 'Criteria' ;
    rdfs:comment 'Structured definition of the qualifying rules and thresholds used to assign a customer account to this segment (e.g., annual revenue > $10M, OEM classification, multi-site deployment). Supports automated segmentation logic in Salesforce CRM and Informatica MDM.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmSegmentRecordCode rdf:type rdf:Property ;
    rdfs:label 'Crm Segment Record Code' ;
    rdfs:comment 'Native Salesforce CRM record identifier for the corresponding segment or account group object in Salesforce Sales Cloud. Used for bi-directional synchronization between the Databricks Silver Layer and the CRM system of record.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerAccountType rdf:type rdf:Property ;
    rdfs:label 'Customer Account Type' ;
    rdfs:comment 'Classification of the customer relationship type that this segment targets. OEM (Original Equipment Manufacturer) accounts receive differentiated pricing and co-development support; Distributors receive channel margin structures; End Users receive direct service SLAs; System Integrators and EPCs (Engineering, Procurement & Construction) receive project-based commercial terms.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dedicatedAccountManagerRequired rdf:type rdf:Property ;
    rdfs:label 'Dedicated Account Manager Required' ;
    rdfs:comment 'Indicates whether customer accounts in this segment require a dedicated named account manager assignment in Salesforce CRM. Strategic and Key Account segments typically require dedicated coverage; Transactional segments may use pooled inside sales resources.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discountRatePct rdf:type rdf:Property ;
    rdfs:label 'Discount Rate Pct' ;
    rdfs:comment 'Standard discount percentage applied to list prices for customers in this segment, expressed as a percentage (e.g., 12.50 = 12.5%). Confidential as it reflects commercial pricing strategy. Used in SAP S/4HANA SD pricing condition records.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:erpCustomerGroupCode rdf:type rdf:Property ;
    rdfs:label 'Erp Customer Group Code' ;
    rdfs:comment 'SAP S/4HANA SD customer group code (Kundengruppe) mapped to this segment. Used to apply segment-specific pricing conditions, output determination, and reporting groupings in the ERP system of record.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Primary geographic sales region associated with this segment definition (e.g., North America, EMEA, APAC, LATAM). Used to align segment management responsibilities with regional sales organizations and territory planning in Salesforce CRM. [ENUM-REF-CANDIDATE: North America|EMEA|APAC|LATAM|Greater China|South Asia|Middle East & Africa — promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxAccountCount rdf:type rdf:Property ;
    rdfs:label 'Max Account Count' ;
    rdfs:comment 'Maximum number of customer accounts permitted in this segment before a split or restructuring review is triggered. Ensures segment managers maintain adequate coverage quality. Null indicates no upper cap.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mdmSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Mdm Segment Code' ;
    rdfs:comment 'Informatica MDM golden record identifier for this segment definition. Ensures cross-system consistency of segment master data across Salesforce CRM, SAP S/4HANA, and Microsoft Dynamics 365 Supply Chain Management.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minAccountCount rdf:type rdf:Property ;
    rdfs:label 'Min Account Count' ;
    rdfs:comment 'Minimum number of customer accounts that should be assigned to this segment to maintain commercial viability and justify dedicated segment management resources. Used in segment health monitoring and portfolio planning.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:moqApplicable rdf:type rdf:Property ;
    rdfs:label 'Moq Applicable' ;
    rdfs:comment 'Indicates whether a Minimum Order Quantity (MOQ) policy applies to customer accounts in this segment. When True, the MOQ defined in SAP S/4HANA SD condition records is enforced during order entry for accounts in this segment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ndaRequired rdf:type rdf:Property ;
    rdfs:label 'Nda Required' ;
    rdfs:comment 'Indicates whether a Non-Disclosure Agreement (NDA) is required for customer accounts in this segment before sharing product roadmaps, engineering specifications, or pricing strategies. Relevant for Strategic and OEM segments involved in co-development programs.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownerEmail rdf:type rdf:Property ;
    rdfs:label 'Owner Email' ;
    rdfs:comment 'Business email address of the assigned segment manager. Used for automated notifications, review cycle reminders, and escalation routing in Salesforce CRM workflows. Classified confidential as it is an internal business contact.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingTierCode rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier Code' ;
    rdfs:comment 'Code referencing the applicable pricing tier in SAP S/4HANA SD condition records for customers assigned to this segment. Drives list price, discount matrix, and rebate eligibility. Confidential as it encodes commercial pricing strategy.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateEligible rdf:type rdf:Property ;
    rdfs:label 'Rebate Eligible' ;
    rdfs:comment 'Indicates whether customer accounts in this segment are eligible for volume-based rebate programs. When True, rebate agreements are activated in SAP S/4HANA SD rebate processing for qualifying accounts.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueBandCurrency rdf:type rdf:Property ;
    rdfs:label 'Revenue Band Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the revenue band thresholds (revenue_band_min and revenue_band_max) are denominated (e.g., USD, EUR, GBP). Ensures consistent multi-currency interpretation across global sales regions.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueBandMax rdf:type rdf:Property ;
    rdfs:label 'Revenue Band Max' ;
    rdfs:comment 'Maximum annual revenue threshold (in USD) that defines the upper boundary of the revenue band for this segment. Null indicates an open-ended upper bound (e.g., for the Strategic tier). Used in pricing tier assignment and SLA prioritization.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueBandMin rdf:type rdf:Property ;
    rdfs:label 'Revenue Band Min' ;
    rdfs:comment 'Minimum annual revenue threshold (in USD) that a customer account must meet to qualify for this segment. Used in conjunction with revenue_band_max to define the revenue band boundary for segmentation scoring.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewCycleMonths rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Months' ;
    rdfs:comment 'Frequency in months at which the segment definition, criteria, and account assignments are formally reviewed and validated by the segment manager and commercial leadership (e.g., 3 = quarterly, 6 = semi-annual, 12 = annual).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Detailed narrative description of the segment\'s commercial purpose, qualifying criteria, and strategic intent. Used by sales managers and account teams to understand segment boundaries and apply correct commercial policies.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable name of the customer segment (e.g., Strategic, Key Account, Growth, Transactional). Used in sales strategy, pricing tier assignment, and service prioritization workflows.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle state of the segment definition. Active segments are applied in commercial operations; Under Review segments are being reassessed during periodic review cycles; Archived segments are retired and no longer assigned to new accounts.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Classification of the segment into one of the four standard commercial tiers used by the industrial manufacturing sales organization: Strategic (top-tier OEM/enterprise accounts), Key Account (high-value recurring customers), Growth (emerging or expanding accounts), Transactional (low-frequency, price-driven buyers).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicePriorityLevel rdf:type rdf:Property ;
    rdfs:label 'Service Priority Level' ;
    rdfs:comment 'Service prioritization level for after-sales support and field service dispatch for customers in this segment. Critical and High priority segments receive preferential scheduling in Salesforce Service Cloud and Maximo work order queues.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTierCode rdf:type rdf:Property ;
    rdfs:label 'Sla Tier Code' ;
    rdfs:comment 'Code identifying the SLA tier assigned to customers in this segment, referencing the SLA agreement product. Determines response time commitments, field service priority, spare parts availability guarantees, and escalation paths in Salesforce Service Cloud and Maximo Asset Management.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Strategic Account Flag' ;
    rdfs:comment 'Indicates whether this segment is classified as a strategic segment requiring executive sponsorship, board-level visibility, and dedicated cross-functional account teams. Drives escalation routing and executive review cadence in Salesforce CRM.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetGrossMarginPct rdf:type rdf:Property ;
    rdfs:label 'Target Gross Margin Pct' ;
    rdfs:comment 'Target gross margin percentage for the segment, used in pricing strategy and commercial deal approval thresholds. Deals below this margin threshold require escalated approval for accounts in this segment. Confidential as it encodes commercial profitability strategy.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetRevenueUsd rdf:type rdf:Property ;
    rdfs:label 'Target Revenue Usd' ;
    rdfs:comment 'Annual revenue target in USD for the aggregate of all customer accounts assigned to this segment. Used in commercial planning, sales quota allocation, and KPI tracking against actual segment revenue performance.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerEntitlementId rdf:type rdf:Property ;
    rdfs:label 'Customer Entitlement Id' ;
    rdfs:comment 'Unique surrogate identifier for the customer entitlement record in the Databricks Silver Layer. Maps to the Salesforce Service Cloud Entitlement object primary key.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerEntitlement .

ind:autoRenew rdf:type rdf:Property ;
    rdfs:label 'Auto Renew' ;
    rdfs:comment 'Indicates whether this entitlement is configured to automatically renew upon expiry based on the parent SLA agreement terms. Drives renewal workflow triggers in Salesforce CRM and SAP S/4HANA SD.' ;
    rdfs:domain ind:CustomerEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessUnit rdf:type rdf:Property ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'The internal business unit or division of the manufacturing organization responsible for delivering the services covered by this entitlement (e.g., Automation Systems, Electrification Solutions, Smart Infrastructure). Used for revenue attribution and service capacity planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumedQuantity rdf:type rdf:Property ;
    rdfs:label 'Consumed Quantity' ;
    rdfs:comment 'The cumulative number of service units, incidents, visits, or licenses consumed against this entitlement to date. Updated each time a case, work order, or service event is closed and linked to this entitlement.' ;
    rdfs:domain ind:CustomerEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractLineNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Line Number' ;
    rdfs:comment 'The specific line item number within the parent sales or service contract (SAP S/4HANA SD contract) from which this entitlement was generated. Enables traceability from entitlement back to the originating commercial contract.' ;
    rdfs:domain ind:CustomerEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedValue rdf:type rdf:Property ;
    rdfs:label 'Contracted Value' ;
    rdfs:comment 'The total monetary value of the services covered by this entitlement as agreed in the commercial contract. Used for revenue recognition, deferred revenue tracking, and customer profitability analysis. Expressed in the currency defined by currency_code.' ;
    rdfs:domain ind:CustomerEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageScheduleCode rdf:type rdf:Property ;
    rdfs:label 'Coverage Schedule Code' ;
    rdfs:comment 'Reference to the operating hours / coverage schedule that defines when this entitlement\'s services are available (e.g., 8x5, 24x7, business hours only). Maps to the Salesforce Operating Hours object linked to the entitlement.' ;
    rdfs:domain ind:CustomerEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coverageType rdf:type rdf:Property ;
    rdfs:label 'Coverage Type' ;
    rdfs:comment 'Defines the mode of service delivery covered by this entitlement. \'on_site\' requires a field engineer visit; \'remote\' covers phone/digital support only; \'hybrid\' allows both; \'parts_only\' covers spare parts shipment without labor.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerEntitlementName rdf:type rdf:Property ;
    rdfs:label 'Customer Entitlement Name' ;
    rdfs:comment 'Human-readable name describing the entitlement, such as \'Gold Support – CNC Machining Line 2024\' or \'Preventive Maintenance – Automation Cell A\'. Used for display and search in service portals.' ;
    rdfs:domain ind:CustomerEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerEntitlementStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Entitlement Status' ;
    rdfs:comment 'Current lifecycle state of the entitlement record. \'active\' indicates the entitlement is valid and consumable; \'expired\' indicates the end date has passed; \'suspended\' indicates temporary hold pending review; \'pending_activation\' indicates awaiting contract confirmation.' ;
    rdfs:domain ind:CustomerEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementNumber rdf:type rdf:Property ;
    rdfs:label 'Entitlement Number' ;
    rdfs:comment 'Externally-known business identifier for the entitlement record, used in customer-facing communications, service portals, and cross-system references. Sourced from Salesforce Service Cloud.' ;
    rdfs:domain ind:CustomerEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementType rdf:type rdf:Property ;
    rdfs:label 'Entitlement Type' ;
    rdfs:comment 'Classification of the entitlement category defining what service or coverage the customer is entitled to. Drives service fulfillment routing and eligibility checks in Salesforce Service Cloud and SAP S/4HANA QM. [ENUM-REF-CANDIDATE: warranty|support_incident|preventive_maintenance|software_update|spare_parts_access|field_service_visit — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationContact rdf:type rdf:Property ;
    rdfs:label 'Escalation Contact' ;
    rdfs:comment 'Name or identifier of the designated escalation contact (internal or customer-side) for critical service issues under this entitlement. Used when standard response time milestones are breached.' ;
    rdfs:domain ind:CustomerEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographyRegion rdf:type rdf:Property ;
    rdfs:label 'Geography Region' ;
    rdfs:comment 'The geographic region where the entitlement\'s covered asset or customer account is located (e.g., EMEA, APAC, AMER). Used for service dispatch routing, regional SLA compliance reporting, and capacity planning.' ;
    rdfs:domain ind:CustomerEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPerpetual rdf:type rdf:Property ;
    rdfs:label 'Is Perpetual' ;
    rdfs:comment 'Indicates whether this entitlement has no expiry date and is valid indefinitely (e.g., perpetual software licenses or lifetime warranty on specific components). When True, end_date is expected to be null.' ;
    rdfs:domain ind:CustomerEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partsAccessEligible rdf:type rdf:Property ;
    rdfs:label 'Parts Access Eligible' ;
    rdfs:comment 'Indicates whether the customer is entitled to access spare parts under this entitlement. When True, the customer may order spare parts at contracted pricing or at no charge depending on the entitlement terms.' ;
    rdfs:domain ind:CustomerEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preventiveMaintenanceVisits rdf:type rdf:Property ;
    rdfs:label 'Preventive Maintenance Visits' ;
    rdfs:comment 'Total number of scheduled preventive maintenance visits allocated under this entitlement per contract period. Applicable to entitlements of type \'preventive_maintenance\'. Supports TPM (Total Productive Maintenance) planning.' ;
    rdfs:domain ind:CustomerEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preventiveMaintenanceVisitsUsed rdf:type rdf:Property ;
    rdfs:label 'Preventive Maintenance Visits Used' ;
    rdfs:comment 'Number of preventive maintenance visits already consumed against the allocated visits for this entitlement. Updated upon completion of each PM work order linked to this entitlement in Maximo or Salesforce.' ;
    rdfs:domain ind:CustomerEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityUnit rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit' ;
    rdfs:comment 'The unit of measure for the entitlement quantity fields (total, consumed, remaining). Examples: \'incident\' for support cases, \'visit\' for preventive maintenance, \'license\' for software seats, \'hour\' for service hours.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingQuantity rdf:type rdf:Property ;
    rdfs:label 'Remaining Quantity' ;
    rdfs:comment 'The number of service units, incidents, visits, or licenses still available for consumption under this entitlement (total_quantity minus consumed_quantity). Maintained as a stored field in Salesforce for real-time eligibility checks rather than computed on-the-fly.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionTimeHours rdf:type rdf:Property ;
    rdfs:label 'Resolution Time Hours' ;
    rdfs:comment 'Maximum number of hours within which a service issue must be fully resolved under this entitlement, as defined by the SLA tier. Drives escalation workflows and SLA breach alerts in Salesforce Service Cloud.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Response Time Hours' ;
    rdfs:comment 'Maximum number of hours within which the service team must respond to a service request under this entitlement, as defined by the SLA tier. Used for case routing and SLA compliance monitoring.' ;
    rdfs:domain ind:CustomerEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceHoursAllocation rdf:type rdf:Property ;
    rdfs:label 'Service Hours Allocation' ;
    rdfs:comment 'Total number of service hours allocated under this entitlement for on-site or remote support activities. Applicable primarily to time-and-materials or block-hour SLA entitlements. Null when the entitlement is incident-based rather than time-based.' ;
    rdfs:domain ind:CustomerEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceHoursConsumed rdf:type rdf:Property ;
    rdfs:label 'Service Hours Consumed' ;
    rdfs:comment 'Cumulative number of service hours consumed against the allocated service hours for this entitlement. Updated upon closure of service work orders or field service visits linked to this entitlement.' ;
    rdfs:domain ind:CustomerEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:softwareUpdateEligible rdf:type rdf:Property ;
    rdfs:label 'Software Update Eligible' ;
    rdfs:comment 'Indicates whether the customer is entitled to receive software updates, patches, or firmware upgrades for covered products under this entitlement. Relevant for PLC, SCADA, MES, and HMI software components.' ;
    rdfs:domain ind:CustomerEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sparePartsCreditLimit rdf:type rdf:Property ;
    rdfs:label 'Spare Parts Credit Limit' ;
    rdfs:comment 'Maximum monetary value of spare parts the customer may claim or order at no charge or at contracted pricing under this entitlement. Applicable when entitlement_type includes spare_parts_access. Expressed in currency_code.' ;
    rdfs:domain ind:CustomerEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Quantity' ;
    rdfs:comment 'The total number of service units, incidents, visits, or licenses originally allocated under this entitlement (e.g., 10 support incidents, 4 preventive maintenance visits, 5 software licenses). Represents the full allocation at entitlement creation.' ;
    rdfs:domain ind:CustomerEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyClaimEligible rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Eligible' ;
    rdfs:comment 'Indicates whether the customer is currently eligible to submit warranty claims under this entitlement. May be set to False if the entitlement is suspended, the asset has been modified outside approved parameters, or warranty conditions have been voided.' ;
    rdfs:domain ind:CustomerEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interactionId rdf:type rdf:Property ;
    rdfs:label 'Interaction Id' ;
    rdfs:comment 'Unique surrogate identifier for each customer interaction record in the silver layer lakehouse. Primary key for the interaction data product.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requestId rdf:type rdf:Property ;
    rdfs:label 'Request Id' ;
    rdfs:comment 'Reference to the customer service case or support ticket associated with this interaction, if applicable. Links interaction to after-sales support and CAPA processes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Request .

ind:slaAgreementId rdf:type rdf:Property ;
    rdfs:label 'Sla Agreement Id' ;
    rdfs:comment 'Reference to the SLA agreement governing the response and service standards applicable to this customer interaction. Enables SLA compliance monitoring for after-sales and service interactions.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaAgreement .

ind:campaignCode rdf:type rdf:Property ;
    rdfs:label 'Campaign Code' ;
    rdfs:comment 'Reference to the marketing campaign that originated or is associated with this interaction (e.g., trade show campaign, email nurture campaign). Links interaction to campaign ROI analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmActivityCode rdf:type rdf:Property ;
    rdfs:label 'Crm Activity Code' ;
    rdfs:comment 'External identifier of the corresponding Task or Event record in Salesforce CRM. Used for cross-system traceability and delta-load reconciliation from the source system of record.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalParticipants rdf:type rdf:Property ;
    rdfs:label 'External Participants' ;
    rdfs:comment 'Comma-separated list of customer-side participant names and roles who attended the interaction (e.g., \'John Smith - VP Engineering, Jane Doe - Procurement Manager\'). Classified confidential as it contains customer personnel information.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpDueDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Due Date' ;
    rdfs:comment 'Target date by which the follow-up action resulting from this interaction must be completed. Used for account manager task management and SLA tracking.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required' ;
    rdfs:comment 'Indicates whether a follow-up action or subsequent interaction is required as a result of this interaction. Drives task creation and account manager workflow.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interactionDate rdf:type rdf:Property ;
    rdfs:label 'Interaction Date' ;
    rdfs:comment 'The calendar date on which the customer interaction took place. Used for day-level scheduling, reporting, and relationship cadence analysis.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interactionDescription rdf:type rdf:Property ;
    rdfs:label 'Interaction Description' ;
    rdfs:comment 'Detailed narrative of the interaction content, topics discussed, key decisions made, and context. Supports relationship history review and account management continuity.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionSource rdf:type rdf:Property ;
    rdfs:label 'Interaction Source' ;
    rdfs:comment 'System or method through which this interaction record was created or ingested. Supports data lineage tracking and source system reconciliation in the lakehouse silver layer.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionStatus rdf:type rdf:Property ;
    rdfs:label 'Interaction Status' ;
    rdfs:comment 'Current lifecycle state of the interaction record. Tracks whether the interaction has been planned, is underway, has been completed, or was cancelled or deferred.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionType rdf:type rdf:Property ;
    rdfs:label 'Interaction Type' ;
    rdfs:comment 'Classification of the nature of the customer interaction. Distinguishes between sales-driven, technical, executive, and survey touchpoints. [ENUM-REF-CANDIDATE: sales_call|site_visit|product_demo|technical_consultation|executive_briefing|trade_show_meeting|nps_survey|email_outreach — promote to reference product]' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalParticipants rdf:type rdf:Property ;
    rdfs:label 'Internal Participants' ;
    rdfs:comment 'Comma-separated list of internal employee names or IDs who participated in the interaction (e.g., account manager, field application engineer, product specialist, executive sponsor). Supports multi-stakeholder engagement tracking.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCustomerComplaint rdf:type rdf:Property ;
    rdfs:label 'Is Customer Complaint' ;
    rdfs:comment 'Indicates whether this interaction involved a formal or informal customer complaint. Triggers CAPA workflow and quality management escalation per ISO 9001 requirements.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isExecutiveSponsorInvolved rdf:type rdf:Property ;
    rdfs:label 'Is Executive Sponsor Involved' ;
    rdfs:comment 'Indicates whether an executive sponsor (C-level or VP-level) from the company participated in this interaction. Flags high-touch executive engagement for strategic account management reporting.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextInteractionDate rdf:type rdf:Property ;
    rdfs:label 'Next Interaction Date' ;
    rdfs:comment 'Planned date for the next scheduled customer interaction as agreed during this interaction. Supports proactive account management cadence and relationship continuity planning.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:npsScore rdf:type rdf:Property ;
    rdfs:label 'Nps Score' ;
    rdfs:comment 'Net Promoter Score captured during customer satisfaction survey interactions. Integer value on a 0–10 scale where 0–6 = Detractor, 7–8 = Passive, 9–10 = Promoter. Null for non-survey interaction types.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outcomeNotes rdf:type rdf:Property ;
    rdfs:label 'Outcome Notes' ;
    rdfs:comment 'Free-text notes elaborating on the interaction outcome, including specific commitments made, objections raised, or next steps agreed upon with the customer.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantCount rdf:type rdf:Property ;
    rdfs:label 'Participant Count' ;
    rdfs:comment 'Total number of participants (internal and external combined) who attended the interaction. Used for engagement scale analysis and resource planning.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productLine rdf:type rdf:Property ;
    rdfs:label 'Product Line' ;
    rdfs:comment 'The primary product line or solution portfolio discussed during the interaction (e.g., \'Automation Systems\', \'Electrification Solutions\', \'Smart Infrastructure\'). Supports product-level engagement analytics.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:satisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Satisfaction Rating' ;
    rdfs:comment 'Customer satisfaction rating on a 1–5 scale collected at the end of the interaction (1 = Very Dissatisfied, 5 = Very Satisfied). Applicable to service calls, technical consultations, and post-delivery reviews.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sentimentCategory rdf:type rdf:Property ;
    rdfs:label 'Sentiment Category' ;
    rdfs:comment 'Categorized sentiment of the interaction as assessed by the interaction owner or derived from verbatim feedback analysis. Supports relationship health scoring and early warning detection for at-risk accounts.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Short descriptive title or subject line summarizing the purpose of the interaction (e.g., \'Q3 Automation System Review\', \'PLC Upgrade Technical Demo\'). Maps to Salesforce CRM Activity Subject field.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verbatimFeedback rdf:type rdf:Property ;
    rdfs:label 'Verbatim Feedback' ;
    rdfs:comment 'Unstructured, verbatim text feedback provided by the customer during or after the interaction. Captured for voice-of-customer (VoC) analysis, sentiment analysis, and continuous improvement programs. Classified confidential as it contains customer-specific business opinions.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerLeadId rdf:type rdf:Property ;
    rdfs:label 'Customer Lead Id' ;
    rdfs:comment 'Unique surrogate identifier for the sales lead record in the Databricks Silver Layer. Primary key for the lead data product.' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedSalesRepId rdf:type rdf:Property ;
    rdfs:label 'Assigned Sales Rep Id' ;
    rdfs:comment 'Reference to the internal sales representative or account executive assigned to own and work this lead through the qualification and conversion process.' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:interestedSkuMasterId rdf:type rdf:Property ;
    rdfs:label 'Interested Sku Master Id' ;
    rdfs:comment 'Foreign key linking to product.sku_master. Business justification: Supports lead qualification by capturing the exact SKU a prospect is interested in, driving accurate forecasting and targeted marketing.' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuMaster .

ind:annualEnergyConsumptionMwh rdf:type rdf:Property ;
    rdfs:label 'Annual Energy Consumption Mwh' ;
    rdfs:comment 'Estimated annual energy consumption of the prospective customer\'s facilities in megawatt-hours. Key qualification criterion for electrification and energy management solution sales (ISO 50001 alignment).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buyingStage rdf:type rdf:Property ;
    rdfs:label 'Buying Stage' ;
    rdfs:comment 'Estimated stage in the buyer\'s journey for this lead based on engagement signals and sales rep assessment. Informs content strategy and sales approach for industrial automation solutions.' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyIndustry rdf:type rdf:Property ;
    rdfs:label 'Company Industry' ;
    rdfs:comment 'Industry vertical of the prospective company (e.g., Automotive, Food & Beverage, Oil & Gas, Utilities, Building Automation, Transportation). Used for segmentation and targeted product positioning. [ENUM-REF-CANDIDATE: Automotive|Food & Beverage|Oil & Gas|Utilities|Building Automation|Transportation|Pharmaceuticals|Metals & Mining|Chemicals|Data Centers — promote to reference product]' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyName rdf:type rdf:Property ;
    rdfs:label 'Company Name' ;
    rdfs:comment 'Legal or trading name of the prospective customer organization. Represents the B2B account target for industrial automation, electrification, or smart infrastructure products.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companySize rdf:type rdf:Property ;
    rdfs:label 'Company Size' ;
    rdfs:comment 'Employee headcount band of the prospective organization. Used for lead scoring, segmentation, and determining appropriate sales motion (inside sales vs. field sales vs. enterprise).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionDate rdf:type rdf:Property ;
    rdfs:label 'Conversion Date' ;
    rdfs:comment 'Date on which the lead was formally converted to a customer account and opportunity. Null for unconverted leads. Used for sales cycle duration analysis and conversion rate reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disqualificationReason rdf:type rdf:Property ;
    rdfs:label 'Disqualification Reason' ;
    rdfs:comment 'Reason code explaining why the lead was disqualified using the BANT (Budget, Authority, Need, Timeline) framework or other criteria. Populated when lead_status = \'Disqualified\'. Used for funnel quality analysis. [ENUM-REF-CANDIDATE: No Budget|No Authority|No Need|No Timeline|Competitor|Duplicate|Invalid Data|Opted Out — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotContact rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact' ;
    rdfs:comment 'Indicates whether the lead contact has opted out of all sales and marketing communications. When True, all outreach must cease immediately to comply with GDPR, CAN-SPAM, and CASL regulations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedAnnualRevenue rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Revenue' ;
    rdfs:comment 'Estimated annual revenue of the prospective company in USD. Used for lead scoring, account tiering, and prioritization of sales resources. Sourced from public data, third-party enrichment, or sales rep input.' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedCloseDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Close Date' ;
    rdfs:comment 'Sales representative\'s estimated date by which the lead could be converted to a qualified opportunity or closed deal. Used for pipeline timing and sales cycle analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedDealValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Deal Value' ;
    rdfs:comment 'Sales representative\'s estimate of the potential deal value in the revenue_currency if the lead converts to an opportunity. Used for pipeline forecasting and sales territory planning.' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:existingAutomationVendor rdf:type rdf:Property ;
    rdfs:label 'Existing Automation Vendor' ;
    rdfs:comment 'Name of the incumbent automation or electrification vendor currently deployed at the prospective customer\'s facilities (e.g., ABB, Rockwell, Schneider). Critical competitive intelligence for sales strategy and displacement campaigns.' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grade rdf:type rdf:Property ;
    rdfs:label 'Grade' ;
    rdfs:comment 'Alphabetic grade (A–D) representing the lead\'s firmographic fit against the Ideal Customer Profile (ICP) for industrial automation and electrification products. Complements lead_score which measures behavioral engagement.' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConverted rdf:type rdf:Property ;
    rdfs:label 'Is Converted' ;
    rdfs:comment 'Boolean flag indicating whether this lead has been successfully converted to a customer account, contact, and opportunity in the CRM. True when lead_status = \'Converted\'.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadStatus rdf:type rdf:Property ;
    rdfs:label 'Lead Status' ;
    rdfs:comment 'Current lifecycle stage of the sales lead in the qualification funnel. \'New\' = uncontacted; \'Working\' = active outreach in progress; \'Qualified\' = meets ICP criteria; \'Converted\' = converted to customer_account; \'Disqualified\' = does not meet criteria or opted out.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadType rdf:type rdf:Property ;
    rdfs:label 'Lead Type' ;
    rdfs:comment 'Classification of the lead by origination motion and relationship type. Distinguishes inbound (self-generated interest) from outbound (sales-initiated), and identifies OEM, distributor, or direct end-user engagement models.' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextFollowUpDate rdf:type rdf:Property ;
    rdfs:label 'Next Follow Up Date' ;
    rdfs:comment 'Scheduled date for the next sales follow-up action on this lead. Used by sales reps for pipeline management and by sales managers for activity monitoring.' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:noOfEmployees rdf:type rdf:Property ;
    rdfs:label 'No Of Employees' ;
    rdfs:comment 'Exact or estimated number of employees at the prospective company. Used alongside company_size band for more precise lead scoring and account tiering.' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:noOfProductionSites rdf:type rdf:Property ;
    rdfs:label 'No Of Production Sites' ;
    rdfs:comment 'Estimated number of manufacturing plants, production facilities, or operational sites operated by the prospective company. Used to assess deal complexity, multi-site deployment potential, and enterprise account classification.' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plcInstalledBase rdf:type rdf:Property ;
    rdfs:label 'Plc Installed Base' ;
    rdfs:comment 'Description of the existing PLC (Programmable Logic Controller) installed base at the prospect\'s facilities (e.g., \'Siemens S7-300\', \'Allen-Bradley ControlLogix\'). Used to assess upgrade/migration opportunity and compatibility.' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productInterestArea rdf:type rdf:Property ;
    rdfs:label 'Product Interest Area' ;
    rdfs:comment 'Primary product category or solution area the lead has expressed interest in. Drives sales rep assignment, product specialist routing, and targeted content delivery. [ENUM-REF-CANDIDATE: Drives|PLCs|Switchgear|Building Automation|Grid Solutions|Motion Control|Industrial IoT|SCADA|HMI|Robotics — promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralPartnerName rdf:type rdf:Property ;
    rdfs:label 'Referral Partner Name' ;
    rdfs:comment 'Name of the channel partner, distributor, OEM, or system integrator who referred this lead. Populated when lead_source is \'Partner Referral\' or \'Referral\'. Used for partner performance tracking and commission attribution.' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueCurrency rdf:type rdf:Property ;
    rdfs:label 'Revenue Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the estimated_annual_revenue field (e.g., USD, EUR, GBP). Enables multi-currency normalization for global lead management.' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesTerritory rdf:type rdf:Property ;
    rdfs:label 'Sales Territory' ;
    rdfs:comment 'Geographic or account-based sales territory to which this lead is assigned (e.g., EMEA-North, APAC-Industrial, NA-Midwest). Drives sales rep routing and territory performance reporting.' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceLeadCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Lead Code' ;
    rdfs:comment 'Native Salesforce CRM Lead object identifier (18-character Salesforce ID) used for cross-system traceability and synchronization with the source system of record.' ;
    rdfs:domain ind:CustomerLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:score rdf:type rdf:Property ;
    rdfs:label 'Score' ;
    rdfs:comment 'Numeric score (typically 0–100) representing the lead\'s likelihood to convert based on behavioral signals, firmographic fit, and engagement data. Used for prioritization and sales rep workload management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerOnboardingId rdf:type rdf:Property ;
    rdfs:label 'Customer Onboarding Id' ;
    rdfs:comment 'Unique system-generated identifier for the customer onboarding record. Primary key for the onboarding data product in the customer domain.' ;
    rdfs:domain ind:CustomerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountSegment rdf:type rdf:Property ;
    rdfs:label 'Account Segment' ;
    rdfs:comment 'Business segment classification of the customer account, used to prioritize onboarding resources and apply segment-specific SLA targets.' ;
    rdfs:domain ind:CustomerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'The actual date on which the customer onboarding was fully completed and the account achieved first-order readiness. Null if onboarding is still in progress.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignedSalesRegion rdf:type rdf:Property ;
    rdfs:label 'Assigned Sales Region' ;
    rdfs:comment 'The sales region to which the customer account is assigned, used for coordinator assignment, reporting, and regional SLA management.' ;
    rdfs:domain ind:CustomerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockerCategory rdf:type rdf:Property ;
    rdfs:label 'Blocker Category' ;
    rdfs:comment 'Categorical classification of the onboarding blocker type, enabling root cause analysis and process improvement reporting across the onboarding program. [ENUM-REF-CANDIDATE: credit|compliance|edi_technical|erp_setup|customer_response|internal_process|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CustomerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockerDescription rdf:type rdf:Property ;
    rdfs:label 'Blocker Description' ;
    rdfs:comment 'Free-text description of any current impediment or blocker preventing the onboarding from progressing. Captures the nature of the issue for escalation and resolution tracking.' ;
    rdfs:domain ind:CustomerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistCompletionPct rdf:type rdf:Property ;
    rdfs:label 'Checklist Completion Pct' ;
    rdfs:comment 'The percentage of onboarding checklist items that have been marked as completed. Provides a quantitative measure of onboarding progress (0.00 to 100.00).' ;
    rdfs:domain ind:CustomerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completedChecklistItems rdf:type rdf:Property ;
    rdfs:label 'Completed Checklist Items' ;
    rdfs:comment 'The number of onboarding checklist items that have been completed and verified. Numerator for checklist completion percentage.' ;
    rdfs:domain ind:CustomerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Check Status' ;
    rdfs:comment 'Status of mandatory regulatory and trade compliance screening for the new customer, including export control, sanctions screening, and anti-bribery checks.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Contract Signature Date' ;
    rdfs:comment 'The date on which the customer signed the contract, marking the official start trigger for the onboarding workflow.' ;
    rdfs:domain ind:CustomerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditLimitApproved rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Approved' ;
    rdfs:comment 'The approved credit limit amount (in base currency) assigned to the customer account during onboarding. Established by the finance team as part of credit setup.' ;
    rdfs:domain ind:CustomerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditSetupStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Setup Status' ;
    rdfs:comment 'Current status of the credit limit and payment terms setup for the new customer account in SAP S/4HANA FI. A prerequisite for first order processing.' ;
    rdfs:domain ind:CustomerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerPrimaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Customer Primary Contact Email' ;
    rdfs:comment 'Email address of the primary contact person at the customer organization for onboarding communications and coordination.' ;
    rdfs:domain ind:CustomerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerPrimaryContactName rdf:type rdf:Property ;
    rdfs:label 'Customer Primary Contact Name' ;
    rdfs:comment 'Full name of the primary contact person at the customer organization responsible for coordinating the onboarding process on the customer side.' ;
    rdfs:domain ind:CustomerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediSetupStatus rdf:type rdf:Property ;
    rdfs:label 'Edi Setup Status' ;
    rdfs:comment 'Current status of the Electronic Data Interchange (EDI) integration setup for the customer. Tracks configuration, testing, and go-live of EDI order transmission channels.' ;
    rdfs:domain ind:CustomerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpAccountCreatedFlag rdf:type rdf:Property ;
    rdfs:label 'Erp Account Created Flag' ;
    rdfs:comment 'Indicates whether the customer master record has been successfully created in SAP S/4HANA. A mandatory prerequisite for order processing and invoicing.' ;
    rdfs:domain ind:CustomerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:erpCustomerNumber rdf:type rdf:Property ;
    rdfs:label 'Erp Customer Number' ;
    rdfs:comment 'The customer account number assigned in SAP S/4HANA upon master data creation. Used to link the onboarding record to the ERP customer master.' ;
    rdfs:domain ind:CustomerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'The date on which the onboarding case was formally escalated. Null if no escalation has occurred.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exportControlClassification rdf:type rdf:Property ;
    rdfs:label 'Export Control Classification' ;
    rdfs:comment 'Export control compliance classification for the customer, indicating whether the account is cleared for shipment of controlled goods under applicable trade regulations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstOrderDate rdf:type rdf:Property ;
    rdfs:label 'First Order Date' ;
    rdfs:comment 'The date on which the customer placed their first order following successful onboarding. Used to measure time-to-revenue and validate onboarding effectiveness.' ;
    rdfs:domain ind:CustomerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstOrderReadinessFlag rdf:type rdf:Property ;
    rdfs:label 'First Order Readiness Flag' ;
    rdfs:comment 'Indicates whether all onboarding prerequisites have been met and the customer account is fully ready to place and process its first order. The primary success criterion for onboarding completion.' ;
    rdfs:domain ind:CustomerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Initiated Timestamp' ;
    rdfs:comment 'The exact date and time when the onboarding record was created and the activation workflow was formally initiated in the system.' ;
    rdfs:domain ind:CustomerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ndaSignedFlag rdf:type rdf:Property ;
    rdfs:label 'Nda Signed Flag' ;
    rdfs:comment 'Indicates whether a Non-Disclosure Agreement (NDA) has been executed with the customer. Required for OEM and strategic accounts before sharing proprietary product or engineering data.' ;
    rdfs:domain ind:CustomerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onboardingNumber rdf:type rdf:Property ;
    rdfs:label 'Onboarding Number' ;
    rdfs:comment 'Externally visible, human-readable reference number for the onboarding case, used in communications with the customer and internal teams. Format: ONB-YYYY-NNNNNN.' ;
    rdfs:domain ind:CustomerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingStatus rdf:type rdf:Property ;
    rdfs:label 'Onboarding Status' ;
    rdfs:comment 'Current lifecycle state of the onboarding workflow. Tracks progression from initiation through full account activation. Values: not_started, in_progress, on_hold, completed, cancelled.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portalSetupStatus rdf:type rdf:Property ;
    rdfs:label 'Portal Setup Status' ;
    rdfs:comment 'Current status of the customer self-service portal account provisioning, including login credentials, access rights, and order management capabilities.' ;
    rdfs:domain ind:CustomerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingSetupStatus rdf:type rdf:Property ;
    rdfs:label 'Pricing Setup Status' ;
    rdfs:comment 'Current status of the customer-specific pricing configuration in SAP S/4HANA SD, including contract pricing, volume discounts, and special pricing agreements.' ;
    rdfs:domain ind:CustomerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityAgreementSignedFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Agreement Signed Flag' ;
    rdfs:comment 'Indicates whether a formal quality agreement has been signed with the customer, defining quality standards, inspection requirements, and CAPA (Corrective and Preventive Action) processes.' ;
    rdfs:domain ind:CustomerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Indicates whether the onboarding has breached or is at risk of breaching the agreed SLA target completion date. True if the actual or projected completion date exceeds the SLA target.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetDays rdf:type rdf:Property ;
    rdfs:label 'Sla Target Days' ;
    rdfs:comment 'The contractually or operationally agreed number of calendar days within which the onboarding must be completed from contract signature. Drives SLA compliance reporting.' ;
    rdfs:domain ind:CustomerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'Current named stage within the onboarding workflow, representing the active phase of the structured activation process (e.g., Contract Review, Credit Setup, System Configuration, Training, First Order Readiness). [ENUM-REF-CANDIDATE: contract_review|credit_setup|erp_account_creation|edi_portal_setup|pricing_setup|training|first_order_readiness — promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Certificate Number' ;
    rdfs:comment 'The official certificate number of the customer\'s tax exemption document. Required for tax-exempt account configuration in SAP S/4HANA FI.' ;
    rdfs:domain ind:CustomerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Flag' ;
    rdfs:comment 'Indicates whether the customer has a valid tax exemption certificate on file. Affects tax configuration in SAP S/4HANA during account setup.' ;
    rdfs:domain ind:CustomerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:templateCode rdf:type rdf:Property ;
    rdfs:label 'Template Code' ;
    rdfs:comment 'The code identifying the onboarding workflow template applied to this account. Templates vary by account type (OEM, distributor, end-user) and define the required checklist items and stage sequence.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Training Completed Flag' ;
    rdfs:comment 'Indicates whether the customer has completed all required product, portal, and ordering process training sessions as part of the onboarding checklist.' ;
    rdfs:domain ind:CustomerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Training Completion Date' ;
    rdfs:comment 'The date on which the customer completed all mandatory onboarding training sessions. Null if training has not yet been completed.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agreementName rdf:type rdf:Property ;
    rdfs:label 'Agreement Name' ;
    rdfs:comment 'Descriptive name of the SLA agreement as displayed in Salesforce Service Cloud and customer-facing documents (e.g., \'Platinum Support SLA — Acme Automation 2024\'). Used for identification and reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known, human-readable unique reference number for the SLA agreement as assigned in Salesforce Service Cloud (e.g., SLA-2024-00123). Used in customer communications, contract documents, and cross-system references.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle state of the SLA agreement: draft (under negotiation), active (in force), suspended (temporarily paused), expired (past end date without renewal), or terminated (cancelled before end date). Governs whether SLA commitments are enforceable.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualFee rdf:type rdf:Property ;
    rdfs:label 'Annual Fee' ;
    rdfs:comment 'The recurring annual fee charged to the customer for the SLA agreement, in the agreement currency. Used for revenue recognition, billing scheduling in SAP S/4HANA SD, and profitability analysis.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autoRenewal rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal' ;
    rdfs:comment 'Indicates whether the SLA agreement automatically renews upon expiry without requiring a new contract signature. True = auto-renews; False = requires explicit renewal action. Drives renewal workflow automation in Salesforce Service Cloud.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Contract Document Ref' ;
    rdfs:comment 'Reference identifier or URL to the signed SLA contract document stored in the document management system (e.g., Siemens Teamcenter PLM or SharePoint). Enables traceability to the original legal document.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractValue rdf:type rdf:Property ;
    rdfs:label 'Contract Value' ;
    rdfs:comment 'The total monetary value of the SLA agreement over its full term, expressed in the agreement currency. Used for financial reporting, revenue recognition under IFRS 15/ASC 606, and penalty cap calculations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coveredAssetCount rdf:type rdf:Property ;
    rdfs:label 'Covered Asset Count' ;
    rdfs:comment 'The number of individual equipment units, machines, or installed assets covered under this SLA agreement. Used for capacity planning of field service resources and Maximo Asset Management integration.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fieldServiceIncluded rdf:type rdf:Property ;
    rdfs:label 'Field Service Included' ;
    rdfs:comment 'Indicates whether on-site field service visits are included in the SLA agreement. True = field service dispatches are covered; False = remote support only. Drives field service scheduling and resource allocation in Salesforce Field Service.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initialResponseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Initial Response Time Hours' ;
    rdfs:comment 'The maximum number of hours within which the service team must provide an initial acknowledgment or response to a customer-reported incident or service request under this SLA. A core contractual KPI metric tracked in Salesforce Service Cloud.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxAnnualServiceVisits rdf:type rdf:Property ;
    rdfs:label 'Max Annual Service Visits' ;
    rdfs:comment 'The maximum number of on-site service visits (preventive or corrective) included per year under this SLA agreement. Null if unlimited or not applicable. Used for field service capacity planning and entitlement consumption tracking.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onTimeDeliveryTargetPct rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Target Pct' ;
    rdfs:comment 'The contractually committed minimum percentage of orders or shipments that must be delivered on or before the promised delivery date under this SLA. Applicable for on_time_delivery SLA types. Tracked against SAP S/4HANA SD delivery performance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentContractRef rdf:type rdf:Property ;
    rdfs:label 'Parent Contract Ref' ;
    rdfs:comment 'Reference number of the master or parent commercial contract (e.g., Master Service Agreement or Framework Agreement) under which this SLA agreement is issued. Enables hierarchical contract traceability in SAP S/4HANA SD.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyCapPct rdf:type rdf:Property ;
    rdfs:label 'Penalty Cap Pct' ;
    rdfs:comment 'The maximum cumulative penalty or service credit that can be applied over the agreement period, expressed as a percentage of the total contract value. Limits the company\'s financial liability exposure from SLA breaches.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyClauseApplicable rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause Applicable' ;
    rdfs:comment 'Indicates whether financial or service credit penalties apply to this SLA agreement when contractual thresholds are breached. True = penalty clauses are active; False = no penalty provisions. Drives financial exposure tracking and CAPA processes.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyCreditPct rdf:type rdf:Property ;
    rdfs:label 'Penalty Credit Pct' ;
    rdfs:comment 'The percentage of the contracted service fee or invoice value that is credited or refunded to the customer for each SLA breach event, as defined in the penalty clause. Null when penalty_clause_applicable is False.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preventiveMaintenanceIncluded rdf:type rdf:Property ;
    rdfs:label 'Preventive Maintenance Included' ;
    rdfs:comment 'Indicates whether scheduled preventive maintenance visits are included as part of the SLA agreement entitlement. True = preventive maintenance is covered; False = corrective/reactive only. Linked to TPM programs managed in Maximo.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productLineScope rdf:type rdf:Property ;
    rdfs:label 'Product Line Scope' ;
    rdfs:comment 'Description of the specific product lines, equipment categories, or automation system families covered under this SLA agreement (e.g., \'CNC Machining Centers\', \'PLC Control Systems\', \'Electrification Solutions\'). Defines the boundary of service coverage.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteMonitoringIncluded rdf:type rdf:Property ;
    rdfs:label 'Remote Monitoring Included' ;
    rdfs:comment 'Indicates whether IIoT-based remote monitoring and diagnostics of covered assets is included in the SLA agreement. True = remote monitoring via Aveva SCADA or IIoT platform is active; False = not included.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'The number of calendar days before the expiry date by which either party must provide written notice of intent to renew or terminate the SLA agreement. Triggers automated renewal alerts in Salesforce Service Cloud.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceRegion rdf:type rdf:Property ;
    rdfs:label 'Service Region' ;
    rdfs:comment 'The primary geographic region where the SLA service commitments apply, expressed as an ISO 3166-1 alpha-3 country code (e.g., USA, DEU, GBR). Determines applicable regulatory requirements, support staffing, and logistics SLA parameters.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTier rdf:type rdf:Property ;
    rdfs:label 'Service Tier' ;
    rdfs:comment 'The contractual service tier level assigned to this SLA agreement, determining the priority, response speed, and entitlements available to the customer. Platinum is the highest tier; Bronze is the base tier. Drives case prioritization in Salesforce Service Cloud.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaType rdf:type rdf:Property ;
    rdfs:label 'Sla Type' ;
    rdfs:comment 'Classification of the SLA agreement by the primary service commitment it governs: response_time (initial response to incidents), uptime_guarantee (system/equipment availability), on_time_delivery (order fulfillment punctuality), support_entitlement (support tier access), or maintenance_coverage (preventive/corrective maintenance). [ENUM-REF-CANDIDATE: response_time|uptime_guarantee|on_time_delivery|support_entitlement|maintenance_coverage|field_service — promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sparePartsIncluded rdf:type rdf:Property ;
    rdfs:label 'Spare Parts Included' ;
    rdfs:comment 'Indicates whether the cost of spare parts and replacement components is covered under this SLA agreement. True = parts included; False = parts billed separately. Impacts inventory planning in SAP S/4HANA MM and WMS.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportHoursCoverage rdf:type rdf:Property ;
    rdfs:label 'Support Hours Coverage' ;
    rdfs:comment 'The contracted support availability window defining hours per day and days per week during which the service team is obligated to respond (e.g., 8x5 = 8 hours/day, 5 days/week; 24x7 = round-the-clock). Determines staffing and escalation routing in Salesforce Service Cloud.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'The actual date on which the SLA agreement was terminated prior to its scheduled expiry date. Null for agreements that are active or expired naturally. Required for financial accrual reversal and CAPA closure in SAP S/4HANA.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:uptimeTargetPct rdf:type rdf:Property ;
    rdfs:label 'Uptime Target Pct' ;
    rdfs:comment 'The contractually committed minimum system or equipment availability expressed as a percentage (e.g., 99.5 for 99.5% uptime). Applicable for uptime_guarantee SLA types. Used in OEE and availability reporting.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bomId rdf:type rdf:Property ;
    rdfs:label 'Bom Id' ;
    rdfs:comment 'Unique identifier for the Bill of Materials record. Primary key for the BOM master data entity.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bom .

ind:alternativeBomIndicator rdf:type rdf:Property ;
    rdfs:label 'Alternative Bom Indicator' ;
    rdfs:comment 'Identifier for alternative BOM variants of the same product, used to represent different manufacturing methods, material substitutions, or regional variations. Blank for primary BOM.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Base Unit Of Measure' ;
    rdfs:comment 'The fundamental unit of measure in which the finished product is stocked and sold, independent of the BOM quantity basis. Used for inventory and sales order processing.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomCategory rdf:type rdf:Property ;
    rdfs:label 'Bom Category' ;
    rdfs:comment 'High-level classification of the BOM structure. Material BOM lists physical components, Document BOM references technical drawings and specifications, Equipment BOM defines installed assets, Variant BOM supports product families, Configurable BOM enables customer-specific selections.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomDescription rdf:type rdf:Property ;
    rdfs:label 'Bom Description' ;
    rdfs:comment 'Free-text description of the BOM, providing additional context about the product structure, manufacturing method, or special handling requirements. Supplements the BOM number and type.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomNumber rdf:type rdf:Property ;
    rdfs:label 'Bom Number' ;
    rdfs:comment 'Business identifier for the BOM, typically a human-readable code used across engineering, manufacturing, and procurement systems. Serves as the externally-known unique reference.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomStatus rdf:type rdf:Property ;
    rdfs:label 'Bom Status' ;
    rdfs:comment 'Current lifecycle state of the BOM. Draft indicates work in progress, In Review means under engineering approval, Approved is ready for release, Active is in production use, Obsolete is no longer valid, Superseded has been replaced by a newer revision, and Frozen is locked for regulatory or contractual reasons. [ENUM-REF-CANDIDATE: draft|in_review|approved|active|obsolete|superseded|frozen — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomType rdf:type rdf:Property ;
    rdfs:label 'Bom Type' ;
    rdfs:comment 'Classification of the BOM by its intended business purpose. Engineering BOM (EBOM) represents design intent, Manufacturing BOM (MBOM) reflects shop floor assembly, Service BOM supports after-sales maintenance, Sales BOM defines customer-facing configurations, Planning BOM is used for MRP, and As-Maintained BOM tracks actual installed configurations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationProfile rdf:type rdf:Property ;
    rdfs:label 'Configuration Profile' ;
    rdfs:comment 'Identifier for a variant configuration profile or product family definition. Used in configurable BOMs to define which components are included based on customer selections or feature options.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimateCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the BOM cost estimate. Supports multi-currency costing for global manufacturing operations.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimateTotal rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Total' ;
    rdfs:comment 'Estimated total cost of the BOM including all material, labor, and overhead components. Rolled up from component costs and routing operations. Used for product costing and pricing decisions.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'Date until which this BOM revision remains valid. Nullable for open-ended BOMs. Used to manage phase-out of legacy product structures and ensure correct BOM selection in MRP and MES systems.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engineeringChangeOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Engineering Change Order Number' ;
    rdfs:comment 'Reference to the ECO that created or last modified this BOM revision. Provides traceability to the engineering change management process and links to ECO approval workflows.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:explosionType rdf:type rdf:Property ;
    rdfs:label 'Explosion Type' ;
    rdfs:comment 'Defines how the BOM structure should be expanded for planning and execution. Single Level shows only immediate children, Multi Level recursively expands all sub-assemblies, Summarized aggregates quantities across all levels.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConfigurable rdf:type rdf:Property ;
    rdfs:label 'Is Configurable' ;
    rdfs:comment 'Flag indicating whether this BOM supports variant configuration, allowing customer-specific or order-specific component selection. True for configurable BOMs, False for fixed BOMs.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCriticalBom rdf:type rdf:Property ;
    rdfs:label 'Is Critical Bom' ;
    rdfs:comment 'Flag indicating whether this BOM is for a critical or high-value product requiring special handling, approval workflows, or regulatory compliance. True for critical BOMs, False for standard BOMs.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPhantomBom rdf:type rdf:Property ;
    rdfs:label 'Is Phantom Bom' ;
    rdfs:comment 'Flag indicating whether this is a phantom (transient) BOM that is not stocked as a discrete item but is exploded through to its components during MRP and production. True for phantom BOMs, False for standard stocked assemblies.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotSize rdf:type rdf:Property ;
    rdfs:label 'Lot Size' ;
    rdfs:comment 'Standard production lot or batch size for which this BOM is optimized. Used in MRP calculations to determine component requirements and setup costs. Nullable if not applicable.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'Name or identifier of the person or system that last modified this BOM record. Supports audit trail and change tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plmItemCode rdf:type rdf:Property ;
    rdfs:label 'Plm Item Code' ;
    rdfs:comment 'Reference to the owning PLM item in Siemens Teamcenter that this BOM structure represents. Links the BOM to its parent product or assembly definition.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionVersion rdf:type rdf:Property ;
    rdfs:label 'Production Version' ;
    rdfs:comment 'Identifier linking this BOM to a specific production version in SAP PP, which combines a BOM with a routing to define a complete manufacturing process. Supports multiple production methods for the same product.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityBasis rdf:type rdf:Property ;
    rdfs:label 'Quantity Basis' ;
    rdfs:comment 'The base quantity for which this BOM is defined, typically 1 for single-unit BOMs or a batch size for process manufacturing. All component quantities in the BOM structure are expressed relative to this basis.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revision rdf:type rdf:Property ;
    rdfs:label 'Revision' ;
    rdfs:comment 'Revision level or version identifier for this BOM structure. Tracks engineering changes and ensures traceability across ECO and ECN processes. Critical for change management and configuration control.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapPercentage rdf:type rdf:Property ;
    rdfs:label 'Scrap Percentage' ;
    rdfs:comment 'Expected scrap or waste percentage at the BOM header level, applied to all components. Used in MRP to inflate material requirements. Expressed as a percentage (e.g., 5.00 for 5%).' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usage rdf:type rdf:Property ;
    rdfs:label 'Usage' ;
    rdfs:comment 'Defines the business context in which this BOM is intended to be used. Production for shop floor execution, Costing for standard cost calculation, Engineering for design and development, Maintenance for service and repair, Sales Order for customer-specific configurations, Project for one-time builds.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightTotal rdf:type rdf:Property ;
    rdfs:label 'Weight Total' ;
    rdfs:comment 'Total weight of the finished assembly including all components, calculated from the BOM structure. Used for logistics planning, freight cost estimation, and product specifications.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightUnit rdf:type rdf:Property ;
    rdfs:label 'Weight Unit' ;
    rdfs:comment 'Unit of measure for the total BOM weight. KG (kilogram), LB (pound), G (gram), OZ (ounce), MT (metric ton).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineeringBomLineId rdf:type rdf:Property ;
    rdfs:label 'Engineering Bom Line Id' ;
    rdfs:comment 'Unique identifier for the BOM line item. Primary key for the BOM line entity representing a single parent-child component relationship within a bill of materials structure.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EngineeringBomLine .

ind:bomHeaderId rdf:type rdf:Property ;
    rdfs:label 'Bom Header Id' ;
    rdfs:comment 'Reference to the parent BOM header that this line belongs to. Links the line item to its containing bill of materials assembly structure.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BomHeader .

ind:primaryEngineeringComponentId rdf:type rdf:Property ;
    rdfs:label 'Primary Engineering Component Id' ;
    rdfs:comment 'Reference to the parent assembly or product that contains this component. Represents the \'parent\' side of the parent-child relationship in the BOM structure.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Component .

ind:tertiaryEngineeringSubstituteComponentId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Engineering Substitute Component Id' ;
    rdfs:comment 'Reference to an approved alternate component that can be used in place of the primary component without requiring an Engineering Change Order (ECO). Enables flexible sourcing and supply chain continuity.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Component .

ind:assemblyInstruction rdf:type rdf:Property ;
    rdfs:label 'Assembly Instruction' ;
    rdfs:comment 'Specific instructions for assembling or installing this component into the parent assembly. May reference work instructions, torque specifications, or special tooling requirements.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulkMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Bulk Material Flag' ;
    rdfs:comment 'Indicates whether this component is a bulk material (e.g., paint, adhesive, lubricant) that is consumed in variable quantities and may not be tracked at individual unit level.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeNumber rdf:type rdf:Property ;
    rdfs:label 'Change Number' ;
    rdfs:comment 'The Engineering Change Order (ECO) or Engineering Change Notice (ECN) number that introduced or last modified this BOM line. Provides traceability to engineering change governance processes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coProductFlag rdf:type rdf:Property ;
    rdfs:label 'Co Product Flag' ;
    rdfs:comment 'Indicates whether this line represents a co-product or by-product that is produced alongside the main assembly. Co-products have negative quantities in the BOM and represent outputs rather than inputs.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costRollupFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Rollup Flag' ;
    rdfs:comment 'Indicates whether the cost of this component should be included in the parent assembly cost rollup calculation. Some components (e.g., reference items, tooling) may be excluded from product costing.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalComponentFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Component Flag' ;
    rdfs:comment 'Indicates whether this component is critical to product functionality, safety, or regulatory compliance. Critical components may require additional quality controls, traceability, or supply chain management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectivityEndDate rdf:type rdf:Property ;
    rdfs:label 'Effectivity End Date' ;
    rdfs:comment 'The date after which this component is no longer effective in the parent assembly. Used to manage engineering changes and phase-out of obsolete components. Null indicates the component is currently effective with no planned end date.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivitySerialNumberEnd rdf:type rdf:Property ;
    rdfs:label 'Effectivity Serial Number End' ;
    rdfs:comment 'The ending serial number of the parent assembly for which this component is effective. Null indicates the component remains effective for all subsequent serial numbers.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivitySerialNumberStart rdf:type rdf:Property ;
    rdfs:label 'Effectivity Serial Number Start' ;
    rdfs:comment 'The starting serial number of the parent assembly for which this component is effective. Enables serial-number-based effectivity control for mid-production engineering changes.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivityStartDate rdf:type rdf:Property ;
    rdfs:label 'Effectivity Start Date' ;
    rdfs:comment 'The date from which this component becomes effective in the parent assembly. Used to manage engineering changes and phase-in of new components without creating new BOM versions.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engineeringBomLineStatus rdf:type rdf:Property ;
    rdfs:label 'Engineering Bom Line Status' ;
    rdfs:comment 'Current lifecycle status of this BOM line. Indicates whether the component relationship is currently in use, pending approval, or has been superseded.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineeringNotes rdf:type rdf:Property ;
    rdfs:label 'Engineering Notes' ;
    rdfs:comment 'Free-text notes from engineering regarding special assembly instructions, design considerations, quality requirements, or other technical information relevant to this component usage.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findNumber rdf:type rdf:Property ;
    rdfs:label 'Find Number' ;
    rdfs:comment 'Reference designator or callout number used to locate this component on engineering drawings, assembly diagrams, and technical documentation. Also known as item number or balloon number.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedQuantityFlag rdf:type rdf:Property ;
    rdfs:label 'Fixed Quantity Flag' ;
    rdfs:comment 'Indicates whether the component quantity is fixed regardless of parent assembly batch size. When true, the quantity does not scale with production order quantity (e.g., setup materials, tooling).' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:installationPoint rdf:type rdf:Property ;
    rdfs:label 'Installation Point' ;
    rdfs:comment 'The specific location or mounting point within the parent assembly where this component is installed. Used in assembly instructions and maintenance documentation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadTimeOffsetDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Offset Days' ;
    rdfs:comment 'The number of days before the parent assembly start date that this component must be available. Used in production scheduling and material requirements planning (MRP) to ensure timely component availability.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phantomFlag rdf:type rdf:Property ;
    rdfs:label 'Phantom Flag' ;
    rdfs:comment 'Indicates whether this component is a phantom (transient) assembly that is not stocked or tracked in inventory. Phantom items are exploded through to their child components during MRP processing.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:positionNumber rdf:type rdf:Property ;
    rdfs:label 'Position Number' ;
    rdfs:comment 'Sequential position or line number of this component within the parent assembly BOM. Used for ordering and identifying components in engineering drawings and manufacturing instructions.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityPerAssembly rdf:type rdf:Property ;
    rdfs:label 'Quantity Per Assembly' ;
    rdfs:comment 'The number of units of this component required to build one unit of the parent assembly. Used for material requirements planning (MRP) calculations and cost rollup.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceDesignator rdf:type rdf:Property ;
    rdfs:label 'Reference Designator' ;
    rdfs:comment 'Alphanumeric code identifying the specific location or function of the component in the assembly (e.g., R1, C5, U3 for electronics; A-01, B-12 for mechanical). Used in assembly instructions and maintenance documentation.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionLevel rdf:type rdf:Property ;
    rdfs:label 'Revision Level' ;
    rdfs:comment 'The revision or version of the component that is specified for use in this assembly. Ensures that the correct component revision is used for manufacturing and quality control.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapFactorPercentage rdf:type rdf:Property ;
    rdfs:label 'Scrap Factor Percentage' ;
    rdfs:comment 'Expected scrap or waste percentage for this component during assembly or manufacturing. Used to adjust material requirements planning (MRP) calculations to account for normal production losses.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sortSequence rdf:type rdf:Property ;
    rdfs:label 'Sort Sequence' ;
    rdfs:comment 'Numeric value used to control the display order of BOM lines in reports, pick lists, and assembly instructions. Lower values appear first.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:substituteQualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Substitute Qualification Status' ;
    rdfs:comment 'Approval status of the substitute component for use in this assembly. Indicates whether the alternate has passed qualification testing and is approved for production use.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substituteUsageRestriction rdf:type rdf:Property ;
    rdfs:label 'Substitute Usage Restriction' ;
    rdfs:comment 'Conditions or limitations on when the substitute component may be used (e.g., only for specific customer orders, only when primary is unavailable, geographic restrictions). Ensures proper alternate sourcing governance.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cadModelId rdf:type rdf:Property ;
    rdfs:label 'Cad Model Id' ;
    rdfs:comment 'Unique identifier for the CAD/CAM design file record in the PLM system.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Author Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: CAD model author is needed for design ownership, IP protection and change-management reporting.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:authoringTool rdf:type rdf:Property ;
    rdfs:label 'Authoring Tool' ;
    rdfs:comment 'Name of the CAD software application used to create the model (e.g., Siemens NX, SolidWorks, CATIA, AutoCAD).' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authoringToolVersion rdf:type rdf:Property ;
    rdfs:label 'Authoring Tool Version' ;
    rdfs:comment 'Version number of the CAD authoring software used to create or last modify the model, critical for file compatibility and migration planning.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boundingBoxHeight rdf:type rdf:Property ;
    rdfs:label 'Bounding Box Height' ;
    rdfs:comment 'Maximum height dimension of the CAD model bounding box, used for spatial analysis and packaging planning.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:boundingBoxLength rdf:type rdf:Property ;
    rdfs:label 'Bounding Box Length' ;
    rdfs:comment 'Maximum length dimension of the CAD model bounding box, used for spatial analysis and packaging planning.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:boundingBoxWidth rdf:type rdf:Property ;
    rdfs:label 'Bounding Box Width' ;
    rdfs:comment 'Maximum width dimension of the CAD model bounding box, used for spatial analysis and packaging planning.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:camProgramReference rdf:type rdf:Property ;
    rdfs:label 'Cam Program Reference' ;
    rdfs:comment 'Reference to the associated CAM toolpath program generated from this CAD model for CNC machining operations.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:camProgrammingRequired rdf:type rdf:Property ;
    rdfs:label 'Cam Programming Required' ;
    rdfs:comment 'Flag indicating whether this CAD model requires CAM toolpath programming for CNC machining or other automated manufacturing processes.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:centerOfGravityX rdf:type rdf:Property ;
    rdfs:label 'Center Of Gravity X' ;
    rdfs:comment 'X-coordinate of the calculated center of gravity for the 3D model, used for balance and assembly analysis.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:centerOfGravityY rdf:type rdf:Property ;
    rdfs:label 'Center Of Gravity Y' ;
    rdfs:comment 'Y-coordinate of the calculated center of gravity for the 3D model, used for balance and assembly analysis.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:centerOfGravityZ rdf:type rdf:Property ;
    rdfs:label 'Center Of Gravity Z' ;
    rdfs:comment 'Z-coordinate of the calculated center of gravity for the 3D model, used for balance and assembly analysis.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:checksumHash rdf:type rdf:Property ;
    rdfs:label 'Checksum Hash' ;
    rdfs:comment 'Cryptographic hash (e.g., SHA-256) of the CAD file content, used for integrity verification and change detection.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:datasetType rdf:type rdf:Property ;
    rdfs:label 'Dataset Type' ;
    rdfs:comment 'Classification of the CAD dataset indicating whether it is a 3D solid model, 2D drawing, assembly, simulation file, or CAM toolpath file.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designIntent rdf:type rdf:Property ;
    rdfs:label 'Design Intent' ;
    rdfs:comment 'Engineering rationale and functional requirements that guided the design of this CAD model, supporting Design for Manufacturability (DFM) analysis.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dfmAnalysisStatus rdf:type rdf:Property ;
    rdfs:label 'Dfm Analysis Status' ;
    rdfs:comment 'Status of the Design for Manufacturability analysis for this CAD model, indicating whether the design has been reviewed for manufacturing feasibility.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dfmComplexityScore rdf:type rdf:Property ;
    rdfs:label 'Dfm Complexity Score' ;
    rdfs:comment 'Numerical score representing the manufacturing complexity of the design, derived from DFM analysis (higher scores indicate more complex manufacturing requirements).' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ecoNumber rdf:type rdf:Property ;
    rdfs:label 'Eco Number' ;
    rdfs:comment 'Reference to the Engineering Change Order that authorized the creation or modification of this CAD model revision.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'Native file format of the CAD model (e.g., STEP for neutral exchange, JT for visualization, NX for native Siemens format, DXF for 2D drawings). [ENUM-REF-CANDIDATE: STEP|JT|NX|DXF|DWG|IGES|STL|Parasolid|CATIA|SolidWorks — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intellectualPropertyOwner rdf:type rdf:Property ;
    rdfs:label 'Intellectual Property Owner' ;
    rdfs:comment 'Legal entity or business unit that owns the intellectual property rights to this CAD model design.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialSpecification rdf:type rdf:Property ;
    rdfs:label 'Material Specification' ;
    rdfs:comment 'Specification of the material to be used for manufacturing the component represented by this CAD model (e.g., steel grade, aluminum alloy, polymer type).' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelDescription rdf:type rdf:Property ;
    rdfs:label 'Model Description' ;
    rdfs:comment 'Detailed textual description of the CAD model, including its purpose, key features, and design intent.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelMass rdf:type rdf:Property ;
    rdfs:label 'Model Mass' ;
    rdfs:comment 'Calculated mass of the component based on model volume and material density, used for weight analysis and shipping planning.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelMaturityState rdf:type rdf:Property ;
    rdfs:label 'Model Maturity State' ;
    rdfs:comment 'Current lifecycle state of the CAD model indicating its readiness for manufacturing (e.g., Draft, In Review, Approved, Released, Obsolete).' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelName rdf:type rdf:Property ;
    rdfs:label 'Model Name' ;
    rdfs:comment 'Human-readable name or title of the CAD model file as assigned by the design engineer.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelSurfaceArea rdf:type rdf:Property ;
    rdfs:label 'Model Surface Area' ;
    rdfs:comment 'Calculated surface area of the 3D model, used for coating, painting, and finishing process planning.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelVolume rdf:type rdf:Property ;
    rdfs:label 'Model Volume' ;
    rdfs:comment 'Calculated volume of the 3D solid model, used for material estimation and weight calculation.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:obsoleteTimestamp rdf:type rdf:Property ;
    rdfs:label 'Obsolete Timestamp' ;
    rdfs:comment 'Date and time when the CAD model was marked as obsolete and superseded by a newer revision.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:releasedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Released Timestamp' ;
    rdfs:comment 'Date and time when the CAD model was officially released to production and made available for manufacturing use.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:vaultStoragePath rdf:type rdf:Property ;
    rdfs:label 'Vault Storage Path' ;
    rdfs:comment 'File system or vault storage location reference where the physical CAD file is stored in the PLM repository.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationRequirementId rdf:type rdf:Property ;
    rdfs:label 'Certification Requirement Id' ;
    rdfs:comment 'Unique identifier for the certification requirement record. Primary key.' ;
    rdfs:domain ind:CertificationRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testResultId rdf:type rdf:Property ;
    rdfs:label 'Test Result Id' ;
    rdfs:comment 'Reference to the prototype test activity linked to this certification requirement.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestResult .

ind:actualCostAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Amount' ;
    rdfs:comment 'Actual total cost incurred for achieving this certification, populated after completion.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationBodyAccreditation rdf:type rdf:Property ;
    rdfs:label 'Certification Body Accreditation' ;
    rdfs:comment 'Accreditation standard or authority under which the certification body operates (e.g., ANAB, UKAS, DAkkS).' ;
    rdfs:domain ind:CertificationRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationPriority rdf:type rdf:Property ;
    rdfs:label 'Certification Priority' ;
    rdfs:comment 'Business priority level for achieving this certification based on market access criticality and project timeline.' ;
    rdfs:domain ind:CertificationRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the estimated cost amount.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecnNumber rdf:type rdf:Property ;
    rdfs:label 'Ecn Number' ;
    rdfs:comment 'Engineering Change Notice number associated with this certification requirement.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Amount' ;
    rdfs:comment 'Estimated total cost for achieving this certification, including testing fees, certification body fees, and related expenses.' ;
    rdfs:domain ind:CertificationRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Estimated Lead Time Days' ;
    rdfs:comment 'Estimated number of calendar days required to complete testing and obtain certification from submission to approval.' ;
    rdfs:domain ind:CertificationRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nonComplianceImpact rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Impact' ;
    rdfs:comment 'Description of business impact if this certification is not achieved (e.g., market access blocked, product recall, legal penalties).' ;
    rdfs:domain ind:CertificationRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Completion Date' ;
    rdfs:comment 'Target date for achieving certification approval.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulationStandard rdf:type rdf:Property ;
    rdfs:label 'Regulation Standard' ;
    rdfs:comment 'The specific regulation, standard, or directive that mandates this certification (e.g., CE Marking, UL 508A, IEC 61131-2, IEC 62443-4-1, RoHS, REACH, ISO 9001).' ;
    rdfs:domain ind:CertificationRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Frequency Months' ;
    rdfs:comment 'Number of months between required renewals or re-certifications.' ;
    rdfs:domain ind:CertificationRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Required Flag' ;
    rdfs:comment 'Indicates whether periodic renewal or re-certification is required to maintain compliance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleEngineer rdf:type rdf:Property ;
    rdfs:label 'Responsible Engineer' ;
    rdfs:comment 'Name or identifier of the engineer responsible for managing this certification requirement.' ;
    rdfs:domain ind:CertificationRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardVersion rdf:type rdf:Property ;
    rdfs:label 'Standard Version' ;
    rdfs:comment 'Version or edition of the regulation or standard applicable to this requirement.' ;
    rdfs:domain ind:CertificationRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCountryCode rdf:type rdf:Property ;
    rdfs:label 'Target Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the specific country requiring this certification.' ;
    rdfs:domain ind:CertificationRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMarket rdf:type rdf:Property ;
    rdfs:label 'Target Market' ;
    rdfs:comment 'Geographic market or region where this certification is required (e.g., European Union, United States, China, Global).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testSpecification rdf:type rdf:Property ;
    rdfs:label 'Test Specification' ;
    rdfs:comment 'Detailed specification or protocol defining the test procedures and acceptance criteria.' ;
    rdfs:domain ind:CertificationRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Approval Date' ;
    rdfs:comment 'Date when the waiver or deferral was officially approved.' ;
    rdfs:domain ind:CertificationRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved By' ;
    rdfs:comment 'Name or identifier of the authority who approved the waiver or deferral.' ;
    rdfs:domain ind:CertificationRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverJustification rdf:type rdf:Property ;
    rdfs:label 'Waiver Justification' ;
    rdfs:comment 'Business justification if this certification requirement has been waived or deferred.' ;
    rdfs:domain ind:CertificationRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designEngineerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Design Engineer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Required for Component Design Responsibility report, linking each component to the engineer accountable for its design.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:substituteComponentId rdf:type rdf:Property ;
    rdfs:label 'Substitute Component Id' ;
    rdfs:comment 'Identifier of an approved substitute component that can be used interchangeably. Supports supply chain flexibility and risk mitigation.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Component .

ind:abcClassification rdf:type rdf:Property ;
    rdfs:label 'Abc Classification' ;
    rdfs:comment 'Inventory classification by value contribution. A items are high-value requiring tight control, C items are low-value with relaxed management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cadModelReference rdf:type rdf:Property ;
    rdfs:label 'Cad Model Reference' ;
    rdfs:comment 'File path or URI reference to the authoritative CAD model in PLM. Links to 3D geometry for design, simulation, and manufacturing.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityCode rdf:type rdf:Property ;
    rdfs:label 'Commodity Code' ;
    rdfs:comment 'Procurement commodity classification code. Groups components by material family for sourcing strategy and supplier alignment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentDescription rdf:type rdf:Property ;
    rdfs:label 'Component Description' ;
    rdfs:comment 'Detailed technical description of the component including functional characteristics, application context, and distinguishing features.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentName rdf:type rdf:Property ;
    rdfs:label 'Component Name' ;
    rdfs:comment 'Descriptive name of the component. Primary human-readable identifier used in engineering documentation and BOMs.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentNumber rdf:type rdf:Property ;
    rdfs:label 'Component Number' ;
    rdfs:comment 'Business identifier for the component. Human-readable unique code used across engineering, procurement, and manufacturing.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentType rdf:type rdf:Property ;
    rdfs:label 'Component Type' ;
    rdfs:comment 'Classification of the component by procurement and manufacturing strategy. Determines BOM explosion logic and sourcing approach.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dfmScore rdf:type rdf:Property ;
    rdfs:label 'Dfm Score' ;
    rdfs:comment 'Quantitative assessment of component manufacturability. Higher scores indicate easier, lower-cost manufacturing.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dfmeaReference rdf:type rdf:Property ;
    rdfs:label 'Dfmea Reference' ;
    rdfs:comment 'Reference identifier to the DFMEA document analyzing potential design failure modes and mitigation strategies.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalGroup rdf:type rdf:Property ;
    rdfs:label 'Functional Group' ;
    rdfs:comment 'Functional classification of the component within the product architecture. Used for design reuse and modular engineering.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heightMm rdf:type rdf:Property ;
    rdfs:label 'Height Mm' ;
    rdfs:comment 'Maximum height dimension of the component envelope in millimeters. Part of dimensional specification for packaging and assembly planning.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lengthMm rdf:type rdf:Property ;
    rdfs:label 'Length Mm' ;
    rdfs:comment 'Maximum length dimension of the component envelope in millimeters. Part of dimensional specification for packaging and assembly planning.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifecyclePhase rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Phase' ;
    rdfs:comment 'Current phase in the component lifecycle from concept through obsolescence. Governs release status and usage authorization. [ENUM-REF-CANDIDATE: concept|design|prototype|validation|production|phase_out|obsolete — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:makeOrBuy rdf:type rdf:Property ;
    rdfs:label 'Make Or Buy' ;
    rdfs:comment 'Strategic sourcing decision indicating whether the component is manufactured in-house, purchased from suppliers, or both.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'Minimum order quantity required by supplier or manufacturing process. Constraint for procurement and production planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obsolescenceDate rdf:type rdf:Property ;
    rdfs:label 'Obsolescence Date' ;
    rdfs:comment 'Planned or actual date when the component will be obsoleted and no longer available for new designs. Supports lifecycle planning.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pfmeaReference rdf:type rdf:Property ;
    rdfs:label 'Pfmea Reference' ;
    rdfs:comment 'Reference identifier to the PFMEA document analyzing potential manufacturing process failure modes and controls.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Reach Compliant Flag' ;
    rdfs:comment 'Indicates compliance with EU REACH regulation for chemical substance registration and safety assessment.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rohsCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Rohs Compliant Flag' ;
    rdfs:comment 'Indicates compliance with EU RoHS directive restricting use of hazardous substances in electrical and electronic equipment.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Quantity' ;
    rdfs:comment 'Minimum inventory buffer quantity to protect against demand variability and supply disruptions. Input to MRP calculations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technologyFamily rdf:type rdf:Property ;
    rdfs:label 'Technology Family' ;
    rdfs:comment 'Engineering technology classification grouping components by functional domain (e.g., electrification, automation, control systems).' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceClass rdf:type rdf:Property ;
    rdfs:label 'Tolerance Class' ;
    rdfs:comment 'Manufacturing tolerance classification defining acceptable dimensional variation. Drives manufacturing process selection and quality inspection requirements.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ulCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Ul Certification Number' ;
    rdfs:comment 'UL certification identifier for product safety compliance. Required for electrical components in North American markets.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:widthMm rdf:type rdf:Property ;
    rdfs:label 'Width Mm' ;
    rdfs:comment 'Maximum width dimension of the component envelope in millimeters. Part of dimensional specification for packaging and assembly planning.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:configurationBaselineId rdf:type rdf:Property ;
    rdfs:label 'Configuration Baseline Id' ;
    rdfs:comment 'Unique system-generated identifier for the configuration baseline record.' ;
    rdfs:domain ind:ConfigurationBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:associatedEcnNumber rdf:type rdf:Property ;
    rdfs:label 'Associated Ecn Number' ;
    rdfs:comment 'ECN number linked to this baseline, if any.' ;
    rdfs:domain ind:ConfigurationBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:associatedEcoNumber rdf:type rdf:Property ;
    rdfs:label 'Associated Eco Number' ;
    rdfs:comment 'ECO number linked to this baseline, if any.' ;
    rdfs:domain ind:ConfigurationBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineCode rdf:type rdf:Property ;
    rdfs:label 'Baseline Code' ;
    rdfs:comment 'Business identifier or code used externally to reference the baseline.' ;
    rdfs:domain ind:ConfigurationBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineName rdf:type rdf:Property ;
    rdfs:label 'Baseline Name' ;
    rdfs:comment 'Human-readable name describing the baseline (e.g., "Functional Baseline – Rev A").' ;
    rdfs:domain ind:ConfigurationBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineScope rdf:type rdf:Property ;
    rdfs:label 'Baseline Scope' ;
    rdfs:comment 'Scope of the baseline (e.g., entire product, subsystem only).' ;
    rdfs:domain ind:ConfigurationBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineType rdf:type rdf:Property ;
    rdfs:label 'Baseline Type' ;
    rdfs:comment 'Classification of the baseline according to ISO 10007 (functional, allocated, product, etc.).' ;
    rdfs:domain ind:ConfigurationBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeCategory rdf:type rdf:Property ;
    rdfs:label 'Change Category' ;
    rdfs:comment 'Category of change (e.g., design, material, process).' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeLockFlag rdf:type rdf:Property ;
    rdfs:label 'Change Lock Flag' ;
    rdfs:comment 'Indicates whether further changes to the baseline are locked (true) or allowed (false).' ;
    rdfs:domain ind:ConfigurationBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:configurationBaselineDescription rdf:type rdf:Property ;
    rdfs:label 'Configuration Baseline Description' ;
    rdfs:comment 'Free-form description of the baseline purpose and scope.' ;
    rdfs:domain ind:ConfigurationBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationBaselineStatus rdf:type rdf:Property ;
    rdfs:label 'Configuration Baseline Status' ;
    rdfs:comment 'Current lifecycle status of the baseline.' ;
    rdfs:domain ind:ConfigurationBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpactCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the cost impact estimate.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpactEstimate rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Estimate' ;
    rdfs:comment 'Estimated financial impact of the baseline change.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isFunctionalBaseline rdf:type rdf:Property ;
    rdfs:label 'Is Functional Baseline' ;
    rdfs:comment 'True if the baseline represents a functional configuration.' ;
    rdfs:domain ind:ConfigurationBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPhysicalBaseline rdf:type rdf:Property ;
    rdfs:label 'Is Physical Baseline' ;
    rdfs:comment 'True if the baseline represents a physical configuration (as opposed to functional).' ;
    rdfs:domain ind:ConfigurationBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:linkedBomRevision rdf:type rdf:Property ;
    rdfs:label 'Linked Bom Revision' ;
    rdfs:comment 'Identifier of the BOM revision frozen in this baseline.' ;
    rdfs:domain ind:ConfigurationBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedComponentSet rdf:type rdf:Property ;
    rdfs:label 'Linked Component Set' ;
    rdfs:comment 'Reference to the frozen set of component revisions included in the baseline.' ;
    rdfs:domain ind:ConfigurationBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedDrawingRevision rdf:type rdf:Property ;
    rdfs:label 'Linked Drawing Revision' ;
    rdfs:comment 'Identifier of the drawing revision captured in the baseline.' ;
    rdfs:domain ind:ConfigurationBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedSpecRevision rdf:type rdf:Property ;
    rdfs:label 'Linked Spec Revision' ;
    rdfs:comment 'Identifier of the specification revision associated with the baseline.' ;
    rdfs:domain ind:ConfigurationBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockReason rdf:type rdf:Property ;
    rdfs:label 'Lock Reason' ;
    rdfs:comment 'Explanation why the baseline was locked from further changes.' ;
    rdfs:domain ind:ConfigurationBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectPhase rdf:type rdf:Property ;
    rdfs:label 'Project Phase' ;
    rdfs:comment 'Phase of the engineering project at the time of baseline creation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Impact Flag' ;
    rdfs:comment 'True if the baseline triggers regulatory reporting or filing requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduleImpactDays rdf:type rdf:Property ;
    rdfs:label 'Schedule Impact Days' ;
    rdfs:comment 'Estimated change in project schedule (in days) caused by the baseline.' ;
    rdfs:domain ind:ConfigurationBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:designReviewId rdf:type rdf:Property ;
    rdfs:label 'Design Review Id' ;
    rdfs:comment 'Unique identifier for the design review event. Primary key for the design review record.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DesignReview .

ind:chairpersonEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Chairperson Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Design review chairperson is required for governance minutes and compliance sign-off tracking.' ;
    rdfs:domain ind:DesignReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:controlPlanId rdf:type rdf:Property ;
    rdfs:label 'Control Plan Id' ;
    rdfs:comment 'Foreign key reference to the control plan reviewed or approved during this design review. Links design review to quality control planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControlPlan .

ind:dfmeaId rdf:type rdf:Property ;
    rdfs:label 'Dfmea Id' ;
    rdfs:comment 'Foreign key reference to the DFMEA document reviewed or updated during this design review. Links design review to formal risk analysis.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dfmea .

ind:fmeaId rdf:type rdf:Property ;
    rdfs:label 'Fmea Id' ;
    rdfs:comment 'Foreign key reference to the PFMEA document reviewed or updated during this design review. Links design review to process risk analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fmea .

ind:projectId rdf:type rdf:Property ;
    rdfs:label 'Project Id' ;
    rdfs:comment 'Foreign key reference to the parent engineering project or APQP project under which this design review is conducted.' ;
    rdfs:domain ind:DesignReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EngineeringProject .

ind:actionItemCount rdf:type rdf:Property ;
    rdfs:label 'Action Item Count' ;
    rdfs:comment 'Total number of action items generated from the design review. Used for tracking review effectiveness and closure metrics.' ;
    rdfs:domain ind:DesignReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actionItems rdf:type rdf:Property ;
    rdfs:label 'Action Items' ;
    rdfs:comment 'Structured list of action items generated during the design review, typically stored as JSON or delimited text. Each action item includes description, category, assignee, due date, status, and resolution.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether formal management approval is required to close this design review gate. True=approval required, False=no approval required.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'Full name of the individual who provided formal approval for the design review gate closure. Typically a senior engineering manager or program manager.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apqpPhase rdf:type rdf:Property ;
    rdfs:label 'Apqp Phase' ;
    rdfs:comment 'APQP phase to which this design review is linked. Phase 1=Plan and Define, Phase 2=Product Design and Development, Phase 3=Process Design and Development, Phase 4=Product and Process Validation, Phase 5=Launch Feedback and Corrective Action.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attendeeCount rdf:type rdf:Property ;
    rdfs:label 'Attendee Count' ;
    rdfs:comment 'Total number of individuals who attended the design review meeting. Used for quorum validation and meeting effectiveness metrics.' ;
    rdfs:domain ind:DesignReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attendeeList rdf:type rdf:Property ;
    rdfs:label 'Attendee List' ;
    rdfs:comment 'Comma-separated or semicolon-separated list of attendee names who participated in the design review. Provides audit trail of review participants.' ;
    rdfs:domain ind:DesignReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirements rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirements' ;
    rdfs:comment 'List of regulatory, safety, and industry compliance requirements evaluated during the design review (e.g., UL, CE, IEC 61131, ISO 9001). Stored as delimited text or JSON.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criteriaFailCount rdf:type rdf:Property ;
    rdfs:label 'Criteria Fail Count' ;
    rdfs:comment 'Number of gate criteria that received a fail status during the review. Indicates areas requiring corrective action before gate closure.' ;
    rdfs:domain ind:DesignReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:criteriaNaCount rdf:type rdf:Property ;
    rdfs:label 'Criteria Na Count' ;
    rdfs:comment 'Number of gate criteria marked as not applicable for this specific review. Used to adjust compliance calculations.' ;
    rdfs:domain ind:DesignReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:criteriaPassCount rdf:type rdf:Property ;
    rdfs:label 'Criteria Pass Count' ;
    rdfs:comment 'Number of gate criteria that received a pass status during the review. Used to calculate gate compliance percentage.' ;
    rdfs:domain ind:DesignReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:designMaturityLevel rdf:type rdf:Property ;
    rdfs:label 'Design Maturity Level' ;
    rdfs:comment 'Maturity level of the design at the time of review. Concept=early ideation, Preliminary=initial design, Detailed=fully specified, Final=pre-release, Released=production-ready.' ;
    rdfs:domain ind:DesignReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Design Validation Status' ;
    rdfs:comment 'Status of design validation activities (customer/user testing) at the time of the design review. Indicates whether design meets intended use requirements.' ;
    rdfs:domain ind:DesignReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Design Verification Status' ;
    rdfs:comment 'Status of design verification activities (testing, analysis, inspection) at the time of the design review. Indicates whether design meets specified requirements.' ;
    rdfs:domain ind:DesignReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReferences rdf:type rdf:Property ;
    rdfs:label 'Document References' ;
    rdfs:comment 'List of supporting documents reviewed during the design review (e.g., CAD drawings, specifications, test reports, FMEA documents). Stored as delimited text or JSON with document IDs and titles.' ;
    rdfs:domain ind:DesignReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateCriteriaChecklist rdf:type rdf:Property ;
    rdfs:label 'Gate Criteria Checklist' ;
    rdfs:comment 'Structured checklist of gate criteria evaluated during the review, typically stored as JSON or delimited text. Each criterion includes pass/fail/NA status and comments.' ;
    rdfs:domain ind:DesignReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateDecision rdf:type rdf:Property ;
    rdfs:label 'Gate Decision' ;
    rdfs:comment 'Final decision outcome of the design review gate. Pass=approved to proceed, Conditional Pass=approved with conditions/action items, Fail=not approved, Deferred=decision postponed pending additional information.' ;
    rdfs:domain ind:DesignReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Gate Decision Date' ;
    rdfs:comment 'Date on which the formal gate decision was rendered. May differ from review_date if decision was deferred or required additional deliberation.' ;
    rdfs:domain ind:DesignReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:meetingDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Meeting Duration Minutes' ;
    rdfs:comment 'Duration of the design review meeting in minutes. Used for resource planning and meeting effectiveness analysis.' ;
    rdfs:domain ind:DesignReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:meetingLocation rdf:type rdf:Property ;
    rdfs:label 'Meeting Location' ;
    rdfs:comment 'Physical or virtual location where the design review meeting was conducted (e.g., conference room, site name, or virtual meeting platform).' ;
    rdfs:domain ind:DesignReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openActionItemCount rdf:type rdf:Property ;
    rdfs:label 'Open Action Item Count' ;
    rdfs:comment 'Number of action items from this design review that remain open/unresolved. Used to track gate closure readiness.' ;
    rdfs:domain ind:DesignReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewNumber rdf:type rdf:Property ;
    rdfs:label 'Review Number' ;
    rdfs:comment 'Business identifier for the design review event, typically following organizational numbering convention (e.g., DR-2024-001234). Used for external reference and traceability.' ;
    rdfs:domain ind:DesignReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Current lifecycle status of the design review event. Tracks whether the review is scheduled, actively being conducted, completed, cancelled, or postponed.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewSummary rdf:type rdf:Property ;
    rdfs:label 'Review Summary' ;
    rdfs:comment 'Executive summary of the design review outcomes, key findings, and recommendations. Provides high-level overview for stakeholders.' ;
    rdfs:domain ind:DesignReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewType rdf:type rdf:Property ;
    rdfs:label 'Review Type' ;
    rdfs:comment 'Type of design review gate conducted. PDR=Preliminary Design Review, CDR=Critical Design Review, PRR=Production Readiness Review, TRR=Test Readiness Review, FDR=Final Design Review, MDR=Manufacturing Design Review.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedItemDescription rdf:type rdf:Property ;
    rdfs:label 'Reviewed Item Description' ;
    rdfs:comment 'Textual description of the item, assembly, or product being reviewed. Provides human-readable context for the reviewed design.' ;
    rdfs:domain ind:DesignReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedItemNumber rdf:type rdf:Property ;
    rdfs:label 'Reviewed Item Number' ;
    rdfs:comment 'Part number, assembly number, or product identifier of the item/design being reviewed. Links to the engineering item under evaluation.' ;
    rdfs:domain ind:DesignReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedItemRevision rdf:type rdf:Property ;
    rdfs:label 'Reviewed Item Revision' ;
    rdfs:comment 'Revision level of the item/design being reviewed at the time of the design review (e.g., A, B, C, Rev 01). Ensures traceability to specific design iteration.' ;
    rdfs:domain ind:DesignReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentSummary rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Summary' ;
    rdfs:comment 'Summary of design risks identified during the review, including risk severity, mitigation plans, and residual risk levels. Links to DFMEA/PFMEA where applicable.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dfmAnalysisId rdf:type rdf:Property ;
    rdfs:label 'Dfm Analysis Id' ;
    rdfs:comment 'Unique identifier for the DFM analysis record. Primary key.' ;
    rdfs:domain ind:DfmAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:relatedPfmeaFmeaId rdf:type rdf:Property ;
    rdfs:label 'Related Pfmea Fmea Id' ;
    rdfs:comment 'Reference to a related PFMEA record if the DFM analysis is linked to a process failure mode assessment.' ;
    rdfs:domain ind:DfmAnalysis ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fmea .

ind:affectedFeature rdf:type rdf:Property ;
    rdfs:label 'Affected Feature' ;
    rdfs:comment 'Specific design feature, dimension, tolerance, or characteristic that is causing the manufacturability concern.' ;
    rdfs:domain ind:DfmAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeSolution rdf:type rdf:Property ;
    rdfs:label 'Alternative Solution' ;
    rdfs:comment 'Alternative approaches or workarounds if the recommended design modification is not feasible (e.g., process change, tooling investment, supplier change).' ;
    rdfs:domain ind:DfmAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisNumber rdf:type rdf:Property ;
    rdfs:label 'Analysis Number' ;
    rdfs:comment 'Business identifier for the DFM analysis, typically following organizational numbering convention (e.g., DFM-000012345).' ;
    rdfs:domain ind:DfmAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisType rdf:type rdf:Property ;
    rdfs:label 'Analysis Type' ;
    rdfs:comment 'Classification of the DFM analysis trigger or purpose (e.g., initial design review, design change review, cost reduction review).' ;
    rdfs:domain ind:DfmAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analystName rdf:type rdf:Property ;
    rdfs:label 'Analyst Name' ;
    rdfs:comment 'Name of the manufacturing engineer or DFM analyst who conducted the review.' ;
    rdfs:domain ind:DfmAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Required' ;
    rdfs:comment 'Flag indicating whether formal approval is required before implementing the recommended design modification.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dfmIssueDetail rdf:type rdf:Property ;
    rdfs:label 'Dfm Issue Detail' ;
    rdfs:comment 'Detailed description of the specific manufacturability issues, constraints, or risks identified during the analysis.' ;
    rdfs:domain ind:DfmAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dfmIssueSummary rdf:type rdf:Property ;
    rdfs:label 'Dfm Issue Summary' ;
    rdfs:comment 'High-level summary of the identified DFM issues or concerns with the current design.' ;
    rdfs:domain ind:DfmAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionRationale rdf:type rdf:Property ;
    rdfs:label 'Disposition Rationale' ;
    rdfs:comment 'Justification or reasoning for the disposition decision (e.g., why design change is required, why accepted as-is).' ;
    rdfs:domain ind:DfmAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionStatus rdf:type rdf:Property ;
    rdfs:label 'Disposition Status' ;
    rdfs:comment 'Current status of the DFM analysis: open (pending review), under_review (being evaluated), design_change_required (ECO initiated), accepted_as_is (no change needed), closed (resolved), cancelled (no longer applicable).' ;
    rdfs:domain ind:DfmAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecoInitiated rdf:type rdf:Property ;
    rdfs:label 'Eco Initiated' ;
    rdfs:comment 'Flag indicating whether an Engineering Change Order was initiated as a result of this DFM analysis.' ;
    rdfs:domain ind:DfmAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedCostImpact rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Impact' ;
    rdfs:comment 'Estimated financial impact of the DFM issue if not addressed, including increased manufacturing cost, scrap, rework, or yield loss.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedCostSavings rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Savings' ;
    rdfs:comment 'Projected cost savings if the recommended design modification is implemented.' ;
    rdfs:domain ind:DfmAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impactOnLeadTime rdf:type rdf:Property ;
    rdfs:label 'Impact On Lead Time' ;
    rdfs:comment 'Assessment of how the DFM issue or recommended change affects manufacturing lead time.' ;
    rdfs:domain ind:DfmAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:impactOnQuality rdf:type rdf:Property ;
    rdfs:label 'Impact On Quality' ;
    rdfs:comment 'Assessment of how the DFM issue or recommended change affects product quality and conformance.' ;
    rdfs:domain ind:DfmAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingProcessScope rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Process Scope' ;
    rdfs:comment 'Primary manufacturing process or processes being evaluated in this DFM analysis (e.g., machining, casting, stamping, PCB assembly). [ENUM-REF-CANDIDATE: machining|casting|stamping|forging|injection_molding|pcb_assembly|sheet_metal_fabrication|welding|additive_manufacturing|assembly|multi_process — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DfmAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingSite rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Site' ;
    rdfs:comment 'Manufacturing facility or site where the component will be produced, relevant to the DFM analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processConstraint rdf:type rdf:Property ;
    rdfs:label 'Process Constraint' ;
    rdfs:comment 'Description of the manufacturing process constraint or limitation that the design violates or challenges (e.g., tool access, tolerance capability, material flow).' ;
    rdfs:domain ind:DfmAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedDesignModification rdf:type rdf:Property ;
    rdfs:label 'Recommended Design Modification' ;
    rdfs:comment 'Proposed design changes or modifications to resolve the DFM issue and improve manufacturability.' ;
    rdfs:domain ind:DfmAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Completion Timestamp' ;
    rdfs:comment 'Timestamp when the DFM analysis was completed and documented.' ;
    rdfs:domain ind:DfmAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:severityClassification rdf:type rdf:Property ;
    rdfs:label 'Severity Classification' ;
    rdfs:comment 'Severity level of the identified DFM issue: critical (cannot manufacture), major (significant cost/quality impact), moderate (manageable impact), minor (low impact), informational (observation only).' ;
    rdfs:domain ind:DfmAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierFeedback rdf:type rdf:Property ;
    rdfs:label 'Supplier Feedback' ;
    rdfs:comment 'Input or feedback from manufacturing suppliers or contract manufacturers regarding the design manufacturability.' ;
    rdfs:domain ind:DfmAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolingRequirement rdf:type rdf:Property ;
    rdfs:label 'Tooling Requirement' ;
    rdfs:comment 'Description of any special tooling, fixtures, or equipment required to manufacture the design as-is or with the recommended modification.' ;
    rdfs:domain ind:DfmAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apqpProjectId rdf:type rdf:Property ;
    rdfs:label 'Apqp Project Id' ;
    rdfs:comment 'Reference to the parent APQP project under which this DFMEA is conducted. Links to APQP project master.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApqpProject .

ind:dfmeaApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Dfmea Approved By Employee Id' ;
    rdfs:comment 'Reference to the quality manager or engineering director who approved the DFMEA. Links to employee master. Null if not yet approved.' ;
    rdfs:domain ind:Dfmea ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:dfmeaEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Dfmea Employee Id' ;
    rdfs:comment 'Reference to the design engineer or engineering manager responsible for implementing the recommended action. Links to employee/workforce master.' ;
    rdfs:domain ind:Dfmea ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:dfmeaTeamLeadEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Dfmea Team Lead Employee Id' ;
    rdfs:comment 'Reference to the engineer or quality professional leading the DFMEA team. Responsible for facilitating the analysis and ensuring completeness. Links to employee master.' ;
    rdfs:domain ind:Dfmea ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ppapSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Ppap Submission Id' ;
    rdfs:comment 'Reference to the PPAP submission package that includes this DFMEA as a required deliverable. Links to PPAP submission master.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PpapSubmission .

ind:actionPriority rdf:type rdf:Property ;
    rdfs:label 'Action Priority' ;
    rdfs:comment 'Action Priority classification per VDA FMEA methodology. Determined by severity and occurrence/detection combination using the AP matrix. High = immediate action required, Medium = action should be taken, Low = action may be considered.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionStatus rdf:type rdf:Property ;
    rdfs:label 'Action Status' ;
    rdfs:comment 'Current status of the recommended action in its lifecycle. Open = not started, In Progress = work underway, Completed = action finished, Verified = effectiveness confirmed, Cancelled = action no longer required.' ;
    rdfs:domain ind:Dfmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionTaken rdf:type rdf:Property ;
    rdfs:label 'Action Taken' ;
    rdfs:comment 'Detailed description of the actual corrective or preventive action that was implemented. Documents what was done to address the failure mode.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Date' ;
    rdfs:comment 'Date when the DFMEA analysis was originally conducted or last updated. Represents the business event timestamp for the analysis session.' ;
    rdfs:domain ind:Dfmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentDetectionControls rdf:type rdf:Property ;
    rdfs:label 'Current Detection Controls' ;
    rdfs:comment 'Design verification and validation controls currently in place to detect the failure mode or cause before release (e.g., design reviews, prototype testing, Computer-Aided Engineering (CAE) analysis, Design Verification Plan and Report (DVP&R)).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentPreventionControls rdf:type rdf:Property ;
    rdfs:label 'Current Prevention Controls' ;
    rdfs:comment 'Design controls currently in place to prevent the failure cause from occurring (e.g., design rules, standards, simulations, Design for Manufacturability (DFM) guidelines, redundancy).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerRequirementReference rdf:type rdf:Property ;
    rdfs:label 'Customer Requirement Reference' ;
    rdfs:comment 'Reference to specific customer requirements, specifications, or standards that drive this DFMEA analysis (e.g., customer FMEA requirements, industry standards, regulatory requirements).' ;
    rdfs:domain ind:Dfmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designPhase rdf:type rdf:Property ;
    rdfs:label 'Design Phase' ;
    rdfs:comment 'The phase of the product design lifecycle when this DFMEA was conducted. Concept = early ideation, Preliminary = initial design, Detailed = final design, Validation = testing phase, Production = manufacturing release.' ;
    rdfs:domain ind:Dfmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dfmeaNumber rdf:type rdf:Property ;
    rdfs:label 'Dfmea Number' ;
    rdfs:comment 'Business identifier for the DFMEA document. Human-readable unique number assigned per organizational numbering convention.' ;
    rdfs:domain ind:Dfmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dfmeaStatus rdf:type rdf:Property ;
    rdfs:label 'Dfmea Status' ;
    rdfs:comment 'Current lifecycle status of the DFMEA document. Draft = under development, In Review = undergoing team review, Approved = formally approved, Active = in use, Superseded = replaced by newer revision, Obsolete = no longer applicable.' ;
    rdfs:domain ind:Dfmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceReference rdf:type rdf:Property ;
    rdfs:label 'Evidence Reference' ;
    rdfs:comment 'Reference to supporting evidence, documentation, or test results that validate the action effectiveness (e.g., test report number, Engineering Change Order (ECO) number, validation protocol ID). Used for Production Part Approval Process (PPAP) evidence packages.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureCause rdf:type rdf:Property ;
    rdfs:label 'Failure Cause' ;
    rdfs:comment 'The root cause or mechanism that leads to the failure mode. Describes why the failure occurs (e.g., design deficiency, material weakness, tolerance stack-up).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureEffect rdf:type rdf:Property ;
    rdfs:label 'Failure Effect' ;
    rdfs:comment 'The consequence or impact of the failure mode on the customer, end user, or downstream operations. Describes what the customer experiences.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureMode rdf:type rdf:Property ;
    rdfs:label 'Failure Mode' ;
    rdfs:comment 'The manner in which the design item could potentially fail to meet the intended function. Describes how the failure manifests.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemFunction rdf:type rdf:Property ;
    rdfs:label 'Item Function' ;
    rdfs:comment 'The intended function or purpose of the design item being analyzed. Describes what the item is supposed to do under normal operating conditions.' ;
    rdfs:domain ind:Dfmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedAction rdf:type rdf:Property ;
    rdfs:label 'Recommended Action' ;
    rdfs:comment 'Detailed description of the recommended corrective or preventive action to reduce severity, occurrence, or improve detection. May include design changes, additional testing, or enhanced controls.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedActionPriority rdf:type rdf:Property ;
    rdfs:label 'Revised Action Priority' ;
    rdfs:comment 'Recalculated Action Priority per VDA methodology after action implementation. Should show improvement (e.g., High to Medium). Null if action not yet completed.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedDetectionRating rdf:type rdf:Property ;
    rdfs:label 'Revised Detection Rating' ;
    rdfs:comment 'Updated detection rating (1-10) after corrective action implementation. Should decrease (improve) if detection controls were enhanced. Null if action not yet completed.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revisedOccurrenceRating rdf:type rdf:Property ;
    rdfs:label 'Revised Occurrence Rating' ;
    rdfs:comment 'Updated occurrence rating (1-10) after corrective action implementation. Should decrease if prevention controls were improved. Null if action not yet completed.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revisedRpn rdf:type rdf:Property ;
    rdfs:label 'Revised Rpn' ;
    rdfs:comment 'Recalculated Risk Priority Number after action implementation: Revised S × Revised O × Revised D. Used to measure risk reduction effectiveness. Null if action not yet completed.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revisedSeverityRating rdf:type rdf:Property ;
    rdfs:label 'Revised Severity Rating' ;
    rdfs:comment 'Updated severity rating (1-10) after corrective action implementation. Typically severity does not change unless design function is modified. Null if action not yet completed.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rpn rdf:type rdf:Property ;
    rdfs:label 'Rpn' ;
    rdfs:comment 'Risk Priority Number calculated as Severity × Occurrence × Detection (S × O × D). Used in traditional AIAG FMEA methodology to prioritize risks. Range: 1-1000.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyRelatedFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Related Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this failure mode has safety implications for the end user or operator. True = safety-related failure mode.' ;
    rdfs:domain ind:Dfmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scopeLevel rdf:type rdf:Property ;
    rdfs:label 'Scope Level' ;
    rdfs:comment 'Hierarchical level at which the DFMEA analysis is performed: system (top-level product), subsystem (major assembly), component (individual part), or interface (interaction between elements).' ;
    rdfs:domain ind:Dfmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialCharacteristicsFlag rdf:type rdf:Property ;
    rdfs:label 'Special Characteristics Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this failure mode relates to a special characteristic (critical or significant product/process characteristic requiring additional controls). True = special characteristic involved.' ;
    rdfs:domain ind:Dfmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approved By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Drawing approval authority must be tracked for release control and traceability in PLM.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assemblyLevel rdf:type rdf:Property ;
    rdfs:label 'Assembly Level' ;
    rdfs:comment 'Hierarchical level of the item depicted (component, subassembly, assembly, system). Indicates the complexity and position in the product structure.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkedBy rdf:type rdf:Property ;
    rdfs:label 'Checked By' ;
    rdfs:comment 'Name or identifier of the engineer who reviewed and checked the drawing for accuracy and completeness before approval.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drawingStatus rdf:type rdf:Property ;
    rdfs:label 'Drawing Status' ;
    rdfs:comment 'Current lifecycle status of the drawing (draft, in_review, approved, released, obsolete, superseded). Governs whether the drawing can be used for manufacturing.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drawingType rdf:type rdf:Property ;
    rdfs:label 'Drawing Type' ;
    rdfs:comment 'Classification of the drawing by its purpose and content (assembly, detail, schematic, layout, installation, wiring, piping, fabrication). [ENUM-REF-CANDIDATE: assembly|detail|schematic|layout|installation|wiring|piping|fabrication — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drawnBy rdf:type rdf:Property ;
    rdfs:label 'Drawn By' ;
    rdfs:comment 'Name or identifier of the engineer or drafter who created the drawing. Recorded in the title block.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMasterDrawing rdf:type rdf:Property ;
    rdfs:label 'Is Master Drawing' ;
    rdfs:comment 'Flag indicating whether this is the master (authoritative) drawing for the part. True if this is the primary reference; false if it is a derivative or copy.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialCallout rdf:type rdf:Property ;
    rdfs:label 'Material Callout' ;
    rdfs:comment 'Material specification called out on the drawing (e.g., AISI 304, Al 6061-T6, SAE 1020). Defines the material from which the part is manufactured.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectionMethod rdf:type rdf:Property ;
    rdfs:label 'Projection Method' ;
    rdfs:comment 'Orthographic projection method used (first_angle per ISO, third_angle per ANSI). Determines the arrangement of views.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date when the drawing was officially released for manufacturing and procurement. Marks the transition from engineering to production.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scale rdf:type rdf:Property ;
    rdfs:label 'Scale' ;
    rdfs:comment 'Scale ratio of the drawing (e.g., 1:1, 1:2, 2:1, NTS for Not To Scale). Indicates the relationship between drawing dimensions and actual part dimensions.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sheetCount rdf:type rdf:Property ;
    rdfs:label 'Sheet Count' ;
    rdfs:comment 'Total number of sheets in this drawing set. Multi-sheet drawings are common for complex assemblies.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sheetSize rdf:type rdf:Property ;
    rdfs:label 'Sheet Size' ;
    rdfs:comment 'Standard sheet size designation (ISO: A0, A1, A2, A3, A4; ANSI: A, B, C, D, E, F) used for this drawing. [ENUM-REF-CANDIDATE: A0|A1|A2|A3|A4|A|B|C|D|E|F — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByDrawingNumber rdf:type rdf:Property ;
    rdfs:label 'Superseded By Drawing Number' ;
    rdfs:comment 'Drawing number that supersedes this drawing when status is obsolete or superseded. Maintains traceability in the revision chain.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersedesDrawingNumber rdf:type rdf:Property ;
    rdfs:label 'Supersedes Drawing Number' ;
    rdfs:comment 'Previous drawing number that this drawing supersedes. Establishes the backward link in the revision history.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surfaceFinishSpecification rdf:type rdf:Property ;
    rdfs:label 'Surface Finish Specification' ;
    rdfs:comment 'Surface roughness or finish requirement specified on the drawing (e.g., Ra 0.8, N6, 125 microinch). Critical for functional surfaces.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecnEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Ecn Employee Id' ;
    rdfs:comment 'Reference to the employee or engineer who created and released this ECN.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acknowledgementCount rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Count' ;
    rdfs:comment 'Number of stakeholders who have formally acknowledged receipt and understanding of this ECN. Used to track distribution completion.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acknowledgementRequired rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Required' ;
    rdfs:comment 'Indicates whether recipients must formally acknowledge receipt and understanding of this ECN. True = acknowledgement tracking enabled; False = informational only.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acknowledgementTargetCount rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Target Count' ;
    rdfs:comment 'Total number of stakeholders required to acknowledge this ECN before it can be marked as fully distributed.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedDrawingCount rdf:type rdf:Property ;
    rdfs:label 'Affected Drawing Count' ;
    rdfs:comment 'Total number of engineering drawings, Computer-Aided Design (CAD) models, or technical documents affected by this ECN.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedPartCount rdf:type rdf:Property ;
    rdfs:label 'Affected Part Count' ;
    rdfs:comment 'Total number of distinct part numbers or Bill of Materials (BOM) items affected by this ECN.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedProductLines rdf:type rdf:Property ;
    rdfs:label 'Affected Product Lines' ;
    rdfs:comment 'Comma-separated list or narrative of product lines, families, or platforms impacted by this ECN. Used for scoping and impact analysis.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Bom Impact Flag' ;
    rdfs:comment 'Indicates whether this ECN requires changes to one or more Bill of Materials (BOM) structures. True = BOM changes required; False = no BOM impact.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Required' ;
    rdfs:comment 'Indicates whether customers must be notified of this ECN due to form, fit, function, or regulatory changes. True = customer notification required; False = internal only.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distributionList rdf:type rdf:Property ;
    rdfs:label 'Distribution List' ;
    rdfs:comment 'Comma-separated list or structured text of roles, departments, or individuals who must receive and acknowledge this ECN (e.g., Production, Quality, Supply Chain, Engineering).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecnStatus rdf:type rdf:Property ;
    rdfs:label 'Ecn Status' ;
    rdfs:comment 'Current lifecycle status of the ECN. Draft = being prepared; Released = approved for distribution; Distributed = sent to stakeholders; Acknowledged = recipients confirmed receipt; Closed = implementation complete; Cancelled = voided.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecnType rdf:type rdf:Property ;
    rdfs:label 'Ecn Type' ;
    rdfs:comment 'Classification of the ECN based on urgency and scope. Standard = normal process; Urgent = expedited review; Emergency = immediate action required; Field Change = affects deployed products; Design Improvement = enhancement.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpSyncStatus rdf:type rdf:Property ;
    rdfs:label 'Erp Sync Status' ;
    rdfs:comment 'Status of synchronization of this ECN to downstream Enterprise Resource Planning (ERP) systems (SAP S/4HANA). Pending = awaiting sync; Synced = successfully transmitted; Failed = sync error; Not Required = no ERP impact.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Date' ;
    rdfs:comment 'Actual date when the engineering change was fully implemented across all affected systems and processes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inventoryImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Inventory Impact Flag' ;
    rdfs:comment 'Indicates whether this ECN affects existing inventory, requiring disposition decisions (scrap, rework, use-as-is). True = inventory action required; False = no inventory impact.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mesSyncStatus rdf:type rdf:Property ;
    rdfs:label 'Mes Sync Status' ;
    rdfs:comment 'Status of synchronization of this ECN to Manufacturing Execution System (MES) for shop floor implementation. Pending = awaiting sync; Synced = successfully transmitted; Failed = sync error; Not Required = no MES impact.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plmSystemCode rdf:type rdf:Property ;
    rdfs:label 'Plm System Code' ;
    rdfs:comment 'Unique identifier for this ECN in the source Product Lifecycle Management (PLM) system (Siemens Teamcenter). Used for system integration and traceability.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionFrom rdf:type rdf:Property ;
    rdfs:label 'Revision From' ;
    rdfs:comment 'The previous revision level of the affected item(s) before this ECN takes effect. Used to track revision transitions.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionTo rdf:type rdf:Property ;
    rdfs:label 'Revision To' ;
    rdfs:comment 'The new revision level of the affected item(s) after this ECN is implemented. Represents the target state.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Routing Impact Flag' ;
    rdfs:comment 'Indicates whether this ECN requires changes to manufacturing routings or process plans. True = routing changes required; False = no routing impact.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Supplier Notification Required' ;
    rdfs:comment 'Indicates whether external suppliers must be notified of this ECN due to purchased part changes or specification updates. True = supplier notification required; False = internal only.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initiatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Initiator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: ECO initiation must record the engineer who raised the change, used in engineering change management dashboards.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualCostImpact rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Impact' ;
    rdfs:comment 'Actual financial impact realized after implementation, including all direct and indirect costs.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualScheduleImpactDays rdf:type rdf:Property ;
    rdfs:label 'Actual Schedule Impact Days' ;
    rdfs:comment 'Actual impact on production schedule in days realized after implementation.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedItemsCount rdf:type rdf:Property ;
    rdfs:label 'Affected Items Count' ;
    rdfs:comment 'Total number of product items (parts, assemblies, drawings, documents) affected by this engineering change.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByName rdf:type rdf:Property ;
    rdfs:label 'Approved By Name' ;
    rdfs:comment 'Full name of the final approver who authorized the engineering change.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByTitle rdf:type rdf:Property ;
    rdfs:label 'Approved By Title' ;
    rdfs:comment 'Job title or role of the final approver (e.g., Chief Engineer, VP Engineering, Quality Manager).' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Customer Approval Date' ;
    rdfs:comment 'Date when customer approval was received for the engineering change.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerApprovalReceived rdf:type rdf:Property ;
    rdfs:label 'Customer Approval Received' ;
    rdfs:comment 'Indicates whether required customer approval has been obtained.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispositionAction rdf:type rdf:Property ;
    rdfs:label 'Disposition Action' ;
    rdfs:comment 'Primary disposition action for existing inventory and work-in-progress: use_as_is (no action required), rework (modify to new spec), scrap (discard), retrofit (field upgrade), return_to_supplier (vendor return).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecoDescription rdf:type rdf:Property ;
    rdfs:label 'Eco Description' ;
    rdfs:comment 'Detailed description of the engineering change including technical rationale, scope, and implementation approach.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivityDate rdf:type rdf:Property ;
    rdfs:label 'Effectivity Date' ;
    rdfs:comment 'Date when the engineering change becomes effective and must be implemented in production. Controls when new revision supersedes old revision.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivityReference rdf:type rdf:Property ;
    rdfs:label 'Effectivity Reference' ;
    rdfs:comment 'Reference value for effectivity (e.g., serial number, lot number, or date) that defines the cutover point for the change.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivityType rdf:type rdf:Property ;
    rdfs:label 'Effectivity Type' ;
    rdfs:comment 'Method by which the change takes effect: date (on specific date), serial_number (from specific unit serial), lot_batch (from specific production lot), immediate (next unit produced).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpSystemReference rdf:type rdf:Property ;
    rdfs:label 'Erp System Reference' ;
    rdfs:comment 'Reference identifier linking this ECO to the corresponding engineering change record in the ERP system (e.g., SAP S/4HANA).' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedScheduleImpactDays rdf:type rdf:Property ;
    rdfs:label 'Estimated Schedule Impact Days' ;
    rdfs:comment 'Estimated impact on production schedule in days. Positive values indicate delay; negative values indicate acceleration.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fromRevision rdf:type rdf:Property ;
    rdfs:label 'From Revision' ;
    rdfs:comment 'Current revision level of the primary affected item before the change is applied.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedDate rdf:type rdf:Property ;
    rdfs:label 'Initiated Date' ;
    rdfs:comment 'Date when the engineering change order was formally initiated and entered into the system.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initiatorDepartment rdf:type rdf:Property ;
    rdfs:label 'Initiator Department' ;
    rdfs:comment 'Organizational department or functional area of the change initiator (e.g., Product Engineering, Quality, Manufacturing Engineering).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatorEmail rdf:type rdf:Property ;
    rdfs:label 'Initiator Email' ;
    rdfs:comment 'Email address of the change initiator for communication and audit trail purposes.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plmSystemReference rdf:type rdf:Property ;
    rdfs:label 'Plm System Reference' ;
    rdfs:comment 'Reference identifier or URL linking this ECO to the corresponding record in the PLM system (e.g., Siemens Teamcenter).' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresCustomerApproval rdf:type rdf:Property ;
    rdfs:label 'Requires Customer Approval' ;
    rdfs:comment 'Indicates whether this engineering change requires formal customer notification and approval before implementation.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresSupplierNotification rdf:type rdf:Property ;
    rdfs:label 'Requires Supplier Notification' ;
    rdfs:comment 'Indicates whether this change requires notification to suppliers for purchased components or materials.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submittedDate rdf:type rdf:Property ;
    rdfs:label 'Submitted Date' ;
    rdfs:comment 'Date when the ECO was submitted for formal review and approval.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:toRevision rdf:type rdf:Property ;
    rdfs:label 'To Revision' ;
    rdfs:comment 'New revision level of the primary affected item after the change is applied.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineeringSiteId rdf:type rdf:Property ;
    rdfs:label 'Engineering Site Id' ;
    rdfs:comment 'Reference to the primary engineering facility or R&D center where the project work is being performed.' ;
    rdfs:domain ind:EngineeringProject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:financeBudgetId rdf:type rdf:Property ;
    rdfs:label 'Finance Budget Id' ;
    rdfs:comment 'Foreign key linking to finance.budget. Business justification: Each engineering project references a budget record for approved spending limits and forecasting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinanceBudget .

ind:primaryEngineeringEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Engineering Employee Id' ;
    rdfs:comment 'Reference to the employee responsible for managing and delivering the engineering project.' ;
    rdfs:domain ind:EngineeringProject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Actual Launch Date' ;
    rdfs:comment 'Actual date when the engineering project completed and the product was launched to production or market.' ;
    rdfs:domain ind:EngineeringProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetAllocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated Amount' ;
    rdfs:comment 'Total budget amount allocated to the engineering project for all development activities and resources.' ;
    rdfs:domain ind:EngineeringProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the project budget amounts.' ;
    rdfs:domain ind:EngineeringProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetSpentAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Spent Amount' ;
    rdfs:comment 'Cumulative amount of budget spent to date on the engineering project.' ;
    rdfs:domain ind:EngineeringProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessJustification rdf:type rdf:Property ;
    rdfs:label 'Business Justification' ;
    rdfs:comment 'Strategic rationale and business case for undertaking the engineering project, including expected ROI and market drivers.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collaborationPartners rdf:type rdf:Property ;
    rdfs:label 'Collaboration Partners' ;
    rdfs:comment 'List of external partners, suppliers, or research institutions collaborating on the engineering project.' ;
    rdfs:domain ind:EngineeringProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complexityScore rdf:type rdf:Property ;
    rdfs:label 'Complexity Score' ;
    rdfs:comment 'Numerical score (1-10) representing the technical and organizational complexity of the engineering project.' ;
    rdfs:domain ind:EngineeringProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:designMethodology rdf:type rdf:Property ;
    rdfs:label 'Design Methodology' ;
    rdfs:comment 'Engineering design and development methodology being applied to the project.' ;
    rdfs:domain ind:EngineeringProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designReviewCount rdf:type rdf:Property ;
    rdfs:label 'Design Review Count' ;
    rdfs:comment 'Number of formal design reviews conducted during the engineering project lifecycle.' ;
    rdfs:domain ind:EngineeringProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dfmAnalysisCompleted rdf:type rdf:Property ;
    rdfs:label 'Dfm Analysis Completed' ;
    rdfs:comment 'Indicates whether Design for Manufacturability analysis has been completed for the engineering project.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dfmeaCompleted rdf:type rdf:Property ;
    rdfs:label 'Dfmea Completed' ;
    rdfs:comment 'Indicates whether Design Failure Mode and Effects Analysis has been completed for the engineering project.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ecoCount rdf:type rdf:Property ;
    rdfs:label 'Eco Count' ;
    rdfs:comment 'Total number of Engineering Change Orders issued during the engineering project.' ;
    rdfs:domain ind:EngineeringProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:patentApplicationCount rdf:type rdf:Property ;
    rdfs:label 'Patent Application Count' ;
    rdfs:comment 'Number of patent applications filed as a result of innovations developed in the engineering project.' ;
    rdfs:domain ind:EngineeringProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pfmeaCompleted rdf:type rdf:Property ;
    rdfs:label 'Pfmea Completed' ;
    rdfs:comment 'Indicates whether Process Failure Mode and Effects Analysis has been completed for the engineering project.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppapRequired rdf:type rdf:Property ;
    rdfs:label 'Ppap Required' ;
    rdfs:comment 'Indicates whether Production Part Approval Process is required for the engineering project deliverables.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programPhase rdf:type rdf:Property ;
    rdfs:label 'Program Phase' ;
    rdfs:comment 'Current lifecycle phase of the engineering project within the product development process. [ENUM-REF-CANDIDATE: concept|feasibility|design|development|validation|launch|production|closed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EngineeringProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectDescription rdf:type rdf:Property ;
    rdfs:label 'Project Description' ;
    rdfs:comment 'Detailed narrative description of the engineering project objectives, scope, and deliverables.' ;
    rdfs:domain ind:EngineeringProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectName rdf:type rdf:Property ;
    rdfs:label 'Project Name' ;
    rdfs:comment 'Human-readable name of the engineering project describing the initiative or product being developed.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectStatus rdf:type rdf:Property ;
    rdfs:label 'Project Status' ;
    rdfs:comment 'Current operational status of the engineering project indicating its execution state.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectType rdf:type rdf:Property ;
    rdfs:label 'Project Type' ;
    rdfs:comment 'Classification of the engineering project based on its strategic purpose and scope.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prototypeCount rdf:type rdf:Property ;
    rdfs:label 'Prototype Count' ;
    rdfs:comment 'Number of physical or digital prototypes developed as part of the engineering project.' ;
    rdfs:domain ind:EngineeringProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryComplianceScope rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Scope' ;
    rdfs:comment 'List of regulatory standards and certifications that the engineering project must comply with (e.g., ISO 9001, CE, UL, IEC 61131).' ;
    rdfs:domain ind:EngineeringProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityTarget rdf:type rdf:Property ;
    rdfs:label 'Sustainability Target' ;
    rdfs:comment 'Environmental sustainability goals and targets for the engineering project (e.g., energy efficiency, carbon reduction, recyclability).' ;
    rdfs:domain ind:EngineeringProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Target Launch Date' ;
    rdfs:comment 'Planned date for the engineering project to complete development and transition to production or market launch.' ;
    rdfs:domain ind:EngineeringProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetMarketSegment rdf:type rdf:Property ;
    rdfs:label 'Target Market Segment' ;
    rdfs:comment 'Primary market segment or customer group that the engineering project is designed to serve.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamSizeCount rdf:type rdf:Property ;
    rdfs:label 'Team Size Count' ;
    rdfs:comment 'Number of engineers and team members assigned to the engineering project.' ;
    rdfs:domain ind:EngineeringProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:technologyPlatform rdf:type rdf:Property ;
    rdfs:label 'Technology Platform' ;
    rdfs:comment 'Core technology platform or architecture that the engineering project is based on (e.g., PLC, SCADA, IoT, IIoT).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySupersededByRevisionEngineeringRevisionId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Revision Engineering Revision Id' ;
    rdfs:comment 'Reference to the newer revision that supersedes this revision. Establishes the revision lineage chain for traceability and configuration management. Null if this is the current active revision.' ;
    rdfs:domain ind:EngineeringRevision ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EngineeringRevision .

ind:cadFileReference rdf:type rdf:Property ;
    rdfs:label 'Cad File Reference' ;
    rdfs:comment 'Reference path or identifier to the Computer-Aided Design (CAD) model file associated with this revision in the Product Data Management (PDM) or PLM system.' ;
    rdfs:domain ind:EngineeringRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceMarkingRequired rdf:type rdf:Property ;
    rdfs:label 'Ce Marking Required' ;
    rdfs:comment 'Flag indicating whether CE marking (European Conformity) is required for this revision. True indicates CE marking is mandatory for European market release.' ;
    rdfs:domain ind:EngineeringRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeImpactLevel rdf:type rdf:Property ;
    rdfs:label 'Change Impact Level' ;
    rdfs:comment 'Assessment of the impact magnitude of this revision on form, fit, function, quality, cost, or schedule. Critical indicates significant impact requiring extensive validation, low indicates minimal impact.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeJustification rdf:type rdf:Property ;
    rdfs:label 'Change Justification' ;
    rdfs:comment 'Business justification and summary description of why this revision was created. Captures the rationale for the design change, improvement, or correction.' ;
    rdfs:domain ind:EngineeringRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationBaseline rdf:type rdf:Property ;
    rdfs:label 'Configuration Baseline' ;
    rdfs:comment 'The configuration baseline identifier that this revision belongs to. Used for configuration management and as-designed vs as-built reconciliation.' ;
    rdfs:domain ind:EngineeringRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interchangeabilityCode rdf:type rdf:Property ;
    rdfs:label 'Interchangeability Code' ;
    rdfs:comment 'Indicates whether this revision is interchangeable with previous revisions. Fully interchangeable means drop-in replacement, form-fit-function means functionally equivalent, retrofit required means modification needed, not interchangeable means incompatible.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleState rdf:type rdf:Property ;
    rdfs:label 'Lifecycle State' ;
    rdfs:comment 'Current lifecycle state of the revision within the Product Lifecycle Management (PLM) workflow. In-work indicates active development, in-review indicates pending approval, approved indicates ready for release, released indicates production-ready, obsolete indicates no longer valid, superseded indicates replaced by newer revision, frozen indicates locked for reference. [ENUM-REF-CANDIDATE: in_work|in_review|approved|released|obsolete|superseded|frozen — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EngineeringRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:massProductionApproved rdf:type rdf:Property ;
    rdfs:label 'Mass Production Approved' ;
    rdfs:comment 'Flag indicating whether this revision has been approved for mass production. True indicates all validation activities are complete and production release is authorized.' ;
    rdfs:domain ind:EngineeringRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppapLevel rdf:type rdf:Property ;
    rdfs:label 'Ppap Level' ;
    rdfs:comment 'The PPAP submission level required for this revision (1-5). Level 1 is warrant only, Level 5 is full submission with samples. Null if PPAP is not required.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prototypeTestDate rdf:type rdf:Property ;
    rdfs:label 'Prototype Test Date' ;
    rdfs:comment 'The date when prototype testing was completed for this revision. Null if prototype testing has not been performed.' ;
    rdfs:domain ind:EngineeringRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prototypeTested rdf:type rdf:Property ;
    rdfs:label 'Prototype Tested' ;
    rdfs:comment 'Flag indicating whether a physical prototype of this revision has been built and tested. True indicates prototype validation is complete.' ;
    rdfs:domain ind:EngineeringRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reachCompliant rdf:type rdf:Property ;
    rdfs:label 'Reach Compliant' ;
    rdfs:comment 'Flag indicating whether this revision complies with REACH regulation for chemical substances. True indicates compliance with EU chemical safety requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Status' ;
    rdfs:comment 'Status of regulatory compliance assessment for this revision. Indicates whether the revision meets applicable regulatory requirements (ISO, IEC, UL, CE, OSHA, EPA).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseAuthority rdf:type rdf:Property ;
    rdfs:label 'Release Authority' ;
    rdfs:comment 'Name or identifier of the person, role, or committee that authorized the release of this revision. Captures the approval authority for traceability and compliance.' ;
    rdfs:domain ind:EngineeringRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseAuthorityRole rdf:type rdf:Property ;
    rdfs:label 'Release Authority Role' ;
    rdfs:comment 'The organizational role or title of the release authority (e.g., Chief Engineer, Engineering Manager, Change Control Board). Provides context for the approval level.' ;
    rdfs:domain ind:EngineeringRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionType rdf:type rdf:Property ;
    rdfs:label 'Revision Type' ;
    rdfs:comment 'Classification of the revision indicating the magnitude of change. Major revisions represent significant design changes, minor revisions represent incremental improvements, patch revisions represent corrections, branch revisions represent parallel variant development, and prototype revisions represent pre-release experimental versions.' ;
    rdfs:domain ind:EngineeringRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rohsCompliant rdf:type rdf:Property ;
    rdfs:label 'Rohs Compliant' ;
    rdfs:comment 'Flag indicating whether this revision complies with Restriction of Hazardous Substances (RoHS) directive. True indicates the design meets RoHS material restrictions.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specificationDocument rdf:type rdf:Property ;
    rdfs:label 'Specification Document' ;
    rdfs:comment 'Reference to the technical specification document that defines the requirements and characteristics for this revision.' ;
    rdfs:domain ind:EngineeringRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ulCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Ul Certification Required' ;
    rdfs:comment 'Flag indicating whether Underwriters Laboratories (UL) product safety certification is required for this revision. True indicates UL certification is mandatory for market release.' ;
    rdfs:domain ind:EngineeringRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supersededBySpecificationEngineeringSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Specification Engineering Specification Id' ;
    rdfs:comment 'Reference to the specification that supersedes this specification. Null if this specification is still current. Supports specification revision history and traceability.' ;
    rdfs:domain ind:EngineeringSpecification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EngineeringSpecification .

ind:acceptanceCriteria rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria' ;
    rdfs:comment 'Specific criteria and test methods used to determine whether a component or assembly meets the specification requirements. Defines pass/fail thresholds for inspection, testing, and validation activities.' ;
    rdfs:domain ind:EngineeringSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designAuthority rdf:type rdf:Property ;
    rdfs:label 'Design Authority' ;
    rdfs:comment 'Name or identifier of the engineering team, department, or individual responsible for the technical content and maintenance of this specification. Serves as the point of contact for specification-related questions and change requests.' ;
    rdfs:domain ind:EngineeringSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentFormat rdf:type rdf:Property ;
    rdfs:label 'Document Format' ;
    rdfs:comment 'File format of the specification document (e.g., PDF for released documents, DOCX for drafts, DWG for CAD drawings, STEP/IGES for 3D models, XML for structured data exchange).' ;
    rdfs:domain ind:EngineeringSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentLocation rdf:type rdf:Property ;
    rdfs:label 'Document Location' ;
    rdfs:comment 'File path, URL, or document management system reference where the full specification document is stored. Typically points to a location in Siemens Teamcenter PLM Document Management or a shared engineering repository.' ;
    rdfs:domain ind:EngineeringSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalConditions rdf:type rdf:Property ;
    rdfs:label 'Environmental Conditions' ;
    rdfs:comment 'Specified environmental operating conditions and limits, including temperature range, humidity, vibration, shock, altitude, and exposure to chemicals or contaminants. Critical for environmental-type specifications.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialStandard rdf:type rdf:Property ;
    rdfs:label 'Material Standard' ;
    rdfs:comment 'Specific material standard or grade required for the component or assembly (e.g., ASTM A36, SAE 304, ISO 898-1). Applicable primarily to material-type specifications.' ;
    rdfs:domain ind:EngineeringSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obsoleteDate rdf:type rdf:Property ;
    rdfs:label 'Obsolete Date' ;
    rdfs:comment 'Date when the specification was marked as obsolete or superseded. Null if the specification is still active.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceCriteria rdf:type rdf:Property ;
    rdfs:label 'Performance Criteria' ;
    rdfs:comment 'Detailed performance requirements and acceptance criteria that the component, assembly, or system must meet. Includes quantitative metrics such as load capacity, operating temperature range, voltage ratings, cycle life, and reliability targets.' ;
    rdfs:domain ind:EngineeringSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prototypeRequired rdf:type rdf:Property ;
    rdfs:label 'Prototype Required' ;
    rdfs:comment 'Indicates whether a prototype must be built and validated before the specification is approved for production use. Supports the Advanced Product Quality Planning (APQP) and Production Part Approval Process (PPAP) workflows.' ;
    rdfs:domain ind:EngineeringSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyRequirements rdf:type rdf:Property ;
    rdfs:label 'Safety Requirements' ;
    rdfs:comment 'Safety-related requirements and compliance criteria, including electrical safety, mechanical safety, functional safety, and hazard mitigation measures. Applicable to safety-type specifications and critical for certification.' ;
    rdfs:domain ind:EngineeringSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationNumber rdf:type rdf:Property ;
    rdfs:label 'Specification Number' ;
    rdfs:comment 'Business identifier for the specification document, typically following organizational numbering conventions. Externally-known unique code used for reference in engineering documentation, supplier communications, and design reviews.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationType rdf:type rdf:Property ;
    rdfs:label 'Specification Type' ;
    rdfs:comment 'Classification of the specification document by its primary purpose: material (material properties and composition), functional (operational requirements), interface (connection and integration standards), environmental (operating conditions and environmental compliance), safety (safety requirements and certifications), or performance (performance criteria and benchmarks).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierQualificationRequired rdf:type rdf:Property ;
    rdfs:label 'Supplier Qualification Required' ;
    rdfs:comment 'Indicates whether suppliers must undergo formal qualification and approval before being authorized to supply components or materials meeting this specification. Supports supplier management and procurement processes.' ;
    rdfs:domain ind:EngineeringSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testMethod rdf:type rdf:Property ;
    rdfs:label 'Test Method' ;
    rdfs:comment 'Standardized test method or procedure reference used to verify compliance with the specification (e.g., ASTM test methods, IEC test standards, internal test procedures). Links to quality inspection plans and validation protocols.' ;
    rdfs:domain ind:EngineeringSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceSpecification rdf:type rdf:Property ;
    rdfs:label 'Tolerance Specification' ;
    rdfs:comment 'Dimensional, geometric, and functional tolerances specified for the component or assembly. Defines acceptable variation ranges for critical dimensions and characteristics, supporting Design for Manufacturability (DFM) and Statistical Process Control (SPC).' ;
    rdfs:domain ind:EngineeringSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationDate rdf:type rdf:Property ;
    rdfs:label 'Validation Date' ;
    rdfs:comment 'Date when the design validation was completed. Null if validation is not yet complete. Key milestone in the product development lifecycle.' ;
    rdfs:domain ind:EngineeringSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activityId rdf:type rdf:Property ;
    rdfs:label 'Activity Id' ;
    rdfs:comment 'Foreign key linking to project.project_activity. Business justification: Test execution is scheduled as a project activity; linking test results to the activity enables traceability in the Project Execution Dashboard.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Activity .

ind:lotBatchId rdf:type rdf:Property ;
    rdfs:label 'Lot Batch Id' ;
    rdfs:comment 'Foreign key linking to inventory.lot_batch. Business justification: Quality Assurance links test results to the specific production batch for traceability and regulatory compliance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LotBatch .

ind:originalTestResultId rdf:type rdf:Property ;
    rdfs:label 'Original Test Result Id' ;
    rdfs:comment 'Reference to the original test result record if this is a retest. Creates traceability chain for test iterations.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestResult .

ind:testEngineerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Test Engineer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Test execution accountability; test reports reference the responsible test engineer for quality audits.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:testReportDocumentId rdf:type rdf:Property ;
    rdfs:label 'Test Report Document Id' ;
    rdfs:comment 'Identifier or reference to the formal test report document stored in the document management system. Links structured test data to detailed report artifacts.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProjectDocument .

ind:acceptanceCriteriaLowerLimit rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria Lower Limit' ;
    rdfs:comment 'Minimum acceptable value for the test measurement. Defines the lower boundary of the pass/fail acceptance range.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acceptanceCriteriaTarget rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria Target' ;
    rdfs:comment 'Target or nominal value for the test measurement. Represents the ideal design specification value within the acceptance range.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acceptanceCriteriaUpperLimit rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria Upper Limit' ;
    rdfs:comment 'Maximum acceptable value for the test measurement. Defines the upper boundary of the pass/fail acceptance range.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buildNumber rdf:type rdf:Property ;
    rdfs:label 'Build Number' ;
    rdfs:comment 'Prototype build iteration number or production batch identifier. Tracks which manufacturing build or prototype iteration the tested unit belongs to.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dvpRReference rdf:type rdf:Property ;
    rdfs:label 'Dvp R Reference' ;
    rdfs:comment 'Reference to the Design Verification Plan and Report document that governs this test. Links test execution to the master validation plan.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measuredValueUnit rdf:type rdf:Property ;
    rdfs:label 'Measured Value Unit' ;
    rdfs:comment 'Unit of measure for the measured value (e.g., volts, amps, degrees Celsius, newtons, cycles). Ensures correct interpretation of test measurements.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prototypePhase rdf:type rdf:Property ;
    rdfs:label 'Prototype Phase' ;
    rdfs:comment 'Development phase or maturity stage of the tested unit. Indicates whether the unit is a concept prototype, alpha build, beta unit, pre-production sample, or production unit.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Flag' ;
    rdfs:comment 'Indicates whether this test result is required for regulatory certification or compliance submission (e.g., UL, CE, FCC). Flags test data needed for regulatory dossiers.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retestFlag rdf:type rdf:Property ;
    rdfs:label 'Retest Flag' ;
    rdfs:comment 'Indicates whether this test is a retest of a previously failed or inconclusive test. Used to track test iteration history.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rootCauseAnalysisRequired rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Required' ;
    rdfs:comment 'Indicates whether a formal root cause analysis (RCA) is required for this test result. Typically true for test failures or unexpected results.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testDurationHours rdf:type rdf:Property ;
    rdfs:label 'Test Duration Hours' ;
    rdfs:comment 'Total elapsed time for test execution measured in hours. Captures the actual test run time for endurance and long-duration tests.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testFacility rdf:type rdf:Property ;
    rdfs:label 'Test Facility' ;
    rdfs:comment 'Name or identifier of the laboratory, test center, or facility where the test was conducted. May be internal lab or external third-party testing facility.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testFacilityLocation rdf:type rdf:Property ;
    rdfs:label 'Test Facility Location' ;
    rdfs:comment 'Geographic location or site code of the test facility. Supports multi-site test operations and regulatory reporting.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testNotes rdf:type rdf:Property ;
    rdfs:label 'Test Notes' ;
    rdfs:comment 'Free-form notes, observations, or comments recorded by the test engineer during test execution. Captures contextual information not covered by structured fields.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testOutcome rdf:type rdf:Property ;
    rdfs:label 'Test Outcome' ;
    rdfs:comment 'Overall pass/fail result of the test execution. Indicates whether the tested unit met the acceptance criteria defined in the test specification.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testPurpose rdf:type rdf:Property ;
    rdfs:label 'Test Purpose' ;
    rdfs:comment 'Business objective or reason for conducting the test. Describes the validation goal, such as design verification, production qualification, regulatory compliance, or failure investigation.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testSpecificationVersion rdf:type rdf:Property ;
    rdfs:label 'Test Specification Version' ;
    rdfs:comment 'Version or revision of the test specification document used for this test execution. Ensures traceability to the correct test procedure version.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStandardReference rdf:type rdf:Property ;
    rdfs:label 'Test Standard Reference' ;
    rdfs:comment 'Industry or regulatory standard governing the test procedure. References the specific standard, specification, or protocol followed during test execution (e.g., IEC 61131-2, UL 508, ISO 16750).' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStatus rdf:type rdf:Property ;
    rdfs:label 'Test Status' ;
    rdfs:comment 'Current lifecycle status of the test execution. Tracks the test through its workflow from scheduling to completion.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testedUnitIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tested Unit Identifier' ;
    rdfs:comment 'Unique identifier of the physical unit or sample subjected to testing. May be a serial number, prototype build number, or sample lot identifier.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ap Invoice Id' ;
    rdfs:comment 'System-generated unique identifier for the accounts payable invoice record.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bankStatementReconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Bank Statement Reconciliation Status' ;
    rdfs:comment 'Status of matching the payment against bank statement entries.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'Date used as the starting point for payment terms calculation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cashDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Cash Discount Percentage' ;
    rdfs:comment 'Percentage discount applied when payment is made within discount period.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currency rdf:type rdf:Property ;
    rdfs:label 'Currency' ;
    rdfs:comment 'Three-letter ISO 4217 code of the currency used for the invoice amounts.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Number' ;
    rdfs:comment 'Reference to the goods receipt confirming receipt of materials.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:houseBankAccount rdf:type rdf:Property ;
    rdfs:label 'House Bank Account' ;
    rdfs:comment 'Bank account from which the payment will be issued.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'Amount actually paid for the invoice.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBlockReason rdf:type rdf:Property ;
    rdfs:label 'Payment Block Reason' ;
    rdfs:comment 'Reason why payment processing is blocked for this invoice.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReference rdf:type rdf:Property ;
    rdfs:label 'Payment Reference' ;
    rdfs:comment 'Reference number provided by the bank for the payment transaction.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentValueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Value Date' ;
    rdfs:comment 'Date on which the payment amount is considered effective.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'Date the invoice was posted to the general ledger.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:threeWayMatchStatus rdf:type rdf:Property ;
    rdfs:label 'Three Way Match Status' ;
    rdfs:comment 'Result of PO/GR/IR verification: matched, unmatched, or partially matched.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'Amount of withholding tax deducted at source.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingTaxCode rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Code' ;
    rdfs:comment 'Code defining the withholding tax rate and rules.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arItemId rdf:type rdf:Property ;
    rdfs:label 'Ar Item Id' ;
    rdfs:comment 'System-generated unique identifier for the AR line item record.' ;
    rdfs:domain ind:ArItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agingBucket rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket' ;
    rdfs:comment 'Categorization of the outstanding amount based on days past due.' ;
    rdfs:domain ind:ArItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agingDays rdf:type rdf:Property ;
    rdfs:label 'Aging Days' ;
    rdfs:comment 'Number of days the invoice is overdue.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessArea rdf:type rdf:Property ;
    rdfs:label 'Business Area' ;
    rdfs:comment 'Higher-level grouping of profit centers for consolidated reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearedFlag rdf:type rdf:Property ;
    rdfs:label 'Cleared Flag' ;
    rdfs:comment 'Indicates whether the AR item has been fully settled.' ;
    rdfs:domain ind:ArItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'Four-character code identifying the legal entity within the enterprise.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditMemoAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Amount' ;
    rdfs:comment 'Total amount of credit memos applied to reduce the invoice balance.' ;
    rdfs:domain ind:ArItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditMemoFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Flag' ;
    rdfs:comment 'Indicates whether a credit memo has been issued against this AR item.' ;
    rdfs:domain ind:ArItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Invoice Amount' ;
    rdfs:comment 'Gross amount of the invoice in the document currency before discounts, taxes, or adjustments.' ;
    rdfs:domain ind:ArItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDescription rdf:type rdf:Property ;
    rdfs:label 'Invoice Description' ;
    rdfs:comment 'Free-text description of goods or services billed.' ;
    rdfs:domain ind:ArItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Last Payment Amount' ;
    rdfs:comment 'Amount of the most recent payment applied to this AR item.' ;
    rdfs:domain ind:ArItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPaymentMethod rdf:type rdf:Property ;
    rdfs:label 'Last Payment Method' ;
    rdfs:comment 'Payment method used for the most recent payment.' ;
    rdfs:domain ind:ArItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Amount' ;
    rdfs:comment 'Invoice amount expressed in the company code\'s functional currency.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialNumber rdf:type rdf:Property ;
    rdfs:label 'Material Number' ;
    rdfs:comment 'SAP material identifier for the product sold.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openAmount rdf:type rdf:Property ;
    rdfs:label 'Open Amount' ;
    rdfs:comment 'Remaining amount still outstanding after payments and adjustments.' ;
    rdfs:domain ind:ArItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Sales Order Number' ;
    rdfs:comment 'Sales order that generated the invoice.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segment rdf:type rdf:Property ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Business segment classification for reporting (e.g., Industrial, Services).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffAmount rdf:type rdf:Property ;
    rdfs:label 'Write Off Amount' ;
    rdfs:comment 'Amount that has been written off for this AR item.' ;
    rdfs:domain ind:ArItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffFlag rdf:type rdf:Property ;
    rdfs:label 'Write Off Flag' ;
    rdfs:comment 'Indicates whether the remaining balance has been written off as uncollectible.' ;
    rdfs:domain ind:ArItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountLabel rdf:type rdf:Property ;
    rdfs:label 'Account Label' ;
    rdfs:comment 'Human-readable name or label for the bank account used in reports and UI.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balance rdf:type rdf:Property ;
    rdfs:label 'Balance' ;
    rdfs:comment 'Current monetary balance of the account as of the latest reconciliation.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankAccountStatus rdf:type rdf:Property ;
    rdfs:label 'Bank Account Status' ;
    rdfs:comment 'Current lifecycle status of the bank account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAddress rdf:type rdf:Property ;
    rdfs:label 'Bank Address' ;
    rdfs:comment 'Physical address of the bank branch.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankBranch rdf:type rdf:Property ;
    rdfs:label 'Bank Branch' ;
    rdfs:comment 'Specific branch of the bank where the account is held.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankCity rdf:type rdf:Property ;
    rdfs:label 'Bank City' ;
    rdfs:comment 'City where the bank branch is located.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankContactNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Contact Number' ;
    rdfs:comment 'Telephone number for the bank branch.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankCountryCode rdf:type rdf:Property ;
    rdfs:label 'Bank Country Code' ;
    rdfs:comment 'Three-letter country code where the bank is located.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashPoolMembership rdf:type rdf:Property ;
    rdfs:label 'Cash Pool Membership' ;
    rdfs:comment 'Indicates if the account participates in a cash-pool (primary, secondary, or none).' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailyTransactionLimit rdf:type rdf:Property ;
    rdfs:label 'Daily Transaction Limit' ;
    rdfs:comment 'Maximum aggregate amount that can be processed in a single day.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveTo rdf:type rdf:Property ;
    rdfs:label 'Effective To' ;
    rdfs:comment 'Date when the bank account is no longer active (nullable for open-ended).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iban rdf:type rdf:Property ;
    rdfs:label 'Iban' ;
    rdfs:comment 'Standardized international account identifier for cross-border transactions.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalReference rdf:type rdf:Property ;
    rdfs:label 'Internal Reference' ;
    rdfs:comment 'Free-form field for internal notes or reference codes.' ;
    rdfs:domain ind:BankAccount ;
