    rdfs:comment 'Role performed by the resource on the activity (e.g., Engineer, Technician).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingRateType rdf:type rdf:Property ;
    rdfs:label 'Billing Rate Type' ;
    rdfs:comment 'Type of billing rate applied to the assignment.' ;
    rdfs:domain ind:ResourceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOvertime rdf:type rdf:Property ;
    rdfs:label 'Is Overtime' ;
    rdfs:comment 'Flag indicating whether the assignment includes overtime work.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedHours rdf:type rdf:Property ;
    rdfs:label 'Planned Hours' ;
    rdfs:comment 'Number of work hours originally planned for the assignment.' ;
    rdfs:domain ind:ResourceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resourceUtilizationCategory rdf:type rdf:Property ;
    rdfs:label 'Resource Utilization Category' ;
    rdfs:comment 'Classification of the resource\'s employment type for utilization reporting.' ;
    rdfs:domain ind:ResourceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillLevel rdf:type rdf:Property ;
    rdfs:label 'Skill Level' ;
    rdfs:comment 'Declared skill proficiency of the resource for the assigned role.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizationPercent rdf:type rdf:Property ;
    rdfs:label 'Utilization Percent' ;
    rdfs:comment 'Percentage of the resource\'s available capacity consumed by this assignment.' ;
    rdfs:domain ind:ResourceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityPlanId rdf:type rdf:Property ;
    rdfs:label 'Capacity Plan Id' ;
    rdfs:comment 'Foreign key linking to supply.capacity_plan. Business justification: Enables Capacity Utilization Report per WBS element, linking work center capacity to project breakdown.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapacityPlan .

ind:parentWbsWbsElementId rdf:type rdf:Property ;
    rdfs:label 'Parent Wbs Wbs Element Id' ;
    rdfs:comment 'Identifier of the immediate parent WBS element; null for top-level elements.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WbsElement .

ind:billingElementFlag rdf:type rdf:Property ;
    rdfs:label 'Billing Element Flag' ;
    rdfs:comment 'True if the WBS element is billable to a customer or external party.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedCost rdf:type rdf:Property ;
    rdfs:label 'Planned Cost' ;
    rdfs:comment 'Budgeted cost amount allocated to the WBS element.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsibleDepartmentCode rdf:type rdf:Property ;
    rdfs:label 'Responsible Department Code' ;
    rdfs:comment 'Organizational department that owns the WBS element.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementDescription rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Description' ;
    rdfs:comment 'Full textual description of the WBS element\'s scope and purpose.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementLevel rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Level' ;
    rdfs:comment 'Numeric depth of the element within the WBS hierarchy (root = 1).' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wbsElementStatus rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Status' ;
    rdfs:comment 'Current lifecycle status of the WBS element.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsType rdf:type rdf:Property ;
    rdfs:label 'Wbs Type' ;
    rdfs:comment 'Classification of the WBS element by business purpose.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apqpSkuMasterId rdf:type rdf:Property ;
    rdfs:label 'Apqp Sku Master Id' ;
    rdfs:comment 'FK to product.sku_master' ;
    rdfs:domain ind:ApqpProject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuMaster .

ind:primaryApqpCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Apqp Customer Account Id' ;
    rdfs:comment 'Identifier of the customer for whom this APQP project is being executed. Links to the customer master.' ;
    rdfs:domain ind:ApqpProject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:primaryApqpProgramManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Apqp Program Manager Employee Id' ;
    rdfs:comment 'Employee identifier of the program manager responsible for overall APQP project execution and coordination.' ;
    rdfs:domain ind:ApqpProject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryApqpSkuMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Apqp Sku Master Id' ;
    rdfs:comment 'Identifier of the product or component being launched or changed under this APQP project.' ;
    rdfs:domain ind:ApqpProject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuMaster .

ind:controlPlanCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Control Plan Completion Date' ;
    rdfs:comment 'Date when the control plan was completed and approved.' ;
    rdfs:domain ind:ApqpProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:controlPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Control Plan Status' ;
    rdfs:comment 'Completion status of the control plan deliverable, defining the process controls, inspection methods, and reaction plans for the manufacturing process.' ;
    rdfs:domain ind:ApqpProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossFunctionalTeamMembers rdf:type rdf:Property ;
    rdfs:label 'Cross Functional Team Members' ;
    rdfs:comment 'Comma-separated list or text description of cross-functional team members involved in the APQP project (engineering, manufacturing, quality, supply chain, etc.).' ;
    rdfs:domain ind:ApqpProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designFmeaCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Design Fmea Completion Date' ;
    rdfs:comment 'Date when the Design FMEA was completed and approved by the cross-functional team.' ;
    rdfs:domain ind:ApqpProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:designFmeaStatus rdf:type rdf:Property ;
    rdfs:label 'Design Fmea Status' ;
    rdfs:comment 'Completion status of the Design FMEA deliverable, a critical Phase 2 output identifying potential design failure modes.' ;
    rdfs:domain ind:ApqpProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateReview1Status rdf:type rdf:Property ;
    rdfs:label 'Gate Review 1 Status' ;
    rdfs:comment 'Status of the Phase 1 gate review, assessing readiness to proceed to product design and development.' ;
    rdfs:domain ind:ApqpProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateReview2Status rdf:type rdf:Property ;
    rdfs:label 'Gate Review 2 Status' ;
    rdfs:comment 'Status of the Phase 2 gate review, assessing product design completion and readiness for process design.' ;
    rdfs:domain ind:ApqpProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateReview3Status rdf:type rdf:Property ;
    rdfs:label 'Gate Review 3 Status' ;
    rdfs:comment 'Status of the Phase 3 gate review, assessing process design completion and readiness for validation.' ;
    rdfs:domain ind:ApqpProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateReview4Status rdf:type rdf:Property ;
    rdfs:label 'Gate Review 4 Status' ;
    rdfs:comment 'Status of the Phase 4 gate review, assessing product and process validation completion and readiness for production launch.' ;
    rdfs:domain ind:ApqpProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lessonsLearnedDocumented rdf:type rdf:Property ;
    rdfs:label 'Lessons Learned Documented' ;
    rdfs:comment 'Indicates whether lessons learned from this APQP project have been documented for continuous improvement (Phase 5 activity).' ;
    rdfs:domain ind:ApqpProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppapApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Ppap Approval Date' ;
    rdfs:comment 'Date when the customer approved the PPAP submission, authorizing full production.' ;
    rdfs:domain ind:ApqpProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ppapStatus rdf:type rdf:Property ;
    rdfs:label 'Ppap Status' ;
    rdfs:comment 'Status of the PPAP submission and approval process, the final gate for customer approval to begin production.' ;
    rdfs:domain ind:ApqpProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppapSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Ppap Submission Date' ;
    rdfs:comment 'Date when the PPAP package was submitted to the customer for approval.' ;
    rdfs:domain ind:ApqpProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:processFlowDiagramStatus rdf:type rdf:Property ;
    rdfs:label 'Process Flow Diagram Status' ;
    rdfs:comment 'Completion status of the process flow diagram deliverable, documenting the manufacturing process steps and sequence.' ;
    rdfs:domain ind:ApqpProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processFmeaCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Process Fmea Completion Date' ;
    rdfs:comment 'Date when the Process FMEA was completed and approved by the cross-functional team.' ;
    rdfs:domain ind:ApqpProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:processFmeaStatus rdf:type rdf:Property ;
    rdfs:label 'Process Fmea Status' ;
    rdfs:comment 'Completion status of the Process FMEA deliverable, a critical Phase 3 output identifying potential manufacturing process failure modes.' ;
    rdfs:domain ind:ApqpProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectNotes rdf:type rdf:Property ;
    rdfs:label 'Project Notes' ;
    rdfs:comment 'Free-text field for capturing additional notes, issues, or context related to the APQP project execution.' ;
    rdfs:domain ind:ApqpProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetProductionDate rdf:type rdf:Property ;
    rdfs:label 'Target Production Date' ;
    rdfs:comment 'Planned date for the product to enter full production following successful APQP completion and customer approval.' ;
    rdfs:domain ind:ApqpProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityAuditId rdf:type rdf:Property ;
    rdfs:label 'Quality Audit Id' ;
    rdfs:comment 'Unique identifier for the quality audit record. Primary key for the audit entity.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousAuditQualityAuditId rdf:type rdf:Property ;
    rdfs:label 'Previous Audit Quality Audit Id' ;
    rdfs:comment 'Reference to the previous audit of the same entity, enabling audit history tracking and trend analysis.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityAudit .

ind:programId rdf:type rdf:Property ;
    rdfs:label 'Program Id' ;
    rdfs:comment 'Reference to the annual or periodic audit program under which this audit was scheduled, linking to the master audit schedule and risk-based audit planning.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditProgram .

ind:auditCategory rdf:type rdf:Property ;
    rdfs:label 'Audit Category' ;
    rdfs:comment 'Categorization of the audit by the relationship to the audited party: internal (own departments/processes), external supplier (supplier facilities), external subcontractor (subcontractor sites), external customer (customer-mandated), certification (third-party certification body), surveillance (ongoing certification monitoring), or special (triggered by incident or complaint). [ENUM-REF-CANDIDATE: internal|external_supplier|external_subcontractor|external_customer|certification|surveillance|special — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditMethod rdf:type rdf:Property ;
    rdfs:label 'Audit Method' ;
    rdfs:comment 'The method by which the audit is conducted: on-site (physical presence at audited location), remote (virtual audit via video/document sharing), hybrid (combination of on-site and remote), or document review (desk audit of documentation only).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Number' ;
    rdfs:comment 'Business identifier for the audit, externally visible and used for tracking and reference across systems and documentation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditResult rdf:type rdf:Property ;
    rdfs:label 'Audit Result' ;
    rdfs:comment 'Overall result or conclusion of the audit: conforming (no major issues), non-conforming (major issues found), conditional pass (minor issues requiring follow-up), fail (critical issues), acceptable, or unacceptable.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'Detailed description of the audit scope, including the processes, departments, product lines, or ISO clauses covered. Defines the boundaries and focus areas of the audit.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditedEntityCountry rdf:type rdf:Property ;
    rdfs:label 'Audited Entity Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the audited entity location.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditedEntityLocation rdf:type rdf:Property ;
    rdfs:label 'Audited Entity Location' ;
    rdfs:comment 'Physical location or address of the audited entity, including city, state/province, and country.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditedEntityName rdf:type rdf:Property ;
    rdfs:label 'Audited Entity Name' ;
    rdfs:comment 'Name of the department, supplier, facility, or site being audited.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditedEntityType rdf:type rdf:Property ;
    rdfs:label 'Audited Entity Type' ;
    rdfs:comment 'Type of entity being audited: internal department, supplier facility, subcontractor site, customer site, manufacturing plant, warehouse, or laboratory. [ENUM-REF-CANDIDATE: internal_department|supplier|subcontractor|customer_site|manufacturing_plant|warehouse|laboratory — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditeeContactEmail rdf:type rdf:Property ;
    rdfs:label 'Auditee Contact Email' ;
    rdfs:comment 'Email address of the auditee contact for audit coordination and communication.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditeeContactName rdf:type rdf:Property ;
    rdfs:label 'Auditee Contact Name' ;
    rdfs:comment 'Name of the primary contact person at the audited entity responsible for coordinating the audit and providing access to information.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorIndependenceVerified rdf:type rdf:Property ;
    rdfs:label 'Auditor Independence Verified' ;
    rdfs:comment 'Flag indicating whether auditor independence and impartiality have been verified per ISO 19011 requirements, ensuring no conflict of interest.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capaStatus rdf:type rdf:Property ;
    rdfs:label 'Capa Status' ;
    rdfs:comment 'Current status of the CAPA process: not required, pending (awaiting submission), submitted, under review, approved, rejected, verified (effectiveness confirmed), or closed. [ENUM-REF-CANDIDATE: not_required|pending|submitted|under_review|approved|rejected|verified|closed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Capa Submission Date' ;
    rdfs:comment 'Actual date when the auditee submitted the CAPA plan or evidence of corrective actions taken.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conformingItemsCount rdf:type rdf:Property ;
    rdfs:label 'Conforming Items Count' ;
    rdfs:comment 'Number of checklist items found to be in full conformance with the audit criteria.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:durationDays rdf:type rdf:Property ;
    rdfs:label 'Duration Days' ;
    rdfs:comment 'Total duration of the audit in days, calculated from actual start to actual end date.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceCollected rdf:type rdf:Property ;
    rdfs:label 'Evidence Collected' ;
    rdfs:comment 'Description or reference to the objective evidence collected during the audit, such as documents reviewed, records examined, interviews conducted, and observations made.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadAuditorName rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Name' ;
    rdfs:comment 'Full name of the lead auditor for quick reference and reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadAuditorQualification rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Qualification' ;
    rdfs:comment 'Certification or qualification held by the lead auditor, such as ISO 9001 Lead Auditor, VDA 6.3 Process Auditor, or internal auditor certification.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorNcrCount rdf:type rdf:Property ;
    rdfs:label 'Major Ncr Count' ;
    rdfs:comment 'Number of major non-conformances identified during the audit. Major NCRs represent significant deviations that affect the QMS effectiveness or product quality.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorNcrCount rdf:type rdf:Property ;
    rdfs:label 'Minor Ncr Count' ;
    rdfs:comment 'Number of minor non-conformances identified during the audit. Minor NCRs represent isolated or less significant deviations that do not critically impact the QMS.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:objective rdf:type rdf:Property ;
    rdfs:label 'Objective' ;
    rdfs:comment 'Statement of the audit\'s purpose and intended outcomes, such as QMS conformance verification, process effectiveness assessment, supplier qualification, or compliance validation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationCount rdf:type rdf:Property ;
    rdfs:label 'Observation Count' ;
    rdfs:comment 'Number of observations or opportunities for improvement noted during the audit that do not constitute non-conformances but warrant attention.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reAuditRequired rdf:type rdf:Property ;
    rdfs:label 'Re Audit Required' ;
    rdfs:comment 'Flag indicating whether a follow-up re-audit is required to verify the effectiveness of corrective actions or to address major non-conformances.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reAuditScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Re Audit Scheduled Date' ;
    rdfs:comment 'Scheduled date for the follow-up re-audit to verify corrective action effectiveness.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Report Document Reference' ;
    rdfs:comment 'Document management system reference or file path to the formal audit report document.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Report Issued Date' ;
    rdfs:comment 'Date when the formal audit report was issued and distributed to relevant stakeholders.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:teamMembers rdf:type rdf:Property ;
    rdfs:label 'Team Members' ;
    rdfs:comment 'Comma-separated list of audit team member names or employee IDs participating in the audit alongside the lead auditor.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Capa Approved By Employee Id' ;
    rdfs:comment 'Employee identifier of the quality manager or authorized approver who formally approved the CAPA closure after verifying effectiveness. Required for ISO 9001 audit trail compliance.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionImplementationDate rdf:type rdf:Property ;
    rdfs:label 'Action Implementation Date' ;
    rdfs:comment 'The date on which the corrective and/or preventive actions were fully implemented in the production process or quality system. Marks the transition from planning to execution phase.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualClosureDate rdf:type rdf:Property ;
    rdfs:label 'Actual Closure Date' ;
    rdfs:comment 'The actual calendar date on which the CAPA was formally closed after successful verification of effectiveness. Null if the CAPA is still open. Used to calculate actual cycle time versus target.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedProcessCode rdf:type rdf:Property ;
    rdfs:label 'Affected Process Code' ;
    rdfs:comment 'Identifier of the manufacturing process, work center, or production routing step where the nonconformity was detected or originated. Sourced from SAP PP routing or Siemens Opcenter MES process definition.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaType rdf:type rdf:Property ;
    rdfs:label 'Capa Type' ;
    rdfs:comment 'Classifies whether the action is corrective (addressing an existing nonconformity), preventive (eliminating a potential nonconformity), or both. Drives workflow routing and reporting in SAP QM.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Containment Completion Date' ;
    rdfs:comment 'The date on which all immediate containment actions were completed and verified. Used to measure response speed and compliance with customer-mandated containment timelines.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionPlan rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan' ;
    rdfs:comment 'Detailed description of the permanent corrective actions planned to eliminate the root cause of the nonconformity and prevent recurrence. Includes process changes, design modifications, procedure updates, or training interventions.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Verification Date' ;
    rdfs:comment 'The date on which the effectiveness of the implemented actions was formally verified and documented. Required for CAPA closure per ISO 9001 Clause 10.2.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivenessVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Verification Method' ;
    rdfs:comment 'Description of the method used to verify that the implemented corrective and preventive actions were effective in eliminating the root cause and preventing recurrence. May include SPC monitoring, re-audit, production run data review, or customer feedback analysis.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessVerified rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Verified' ;
    rdfs:comment 'Indicates whether the corrective and preventive actions have been formally verified as effective. True when verification is complete and documented; False when verification is pending or failed. Required gate for CAPA closure.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:immediateContainmentAction rdf:type rdf:Property ;
    rdfs:label 'Immediate Containment Action' ;
    rdfs:comment 'Description of the short-term containment actions taken immediately upon detection of the nonconformity to prevent further defective product from reaching the customer or next process step. Corresponds to D3 in the 8D methodology.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lessonsLearned rdf:type rdf:Property ;
    rdfs:label 'Lessons Learned' ;
    rdfs:comment 'Summary of key lessons learned from the CAPA investigation and resolution that should be shared across the organization to prevent similar issues. Feeds into the knowledge management and APQP process for future product launches.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:n8dReportNumber rdf:type rdf:Property ;
    rdfs:label 'N8d Report Number' ;
    rdfs:comment 'Reference number of the formal 8D (Eight Disciplines) problem-solving report associated with this CAPA, if applicable. Used when customer-mandated 8D reporting is required, particularly in automotive and industrial OEM supply chains.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppapImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Ppap Impact Flag' ;
    rdfs:comment 'Indicates whether this CAPA requires a new or revised Production Part Approval Process (PPAP) submission due to process or design changes resulting from the corrective action. Relevant for automotive and industrial OEM supply chains.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preventiveActionPlan rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Plan' ;
    rdfs:comment 'Description of proactive actions planned to eliminate the causes of potential nonconformities before they occur. Addresses systemic risks identified during root cause analysis that may affect similar processes or products.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:problemDescription rdf:type rdf:Property ;
    rdfs:label 'Problem Description' ;
    rdfs:comment 'Detailed narrative describing the nonconformity, defect, or quality event that triggered the CAPA. Includes observed symptoms, affected product or process, and initial impact assessment. Corresponds to the problem statement in the 8D or CAPA methodology.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityStandardReference rdf:type rdf:Property ;
    rdfs:label 'Quality Standard Reference' ;
    rdfs:comment 'The specific quality standard clause, regulatory requirement, or customer specification that was violated or is being addressed by this CAPA. Examples: ISO 9001:2015 Clause 8.5.2, IATF 16949, customer-specific quality requirements.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceFlag rdf:type rdf:Property ;
    rdfs:label 'Recurrence Flag' ;
    rdfs:comment 'Indicates whether this CAPA addresses a recurring nonconformity that has been previously reported. True if the same or similar root cause has been identified in a prior CAPA. Used for chronic problem identification and escalation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rootCauseAnalysisMethod rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Method' ;
    rdfs:comment 'The structured methodology used to identify the root cause of the nonconformity. Common methods include 5-Why, Ishikawa (fishbone) diagram, 8D problem solving, Failure Mode and Effects Analysis (FMEA), fault tree analysis, or Pareto analysis. [ENUM-REF-CANDIDATE: 5_why|ishikawa|8d|fmea|fault_tree|pareto|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'High-level categorization of the root cause using the 6M Ishikawa framework: Man (human error), Machine (equipment), Material (raw material/component), Method (process/procedure), Measurement (inspection/calibration), or Environment (facility/conditions). Enables systemic trend analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Source Reference Number' ;
    rdfs:comment 'The identifier of the originating document or record that triggered this CAPA, such as an NCR number, audit finding reference, customer complaint ticket number, or SAP QM notification number. Enables traceability back to the triggering event.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetClosureDate rdf:type rdf:Property ;
    rdfs:label 'Target Closure Date' ;
    rdfs:comment 'The planned date by which all corrective and preventive actions must be implemented and verified as effective. Used for on-time closure KPI tracking and escalation management.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateOfConformanceId rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Conformance Id' ;
    rdfs:comment 'Primary key for certificate_of_conformance' ;
    rdfs:domain ind:CertificateOfConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Inspector Employee Id' ;
    rdfs:comment 'Employee identifier of the inspector who performed the quality inspection. Links to HR master data for competency verification.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:authorizedSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory Name' ;
    rdfs:comment 'Name of the authorized person who signed and approved the certificate for release. Typically a quality manager or authorized representative.' ;
    rdfs:domain ind:CertificateOfConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory Title' ;
    rdfs:comment 'Job title or position of the authorized signatory (e.g., Quality Manager, Plant Manager, Authorized Representative).' ;
    rdfs:domain ind:CertificateOfConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateLanguage rdf:type rdf:Property ;
    rdfs:label 'Certificate Language' ;
    rdfs:comment 'Language in which the certificate is issued (ISO 639-1 two-letter code or full language name). May be required for international shipments.' ;
    rdfs:domain ind:CertificateOfConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateStatus rdf:type rdf:Property ;
    rdfs:label 'Certificate Status' ;
    rdfs:comment 'Current lifecycle status of the certificate. Draft = under preparation, Issued = released to customer, Revised = updated version issued, Voided = cancelled, Superseded = replaced by newer version, Archived = historical record.' ;
    rdfs:domain ind:CertificateOfConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateType rdf:type rdf:Property ;
    rdfs:label 'Certificate Type' ;
    rdfs:comment 'Type of quality certificate issued. CoC = Certificate of Conformance, CoA = Certificate of Analysis, CoC_CoA = Combined certificate, Material_Test_Report = MTR, Mill_Test_Certificate = MTC for raw materials, Inspection_Certificate = third-party inspection.' ;
    rdfs:domain ind:CertificateOfConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conformanceStatement rdf:type rdf:Property ;
    rdfs:label 'Conformance Statement' ;
    rdfs:comment 'Formal statement declaring that the material conforms to specified requirements. Typically a standardized declaration text.' ;
    rdfs:domain ind:CertificateOfConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerName rdf:type rdf:Property ;
    rdfs:label 'Customer Name' ;
    rdfs:comment 'Name of the customer receiving this certificate. Denormalized for certificate document completeness.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSpecificRequirements rdf:type rdf:Property ;
    rdfs:label 'Customer Specific Requirements' ;
    rdfs:comment 'Additional customer-specific requirements or clauses that must be included in the certificate per customer contract or specification.' ;
    rdfs:domain ind:CertificateOfConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalSignatureReference rdf:type rdf:Property ;
    rdfs:label 'Digital Signature Reference' ;
    rdfs:comment 'Identifier or hash of the digital signature applied to the certificate for authenticity and non-repudiation. Used for electronic certificates.' ;
    rdfs:domain ind:CertificateOfConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuedDate rdf:type rdf:Property ;
    rdfs:label 'Issued Date' ;
    rdfs:comment 'Date when the certificate was officially issued and released to the customer or recipient.' ;
    rdfs:domain ind:CertificateOfConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issued Timestamp' ;
    rdfs:comment 'Precise timestamp when the certificate was officially issued, including time zone information for global traceability.' ;
    rdfs:domain ind:CertificateOfConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plantName rdf:type rdf:Property ;
    rdfs:label 'Plant Name' ;
    rdfs:comment 'Full name of the manufacturing plant or facility that produced the certified material.' ;
    rdfs:domain ind:CertificateOfConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppapSubmissionNumber rdf:type rdf:Property ;
    rdfs:label 'Ppap Submission Number' ;
    rdfs:comment 'PPAP submission identifier if this certificate is part of a PPAP package submitted to the customer.' ;
    rdfs:domain ind:CertificateOfConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Production Order Number' ;
    rdfs:comment 'Manufacturing order number under which the certified material was produced. Links certificate to production execution records.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityCertified rdf:type rdf:Property ;
    rdfs:label 'Quantity Certified' ;
    rdfs:comment 'Quantity of material covered by this certificate. Represents the amount tested and certified as conforming.' ;
    rdfs:domain ind:CertificateOfConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryComplianceStatement rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Statement' ;
    rdfs:comment 'Statement of compliance with applicable regulatory requirements (e.g., RoHS, REACH, FDA, CE marking). Lists regulations the product conforms to.' ;
    rdfs:domain ind:CertificateOfConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionReason rdf:type rdf:Property ;
    rdfs:label 'Revision Reason' ;
    rdfs:comment 'Explanation for why the certificate was revised. Documents the nature of corrections or updates made.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureDate rdf:type rdf:Property ;
    rdfs:label 'Signature Date' ;
    rdfs:comment 'Date when the authorized signatory signed and approved the certificate.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specificationReference rdf:type rdf:Property ;
    rdfs:label 'Specification Reference' ;
    rdfs:comment 'Reference to the product specification, standard, or drawing against which conformance is certified (e.g., ASTM A36, DIN 1234, customer spec XYZ-001).' ;
    rdfs:domain ind:CertificateOfConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationVersion rdf:type rdf:Property ;
    rdfs:label 'Specification Version' ;
    rdfs:comment 'Version or revision of the specification document referenced. Ensures traceability to correct specification revision.' ;
    rdfs:domain ind:CertificateOfConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testMethodReference rdf:type rdf:Property ;
    rdfs:label 'Test Method Reference' ;
    rdfs:comment 'Reference to the test methods or standards used for inspection and testing (e.g., ASTM E8, ISO 6892, EN 10002). May list multiple methods.' ;
    rdfs:domain ind:CertificateOfConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testResultsSummary rdf:type rdf:Property ;
    rdfs:label 'Test Results Summary' ;
    rdfs:comment 'Summary of key test results and measurements included in the certificate. May include chemical composition, mechanical properties, dimensional checks, etc.' ;
    rdfs:domain ind:CertificateOfConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceTestId rdf:type rdf:Property ;
    rdfs:label 'Compliance Test Id' ;
    rdfs:comment 'Unique identifier for the compliance test record. Primary key for the compliance test entity.' ;
    rdfs:domain ind:ComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificateIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Issued Date' ;
    rdfs:comment 'Date on which the compliance certificate was officially issued by the certifying body or testing laboratory.' ;
    rdfs:domain ind:ComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateValidFromDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Valid From Date' ;
    rdfs:comment 'Start date of the validity period for the compliance certificate, indicating when the certification becomes effective.' ;
    rdfs:domain ind:ComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateValidUntilDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Valid Until Date' ;
    rdfs:comment 'End date of the validity period for the compliance certificate, after which re-testing or re-certification may be required.' ;
    rdfs:domain ind:ComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerSpecificationReference rdf:type rdf:Property ;
    rdfs:label 'Customer Specification Reference' ;
    rdfs:comment 'Reference to customer-specific technical specifications, qualification requirements, or contractual testing obligations that this compliance test addresses.' ;
    rdfs:domain ind:ComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Laboratory Accreditation Number' ;
    rdfs:comment 'Accreditation number or certification identifier for the testing laboratory, demonstrating its authorization to perform compliance testing under relevant standards.' ;
    rdfs:domain ind:ComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryName rdf:type rdf:Property ;
    rdfs:label 'Laboratory Name' ;
    rdfs:comment 'Name of the specific laboratory or testing facility that performed the compliance test, including internal lab names or external accredited laboratory names.' ;
    rdfs:domain ind:ComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppapSubmissionLevel rdf:type rdf:Property ;
    rdfs:label 'Ppap Submission Level' ;
    rdfs:comment 'PPAP submission level associated with this compliance test, indicating the extent of documentation and testing required for customer approval in automotive or regulated industries.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationReference rdf:type rdf:Property ;
    rdfs:label 'Regulation Reference' ;
    rdfs:comment 'Specific regulatory requirement, directive, or legal framework reference that mandates this compliance test, including clause or section numbers where applicable.' ;
    rdfs:domain ind:ComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retestScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Retest Scheduled Date' ;
    rdfs:comment 'Planned date for conducting a retest to address failures, verify corrective actions, or renew expired certifications.' ;
    rdfs:domain ind:ComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Test Completion Date' ;
    rdfs:comment 'Date when the compliance test activities were completed and final results were determined.' ;
    rdfs:domain ind:ComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testConditions rdf:type rdf:Property ;
    rdfs:label 'Test Conditions' ;
    rdfs:comment 'Environmental and operational conditions under which the compliance test was performed, including temperature, humidity, voltage, frequency, load conditions, and any other relevant parameters.' ;
    rdfs:domain ind:ComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCostAmount rdf:type rdf:Property ;
    rdfs:label 'Test Cost Amount' ;
    rdfs:comment 'Total cost incurred for conducting the compliance test, including laboratory fees, material costs, and internal resource costs.' ;
    rdfs:domain ind:ComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Test Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the test cost amount, such as USD, EUR, or CNY.' ;
    rdfs:domain ind:ComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testEngineerName rdf:type rdf:Property ;
    rdfs:label 'Test Engineer Name' ;
    rdfs:comment 'Name of the test engineer or quality engineer responsible for the compliance test execution and validation.' ;
    rdfs:domain ind:ComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testLaboratory rdf:type rdf:Property ;
    rdfs:label 'Test Laboratory' ;
    rdfs:comment 'Type of laboratory where the compliance test was conducted, indicating whether it was performed internally, at an accredited external laboratory, at a customer facility, or by a third-party testing organization.' ;
    rdfs:domain ind:ComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testProcedureReference rdf:type rdf:Property ;
    rdfs:label 'Test Procedure Reference' ;
    rdfs:comment 'Reference to the documented test procedure, test plan, or test method used to conduct the compliance test, ensuring traceability and repeatability.' ;
    rdfs:domain ind:ComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testScope rdf:type rdf:Property ;
    rdfs:label 'Test Scope' ;
    rdfs:comment 'Detailed description of what is being tested, including the specific product components, assemblies, materials, or systems covered by this compliance test.' ;
    rdfs:domain ind:ComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStartDate rdf:type rdf:Property ;
    rdfs:label 'Test Start Date' ;
    rdfs:comment 'Date when the compliance test activities commenced at the testing laboratory or facility.' ;
    rdfs:domain ind:ComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionPlanId rdf:type rdf:Property ;
    rdfs:label 'Inspection Plan Id' ;
    rdfs:comment 'Reference to the SAP QM inspection plan or characteristic catalog entry that operationalizes this control plan characteristic on the shop floor. Links the APQP control plan to the executable inspection instructions.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionPlan .

ind:measurementSystemId rdf:type rdf:Property ;
    rdfs:label 'Measurement System Id' ;
    rdfs:comment 'Reference to the specific calibrated measurement instrument or gauge asset record in Maximo Asset Management used to measure this characteristic. Enables calibration status verification and MSA traceability.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MeasurementSystem .

ind:characteristicClass rdf:type rdf:Property ;
    rdfs:label 'Characteristic Class' ;
    rdfs:comment 'Classification of the quality characteristic by its impact on safety, regulatory compliance, or fit/function. Critical (safety/regulatory impact), Significant (functional impact), Major (customer-noticeable), Minor (cosmetic). Drives inspection frequency and reaction plan severity.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characteristicName rdf:type rdf:Property ;
    rdfs:label 'Characteristic Name' ;
    rdfs:comment 'Name or description of the quality characteristic being controlled (e.g., \'Weld Bead Width\', \'Torque Value\', \'Surface Roughness Ra\'). Directly corresponds to the CTQ characteristic defined in the PFMEA.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characteristicNumber rdf:type rdf:Property ;
    rdfs:label 'Characteristic Number' ;
    rdfs:comment 'Sequential number identifying the specific quality characteristic within the process step of this control plan row. Enables precise referencing of individual CTQ (Critical-to-Quality) characteristics.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characteristicType rdf:type rdf:Property ;
    rdfs:label 'Characteristic Type' ;
    rdfs:comment 'Indicates whether the characteristic is measured on a variable (continuous numeric) or attribute (pass/fail, go/no-go) scale. Determines the applicable SPC (Statistical Process Control) methodology and control chart type.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlMethod rdf:type rdf:Property ;
    rdfs:label 'Control Method' ;
    rdfs:comment 'The process control technique applied to monitor and control this characteristic (e.g., \'SPC X-bar/R Chart\', \'Pre-control Chart\', \'Poka-yoke\', \'Visual Standard\', \'Attribute Control Chart\', \'Process Parameter Monitoring\'). Core APQP deliverable field.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpkMinimumRequired rdf:type rdf:Property ;
    rdfs:label 'Cpk Minimum Required' ;
    rdfs:comment 'The minimum acceptable Cpk (Process Capability Index) value required for this characteristic to be considered capable. Typically 1.33 for production and 1.67 for critical/safety characteristics per AIAG PPAP requirements.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:errorProofingMethod rdf:type rdf:Property ;
    rdfs:label 'Error Proofing Method' ;
    rdfs:comment 'Description of the poka-yoke or error-proofing device/method applied at this process step to prevent or detect non-conformances (e.g., \'Torque monitoring with automatic shutdown\', \'Vision system barcode verification\', \'Fixture limit switch\'). Reduces reliance on operator inspection.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaugeType rdf:type rdf:Property ;
    rdfs:label 'Gauge Type' ;
    rdfs:comment 'Type or category of measurement instrument or gauge used for this characteristic (e.g., \'Vernier Caliper\', \'CMM\', \'Go/No-Go Gauge\', \'Torque Tester\', \'Vision System\'). Used for gauge calibration scheduling and MSA planning.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCtq rdf:type rdf:Property ;
    rdfs:label 'Is Ctq' ;
    rdfs:comment 'Indicates whether this characteristic is designated as Critical-to-Quality (CTQ), meaning it directly impacts customer satisfaction, safety, or regulatory compliance. CTQ characteristics receive enhanced monitoring and are mandatory in PPAP submissions.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryRequirement rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Requirement' ;
    rdfs:comment 'Indicates whether this characteristic is controlled to meet a specific regulatory or certification requirement (e.g., CE Marking, UL, IEC 62443, EPA, OSHA). Drives mandatory retention of inspection records for regulatory audit purposes.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSafetyCharacteristic rdf:type rdf:Property ;
    rdfs:label 'Is Safety Characteristic' ;
    rdfs:comment 'Indicates whether this characteristic is classified as a safety-critical characteristic (SC) per customer-specific requirements or regulatory mandates. Safety characteristics require 100% inspection or validated error-proofing (poka-yoke) and special PPAP documentation.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lowerSpecLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Spec Limit' ;
    rdfs:comment 'The lower engineering specification limit (LSL) for the quality characteristic. Measurements below this value are considered non-conforming. Used in Cp/Cpk process capability index calculations.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partRevision rdf:type rdf:Property ;
    rdfs:label 'Part Revision' ;
    rdfs:comment 'Engineering drawing or design revision level of the part at the time this control plan was created or last revised. Ensures traceability between the control plan and the specific design iteration it governs.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processStepName rdf:type rdf:Property ;
    rdfs:label 'Process Step Name' ;
    rdfs:comment 'Descriptive name of the manufacturing process step or operation (e.g., \'Welding\', \'CNC Machining\', \'Final Assembly Inspection\'). Provides human-readable context for the control being defined.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processStepNumber rdf:type rdf:Property ;
    rdfs:label 'Process Step Number' ;
    rdfs:comment 'Sequential identifier for the manufacturing process step or operation within the control plan (e.g., 10, 20, 30). Aligns with the process flow diagram and PFMEA step numbering per AIAG standards.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reactionPlan rdf:type rdf:Property ;
    rdfs:label 'Reaction Plan' ;
    rdfs:comment 'Prescribed corrective actions to be taken when the process goes out of control or a non-conformance is detected for this characteristic (e.g., \'Stop production, quarantine last 2 hours output, notify quality engineer, initiate NCR\'). Mandatory APQP control plan field.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleFrequency rdf:type rdf:Property ;
    rdfs:label 'Sample Frequency' ;
    rdfs:comment 'Frequency or trigger condition for performing the inspection (e.g., \'Every 2 hours\', \'Every 50 pieces\', \'First-off and last-off\', \'Each lot\', \'100% inspection\'). Defines the inspection cadence on the shop floor.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'Number of parts or units to be measured per inspection event for this characteristic. Defined per statistical sampling plan (e.g., ANSI/ASQ Z1.4, Z1.9) or engineering judgment. Drives inspection workload planning.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spcChartType rdf:type rdf:Property ;
    rdfs:label 'Spc Chart Type' ;
    rdfs:comment 'Type of SPC (Statistical Process Control) control chart applied to monitor this characteristic. Determines the statistical rules and control limit formulas used. Applicable only when control_method includes SPC. [ENUM-REF-CANDIDATE: xbar_r|xbar_s|individuals_mr|p_chart|np_chart|c_chart|u_chart — promote to reference product]' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upperSpecLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Spec Limit' ;
    rdfs:comment 'The upper engineering specification limit (USL) for the quality characteristic. Measurements exceeding this value are considered non-conforming. Used in Cp/Cpk process capability index calculations.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affectedBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Affected Batch Number' ;
    rdfs:comment 'Manufacturing batch or lot number of the affected product. Critical for batch recall analysis, SPC investigation, and supplier quality correlation.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Affected Serial Number' ;
    rdfs:comment 'Serial number of the specific unit reported in the complaint. Enables unit-level traceability through manufacturing, shipping, and field service records.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintDescription rdf:type rdf:Property ;
    rdfs:label 'Complaint Description' ;
    rdfs:comment 'Full narrative description of the customer complaint including observed symptoms, conditions of failure, and customer-reported impact. Corresponds to SAP QM QN Problem Description field.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintNumber rdf:type rdf:Property ;
    rdfs:label 'Complaint Number' ;
    rdfs:comment 'Externally-visible, human-readable complaint reference number used in customer communications and SAP QM Quality Notification (QN). Format: CC-YYYY-NNNNNN.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintSource rdf:type rdf:Property ;
    rdfs:label 'Complaint Source' ;
    rdfs:comment 'Origin channel or party type from which the complaint was received. Supports segmentation of complaint volumes by customer tier.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintStatus rdf:type rdf:Property ;
    rdfs:label 'Complaint Status' ;
    rdfs:comment 'Current workflow state of the complaint record. Drives escalation, SLA tracking, and reporting. \'pending_customer\' indicates awaiting customer feedback or approval.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintTitle rdf:type rdf:Property ;
    rdfs:label 'Complaint Title' ;
    rdfs:comment 'Short, human-readable summary title of the complaint as entered by the quality engineer or service representative. Used in dashboards and notification emails.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintType rdf:type rdf:Property ;
    rdfs:label 'Complaint Type' ;
    rdfs:comment 'Categorization of the complaint by nature of the issue. Used for trend analysis, routing, and regulatory reporting. [ENUM-REF-CANDIDATE: product_defect|field_failure|delivery_issue|documentation_error|safety_concern|performance_deviation — promote to reference product]' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentAction rdf:type rdf:Property ;
    rdfs:label 'Containment Action' ;
    rdfs:comment 'Immediate containment action taken to prevent further defective product from reaching the customer, corresponding to Step D3 of the 8D problem-solving methodology. Includes field holds, sorting, or shipment stops.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentDate rdf:type rdf:Property ;
    rdfs:label 'Containment Date' ;
    rdfs:comment 'Date on which the containment action was implemented. Used to measure response speed and SLA compliance for initial containment.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Completed Date' ;
    rdfs:comment 'Actual date on which the permanent corrective action was fully implemented and verified effective.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Acceptance Status' ;
    rdfs:comment 'Status of the customer\'s acceptance of the proposed resolution or 8D corrective action response. Determines whether the complaint can be formally closed.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerResponseDate rdf:type rdf:Property ;
    rdfs:label 'Customer Response Date' ;
    rdfs:comment 'Date on which the formal response (e.g., 8D report, corrective action plan) was communicated to the customer. Used for SLA compliance measurement.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:defectLocation rdf:type rdf:Property ;
    rdfs:label 'Defect Location' ;
    rdfs:comment 'Physical location or component area on the product where the defect or failure was observed. Supports PFMEA and design engineering root cause analysis.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eightDReportNumber rdf:type rdf:Property ;
    rdfs:label 'Eight D Report Number' ;
    rdfs:comment 'Reference number of the formal 8D (Eight Disciplines) problem-solving report issued to the customer. Required by many OEM customers as part of complaint resolution documentation.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRegulatoryReportable rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Reportable' ;
    rdfs:comment 'Indicates whether this complaint must be reported to a regulatory authority (e.g., OSHA, EPA, UL, CE Marking body). Triggers compliance workflow and documentation requirements.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSafetyRelated rdf:type rdf:Property ;
    rdfs:label 'Is Safety Related' ;
    rdfs:comment 'Indicates whether the complaint involves a potential safety hazard to personnel or end users. Triggers mandatory escalation to product safety and regulatory teams per OSHA and CE Marking requirements.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityComplained rdf:type rdf:Property ;
    rdfs:label 'Quantity Complained' ;
    rdfs:comment 'Number of units reported as defective or non-conforming in the complaint. Used for severity assessment and potential recall scope estimation.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityReturned rdf:type rdf:Property ;
    rdfs:label 'Quantity Returned' ;
    rdfs:comment 'Number of units physically returned by the customer under a Return Material Authorization (RMA). May differ from quantity complained if partial returns occur.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'Precise date and time when the complaint was received and logged in the system. Used for SLA response-time measurement.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:salesforceCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Salesforce Case Number' ;
    rdfs:comment 'Cross-reference identifier from Salesforce Service Cloud case record linked to this complaint, enabling traceability between CRM and quality management systems.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapQnNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Qn Number' ;
    rdfs:comment 'SAP QM Quality Notification number corresponding to this complaint, used for traceability within SAP S/4HANA QM module.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityPpapSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Quality Ppap Submission Id' ;
    rdfs:comment 'Reference to the PPAP submission package that includes this FMEA as a required deliverable. The FMEA is a mandatory PPAP element per AIAG PPAP 4th Edition. Links quality analysis to the formal part approval process.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PpapSubmission .

ind:responsiblePersonEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: REQUIRED: FMEA requires a designated owner; linking to employee allows tracking of accountability and effectiveness verification.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:fmeaNumber rdf:type rdf:Property ;
    rdfs:label 'Fmea Number' ;
    rdfs:comment 'Externally-known, human-readable document control number assigned to the FMEA record in Siemens Teamcenter PLM. Used for cross-referencing in engineering change orders (ECOs), PPAP packages, and APQP deliverables.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmeaScope rdf:type rdf:Property ;
    rdfs:label 'Fmea Scope' ;
    rdfs:comment 'Description of the boundaries and scope of the FMEA analysis, including what is included and excluded from the analysis. Defines the system boundary, interfaces, and assumptions. Required for AIAG-VDA Step 2 (Structure Analysis).' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmeaStatus rdf:type rdf:Property ;
    rdfs:label 'Fmea Status' ;
    rdfs:comment 'Current lifecycle state of the FMEA document within the Siemens Teamcenter PLM workflow. Controls whether the FMEA is editable, under review, formally released for production use, or retired.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmeaType rdf:type rdf:Property ;
    rdfs:label 'Fmea Type' ;
    rdfs:comment 'Classification of the FMEA by analysis scope: DFMEA (Design FMEA) evaluates design-related failure modes; PFMEA (Process FMEA) evaluates manufacturing process failure modes; SFMEA (System FMEA) evaluates system-level interactions; MFMEA (Machinery FMEA) evaluates equipment failure modes. Aligned with AIAG-VDA methodology.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionDescription rdf:type rdf:Property ;
    rdfs:label 'Function Description' ;
    rdfs:comment 'Description of the intended function or purpose of the item, component, or process step being analyzed. Defines what the element is supposed to do under normal operating conditions. Core AIAG-VDA Step 3 field.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processStep rdf:type rdf:Property ;
    rdfs:label 'Process Step' ;
    rdfs:comment 'Name or description of the specific manufacturing process step or operation being analyzed in a PFMEA (e.g., \'Welding Station 3\', \'CNC Milling Op 20\'). Derived from the process routing in SAP S/4HANA PP or Siemens Opcenter MES.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Critical Flag' ;
    rdfs:comment 'Indicates whether the failure mode has a safety-critical or regulatory compliance impact (severity rating 9 or 10). Safety-critical failure modes require mandatory escalation, special controls, and PPAP documentation. Aligned with OSHA and CE Marking requirements.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialCharacteristicCode rdf:type rdf:Property ;
    rdfs:label 'Special Characteristic Code' ;
    rdfs:comment 'Designation indicating whether the failure mode relates to a special product or process characteristic requiring enhanced control. SC = Special Characteristic; CC = Critical Characteristic; KPC = Key Product Characteristic; KCC = Key Control Characteristic. Drives control plan and inspection plan requirements.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Inspection Material Master Id' ;
    rdfs:comment 'FK to inventory.material_master' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:primaryInspectionMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Inspection Material Master Id' ;
    rdfs:comment 'Reference to the material or part master record subject to this inspection lot. Links to the product/material master in SAP MM/PLM for BOM and specification retrieval.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:certificateOfConformanceRequired rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Conformance Required' ;
    rdfs:comment 'Indicates whether a Certificate of Conformance (CoC) or quality certificate must be generated and issued upon acceptance of this inspection lot. Driven by customer contract requirements or regulatory mandates.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defectCount rdf:type rdf:Property ;
    rdfs:label 'Defect Count' ;
    rdfs:comment 'Total number of defects or non-conformances detected across all inspection characteristics within this lot. Used for defect rate calculation, SPC analysis, and NCR triggering thresholds.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispositionBy rdf:type rdf:Property ;
    rdfs:label 'Disposition By' ;
    rdfs:comment 'User ID or name of the quality engineer or authorized personnel who recorded the usage decision and disposition for this inspection lot. Supports accountability and audit trail requirements.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionCode rdf:type rdf:Property ;
    rdfs:label 'Disposition Code' ;
    rdfs:comment 'SAP QM usage decision code (e.g., A1=Accept, R1=Reject, R2=Rework, S1=Scrap) providing a standardized coded classification of the disposition decision for system processing and reporting.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disposition Timestamp' ;
    rdfs:comment 'Date and time when the usage decision (disposition) was formally recorded in the quality management system. Marks the closure of the active inspection phase and triggers downstream stock posting or NCR creation.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dynamicModificationRule rdf:type rdf:Property ;
    rdfs:label 'Dynamic Modification Rule' ;
    rdfs:comment 'Code or name of the dynamic modification rule applied to automatically adjust the inspection level (normal/tightened/reduced/skip) based on cumulative quality history for this material-supplier or material-plant combination. Aligns with SAP QM dynamic modification.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionLevel rdf:type rdf:Property ;
    rdfs:label 'Inspection Level' ;
    rdfs:comment 'Current inspection severity level applied to this lot based on the supplier or process quality history. \'normal\' = standard AQL sampling; \'tightened\' = increased scrutiny due to recent failures; \'reduced\' = relaxed sampling due to consistent quality; \'skip\' = lot accepted without inspection based on skip-lot qualification.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionTypeCode rdf:type rdf:Property ;
    rdfs:label 'Inspection Type Code' ;
    rdfs:comment 'SAP QM inspection type code classifying the origin and nature of the inspection lot. Standard SAP codes: 01=Goods Receipt from Purchase Order (incoming), 04=Goods Receipt from Production Order (final), 05=Goods Issue, 06=Delivery to Customer, 08=In-Process Inspection, 10=Recurring Inspection, 89=RMA/Customer Return Receipt. [ENUM-REF-CANDIDATE: 01|04|05|06|08|10|89 — promote to reference product for full SAP inspection type catalogue]' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Inspection Type Description' ;
    rdfs:comment 'Business-readable classification of the inspection event type: \'incoming\' = supplier goods receipt; \'in_process\' = mid-production milestone check; \'final\' = post-production completion check; \'recurring\' = periodic scheduled inspection; \'rma_receipt\' = customer return receipt inspection; \'delivery\' = pre-shipment inspection; \'goods_issue\' = outbound goods inspection. [ENUM-REF-CANDIDATE: incoming|in_process|final|recurring|rma_receipt|delivery|goods_issue — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotOriginTimestamp rdf:type rdf:Property ;
    rdfs:label 'Lot Origin Timestamp' ;
    rdfs:comment 'The principal real-world business event timestamp recording when the inspection lot was triggered and created in the quality management system. Distinct from ETL audit timestamps. Aligns with SAP QM lot creation date/time.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lotQuantity rdf:type rdf:Property ;
    rdfs:label 'Lot Quantity' ;
    rdfs:comment 'Total quantity of material or units submitted for inspection in this lot. Represents the population from which samples are drawn. Expressed in the base unit of measure of the material.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Lot Quantity Uom' ;
    rdfs:comment 'Unit of measure for the inspection lot quantity (e.g., EA=Each, KG=Kilogram, M=Meter, L=Liter, M2=Square Meter). Aligns with SAP base unit of measure from material master.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotRemarks rdf:type rdf:Property ;
    rdfs:label 'Lot Remarks' ;
    rdfs:comment 'Free-text field for quality engineers to record observations, special conditions, deviations, or contextual notes relevant to this inspection lot that are not captured in structured fields. Supports audit documentation.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncrTriggered rdf:type rdf:Property ;
    rdfs:label 'Ncr Triggered' ;
    rdfs:comment 'Indicates whether a Non-Conformance Report (NCR) was automatically or manually triggered as a result of this inspection lot\'s reject disposition or detected non-conformances. True = NCR created; False = no NCR required.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nonconformingQuantity rdf:type rdf:Property ;
    rdfs:label 'Nonconforming Quantity' ;
    rdfs:comment 'Quantity of units or material within the lot that failed to meet specification requirements. Expressed in the same unit of measure as lot_quantity. Used to calculate reject rate and determine disposition scope.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallResult rdf:type rdf:Property ;
    rdfs:label 'Overall Result' ;
    rdfs:comment 'Summarized quality outcome of the inspection lot based on all characteristic results evaluated against acceptance criteria. \'passed\' = all characteristics within specification; \'failed\' = one or more characteristics out of specification; \'conditionally_passed\' = passed with documented deviations; \'pending\' = results not yet fully recorded.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredEndDate rdf:type rdf:Property ;
    rdfs:label 'Required End Date' ;
    rdfs:comment 'Target date by which the inspection lot must be completed and a usage decision recorded, as defined by the inspection plan or production schedule. Supports SLA monitoring and escalation management.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleDrawingProcedure rdf:type rdf:Property ;
    rdfs:label 'Sample Drawing Procedure' ;
    rdfs:comment 'Code or name of the sampling procedure applied to determine the sample size for this inspection lot (e.g., AQL 1.0, AQL 2.5, 100% inspection, skip-lot). Derived from the inspection plan sampling scheme.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aqlLevel rdf:type rdf:Property ;
    rdfs:label 'Aql Level' ;
    rdfs:comment 'Acceptable Quality Level expressed as a percentage defective, defining the maximum tolerable defect rate for the sampling plan. Used in conjunction with ISO 2859-1 / ANSI Z1.4 sampling tables.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:characteristicCount rdf:type rdf:Property ;
    rdfs:label 'Characteristic Count' ;
    rdfs:comment 'Total number of inspection characteristics (measurement parameters) defined within this inspection plan. Provides a quick summary of plan complexity for scheduling and resource planning.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:characteristicUnit rdf:type rdf:Property ;
    rdfs:label 'Characteristic Unit' ;
    rdfs:comment 'Unit of measure for the inspection characteristic tolerance limits and target value (e.g., mm, µm, N, bar, °C, %). Aligns with SAP QM master inspection characteristic unit.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlMethodCode rdf:type rdf:Property ;
    rdfs:label 'Control Method Code' ;
    rdfs:comment 'Code identifying the measurement or control method used during inspection (e.g., visual, dimensional, functional, chemical, SPC chart). References the SAP QM master inspection characteristic control indicator.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlPlanReference rdf:type rdf:Property ;
    rdfs:label 'Control Plan Reference' ;
    rdfs:comment 'Document number of the associated APQP Control Plan that this inspection plan implements. The control plan defines the process controls and reaction plans linked to inspection characteristics.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpkMinimum rdf:type rdf:Property ;
    rdfs:label 'Cpk Minimum' ;
    rdfs:comment 'Minimum acceptable Cpk (Process Capability Index) value required for this inspection characteristic. Typically 1.33 for standard processes and 1.67 for safety-critical characteristics per PPAP requirements.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerSpecificRequirement rdf:type rdf:Property ;
    rdfs:label 'Customer Specific Requirement' ;
    rdfs:comment 'Indicates whether this inspection plan was created or modified to satisfy a specific customer quality requirement (CSR) beyond standard internal or regulatory requirements. Relevant for OEM (Original Equipment Manufacturer) supply relationships.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fmeaReference rdf:type rdf:Property ;
    rdfs:label 'Fmea Reference' ;
    rdfs:comment 'Document number or identifier of the associated PFMEA (Process Failure Mode and Effects Analysis) or DFMEA (Design Failure Mode and Effects Analysis) that informed the inspection characteristics and control methods in this plan.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionMethodCode rdf:type rdf:Property ;
    rdfs:label 'Inspection Method Code' ;
    rdfs:comment 'Reference to the standardized inspection method or test procedure document used to perform the inspection. Links to the SAP QM inspection method master record.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStage rdf:type rdf:Property ;
    rdfs:label 'Inspection Stage' ;
    rdfs:comment 'Stage in the production or supply chain process at which the inspection is performed. Incoming covers receiving inspection; in-process covers WIP (Work In Progress) checks; final covers end-of-line; outgoing covers pre-shipment; skip indicates skip-lot logic.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longTextDescription rdf:type rdf:Property ;
    rdfs:label 'Long Text Description' ;
    rdfs:comment 'Detailed narrative description of the inspection plan scope, special instructions, safety precautions, and any additional context required by the inspector. Corresponds to SAP QM long text on the task list header.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowerToleranceLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Tolerance Limit' ;
    rdfs:comment 'Lower specification limit for the primary inspection characteristic. Values below this limit result in a non-conformance. Used in SPC and Cp/Cpk capability index calculations.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'Version or revision number of the inspection plan, corresponding to the SAP QM plan group counter. Tracks engineering changes and revisions aligned with ECO/ECN processes.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productGroupCode rdf:type rdf:Property ;
    rdfs:label 'Product Group Code' ;
    rdfs:comment 'SAP material group or product family code to which this inspection plan applies. Enables grouping of inspection plans by product category for reporting and analytics.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSizeUnit rdf:type rdf:Property ;
    rdfs:label 'Sample Size Unit' ;
    rdfs:comment 'Unit of measure for the sample size quantity (e.g., EA for each/piece, KG for kilogram, M for meter). Aligns with SAP base unit of measure for the material. [ENUM-REF-CANDIDATE: EA|PC|KG|M|L|M2|M3 — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingProcedureCode rdf:type rdf:Property ;
    rdfs:label 'Sampling Procedure Code' ;
    rdfs:comment 'Code referencing the statistical sampling procedure applied in this inspection plan, including sample size, acceptance number, and rejection number per AQL (Acceptable Quality Level) tables.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spcEnabled rdf:type rdf:Property ;
    rdfs:label 'Spc Enabled' ;
    rdfs:comment 'Indicates whether SPC (Statistical Process Control) charting and Cp/Cpk capability monitoring are activated for this inspection plan. When true, measurement results feed into control charts and process capability analysis.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:upperToleranceLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Tolerance Limit' ;
    rdfs:comment 'Upper specification limit for the primary inspection characteristic. Values exceeding this limit result in a non-conformance. Used in SPC (Statistical Process Control) and Cp/Cpk capability index calculations.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageDecisionCode rdf:type rdf:Property ;
    rdfs:label 'Usage Decision Code' ;
    rdfs:comment 'SAP QM usage decision code that defines the default disposition action (accept, reject, rework) applied when inspection results meet or fail acceptance criteria.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionResultId rdf:type rdf:Property ;
    rdfs:label 'Inspection Result Id' ;
    rdfs:comment 'Unique surrogate identifier for each inspection characteristic result record within an inspection lot. Primary key for the inspection_result data product in the quality domain.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:characteristicId rdf:type rdf:Property ;
    rdfs:label 'Characteristic Id' ;
    rdfs:comment 'Reference to the master inspection characteristic definition (e.g., dimension, hardness, visual attribute) as configured in the inspection plan. Enables aggregation of results across lots for SPC analysis.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionCharacteristic .

ind:attributeResult rdf:type rdf:Property ;
    rdfs:label 'Attribute Result' ;
    rdfs:comment 'Pass/fail judgment for attribute-type inspection characteristics (e.g., visual defect present/absent, functional test pass/fail). Null for variable characteristics where measured_value is populated.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characteristicCode rdf:type rdf:Property ;
    rdfs:label 'Characteristic Code' ;
    rdfs:comment 'Alphanumeric code identifying the specific quality characteristic being measured (e.g., DIM-001 for a dimensional check, SURF-003 for surface finish). Used for cross-lot SPC charting and reporting.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpIndex rdf:type rdf:Property ;
    rdfs:label 'Cp Index' ;
    rdfs:comment 'Process capability index Cp measuring the ratio of the specification width to the process spread (6-sigma). Indicates whether the process is capable of meeting specification limits regardless of centering. Cp ≥ 1.33 is typically required per PPAP.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpkIndex rdf:type rdf:Property ;
    rdfs:label 'Cpk Index' ;
    rdfs:comment 'Process capability index Cpk measuring the ratio of the nearest specification limit to the process mean, accounting for process centering. Cpk ≥ 1.33 is typically required for PPAP approval. Key metric for supplier quality and process performance reporting.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectCode rdf:type rdf:Property ;
    rdfs:label 'Defect Code' ;
    rdfs:comment 'Standardized defect classification code identifying the type of nonconformance detected (e.g., DIM-OOT for out-of-tolerance dimension, SURF-SCR for surface scratch). Feeds Pareto analysis and CAPA root cause categorization. [ENUM-REF-CANDIDATE: promote to reference product for defect code catalog]' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectDescription rdf:type rdf:Property ;
    rdfs:label 'Defect Description' ;
    rdfs:comment 'Free-text description of the nonconformance or defect observed during inspection. Provides context beyond the defect code for root cause analysis and CAPA documentation.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOutOfControl rdf:type rdf:Property ;
    rdfs:label 'Is Out Of Control' ;
    rdfs:comment 'Indicates whether the measurement triggered an SPC out-of-control signal (e.g., point beyond control limits, run rule violation per Western Electric rules). Distinct from out-of-spec: a process can be in-spec but out-of-control. Triggers SPC investigation workflow.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOutOfSpec rdf:type rdf:Property ;
    rdfs:label 'Is Out Of Spec' ;
    rdfs:comment 'Indicates whether the measured value falls outside the engineering specification limits (USL or LSL). True when measured_value > upper_spec_limit or measured_value < lower_spec_limit. Used for rapid filtering of nonconforming results and NCR triggering.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ncrNumber rdf:type rdf:Property ;
    rdfs:label 'Ncr Number' ;
    rdfs:comment 'Reference number of the Non-Conformance Report (NCR) raised as a result of this inspection finding. Populated when result_status is \'rejected\' or attribute_result is \'fail\'. Links the inspection result to the NCR and CAPA workflow.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultStatus rdf:type rdf:Property ;
    rdfs:label 'Result Status' ;
    rdfs:comment 'Current disposition status of the inspection characteristic result: \'accepted\' (within specification), \'rejected\' (out of specification), \'conditional\' (requires further review or deviation approval), \'open\' (not yet evaluated), or \'cancelled\'.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingProcedure rdf:type rdf:Property ;
    rdfs:label 'Sampling Procedure' ;
    rdfs:comment 'Sampling procedure or plan applied for this inspection characteristic (e.g., AQL 1.0 Level II, 100% inspection, skip-lot). Determines the statistical confidence of the inspection result.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subgroupNumber rdf:type rdf:Property ;
    rdfs:label 'Subgroup Number' ;
    rdfs:comment 'Sequential subgroup number within the SPC control chart for this characteristic. Used to order data points on the SPC chart and identify the rational subgroup to which this measurement belongs.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetTag rdf:type rdf:Property ;
    rdfs:label 'Asset Tag' ;
    rdfs:comment 'Internal asset tag used for tracking within the enterprise asset management system.' ;
    rdfs:domain ind:MeasurementSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaugeRrRepeatability rdf:type rdf:Property ;
    rdfs:label 'Gauge Rr Repeatability' ;
    rdfs:comment 'Percentage repeatability component from the Gauge R&R study.' ;
    rdfs:domain ind:MeasurementSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gaugeRrReproducibility rdf:type rdf:Property ;
    rdfs:label 'Gauge Rr Reproducibility' ;
    rdfs:comment 'Percentage reproducibility component from the Gauge R&R study.' ;
    rdfs:domain ind:MeasurementSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gaugeRrStudyDate rdf:type rdf:Property ;
    rdfs:label 'Gauge Rr Study Date' ;
    rdfs:comment 'Date the most recent Gauge Repeatability & Reproducibility study was performed.' ;
    rdfs:domain ind:MeasurementSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gaugeRrTotalVariation rdf:type rdf:Property ;
    rdfs:label 'Gauge Rr Total Variation' ;
    rdfs:comment 'Combined variation percentage from the Gauge R&R study.' ;
    rdfs:domain ind:MeasurementSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Maintenance Interval Days' ;
    rdfs:comment 'Planned number of days between preventive maintenance activities.' ;
    rdfs:domain ind:MeasurementSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementRangeMax rdf:type rdf:Property ;
    rdfs:label 'Measurement Range Max' ;
    rdfs:comment 'Highest value the system can accurately measure.' ;
    rdfs:domain ind:MeasurementSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementRangeMin rdf:type rdf:Property ;
    rdfs:label 'Measurement Range Min' ;
    rdfs:comment 'Lowest value the system can accurately measure.' ;
    rdfs:domain ind:MeasurementSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementSystemDescription rdf:type rdf:Property ;
    rdfs:label 'Measurement System Description' ;
    rdfs:comment 'Detailed description of the measurement system purpose and application.' ;
    rdfs:domain ind:MeasurementSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementSystemName rdf:type rdf:Property ;
    rdfs:label 'Measurement System Name' ;
    rdfs:comment 'Human-readable name of the measurement system.' ;
    rdfs:domain ind:MeasurementSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msaMethod rdf:type rdf:Property ;
    rdfs:label 'Msa Method' ;
    rdfs:comment 'Methodology used for the MSA (e.g., Gauge R&R, Bias).' ;
    rdfs:domain ind:MeasurementSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msaResult rdf:type rdf:Property ;
    rdfs:label 'Msa Result' ;
    rdfs:comment 'Outcome of the MSA indicating whether the system meets acceptance criteria.' ;
    rdfs:domain ind:MeasurementSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msaStudyDate rdf:type rdf:Property ;
    rdfs:label 'Msa Study Date' ;
    rdfs:comment 'Date the most recent Measurement System Analysis was conducted.' ;
    rdfs:domain ind:MeasurementSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextCalibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Calibration Due Date' ;
    rdfs:comment 'Scheduled date for the next calibration based on the interval.' ;
    rdfs:domain ind:MeasurementSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ncrReportedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Ncr Reported By Employee Id' ;
    rdfs:comment 'Identifier of the employee who detected and formally reported the non-conformance. Links to the workforce/HR master data for accountability and traceability.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:containmentCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Containment Completed Date' ;
    rdfs:comment 'Date by which all immediate containment actions were verified as complete. Used for 8D D3 closure tracking and customer reporting.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerComplaintNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Complaint Number' ;
    rdfs:comment 'Customer-provided reference number for the complaint or quality issue, as received from the customer or logged in Salesforce Service Cloud. Enables cross-reference with customer records.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detection Timestamp' ;
    rdfs:comment 'Date and time when the non-conformance was first detected or observed. This is the principal business event timestamp for the NCR lifecycle.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:disposition rdf:type rdf:Property ;
    rdfs:label 'Disposition' ;
    rdfs:comment 'Formal disposition decision for the non-conforming material: use_as_is (accept with deviation), rework (correct in-house), scrap (destroy), return_to_supplier, repair, replace (issue replacement), credit (issue financial credit), no_fault_found. Drives material handling and financial impact. [ENUM-REF-CANDIDATE: use_as_is|rework|scrap|return_to_supplier|repair|replace|credit|no_fault_found — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionAuthority rdf:type rdf:Property ;
    rdfs:label 'Disposition Authority' ;
    rdfs:comment 'Name or role of the authorized person or body (e.g., Material Review Board, Quality Manager, Engineering) who approved the disposition decision. Required for regulatory and customer-specific quality requirements.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:is8dRequired rdf:type rdf:Property ;
    rdfs:label 'Is 8d Required' ;
    rdfs:comment 'Indicates whether the 8D (Eight Disciplines) structured problem-solving methodology is required for this NCR, typically mandated for customer-facing complaints or high-severity issues.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ncrStatus rdf:type rdf:Property ;
    rdfs:label 'Ncr Status' ;
    rdfs:comment 'Current lifecycle state of the NCR workflow: draft (being authored), open (submitted and active), under_review (root cause analysis in progress), disposition_pending (awaiting disposition decision), closed (all actions complete), cancelled (voided).' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncrType rdf:type rdf:Property ;
    rdfs:label 'Ncr Type' ;
    rdfs:comment 'Classification of the NCR by originating channel: internal (detected in-house), customer (complaint from customer), supplier (incoming material non-conformance), field_return (RMA/field failure), or audit (finding from internal or external audit).' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonconformanceDescription rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Description' ;
    rdfs:comment 'Detailed narrative description of the non-conformance, including the observed defect, deviation from specification, or failure mode. Supports root cause analysis and CAPA.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonconformingQty rdf:type rdf:Property ;
    rdfs:label 'Nonconforming Qty' ;
    rdfs:comment 'Quantity of units, parts, or material identified as non-conforming. Used for scrap cost calculation, yield rate analysis, and containment scope.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Qty Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the non-conforming quantity (e.g., EA=each, KG=kilogram, M=meter, PC=piece). Aligns with SAP base unit of measure. [ENUM-REF-CANDIDATE: EA|KG|LB|M|M2|M3|L|PC|SET|BOX — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportable rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable' ;
    rdfs:comment 'Indicates whether this non-conformance must be reported to a regulatory authority (e.g., OSHA, EPA, CE/UL product safety authority). Triggers mandatory regulatory notification workflows.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnShipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Return Shipment Status' ;
    rdfs:comment 'Current status of the physical return shipment for RMA-linked NCRs: not_applicable (no physical return), pending (RMA issued, awaiting shipment), in_transit (goods in transit), received (goods received at facility), inspected (incoming inspection complete), closed (return process complete).' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapQmNotificationType rdf:type rdf:Property ;
    rdfs:label 'Sap Qm Notification Type' ;
    rdfs:comment 'SAP QM notification type code mapped to this NCR: Q1 (customer complaint), Q2 (internal quality notification), Q3 (supplier quality notification). Enables direct traceability to the SAP QM source record.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationReportedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Notification Reported By Employee Id' ;
    rdfs:comment 'Identifier of the employee who reported or created the quality notification. Links to human resources master data.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Affected Quantity' ;
    rdfs:comment 'Quantity of material or units affected by the quality issue. Used for impact assessment and containment planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectCategory rdf:type rdf:Property ;
    rdfs:label 'Defect Category' ;
    rdfs:comment 'High-level classification grouping of the defect type (e.g., dimensional, functional, cosmetic, material, assembly). Used for trend analysis and reporting.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationDescription rdf:type rdf:Property ;
    rdfs:label 'Notification Description' ;
    rdfs:comment 'Detailed narrative description of the quality issue, including symptoms, observations, and context. Provides comprehensive information for investigation and resolution.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationNumber rdf:type rdf:Property ;
    rdfs:label 'Notification Number' ;
    rdfs:comment 'Business identifier for the quality notification, externally visible and used for tracking and reference across systems. Typically follows SAP QM numbering convention.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationStatus rdf:type rdf:Property ;
    rdfs:label 'Notification Status' ;
    rdfs:comment 'Current lifecycle status of the quality notification. Tracks progression from initial creation through investigation, resolution, and closure. [ENUM-REF-CANDIDATE: draft|open|in_progress|pending_approval|completed|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationType rdf:type rdf:Property ;
    rdfs:label 'Notification Type' ;
    rdfs:comment 'Classification of the quality notification. Q1=Customer Complaint, Q2=Supplier Defect, Q3=Internal Problem, Q4=Audit Finding, Q5=Improvement Request, QA=Quality Alert. Determines workflow and routing.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerName rdf:type rdf:Property ;
    rdfs:label 'Owner Name' ;
    rdfs:comment 'Name of the employee currently responsible for the quality notification. Used for reporting and escalation.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedByName rdf:type rdf:Property ;
    rdfs:label 'Reported By Name' ;
    rdfs:comment 'Name of the employee who reported the quality issue. Provides quick reference without joining to employee master.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pswAuthorizedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Psw Authorized By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: REQUIRED: PSW authorization is performed by a qualified employee; the FK supports PPAP audit trails and regulatory reporting.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:annualProductionVolume rdf:type rdf:Property ;
    rdfs:label 'Annual Production Volume' ;
    rdfs:comment 'Estimated annual production volume (number of parts per year) declared on the Part Submission Warrant. Used by the customer to assess production capacity and process capability requirements.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appearanceApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Appearance Approval Status' ;
    rdfs:comment 'Status of the Appearance Approval Report (AAR) for parts with appearance requirements (PPAP Element 12). Indicates whether the part\'s color, grain, gloss, and surface finish have been approved by the customer.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulkMaterialChecklistStatus rdf:type rdf:Property ;
    rdfs:label 'Bulk Material Checklist Status' ;
    rdfs:comment 'Completion status of the Bulk Material Requirements Checklist (PPAP Element 13), applicable for bulk/raw material submissions. Confirms all regulatory and customer-specific material requirements have been addressed.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkingAidsStatus rdf:type rdf:Property ;
    rdfs:label 'Checking Aids Status' ;
    rdfs:comment 'Status of checking aids (gauges, fixtures, templates) used for part inspection (PPAP Element 14). Confirms that all required checking aids are available, calibrated, and documented.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlPlanNumber rdf:type rdf:Property ;
    rdfs:label 'Control Plan Number' ;
    rdfs:comment 'Document reference number for the Control Plan included in the PPAP package. PPAP Element 6. The control plan defines inspection and monitoring activities for production. Traceable to SAP QM inspection plan.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerApproverName rdf:type rdf:Property ;
    rdfs:label 'Customer Approver Name' ;
    rdfs:comment 'Name of the customer\'s quality representative or engineer who reviewed and issued the formal PPAP disposition. Recorded for audit trail and accountability purposes.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Part Number' ;
    rdfs:comment 'The customer\'s own part number or drawing number for the submitted component, used for cross-reference between the manufacturer\'s and customer\'s part identification systems.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSpecificRequirementsStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Specific Requirements Status' ;
    rdfs:comment 'Status indicating whether all customer-specific requirements (PPAP Element 15) have been addressed in the submission. Customers may have additional requirements beyond the standard AIAG PPAP elements.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Design Record Number' ;
    rdfs:comment 'Document number of the design record (drawing, CAD model, or specification) that defines the part requirements. PPAP Element 1. Traceable to Siemens Teamcenter PLM document management.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionalResultsStatus rdf:type rdf:Property ;
    rdfs:label 'Dimensional Results Status' ;
    rdfs:comment 'Overall status of the dimensional inspection results (PPAP Element 10) indicating whether all measured dimensions conform to the design record tolerances. Pass = all characteristics within tolerance; Fail = one or more out of tolerance; Conditional = deviations accepted with customer concession.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imdsSubmissionReference rdf:type rdf:Property ;
    rdfs:label 'Imds Submission Reference' ;
    rdfs:comment 'Submission identifier in the International Material Data System (IMDS) for material composition reporting. Required for automotive and industrial parts to comply with REACH, RoHS, and ELV regulations. PPAP Element 13 supporting document.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialProcessStudyNumber rdf:type rdf:Property ;
    rdfs:label 'Initial Process Study Number' ;
    rdfs:comment 'Document reference number for the Initial Process Capability Study (Preliminary Process Capability) included in the PPAP package. PPAP Element 8. Contains Cp/Cpk indices for critical characteristics.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interimApprovalExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Interim Approval Expiry Date' ;
    rdfs:comment 'Expiry date of a conditional or interim PPAP approval granted by the customer. Production is authorized only until this date, after which a full approval or resubmission is required. Null if disposition is full approval or rejection.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isSafetyCriticalPart rdf:type rdf:Property ;
    rdfs:label 'Is Safety Critical Part' ;
    rdfs:comment 'Flag indicating whether the submitted part is classified as safety-critical, requiring enhanced PPAP scrutiny, additional testing, and regulatory compliance documentation. Safety-critical parts may require higher PPAP submission levels.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturingProcessDescription rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Process Description' ;
    rdfs:comment 'Brief description of the key manufacturing processes used to produce the part (e.g., CNC machining, injection molding, stamping, welding). Summarizes the process flow documented in the PPAP element.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialTestResultsStatus rdf:type rdf:Property ;
    rdfs:label 'Material Test Results Status' ;
    rdfs:comment 'Overall status of material and functional test results (PPAP Element 11) confirming that the part meets all material specifications and functional performance requirements defined in the design record.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msaStudyNumber rdf:type rdf:Property ;
    rdfs:label 'Msa Study Number' ;
    rdfs:comment 'Document reference number for the Measurement System Analysis (MSA) study included in the PPAP package. PPAP Element 7. Validates the measurement systems used for inspection. Aligns with AIAG MSA 4th Edition.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partRevisionLevel rdf:type rdf:Property ;
    rdfs:label 'Part Revision Level' ;
    rdfs:comment 'Engineering change revision level of the part at the time of PPAP submission, as tracked in the design record and PLM system. Ensures the submission corresponds to the correct design iteration.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pfmeaNumber rdf:type rdf:Property ;
    rdfs:label 'Pfmea Number' ;
    rdfs:comment 'Document reference number for the Process Failure Mode and Effects Analysis (PFMEA) included in the PPAP package. PPAP Element 5. Identifies the PFMEA document in Siemens Teamcenter PLM.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionRunQuantity rdf:type rdf:Property ;
    rdfs:label 'Production Run Quantity' ;
    rdfs:comment 'Total number of parts produced during the significant production run used to generate PPAP samples and process capability data. Typically a minimum of 300 consecutive pieces per AIAG requirements.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pswAuthorizationDate rdf:type rdf:Property ;
    rdfs:label 'Psw Authorization Date' ;
    rdfs:comment 'Date on which the supplier\'s authorized representative signed the Part Submission Warrant (PSW), certifying the completeness and accuracy of the PPAP submission package.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pswDisposition rdf:type rdf:Property ;
    rdfs:label 'Psw Disposition' ;
    rdfs:comment 'Customer\'s formal disposition recorded on the Part Submission Warrant (PSW), the cover document of the PPAP package. Approved = full production authorization; Interim Approval = conditional authorization with defined expiry; Rejected = resubmission required.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionDueDate rdf:type rdf:Property ;
    rdfs:label 'Resubmission Due Date' ;
    rdfs:comment 'Target date by which a corrected PPAP package must be resubmitted to the customer following a rejection or conditional approval. Agreed between supplier and customer quality teams.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleQuantity rdf:type rdf:Property ;
    rdfs:label 'Sample Quantity' ;
    rdfs:comment 'Number of sample parts produced from the production run and submitted to the customer as part of the PPAP package. PPAP Element 9. AIAG typically requires a minimum of 300 consecutive pieces for initial process studies.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submissionLevel rdf:type rdf:Property ;
    rdfs:label 'Submission Level' ;
    rdfs:comment 'AIAG-defined PPAP submission level (1 through 5) indicating the extent of documentation and samples required by the customer. Level 1 = Part Submission Warrant only; Level 5 = Full submission retained at manufacturing site.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submissionNotes rdf:type rdf:Property ;
    rdfs:label 'Submission Notes' ;
    rdfs:comment 'Free-text field for additional notes, clarifications, or special conditions associated with the PPAP submission. May include customer-specific instructions, deviations, or open action items.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionNumber rdf:type rdf:Property ;
    rdfs:label 'Submission Number' ;
    rdfs:comment 'Externally-known business identifier for the PPAP submission package, typically assigned by the quality management system (SAP QM) or PLM system. Used for cross-system traceability and customer communication.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionReason rdf:type rdf:Property ;
    rdfs:label 'Submission Reason' ;
    rdfs:comment 'Reason triggering the PPAP submission as defined by AIAG. Indicates whether the submission is for a new part, an engineering change order (ECO), tooling change, process change, supplier change, or material change. [ENUM-REF-CANDIDATE: new_part|engineering_change|tooling_change|process_change|supplier_change|material_change|correction|resubmission — promote to reference product]' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionStatus rdf:type rdf:Property ;
    rdfs:label 'Submission Status' ;
    rdfs:comment 'Current lifecycle status of the PPAP submission package. Tracks progression from draft preparation through customer review to final disposition (approved, conditionally approved, or rejected). Aligns with SAP QM inspection lot status.' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolingNumber rdf:type rdf:Property ;
    rdfs:label 'Tooling Number' ;
    rdfs:comment 'Identifier of the production tooling (mold, die, fixture) used to manufacture the submitted parts. Relevant for tooling-related PPAP submissions and tracked in the asset management system (Maximo).' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmaDispositionId rdf:type rdf:Property ;
    rdfs:label 'Rma Disposition Id' ;
    rdfs:comment 'Unique identifier for the RMA disposition record. Primary key for tracking quality disposition decisions on returned products.' ;
    rdfs:domain ind:RmaDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rmaAuthorityEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Rma Authority Employee Id' ;
    rdfs:comment 'Employee identifier of the authorized person who made the disposition decision, ensuring accountability.' ;
    rdfs:domain ind:RmaDisposition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:creditCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Credit Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the credit amount (e.g., USD, EUR, CNY).' ;
    rdfs:domain ind:RmaDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Reference Number' ;
    rdfs:comment 'Customer\'s own reference or tracking number for this return, used for cross-reference in customer communications.' ;
    rdfs:domain ind:RmaDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureCodeConfirmed rdf:type rdf:Property ;
    rdfs:label 'Failure Code Confirmed' ;
    rdfs:comment 'Standardized failure code assigned by quality inspection based on actual findings, used for defect trending and FMEA analysis.' ;
    rdfs:domain ind:RmaDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureCodeReported rdf:type rdf:Property ;
    rdfs:label 'Failure Code Reported' ;
    rdfs:comment 'Standardized failure code selected by customer or service representative at time of return initiation.' ;
    rdfs:domain ind:RmaDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureDescriptionConfirmed rdf:type rdf:Property ;
    rdfs:label 'Failure Description Confirmed' ;
    rdfs:comment 'Detailed description of the actual failure or defect as confirmed by quality inspection, which may differ from the customer-reported failure.' ;
    rdfs:domain ind:RmaDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureDescriptionReported rdf:type rdf:Property ;
    rdfs:label 'Failure Description Reported' ;
    rdfs:comment 'Customer\'s description of the failure or defect as reported at the time of RMA initiation.' ;
    rdfs:domain ind:RmaDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomingInspectionResult rdf:type rdf:Property ;
    rdfs:label 'Incoming Inspection Result' ;
    rdfs:comment 'Result of the incoming quality inspection performed upon receipt of the returned product.' ;
    rdfs:domain ind:RmaDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Completed Date' ;
    rdfs:comment 'Date when the incoming inspection and failure analysis were completed.' ;
    rdfs:domain ind:RmaDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receivingWarehouseLocation rdf:type rdf:Property ;
    rdfs:label 'Receiving Warehouse Location' ;
    rdfs:comment 'Specific warehouse location or storage bin where the returned material is held pending disposition.' ;
    rdfs:domain ind:RmaDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repairActionPerformed rdf:type rdf:Property ;
    rdfs:label 'Repair Action Performed' ;
    rdfs:comment 'Description of the repair or rework actions performed on the returned product, if disposition was repair or rework.' ;
    rdfs:domain ind:RmaDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repairCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Repair Completed Date' ;
    rdfs:comment 'Date when repair or rework activities were completed and the product was ready for return or reuse.' ;
    rdfs:domain ind:RmaDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:replacementMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Replacement Material Number' ;
    rdfs:comment 'Material number of the replacement product sent to the customer, if disposition was replace.' ;
    rdfs:domain ind:RmaDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Replacement Serial Number' ;
    rdfs:comment 'Serial number of the replacement unit shipped to the customer, enabling traceability of the replacement.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnInitiatedDate rdf:type rdf:Property ;
    rdfs:label 'Return Initiated Date' ;
    rdfs:comment 'Date when the RMA was authorized and the return process was initiated by the customer or service team.' ;
    rdfs:domain ind:RmaDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnReceivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Return Received Timestamp' ;
    rdfs:comment 'Date and time when the returned product was physically received at the inspection facility or warehouse.' ;
    rdfs:domain ind:RmaDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:returnShipmentDate rdf:type rdf:Property ;
    rdfs:label 'Return Shipment Date' ;
    rdfs:comment 'Date when the repaired or replacement product was shipped back to the customer.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnToCustomerStatus rdf:type rdf:Property ;
    rdfs:label 'Return To Customer Status' ;
    rdfs:comment 'Status of the return shipment to the customer for repaired or replaced products.' ;
    rdfs:domain ind:RmaDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Return Tracking Number' ;
    rdfs:comment 'Carrier tracking number for the return shipment to the customer, enabling delivery confirmation.' ;
    rdfs:domain ind:RmaDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnedMaterialDescription rdf:type rdf:Property ;
    rdfs:label 'Returned Material Description' ;
    rdfs:comment 'Full text description of the returned material for human readability and reporting.' ;
    rdfs:domain ind:RmaDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnedMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Returned Material Number' ;
    rdfs:comment 'Material number (SKU) of the product being returned. References the product master in SAP MM.' ;
    rdfs:domain ind:RmaDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmaStatus rdf:type rdf:Property ;
    rdfs:label 'Rma Status' ;
    rdfs:comment 'Current lifecycle status of the RMA process, tracking progression from initiation through final disposition. [ENUM-REF-CANDIDATE: initiated|in_transit|received|inspection_in_progress|disposition_complete|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RmaDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceCaseReference rdf:type rdf:Property ;
    rdfs:label 'Salesforce Case Reference' ;
    rdfs:comment 'Reference to the originating service case in Salesforce Service Cloud that initiated this RMA.' ;
    rdfs:domain ind:RmaDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapQmNotificationNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Qm Notification Number' ;
    rdfs:comment 'Quality notification number generated in SAP QM module for tracking the quality issue associated with this RMA.' ;
    rdfs:domain ind:RmaDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierResponsibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Supplier Responsibility Flag' ;
    rdfs:comment 'Indicates whether the root cause is attributable to a supplier defect, triggering supplier quality notification and potential cost recovery.' ;
    rdfs:domain ind:RmaDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spcId rdf:type rdf:Property ;
    rdfs:label 'Spc Id' ;
    rdfs:comment 'Primary key for spc' ;
    rdfs:domain ind:Spc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activeRuleSet rdf:type rdf:Property ;
    rdfs:label 'Active Rule Set' ;
    rdfs:comment 'Identifies the specific set of out-of-control detection rules configured for this chart. Determines which pattern tests are evaluated during real-time monitoring in Siemens Opcenter MES.' ;
    rdfs:domain ind:Spc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRecalculateLimits rdf:type rdf:Property ;
    rdfs:label 'Auto Recalculate Limits' ;
    rdfs:comment 'Indicates whether the system should automatically recalculate control limits when a specified number of new subgroups have been collected. Supports dynamic SPC limit management in Siemens Opcenter MES.' ;
    rdfs:domain ind:Spc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baselineSampleCount rdf:type rdf:Property ;
    rdfs:label 'Baseline Sample Count' ;
    rdfs:comment 'Number of subgroups used to establish the initial control limits (UCL, LCL, CL) during the chart setup phase. Typically a minimum of 25 subgroups is required per ANSI/ASQ standards to ensure statistically valid control limits.' ;
    rdfs:domain ind:Spc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capabilityAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Capability Assessment Date' ;
    rdfs:comment 'Date on which the current Cp, Cpk, Pp, Ppk indices were last calculated and recorded. Used to determine whether capability data is current and whether recalculation is required per the control plan review cycle.' ;
    rdfs:domain ind:Spc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:centerLine rdf:type rdf:Property ;
    rdfs:label 'Center Line' ;
    rdfs:comment 'The process mean or grand average used as the center line of the SPC chart. Represents the expected process level when in statistical control. For X-bar charts this is the grand mean; for p-charts this is the average proportion nonconforming.' ;
    rdfs:domain ind:Spc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:characteristicCriticality rdf:type rdf:Property ;
    rdfs:label 'Characteristic Criticality' ;
    rdfs:comment 'Criticality classification of the monitored characteristic based on its impact on product safety, function, or regulatory compliance. Critical characteristics (safety/regulatory) require tighter capability targets (Cpk ≥ 1.67). Aligns with DFMEA/PFMEA severity ratings.' ;
    rdfs:domain ind:Spc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartName rdf:type rdf:Property ;
    rdfs:label 'Chart Name' ;
    rdfs:comment 'Descriptive human-readable name for the SPC chart, identifying the monitored characteristic and process (e.g., \'Shaft Diameter X-bar R — Line 3 CNC\'). Used in operator dashboards and quality reports.' ;
    rdfs:domain ind:Spc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartNumber rdf:type rdf:Property ;
    rdfs:label 'Chart Number' ;
    rdfs:comment 'Externally-known, human-readable unique identifier for the SPC chart, used on shop floor documentation and in Siemens Opcenter MES. Follows the plant-defined numbering convention (e.g., SPC-WC001-00042).' ;
    rdfs:domain ind:Spc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartStatus rdf:type rdf:Property ;
    rdfs:label 'Chart Status' ;
    rdfs:comment 'Current lifecycle status of the SPC chart configuration. Active charts are live on the shop floor; suspended charts are temporarily halted; archived charts are retained for historical reference only.' ;
    rdfs:domain ind:Spc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartType rdf:type rdf:Property ;
    rdfs:label 'Chart Type' ;
    rdfs:comment 'Type of Statistical Process Control (SPC) chart used for monitoring. Determines the statistical method applied: X-bar R (variables, small subgroups), X-bar S (variables, large subgroups), p-chart (proportion nonconforming), c-chart (count of defects, constant area), u-chart (defects per unit, variable area), CUSUM (cumulative sum), EWMA (exponentially weighted moving average). [ENUM-REF-CANDIDATE: xbar_r|xbar_s|p_chart|c_chart|u_chart|cusum|ewma — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Spc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlLimitMethod rdf:type rdf:Property ;
    rdfs:label 'Control Limit Method' ;
    rdfs:comment 'Method used to calculate the control limits for this SPC chart. Standard is 3-sigma (99.73% confidence); 2-sigma may be used for warning limits; probability-based limits are used for non-normal distributions; custom allows manually specified limits.' ;
    rdfs:domain ind:Spc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cusumDecisionInterval rdf:type rdf:Property ;
    rdfs:label 'Cusum Decision Interval' ;
    rdfs:comment 'Decision interval (h) for CUSUM charts, representing the threshold at which the CUSUM statistic triggers an out-of-control signal. Typically set to 4 or 5 times the process standard deviation. Applicable only when chart_type = \'cusum\'. Null for other chart types.' ;
    rdfs:domain ind:Spc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cusumReferenceValue rdf:type rdf:Property ;
    rdfs:label 'Cusum Reference Value' ;
    rdfs:comment 'Reference value (k) for Cumulative Sum (CUSUM) charts, representing the allowable slack or reference value used in the CUSUM statistic calculation. Typically set to half the shift magnitude to be detected. Applicable only when chart_type = \'cusum\'. Null for other chart types.' ;
    rdfs:domain ind:Spc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ewmaLambda rdf:type rdf:Property ;
    rdfs:label 'Ewma Lambda' ;
    rdfs:comment 'Smoothing parameter (λ) for Exponentially Weighted Moving Average (EWMA) charts, ranging from 0 to 1. Lower values give more weight to historical data (better for detecting small shifts); higher values give more weight to recent data. Applicable only when chart_type = \'ewma\'. Null for other chart types.' ;
    rdfs:domain ind:Spc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minCpkRequired rdf:type rdf:Property ;
    rdfs:label 'Min Cpk Required' ;
    rdfs:comment 'Minimum acceptable Cpk value required for this characteristic as specified by the customer, engineering, or quality standard. Typically 1.33 for standard characteristics and 1.67 for critical/safety characteristics per AIAG PPAP requirements.' ;
    rdfs:domain ind:Spc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nelsonRulesEnabled rdf:type rdf:Property ;
    rdfs:label 'Nelson Rules Enabled' ;
    rdfs:comment 'Indicates whether the Nelson rules (8 rules for detecting non-random patterns) are active for this SPC chart in addition to or instead of Western Electric rules. Nelson rules extend WECO with additional run and trend tests.' ;
    rdfs:domain ind:Spc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outOfControlActionPlan rdf:type rdf:Property ;
    rdfs:label 'Out Of Control Action Plan' ;
    rdfs:comment 'Reference to or description of the Out-of-Control Action Plan (OCAP) that operators must follow when an SPC violation is detected. Defines the escalation path, containment actions, and notification requirements.' ;
    rdfs:domain ind:Spc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppIndex rdf:type rdf:Property ;
    rdfs:label 'Pp Index' ;
    rdfs:comment 'Process performance index Pp calculated using the overall (long-term) standard deviation rather than the within-subgroup standard deviation. Used in PPAP submissions to assess long-term process performance potential.' ;
    rdfs:domain ind:Spc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ppkIndex rdf:type rdf:Property ;
    rdfs:label 'Ppk Index' ;
    rdfs:comment 'Process performance index Ppk measuring actual long-term process performance accounting for both process spread and centering using overall standard deviation. Used alongside Cpk in PPAP submissions and ongoing process monitoring.' ;
    rdfs:domain ind:Spc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recalculationTriggerCount rdf:type rdf:Property ;
    rdfs:label 'Recalculation Trigger Count' ;
    rdfs:comment 'Number of new subgroups that must be collected before an automatic recalculation of control limits is triggered. Applicable only when auto_recalculate_limits is true. Null otherwise.' ;
    rdfs:domain ind:Spc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:samplingFrequency rdf:type rdf:Property ;
    rdfs:label 'Sampling Frequency' ;
    rdfs:comment 'Frequency at which subgroup samples are collected for SPC monitoring, expressed as a time interval or production quantity (e.g., \'every 30 minutes\', \'every 50 parts\', \'every batch\'). Defined in the inspection plan and control plan.' ;
    rdfs:domain ind:Spc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingFrequencyMinutes rdf:type rdf:Property ;
    rdfs:label 'Sampling Frequency Minutes' ;
    rdfs:comment 'Numeric representation of the sampling interval in minutes, used for automated scheduling in Siemens Opcenter MES and for SPC monitoring dashboards. Null if sampling is quantity-based rather than time-based.' ;
    rdfs:domain ind:Spc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subgroupSize rdf:type rdf:Property ;
    rdfs:label 'Subgroup Size' ;
    rdfs:comment 'Number of individual measurements collected per subgroup sample for the SPC chart. Determines the applicable control chart constants (A2, D3, D4, B3, B4) and the statistical power of the chart. Typically 2–10 for X-bar R charts.' ;
    rdfs:domain ind:Spc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:westernElectricRulesEnabled rdf:type rdf:Property ;
    rdfs:label 'Western Electric Rules Enabled' ;
    rdfs:comment 'Indicates whether the Western Electric (WECO) sensitizing rules for detecting non-random patterns are active for this SPC chart. When true, the chart evaluates all four Western Electric zone tests in addition to the basic 3-sigma rule.' ;
    rdfs:domain ind:Spc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierQualityAuditId rdf:type rdf:Property ;
    rdfs:label 'Supplier Quality Audit Id' ;
    rdfs:comment 'Unique system-generated identifier for the supplier quality audit record. Primary key for this entity.' ;
    rdfs:domain ind:SupplierQualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousAuditSupplierQualityAuditId rdf:type rdf:Property ;
    rdfs:label 'Previous Audit Supplier Quality Audit Id' ;
    rdfs:comment 'Reference to the immediately preceding audit record for this supplier, enabling audit history chaining and trend analysis across audit cycles.' ;
    rdfs:domain ind:SupplierQualityAudit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierQualityAudit .

ind:auditDurationDays rdf:type rdf:Property ;
    rdfs:label 'Audit Duration Days' ;
    rdfs:comment 'Total number of working days spent conducting the audit, including on-site or remote sessions. Used for resource planning and audit program management.' ;
    rdfs:domain ind:SupplierQualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditObjective rdf:type rdf:Property ;
    rdfs:label 'Audit Objective' ;
    rdfs:comment 'Stated purpose and objectives of the audit, such as initial supplier qualification, periodic surveillance, PPAP readiness assessment, or post-NCR verification.' ;
    rdfs:domain ind:SupplierQualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditReportReference rdf:type rdf:Property ;
    rdfs:label 'Audit Report Reference' ;
    rdfs:comment 'Document reference number or URL/path to the formal audit report stored in the document management system (e.g., Siemens Teamcenter PLM or SharePoint).' ;
    rdfs:domain ind:SupplierQualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStandard rdf:type rdf:Property ;
    rdfs:label 'Audit Standard' ;
    rdfs:comment 'The quality management standard or framework against which the supplier is being audited (e.g., ISO 9001:2015, IATF 16949, ISO 14001, AS9100). [ENUM-REF-CANDIDATE: ISO 9001|IATF 16949|ISO 14001|ISO 45001|AS9100|VDA 6.3 — promote to reference product]' ;
    rdfs:domain ind:SupplierQualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTeamMembers rdf:type rdf:Property ;
    rdfs:label 'Audit Team Members' ;
    rdfs:comment 'Comma-separated list of names or employee IDs of additional audit team members who participated in the audit alongside the lead auditor.' ;
    rdfs:domain ind:SupplierQualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityAgreementSigned rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Agreement Signed' ;
    rdfs:comment 'Indicates whether a non-disclosure or confidentiality agreement was signed by the audit team prior to conducting the audit at the supplier facility.' ;
    rdfs:domain ind:SupplierQualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso9001ClauseCoverage rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Clause Coverage' ;
    rdfs:comment 'Comma-separated list of ISO 9001:2015 clauses evaluated during the audit (e.g., \'4.1,5.1,6.1,8.4,9.1\'). Enables gap analysis against the full standard.' ;
    rdfs:domain ind:SupplierQualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppapAssessmentIncluded rdf:type rdf:Property ;
    rdfs:label 'Ppap Assessment Included' ;
    rdfs:comment 'Indicates whether a Production Part Approval Process (PPAP) readiness or compliance assessment was included as part of this audit scope.' ;
    rdfs:domain ind:SupplierQualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierContactName rdf:type rdf:Property ;
    rdfs:label 'Supplier Contact Name' ;
    rdfs:comment 'Name of the primary supplier representative or quality manager who participated in the audit on behalf of the supplier organization.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierFacilityCountry rdf:type rdf:Property ;
    rdfs:label 'Supplier Facility Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the supplier facility location where the audit was conducted.' ;
    rdfs:domain ind:SupplierQualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierFacilityName rdf:type rdf:Property ;
    rdfs:label 'Supplier Facility Name' ;
    rdfs:comment 'Name of the specific supplier facility or plant location where the audit was conducted or to which the remote audit applies.' ;
    rdfs:domain ind:SupplierQualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierQualificationLevel rdf:type rdf:Property ;
    rdfs:label 'Supplier Qualification Level' ;
    rdfs:comment 'Supplier qualification tier assigned or updated as a result of this audit outcome. Drives procurement decisions in SAP Ariba and SAP MM sourcing.' ;
    rdfs:domain ind:SupplierQualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelPartnerId rdf:type rdf:Property ;
    rdfs:label 'Channel Partner Id' ;
    rdfs:comment 'Unique identifier for the channel partner record. Primary key.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By User Employee Id' ;
    rdfs:comment 'Identifier of the user who created this partner record.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:lastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified this partner record.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:annualRevenueTarget rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Target' ;
    rdfs:comment 'The annual revenue target or quota assigned to the partner for the current fiscal year, in the partner\'s operating currency.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizedProductLines rdf:type rdf:Property ;
    rdfs:label 'Authorized Product Lines' ;
    rdfs:comment 'Comma-separated list of product lines or business units the partner is authorized to sell or integrate. Examples: Industrial Automation, Electrification, Building Technologies, Motion Control, Process Instrumentation.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiry Date' ;
    rdfs:comment 'Date when the partner\'s current certification expires and requires renewal.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'Expiration or renewal date of the current partner agreement or contract.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'Effective start date of the current partner agreement or contract.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dealRegistrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Deal Registration Enabled' ;
    rdfs:comment 'Indicates whether the partner is authorized to register deals for protection and special pricing. True if deal registration is enabled, False otherwise.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discountTier rdf:type rdf:Property ;
    rdfs:label 'Discount Tier' ;
    rdfs:comment 'Discount tier assigned to the partner based on volume commitments and tier status. Determines the standard discount percentage the partner receives on product pricing.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeCountRange rdf:type rdf:Property ;
    rdfs:label 'Employee Count Range' ;
    rdfs:comment 'Size classification of the partner organization by number of employees.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line1' ;
    rdfs:comment 'First line of the street address for the partner\'s headquarters or principal place of business.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryFocus rdf:type rdf:Property ;
    rdfs:label 'Industry Focus' ;
    rdfs:comment 'Primary industry verticals or market segments the partner specializes in serving. Examples: Automotive, Food & Beverage, Pharmaceuticals, Oil & Gas, Water & Wastewater.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPerformanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Performance Review Date' ;
    rdfs:comment 'Date of the most recent formal business review or performance evaluation conducted with the partner.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mdfEligible rdf:type rdf:Property ;
    rdfs:label 'Mdf Eligible' ;
    rdfs:comment 'Indicates whether the partner is eligible to receive Market Development Funds for co-marketing activities. True if eligible, False otherwise.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnerNumber rdf:type rdf:Property ;
    rdfs:label 'Partner Number' ;
    rdfs:comment 'Externally-known unique business identifier for the channel partner, typically assigned by the partner management system. Used in contracts, deal registrations, and commercial correspondence.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerProgramEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Partner Program Enrollment Date' ;
    rdfs:comment 'Date when the partner was enrolled in the channel partner program and the relationship was established.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partnerStatus rdf:type rdf:Property ;
    rdfs:label 'Partner Status' ;
    rdfs:comment 'Current lifecycle status of the partner relationship. Active (authorized to transact), Inactive (temporarily not transacting), Suspended (authorization revoked pending review), Pending Approval (application under review), Terminated (relationship ended).' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerTier rdf:type rdf:Property ;
    rdfs:label 'Partner Tier' ;
    rdfs:comment 'Partner program tier indicating authorization level, benefits, and performance status. Platinum (top tier, highest revenue and certification), Gold (high performance), Silver (standard), Bronze (entry level), Registered (basic enrollment).' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerType rdf:type rdf:Property ;
    rdfs:label 'Partner Type' ;
    rdfs:comment 'Classification of the channel partner by business model: distributor (bulk stock and resell), system integrator (solution design and implementation), VAR (Value-Added Reseller - customize and resell), OEM (Original Equipment Manufacturer - embed products), reseller (direct resale), consultant (advisory and referral).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Target Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the annual revenue target.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalCapabilityLevel rdf:type rdf:Property ;
    rdfs:label 'Technical Capability Level' ;
    rdfs:comment 'Assessment of the partner\'s technical capability and expertise. Advanced (complex system integration, custom engineering), Intermediate (standard configuration and deployment), Basic (product resale with limited technical support).' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'The commercial trading name or DBA name under which the partner operates in the market, if different from legal name.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Primary website URL for the partner organization.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastId rdf:type rdf:Property ;
    rdfs:label 'Forecast Id' ;
    rdfs:comment 'Primary key for forecast' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forecastTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Forecast Territory Id' ;
    rdfs:comment 'Foreign key linking to sales.territory. Business justification: Forecast contains a free-text territory field; adding forecast_territory_id creates a normalized link to sales.territory and eliminates the duplicate string column.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:previousForecastId rdf:type rdf:Property ;
    rdfs:label 'Previous Forecast Id' ;
    rdfs:comment 'Reference to the prior version of this forecast if this is a revision.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Forecast .

ind:bestCaseAmount rdf:type rdf:Property ;
    rdfs:label 'Best Case Amount' ;
    rdfs:comment 'Optimistic revenue projection if all opportunities close favorably.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closedAmount rdf:type rdf:Property ;
    rdfs:label 'Closed Amount' ;
    rdfs:comment 'Actual revenue from deals already closed and won during the forecast period.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'Fiscal quarter designation (Q1, Q2, Q3, Q4) for the forecast period.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastCategory rdf:type rdf:Property ;
    rdfs:label 'Forecast Category' ;
    rdfs:comment 'Classification of forecast confidence level: pipeline (early stage), best_case (optimistic), commit (high confidence), closed (won deals).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastNumber rdf:type rdf:Property ;
    rdfs:label 'Forecast Number' ;
    rdfs:comment 'Business identifier for the forecast record, typically system-generated.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastStatus rdf:type rdf:Property ;
    rdfs:label 'Forecast Status' ;
    rdfs:comment 'Current lifecycle status of the forecast record.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLatestVersion rdf:type rdf:Property ;
    rdfs:label 'Is Latest Version' ;
    rdfs:comment 'Flag indicating whether this is the most current version of the forecast for this period and owner.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:managerAdjustedAmount rdf:type rdf:Property ;
    rdfs:label 'Manager Adjusted Amount' ;
    rdfs:comment 'Revenue amount after manager review and adjustment, may differ from submitted amount based on pipeline scrutiny.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managerNotes rdf:type rdf:Property ;
    rdfs:label 'Manager Notes' ;
    rdfs:comment 'Commentary from the reviewing manager explaining adjustments or concerns.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityCount rdf:type rdf:Property ;
    rdfs:label 'Opportunity Count' ;
    rdfs:comment 'Number of opportunities included in this forecast submission.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'Time granularity of the forecast period: monthly, quarterly, or annual.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineAmount rdf:type rdf:Property ;
    rdfs:label 'Pipeline Amount' ;
    rdfs:comment 'Total pipeline revenue including early-stage opportunities with lower probability.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotaAttainmentPercent rdf:type rdf:Property ;
    rdfs:label 'Quota Attainment Percent' ;
    rdfs:comment 'Percentage of quota achieved based on committed forecast amount.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submittedAmount rdf:type rdf:Property ;
    rdfs:label 'Submitted Amount' ;
    rdfs:comment 'Revenue amount submitted by the sales representative for this forecast period and category.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceToQuota rdf:type rdf:Property ;
    rdfs:label 'Variance To Quota' ;
    rdfs:comment 'Difference between committed forecast amount and quota target, can be positive or negative.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightedPipelineAmount rdf:type rdf:Property ;
    rdfs:label 'Weighted Pipeline Amount' ;
    rdfs:comment 'Pipeline amount adjusted by probability weighting based on opportunity stages.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Reference to the marketing campaign that influenced or generated this opportunity.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:contractId rdf:type rdf:Property ;
    rdfs:label 'Contract Id' ;
    rdfs:comment 'Reference to the resulting contract or order if the opportunity was won and converted.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesContract .

ind:opportunityTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Territory Id' ;
    rdfs:comment 'Foreign key linking to sales.territory. Business justification: Opportunity stores territory as free text; adding opportunity_territory_id creates a proper link to sales.territory, enabling consistent reporting and removing redundant string column.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:syncedQuoteId rdf:type rdf:Property ;
    rdfs:label 'Synced Quote Id' ;
    rdfs:comment 'Reference to the quote that is currently synced with the opportunity amount and line items.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Quote .

ind:competitorName rdf:type rdf:Property ;
    rdfs:label 'Competitor Name' ;
    rdfs:comment 'Name of the primary competitor identified in this sales opportunity.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryInstallationStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Installation Status' ;
    rdfs:comment 'Current status of product delivery and installation for won opportunities. Tracks post-sale fulfillment.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedRevenue rdf:type rdf:Property ;
    rdfs:label 'Expected Revenue' ;
    rdfs:comment 'Probability-weighted revenue calculated as amount multiplied by probability percentage. Used for forecast accuracy.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hasOpenActivity rdf:type rdf:Property ;
    rdfs:label 'Has Open Activity' ;
    rdfs:comment 'Boolean indicator whether there are open tasks or activities associated with this opportunity. Used for pipeline health monitoring.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isClosed rdf:type rdf:Property ;
    rdfs:label 'Is Closed' ;
    rdfs:comment 'Boolean indicator whether the opportunity has reached a final closed state (won or lost).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrivate rdf:type rdf:Property ;
    rdfs:label 'Is Private' ;
    rdfs:comment 'Boolean indicator whether the opportunity is marked as private with restricted visibility.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWon rdf:type rdf:Property ;
    rdfs:label 'Is Won' ;
    rdfs:comment 'Boolean indicator whether the opportunity was closed as won (deal successfully secured).' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lossReason rdf:type rdf:Property ;
    rdfs:label 'Loss Reason' ;
    rdfs:comment 'Primary reason why the opportunity was lost. Used for win/loss analysis and competitive intelligence.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextStep rdf:type rdf:Property ;
    rdfs:label 'Next Step' ;
    rdfs:comment 'Description of the next planned action or milestone to advance the opportunity.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityDescription rdf:type rdf:Property ;
    rdfs:label 'Opportunity Description' ;
    rdfs:comment 'Detailed narrative description of the opportunity including customer needs, solution scope, and strategic context.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityName rdf:type rdf:Property ;
    rdfs:label 'Opportunity Name' ;
    rdfs:comment 'Business-friendly name or title of the sales opportunity describing the potential deal.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityNumber rdf:type rdf:Property ;
    rdfs:label 'Opportunity Number' ;
    rdfs:comment 'Externally-visible unique business identifier for the opportunity used in sales communications and reporting.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityType rdf:type rdf:Property ;
    rdfs:label 'Opportunity Type' ;
    rdfs:comment 'Classification of the opportunity based on customer relationship status (new customer acquisition vs existing customer expansion).' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesCycleDays rdf:type rdf:Property ;
    rdfs:label 'Sales Cycle Days' ;
    rdfs:comment 'Number of days from opportunity creation to close date. Used for sales velocity analysis.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stageChangedDate rdf:type rdf:Property ;
    rdfs:label 'Stage Changed Date' ;
    rdfs:comment 'Timestamp when the opportunity stage was last changed. Used for stage duration and velocity analysis.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderIntakeTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Order Intake Territory Id' ;
    rdfs:comment 'Foreign key linking to sales.territory. Business justification: Order intake records a sales territory as text; adding order_intake_territory_id creates a proper FK to sales.territory and removes the ambiguous string column.' ;
    rdfs:domain ind:OrderIntake ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:salesTeamId rdf:type rdf:Property ;
    rdfs:label 'Sales Team Id' ;
    rdfs:comment 'Reference to the sales team responsible for this order. Used for team-based performance tracking and collaborative selling analytics.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesTeam .

ind:bookingRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Booking Recognition Date' ;
    rdfs:comment 'The date when this order intake was recognized as a booking for quota and sales performance measurement. May differ from intake date based on validation rules.' ;
    rdfs:domain ind:OrderIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bookingRecognizedFlag rdf:type rdf:Property ;
    rdfs:label 'Booking Recognized Flag' ;
    rdfs:comment 'Indicates whether this order intake has been recognized as a booking against sales quota. True when order meets booking recognition criteria per sales policy.' ;
    rdfs:domain ind:OrderIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:committedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Committed Delivery Date' ;
    rdfs:comment 'The delivery date committed by sales to the customer. May differ from requested date based on production capacity and supply chain constraints.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Credit Approval Date' ;
    rdfs:comment 'Date when credit approval was granted for this order, if required. Null if order did not require credit approval or is still pending.' ;
    rdfs:domain ind:OrderIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Check Status' ;
    rdfs:comment 'Result of the customer credit check performed at order intake. Orders failing credit check may require advance payment or credit approval before handoff to fulfillment.' ;
    rdfs:domain ind:OrderIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerPoDate rdf:type rdf:Property ;
    rdfs:label 'Customer Po Date' ;
    rdfs:comment 'The date on the customer\'s purchase order. Used for contract compliance verification and order validity checks.' ;
    rdfs:domain ind:OrderIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerPoNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Po Number' ;
    rdfs:comment 'The customer\'s purchase order reference number. Critical for order validation, invoicing, and customer reconciliation. May be required per customer contract terms.' ;
    rdfs:domain ind:OrderIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handoffDate rdf:type rdf:Property ;
    rdfs:label 'Handoff Date' ;
    rdfs:comment 'The date when the order intake was successfully handed off to the order management domain. Used for sales-to-fulfillment cycle time KPI calculation.' ;
    rdfs:domain ind:OrderIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:handoffStatus rdf:type rdf:Property ;
    rdfs:label 'Handoff Status' ;
    rdfs:comment 'Current status of the handoff from sales to order management domain. Tracks the intake record through validation, transfer, and acceptance by the fulfillment organization.' ;
    rdfs:domain ind:OrderIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intakeDate rdf:type rdf:Property ;
    rdfs:label 'Intake Date' ;
    rdfs:comment 'The date when the order was officially received and recorded in the sales system. This is the booking date used for sales quota recognition and revenue pipeline tracking.' ;
    rdfs:domain ind:OrderIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:intakeNumber rdf:type rdf:Property ;
    rdfs:label 'Intake Number' ;
    rdfs:comment 'Business identifier for the order intake record. Human-readable unique number used for tracking and reference in sales reporting and KPI dashboards.' ;
    rdfs:domain ind:OrderIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intakeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Intake Timestamp' ;
    rdfs:comment 'Precise timestamp when the order intake record was created in the system. Used for sales-to-fulfillment cycle time measurement and operational analytics.' ;
    rdfs:domain ind:OrderIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderManagementReference rdf:type rdf:Property ;
    rdfs:label 'Order Management Reference' ;
    rdfs:comment 'The order number or reference assigned by the order management system after handoff. Links this sales intake record to the authoritative order record in SAP SD or equivalent ERP.' ;
    rdfs:domain ind:OrderIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderValue rdf:type rdf:Property ;
    rdfs:label 'Order Value' ;
    rdfs:comment 'The total confirmed order value at intake. This is the gross order amount before any adjustments, used for sales booking recognition and quota attainment calculation.' ;
    rdfs:domain ind:OrderIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderValueBaseCurrency rdf:type rdf:Property ;
    rdfs:label 'Order Value Base Currency' ;
    rdfs:comment 'Order value converted to the company\'s base reporting currency using the exchange rate at intake date. Used for consolidated sales reporting and KPI tracking.' ;
    rdfs:domain ind:OrderIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specialTermsConditions rdf:type rdf:Property ;
    rdfs:label 'Special Terms Conditions' ;
    rdfs:comment 'Any special commercial terms, conditions, or customer-specific agreements applicable to this order. May include warranty extensions, service level commitments, or pricing exceptions.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentPriceBookId rdf:type rdf:Property ;
    rdfs:label 'Parent Price Book Id' ;
    rdfs:comment 'Reference to a parent or master price book from which this price book inherits base pricing. Null if this is a top-level price book.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceBook .

ind:primaryPriceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Price Employee Id' ;
    rdfs:comment 'Identifier of the user or team responsible for maintaining and managing this price book.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryPriceLastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Price Last Modified By Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified this price book record.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:discountPolicy rdf:type rdf:Property ;
    rdfs:label 'Discount Policy' ;
    rdfs:comment 'Reference to the discount policy or guidelines that govern allowable discounts from this price book (e.g., \'Standard 10% max\', \'Volume-based tiered\', \'No discounts allowed\').' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isStandard rdf:type rdf:Property ;
    rdfs:label 'Is Standard' ;
    rdfs:comment 'Boolean flag indicating whether this is the standard (default) price book for the organization. Only one standard price book should be active at a time.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceBookCode rdf:type rdf:Property ;
    rdfs:label 'Price Book Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the price book for system integration and reporting purposes.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceBookDescription rdf:type rdf:Property ;
    rdfs:label 'Price Book Description' ;
    rdfs:comment 'Detailed description of the price book purpose, scope, and applicability (e.g., \'Standard list prices for North America industrial automation products effective Q1 2024\').' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceBookName rdf:type rdf:Property ;
    rdfs:label 'Price Book Name' ;
    rdfs:comment 'Business name of the price book (e.g., \'Standard Price Book\', \'EMEA Industrial Automation 2024\', \'OEM Partner Pricing\').' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceBookStatus rdf:type rdf:Property ;
    rdfs:label 'Price Book Status' ;
    rdfs:comment 'Current lifecycle status of the price book indicating whether it is available for use in sales transactions.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceBookType rdf:type rdf:Property ;
    rdfs:label 'Price Book Type' ;
    rdfs:comment 'Classification of the price book indicating its purpose and usage context within the sales organization.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingStrategy rdf:type rdf:Property ;
    rdfs:label 'Pricing Strategy' ;
    rdfs:comment 'The pricing methodology or strategy applied in this price book (e.g., list pricing, cost-plus, competitive pricing, value-based pricing).' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceBookEntryId rdf:type rdf:Property ;
    rdfs:label 'Price Book Entry Id' ;
    rdfs:comment 'Unique identifier for the price book entry record. Primary key.' ;
    rdfs:domain ind:PriceBookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discountScheduleId rdf:type rdf:Property ;
    rdfs:label 'Discount Schedule Id' ;
    rdfs:comment 'Reference to a volume-based or tiered discount schedule that applies to this product. Enables automated discount calculation in Configure Price Quote (CPQ) systems.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DiscountSchedule .

ind:primaryPriceCatalogEntryId rdf:type rdf:Property ;
    rdfs:label 'Primary Price Catalog Entry Id' ;
    rdfs:comment 'Reference to the product or Stock Keeping Unit (SKU) that this price book entry applies to. Links to the product master record in the product catalog.' ;
    rdfs:domain ind:PriceBookEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogEntry .

ind:tertiaryPriceProductCatalogEntryId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Price Product Catalog Entry Id' ;
    rdfs:comment 'FK to product.catalog_entry' ;
    rdfs:domain ind:PriceBookEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogEntry .

ind:costPrice rdf:type rdf:Property ;
    rdfs:label 'Cost Price' ;
    rdfs:comment 'The internal cost or standard cost of the product. Used for margin calculation and profitability analysis. Business-confidential data.' ;
    rdfs:domain ind:PriceBookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographyCode rdf:type rdf:Property ;
    rdfs:label 'Geography Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country or region code indicating the geographic market for which this pricing applies (e.g., USA, DEU, CHN).' ;
    rdfs:domain ind:PriceBookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumDiscountPercent rdf:type rdf:Property ;
    rdfs:label 'Maximum Discount Percent' ;
    rdfs:comment 'The maximum allowable discount percentage that can be applied to this product without requiring special approval. Used to enforce pricing governance.' ;
    rdfs:domain ind:PriceBookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumPrice rdf:type rdf:Property ;
    rdfs:label 'Minimum Price' ;
    rdfs:comment 'The floor price below which this product cannot be sold. Used to enforce pricing policies and protect margin thresholds in Configure Price Quote (CPQ) processes.' ;
    rdfs:domain ind:PriceBookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceBookEntryDescription rdf:type rdf:Property ;
    rdfs:label 'Price Book Entry Description' ;
    rdfs:comment 'Additional notes or description providing context about this pricing entry, such as special terms, conditions, or the rationale for custom pricing.' ;
    rdfs:domain ind:PriceBookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceBookEntryName rdf:type rdf:Property ;
    rdfs:label 'Price Book Entry Name' ;
    rdfs:comment 'A descriptive name or label for this price book entry, typically combining product name, price book name, and currency for easy identification in reports and user interfaces.' ;
    rdfs:domain ind:PriceBookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceType rdf:type rdf:Property ;
    rdfs:label 'Price Type' ;
    rdfs:comment 'The type or nature of the price (e.g., list price, negotiated price, promotional price, contract price, spot price). Indicates the pricing strategy applied.' ;
    rdfs:domain ind:PriceBookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productFamily rdf:type rdf:Property ;
    rdfs:label 'Product Family' ;
    rdfs:comment 'The product family or category to which this product belongs (e.g., Automation Controllers, Electrification Components, SCADA Systems). Used for reporting and segmentation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:useStandardPrice rdf:type rdf:Property ;
    rdfs:label 'Use Standard Price' ;
    rdfs:comment 'Indicates whether this entry uses the standard price book price or a custom price. True means standard pricing applies; false indicates custom or negotiated pricing.' ;
    rdfs:domain ind:PriceBookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proposalId rdf:type rdf:Property ;
    rdfs:label 'Proposal Id' ;
    rdfs:comment 'Unique identifier for the proposal record. Primary key.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proposalTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Proposal Territory Id' ;
    rdfs:comment 'Foreign key linking to sales.territory. Business justification: Proposal includes a sales_territory string; adding proposal_territory_id provides a normalized reference to sales.territory and removes the redundant column.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:assumptions rdf:type rdf:Property ;
    rdfs:label 'Assumptions' ;
    rdfs:comment 'Key assumptions underlying the proposal including site conditions, customer responsibilities, and external dependencies.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorNames rdf:type rdf:Property ;
    rdfs:label 'Competitor Names' ;
    rdfs:comment 'Names of known competitors also bidding for this project or opportunity.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertifications rdf:type rdf:Property ;
    rdfs:label 'Compliance Certifications' ;
    rdfs:comment 'List of applicable compliance certifications and standards that the proposed solution meets (CE, UL, IEC 61131, ISO 13849, IEC 62443).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Email' ;
    rdfs:comment 'Email address of the primary customer contact for proposal correspondence.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerContactName rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Name' ;
    rdfs:comment 'Name of the primary customer contact person to whom the proposal is addressed.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Phone' ;
    rdfs:comment 'Phone number of the primary customer contact for proposal discussions.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Completion Date' ;
    rdfs:comment 'Proposed date for project completion and final delivery as outlined in the proposal.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedStartDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Start Date' ;
    rdfs:comment 'Proposed date for project commencement as outlined in the proposal.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusions rdf:type rdf:Property ;
    rdfs:label 'Exclusions' ;
    rdfs:comment 'Items, services, or responsibilities explicitly excluded from the proposal scope to manage expectations and risk.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grandTotal rdf:type rdf:Property ;
    rdfs:label 'Grand Total' ;
    rdfs:comment 'Final total value of the proposal including all charges and taxes.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preparedBy rdf:type rdf:Property ;
    rdfs:label 'Prepared By' ;
    rdfs:comment 'Name or identifier of the sales engineer or proposal manager who prepared the proposal.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingBreakdown rdf:type rdf:Property ;
    rdfs:label 'Pricing Breakdown' ;
    rdfs:comment 'Itemized breakdown of pricing including equipment, engineering, installation, commissioning, training, and support costs.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectDurationDays rdf:type rdf:Property ;
    rdfs:label 'Project Duration Days' ;
    rdfs:comment 'Estimated total duration of the project from commencement to completion in calendar days.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proposalNumber rdf:type rdf:Property ;
    rdfs:label 'Proposal Number' ;
    rdfs:comment 'Externally visible unique business identifier for the proposal document.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalStatus rdf:type rdf:Property ;
    rdfs:label 'Proposal Status' ;
    rdfs:comment 'Current lifecycle status of the proposal in the sales process. [ENUM-REF-CANDIDATE: draft|under_review|approved|submitted|accepted|rejected|withdrawn|expired — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalType rdf:type rdf:Property ;
    rdfs:label 'Proposal Type' ;
    rdfs:comment 'Classification of the proposal based on its nature and scope (technical, commercial, combined, RFP response, EPC, turnkey).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfpReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Rfp Reference Number' ;
    rdfs:comment 'Customer\'s RFP or tender reference number if this proposal is in response to a formal request.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskClauses rdf:type rdf:Property ;
    rdfs:label 'Risk Clauses' ;
    rdfs:comment 'Legal and commercial risk mitigation clauses including liability limitations, force majeure, and indemnification.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeOfSupply rdf:type rdf:Property ;
    rdfs:label 'Scope Of Supply' ;
    rdfs:comment 'Detailed description of all equipment, systems, services, and deliverables included in the proposal.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solutionArchitectureSummary rdf:type rdf:Property ;
    rdfs:label 'Solution Architecture Summary' ;
    rdfs:comment 'High-level technical description of the proposed automation or electrification solution architecture.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalSpecifications rdf:type rdf:Property ;
    rdfs:label 'Technical Specifications' ;
    rdfs:comment 'Detailed technical specifications of the proposed equipment, systems, and components including performance parameters.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalValue rdf:type rdf:Property ;
    rdfs:label 'Total Value' ;
    rdfs:comment 'Total monetary value of the proposal including all line items, services, and charges before taxes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validUntilDate rdf:type rdf:Property ;
    rdfs:label 'Valid Until Date' ;
    rdfs:comment 'Expiration date after which the proposal terms, pricing, and commitments are no longer binding.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:winProbabilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Win Probability Percentage' ;
    rdfs:comment 'Estimated probability of winning the proposal expressed as a percentage based on sales assessment.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotaId rdf:type rdf:Property ;
    rdfs:label 'Quota Id' ;
    rdfs:comment 'Unique identifier for the sales quota record. Primary key.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentQuotaId rdf:type rdf:Property ;
    rdfs:label 'Parent Quota Id' ;
    rdfs:comment 'Identifier of the parent quota in a hierarchical quota structure (e.g., a regional quota that rolls up to a global quota). Enables quota hierarchy navigation and rollup reporting.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Quota .

ind:quotaCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quota Created By Employee Id' ;
    rdfs:comment 'Identifier of the user who created this quota record. Links to the user record for audit trail and accountability purposes.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quotaEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quota Employee Id' ;
    rdfs:comment 'Identifier of the manager or executive who approved this quota assignment. Links to the user record for audit trail and governance purposes.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quotaLastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quota Last Modified By Employee Id' ;
    rdfs:comment 'Identifier of the user who most recently modified this quota record. Links to the user record for change tracking and audit compliance.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quotaTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Quota Territory Id' ;
    rdfs:comment 'Foreign key linking to sales.territory. Business justification: Quota has a free-text territory field; adding quota_territory_id links quota to the territory hierarchy and eliminates the redundant string column.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'The net amount by which the base quota was adjusted after initial assignment. Positive values indicate quota increases; negative values indicate reductions. Used for variance analysis and compensation dispute resolution.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentDate rdf:type rdf:Property ;
    rdfs:label 'Adjustment Date' ;
    rdfs:comment 'The effective date of the most recent quota adjustment. Used to track when changes were applied for accurate period-over-period performance comparison.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:attainmentAmount rdf:type rdf:Property ;
    rdfs:label 'Attainment Amount' ;
    rdfs:comment 'The actual performance amount achieved against this quota as of the last calculation date. Updated periodically (daily, weekly, monthly) based on closed-won opportunities or booked orders.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attainmentPercent rdf:type rdf:Property ;
    rdfs:label 'Attainment Percent' ;
    rdfs:comment 'The percentage of base quota achieved, calculated as (attainment_amount / base_quota_amount) * 100. Key performance indicator (KPI) for sales performance dashboards and incentive compensation calculations.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseQuotaAmount rdf:type rdf:Property ;
    rdfs:label 'Base Quota Amount' ;
    rdfs:comment 'The standard target amount assigned to the quota owner for the period. Represents the minimum performance expectation for full incentive payout.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isTeamQuota rdf:type rdf:Property ;
    rdfs:label 'Is Team Quota' ;
    rdfs:comment 'Boolean flag indicating whether this quota is assigned to a team (True) or an individual sales representative (False). Supports team-based incentive structures and collaborative selling models.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAttainmentCalculationDate rdf:type rdf:Property ;
    rdfs:label 'Last Attainment Calculation Date' ;
    rdfs:comment 'The date when the attainment amount and percentage were last recalculated. Indicates the freshness of performance metrics for reporting and compensation purposes.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'The last date of the performance period for which this quota is effective. Defines the end of the measurement window.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'The first date of the performance period for which this quota is effective. Defines the beginning of the measurement window.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quotaNumber rdf:type rdf:Property ;
    rdfs:label 'Quota Number' ;
    rdfs:comment 'Human-readable business identifier for the quota record, typically following a pattern such as QTA-YYYYNNNN for external reference and reporting.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaStatus rdf:type rdf:Property ;
    rdfs:label 'Quota Status' ;
    rdfs:comment 'Current lifecycle state of the quota: draft (under review), active (in effect), suspended (temporarily paused), closed (period completed), or cancelled (no longer valid).' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaType rdf:type rdf:Property ;
    rdfs:label 'Quota Type' ;
    rdfs:comment 'Classification of the quota by measurement type: revenue (monetary sales target), units (volume target), margin (gross profit target), new logos (new customer acquisition target), bookings (order intake target), or pipeline (opportunity generation target).' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stretchQuotaAmount rdf:type rdf:Property ;
    rdfs:label 'Stretch Quota Amount' ;
    rdfs:comment 'The aspirational target amount beyond the base quota, used to incentivize exceptional performance with accelerated commission rates or bonuses.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousQuoteId rdf:type rdf:Property ;
    rdfs:label 'Previous Quote Id' ;
    rdfs:comment 'Reference to the prior version of this quote if this is a revision or amendment.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Quote .

ind:templateId rdf:type rdf:Property ;
    rdfs:label 'Template Id' ;
    rdfs:comment 'Reference to the document template used to generate the customer-facing quote document.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QuoteTemplate .

ind:acceptedDate rdf:type rdf:Property ;
    rdfs:label 'Accepted Date' ;
    rdfs:comment 'Date on which the customer formally accepted the quote, triggering order creation.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:configurationSummary rdf:type rdf:Property ;
    rdfs:label 'Configuration Summary' ;
    rdfs:comment 'High-level summary of the product configuration details included in the quote (e.g., system specifications, key components, customization notes).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Lead Time Days' ;
    rdfs:comment 'Estimated number of days from order confirmation to delivery of the quoted products.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incoterm rdf:type rdf:Property ;
    rdfs:label 'Incoterm' ;
    rdfs:comment 'International Commercial Terms (Incoterms) defining the responsibilities of buyer and seller for delivery, insurance, and risk transfer. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonStandardDiscountFlag rdf:type rdf:Property ;
    rdfs:label 'Non Standard Discount Flag' ;
    rdfs:comment 'Indicates whether the quote includes discounts that exceed standard approval thresholds and require special authorization.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:presentedDate rdf:type rdf:Property ;
    rdfs:label 'Presented Date' ;
    rdfs:comment 'Date on which the quote was formally presented to the customer.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quoteDate rdf:type rdf:Property ;
    rdfs:label 'Quote Date' ;
    rdfs:comment 'Date on which the quote was formally issued to the customer.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quoteName rdf:type rdf:Property ;
    rdfs:label 'Quote Name' ;
    rdfs:comment 'Descriptive name or title of the quote, typically reflecting the project or product scope (e.g., \'Factory Automation System - Plant 5\').' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteNumber rdf:type rdf:Property ;
    rdfs:label 'Quote Number' ;
    rdfs:comment 'Externally visible business identifier for the quote. Used in customer communications and contract references.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteStatus rdf:type rdf:Property ;
    rdfs:label 'Quote Status' ;
    rdfs:comment 'Current lifecycle status of the quote in the sales workflow. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|presented|accepted|rejected|expired — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteType rdf:type rdf:Property ;
    rdfs:label 'Quote Type' ;
    rdfs:comment 'Classification of the quote based on the nature of the commercial transaction.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelAgreement rdf:type rdf:Property ;
    rdfs:label 'Service Level Agreement' ;
    rdfs:comment 'Service level commitments included in the quote (e.g., response time, uptime guarantees, maintenance windows).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingHandlingAmount rdf:type rdf:Property ;
    rdfs:label 'Shipping Handling Amount' ;
    rdfs:comment 'Estimated cost for shipping and handling of the quoted products to the customer site.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Subtotal Amount' ;
    rdfs:comment 'Total value of all quoted line items before discounts, taxes, and adjustments.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bundleParentLineId rdf:type rdf:Property ;
    rdfs:label 'Bundle Parent Line Id' ;
    rdfs:comment 'Reference to the parent quote line if this line is part of a product bundle. Enables hierarchical quote structures for complex system quotes.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QuoteLine .

ind:primaryQuoteEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Quote Employee Id' ;
    rdfs:comment 'Reference to the user who created this quote line record. Audit trail for accountability.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryQuoteSkuMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Quote Sku Master Id' ;
    rdfs:comment 'Reference to the product master record. Identifies the specific SKU (Stock Keeping Unit), product configuration, or service offering being quoted.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuMaster .

ind:quoteSkuMasterId rdf:type rdf:Property ;
    rdfs:label 'Quote Sku Master Id' ;
    rdfs:comment 'FK to product.sku_master' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuMaster .

ind:commissionPercent rdf:type rdf:Property ;
    rdfs:label 'Commission Percent' ;
    rdfs:comment 'The commission rate applicable to this line item for sales compensation. Business confidential.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBundleParent rdf:type rdf:Property ;
    rdfs:label 'Is Bundle Parent' ;
    rdfs:comment 'Indicates whether this line item is a parent bundle that contains child line items. True for bundle headers, false for standalone or child items.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOptional rdf:type rdf:Property ;
    rdfs:label 'Is Optional' ;
    rdfs:comment 'Indicates whether this line item is optional or required. Optional items may be removed by the customer without affecting the core quote.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marginAmount rdf:type rdf:Property ;
    rdfs:label 'Margin Amount' ;
    rdfs:comment 'The gross margin amount for this line item. Calculated as subtotal amount minus cost amount. Business confidential.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marginPercent rdf:type rdf:Property ;
    rdfs:label 'Margin Percent' ;
    rdfs:comment 'The gross margin percentage for this line item. Calculated as margin amount divided by subtotal amount. Business confidential.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specialTerms rdf:type rdf:Property ;
    rdfs:label 'Special Terms' ;
    rdfs:comment 'Any special terms, conditions, or notes specific to this line item. May include warranty extensions, service level agreements, or custom provisions.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repId rdf:type rdf:Property ;
    rdfs:label 'Rep Id' ;
    rdfs:comment 'Primary key for rep' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managerRepId rdf:type rdf:Property ;
    rdfs:label 'Manager Rep Id' ;
    rdfs:comment 'Reference to the sales representative record of this rep\'s direct manager in the sales hierarchy.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:activeAccountCount rdf:type rdf:Property ;
    rdfs:label 'Active Account Count' ;
    rdfs:comment 'Number of active customer accounts currently assigned to and managed by this sales representative.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activeOpportunityCount rdf:type rdf:Property ;
    rdfs:label 'Active Opportunity Count' ;
    rdfs:comment 'Number of open sales opportunities currently in the representative\'s pipeline.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualQuotaAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Quota Amount' ;
    rdfs:comment 'Annual sales quota target assigned to the representative measured in base currency. Used for performance tracking and commission calculation.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookOfBusinessValue rdf:type rdf:Property ;
    rdfs:label 'Book Of Business Value' ;
    rdfs:comment 'Total annual recurring revenue or contract value of the customer accounts currently managed by this sales representative.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationList rdf:type rdf:Property ;
    rdfs:label 'Certification List' ;
    rdfs:comment 'Professional certifications held by the sales representative relevant to industrial automation and electrification sales, such as product certifications, technical sales training, or industry credentials.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionPlanCode rdf:type rdf:Property ;
    rdfs:label 'Commission Plan Code' ;
    rdfs:comment 'Reference code to the commission plan structure governing how this sales representative earns variable compensation based on sales performance.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmUserCode rdf:type rdf:Property ;
    rdfs:label 'Crm User Code' ;
    rdfs:comment 'Salesforce Sales Cloud user identifier linking this sales representative to their CRM login and activity tracking.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary business email address for the sales representative used for customer communication and internal correspondence.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'Full legal name of the sales representative as recorded in the sales system.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'Date when the sales representative was hired into the sales organization.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:industryVerticalFocus rdf:type rdf:Property ;
    rdfs:label 'Industry Vertical Focus' ;
    rdfs:comment 'Target industry vertical or market segment that the sales representative focuses on, such as automotive, food and beverage, pharmaceuticals, or infrastructure.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isKeyAccountManager rdf:type rdf:Property ;
    rdfs:label 'Is Key Account Manager' ;
    rdfs:comment 'Boolean flag indicating whether this sales representative is designated as a key account manager responsible for strategic, high-value customer relationships.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageProficiency rdf:type rdf:Property ;
    rdfs:label 'Language Proficiency' ;
    rdfs:comment 'Languages spoken by the sales representative relevant for customer communication and territory coverage, stored as comma-separated language codes.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTrainingDate rdf:type rdf:Property ;
    rdfs:label 'Last Training Date' ;
    rdfs:comment 'Date of the most recent sales training, product training, or professional development activity completed by the representative.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mobileNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Number' ;
    rdfs:comment 'Mobile phone number for the sales representative used for field communication and urgent customer contact.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Completion Date' ;
    rdfs:comment 'Date when the sales representative completed the formal onboarding and training program for new sales hires.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceRating rdf:type rdf:Property ;
    rdfs:label 'Performance Rating' ;
    rdfs:comment 'Most recent performance evaluation rating for the sales representative based on quota attainment, customer satisfaction, and other Key Performance Indicators (KPIs).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary business phone number for the sales representative to be contacted by customers and internal stakeholders.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLineSpecialization rdf:type rdf:Property ;
    rdfs:label 'Product Line Specialization' ;
    rdfs:comment 'Primary product line or solution area that the sales representative specializes in, such as drives, PLCs (Programmable Logic Controllers), switchgear, building automation, or electrification systems.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Quota Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the quota amount (e.g., USD, EUR, CNY).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Quota Period End Date' ;
    rdfs:comment 'End date of the current quota period for this sales representative.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quotaPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Quota Period Start Date' ;
    rdfs:comment 'Start date of the current quota period for this sales representative, typically aligned with fiscal year or calendar year.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:repCode rdf:type rdf:Property ;
    rdfs:label 'Rep Code' ;
    rdfs:comment 'Business-assigned unique code for the sales representative used in order entry, commission tracking, and reporting systems.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repStatus rdf:type rdf:Property ;
    rdfs:label 'Rep Status' ;
    rdfs:comment 'Current lifecycle status of the sales representative indicating their availability and eligibility for sales assignments.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOfficeLocation rdf:type rdf:Property ;
    rdfs:label 'Sales Office Location' ;
    rdfs:comment 'Primary office location or branch where the sales representative is based for administrative and reporting purposes.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesRole rdf:type rdf:Property ;
    rdfs:label 'Sales Role' ;
    rdfs:comment 'Commercial role classification indicating the sales representative\'s position in the sales organization hierarchy.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelPercentage rdf:type rdf:Property ;
    rdfs:label 'Travel Percentage' ;
    rdfs:comment 'Expected percentage of work time spent traveling for customer visits, trade shows, and field sales activities.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yearsOfExperience rdf:type rdf:Property ;
    rdfs:label 'Years Of Experience' ;
    rdfs:comment 'Total years of sales experience in industrial automation, electrification, or related technical sales roles.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceCertificationsRequired rdf:type rdf:Property ;
    rdfs:label 'Compliance Certifications Required' ;
    rdfs:comment 'List of mandatory certifications, standards, or regulatory approvals that products or services must meet under the sales contract. Examples: CE marking, UL certification, ISO 9001, IEC 61131, OSHA compliance.' ;
    rdfs:domain ind:SalesContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityClause rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Clause' ;
    rdfs:comment 'Contractual provisions protecting proprietary information, trade secrets, technical specifications, and business data shared between parties. Defines confidential information, permitted uses, and disclosure restrictions.' ;
    rdfs:domain ind:SalesContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Customer Signatory Name' ;
    rdfs:comment 'Full name of the authorized representative who signed the sales contract on behalf of the customer. Used for legal verification and audit trail.' ;
    rdfs:domain ind:SalesContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverySchedule rdf:type rdf:Property ;
    rdfs:label 'Delivery Schedule' ;
    rdfs:comment 'Detailed timeline and milestones for delivery of products, systems, or services under the sales contract. May include phased deliveries, installation schedules, and commissioning dates.' ;
    rdfs:domain ind:SalesContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Method' ;
    rdfs:comment 'Agreed mechanism for resolving disputes arising from the sales contract. Litigation involves court proceedings; arbitration uses neutral arbitrators; mediation involves facilitated negotiation; negotiation is direct party-to-party resolution.' ;
    rdfs:domain ind:SalesContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forceMajeureClause rdf:type rdf:Property ;
    rdfs:label 'Force Majeure Clause' ;
    rdfs:comment 'Contractual provisions excusing non-performance due to unforeseeable events beyond parties control such as natural disasters, war, pandemics, or government actions. Defines qualifying events and relief procedures.' ;
    rdfs:domain ind:SalesContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLaw rdf:type rdf:Property ;
    rdfs:label 'Governing Law' ;
    rdfs:comment 'Legal jurisdiction and body of law that governs the interpretation, enforcement, and dispute resolution of the sales contract. Typically specifies country and state/province.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequirements rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirements' ;
    rdfs:comment 'Mandatory insurance coverage that the supplier or customer must maintain during contract performance. May include general liability, professional indemnity, product liability, or cargo insurance with specified coverage limits.' ;
    rdfs:domain ind:SalesContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intellectualPropertyTerms rdf:type rdf:Property ;
    rdfs:label 'Intellectual Property Terms' ;
    rdfs:comment 'Provisions defining ownership, licensing, and usage rights for intellectual property including patents, designs, software, documentation, and technical know-how. Specifies IP ownership and license grants.' ;
    rdfs:domain ind:SalesContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityCapAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Cap Amount' ;
    rdfs:comment 'Maximum financial liability amount that either party can be held responsible for under the sales contract. Limits exposure for damages, losses, or claims arising from contract performance.' ;
    rdfs:domain ind:SalesContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netContractValue rdf:type rdf:Property ;
    rdfs:label 'Net Contract Value' ;
    rdfs:comment 'Net monetary value of the sales contract after applying discounts, rebates, and before taxes. Represents the actual revenue to be recognized.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalTerms rdf:type rdf:Property ;
    rdfs:label 'Renewal Terms' ;
    rdfs:comment 'Provisions governing automatic renewal, renewal options, or renegotiation terms at contract expiration. Defines renewal notice periods, pricing adjustments, and renewal conditions.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResolutionTimeHours rdf:type rdf:Property ;
    rdfs:label 'Sla Resolution Time Hours' ;
    rdfs:comment 'Maximum number of hours within which the supplier must resolve customer issues or restore service under the contract. Part of SLA commitments for uptime and availability.' ;
    rdfs:domain ind:SalesContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaResponseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Sla Response Time Hours' ;
    rdfs:comment 'Maximum number of hours within which the supplier must respond to customer service requests or incidents under the contract. Part of SLA commitments for support and maintenance.' ;
    rdfs:domain ind:SalesContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaUptimePercentage rdf:type rdf:Property ;
    rdfs:label 'Sla Uptime Percentage' ;
    rdfs:comment 'Guaranteed minimum uptime or availability percentage for systems, equipment, or services covered by the sales contract. Expressed as a percentage (e.g., 99.5% uptime).' ;
    rdfs:domain ind:SalesContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Supplier Signatory Name' ;
    rdfs:comment 'Full name of the authorized representative who signed the sales contract on behalf of the supplier. Used for legal verification and audit trail.' ;
    rdfs:domain ind:SalesContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationClause rdf:type rdf:Property ;
    rdfs:label 'Termination Clause' ;
    rdfs:comment 'Contractual provisions defining conditions, notice periods, and procedures under which either party may terminate the sales contract. Includes termination for cause, convenience, or force majeure.' ;
    rdfs:domain ind:SalesContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueCurrency rdf:type rdf:Property ;
    rdfs:label 'Value Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the contract value. Defines the currency in which all financial terms, payments, and penalties are denominated.' ;
    rdfs:domain ind:SalesContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesLeadId rdf:type rdf:Property ;
    rdfs:label 'Sales Lead Id' ;
    rdfs:comment 'Unique identifier for the sales lead record. Primary key.' ;
    rdfs:domain ind:SalesLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:convertedOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Converted Opportunity Id' ;
    rdfs:comment 'Identifier of the opportunity record created when this lead was converted, establishing traceability from lead to opportunity.' ;
    rdfs:domain ind:SalesLead ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:contactFirstName rdf:type rdf:Property ;
    rdfs:label 'Contact First Name' ;
    rdfs:comment 'First name of the primary contact person at the prospective customer organization.' ;
    rdfs:domain ind:SalesLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactLastName rdf:type rdf:Property ;
    rdfs:label 'Contact Last Name' ;
    rdfs:comment 'Last name of the primary contact person at the prospective customer organization.' ;
    rdfs:domain ind:SalesLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactTitle rdf:type rdf:Property ;
    rdfs:label 'Contact Title' ;
    rdfs:comment 'Job title or role of the primary contact (e.g., Plant Manager, Automation Engineer, Procurement Director).' ;
    rdfs:domain ind:SalesLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedProjectValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Project Value' ;
    rdfs:comment 'Estimated monetary value of the potential project or opportunity in USD, if known at lead stage.' ;
    rdfs:domain ind:SalesLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadNumber rdf:type rdf:Property ;
    rdfs:label 'Lead Number' ;
    rdfs:comment 'Business-facing unique identifier for the lead, typically auto-generated by Salesforce CRM in format LEAD-########.' ;
    rdfs:domain ind:SalesLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationNotes rdf:type rdf:Property ;
    rdfs:label 'Qualification Notes' ;
    rdfs:comment 'Free-text notes capturing qualification details, BANT criteria assessment (Budget, Authority, Need, Timeline), or disqualification reasons.' ;
    rdfs:domain ind:SalesLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rating rdf:type rdf:Property ;
    rdfs:label 'Rating' ;
    rdfs:comment 'Qualitative assessment of lead temperature or priority (hot, warm, cold) based on engagement level and fit.' ;
    rdfs:domain ind:SalesLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesLeadDescription rdf:type rdf:Property ;
    rdfs:label 'Sales Lead Description' ;
    rdfs:comment 'Free-text description of the lead, capturing additional context, project details, or special requirements.' ;
    rdfs:domain ind:SalesLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDetail rdf:type rdf:Property ;
    rdfs:label 'Source Detail' ;
    rdfs:comment 'Additional detail about the lead source, such as specific trade show name, campaign identifier, or referring partner name.' ;
    rdfs:domain ind:SalesLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:streetAddress rdf:type rdf:Property ;
    rdfs:label 'Street Address' ;
    rdfs:comment 'Street address of the prospective customer organization or contact location.' ;
    rdfs:domain ind:SalesLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Territory Id' ;
    rdfs:comment 'Reference to the parent territory in the hierarchical territory structure. Null for top-level territories.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:accountCount rdf:type rdf:Property ;
    rdfs:label 'Account Count' ;
    rdfs:comment 'Total number of customer accounts assigned to this territory. Used for territory balance and coverage analysis.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualRevenueQuota rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Quota' ;
    rdfs:comment 'Target annual revenue quota assigned to this territory in the base currency. Used for quota attainment tracking and sales performance measurement.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentRule rdf:type rdf:Property ;
    rdfs:label 'Assignment Rule' ;
    rdfs:comment 'Business rule or criteria used to assign accounts or opportunities to this territory (e.g., \'Postal codes 10000-19999\', \'Annual revenue > $1M in automotive sector\'). Free-text description of assignment logic.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCodes rdf:type rdf:Property ;
    rdfs:label 'Country Codes' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes covered by this territory (e.g., \'USA,CAN,MEX\' or \'DEU,AUT,CHE\').' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageModel rdf:type rdf:Property ;
    rdfs:label 'Coverage Model' ;
    rdfs:comment 'Sales coverage approach for this territory: direct (direct sales force), channel (partner/distributor), hybrid (combination), inside_sales (remote/phone), or field_sales (on-site visits).' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOverlayTerritory rdf:type rdf:Property ;
    rdfs:label 'Is Overlay Territory' ;
    rdfs:comment 'Boolean flag indicating whether this is an overlay territory (True) that operates across other territories for specialized products or services, or a standard exclusive territory (False).' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overlayType rdf:type rdf:Property ;
    rdfs:label 'Overlay Type' ;
    rdfs:comment 'Type of overlay territory if is_overlay_territory is True: product_specialist (specific product expertise), solution_architect (technical pre-sales), key_account (strategic account support), or none (not an overlay).' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionLevel rdf:type rdf:Property ;
    rdfs:label 'Region Level' ;
    rdfs:comment 'Hierarchical level of the territory within the organizational geography: global (worldwide), regional (multi-country), country (single nation), local (sub-national), district (city/metro), or zone (sub-district).' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesTeamSize rdf:type rdf:Property ;
    rdfs:label 'Sales Team Size' ;
    rdfs:comment 'Number of sales representatives assigned to this territory. Used for capacity planning and workload distribution.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:territoryDescription rdf:type rdf:Property ;
    rdfs:label 'Territory Description' ;
    rdfs:comment 'Detailed textual description of the territory scope, strategic objectives, and special considerations. Provides context for territory planning and handoff.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryName rdf:type rdf:Property ;
    rdfs:label 'Territory Name' ;
    rdfs:comment 'Human-readable name of the sales territory (e.g., \'North America Industrial Automation\', \'EMEA Electrification Solutions\').' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryStatus rdf:type rdf:Property ;
    rdfs:label 'Territory Status' ;
    rdfs:comment 'Current lifecycle status of the territory: active (operational), inactive (not in use), pending (awaiting activation), suspended (temporarily disabled), archived (historical), or planned (future territory).' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryType rdf:type rdf:Property ;
    rdfs:label 'Territory Type' ;
    rdfs:comment 'Classification of territory assignment model: geographic (region-based), industry_vertical (sector-based), account_based (strategic accounts), product_line (product family focus), hybrid (combination), or named_account (specific customer assignment).' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Territory Assignment Id' ;
    rdfs:comment 'Unique identifier for the territory assignment record. Primary key for the territory assignment entity.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPredecessorAssignmentTerritoryAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Predecessor Assignment Territory Assignment Id' ;
    rdfs:comment 'Identifier of the previous territory assignment record that this assignment replaces. Used to track territory transition history and account handoff lineage. Nullable for initial assignments.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TerritoryAssignment .

ind:primaryTerritoryEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Territory Employee Id' ;
    rdfs:comment 'Identifier of the sales manager or team leader to whom this sales representative reports for this territory assignment. Supports matrix reporting structures where a specialist may report to a different manager than the primary account manager.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assignment Notes' ;
    rdfs:comment 'Free-text notes documenting special conditions, transition plans, account handoff details, or coverage agreements for this territory assignment. Used for knowledge transfer and audit trail.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentPriority rdf:type rdf:Property ;
    rdfs:label 'Assignment Priority' ;
    rdfs:comment 'Numeric priority ranking for this assignment when multiple representatives cover the same territory. Lower numbers indicate higher priority. Used for opportunity routing and conflict resolution in matrix sales organizations.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentSource rdf:type rdf:Property ;
    rdfs:label 'Assignment Source' ;
    rdfs:comment 'Origin of the territory assignment record. Manual indicates user-created; automated rule indicates system-generated based on assignment rules; territory model indicates derived from territory planning model; import indicates bulk data load; api indicates external system integration.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentVersion rdf:type rdf:Property ;
    rdfs:label 'Assignment Version' ;
    rdfs:comment 'Version number of the territory assignment record. Incremented with each modification to support change tracking and audit history. Used in territory planning and governance.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commissionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Commission Eligible Flag' ;
    rdfs:comment 'Indicates whether this assignment is eligible for commission calculation. True for quota-carrying roles; false for support roles or salaried positions. Used in compensation processing.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coverageLevel rdf:type rdf:Property ;
    rdfs:label 'Coverage Level' ;
    rdfs:comment 'Scope of coverage responsibility within the territory. Full indicates complete account coverage; partial indicates subset of accounts or opportunities; strategic accounts only indicates focus on key accounts; named accounts indicates specific account list; transactional indicates order processing only.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageRole rdf:type rdf:Property ;
    rdfs:label 'Coverage Role' ;
    rdfs:comment 'Functional role of the sales representative in this territory assignment. Account manager owns customer relationship; product specialist provides domain expertise (e.g., drives, automation, electrification); technical consultant provides pre-sales engineering; inside sales rep provides remote support; channel manager manages indirect partners; overlay specialist provides supplemental coverage.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAssignmentFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Assignment Flag' ;
    rdfs:comment 'Indicates whether this is the primary assignment for the territory. True for the main account owner; false for overlay and specialist assignments. Used to determine default opportunity ownership and customer communication responsibility.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productLineFocus rdf:type rdf:Property ;
    rdfs:label 'Product Line Focus' ;
    rdfs:comment 'Specific product line or solution area this assignment covers within the territory. Examples: drives and motors, programmable logic controllers (PLC), building automation, electrification products, industrial communication, motion control, process instrumentation. Supports product specialist overlay model common in industrial automation sales.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Quota Allocation Percentage' ;
    rdfs:comment 'Percentage of territory quota assigned to this sales representative. Used for performance measurement and capacity planning. May differ from revenue allocation in overlay models where specialists receive credit but not quota burden.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Revenue Allocation Percentage' ;
    rdfs:comment 'Percentage of territory revenue credited to this sales representative for quota and commission calculation. Supports split-credit scenarios in matrix sales organizations where multiple specialists support the same account. Sum of all assignments for a territory may exceed 100% in overlay models.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bulletinId rdf:type rdf:Property ;
    rdfs:label 'Bulletin Id' ;
    rdfs:comment 'Primary key for bulletin' ;
    rdfs:domain ind:Bulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorEngineerId rdf:type rdf:Property ;
    rdfs:label 'Author Engineer Id' ;
    rdfs:comment 'Foreign key linking to service.engineer. Business justification: Bulletin author is a service engineer; FK replaces free-text author field.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Engineer .

ind:actionRequired rdf:type rdf:Property ;
    rdfs:label 'Action Required' ;
    rdfs:comment 'Detailed description of the service action(s) that must be performed.' ;
    rdfs:domain ind:Bulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedProductModels rdf:type rdf:Property ;
    rdfs:label 'Affected Product Models' ;
    rdfs:comment 'Comma-separated list of product model identifiers impacted by the bulletin.' ;
    rdfs:domain ind:Bulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulletinNumber rdf:type rdf:Property ;
    rdfs:label 'Bulletin Number' ;
    rdfs:comment 'Official alphanumeric identifier assigned to the bulletin by engineering.' ;
    rdfs:domain ind:Bulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulletinStatus rdf:type rdf:Property ;
    rdfs:label 'Bulletin Status' ;
    rdfs:comment 'Current lifecycle state of the bulletin.' ;
    rdfs:domain ind:Bulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulletinType rdf:type rdf:Property ;
    rdfs:label 'Bulletin Type' ;
    rdfs:comment 'Category of the bulletin indicating its purpose and urgency.' ;
    rdfs:domain ind:Bulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineeringDepartment rdf:type rdf:Property ;
    rdfs:label 'Engineering Department' ;
    rdfs:comment 'Department within engineering responsible for the bulletin.' ;
    rdfs:domain ind:Bulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedLaborHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Labor Hours' ;
    rdfs:comment 'Projected labor effort in hours to complete the required actions.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborRatePerHour rdf:type rdf:Property ;
    rdfs:label 'Labor Rate Per Hour' ;
    rdfs:comment 'Standard labor rate used for cost estimation, expressed in the selected currency.' ;
    rdfs:domain ind:Bulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partsRequired rdf:type rdf:Property ;
    rdfs:label 'Parts Required' ;
    rdfs:comment 'Comma-separated list of part numbers and quantities needed to comply.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyNoticeFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Notice Flag' ;
    rdfs:comment 'True if the bulletin contains a safety-critical notice.' ;
    rdfs:domain ind:Bulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:softwarePatchVersion rdf:type rdf:Property ;
    rdfs:label 'Software Patch Version' ;
    rdfs:comment 'Version of the software patch associated with the bulletin.' ;
    rdfs:domain ind:Bulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceContractLineId rdf:type rdf:Property ;
    rdfs:label 'Service Contract Line Id' ;
    rdfs:comment 'Primary key for the service_contract_line association' ;
    rdfs:domain ind:ServiceContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryServiceContractId rdf:type rdf:Property ;
    rdfs:label 'Primary Service Contract Id' ;
    rdfs:comment 'Identifier of the parent service contract header.' ;
    rdfs:domain ind:ServiceContractLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceContract .

ind:approvalReference rdf:type rdf:Property ;
    rdfs:label 'Approval Reference' ;
    rdfs:comment 'Reference number or document for regulatory approval.' ;
    rdfs:domain ind:ServiceContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractLineDescription rdf:type rdf:Property ;
    rdfs:label 'Contract Line Description' ;
    rdfs:comment 'Detailed description of the line item.' ;
    rdfs:domain ind:ServiceContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Coverage End Timestamp' ;
    rdfs:comment 'Exact moment coverage ends.' ;
    rdfs:domain ind:ServiceContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:coverageStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Coverage Start Timestamp' ;
    rdfs:comment 'Exact moment coverage begins.' ;
    rdfs:domain ind:ServiceContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:discountType rdf:type rdf:Property ;
    rdfs:label 'Discount Type' ;
    rdfs:comment 'Method used to calculate the discount.' ;
    rdfs:domain ind:ServiceContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExclusive rdf:type rdf:Property ;
    rdfs:label 'Is Exclusive' ;
    rdfs:comment 'Indicates if the coverage is exclusive to the asset.' ;
    rdfs:domain ind:ServiceContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRenewable rdf:type rdf:Property ;
    rdfs:label 'Is Renewable' ;
    rdfs:comment 'Indicates if the line can be renewed after expiry.' ;
    rdfs:domain ind:ServiceContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:metricTargetValue rdf:type rdf:Property ;
    rdfs:label 'Metric Target Value' ;
    rdfs:comment 'Target value for the service metric.' ;
    rdfs:domain ind:ServiceContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metricUnit rdf:type rdf:Property ;
    rdfs:label 'Metric Unit' ;
    rdfs:comment 'Unit for the service metric (e.g., hours, percent).' ;
    rdfs:domain ind:ServiceContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceAmount rdf:type rdf:Property ;
    rdfs:label 'Price Amount' ;
    rdfs:comment 'Monetary amount charged for this equipment under the contract line' ;
    rdfs:domain ind:ServiceContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceCurrency rdf:type rdf:Property ;
    rdfs:label 'Price Currency' ;
    rdfs:comment 'Currency code for the price amount.' ;
    rdfs:domain ind:ServiceContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Flag' ;
    rdfs:comment 'Indicates whether regulatory approval has been obtained.' ;
    rdfs:domain ind:ServiceContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Flag' ;
    rdfs:comment 'Indicates if the line is set for automatic renewal.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceContractLineStatus rdf:type rdf:Property ;
    rdfs:label 'Service Contract Line Status' ;
    rdfs:comment 'Current operational status of the contract line.' ;
    rdfs:domain ind:ServiceContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceMetric rdf:type rdf:Property ;
    rdfs:label 'Service Metric' ;
    rdfs:comment 'Metric used to measure service performance.' ;
    rdfs:domain ind:ServiceContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Included Flag' ;
    rdfs:comment 'Indicates whether tax is already included in the price.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warrantyFlag rdf:type rdf:Property ;
    rdfs:label 'Warranty Flag' ;
    rdfs:comment 'Indicates whether a warranty is included.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:engineerId rdf:type rdf:Property ;
    rdfs:label 'Engineer Id' ;
    rdfs:comment 'Primary key for engineer' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Engineer .

ind:activeAssignmentCount rdf:type rdf:Property ;
    rdfs:label 'Active Assignment Count' ;
    rdfs:comment 'Number of service assignments currently active for the engineer.' ;
    rdfs:domain ind:Engineer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationDriveExpiry rdf:type rdf:Property ;
    rdfs:label 'Certification Drive Expiry' ;
    rdfs:comment 'Expiration date of the drive-systems certification.' ;
    rdfs:domain ind:Engineer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationElectrificationExpiry rdf:type rdf:Property ;
    rdfs:label 'Certification Electrification Expiry' ;
    rdfs:comment 'Expiration date of the electrification certification.' ;
    rdfs:domain ind:Engineer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationHmiExpiry rdf:type rdf:Property ;
    rdfs:label 'Certification Hmi Expiry' ;
    rdfs:comment 'Expiration date of the HMI certification.' ;
    rdfs:domain ind:Engineer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationPlcExpiry rdf:type rdf:Property ;
    rdfs:label 'Certification Plc Expiry' ;
    rdfs:comment 'Expiration date of the PLC certification.' ;
    rdfs:domain ind:Engineer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationRoboticsExpiry rdf:type rdf:Property ;
    rdfs:label 'Certification Robotics Expiry' ;
    rdfs:comment 'Expiration date of the robotics certification.' ;
    rdfs:domain ind:Engineer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationScadaExpiry rdf:type rdf:Property ;
    rdfs:label 'Certification Scada Expiry' ;
    rdfs:comment 'Expiration date of the SCADA certification.' ;
    rdfs:domain ind:Engineer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:classificationOrType rdf:type rdf:Property ;
    rdfs:label 'Classification Or Type' ;
    rdfs:comment 'Category of the engineer (e.g., internal employee, contractor, vendor).' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchZone rdf:type rdf:Property ;
    rdfs:label 'Dispatch Zone' ;
    rdfs:comment 'Specific dispatch zone or area assigned to the engineer.' ;
    rdfs:domain ind:Engineer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentType rdf:type rdf:Property ;
    rdfs:label 'Employment Type' ;
    rdfs:comment 'Type of employment relationship.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborClassification rdf:type rdf:Property ;
    rdfs:label 'Labor Classification' ;
    rdfs:comment 'Labor classification for payroll and cost allocation.' ;
    rdfs:domain ind:Engineer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborRateHourly rdf:type rdf:Property ;
    rdfs:label 'Labor Rate Hourly' ;
    rdfs:comment 'Standard hourly labor rate for the engineer.' ;
    rdfs:domain ind:Engineer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastDispatchTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Dispatch Timestamp' ;
    rdfs:comment 'Timestamp of the most recent dispatch of the engineer.' ;
    rdfs:domain ind:Engineer ;
    rdf:type owl:DatatypeProperty ;
