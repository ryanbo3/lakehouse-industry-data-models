    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxTravelTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Max Travel Time Minutes' ;
    rdfs:comment 'Maximum expected travel time from the service center to any point in the zone.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatingHours rdf:type rdf:Property ;
    rdfs:label 'Operating Hours' ;
    rdfs:comment 'Standard daily operating window for field service (e.g., 08:00-17:00).' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCodeRange rdf:type rdf:Property ;
    rdfs:label 'Postal Code Range' ;
    rdfs:comment 'Range of postal codes (e.g., 10001-10292) defining the zone boundaries.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaCoverageLevel rdf:type rdf:Property ;
    rdfs:label 'Sla Coverage Level' ;
    rdfs:comment 'Level of service commitment promised for the zone.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedProductFamily rdf:type rdf:Property ;
    rdfs:label 'Supported Product Family' ;
    rdfs:comment 'Product families that can be serviced within this zone.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneDescription rdf:type rdf:Property ;
    rdfs:label 'Zone Description' ;
    rdfs:comment 'Free-form description of the zone’s characteristics and purpose.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneName rdf:type rdf:Property ;
    rdfs:label 'Zone Name' ;
    rdfs:comment 'Human-readable name of the service territory.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneStatus rdf:type rdf:Property ;
    rdfs:label 'Zone Status' ;
    rdfs:comment 'Current lifecycle status of the zone.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Sla Milestone Id' ;
    rdfs:comment 'Unique system-generated identifier for the SLA milestone record.' ;
    rdfs:domain ind:SlaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Timestamp' ;
    rdfs:comment 'The actual date and time when the milestone was completed.' ;
    rdfs:domain ind:SlaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignedTeam rdf:type rdf:Property ;
    rdfs:label 'Assigned Team' ;
    rdfs:comment 'Name or identifier of the support team responsible for meeting the milestone.' ;
    rdfs:domain ind:SlaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachFlag rdf:type rdf:Property ;
    rdfs:label 'Breach Flag' ;
    rdfs:comment 'True if the milestone was not met within the target time, otherwise False.' ;
    rdfs:domain ind:SlaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breachReason rdf:type rdf:Property ;
    rdfs:label 'Breach Reason' ;
    rdfs:comment 'Free-text description of why the SLA milestone was breached.' ;
    rdfs:domain ind:SlaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elapsedTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Elapsed Time Minutes' ;
    rdfs:comment 'Total minutes elapsed between the target timestamp and the actual completion timestamp.' ;
    rdfs:domain ind:SlaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:entitlementTier rdf:type rdf:Property ;
    rdfs:label 'Entitlement Tier' ;
    rdfs:comment 'Tier of service entitlement that defines SLA targets for the request.' ;
    rdfs:domain ind:SlaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalatedFlag rdf:type rdf:Property ;
    rdfs:label 'Escalated Flag' ;
    rdfs:comment 'True if the milestone required escalation to a higher support tier.' ;
    rdfs:domain ind:SlaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionCode rdf:type rdf:Property ;
    rdfs:label 'Resolution Code' ;
    rdfs:comment 'Standard code indicating how the milestone was resolved (e.g., completed, workaround, escalated).' ;
    rdfs:domain ind:SlaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaMilestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Milestone Status' ;
    rdfs:comment 'Current status of the milestone (e.g., pending, met, breached, cancelled).' ;
    rdfs:domain ind:SlaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetTimestamp rdf:type rdf:Property ;
    rdfs:label 'Target Timestamp' ;
    rdfs:comment 'The contractual target date and time by which the milestone must be achieved.' ;
    rdfs:domain ind:SlaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvedVendorListId rdf:type rdf:Property ;
    rdfs:label 'Approved Vendor List Id' ;
    rdfs:comment 'Unique identifier for the approved vendor list entry. Primary key for the AVL record linking a qualified supplier to authorized commodity categories.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryApprovedSupplierId rdf:type rdf:Property ;
    rdfs:label 'Primary Approved Supplier Id' ;
    rdfs:comment 'Reference to the qualified supplier authorized to supply materials or services for the specified commodity category.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:annualSpendTarget rdf:type rdf:Property ;
    rdfs:label 'Annual Spend Target' ;
    rdfs:comment 'Target annual procurement spend with this supplier for the specified commodity category, used for volume commitment tracking and supplier relationship management.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avlNumber rdf:type rdf:Property ;
    rdfs:label 'Avl Number' ;
    rdfs:comment 'Business identifier for the AVL entry used in procurement documents and Material Requirements Planning (MRP) source selection.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avlStatus rdf:type rdf:Property ;
    rdfs:label 'Avl Status' ;
    rdfs:comment 'Current lifecycle status of the AVL entry determining whether the supplier can be selected during purchase order creation in Material Requirements Planning (MRP) and procurement processes.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityRating rdf:type rdf:Property ;
    rdfs:label 'Capacity Rating' ;
    rdfs:comment 'Assessment of the suppliers production capacity and ability to scale volume for this commodity category.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Required Flag' ;
    rdfs:comment 'Indicates whether specific certifications (ISO, industry-specific, regulatory) are required for the supplier to maintain AVL status for this commodity.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'Reference number of the master supply agreement or contract governing pricing, terms, and conditions for this commodity category.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCompetitivenessRating rdf:type rdf:Property ;
    rdfs:label 'Cost Competitiveness Rating' ;
    rdfs:comment 'Cost competitiveness rating comparing the suppliers pricing for this commodity against market benchmarks and other approved suppliers.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryRating rdf:type rdf:Property ;
    rdfs:label 'Delivery Rating' ;
    rdfs:comment 'Current on-time delivery performance rating for the supplier in this commodity category, used in Material Requirements Planning (MRP) source selection.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expeditedLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Expedited Lead Time Days' ;
    rdfs:comment 'Expedited lead time in days available for urgent orders, typically shorter than standard lead time but may incur additional costs.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geographicSupplyRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Supply Region' ;
    rdfs:comment 'Three-letter ISO country code or region code indicating the primary geographic region from which the supplier will ship materials for this commodity.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent supplier audit conducted for this commodity category, supporting ongoing qualification status.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:moq rdf:type rdf:Property ;
    rdfs:label 'Moq' ;
    rdfs:comment 'Minimum Order Quantity (MOQ) required by the supplier for this commodity category. Used by Material Requirements Planning (MRP) to ensure order quantities meet supplier constraints.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moqUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Moq Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the Minimum Order Quantity (MOQ) such as EA (each), KG (kilogram), M (meter), L (liter).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partFamily rdf:type rdf:Property ;
    rdfs:label 'Part Family' ;
    rdfs:comment 'Part family or product line grouping for which the supplier is qualified to provide components or assemblies.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceValidityEndDate rdf:type rdf:Property ;
    rdfs:label 'Price Validity End Date' ;
    rdfs:comment 'End date for the current pricing agreement, after which prices must be renegotiated or updated.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceValidityStartDate rdf:type rdf:Property ;
    rdfs:label 'Price Validity Start Date' ;
    rdfs:comment 'Start date for the current pricing agreement applicable to this AVL entry.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityRating rdf:type rdf:Property ;
    rdfs:label 'Quality Rating' ;
    rdfs:comment 'Current quality performance rating for the supplier in this commodity category, typically expressed as a percentage or score used in supplier selection decisions.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:singleSourceFlag rdf:type rdf:Property ;
    rdfs:label 'Single Source Flag' ;
    rdfs:comment 'Indicates whether this supplier is the only approved source for the commodity category, representing a supply chain risk requiring mitigation strategies.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierDesignation rdf:type rdf:Property ;
    rdfs:label 'Supplier Designation' ;
    rdfs:comment 'Designation indicating the suppliers priority level for sourcing decisions. Preferred suppliers are selected first by Material Requirements Planning (MRP), backup suppliers are used when preferred suppliers cannot fulfill demand.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyPlantCode rdf:type rdf:Property ;
    rdfs:label 'Supply Plant Code' ;
    rdfs:comment 'Supplier plant or facility code from which materials will be shipped for this commodity category.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeNotificationId rdf:type rdf:Property ;
    rdfs:label 'Change Notification Id' ;
    rdfs:comment 'Unique identifier for the supplier change notification record. Primary key.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryChangeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Change Employee Id' ;
    rdfs:comment 'Employee identifier of the Manufacturing approver.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedPartNumbers rdf:type rdf:Property ;
    rdfs:label 'Affected Part Numbers' ;
    rdfs:comment 'Comma-separated or structured list of Manufacturing part numbers (SKUs) impacted by this change.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalDecision rdf:type rdf:Property ;
    rdfs:label 'Approval Decision' ;
    rdfs:comment 'Manufacturing\'s final decision on the supplier change notification: approved (change accepted), rejected (change denied), conditional (approved with requirements), pending (decision not yet made).' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Required Flag' ;
    rdfs:comment 'Indicates whether an on-site supplier audit is required to verify the change implementation.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conditionalApprovalRequirements rdf:type rdf:Property ;
    rdfs:label 'Conditional Approval Requirements' ;
    rdfs:comment 'Specific conditions or requirements that must be met for a conditionally approved change (e.g., re-qualification testing, PPAP re-submission, phased implementation).' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Flag' ;
    rdfs:comment 'Indicates whether the change has potential impact on product cost or pricing.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impactAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment Date' ;
    rdfs:comment 'Date when Manufacturing completed the impact assessment for this change notification.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:impactAssessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment Status' ;
    rdfs:comment 'Status of Manufacturing\'s internal impact assessment process to evaluate the effect of the supplier change on products, quality, cost, and supply chain.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactLevel rdf:type rdf:Property ;
    rdfs:label 'Impact Level' ;
    rdfs:comment 'Assessed severity of impact on Manufacturing\'s products, operations, or customers: critical (major impact requiring immediate action), high (significant impact), medium (moderate impact), low (minor impact), none (no material impact).' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingContactName rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Contact Name' ;
    rdfs:comment 'Name of the Manufacturing employee responsible for managing this change notification (e.g., commodity manager, quality engineer).' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationDate rdf:type rdf:Property ;
    rdfs:label 'Notification Date' ;
    rdfs:comment 'Date when the supplier formally submitted the change notification to Manufacturing.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ppapLevelRequired rdf:type rdf:Property ;
    rdfs:label 'Ppap Level Required' ;
    rdfs:comment 'PPAP submission level required for re-qualification (1-5), where higher levels require more comprehensive documentation.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ppapResubmissionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Ppap Resubmission Required Flag' ;
    rdfs:comment 'Indicates whether the supplier must re-submit PPAP documentation due to this change.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Impact Flag' ;
    rdfs:comment 'Indicates whether the change has potential impact on product quality, performance, or reliability.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relatedEcoNumber rdf:type rdf:Property ;
    rdfs:label 'Related Eco Number' ;
    rdfs:comment 'Reference to Manufacturing\'s internal ECO or ECN number if this supplier change triggers an internal engineering change.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requalificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Requalification Required Flag' ;
    rdfs:comment 'Indicates whether the supplier must undergo re-qualification or re-approval process due to this change.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestedEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Requested Effective Date' ;
    rdfs:comment 'Original effective date requested by the supplier, may differ from final approved effective date.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'Date by which Manufacturing must provide a response or decision to the supplier on the change notification.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Schedule Impact Flag' ;
    rdfs:comment 'Indicates whether the change has potential impact on delivery schedules or lead times.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierContactEmail rdf:type rdf:Property ;
    rdfs:label 'Supplier Contact Email' ;
    rdfs:comment 'Email address of the supplier contact for this change notification.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Testing Required Flag' ;
    rdfs:comment 'Indicates whether Manufacturing requires additional testing or validation of parts produced after the change.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionId rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Id' ;
    rdfs:comment 'Unique identifier for the supplier corrective action request record.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCorrectiveEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Corrective Employee Id' ;
    rdfs:comment 'Identifier of the user who issued the corrective action request to the supplier.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedLotBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Affected Lot Batch Number' ;
    rdfs:comment 'Lot or batch number of the affected material or product.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedMaterialCode rdf:type rdf:Property ;
    rdfs:label 'Affected Material Code' ;
    rdfs:comment 'Material or part number affected by the issue requiring corrective action.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attachmentDocumentIds rdf:type rdf:Property ;
    rdfs:label 'Attachment Document Ids' ;
    rdfs:comment 'Comma-separated list of document identifiers for supporting evidence, photos, test reports, or supplier response documents.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentActionDate rdf:type rdf:Property ;
    rdfs:label 'Containment Action Date' ;
    rdfs:comment 'Date when the containment action was implemented.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Amount' ;
    rdfs:comment 'Estimated or actual financial impact of the issue including scrap, rework, downtime, and expediting costs.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costImpactCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the cost impact amount.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permanentCorrectiveAction rdf:type rdf:Property ;
    rdfs:label 'Permanent Corrective Action' ;
    rdfs:comment 'Permanent corrective action implemented by the supplier to address the root cause and prevent recurrence.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveActionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Completion Date' ;
    rdfs:comment 'Actual date when the preventive action was completed by the supplier.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preventiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Due Date' ;
    rdfs:comment 'Target date by which the preventive action must be completed.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:previousScarNumber rdf:type rdf:Property ;
    rdfs:label 'Previous Scar Number' ;
    rdfs:comment 'Reference to a previous SCAR number if this is a recurrence of a prior issue.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedPurchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Related Purchase Order Number' ;
    rdfs:comment 'Purchase order number associated with the affected material or delivery.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedRmaNumber rdf:type rdf:Property ;
    rdfs:label 'Related Rma Number' ;
    rdfs:comment 'RMA number if the issue resulted in material being returned to the supplier.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scarNumber rdf:type rdf:Property ;
    rdfs:label 'Scar Number' ;
    rdfs:comment 'Externally-known unique business identifier for the supplier corrective action request.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierResponseComments rdf:type rdf:Property ;
    rdfs:label 'Supplier Response Comments' ;
    rdfs:comment 'Comments or explanation provided by the supplier in response to the corrective action request.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierResponseDate rdf:type rdf:Property ;
    rdfs:label 'Supplier Response Date' ;
    rdfs:comment 'Date when the supplier formally responded to the corrective action request.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationComments rdf:type rdf:Property ;
    rdfs:label 'Verification Comments' ;
    rdfs:comment 'Additional comments or observations from the verification activity.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developmentPlanId rdf:type rdf:Property ;
    rdfs:label 'Development Plan Id' ;
    rdfs:comment 'Unique identifier for the supplier development plan or Supplier Corrective Action Request (SCAR). Primary key for this entity.' ;
    rdfs:domain ind:DevelopmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAssignedDevelopmentEngineerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Assigned Development Engineer Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:DevelopmentPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supplierAuditId rdf:type rdf:Property ;
    rdfs:label 'Supplier Audit Id' ;
    rdfs:comment 'Identifier of the supplier audit that identified findings leading to this plan, if applicable. Null if triggered by other sources.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierAudit .

ind:triggeredByNcrId rdf:type rdf:Property ;
    rdfs:label 'Triggered By Ncr Id' ;
    rdfs:comment 'Identifier of the Non-Conformance Report (NCR) that triggered this corrective action plan, if applicable. Null if triggered by other sources.' ;
    rdfs:domain ind:DevelopmentPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ncr .

ind:triggeredByScorecardId rdf:type rdf:Property ;
    rdfs:label 'Triggered By Scorecard Id' ;
    rdfs:comment 'Identifier of the supplier scorecard evaluation that triggered this development plan, if applicable. Null if triggered by other sources.' ;
    rdfs:domain ind:DevelopmentPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Scorecard .

ind:actionType rdf:type rdf:Property ;
    rdfs:label 'Action Type' ;
    rdfs:comment 'Classification of the supplier-facing improvement intervention: performance improvement plan, capability development, quality remediation, SCAR (Supplier Corrective Action Request), preventive action, or cost reduction initiative.' ;
    rdfs:domain ind:DevelopmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualKpiValue rdf:type rdf:Property ;
    rdfs:label 'Actual Kpi Value' ;
    rdfs:comment 'The actual KPI value achieved after plan completion, used to determine effectiveness.' ;
    rdfs:domain ind:DevelopmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineKpiValue rdf:type rdf:Property ;
    rdfs:label 'Baseline Kpi Value' ;
    rdfs:comment 'The baseline value of the target KPI before the development plan was initiated.' ;
    rdfs:domain ind:DevelopmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closureOutcome rdf:type rdf:Property ;
    rdfs:label 'Closure Outcome' ;
    rdfs:comment 'Final outcome when the plan is closed: successful (issue resolved and verified), unsuccessful (actions failed to resolve issue), cancelled (plan terminated before completion), or escalated (issue elevated to higher management or alternative resolution path).' ;
    rdfs:domain ind:DevelopmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Completion Date' ;
    rdfs:comment 'Date when the permanent corrective action was fully implemented.' ;
    rdfs:domain ind:DevelopmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedSavings rdf:type rdf:Property ;
    rdfs:label 'Estimated Savings' ;
    rdfs:comment 'Estimated financial savings or cost avoidance expected from successful completion of this plan (e.g., reduced defects, improved efficiency, lower scrap rates).' ;
    rdfs:domain ind:DevelopmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:kpiUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Kpi Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the KPI values (e.g., percentage, PPM, days, USD, count).' ;
    rdfs:domain ind:DevelopmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneSchedule rdf:type rdf:Property ;
    rdfs:label 'Milestone Schedule' ;
    rdfs:comment 'Structured schedule of key milestones and target dates for the development plan (e.g., root cause analysis complete by date X, corrective action implemented by date Y, verification by date Z). May be stored as JSON or delimited text.' ;
    rdfs:domain ind:DevelopmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan End Date' ;
    rdfs:comment 'Target completion date for all actions in the development plan. May be extended if verification fails.' ;
    rdfs:domain ind:DevelopmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Start Date' ;
    rdfs:comment 'Date when the development plan or corrective action was officially initiated.' ;
    rdfs:domain ind:DevelopmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scarReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Scar Reference Number' ;
    rdfs:comment 'External SCAR reference number if this plan originated from a formal SCAR process. May be null for proactive development plans.' ;
    rdfs:domain ind:DevelopmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetKpiMetric rdf:type rdf:Property ;
    rdfs:label 'Target Kpi Metric' ;
    rdfs:comment 'The specific KPI or performance metric that this plan aims to improve (e.g., PPM defect rate, OTD percentage, cost variance, lead time).' ;
    rdfs:domain ind:DevelopmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetKpiValue rdf:type rdf:Property ;
    rdfs:label 'Target Kpi Value' ;
    rdfs:comment 'The target value for the KPI that the plan aims to achieve upon successful completion.' ;
    rdfs:domain ind:DevelopmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualificationId rdf:type rdf:Property ;
    rdfs:label 'Qualification Id' ;
    rdfs:comment 'Unique identifier for the supplier qualification record. Primary key.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualificationApprovingEngineerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Qualification Approving Engineer Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:qualificationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Qualification Employee Id' ;
    rdfs:comment 'Reference to the quality or sourcing engineer who authorized the qualification decision.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:qualificationModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Qualification Modified By User Employee Id' ;
    rdfs:comment 'User identifier of the person who last modified the qualification record, captured for audit trail purposes.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedCommodities rdf:type rdf:Property ;
    rdfs:label 'Affected Commodities' ;
    rdfs:comment 'Comma-separated list or description of commodity categories affected by a disqualification event. Null if not disqualified or if disqualification is global.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basis rdf:type rdf:Property ;
    rdfs:label 'Basis' ;
    rdfs:comment 'Primary method or standard used to qualify the supplier: PPAP (Production Part Approval Process), APQP (Advanced Product Quality Planning), on-site audit, sample approval, document review, third-party certification (ISO, UL, etc.), or legacy performance history. [ENUM-REF-CANDIDATE: ppap|apqp|on_site_audit|sample_approval|document_review|third_party_certification|legacy_performance — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationRequired rdf:type rdf:Property ;
    rdfs:label 'Certification Required' ;
    rdfs:comment 'Comma-separated list of certifications or standards the supplier must hold to maintain qualification (e.g., ISO 9001, ISO 14001, ISO 45001, IATF 16949, UL, CE). Null if no specific certifications are required.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionalApprovalExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Conditional Approval Expiry Date' ;
    rdfs:comment 'Date by which the supplier must satisfy conditional approval requirements to achieve full approval status. Null if not conditionally approved.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conditionalApprovalReason rdf:type rdf:Property ;
    rdfs:label 'Conditional Approval Reason' ;
    rdfs:comment 'Explanation of why the supplier was granted conditional approval rather than full approval, including specific restrictions or pending actions. Null if not conditionally approved.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disqualificationDate rdf:type rdf:Property ;
    rdfs:label 'Disqualification Date' ;
    rdfs:comment 'Date when the supplier was formally disqualified or approval was revoked. Null if not disqualified.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationNotes rdf:type rdf:Property ;
    rdfs:label 'Evaluation Notes' ;
    rdfs:comment 'Free-text field capturing additional observations, findings, or context from the qualification evaluation process.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationTeam rdf:type rdf:Property ;
    rdfs:label 'Evaluation Team' ;
    rdfs:comment 'Comma-separated list or description of the cross-functional team members who participated in the supplier qualification evaluation (e.g., quality, engineering, procurement, operations).' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationNumber rdf:type rdf:Property ;
    rdfs:label 'Qualification Number' ;
    rdfs:comment 'Business identifier for the qualification record, typically system-generated and used in external communications and audit trails.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Status' ;
    rdfs:comment 'Current lifecycle status of the supplier qualification: prospective (initial inquiry), under evaluation (assessment in progress), approved (fully qualified), conditional (approved with restrictions or pending actions), disqualified (rejected or revoked), expired (approval period lapsed).' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationType rdf:type rdf:Property ;
    rdfs:label 'Qualification Type' ;
    rdfs:comment 'Type of qualification event: new supplier onboarding, periodic re-qualification, extension to new commodity categories, disqualification action, or conditional approval pending corrective action.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reQualificationConditions rdf:type rdf:Property ;
    rdfs:label 'Re Qualification Conditions' ;
    rdfs:comment 'Specific conditions or corrective actions the supplier must complete before being eligible for re-qualification. Null if not applicable or if permanently disqualified.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reQualificationEligible rdf:type rdf:Property ;
    rdfs:label 'Re Qualification Eligible' ;
    rdfs:comment 'Indicates whether a disqualified supplier is eligible to apply for re-qualification in the future. True if eligible, False if permanently disqualified.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transitionPlanReference rdf:type rdf:Property ;
    rdfs:label 'Transition Plan Reference' ;
    rdfs:comment 'Reference identifier or document number for the supplier transition or phase-out plan in the event of disqualification. Null if not applicable.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRatingId rdf:type rdf:Property ;
    rdfs:label 'Risk Rating Id' ;
    rdfs:comment 'Unique identifier for the supplier risk rating assessment record.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRiskEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Risk Employee Id' ;
    rdfs:comment 'Identifier of the employee or team member who conducted the risk assessment.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assessmentPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Period End Date' ;
    rdfs:comment 'End date of the observation period used for risk data collection and analysis.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Period Start Date' ;
    rdfs:comment 'Start date of the observation period used for risk data collection and analysis.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capacityUtilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Capacity Utilization Percentage' ;
    rdfs:comment 'Percentage of the suppliers production capacity currently utilized, indicating headroom for demand increases or risk of over-commitment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationGapCount rdf:type rdf:Property ;
    rdfs:label 'Certification Gap Count' ;
    rdfs:comment 'Number of required certifications or standards that the supplier does not currently hold, representing compliance risk.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conflictMineralsFlag rdf:type rdf:Property ;
    rdfs:label 'Conflict Minerals Flag' ;
    rdfs:comment 'Boolean indicator whether the supplier sources conflict minerals from high-risk regions, representing ESG and regulatory compliance risk.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countryRiskRating rdf:type rdf:Property ;
    rdfs:label 'Country Risk Rating' ;
    rdfs:comment 'Risk rating for the suppliers primary operating country reflecting political stability, economic conditions, and regulatory environment.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditScore rdf:type rdf:Property ;
    rdfs:label 'Credit Score' ;
    rdfs:comment 'Numerical credit score from financial rating agencies indicating the suppliers creditworthiness and payment reliability.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cybersecurityIncidentCount rdf:type rdf:Property ;
    rdfs:label 'Cybersecurity Incident Count' ;
    rdfs:comment 'Number of reported cybersecurity incidents or breaches at the supplier during the assessment period.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cybersecurityRiskScore rdf:type rdf:Property ;
    rdfs:label 'Cybersecurity Risk Score' ;
    rdfs:comment 'Risk score for cybersecurity maturity dimension evaluating IEC 62443 compliance level, incident history, vulnerability management, and data protection practices.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSources rdf:type rdf:Property ;
    rdfs:label 'Data Sources' ;
    rdfs:comment 'Comma-separated list of data sources used for the risk assessment, such as Dun & Bradstreet, RapidRatings, EcoVadis, internal scorecards, audit reports, or supplier self-declarations.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dnbRating rdf:type rdf:Property ;
    rdfs:label 'Dnb Rating' ;
    rdfs:comment 'Dun & Bradstreet credit rating or risk indicator for the supplier, providing third-party financial risk assessment.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecovadisScore rdf:type rdf:Property ;
    rdfs:label 'Ecovadis Score' ;
    rdfs:comment 'EcoVadis sustainability rating score (0-100) assessing the suppliers ESG performance across environment, labor practices, ethics, and sustainable procurement.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:environmentalComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Status' ;
    rdfs:comment 'Status of the suppliers compliance with environmental regulations and ISO 14001 standards.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgRiskScore rdf:type rdf:Property ;
    rdfs:label 'Esg Risk Score' ;
    rdfs:comment 'Risk score for ESG (Environmental, Social, and Governance) dimension covering environmental compliance, labor practices, conflict minerals sourcing, and sustainability performance.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialRiskScore rdf:type rdf:Property ;
    rdfs:label 'Financial Risk Score' ;
    rdfs:comment 'Risk score for financial stability dimension based on credit rating, liquidity ratios, debt levels, and financial health indicators from sources like Dun & Bradstreet or RapidRatings.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geopoliticalRiskScore rdf:type rdf:Property ;
    rdfs:label 'Geopolitical Risk Score' ;
    rdfs:comment 'Risk score for geopolitical exposure dimension covering country risk, sanctions lists, trade restrictions, political stability, and regulatory environment.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iec62443MaturityLevel rdf:type rdf:Property ;
    rdfs:label 'Iec 62443 Maturity Level' ;
    rdfs:comment 'Industrial cybersecurity maturity level per IEC 62443 standard, indicating the suppliers capability to protect industrial control systems and operational technology.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyRiskDrivers rdf:type rdf:Property ;
    rdfs:label 'Key Risk Drivers' ;
    rdfs:comment 'Narrative summary of the primary risk factors and drivers contributing to the overall risk rating, highlighting specific concerns or vulnerabilities.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadTimeVolatilityIndex rdf:type rdf:Property ;
    rdfs:label 'Lead Time Volatility Index' ;
    rdfs:comment 'Statistical measure of lead time variability and unpredictability, calculated as coefficient of variation or standard deviation of delivery lead times.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mitigationActions rdf:type rdf:Property ;
    rdfs:label 'Mitigation Actions' ;
    rdfs:comment 'Description of risk mitigation actions currently in place or planned, such as dual sourcing, increased inventory buffers, supplier development programs, or contractual safeguards.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalRiskScore rdf:type rdf:Property ;
    rdfs:label 'Operational Risk Score' ;
    rdfs:comment 'Risk score for operational continuity dimension assessing single-source dependency, capacity utilization, lead time volatility, and business continuity preparedness.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallRiskTier rdf:type rdf:Property ;
    rdfs:label 'Overall Risk Tier' ;
    rdfs:comment 'Aggregated risk classification tier representing the suppliers overall risk exposure level across all dimensions.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppmDefectRate rdf:type rdf:Property ;
    rdfs:label 'Ppm Defect Rate' ;
    rdfs:comment 'Quality metric representing defective parts per million units received, used to assess quality risk exposure.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publishedDate rdf:type rdf:Property ;
    rdfs:label 'Published Date' ;
    rdfs:comment 'Date when the risk rating was published and made available to stakeholders for supply chain risk management and sourcing decisions.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityRiskScore rdf:type rdf:Property ;
    rdfs:label 'Quality Risk Score' ;
    rdfs:comment 'Risk score for quality performance dimension based on PPM (Parts Per Million) defect trends, audit history, certification gaps, and NCR (Non-Conformance Report) frequency.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Level' ;
    rdfs:comment 'Risk level remaining after mitigation actions have been applied, representing the net risk exposure the organization accepts.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsFlag rdf:type rdf:Property ;
    rdfs:label 'Sanctions Flag' ;
    rdfs:comment 'Boolean indicator whether the supplier or its country of operation is subject to international trade sanctions or restricted party lists.' ;
    rdfs:domain ind:RiskRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scorecardId rdf:type rdf:Property ;
    rdfs:label 'Scorecard Id' ;
    rdfs:comment 'Unique identifier for the supplier performance scorecard record.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scorecardEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Scorecard Employee Id' ;
    rdfs:comment 'Reference to the buyer, procurement specialist, or quality engineer who conducted the scorecard evaluation.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:capaCount rdf:type rdf:Property ;
    rdfs:label 'Capa Count' ;
    rdfs:comment 'Total number of corrective and preventive action requests issued to this supplier during the evaluation period.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costScore rdf:type rdf:Property ;
    rdfs:label 'Cost Score' ;
    rdfs:comment 'Performance score for the cost pillar, measuring price competitiveness, cost variance, and total cost of ownership, expressed as a percentage (0-100).' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Variance Percentage' ;
    rdfs:comment 'Percentage variance between actual costs and target or budgeted costs during the evaluation period, where negative values indicate cost savings.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costWeightPercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Weight Percentage' ;
    rdfs:comment 'Percentage weight assigned to the cost pillar in the overall score calculation.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryScore rdf:type rdf:Property ;
    rdfs:label 'Delivery Score' ;
    rdfs:comment 'Performance score for the delivery pillar, measuring on-time delivery performance and schedule adherence, expressed as a percentage (0-100).' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationMethodology rdf:type rdf:Property ;
    rdfs:label 'Evaluation Methodology' ;
    rdfs:comment 'Description of the scoring methodology, weighting scheme, and calculation approach used for this scorecard evaluation.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period End Date' ;
    rdfs:comment 'The end date of the performance evaluation period covered by this scorecard.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Start Date' ;
    rdfs:comment 'The start date of the performance evaluation period covered by this scorecard.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:improvementActionsRequired rdf:type rdf:Property ;
    rdfs:label 'Improvement Actions Required' ;
    rdfs:comment 'Summary of required improvement actions or corrective measures the supplier must implement based on scorecard results.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncrCount rdf:type rdf:Property ;
    rdfs:label 'Ncr Count' ;
    rdfs:comment 'Total number of non-conformance reports issued against this supplier during the evaluation period.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:otdPercentage rdf:type rdf:Property ;
    rdfs:label 'Otd Percentage' ;
    rdfs:comment 'Percentage of deliveries received on or before the scheduled delivery date during the evaluation period, a key delivery performance indicator.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousRatingTier rdf:type rdf:Property ;
    rdfs:label 'Previous Rating Tier' ;
    rdfs:comment 'The rating tier assigned to the supplier in the previous evaluation period, used for trend analysis and tier movement tracking.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingTier rdf:type rdf:Property ;
    rdfs:label 'Rating Tier' ;
    rdfs:comment 'Strategic classification tier assigned to the supplier based on scorecard performance, driving sourcing decisions and supplier development programs.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsivenessIndex rdf:type rdf:Property ;
    rdfs:label 'Responsiveness Index' ;
    rdfs:comment 'Composite index measuring supplier responsiveness across communication, issue resolution, and collaboration dimensions, expressed as a percentage (0-100).' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsivenessScore rdf:type rdf:Property ;
    rdfs:label 'Responsiveness Score' ;
    rdfs:comment 'Performance score for the responsiveness pillar, measuring communication effectiveness, issue resolution speed, and collaboration quality, expressed as a percentage (0-100).' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsivenessWeightPercentage rdf:type rdf:Property ;
    rdfs:label 'Responsiveness Weight Percentage' ;
    rdfs:comment 'Percentage weight assigned to the responsiveness pillar in the overall score calculation.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rmaCount rdf:type rdf:Property ;
    rdfs:label 'Rma Count' ;
    rdfs:comment 'Total number of return material authorizations processed for defective or non-conforming materials from this supplier during the evaluation period.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scorecardNumber rdf:type rdf:Property ;
    rdfs:label 'Scorecard Number' ;
    rdfs:comment 'Business identifier for the scorecard, typically formatted as a human-readable code used in reports and communications.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scorecardStatus rdf:type rdf:Property ;
    rdfs:label 'Scorecard Status' ;
    rdfs:comment 'Current lifecycle status of the scorecard indicating its approval and publication state.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strengthsSummary rdf:type rdf:Property ;
    rdfs:label 'Strengths Summary' ;
    rdfs:comment 'Summary of the supplier\'s key strengths and positive performance areas identified during the evaluation period.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalLineItemsEvaluated rdf:type rdf:Property ;
    rdfs:label 'Total Line Items Evaluated' ;
    rdfs:comment 'Total number of purchase order line items included in the evaluation period for this scorecard.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalOrdersEvaluated rdf:type rdf:Property ;
    rdfs:label 'Total Orders Evaluated' ;
    rdfs:comment 'Total number of purchase orders included in the evaluation period for this scorecard.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPurchaseValue rdf:type rdf:Property ;
    rdfs:label 'Total Purchase Value' ;
    rdfs:comment 'Total monetary value of purchases from this supplier during the evaluation period, used for spend-weighted performance analysis.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalReceiptsEvaluated rdf:type rdf:Property ;
    rdfs:label 'Total Receipts Evaluated' ;
    rdfs:comment 'Total number of goods receipts or deliveries included in the evaluation period for this scorecard.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weaknessesSummary rdf:type rdf:Property ;
    rdfs:label 'Weaknesses Summary' ;
    rdfs:comment 'Summary of the supplier\'s key weaknesses and performance gaps identified during the evaluation period.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Account Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: PROCUREMENT: Assigns an internal account manager to each supplier for relationship management; required for supplier performance dashboards and contract negotiations.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:businessType rdf:type rdf:Property ;
    rdfs:label 'Business Type' ;
    rdfs:comment 'Classification of the supplier based on the type of goods or services provided. OEM (Original Equipment Manufacturer) supplies finished components, distributor resells products, raw_material provides base materials, MRO (Maintenance Repair Operations) supplies consumables, subcontractor provides manufacturing services, service_provider delivers non-manufacturing services.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line2' ;
    rdfs:comment 'Secondary address line for suite, building, or floor information at the supplier\'s headquarters location.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountry rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country' ;
    rdfs:comment 'Three-letter ISO country code for the supplier\'s headquarters location. May differ from incorporation country for multinational organizations.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationCountry rdf:type rdf:Property ;
    rdfs:label 'Incorporation Country' ;
    rdfs:comment 'Three-letter ISO country code representing the country where the supplier is legally incorporated and registered. Used for trade compliance, tax jurisdiction, and regulatory reporting.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso14001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso14001 Certified' ;
    rdfs:comment 'Indicates whether the supplier holds valid ISO 14001 Environmental Management System certification. True if certified, False if not certified or certification expired.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso45001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso45001 Certified' ;
    rdfs:comment 'Indicates whether the supplier holds valid ISO 45001 Occupational Health and Safety Management System certification. True if certified, False if not certified or certification expired.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso9001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso9001 Certified' ;
    rdfs:comment 'Indicates whether the supplier holds valid ISO 9001 Quality Management System certification. True if certified, False if not certified or certification expired.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastScorecardDate rdf:type rdf:Property ;
    rdfs:label 'Last Scorecard Date' ;
    rdfs:comment 'Date of the most recent supplier scorecard evaluation. Scorecards typically assess quality, delivery, cost, and responsiveness on a quarterly or annual basis.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minorityOwned rdf:type rdf:Property ;
    rdfs:label 'Minority Owned' ;
    rdfs:comment 'Indicates whether the supplier is certified as a minority-owned business enterprise. Used for diversity supplier programs and regulatory reporting.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Due Date' ;
    rdfs:comment 'Scheduled date for the next supplier audit based on risk rating, performance, and audit frequency policy. Used for audit planning and compliance tracking.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onTimeDeliveryRate rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Rate' ;
    rdfs:comment 'Percentage of purchase orders delivered on or before the requested delivery date over the evaluation period. Key performance indicator (KPI) for supplier scorecard and performance management. Expressed as percentage (0.00 to 100.00).' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallScorecardRating rdf:type rdf:Property ;
    rdfs:label 'Overall Scorecard Rating' ;
    rdfs:comment 'Composite supplier performance score from the most recent scorecard evaluation, typically on a scale of 0.0 to 10.0 or 0.0 to 100.0. Aggregates quality, delivery, cost, and service metrics into a single performance indicator.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredCurrency rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the supplier\'s preferred currency for invoicing and payment transactions (e.g., USD, EUR, CNY).' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityAcceptanceRate rdf:type rdf:Property ;
    rdfs:label 'Quality Acceptance Rate' ;
    rdfs:comment 'Percentage of received materials that passed incoming quality inspection without rejection or rework over the evaluation period. Key performance indicator (KPI) for supplier quality performance. Expressed as percentage (0.00 to 100.00).' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relationshipEndDate rdf:type rdf:Property ;
    rdfs:label 'Relationship End Date' ;
    rdfs:comment 'Date when the business relationship with this supplier was terminated or the vendor record was deactivated. Null for active suppliers. Used for supplier lifecycle tracking and historical analysis.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipStartDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Start Date' ;
    rdfs:comment 'Date when the business relationship with this supplier was established and the vendor record was first activated. Used for relationship tenure analysis and supplier lifecycle reporting.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapVendorNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Vendor Number' ;
    rdfs:comment 'Vendor master number from SAP S/4HANA MM (Materials Management) or SAP Ariba. This is the authoritative supplier identifier in the ERP system used for procurement transactions.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smallBusiness rdf:type rdf:Property ;
    rdfs:label 'Small Business' ;
    rdfs:comment 'Indicates whether the supplier qualifies as a small business based on revenue, employee count, or regulatory definitions. Used for small business procurement programs and compliance reporting.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierCategory rdf:type rdf:Property ;
    rdfs:label 'Supplier Category' ;
    rdfs:comment 'Strategic classification indicating the supplier\'s relationship tier and procurement priority. Strategic suppliers are critical long-term partners, preferred suppliers have favorable terms, approved suppliers meet minimum standards, conditional suppliers are under review, blocked suppliers are prohibited from new business.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierStatus rdf:type rdf:Property ;
    rdfs:label 'Supplier Status' ;
    rdfs:comment 'Current lifecycle status of the supplier relationship. Active suppliers are approved for procurement, inactive suppliers are no longer used, suspended suppliers are temporarily restricted, pending_approval suppliers are under qualification review, blocked suppliers are prohibited from new transactions.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'Full legal name of the supplier organization as registered with incorporation authorities. Used for contracts, purchase orders, and legal documentation.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:womanOwned rdf:type rdf:Property ;
    rdfs:label 'Woman Owned' ;
    rdfs:comment 'Indicates whether the supplier is certified as a woman-owned business enterprise. Used for diversity supplier programs and regulatory reporting.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:agreementId rdf:type rdf:Property ;
    rdfs:label 'Agreement Id' ;
    rdfs:comment 'System-generated unique identifier for the supplier agreement record.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the agreement (e.g., framework, quality, NDA, long-term agreement, consignment, tooling loan).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentDescription rdf:type rdf:Property ;
    rdfs:label 'Amendment Description' ;
    rdfs:comment 'Narrative description of changes introduced by the amendment.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalTermMonths rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Term Months' ;
    rdfs:comment 'Length of each renewal period in months when auto-renewal is enabled.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commodityScope rdf:type rdf:Property ;
    rdfs:label 'Commodity Scope' ;
    rdfs:comment 'List or description of product categories, parts, or services covered by the agreement.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractualTermMonths rdf:type rdf:Property ;
    rdfs:label 'Contractual Term Months' ;
    rdfs:comment 'Original length of the agreement in months, excluding renewals.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discountTerms rdf:type rdf:Property ;
    rdfs:label 'Discount Terms' ;
    rdfs:comment 'Conditions under which discounts apply (e.g., volume rebates, early-pay discounts).' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Esg Compliance Flag' ;
    rdfs:comment 'Indicates whether the agreement includes ESG (environmental, social, governance) compliance requirements.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipProtectionClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Ip Protection Clause Flag' ;
    rdfs:comment 'Indicates whether intellectual-property protection terms are present.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceKpiSummary rdf:type rdf:Property ;
    rdfs:label 'Performance Kpi Summary' ;
    rdfs:comment 'Key performance indicators and targets defined in the agreement (e.g., OEE, delivery reliability).' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceIndex rdf:type rdf:Property ;
    rdfs:label 'Price Index' ;
    rdfs:comment 'Reference to any price index or formula used to adjust pricing over time.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityExpectationsSummary rdf:type rdf:Property ;
    rdfs:label 'Quality Expectations Summary' ;
    rdfs:comment 'High-level description of quality standards and metrics required from the supplier.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Period Days' ;
    rdfs:comment 'Number of days prior to expiry that a renewal notice must be issued.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:terminationNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Period Days' ;
    rdfs:comment 'Number of days required to give notice before terminating the agreement.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportDocumentId rdf:type rdf:Property ;
    rdfs:label 'Report Document Id' ;
    rdfs:comment 'Reference identifier or document management system link to the formal audit report document.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControlledDocument .

ind:auditorComments rdf:type rdf:Property ;
    rdfs:label 'Auditor Comments' ;
    rdfs:comment 'Free-text comments and observations from the lead auditor summarizing key findings, strengths, and areas for improvement.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Capa Completion Date' ;
    rdfs:comment 'Actual date when all required corrective and preventive actions were verified as complete and closed.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationStandard rdf:type rdf:Property ;
    rdfs:label 'Certification Standard' ;
    rdfs:comment 'The specific certification standard or framework being audited against, such as ISO 9001, IATF 16949, ISO 14001, ISO 45001, IEC 62443, or other industry-specific standards.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpAuditDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Date' ;
    rdfs:comment 'Scheduled or actual date of the follow-up audit conducted to verify corrective action effectiveness.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpAuditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Required Flag' ;
    rdfs:comment 'Boolean indicator whether a follow-up audit is required to verify implementation and effectiveness of corrective actions.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:frequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Frequency Months' ;
    rdfs:comment 'Standard audit frequency interval in months for this supplier based on risk classification and business requirements (e.g., 12, 24, 36 months).' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:majorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Major Findings Count' ;
    rdfs:comment 'Number of major non-conformances or findings identified during the audit that represent significant deviations from standards or requirements.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Minor Findings Count' ;
    rdfs:comment 'Number of minor non-conformances or findings identified during the audit that represent isolated or low-impact deviations from standards.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskRatingPostAudit rdf:type rdf:Property ;
    rdfs:label 'Risk Rating Post Audit' ;
    rdfs:comment 'Updated supplier risk rating assigned after the audit based on audit findings and overall performance evaluation.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRatingPreAudit rdf:type rdf:Property ;
    rdfs:label 'Risk Rating Pre Audit' ;
    rdfs:comment 'Supplier risk rating assigned before the audit based on historical performance, criticality, and risk assessment criteria.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierResponse rdf:type rdf:Property ;
    rdfs:label 'Supplier Response' ;
    rdfs:comment 'Free-text response or feedback from the supplier regarding the audit findings and proposed corrective actions.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Total Findings Count' ;
    rdfs:comment 'Total number of all findings (critical, major, minor) identified during the audit, excluding observations.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierAuditFindingId rdf:type rdf:Property ;
    rdfs:label 'Supplier Audit Finding Id' ;
    rdfs:comment 'Unique identifier for the supplier audit finding record. Primary key.' ;
    rdfs:domain ind:SupplierAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousFindingSupplierAuditFindingId rdf:type rdf:Property ;
    rdfs:label 'Previous Finding Supplier Audit Finding Id' ;
    rdfs:comment 'Reference to the previous finding record if this is identified as a repeat finding.' ;
    rdfs:domain ind:SupplierAuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierAuditFinding .

ind:clauseReference rdf:type rdf:Property ;
    rdfs:label 'Clause Reference' ;
    rdfs:comment 'Reference to the specific standard clause, requirement, or specification section that was not met (e.g., ISO 9001:2015 Clause 8.5.1, customer specification section 4.2).' ;
    rdfs:domain ind:SupplierAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingDescription rdf:type rdf:Property ;
    rdfs:label 'Finding Description' ;
    rdfs:comment 'Detailed narrative description of the non-conformance or observation, including objective evidence and specific details of what was found during the audit.' ;
    rdfs:domain ind:SupplierAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingNumber rdf:type rdf:Property ;
    rdfs:label 'Finding Number' ;
    rdfs:comment 'Externally visible unique reference number assigned to this finding for tracking and communication purposes.' ;
    rdfs:domain ind:SupplierAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingStatus rdf:type rdf:Property ;
    rdfs:label 'Finding Status' ;
    rdfs:comment 'Current state of the finding in its resolution lifecycle from identification through closure.' ;
    rdfs:domain ind:SupplierAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identified Date' ;
    rdfs:comment 'Date when the finding was first identified during the audit activity.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:repeatFindingFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Finding Flag' ;
    rdfs:comment 'Indicates whether this finding is a repeat of a previously identified issue from a prior audit, suggesting ineffective corrective action or systemic problem.' ;
    rdfs:domain ind:SupplierAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleParty rdf:type rdf:Property ;
    rdfs:label 'Responsible Party' ;
    rdfs:comment 'Name or identifier of the supplier personnel or department responsible for implementing the corrective action.' ;
    rdfs:domain ind:SupplierAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierCertificationId rdf:type rdf:Property ;
    rdfs:label 'Supplier Certification Id' ;
    rdfs:comment 'Unique identifier for the supplier certification record. Primary key for the supplier certification entity.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certifyingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Certifying Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: CERTIFICATION OVERSIGHT: Tracks which internal employee manages each supplier certification; required for compliance audit traceability.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accreditationBody rdf:type rdf:Property ;
    rdfs:label 'Accreditation Body' ;
    rdfs:comment 'The name of the accreditation body that accredits the issuing certification body. Examples include ANAB (ANSI National Accreditation Board), UKAS (United Kingdom Accreditation Service), DAkkS (German Accreditation Body), or other national accreditation authorities.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertThresholdDays rdf:type rdf:Property ;
    rdfs:label 'Alert Threshold Days' ;
    rdfs:comment 'The number of days before expiry at which automated alerts should be triggered to notify stakeholders of the upcoming certification expiration. Typical values range from 30 to 180 days.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditReportUrl rdf:type rdf:Property ;
    rdfs:label 'Audit Report Url' ;
    rdfs:comment 'The URL or file path to the most recent audit report document stored in the document management system or cloud storage.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Enabled' ;
    rdfs:comment 'Boolean flag indicating whether automatic renewal workflows and alerts are enabled for this certification. True if the system should automatically trigger renewal processes and notifications. False if renewal is managed manually.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessCriticality rdf:type rdf:Property ;
    rdfs:label 'Business Criticality' ;
    rdfs:comment 'The importance of this certification to the business relationship with the supplier. Critical certifications are mandatory for continued business. High criticality certifications are strongly preferred. Medium and low criticality certifications are informational or nice-to-have.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedProcesses rdf:type rdf:Property ;
    rdfs:label 'Certified Processes' ;
    rdfs:comment 'A comma-separated or structured list of specific manufacturing processes, production lines, or operational activities that are covered under this certification. Examples include welding, machining, assembly, testing, or packaging.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedProducts rdf:type rdf:Property ;
    rdfs:label 'Certified Products' ;
    rdfs:comment 'A comma-separated or structured list of specific product categories, product families, or SKUs (Stock Keeping Units) that are covered under this certification. Used to gate procurement decisions for regulated commodity categories.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionsRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Required' ;
    rdfs:comment 'Boolean flag indicating whether corrective actions are required to address audit findings. True if corrective actions are pending or in progress. False if no corrective actions are needed or all have been completed.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gatedCommodityCategories rdf:type rdf:Property ;
    rdfs:label 'Gated Commodity Categories' ;
    rdfs:comment 'A comma-separated list of commodity categories or material groups for which this certification is mandatory. Procurement of these commodities from this supplier is blocked if the certification is not active and valid.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBody rdf:type rdf:Property ;
    rdfs:label 'Issuing Body' ;
    rdfs:comment 'The name of the certification body, registrar, or regulatory authority that issued the certification. Examples include TUV, BSI, DNV, SGS, UL, Intertek, Bureau Veritas, LRQA, or government agencies.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Last Updated By' ;
    rdfs:comment 'The user identifier or system account that most recently modified this certification record. Audit trail field for accountability and data lineage.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorNonconformanceCount rdf:type rdf:Property ;
    rdfs:label 'Major Nonconformance Count' ;
    rdfs:comment 'The number of major non-conformances identified during the most recent audit. Major non-conformances are serious violations that can lead to certification suspension or revocation.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorNonconformanceCount rdf:type rdf:Property ;
    rdfs:label 'Minor Nonconformance Count' ;
    rdfs:comment 'The number of minor non-conformances identified during the most recent audit. Minor non-conformances are less serious violations that require corrective action but do not immediately threaten certification status.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:procurementGateEnabled rdf:type rdf:Property ;
    rdfs:label 'Procurement Gate Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this certification is used to gate procurement decisions. True if suppliers without valid certification in this standard cannot be selected for certain commodity categories. False if the certification is informational only.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scopeOfCertification rdf:type rdf:Property ;
    rdfs:label 'Scope Of Certification' ;
    rdfs:comment 'A detailed description of the scope, activities, products, services, or processes covered by this certification. Defines the boundaries and applicability of the certification within the supplier\'s operations.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationHeld rdf:type rdf:Property ;
    rdfs:label 'Certification Held' ;
    rdfs:comment 'Professional certifications or qualifications held by the contact relevant to their role (e.g., Six Sigma Black Belt, PMP, ISO Lead Auditor, APICS CPIM). Multiple certifications separated by semicolon.' ;
    rdfs:domain ind:SupplierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationPreference rdf:type rdf:Property ;
    rdfs:label 'Communication Preference' ;
    rdfs:comment 'Preferred method of communication for reaching this contact for routine supplier relationship activities.' ;
    rdfs:domain ind:SupplierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactRole rdf:type rdf:Property ;
    rdfs:label 'Contact Role' ;
    rdfs:comment 'Primary functional role of the contact in the supplier relationship. Determines routing of communications and escalations.' ;
    rdfs:domain ind:SupplierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the vendor contact. Inactive or terminated contacts should not receive communications.' ;
    rdfs:domain ind:SupplierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Interaction Frequency Days' ;
    rdfs:comment 'Target frequency in days for regular business interactions with this contact. Used for relationship management planning and alerts.' ;
    rdfs:domain ind:SupplierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastInteractionDate rdf:type rdf:Property ;
    rdfs:label 'Last Interaction Date' ;
    rdfs:comment 'Date of the most recent business interaction or communication with this contact. Used for relationship health monitoring.' ;
    rdfs:domain ind:SupplierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:linkedinProfileUrl rdf:type rdf:Property ;
    rdfs:label 'Linkedin Profile Url' ;
    rdfs:comment 'URL to the contacts LinkedIn professional profile. Used for relationship intelligence and network mapping.' ;
    rdfs:domain ind:SupplierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeLocation rdf:type rdf:Property ;
    rdfs:label 'Office Location' ;
    rdfs:comment 'Physical office location or site where the contact is based (e.g., headquarters, regional office, manufacturing plant).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'ISO 639-2 three-letter language code representing the contacts preferred language for business communications (e.g., ENG, DEU, FRA, SPA, CHI, JPN).' ;
    rdfs:domain ind:SupplierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStrengthScore rdf:type rdf:Property ;
    rdfs:label 'Relationship Strength Score' ;
    rdfs:comment 'Quantitative score (0-100) representing the strength and quality of the business relationship with this contact. Based on interaction frequency, responsiveness, collaboration quality, and business outcomes.' ;
    rdfs:domain ind:SupplierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specializationArea rdf:type rdf:Property ;
    rdfs:label 'Specialization Area' ;
    rdfs:comment 'Specific area of expertise or specialization for the contact (e.g., electrification products, automation systems, quality management, supply chain logistics, contract negotiation).' ;
    rdfs:domain ind:SupplierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierOnboardingId rdf:type rdf:Property ;
    rdfs:label 'Supplier Onboarding Id' ;
    rdfs:comment 'Unique identifier for the supplier onboarding record. Primary key for tracking the end-to-end onboarding workflow from initial registration through final approval.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockingIssueDescription rdf:type rdf:Property ;
    rdfs:label 'Blocking Issue Description' ;
    rdfs:comment 'Detailed description of any blocking issues, missing documents, compliance gaps, or other obstacles preventing onboarding completion.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingIssueFlag rdf:type rdf:Property ;
    rdfs:label 'Blocking Issue Flag' ;
    rdfs:comment 'Indicates whether there are currently blocking issues preventing onboarding progress. True if issues exist, false otherwise.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockingIssueOwner rdf:type rdf:Property ;
    rdfs:label 'Blocking Issue Owner' ;
    rdfs:comment 'Name or role of the person or team responsible for resolving the current blocking issue.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleTimeDays rdf:type rdf:Property ;
    rdfs:label 'Cycle Time Days' ;
    rdfs:comment 'Total number of calendar days from request date to actual completion date. Key performance indicator (KPI) for onboarding efficiency.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentCollectionCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Document Collection Completed Date' ;
    rdfs:comment 'Date when all required documents (certificates, insurance, tax forms, bank details) were received and validated.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedAnnualSpend rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Spend' ;
    rdfs:comment 'Projected annual purchase value with this supplier. Used to prioritize onboarding resources and determine approval authority levels.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Final Approval Date' ;
    rdfs:comment 'Date when the supplier onboarding was granted final approval and the supplier became active for purchasing.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialReviewCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Financial Review Completed Date' ;
    rdfs:comment 'Date when finance department completed credit assessment, payment terms setup, and financial risk evaluation.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:itSetupCompletedDate rdf:type rdf:Property ;
    rdfs:label 'It Setup Completed Date' ;
    rdfs:comment 'Date when IT department completed system configuration, vendor master creation in ERP (Enterprise Resource Planning), and EDI (Electronic Data Interchange) or portal access setup.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalReviewCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Legal Review Completed Date' ;
    rdfs:comment 'Date when legal department completed contract review, terms negotiation, and compliance verification.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingType rdf:type rdf:Property ;
    rdfs:label 'Onboarding Type' ;
    rdfs:comment 'Classification of the onboarding request: new vendor (first-time supplier), new site (existing supplier adding location), new commodity (existing supplier expanding product categories), vendor reactivation (previously inactive supplier), or vendor update (major profile changes requiring re-approval).' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationReviewCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Review Completed Date' ;
    rdfs:comment 'Date when procurement and quality teams completed technical and operational qualification assessment.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityAuditCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Quality Audit Completed Date' ;
    rdfs:comment 'Date when the required quality audit was completed. Null if no audit is required or if audit is pending.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityAuditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Audit Required Flag' ;
    rdfs:comment 'Indicates whether an on-site or remote quality audit is required before final approval. True for high-risk or critical suppliers.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityAuditResult rdf:type rdf:Property ;
    rdfs:label 'Quality Audit Result' ;
    rdfs:comment 'Outcome of the quality audit. Passed allows immediate approval, passed with conditions requires corrective actions, failed blocks onboarding.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Registration Completed Date' ;
    rdfs:comment 'Date when the supplier completed initial registration and profile setup in the supplier portal.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestorEmail rdf:type rdf:Property ;
    rdfs:label 'Requestor Email' ;
    rdfs:comment 'Email address of the employee who initiated the onboarding request. Used for workflow notifications and status updates.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Spend Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated annual spend amount.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorMasterNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Master Number' ;
    rdfs:comment 'Unique vendor identifier assigned in SAP S/4HANA upon successful onboarding. Links the onboarding record to the operational vendor master.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowStage rdf:type rdf:Property ;
    rdfs:label 'Workflow Stage' ;
    rdfs:comment 'Current stage in the onboarding workflow sequence: registration, document collection, qualification review, legal review, financial review, IT system setup, or final approval. Provides granular visibility into onboarding progress.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteId rdf:type rdf:Property ;
    rdfs:label 'Site Id' ;
    rdfs:comment 'Primary key for site' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedForNewBusiness rdf:type rdf:Property ;
    rdfs:label 'Approved For New Business' ;
    rdfs:comment 'Indicates whether the vendor site is approved to receive new purchase orders and sourcing awards.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryPerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Delivery Performance Score' ;
    rdfs:comment 'On-time delivery performance score for the vendor site. Scale 0-100.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iatf16949Certified rdf:type rdf:Property ;
    rdfs:label 'Iatf 16949 Certified' ;
    rdfs:comment 'Indicates whether the vendor site holds IATF 16949 automotive quality management certification. Required for automotive supply chain participation.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso14001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Certified' ;
    rdfs:comment 'Indicates whether the vendor site holds ISO 14001 Environmental Management System certification.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso45001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 45001 Certified' ;
    rdfs:comment 'Indicates whether the vendor site holds ISO 45001 Occupational Health and Safety Management System certification.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso9001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Certified' ;
    rdfs:comment 'Indicates whether the vendor site holds ISO 9001 Quality Management System certification. Critical for supplier qualification.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionCapacityAnnual rdf:type rdf:Property ;
    rdfs:label 'Production Capacity Annual' ;
    rdfs:comment 'Annual production capacity of the site in units relevant to the site type. Used for capacity planning and sourcing allocation decisions.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toolingAssetId rdf:type rdf:Property ;
    rdfs:label 'Tooling Asset Id' ;
    rdfs:comment 'Unique identifier for the tooling asset record. Primary key for the tooling asset entity.' ;
    rdfs:domain ind:ToolingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryToolingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Tooling Employee Id' ;
    rdfs:comment 'Identifier of the manufacturing engineer responsible for managing and tracking the tooling asset.' ;
    rdfs:domain ind:ToolingAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acquisitionCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the acquisition cost amount.' ;
    rdfs:domain ind:ToolingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookValueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Book Value Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the current book value amount.' ;
    rdfs:domain ind:ToolingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalityRating rdf:type rdf:Property ;
    rdfs:label 'Criticality Rating' ;
    rdfs:comment 'Business criticality assessment of the tooling asset based on its impact to production continuity and revenue.' ;
    rdfs:domain ind:ToolingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentBookValue rdf:type rdf:Property ;
    rdfs:label 'Current Book Value' ;
    rdfs:comment 'Current accounting book value of the tooling asset after depreciation and impairment adjustments.' ;
    rdfs:domain ind:ToolingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Inspection Frequency Months' ;
    rdfs:comment 'Required frequency in months between scheduled inspections of the tooling asset.' ;
    rdfs:domain ind:ToolingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:insuranceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Required Flag' ;
    rdfs:comment 'Indicator whether the tooling asset requires insurance coverage due to its value or criticality.' ;
    rdfs:domain ind:ToolingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownershipConfirmationFlag rdf:type rdf:Property ;
    rdfs:label 'Ownership Confirmation Flag' ;
    rdfs:comment 'Indicator whether ownership of the tooling asset has been formally confirmed and documented with the supplier.' ;
    rdfs:domain ind:ToolingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownershipStatus rdf:type rdf:Property ;
    rdfs:label 'Ownership Status' ;
    rdfs:comment 'Legal ownership classification of the tooling asset indicating which party holds title and responsibility.' ;
    rdfs:domain ind:ToolingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementDate rdf:type rdf:Property ;
    rdfs:label 'Placement Date' ;
    rdfs:comment 'Date when the tooling asset was physically placed at the current supplier site location.' ;
    rdfs:domain ind:ToolingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratedCycleCapacity rdf:type rdf:Property ;
    rdfs:label 'Rated Cycle Capacity' ;
    rdfs:comment 'Maximum number of production cycles or shots the tooling asset is designed to perform before requiring major refurbishment or replacement.' ;
    rdfs:domain ind:ToolingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recoveryPriority rdf:type rdf:Property ;
    rdfs:label 'Recovery Priority' ;
    rdfs:comment 'Priority level assigned for recovery or retrieval of the tooling asset during supplier transitions or disqualifications.' ;
    rdfs:domain ind:ToolingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingCycleCapacity rdf:type rdf:Property ;
    rdfs:label 'Remaining Cycle Capacity' ;
    rdfs:comment 'Estimated number of production cycles remaining before the tooling asset reaches its rated capacity limit.' ;
    rdfs:domain ind:ToolingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfidTagCode rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag Code' ;
    rdfs:comment 'Unique identifier of the RFID tag attached to the tooling asset for automated tracking and location monitoring.' ;
    rdfs:domain ind:ToolingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolDescription rdf:type rdf:Property ;
    rdfs:label 'Tool Description' ;
    rdfs:comment 'Detailed textual description of the tooling asset including specifications, dimensions, and functional characteristics.' ;
    rdfs:domain ind:ToolingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolLocationDescription rdf:type rdf:Property ;
    rdfs:label 'Tool Location Description' ;
    rdfs:comment 'Detailed description of the physical location of the tooling asset within the supplier site including building, area, or cell designation.' ;
    rdfs:domain ind:ToolingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolNumber rdf:type rdf:Property ;
    rdfs:label 'Tool Number' ;
    rdfs:comment 'Unique business identifier assigned to the tooling asset for tracking and reference purposes.' ;
    rdfs:domain ind:ToolingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolStatus rdf:type rdf:Property ;
    rdfs:label 'Tool Status' ;
    rdfs:comment 'Current lifecycle status of the tooling asset indicating its availability and operational state.' ;
    rdfs:domain ind:ToolingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolType rdf:type rdf:Property ;
    rdfs:label 'Tool Type' ;
    rdfs:comment 'Classification of the tooling asset by its functional purpose in the manufacturing process. [ENUM-REF-CANDIDATE: die|fixture|gauge|mold|jig|cutting_tool|forming_tool|inspection_tool — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ToolingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalProductionCycles rdf:type rdf:Property ;
    rdfs:label 'Total Production Cycles' ;
    rdfs:comment 'Cumulative count of production cycles or shots the tooling asset has completed since acquisition.' ;
    rdfs:domain ind:ToolingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationId rdf:type rdf:Property ;
    rdfs:label 'Allocation Id' ;
    rdfs:comment 'Primary key for allocation' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocated Quantity' ;
    rdfs:comment 'Quantity of material allocated to the recipient entity (customer, plant, distribution center, or product line).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Number' ;
    rdfs:comment 'Business-facing unique allocation identifier used for tracking and reference in supply chain communications.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableSupplyQuantity rdf:type rdf:Property ;
    rdfs:label 'Available Supply Quantity' ;
    rdfs:comment 'Total constrained supply quantity available for allocation across all competing demand requests.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:communicationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Communication Sent Flag' ;
    rdfs:comment 'Indicates whether allocation notification has been sent to the affected customer or recipient entity.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:communicationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Communication Sent Timestamp' ;
    rdfs:comment 'Date and time when allocation notification was sent to the recipient.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:constraintDescription rdf:type rdf:Property ;
    rdfs:label 'Constraint Description' ;
    rdfs:comment 'Detailed narrative explanation of the supply constraint circumstances, including supplier names, affected components, and expected resolution timeline.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintReasonCode rdf:type rdf:Property ;
    rdfs:label 'Constraint Reason Code' ;
    rdfs:comment 'Standardized code identifying the root cause of the supply constraint that necessitated this allocation decision.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractualCommitmentFlag rdf:type rdf:Property ;
    rdfs:label 'Contractual Commitment Flag' ;
    rdfs:comment 'Indicates whether this allocation fulfills a contractual supply commitment or service level agreement (SLA) obligation.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerTier rdf:type rdf:Property ;
    rdfs:label 'Customer Tier' ;
    rdfs:comment 'Customer segmentation tier used in priority-based or customer-tier allocation methods to determine allocation preference.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decision Timestamp' ;
    rdfs:comment 'Date and time when the allocation decision was made by the supply planning team or automated allocation engine.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expectedResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Expected Resolution Date' ;
    rdfs:comment 'Anticipated date when the supply constraint will be resolved and normal supply levels restored.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fulfillmentPercentage rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Percentage' ;
    rdfs:comment 'Percentage of requested quantity that was allocated, calculated as (allocated_quantity / requested_quantity) * 100.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productLineCode rdf:type rdf:Property ;
    rdfs:label 'Product Line Code' ;
    rdfs:comment 'Code identifying the product line receiving the allocation when allocation_recipient_type is product_line.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientDistributionCenterCode rdf:type rdf:Property ;
    rdfs:label 'Recipient Distribution Center Code' ;
    rdfs:comment 'Code identifying the regional distribution center receiving the allocation when allocation_recipient_type is distribution_center.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientPlantCode rdf:type rdf:Property ;
    rdfs:label 'Recipient Plant Code' ;
    rdfs:comment 'Four-character code identifying the recipient plant when allocation_recipient_type is plant.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientType rdf:type rdf:Property ;
    rdfs:label 'Recipient Type' ;
    rdfs:comment 'Type of entity receiving the allocated supply, used to determine the appropriate recipient identifier field.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apsScheduleId rdf:type rdf:Property ;
    rdfs:label 'Aps Schedule Id' ;
    rdfs:comment 'Unique identifier for the APS schedule record. Primary key for the schedule entry generated by the APS engine.' ;
    rdfs:domain ind:ApsSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:schedulingRunId rdf:type rdf:Property ;
    rdfs:label 'Scheduling Run Id' ;
    rdfs:comment 'Reference to the APS scheduling run that generated this schedule entry. Links to the planning execution batch for traceability.' ;
    rdfs:domain ind:ApsSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Run .

ind:capacityUtilizationPercent rdf:type rdf:Property ;
    rdfs:label 'Capacity Utilization Percent' ;
    rdfs:comment 'Percentage of work center capacity consumed by this scheduled operation during its time window. Used for capacity planning analysis.' ;
    rdfs:domain ind:ApsSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:constraintType rdf:type rdf:Property ;
    rdfs:label 'Constraint Type' ;
    rdfs:comment 'Primary constraint that limited the scheduling of this operation. Identifies the bottleneck resource or dependency.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalPathFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Path Flag' ;
    rdfs:comment 'Indicates whether this operation is on the critical path for the production order. True if any delay will impact the order completion date.' ;
    rdfs:domain ind:ApsSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:earliestStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Earliest Start Timestamp' ;
    rdfs:comment 'Earliest permissible start time for this operation based on material availability, predecessor operations, and business constraints.' ;
    rdfs:domain ind:ApsSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fixedScheduleFlag rdf:type rdf:Property ;
    rdfs:label 'Fixed Schedule Flag' ;
    rdfs:comment 'Indicates whether this schedule entry is locked and cannot be rescheduled by subsequent APS runs. True if fixed, false if flexible.' ;
    rdfs:domain ind:ApsSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latestEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Latest End Timestamp' ;
    rdfs:comment 'Latest permissible completion time for this operation to meet downstream commitments and customer delivery dates.' ;
    rdfs:domain ind:ApsSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:machineCode rdf:type rdf:Property ;
    rdfs:label 'Machine Code' ;
    rdfs:comment 'Reference to the specific machine or equipment unit assigned to execute this operation. Links to the equipment register in asset management.' ;
    rdfs:domain ind:ApsSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overlapAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Overlap Allowed Flag' ;
    rdfs:comment 'Indicates whether this operation can overlap with subsequent operations in the routing. True if overlap is permitted, false if sequential execution is required.' ;
    rdfs:domain ind:ApsSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planningHorizonDate rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Date' ;
    rdfs:comment 'The planning horizon end date for the APS run that created this schedule. Defines the time boundary of the scheduling optimization.' ;
    rdfs:domain ind:ApsSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:queueTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Queue Time Minutes' ;
    rdfs:comment 'Planned waiting time before the operation can start due to work center queue or resource availability constraints, measured in minutes.' ;
    rdfs:domain ind:ApsSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releasedToMesFlag rdf:type rdf:Property ;
    rdfs:label 'Released To Mes Flag' ;
    rdfs:comment 'Indicates whether this schedule has been released to the MES for shop floor execution. True if released, false if still in planning state.' ;
    rdfs:domain ind:ApsSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releasedToMesTimestamp rdf:type rdf:Property ;
    rdfs:label 'Released To Mes Timestamp' ;
    rdfs:comment 'Date and time when this schedule was released to the MES system for execution. Marks the transition from planning to execution.' ;
    rdfs:domain ind:ApsSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Run Time Minutes' ;
    rdfs:comment 'Planned production run time for this operation, measured in minutes. Represents the active processing time excluding setup and teardown.' ;
    rdfs:domain ind:ApsSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:schedulingMethod rdf:type rdf:Property ;
    rdfs:label 'Scheduling Method' ;
    rdfs:comment 'Scheduling algorithm method used by APS to generate this schedule entry (forward scheduling, backward scheduling, finite capacity, infinite capacity).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schedulingNotes rdf:type rdf:Property ;
    rdfs:label 'Scheduling Notes' ;
    rdfs:comment 'Free-text notes or comments related to this schedule entry. May include special instructions, constraint explanations, or planner annotations.' ;
    rdfs:domain ind:ApsSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slackTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Slack Time Minutes' ;
    rdfs:comment 'Available buffer time between the scheduled end and the latest permissible end, measured in minutes. Indicates scheduling flexibility.' ;
    rdfs:domain ind:ApsSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:splitAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Split Allowed Flag' ;
    rdfs:comment 'Indicates whether this operation can be split across multiple work centers or time slots. True if splitting is permitted, false if operation must be continuous.' ;
    rdfs:domain ind:ApsSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:teardownTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Teardown Time Minutes' ;
    rdfs:comment 'Planned teardown or cleanup time after operation completion, measured in minutes. Includes tooling removal and work center cleanup.' ;
    rdfs:domain ind:ApsSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apsScenarioId rdf:type rdf:Property ;
    rdfs:label 'Aps Scenario Id' ;
    rdfs:comment 'Identifier of the APS scenario or simulation run that generated this capacity plan. Links to Siemens Opcenter APS or Microsoft Dynamics 365 SCM planning scenarios.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApsScenario .

ind:availableCapacityHours rdf:type rdf:Property ;
    rdfs:label 'Available Capacity Hours' ;
    rdfs:comment 'Total available capacity in hours for the work center during the planning period. Calculated based on shifts, calendar days, and resource availability.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityBufferHours rdf:type rdf:Property ;
    rdfs:label 'Capacity Buffer Hours' ;
    rdfs:comment 'Safety buffer or protective capacity reserved to absorb variability and prevent schedule disruptions. Part of Theory of Constraints buffer management.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityLoadProfile rdf:type rdf:Property ;
    rdfs:label 'Capacity Load Profile' ;
    rdfs:comment 'Pattern of capacity demand over the planning period. Indicates whether load is evenly distributed, concentrated in peaks, or highly variable.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacitySourceSystem rdf:type rdf:Property ;
    rdfs:label 'Capacity Source System' ;
    rdfs:comment 'Source system that generated the capacity plan data. Typically SAP PP, Siemens Opcenter APS, or Microsoft Dynamics 365 SCM.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUnit rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit' ;
    rdfs:comment 'Unit of measure for capacity planning. Typically hours for time-based capacity or units/pieces for output-based capacity.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUtilizationRate rdf:type rdf:Property ;
    rdfs:label 'Capacity Utilization Rate' ;
    rdfs:comment 'Percentage of available capacity that is utilized by required capacity. Calculated as (required_capacity_hours / available_capacity_hours) * 100. Key metric for identifying overload or underutilization.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalRatio rdf:type rdf:Property ;
    rdfs:label 'Critical Ratio' ;
    rdfs:comment 'Ratio of time remaining until due date to work time remaining. Used for priority scheduling and capacity allocation. Values less than 1.0 indicate behind schedule.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:efficiencyRate rdf:type rdf:Property ;
    rdfs:label 'Efficiency Rate' ;
    rdfs:comment 'Efficiency factor applied to available capacity to account for actual performance versus standard. Expressed as percentage. Used to adjust theoretical capacity to realistic capacity.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBottleneck rdf:type rdf:Property ;
    rdfs:label 'Is Bottleneck' ;
    rdfs:comment 'Boolean flag indicating whether this work center is identified as a bottleneck constraint in the production schedule. True if utilization exceeds threshold or if this resource limits throughput.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMrpRunDate rdf:type rdf:Property ;
    rdfs:label 'Last Mrp Run Date' ;
    rdfs:comment 'Date of the last MRP or MRP II run that generated the required capacity data for this plan. Indicates data freshness.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:levelingAdjustmentHours rdf:type rdf:Property ;
    rdfs:label 'Leveling Adjustment Hours' ;
    rdfs:comment 'Capacity adjustment applied through leveling actions such as overtime, shift changes, subcontracting, or order rescheduling to balance load.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:levelingStrategy rdf:type rdf:Property ;
    rdfs:label 'Leveling Strategy' ;
    rdfs:comment 'Strategy applied to resolve capacity overload. Indicates the method used to balance capacity constraints.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overloadHours rdf:type rdf:Property ;
    rdfs:label 'Overload Hours' ;
    rdfs:comment 'Number of hours by which required capacity exceeds available capacity. Positive value indicates capacity shortage requiring leveling or additional resources.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Plan Created Timestamp' ;
    rdfs:comment 'Timestamp when the capacity plan record was created in the system.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:planUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Plan Updated Timestamp' ;
    rdfs:comment 'Timestamp when the capacity plan record was last updated or recalculated.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedDowntimeHours rdf:type rdf:Property ;
    rdfs:label 'Planned Downtime Hours' ;
    rdfs:comment 'Hours of planned maintenance, changeovers, or scheduled downtime that reduce available capacity during the planning period.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningHorizon rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon' ;
    rdfs:comment 'Time granularity of the capacity plan. Indicates whether this is a short-term, medium-term, or long-term capacity plan.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period End Date' ;
    rdfs:comment 'End date of the capacity planning period. Defines the end of the time bucket for capacity analysis.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period Start Date' ;
    rdfs:comment 'Start date of the capacity planning period. Defines the beginning of the time bucket for capacity analysis.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningVersion rdf:type rdf:Property ;
    rdfs:label 'Planning Version' ;
    rdfs:comment 'Version identifier for the capacity plan. Supports scenario planning and what-if analysis by maintaining multiple plan versions.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queueTimeHours rdf:type rdf:Property ;
    rdfs:label 'Queue Time Hours' ;
    rdfs:comment 'Average queue time or wait time for jobs at this work center during the planning period. Indicates congestion and scheduling delays.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredCapacityHours rdf:type rdf:Property ;
    rdfs:label 'Required Capacity Hours' ;
    rdfs:comment 'Total required capacity in hours derived from planned orders, production orders, and demand forecasts for the planning period.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resourceType rdf:type rdf:Property ;
    rdfs:label 'Resource Type' ;
    rdfs:comment 'Type of production resource being planned. Distinguishes between machine capacity, labor capacity, tooling, or other equipment.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftCount rdf:type rdf:Property ;
    rdfs:label 'Shift Count' ;
    rdfs:comment 'Number of production shifts scheduled for the work center during the planning period. Used to calculate available capacity.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shiftHoursPerDay rdf:type rdf:Property ;
    rdfs:label 'Shift Hours Per Day' ;
    rdfs:comment 'Total productive hours per day across all shifts. Excludes breaks and non-productive time.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:underloadHours rdf:type rdf:Property ;
    rdfs:label 'Underload Hours' ;
    rdfs:comment 'Number of hours by which available capacity exceeds required capacity. Positive value indicates spare capacity available for additional orders or maintenance.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unplannedDowntimeHours rdf:type rdf:Property ;
    rdfs:label 'Unplanned Downtime Hours' ;
    rdfs:comment 'Estimated or historical hours of unplanned downtime (breakdowns, failures) factored into capacity planning to provide realistic capacity estimates.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandPlanVersionId rdf:type rdf:Property ;
    rdfs:label 'Demand Plan Version Id' ;
    rdfs:comment 'Reference to the forecast version record enabling scenario comparison and version lineage tracking.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemandPlanVersion .

ind:salesForecastId rdf:type rdf:Property ;
    rdfs:label 'Sales Forecast Id' ;
    rdfs:comment 'Foreign key linking to sales.forecast. Business justification: Demand forecasting aligns internal plans with external sales forecasts; linking enables S&OP reconciliation.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Forecast .

ind:biasPercent rdf:type rdf:Property ;
    rdfs:label 'Bias Percent' ;
    rdfs:comment 'Systematic forecast bias expressed as percentage, indicating tendency to over-forecast (positive) or under-forecast (negative). Used to detect and correct systematic errors.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceIntervalLower rdf:type rdf:Property ;
    rdfs:label 'Confidence Interval Lower' ;
    rdfs:comment 'Lower bound of the forecast confidence interval, representing the pessimistic demand scenario for risk analysis and safety stock planning.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceIntervalUpper rdf:type rdf:Property ;
    rdfs:label 'Confidence Interval Upper' ;
    rdfs:comment 'Upper bound of the forecast confidence interval, representing the optimistic demand scenario for capacity planning and supply risk assessment.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceLevelPercent rdf:type rdf:Property ;
    rdfs:label 'Confidence Level Percent' ;
    rdfs:comment 'Statistical confidence level of the forecast interval expressed as a percentage (e.g., 95.00 for 95% confidence). Used for supply planning sensitivity analysis.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consensusApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Consensus Approval Date' ;
    rdfs:comment 'Date when the forecast achieved consensus approval in the Sales and Operations Planning (S&OP) process, marking it as the agreed demand plan.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Customer Segment Code' ;
    rdfs:comment 'Code identifying the customer segment or channel for which this forecast applies (e.g., OEM, AFTERMARKET, DISTRIBUTOR). Enables segment-level demand planning.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandClass rdf:type rdf:Property ;
    rdfs:label 'Demand Class' ;
    rdfs:comment 'Classification of demand type: independent (end-customer driven, forecasted) or dependent (derived from BOM and parent item demand via MRP explosion).' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandPattern rdf:type rdf:Property ;
    rdfs:label 'Demand Pattern' ;
    rdfs:comment 'Characterization of the historical demand behavior pattern used to select appropriate forecasting models and safety stock strategies.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastAccuracyPercent rdf:type rdf:Property ;
    rdfs:label 'Forecast Accuracy Percent' ;
    rdfs:comment 'Historical accuracy percentage of the forecast model for this material-location combination, calculated as (1 - MAPE) * 100. Used for model selection and tuning.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastConsumptionFlag rdf:type rdf:Property ;
    rdfs:label 'Forecast Consumption Flag' ;
    rdfs:comment 'Indicates whether this forecast is subject to consumption by actual customer orders in the MRP logic. Controls forecast vs. order-driven planning behavior.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:forecastGenerationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Forecast Generation Timestamp' ;
    rdfs:comment 'Timestamp when the forecast was generated by the forecasting engine or planning system. Represents the business event time of forecast creation.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:forecastHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Forecast Horizon Days' ;
    rdfs:comment 'Number of days into the future that this forecast covers, calculated from the planning period start date. Used for lead time coverage analysis.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forecastModelCode rdf:type rdf:Property ;
    rdfs:label 'Forecast Model Code' ;
    rdfs:comment 'Code identifying the statistical or algorithmic model used to generate the forecast (e.g., ARIMA, EXP_SMOOTH, MOVING_AVG, ML_ENSEMBLE).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastModelName rdf:type rdf:Property ;
    rdfs:label 'Forecast Model Name' ;
    rdfs:comment 'Human-readable name of the forecasting model or algorithm applied to generate this forecast.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastQuantity rdf:type rdf:Property ;
    rdfs:label 'Forecast Quantity' ;
    rdfs:comment 'Predicted demand quantity for the material at the specified location during the planning period. Core forecast value used for MRP and capacity planning.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanAbsolutePercentageError rdf:type rdf:Property ;
    rdfs:label 'Mean Absolute Percentage Error' ;
    rdfs:comment 'MAPE metric measuring forecast error as a percentage of actual demand. Lower values indicate better forecast accuracy. Key KPI for demand planning performance.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mrpAreaCode rdf:type rdf:Property ;
    rdfs:label 'Mrp Area Code' ;
    rdfs:comment 'MRP area code defining the planning scope and organizational unit for material requirements planning execution.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outlierFlag rdf:type rdf:Property ;
    rdfs:label 'Outlier Flag' ;
    rdfs:comment 'Indicates whether this forecast was flagged as a statistical outlier requiring review. Used for data quality monitoring and exception management.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outlierReason rdf:type rdf:Property ;
    rdfs:label 'Outlier Reason' ;
    rdfs:comment 'Explanation for why this forecast was flagged as an outlier, documenting the business or statistical reason for the exception.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningGroupCode rdf:type rdf:Property ;
    rdfs:label 'Planning Group Code' ;
    rdfs:comment 'Code identifying the planning group or demand planner responsible for this forecast. Used for workload distribution and accountability.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Product Lifecycle Stage' ;
    rdfs:comment 'Current stage of the product in its lifecycle. Influences forecasting model selection and demand pattern expectations.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Flag' ;
    rdfs:comment 'Indicates whether this forecast includes promotional or campaign-driven demand uplift. Used to separate base demand from promotional spikes.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionalUpliftPercent rdf:type rdf:Property ;
    rdfs:label 'Promotional Uplift Percent' ;
    rdfs:comment 'Expected percentage increase in demand due to promotional activities during the planning period. Used for promotional planning and inventory pre-positioning.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesAdjustmentQuantity rdf:type rdf:Property ;
    rdfs:label 'Sales Adjustment Quantity' ;
    rdfs:comment 'Manual adjustment quantity applied by sales team to the statistical baseline forecast, reflecting market intelligence and customer commitments.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesAdjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Sales Adjustment Reason' ;
    rdfs:comment 'Business justification for the sales adjustment, documenting market intelligence, customer commitments, or promotional activities driving the override.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalityIndex rdf:type rdf:Property ;
    rdfs:label 'Seasonality Index' ;
    rdfs:comment 'Seasonal adjustment factor applied to the forecast for this planning period. Values above 1.0 indicate peak season, below 1.0 indicate off-season.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trendCoefficient rdf:type rdf:Property ;
    rdfs:label 'Trend Coefficient' ;
    rdfs:comment 'Trend component coefficient from the forecasting model, indicating the rate of demand growth or decline over time.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandPlanId rdf:type rdf:Property ;
    rdfs:label 'Demand Plan Id' ;
    rdfs:comment 'Reference to the parent demand plan that this version belongs to. Links to the master demand plan entity.' ;
    rdfs:domain ind:DemandPlanVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:primaryDemandEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Demand Employee Id' ;
    rdfs:comment 'Reference to the user who granted final approval for this demand plan version. Links to the user or employee master for audit trail and accountability in the S&OP approval workflow.' ;
    rdfs:domain ind:DemandPlanVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededByVersionDemandPlanVersionId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Version Demand Plan Version Id' ;
    rdfs:comment 'Reference to the newer demand plan version that replaces this version. Null if this is the current active version. Maintains version lineage and audit trail for plan evolution tracking.' ;
    rdfs:domain ind:DemandPlanVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemandPlanVersion .

ind:tertiaryDemandLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Demand Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who most recently modified this demand plan version record. Links to the user or employee master for change tracking and accountability.' ;
    rdfs:domain ind:DemandPlanVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvedFlag rdf:type rdf:Property ;
    rdfs:label 'Approved Flag' ;
    rdfs:comment 'Indicates whether this demand plan version has received formal approval through the S&OP governance process. True if approved for execution, false if still in draft or review.' ;
    rdfs:domain ind:DemandPlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baselineVersionFlag rdf:type rdf:Property ;
    rdfs:label 'Baseline Version Flag' ;
    rdfs:comment 'Indicates whether this version serves as the baseline reference for variance analysis and scenario comparison. True if this is the authoritative baseline, false for alternative scenarios or working versions.' ;
    rdfs:domain ind:DemandPlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:biasPercentage rdf:type rdf:Property ;
    rdfs:label 'Bias Percentage' ;
    rdfs:comment 'Systematic tendency of this demand plan version to over-forecast (positive bias) or under-forecast (negative bias) actual demand. Calculated as the sum of forecast errors divided by sum of actuals, used to detect and correct persistent forecasting errors.' ;
    rdfs:domain ind:DemandPlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceLevelPercentage rdf:type rdf:Property ;
    rdfs:label 'Confidence Level Percentage' ;
    rdfs:comment 'Statistical confidence level associated with the demand forecast in this version. Represents the probability that actual demand will fall within the forecasted range, typically 80%, 90%, or 95% confidence intervals used for safety stock calculations.' ;
    rdfs:domain ind:DemandPlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandTimeFenceDays rdf:type rdf:Property ;
    rdfs:label 'Demand Time Fence Days' ;
    rdfs:comment 'Number of days from the current date within which demand changes are frozen or restricted. Defines the period where MRP (Material Requirements Planning) will not automatically adjust planned orders based on forecast changes, protecting near-term production stability.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forecastAccuracyPercentage rdf:type rdf:Property ;
    rdfs:label 'Forecast Accuracy Percentage' ;
    rdfs:comment 'Measured accuracy of this demand plan version compared to actual demand realization. Calculated as 100 minus the Mean Absolute Percentage Error (MAPE), used for continuous improvement of forecasting methods and model selection.' ;
    rdfs:domain ind:DemandPlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Days' ;
    rdfs:comment 'Total number of calendar days covered by this demand plan version. Calculated as the difference between planning horizon end and start dates, used for capacity planning and lead time analysis.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningHorizonEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon End Date' ;
    rdfs:comment 'Last date of the planning period covered by this demand plan version. Defines the end of the forecast window, typically aligned with fiscal quarters or annual planning cycles.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningHorizonStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Start Date' ;
    rdfs:comment 'First date of the planning period covered by this demand plan version. Defines the beginning of the forecast window for supply planning and MRP (Material Requirements Planning) execution.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningMethod rdf:type rdf:Property ;
    rdfs:label 'Planning Method' ;
    rdfs:comment 'Methodology used to generate this demand plan version. Statistical uses algorithmic forecasting, collaborative incorporates cross-functional input, consensus reflects S&OP agreement, APS (Advanced Planning and Scheduling) uses optimization engines, and manual indicates planner-driven creation.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningTimeFenceDays rdf:type rdf:Property ;
    rdfs:label 'Planning Time Fence Days' ;
    rdfs:comment 'Number of days from the current date within which supply planning changes require manual approval. Defines the period where automated MRP adjustments are restricted to prevent disruption to committed production schedules.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPlannedDemandQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Planned Demand Quantity' ;
    rdfs:comment 'Aggregate demand quantity across all materials and time buckets within this plan version. Represents the total forecasted demand volume for supply network capacity planning and scenario comparison.' ;
    rdfs:domain ind:DemandPlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:versionNotes rdf:type rdf:Property ;
    rdfs:label 'Version Notes' ;
    rdfs:comment 'Free-text commentary and business context for this demand plan version. Captures assumptions, market conditions, promotional events, supply constraints, or other factors influencing the forecast that are relevant for scenario interpretation and decision-making.' ;
    rdfs:domain ind:DemandPlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionStatus rdf:type rdf:Property ;
    rdfs:label 'Version Status' ;
    rdfs:comment 'Current lifecycle status of the demand plan version. Tracks the approval workflow state from initial draft through review, approval, and eventual archival or supersession by newer versions.' ;
    rdfs:domain ind:DemandPlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creationDate rdf:type rdf:Property ;
    rdfs:label 'Creation Date' ;
    rdfs:comment 'Date when this demand plan version was created. Represents the business event timestamp for version instantiation in the S&OP cycle.' ;
    rdfs:domain ind:DemandPlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inventoryPositionId rdf:type rdf:Property ;
    rdfs:label 'Inventory Position Id' ;
    rdfs:comment 'Unique identifier for the inventory position snapshot record.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availableToPromiseQuantity rdf:type rdf:Property ;
    rdfs:label 'Available To Promise Quantity' ;
    rdfs:comment 'The quantity of material available to promise to new customer orders. Calculated as on-hand plus scheduled receipts minus existing commitments. This is the key metric for order promising and customer service.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageDailyDemand rdf:type rdf:Property ;
    rdfs:label 'Average Daily Demand' ;
    rdfs:comment 'The average daily consumption or demand rate for the material, used for days-of-supply calculations and replenishment planning.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blockedStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Blocked Stock Quantity' ;
    rdfs:comment 'Quantity of material that is blocked for use due to quality issues, damage, or other restrictions. This stock cannot be used for production or sales.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysOfSupply rdf:type rdf:Property ;
    rdfs:label 'Days Of Supply' ;
    rdfs:comment 'The number of days the current on-hand inventory will last based on average daily demand. Calculated as on-hand quantity divided by average daily consumption rate.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:excessStockFlag rdf:type rdf:Property ;
    rdfs:label 'Excess Stock Flag' ;
    rdfs:comment 'Boolean flag indicating whether the material has excess inventory above normal levels. True if on-hand quantity significantly exceeds safety stock plus near-term demand.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:forecastDemandQuantity rdf:type rdf:Property ;
    rdfs:label 'Forecast Demand Quantity' ;
    rdfs:comment 'Total forecasted demand quantity for the material within the planning horizon. This is the statistical forecast used for supply planning when firm sales orders are not yet available.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inQualityInspectionQuantity rdf:type rdf:Property ;
    rdfs:label 'In Quality Inspection Quantity' ;
    rdfs:comment 'Quantity of material currently in quality inspection status and not yet released for unrestricted use. This stock is physically available but not yet approved for consumption.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufacturingLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Lead Time Days' ;
    rdfs:comment 'The number of days required to manufacture the material from raw materials to finished goods. This is the production lead time used in MRP calculations.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mrpControllerCode rdf:type rdf:Property ;
    rdfs:label 'Mrp Controller Code' ;
    rdfs:comment 'Three-character code identifying the MRP controller or planner responsible for managing this material. Used for workload distribution and accountability.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netRequirementQuantity rdf:type rdf:Property ;
    rdfs:label 'Net Requirement Quantity' ;
    rdfs:comment 'The net material requirement calculated by MRP as total demand minus available supply. A positive value indicates a shortage that requires replenishment action.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onHandQuantity rdf:type rdf:Property ;
    rdfs:label 'On Hand Quantity' ;
    rdfs:comment 'Physical stock quantity currently available in the warehouse or storage location. This is the unrestricted-use stock available for consumption or sale.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openPlannedOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Open Planned Order Quantity' ;
    rdfs:comment 'Total quantity of material on planned orders generated by MRP but not yet converted to firm production or purchase orders. These are MRP-generated supply recommendations.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openProductionOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Open Production Order Quantity' ;
    rdfs:comment 'Total quantity of material on open production orders (manufacturing orders) that are in progress or scheduled but not yet completed and received into stock.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openPurchaseOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Open Purchase Order Quantity' ;
    rdfs:comment 'Total quantity of material on open purchase orders that have been released to suppliers but not yet received. This represents inbound supply in transit or scheduled for delivery.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Planned Receipt Date' ;
    rdfs:comment 'The earliest date on which a planned or open order is scheduled to be received into stock. This is the next expected supply arrival date.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningStrategyGroup rdf:type rdf:Property ;
    rdfs:label 'Planning Strategy Group' ;
    rdfs:comment 'Two-character code defining the planning strategy for the material (e.g., make-to-stock, make-to-order, engineer-to-order). Determines how demand and supply are matched.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrderDemandQuantity rdf:type rdf:Property ;
    rdfs:label 'Sales Order Demand Quantity' ;
    rdfs:comment 'Total quantity of material committed to open sales orders. This represents firm customer demand that must be fulfilled.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:snapshotDate rdf:type rdf:Property ;
    rdfs:label 'Snapshot Date' ;
    rdfs:comment 'The date for which this inventory position snapshot was calculated. This is the business event date representing the point-in-time view of supply and demand.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stockOutRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Stock Out Risk Flag' ;
    rdfs:comment 'Boolean flag indicating whether the material is at risk of stock-out based on current inventory position and demand forecast. True if ATP is below safety stock or net requirement is positive.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Supplier Lead Time Days' ;
    rdfs:comment 'The number of days required from order placement to receipt of material from the supplier. This is the procurement lead time used in MRP calculations.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bomExplosionDate rdf:type rdf:Property ;
    rdfs:label 'Bom Explosion Date' ;
    rdfs:comment 'The date on which the BOM was exploded to generate dependent requirements for component materials.' ;
    rdfs:domain ind:MaterialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exceptionMessageCode rdf:type rdf:Property ;
    rdfs:label 'Exception Message Code' ;
    rdfs:comment 'SAP exception code indicating planning issues such as late orders, missing parts, excess stock, or capacity overload.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionMessageText rdf:type rdf:Property ;
    rdfs:label 'Exception Message Text' ;
    rdfs:comment 'Human-readable description of the planning exception or issue requiring planner attention.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firmingDate rdf:type rdf:Property ;
    rdfs:label 'Firming Date' ;
    rdfs:comment 'Date after which this planned order is frozen and will not be automatically rescheduled or changed by subsequent MRP runs.' ;
    rdfs:domain ind:MaterialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossRequirementQuantity rdf:type rdf:Property ;
    rdfs:label 'Gross Requirement Quantity' ;
    rdfs:comment 'Total quantity of material required before considering available stock or scheduled receipts.' ;
    rdfs:domain ind:MaterialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotSizeKey rdf:type rdf:Property ;
    rdfs:label 'Lot Size Key' ;
    rdfs:comment 'SAP lot-sizing procedure code applied to this requirement: EX (lot-for-lot), HB (replenish to maximum), FX (fixed lot size), WB (weekly lot size), PD (period lot size).' ;
    rdfs:domain ind:MaterialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Quantity' ;
    rdfs:comment 'Largest quantity that can be ordered or produced in a single transaction due to capacity, storage, or supplier constraints.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mrpElementType rdf:type rdf:Property ;
    rdfs:label 'Mrp Element Type' ;
    rdfs:comment 'Classification of the MRP element that created this requirement: sales order, forecast, safety stock replenishment, dependent requirement from BOM explosion, planned order, or purchase requisition.' ;
    rdfs:domain ind:MaterialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpRunTimestamp rdf:type rdf:Property ;
    rdfs:label 'Mrp Run Timestamp' ;
    rdfs:comment 'Date and time when the MRP run that generated this requirement record was executed.' ;
    rdfs:domain ind:MaterialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:peggingRequirementReference rdf:type rdf:Property ;
    rdfs:label 'Pegging Requirement Reference' ;
    rdfs:comment 'Reference to the parent requirement that triggered this dependent requirement through BOM explosion (used for requirement traceability).' ;
    rdfs:domain ind:MaterialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Order Quantity' ;
    rdfs:comment 'The lot-size adjusted quantity that MRP proposes to procure or produce, after applying lot-sizing rules (MOQ, rounding, fixed lot size).' ;
    rdfs:domain ind:MaterialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedAvailableBalance rdf:type rdf:Property ;
    rdfs:label 'Projected Available Balance' ;
    rdfs:comment 'Projected on-hand inventory balance after accounting for gross requirements and scheduled receipts up to this requirement date.' ;
    rdfs:domain ind:MaterialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requirementDate rdf:type rdf:Property ;
    rdfs:label 'Requirement Date' ;
    rdfs:comment 'The date on which the material is needed to meet demand or production schedule.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requirementPriority rdf:type rdf:Property ;
    rdfs:label 'Requirement Priority' ;
    rdfs:comment 'Numeric priority ranking used to sequence requirements when allocating limited supply or production capacity (lower number = higher priority).' ;
    rdfs:domain ind:MaterialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requirementSourceItem rdf:type rdf:Property ;
    rdfs:label 'Requirement Source Item' ;
    rdfs:comment 'The line item number within the source document that triggered this requirement.' ;
    rdfs:domain ind:MaterialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementSourceNumber rdf:type rdf:Property ;
    rdfs:label 'Requirement Source Number' ;
    rdfs:comment 'The document number of the source that triggered this requirement (e.g., sales order number, forecast ID, planned order number).' ;
    rdfs:domain ind:MaterialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementStatus rdf:type rdf:Property ;
    rdfs:label 'Requirement Status' ;
    rdfs:comment 'Current fulfillment status of the material requirement: open (not yet covered), partially covered (some supply allocated), fully covered (sufficient supply allocated), cancelled, or expired.' ;
    rdfs:domain ind:MaterialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledReceiptQuantity rdf:type rdf:Property ;
    rdfs:label 'Scheduled Receipt Quantity' ;
    rdfs:comment 'Quantity of material expected to be received from open purchase orders, production orders, or transfer orders by the requirement date.' ;
    rdfs:domain ind:MaterialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moqConstraintId rdf:type rdf:Property ;
    rdfs:label 'Moq Constraint Id' ;
    rdfs:comment 'Unique identifier for the MOQ constraint record. Primary key for the moq_constraint product.' ;
    rdfs:domain ind:MoqConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applyToForecastFlag rdf:type rdf:Property ;
    rdfs:label 'Apply To Forecast Flag' ;
    rdfs:comment 'Indicates whether this MOQ constraint should be applied to forecast-driven planned orders in addition to customer order-driven requirements.' ;
    rdfs:domain ind:MoqConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applyToSafetyStockFlag rdf:type rdf:Property ;
    rdfs:label 'Apply To Safety Stock Flag' ;
    rdfs:comment 'Indicates whether this MOQ constraint should be applied when MRP generates planned orders to replenish safety stock levels.' ;
    rdfs:domain ind:MoqConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:constraintSource rdf:type rdf:Property ;
    rdfs:label 'Constraint Source' ;
    rdfs:comment 'Origin or driver of this MOQ constraint, indicating whether it stems from supplier requirements, logistics limitations, cost considerations, or other factors.' ;
    rdfs:domain ind:MoqConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintStatus rdf:type rdf:Property ;
    rdfs:label 'Constraint Status' ;
    rdfs:comment 'Current lifecycle status of the MOQ constraint. Only active constraints are applied by MRP during planning runs.' ;
    rdfs:domain ind:MoqConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpactPerUnit rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Per Unit' ;
    rdfs:comment 'Estimated cost impact per unit when ordering below the MOQ threshold. Used for cost-benefit analysis of MOQ exceptions.' ;
    rdfs:domain ind:MoqConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionApprovalAuthority rdf:type rdf:Property ;
    rdfs:label 'Exception Approval Authority' ;
    rdfs:comment 'Role or position authorized to approve exceptions to this MOQ constraint (e.g., Supply Planning Manager, Procurement Director).' ;
    rdfs:domain ind:MoqConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionApprovalFlag rdf:type rdf:Property ;
    rdfs:label 'Exception Approval Flag' ;
    rdfs:comment 'Indicates whether exceptions to this MOQ constraint can be approved by supply planners on a case-by-case basis.' ;
    rdfs:domain ind:MoqConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:moqValue rdf:type rdf:Property ;
    rdfs:label 'Moq Value' ;
    rdfs:comment 'Minimum order quantity that must be purchased from this supplier for this material. MRP will not generate planned orders below this threshold.' ;
    rdfs:domain ind:MoqConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mrpLotSizingProcedureCode rdf:type rdf:Property ;
    rdfs:label 'Mrp Lot Sizing Procedure Code' ;
    rdfs:comment 'SAP MRP lot-sizing procedure code that incorporates this MOQ constraint (e.g., EX for lot-for-lot with rounding, HB for replenish to maximum stock level).' ;
    rdfs:domain ind:MoqConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousMoqValue rdf:type rdf:Property ;
    rdfs:label 'Previous Moq Value' ;
    rdfs:comment 'Previous minimum order quantity value before the most recent change. Used to track MOQ negotiation history and trends.' ;
    rdfs:domain ind:MoqConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorityRanking rdf:type rdf:Property ;
    rdfs:label 'Priority Ranking' ;
    rdfs:comment 'Priority ranking of this constraint when multiple MOQ constraints exist for the same material from different suppliers. Lower numbers indicate higher priority.' ;
    rdfs:domain ind:MoqConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source System Record Reference' ;
    rdfs:comment 'Unique identifier of this MOQ constraint record in the source system, enabling traceability and reconciliation.' ;
    rdfs:domain ind:MoqConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierPackageQuantity rdf:type rdf:Property ;
    rdfs:label 'Supplier Package Quantity' ;
    rdfs:comment 'Standard package or container quantity defined by the supplier. Orders must be placed in multiples of this package size.' ;
    rdfs:domain ind:MoqConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bomExplosionLevel rdf:type rdf:Property ;
    rdfs:label 'Bom Explosion Level' ;
    rdfs:comment 'Maximum depth of BOM explosion performed during this MRP run. Indicates how many levels down the product structure the planning calculation extended (e.g., 1 for single-level, 99 for full multi-level explosion).' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completionNotes rdf:type rdf:Property ;
    rdfs:label 'Completion Notes' ;
    rdfs:comment 'Free-text notes or comments entered by planners or system administrators regarding the outcome, issues, or special circumstances of this MRP run.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorMessagesCount rdf:type rdf:Property ;
    rdfs:label 'Error Messages Count' ;
    rdfs:comment 'Total number of error messages generated during this MRP run that prevented successful completion or caused partial failures.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exceptionMessagesCount rdf:type rdf:Property ;
    rdfs:label 'Exception Messages Count' ;
    rdfs:comment 'Total number of exception or warning messages generated during this MRP run, indicating planning issues such as material shortages, capacity overloads, or invalid master data.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:includeForecastFlag rdf:type rdf:Property ;
    rdfs:label 'Include Forecast Flag' ;
    rdfs:comment 'Indicates whether demand forecast data was included in the MRP calculation (True) or only firm customer orders were considered (False).' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includeSafetyStockFlag rdf:type rdf:Property ;
    rdfs:label 'Include Safety Stock Flag' ;
    rdfs:comment 'Indicates whether safety stock requirements were included in the MRP calculation (True) or excluded (False).' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includeWipFlag rdf:type rdf:Property ;
    rdfs:label 'Include Wip Flag' ;
    rdfs:comment 'Indicates whether existing work-in-progress inventory was considered as available supply during this MRP run (True) or excluded (False).' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialsProcessedCount rdf:type rdf:Property ;
    rdfs:label 'Materials Processed Count' ;
    rdfs:comment 'Total number of material master records processed during this MRP run. Indicates the scope and scale of the planning calculation.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedOrdersCancelledCount rdf:type rdf:Property ;
    rdfs:label 'Planned Orders Cancelled Count' ;
    rdfs:comment 'Total number of existing planned orders that were cancelled by this MRP run because they were no longer needed to satisfy material requirements.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedOrdersCreatedCount rdf:type rdf:Property ;
    rdfs:label 'Planned Orders Created Count' ;
    rdfs:comment 'Total number of new planned orders (purchase requisitions or production orders) created by this MRP run to satisfy material requirements.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedOrdersRescheduledCount rdf:type rdf:Property ;
    rdfs:label 'Planned Orders Rescheduled Count' ;
    rdfs:comment 'Total number of existing planned orders that were rescheduled (date or quantity changed) by this MRP run due to changes in demand or supply.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningMode rdf:type rdf:Property ;
    rdfs:label 'Planning Mode' ;
    rdfs:comment 'Manufacturing planning strategy applied during this MRP run: make-to-stock (MTS), make-to-order (MTO), assemble-to-order (ATO), or engineer-to-order (ETO).' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingExplosionFlag rdf:type rdf:Property ;
    rdfs:label 'Routing Explosion Flag' ;
    rdfs:comment 'Indicates whether production routing and work center capacity requirements were calculated during this MRP run (True) or only material requirements were computed (False).' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:runDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Run Duration Minutes' ;
    rdfs:comment 'Total elapsed time in minutes from actual start to actual end of the MRP run. Key performance indicator for planning system efficiency.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runParametersJson rdf:type rdf:Property ;
    rdfs:label 'Run Parameters Json' ;
    rdfs:comment 'JSON-formatted string containing additional MRP run configuration parameters and settings not captured in dedicated columns. Enables flexible storage of system-specific or advanced planning parameters.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockMethod rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Method' ;
    rdfs:comment 'Safety stock calculation method applied during this MRP run: fixed quantity, days of supply, statistical (based on demand variability), or none.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeSourcingRules rdf:type rdf:Property ;
    rdfs:label 'Active Sourcing Rules' ;
    rdfs:comment 'Comma-separated list of active sourcing rule identifiers or strategies applied to this node (e.g., \'JIT (Just In Time)\', \'VMI (Vendor Managed Inventory)\', \'consignment\').' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moqMinimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Moq Minimum Order Quantity' ;
    rdfs:comment 'Minimum order quantity required for procurement or production at this node.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkTierLevel rdf:type rdf:Property ;
    rdfs:label 'Network Tier Level' ;
    rdfs:comment 'Hierarchical tier position in the multi-tier supply network (0=owned plant, 1=tier-1 supplier, 2=tier-2 supplier, 3=tier-3 supplier, etc.).' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nodeSubtype rdf:type rdf:Property ;
    rdfs:label 'Node Subtype' ;
    rdfs:comment 'Detailed sub-classification of the node (e.g., \'automation_assembly\', \'electrification_production\', \'smart_infrastructure_fabrication\', \'tier_1_supplier\', \'tier_2_supplier\', \'tier_3_supplier\').' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingDaysPerWeek rdf:type rdf:Property ;
    rdfs:label 'Operating Days Per Week' ;
    rdfs:comment 'Number of operating days per week for the network node (typically 5, 6, or 7).' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatingHoursPerDay rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Per Day' ;
    rdfs:comment 'Standard daily operating hours of the network node facility.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskExposureScore rdf:type rdf:Property ;
    rdfs:label 'Risk Exposure Score' ;
    rdfs:comment 'Quantitative risk assessment score for the node based on geopolitical, operational, financial, and supply continuity factors (scale 0-100, higher = higher risk).' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageCapacityCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Cubic Meters' ;
    rdfs:comment 'Total warehouse or storage capacity of the node in cubic meters.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierPerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Supplier Performance Rating' ;
    rdfs:comment 'Performance rating score for supplier nodes based on OTD (On-Time Delivery), quality, and compliance metrics (scale 0-100).' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportsCrossDocking rdf:type rdf:Property ;
    rdfs:label 'Supports Cross Docking' ;
    rdfs:comment 'Indicates whether the node supports cross-docking operations (direct transfer from inbound to outbound without storage).' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsKitting rdf:type rdf:Property ;
    rdfs:label 'Supports Kitting' ;
    rdfs:comment 'Indicates whether the node supports kitting or assembly operations (combining multiple components into a kit).' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsPostponement rdf:type rdf:Property ;
    rdfs:label 'Supports Postponement' ;
    rdfs:comment 'Indicates whether the node supports postponement strategies (delaying final product configuration until customer order).' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:throughputCapacityUnitsPerDay rdf:type rdf:Property ;
    rdfs:label 'Throughput Capacity Units Per Day' ;
    rdfs:comment 'Maximum daily production or handling capacity of the node measured in standard units (e.g., units, pallets, tons).' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transitLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Transit Lead Time Days' ;
    rdfs:comment 'Average transportation lead time in days from this node to primary downstream nodes.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planId rdf:type rdf:Property ;
    rdfs:label 'Plan Id' ;
    rdfs:comment 'Primary key for plan' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:demandForecastQuantity rdf:type rdf:Property ;
    rdfs:label 'Demand Forecast Quantity' ;
    rdfs:comment 'Total forecasted demand quantity for the planning period, serving as the primary input to the supply plan.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotSizingProcedure rdf:type rdf:Property ;
    rdfs:label 'Lot Sizing Procedure' ;
    rdfs:comment 'Lot-sizing rule used to determine planned order quantities: LOT_FOR_LOT (exact requirement), FIXED_LOT (fixed quantity), EOQ (Economic Order Quantity), POQ (Periodic Order Quantity), or PERIOD_LOT (period-based aggregation).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedSupplyQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Supply Quantity' ;
    rdfs:comment 'Total quantity of material planned to be supplied during the planning period, aggregated across all time buckets.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningRunTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planning Run Timestamp' ;
    rdfs:comment 'Date and time when the MRP/APS planning run was executed to generate this supply plan.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supplyRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Supply Risk Level' ;
    rdfs:comment 'Assessed risk level for supply availability: LOW (stable supply), MEDIUM (minor risks), HIGH (significant risks), or CRITICAL (severe supply constraints).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'Variance expressed as a percentage of demand forecast, enabling normalized comparison across materials.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryPlannedEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Planned Employee Id' ;
    rdfs:comment 'User ID of the planner who firmed this planned order, locking it from automatic replanning.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:convertedOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Converted Order Number' ;
    rdfs:comment 'Document number of the production order, purchase requisition, or stock transfer order created when this planned order was converted to an executable order.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:convertedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Converted Timestamp' ;
    rdfs:comment 'Date and time when the planned order was converted to an executable order.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deletionFlag rdf:type rdf:Property ;
    rdfs:label 'Deletion Flag' ;
    rdfs:comment 'Indicator that this planned order has been marked for deletion by a subsequent planning run because the requirement no longer exists or has been satisfied by other means.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceptionCode rdf:type rdf:Property ;
    rdfs:label 'Exception Code' ;
    rdfs:comment 'Code identifying planning exceptions or issues requiring planner intervention (e.g., capacity overload, material shortage, lead time violation, MOQ conflict).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionMessage rdf:type rdf:Property ;
    rdfs:label 'Exception Message' ;
    rdfs:comment 'Detailed description of the planning exception or constraint violation that requires planner review and resolution.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Firmed Timestamp' ;
    rdfs:comment 'Date and time when the planned order was firmed by the planner.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:firmingIndicator rdf:type rdf:Property ;
    rdfs:label 'Firming Indicator' ;
    rdfs:comment 'Flag indicating whether this planned order has been firmed by the planner, preventing it from being automatically changed or deleted by subsequent planning runs.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:moqQuantity rdf:type rdf:Property ;
    rdfs:label 'Moq Quantity' ;
    rdfs:comment 'Minimum order quantity constraint from the supplier or production process that was applied during lot sizing.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:multiTierSupplierFlag rdf:type rdf:Property ;
    rdfs:label 'Multi Tier Supplier Flag' ;
    rdfs:comment 'Indicator that this planned order requires coordination across multiple tiers of the supply network (e.g., raw material supplier, component manufacturer, final assembly).' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannerNotes rdf:type rdf:Property ;
    rdfs:label 'Planner Notes' ;
    rdfs:comment 'Free-text comments entered by the planner documenting decisions, constraints, or coordination details related to this planned order.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannerOverrideDate rdf:type rdf:Property ;
    rdfs:label 'Planner Override Date' ;
    rdfs:comment 'Manually adjusted scheduled finish date entered by the planner to override the system-calculated date based on capacity constraints or customer negotiation.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannerOverrideQuantity rdf:type rdf:Property ;
    rdfs:label 'Planner Override Quantity' ;
    rdfs:comment 'Manually adjusted quantity entered by the planner to override the system-calculated planned quantity based on business judgment or known constraints.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procurementLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Procurement Lead Time Days' ;
    rdfs:comment 'Number of days required to procure or produce the material, used by the planning system to calculate scheduled start date from requirement date.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceRequirementNumber rdf:type rdf:Property ;
    rdfs:label 'Source Requirement Number' ;
    rdfs:comment 'Document number of the originating requirement (sales order, production order, forecast entry) that drove the creation of this planned order.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRequirementType rdf:type rdf:Property ;
    rdfs:label 'Source Requirement Type' ;
    rdfs:comment 'Type of demand that triggered the creation of this planned order: sales order (customer demand), production order (component requirement), safety stock (replenishment), forecast (anticipated demand), or service order (spare parts).' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyRiskScore rdf:type rdf:Property ;
    rdfs:label 'Supply Risk Score' ;
    rdfs:comment 'Quantitative risk assessment score (0-100) indicating the likelihood of supply disruption for this planned order based on supplier performance, lead time volatility, and geopolitical factors.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningExceptionId rdf:type rdf:Property ;
    rdfs:label 'Planning Exception Id' ;
    rdfs:comment 'Primary key for planning_exception' ;
    rdfs:domain ind:PlanningException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availableStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Available Stock Quantity' ;
    rdfs:comment 'The current available stock (unrestricted use stock minus allocated quantities) for the material at the plant. Used to assess whether existing inventory can partially mitigate the exception.' ;
    rdfs:domain ind:PlanningException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessImpactDescription rdf:type rdf:Property ;
    rdfs:label 'Business Impact Description' ;
    rdfs:comment 'Free-text description of the business impact if the exception is not resolved (e.g., production line stoppage, customer order delay, revenue at risk, contractual penalty exposure). Used for prioritization and escalation decisions.' ;
    rdfs:domain ind:PlanningException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Current Receipt Date' ;
    rdfs:comment 'The currently scheduled receipt date for the supply order (purchase order, production order, or transfer order) related to this exception. Null if exception is demand-driven shortage with no existing supply order.' ;
    rdfs:domain ind:PlanningException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:demandOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Demand Order Number' ;
    rdfs:comment 'The sales order, service order, or project number that is the source of demand causing the exception. Used to trace exception back to customer commitment and assess business impact of shortage or delay.' ;
    rdfs:domain ind:PlanningException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandSource rdf:type rdf:Property ;
    rdfs:label 'Demand Source' ;
    rdfs:comment 'The origin of the demand that triggered the exception. Sales_order indicates firm customer commitment; forecast indicates statistical projection; safety_stock indicates buffer replenishment; dependent_requirement indicates BOM-driven demand from higher-level assembly.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionDate rdf:type rdf:Property ;
    rdfs:label 'Exception Date' ;
    rdfs:comment 'The date when the supply-demand imbalance occurs or is projected to occur. This is the key date planners use to prioritize exception resolution by urgency.' ;
    rdfs:domain ind:PlanningException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exceptionDetectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exception Detected Timestamp' ;
    rdfs:comment 'The date and time when the exception was first detected and created by the MRP or APS system. Used to calculate exception aging and track planner response time.' ;
    rdfs:domain ind:PlanningException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exceptionNumber rdf:type rdf:Property ;
    rdfs:label 'Exception Number' ;
    rdfs:comment 'Human-readable business identifier for the exception, typically auto-generated by MRP or APS system. Used by planners to reference and track exceptions in daily workflow.' ;
    rdfs:domain ind:PlanningException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionQuantity rdf:type rdf:Property ;
    rdfs:label 'Exception Quantity' ;
    rdfs:comment 'The quantity of material involved in the exception (shortage amount, excess amount, or quantity to reschedule). Expressed in base unit of measure for the material.' ;
    rdfs:domain ind:PlanningException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionStatus rdf:type rdf:Property ;
    rdfs:label 'Exception Status' ;
    rdfs:comment 'Current lifecycle state of the exception. Open indicates new exception requiring planner action; in_progress indicates planner is working resolution; resolved indicates action completed; cancelled indicates exception no longer valid; deferred indicates postponed to future planning cycle.' ;
    rdfs:domain ind:PlanningException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionType rdf:type rdf:Property ;
    rdfs:label 'Exception Type' ;
    rdfs:comment 'Classification of the planning exception: shortage (demand exceeds supply), excess (supply exceeds demand), reschedule_in (move receipt earlier), reschedule_out (move receipt later), expedite (urgent acceleration needed), cancel (order no longer needed), lead_time_violation (supplier lead time exceeded). [ENUM-REF-CANDIDATE: shortage|excess|reschedule_in|reschedule_out|expedite|cancel|lead_time_violation — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PlanningException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Recommended Receipt Date' ;
    rdfs:comment 'The MRP or APS system-recommended new receipt date to resolve the exception. Used for reschedule-in and reschedule-out exception types.' ;
    rdfs:domain ind:PlanningException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionActionTaken rdf:type rdf:Property ;
    rdfs:label 'Resolution Action Taken' ;
    rdfs:comment 'Free-text description of the actual action taken by the planner to resolve the exception. May differ from recommended_action if planner used business judgment to override system recommendation.' ;
    rdfs:domain ind:PlanningException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolved Timestamp' ;
    rdfs:comment 'The date and time when the exception was marked as resolved by the planner. Used to calculate resolution cycle time and planner productivity metrics.' ;
    rdfs:domain ind:PlanningException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Source Order Number' ;
    rdfs:comment 'The purchase order, production order, or planned order number that is the source of the exception (e.g., the order that needs to be rescheduled, expedited, or cancelled). Null for shortage exceptions with no existing supply order.' ;
    rdfs:domain ind:PlanningException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceOrderType rdf:type rdf:Property ;
    rdfs:label 'Source Order Type' ;
    rdfs:comment 'The type of supply order related to this exception. Used to route exception resolution to appropriate procurement, production, or logistics team.' ;
    rdfs:domain ind:PlanningException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningCalendarId rdf:type rdf:Property ;
    rdfs:label 'Planning Calendar Id' ;
    rdfs:comment 'Factory calendar identifier that defines working days, holidays, and shifts used to schedule planned order dates and calculate lead times.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlanningCalendar .

ind:primaryPlanningEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Planning Employee Id' ;
    rdfs:comment 'System user identifier of the planner or administrator who created this planning parameter configuration record.' ;
    rdfs:domain ind:PlanningParameter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryPlanningMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Planning Material Master Id' ;
    rdfs:comment 'Reference to the material master record for which these planning parameters apply.' ;
    rdfs:domain ind:PlanningParameter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:assemblyScrapPercent rdf:type rdf:Property ;
    rdfs:label 'Assembly Scrap Percent' ;
    rdfs:comment 'Expected scrap or yield loss percentage during assembly or production, used to inflate gross requirements to account for anticipated waste.' ;
    rdfs:domain ind:PlanningParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backwardConsumptionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Backward Consumption Period Days' ;
    rdfs:comment 'Number of days in the past that actual demand (sales orders, shipments) can consume forecast quantities, reducing planned independent requirements retroactively.' ;
    rdfs:domain ind:PlanningParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consumptionMode rdf:type rdf:Property ;
    rdfs:label 'Consumption Mode' ;
    rdfs:comment 'Defines how actual demand consumes forecast: 1=Backward Only, 2=Backward and Forward, 3=Forward Only, 4=Forecast Reduction by Material.' ;
    rdfs:domain ind:PlanningParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionIndicator rdf:type rdf:Property ;
    rdfs:label 'Conversion Indicator' ;
    rdfs:comment 'Controls whether planned orders are automatically converted to production or purchase orders: 1=Automatic Conversion, 2=Manual Conversion Required.' ;
    rdfs:domain ind:PlanningParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinuationIndicator rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Indicator' ;
    rdfs:comment 'Flags materials in phase-out: 1=Material to be Discontinued, 2=Successor Material Exists, Z=Discontinuation Effective, used to trigger follow-up material substitution in planning.' ;
    rdfs:domain ind:PlanningParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forwardConsumptionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Forward Consumption Period Days' ;
    rdfs:comment 'Number of days in the future that actual demand can consume forecast quantities, allowing early orders to reduce future planned independent requirements.' ;
    rdfs:domain ind:PlanningParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:individualCollectiveIndicator rdf:type rdf:Property ;
    rdfs:label 'Individual Collective Indicator' ;
    rdfs:comment 'Defines whether requirements are managed individually per sales order (1=Individual Requirements) or pooled across orders (2=Collective Requirements) for planning purposes.' ;
    rdfs:domain ind:PlanningParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jitDeliverySchedulesFlag rdf:type rdf:Property ;
    rdfs:label 'Jit Delivery Schedules Flag' ;
    rdfs:comment 'Indicates whether this material is managed under JIT delivery schedules with suppliers, enabling frequent small-lot deliveries synchronized with production consumption.' ;
    rdfs:domain ind:PlanningParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMrpRunTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Mrp Run Timestamp' ;
    rdfs:comment 'Timestamp of the most recent MRP run that processed this material-plant combination using these planning parameters, enabling audit and troubleshooting.' ;
    rdfs:domain ind:PlanningParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maximumLotSizeQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Lot Size Quantity' ;
    rdfs:comment 'Maximum order quantity that can be procured or produced in a single lot, driven by storage capacity, equipment constraints, or supplier limitations.' ;
    rdfs:domain ind:PlanningParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumLotSizeQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Lot Size Quantity' ;
    rdfs:comment 'Minimum order quantity that must be procured or produced in a single lot, enforcing MOQ constraints from suppliers or production efficiency requirements.' ;
    rdfs:domain ind:PlanningParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mixedMrpIndicator rdf:type rdf:Property ;
    rdfs:label 'Mixed Mrp Indicator' ;
    rdfs:comment 'Controls whether subassemblies are planned with the header material or separately: 1=Plan Subassemblies Separately, 2=Plan with Header, 3=No Mixed MRP.' ;
    rdfs:domain ind:PlanningParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Parameter Effective Date' ;
    rdfs:comment 'Date from which this planning parameter configuration becomes active and is used by MRP runs, enabling time-phased parameter changes.' ;
    rdfs:domain ind:PlanningParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parameterExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Parameter Expiry Date' ;
    rdfs:comment 'Date on which this planning parameter configuration expires and is no longer used by MRP runs, supporting planned transitions to new parameter sets.' ;
    rdfs:domain ind:PlanningParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parameterStatus rdf:type rdf:Property ;
    rdfs:label 'Parameter Status' ;
    rdfs:comment 'Current lifecycle status of this planning parameter record: active=In Use by MRP, inactive=Disabled, pending=Awaiting Approval, archived=Historical Record.' ;
    rdfs:domain ind:PlanningParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodIndicator rdf:type rdf:Property ;
    rdfs:label 'Period Indicator' ;
    rdfs:comment 'Defines the planning period granularity for this material: D=Daily, W=Weekly, M=Monthly, controlling how requirements are bucketed and planned orders are generated.' ;
    rdfs:domain ind:PlanningParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaArrangementUsage rdf:type rdf:Property ;
    rdfs:label 'Quota Arrangement Usage' ;
    rdfs:comment 'Defines how quota arrangements distribute procurement across multiple sources: 1=Quota Arrangement Active, 2=Quota Arrangement Inactive, 3=Quota Arrangement for Subcontracting.' ;
    rdfs:domain ind:PlanningParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roundingValueQuantity rdf:type rdf:Property ;
    rdfs:label 'Rounding Value Quantity' ;
    rdfs:comment 'Quantity increment to which planned order quantities are rounded up to align with packaging units, pallet sizes, or standard container quantities.' ;
    rdfs:domain ind:PlanningParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strategyGroupCounter rdf:type rdf:Property ;
    rdfs:label 'Strategy Group Counter' ;
    rdfs:comment 'Sequence number used in conjunction with planning strategy group to differentiate multiple planning variants for the same material-plant combination.' ;
    rdfs:domain ind:PlanningParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourcePlantId rdf:type rdf:Property ;
    rdfs:label 'Source Plant Id' ;
    rdfs:comment 'FK to supply.plant' ;
    rdfs:domain ind:ReplenishmentProposal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:convertedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Converted Document Number' ;
    rdfs:comment 'Document number of the purchase order, production order, or stock transport order created from this proposal. Null if not yet converted.' ;
    rdfs:domain ind:ReplenishmentProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:convertedDocumentType rdf:type rdf:Property ;
    rdfs:label 'Converted Document Type' ;
    rdfs:comment 'Type of execution document created when the proposal was converted: purchase_order, production_order, stock_transport_order, or subcontract_order. Null if not yet converted.' ;
    rdfs:domain ind:ReplenishmentProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningTimeFenceFlag rdf:type rdf:Property ;
    rdfs:label 'Planning Time Fence Flag' ;
    rdfs:comment 'Indicates whether this proposal falls within the planning time fence period where automatic MRP changes are restricted and planner approval is required for modifications.' ;
    rdfs:domain ind:ReplenishmentProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proposedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Proposed Delivery Date' ;
    rdfs:comment 'Date by which the material should be available to meet demand requirements, calculated by MRP based on lead time and requirement date.' ;
    rdfs:domain ind:ReplenishmentProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proposedOrderDate rdf:type rdf:Property ;
    rdfs:label 'Proposed Order Date' ;
    rdfs:comment 'Date when the purchase requisition or production order should be created to meet the proposed delivery date, accounting for procurement or manufacturing lead time.' ;
    rdfs:domain ind:ReplenishmentProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proposedQuantity rdf:type rdf:Property ;
    rdfs:label 'Proposed Quantity' ;
    rdfs:comment 'Quantity of material recommended by MRP for replenishment, calculated based on net requirements, lot sizing rules, and safety stock policies.' ;
    rdfs:domain ind:ReplenishmentProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectionReasonText rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Text' ;
    rdfs:comment 'Detailed explanation of why the proposal was rejected by the planner. Null if not rejected.' ;
    rdfs:domain ind:ReplenishmentProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryRiskSupplierId rdf:type rdf:Property ;
    rdfs:label 'Primary Risk Supplier Id' ;
    rdfs:comment 'Reference to the supplier associated with this supply risk. Links to supplier master data in SAP Ariba or SAP MM vendor master.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:riskOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Risk Owner Employee Id' ;
    rdfs:comment 'Reference to the employee responsible for monitoring and managing this supply risk. Links to employee master data in Workday HCM.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:alternativeSupplierIdentifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Alternative Supplier Identified Flag' ;
    rdfs:comment 'Boolean indicator whether an alternative or backup supplier has been identified and qualified for this material or component. True indicates alternative supplier is available.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assessedDate rdf:type rdf:Property ;
    rdfs:label 'Assessed Date' ;
    rdfs:comment 'Date when the risk assessment (severity, probability, impact analysis) was completed, supporting risk management process compliance.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contingencyPlan rdf:type rdf:Property ;
    rdfs:label 'Contingency Plan' ;
    rdfs:comment 'Detailed contingency or backup plan to be activated if the risk materializes and primary mitigation strategies fail, supporting business continuity.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'Estimated financial impact in the base currency if the risk materializes, including potential revenue loss, additional costs, or penalties.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialImpactCurrency rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the financial impact amount (e.g., USD, EUR, GBP, CNY).' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Impact Quantity Uom' ;
    rdfs:comment 'Unit of measure for the potential supply impact quantity (e.g., EA for each, KG for kilograms, L for liters, M for meters).' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadTimeImpactDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Impact Days' ;
    rdfs:comment 'Estimated increase in procurement or production lead time (in days) if the risk materializes, used for Material Requirements Planning (MRP) and Advanced Planning and Scheduling (APS) adjustments.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mitigationCost rdf:type rdf:Property ;
    rdfs:label 'Mitigation Cost' ;
    rdfs:comment 'Estimated or actual cost to implement the mitigation strategy, used for cost-benefit analysis and budget planning.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mitigationCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Mitigation Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the mitigation cost (e.g., USD, EUR, GBP, CNY).' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationStatus rdf:type rdf:Property ;
    rdfs:label 'Mitigation Status' ;
    rdfs:comment 'Current status of the mitigation action plan: not started (planned but not initiated), in progress (actively being implemented), completed (mitigation actions finished), on hold (temporarily paused), or cancelled (mitigation plan abandoned).' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationStrategy rdf:type rdf:Property ;
    rdfs:label 'Mitigation Strategy' ;
    rdfs:comment 'Detailed description of the mitigation actions and strategies planned or implemented to reduce the likelihood or impact of the supply risk.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationTargetDate rdf:type rdf:Property ;
    rdfs:label 'Mitigation Target Date' ;
    rdfs:comment 'Target completion date for the mitigation actions, used for project management and risk reduction tracking.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:moqImpact rdf:type rdf:Property ;
    rdfs:label 'Moq Impact' ;
    rdfs:comment 'Change in Minimum Order Quantity (MOQ) requirements if the risk materializes and alternative sourcing is required, impacting inventory planning and working capital.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:potentialImpactDurationDays rdf:type rdf:Property ;
    rdfs:label 'Potential Impact Duration Days' ;
    rdfs:comment 'Estimated duration in days that the supply disruption could last if the risk materializes, used for business continuity and recovery planning.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:potentialSupplyImpactQuantity rdf:type rdf:Property ;
    rdfs:label 'Potential Supply Impact Quantity' ;
    rdfs:comment 'Estimated quantity of material or product that could be impacted if the risk materializes, measured in the base unit of measure (UOM) for the material.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:probabilityOfOccurrence rdf:type rdf:Property ;
    rdfs:label 'Probability Of Occurrence' ;
    rdfs:comment 'Likelihood that the supply risk will materialize within the planning horizon: very high (>80% probability), high (60-80%), medium (40-60%), low (20-40%), or very low (<20%).' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCode rdf:type rdf:Property ;
    rdfs:label 'Risk Code' ;
    rdfs:comment 'Business identifier code for the supply risk following the pattern AAA-NNNNNN where AAA represents risk category and NNNNNN is sequential number.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskStatus rdf:type rdf:Property ;
    rdfs:label 'Risk Status' ;
    rdfs:comment 'Current lifecycle status of the supply risk: identified (newly discovered), assessed (analysis complete), active (currently impacting operations), mitigated (actions taken to reduce impact), closed (risk no longer applicable), or monitoring (under continuous observation).' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTitle rdf:type rdf:Property ;
    rdfs:label 'Risk Title' ;
    rdfs:comment 'Short descriptive title of the supply chain risk for quick identification and reporting.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskType rdf:type rdf:Property ;
    rdfs:label 'Risk Type' ;
    rdfs:comment 'Classification of the supply chain risk by its nature: single-source dependency (sole supplier risk), geopolitical (trade restrictions, sanctions, political instability), capacity constraint (supplier unable to meet demand), quality issue (supplier quality failures), natural disaster (floods, earthquakes, pandemics), or financial instability (supplier bankruptcy risk).' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockRecommendation rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Recommendation' ;
    rdfs:comment 'Recommended safety stock quantity to buffer against this supply risk, used for inventory policy adjustments and working capital planning.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sopCycleId rdf:type rdf:Property ;
    rdfs:label 'Sop Cycle Id' ;
    rdfs:comment 'Unique identifier for the S&OP cycle record. Primary key.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySopEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Sop Employee Id' ;
    rdfs:comment 'Identifier of the user responsible for orchestrating and managing this S&OP cycle. Typically the S&OP manager or demand planning manager.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvedDemandForecastVersion rdf:type rdf:Property ;
    rdfs:label 'Approved Demand Forecast Version' ;
    rdfs:comment 'Version identifier of the demand forecast approved during this S&OP cycle. Links to the demand forecast master data in Microsoft Dynamics 365 SCM.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedSupplyPlanVersion rdf:type rdf:Property ;
    rdfs:label 'Approved Supply Plan Version' ;
    rdfs:comment 'Version identifier of the supply plan approved during this S&OP cycle. Links to the supply plan master data in Microsoft Dynamics 365 SCM and SAP PP/MM.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessUnitCode rdf:type rdf:Property ;
    rdfs:label 'Business Unit Code' ;
    rdfs:comment 'Code identifying the primary business unit participating in this S&OP cycle (e.g., AUTO for Automation, ELEC for Electrification, INFRA for Smart Infrastructure).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUtilizationTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Capacity Utilization Target Percentage' ;
    rdfs:comment 'Target capacity utilization percentage for manufacturing plants during the planning period. Used to assess supply plan feasibility and identify capacity constraints.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPlanAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Plan Amount' ;
    rdfs:comment 'Total planned cost of goods sold (COGS) for the planning period based on the approved supply plan and material/labor cost assumptions. Used for financial reconciliation.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleName rdf:type rdf:Property ;
    rdfs:label 'Cycle Name' ;
    rdfs:comment 'Descriptive name for the S&OP cycle, often including the planning period and business context (e.g., \'January 2024 S&OP Cycle - Automation Division\').' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleNotes rdf:type rdf:Property ;
    rdfs:label 'Cycle Notes' ;
    rdfs:comment 'Free-text notes capturing additional context, special circumstances, or important observations related to this S&OP cycle.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleNumber rdf:type rdf:Property ;
    rdfs:label 'Cycle Number' ;
    rdfs:comment 'Business identifier for the S&OP cycle, typically formatted as SOP-YYYY-MM representing the planning period.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleStatus rdf:type rdf:Property ;
    rdfs:label 'Cycle Status' ;
    rdfs:comment 'Current lifecycle status of the S&OP cycle. Tracks progression through demand review, supply review, pre-S&OP meeting, executive S&OP decision, approval, and closure. [ENUM-REF-CANDIDATE: draft|demand_review|supply_review|pre_sop|executive_sop|approved|closed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandReviewCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Demand Review Completion Date' ;
    rdfs:comment 'Date when the demand review phase was completed and demand consensus was achieved.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:demandReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Demand Review Status' ;
    rdfs:comment 'Status of the demand review phase within this S&OP cycle. Tracks completion of demand consensus building across sales, marketing, and product management.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandSupplyGapQuantity rdf:type rdf:Property ;
    rdfs:label 'Demand Supply Gap Quantity' ;
    rdfs:comment 'Aggregate quantity gap between demand forecast and supply plan across all materials and time periods within this S&OP cycle. Positive values indicate demand exceeds supply; negative values indicate supply exceeds demand.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandSupplyGapValue rdf:type rdf:Property ;
    rdfs:label 'Demand Supply Gap Value' ;
    rdfs:comment 'Aggregate financial value of the demand-supply gap in base currency. Represents revenue at risk (if demand exceeds supply) or excess inventory exposure (if supply exceeds demand).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:executiveSopDecision rdf:type rdf:Property ;
    rdfs:label 'Executive Sop Decision' ;
    rdfs:comment 'Summary of executive decisions made during the executive S&OP meeting, including strategic trade-offs, investment approvals, and final plan authorization.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executiveSopMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Executive Sop Meeting Date' ;
    rdfs:comment 'Date when the executive S&OP meeting was held for final decision-making and plan approval by senior leadership.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialReconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Financial Reconciliation Date' ;
    rdfs:comment 'Date when financial reconciliation was completed and the S&OP plan was aligned with the financial budget.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialReconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Financial Reconciliation Status' ;
    rdfs:comment 'Status of financial reconciliation between the approved S&OP plan and the financial budget. Ensures alignment between operational plans and financial commitments.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gapResolutionStrategy rdf:type rdf:Property ;
    rdfs:label 'Gap Resolution Strategy' ;
    rdfs:comment 'Description of the strategy approved to resolve demand-supply gaps, including capacity expansion, supplier escalation, demand shaping, inventory build, or customer allocation decisions.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryPlanValue rdf:type rdf:Property ;
    rdfs:label 'Inventory Plan Value' ;
    rdfs:comment 'Target inventory value at the end of the planning period based on the approved supply plan. Used for working capital planning and financial reconciliation.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:keyAssumptions rdf:type rdf:Property ;
    rdfs:label 'Key Assumptions' ;
    rdfs:comment 'Critical assumptions underlying the S&OP plan, including market conditions, customer demand drivers, supplier performance, capacity availability, and economic factors.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningHorizonMonths rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Months' ;
    rdfs:comment 'Number of months into the future covered by this S&OP cycle planning horizon. Typically 12-18 months for industrial manufacturing.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preSopMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Pre Sop Meeting Date' ;
    rdfs:comment 'Date when the pre-S&OP meeting was held to reconcile demand and supply plans and prepare recommendations for executive review.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preSopMeetingOutcome rdf:type rdf:Property ;
    rdfs:label 'Pre Sop Meeting Outcome' ;
    rdfs:comment 'Summary of key decisions, gap resolutions, and recommendations from the pre-S&OP meeting. Captures consensus on demand-supply balance and escalation items for executive S&OP.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyReviewCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Supply Review Completion Date' ;
    rdfs:comment 'Date when the supply review phase was completed and supply commitment was established.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supplyReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Supply Review Status' ;
    rdfs:comment 'Status of the supply review phase within this S&OP cycle. Tracks completion of supply capability assessment across manufacturing, procurement, and logistics.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyRiskMitigationPlan rdf:type rdf:Property ;
    rdfs:label 'Supply Risk Mitigation Plan' ;
    rdfs:comment 'Description of actions planned to mitigate identified supply risks, including supplier diversification, safety stock increases, or alternative sourcing strategies.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automaticPoFlag rdf:type rdf:Property ;
    rdfs:label 'Automatic Po Flag' ;
    rdfs:comment 'Indicates whether MRP is authorized to automatically convert planned orders to purchase orders without manual intervention for this sourcing rule.' ;
    rdfs:domain ind:SourcingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceptionReason rdf:type rdf:Property ;
    rdfs:label 'Exception Reason' ;
    rdfs:comment 'Free-text explanation for any exceptions or deviations from standard sourcing policies, such as emergency procurement, single-source justification, or temporary supplier changes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMoqNegotiationDate rdf:type rdf:Property ;
    rdfs:label 'Last Moq Negotiation Date' ;
    rdfs:comment 'Date when the MOQ was last negotiated or reviewed with the supplier, used to track contract refresh cycles and renegotiation schedules.' ;
    rdfs:domain ind:SourcingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotSizeRoundingValue rdf:type rdf:Property ;
    rdfs:label 'Lot Size Rounding Value' ;
    rdfs:comment 'Rounding increment for order quantities. MRP will round calculated requirements up to the nearest multiple of this value to align with packaging or production batch constraints.' ;
    rdfs:domain ind:SourcingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:makeOrBuyIndicator rdf:type rdf:Property ;
    rdfs:label 'Make Or Buy Indicator' ;
    rdfs:comment 'Strategic decision indicator specifying whether the material is manufactured in-house (make), procured externally (buy), or both options are available.' ;
    rdfs:domain ind:SourcingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderUnit rdf:type rdf:Property ;
    rdfs:label 'Order Unit' ;
    rdfs:comment 'Unit of measure in which orders are placed with the supplier (e.g., EA for each, KG for kilogram, M for meter). Must be convertible to base UOM.' ;
    rdfs:domain ind:SourcingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannerApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Planner Approved Flag' ;
    rdfs:comment 'Indicates whether the sourcing rule has been reviewed and approved by the material planner or supply chain manager for use in MRP runs.' ;
    rdfs:domain ind:SourcingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quotaArrangementFlag rdf:type rdf:Property ;
    rdfs:label 'Quota Arrangement Flag' ;
    rdfs:comment 'Indicates whether this sourcing rule is part of a quota arrangement where demand is split across multiple suppliers based on allocation percentages.' ;
    rdfs:domain ind:SourcingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Business-assigned unique code identifying this sourcing rule for operational reference and reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Descriptive name of the sourcing rule for business user identification and reporting purposes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current lifecycle status of the sourcing rule indicating whether it is active and available for MRP, temporarily blocked, awaiting approval, or expired.' ;
    rdfs:domain ind:SourcingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingPriority rdf:type rdf:Property ;
    rdfs:label 'Sourcing Priority' ;
    rdfs:comment 'Numeric ranking indicating the preference order when multiple sourcing rules exist for the same material-plant combination. Lower numbers indicate higher priority.' ;
    rdfs:domain ind:SourcingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourcingType rdf:type rdf:Property ;
    rdfs:label 'Sourcing Type' ;
    rdfs:comment 'Classification of the sourcing method: external procurement from supplier, in-house production, subcontracting, stock transfer between plants, or consignment arrangement.' ;
    rdfs:domain ind:SourcingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplySafetyStockPolicyId rdf:type rdf:Property ;
    rdfs:label 'Supply Safety Stock Policy Id' ;
    rdfs:comment 'Unique identifier for the safety stock policy record.' ;
    rdfs:domain ind:SupplySafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:criticalityCode rdf:type rdf:Property ;
    rdfs:label 'Criticality Code' ;
    rdfs:comment 'Business criticality rating indicating the impact of stockout on operations: critical (production stoppage), high (significant disruption), medium (moderate impact), low (minimal impact).' ;
    rdfs:domain ind:SupplySafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandVariabilityCoefficient rdf:type rdf:Property ;
    rdfs:label 'Demand Variability Coefficient' ;
    rdfs:comment 'Statistical measure of demand fluctuation (coefficient of variation or standard deviation) used in statistical safety stock calculations.' ;
    rdfs:domain ind:SupplySafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdingCostPercentAnnual rdf:type rdf:Property ;
    rdfs:label 'Holding Cost Percent Annual' ;
    rdfs:comment 'Annual inventory carrying cost as a percentage of material value, including warehousing, insurance, obsolescence, and cost of capital.' ;
    rdfs:domain ind:SupplySafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadTimeVariabilityDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Variability Days' ;
    rdfs:comment 'Standard deviation of supplier lead time in days, used to account for supply uncertainty in safety stock calculations.' ;
    rdfs:domain ind:SupplySafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumStockLevel rdf:type rdf:Property ;
    rdfs:label 'Minimum Stock Level' ;
    rdfs:comment 'The lower inventory threshold below which stock should not fall under normal operating conditions.' ;
    rdfs:domain ind:SupplySafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDeliveryLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Lead Time Days' ;
    rdfs:comment 'Expected number of calendar days from order placement to material receipt, used in reorder point calculation.' ;
    rdfs:domain ind:SupplySafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannerCode rdf:type rdf:Property ;
    rdfs:label 'Planner Code' ;
    rdfs:comment 'Three-character code identifying the supply chain planner or buyer responsible for managing this material-plant combination.' ;
    rdfs:domain ind:SupplySafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Days' ;
    rdfs:comment 'Number of days between scheduled reviews of this safety stock policy to ensure continued relevance and accuracy.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyDaysSupply rdf:type rdf:Property ;
    rdfs:label 'Safety Days Supply' ;
    rdfs:comment 'Number of days of average demand that the safety stock quantity is intended to cover.' ;
    rdfs:domain ind:SupplySafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialProcurementKey rdf:type rdf:Property ;
    rdfs:label 'Special Procurement Key' ;
    rdfs:comment 'Two-digit SAP code indicating special procurement scenarios such as subcontracting, consignment, stock transfer, or third-party processing.' ;
    rdfs:domain ind:SupplySafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:absenceRecordId rdf:type rdf:Property ;
    rdfs:label 'Absence Record Id' ;
    rdfs:comment 'Unique identifier for the absence record. Primary key.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payrollPeriodId rdf:type rdf:Property ;
    rdfs:label 'Payroll Period Id' ;
    rdfs:comment 'Identifier of the payroll period in which this absence is processed for payroll deduction or accrual adjustment.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayrollPeriod .

ind:primaryAbsenceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Absence Employee Id' ;
    rdfs:comment 'Identifier of the employee who is absent. Links to the employee master record in Workday HCM.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryAbsenceReplacementEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Absence Replacement Employee Id' ;
    rdfs:comment 'Employee identifier of the replacement worker assigned to cover the absent employee\'s shift or responsibilities.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:absenceNotes rdf:type rdf:Property ;
    rdfs:label 'Absence Notes' ;
    rdfs:comment 'Free-text notes or comments regarding the absence, including special circumstances, accommodation requests, or manager observations.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:absenceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Absence Reason Code' ;
    rdfs:comment 'Detailed reason code for the absence. May include specific illness codes, family emergency types, or other granular classifications as defined by HR policy.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:absenceTypeCode rdf:type rdf:Property ;
    rdfs:label 'Absence Type Code' ;
    rdfs:comment 'Code representing the category of absence: VACATION (planned vacation leave), SICK (unplanned sick leave), PERSONAL (personal time off), PARENTAL (maternity/paternity leave), FMLA (Family and Medical Leave Act protected leave), BEREAVEMENT (compassionate leave), JURY_DUTY (civic duty leave), MILITARY (military service leave), UNPAID (unpaid leave of absence). [ENUM-REF-CANDIDATE: VACATION|SICK|PERSONAL|PARENTAL|FMLA|BEREAVEMENT|JURY_DUTY|MILITARY|UNPAID — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualBalanceDeducted rdf:type rdf:Property ;
    rdfs:label 'Accrual Balance Deducted' ;
    rdfs:comment 'Number of hours deducted from the employee\'s leave accrual balance (vacation bank, sick leave bank, etc.) for this absence.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isFmlaProtected rdf:type rdf:Property ;
    rdfs:label 'Is Fmla Protected' ;
    rdfs:comment 'Indicates whether this absence is protected under the Family and Medical Leave Act (FMLA) regulations, providing job protection and continuation of benefits.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isIntermittent rdf:type rdf:Property ;
    rdfs:label 'Is Intermittent' ;
    rdfs:comment 'Indicates whether this absence is part of an intermittent leave pattern (true) such as recurring FMLA leave, or a continuous block of absence (false).' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPaid rdf:type rdf:Property ;
    rdfs:label 'Is Paid' ;
    rdfs:comment 'Indicates whether the absence is paid (true) or unpaid (false). Determines whether payroll deduction or accrual balance adjustment is required.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalCertificationReceived rdf:type rdf:Property ;
    rdfs:label 'Medical Certification Received' ;
    rdfs:comment 'Indicates whether the required medical certification documentation has been received and validated by HR.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Medical Certification Required' ;
    rdfs:comment 'Indicates whether medical certification documentation is required for this absence per company policy or regulatory requirement.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnToWorkCertificationReceived rdf:type rdf:Property ;
    rdfs:label 'Return To Work Certification Received' ;
    rdfs:comment 'Indicates whether a medical clearance or return-to-work certification was received before the employee resumed duties, as required by occupational health policy per ISO 45001.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnToWorkDate rdf:type rdf:Property ;
    rdfs:label 'Return To Work Date' ;
    rdfs:comment 'Actual date the employee returned to work following the absence. May differ from the planned end_date if the absence was extended or shortened.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentId rdf:type rdf:Property ;
    rdfs:label 'Assignment Id' ;
    rdfs:comment 'Primary key for assignment' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assignment Employee Id' ;
    rdfs:comment 'Reference to the employee master record. Links this assignment to the worker in the workforce domain.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignmentSupervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assignment Supervisor Employee Id' ;
    rdfs:comment 'Reference to the employee record of the direct supervisor or manager for this assignment. Establishes reporting relationships.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:businessUnitId rdf:type rdf:Property ;
    rdfs:label 'Business Unit Id' ;
    rdfs:comment 'Reference to the business unit for financial and operational reporting. Links to the enterprise business unit hierarchy.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:jobProfileId rdf:type rdf:Property ;
    rdfs:label 'Job Profile Id' ;
    rdfs:comment 'Reference to the job profile defining the role, responsibilities, and competencies for this assignment.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobProfile .

ind:positionId rdf:type rdf:Property ;
    rdfs:label 'Position Id' ;
    rdfs:comment 'Reference to the position master record. Identifies the specific position to which the employee is assigned.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:workLocationId rdf:type rdf:Property ;
    rdfs:label 'Work Location Id' ;
    rdfs:comment 'Reference to the primary physical work location for this assignment. Links to facility or site master data.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:assignmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Number' ;
    rdfs:comment 'Business-facing unique identifier for the assignment. Used for external reference and reporting.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basePayRate rdf:type rdf:Property ;
    rdfs:label 'Base Pay Rate' ;
    rdfs:comment 'Base compensation rate for the assignment. Amount is in the currency specified by pay_currency_code.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Bonus Target Percentage' ;
    rdfs:comment 'Target bonus as a percentage of base pay. Represents the expected variable compensation opportunity for this assignment.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCenterSplitPercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Center Split Percentage' ;
    rdfs:comment 'Percentage of labor cost allocated to the primary cost center. Used when an employee\'s time is split across multiple cost centers.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ftePercentage rdf:type rdf:Property ;
    rdfs:label 'Fte Percentage' ;
    rdfs:comment 'Percentage of full-time equivalent hours for this assignment. 100.00 represents full-time, values below 100 represent part-time.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jobFamily rdf:type rdf:Property ;
    rdfs:label 'Job Family' ;
    rdfs:comment 'Broad categorization of the job role. Groups similar positions for workforce planning and talent management.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobLevel rdf:type rdf:Property ;
    rdfs:label 'Job Level' ;
    rdfs:comment 'Hierarchical level of the position within the organization. Used for career progression tracking and compensation benchmarking.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overtimeEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Overtime Eligible Flag' ;
    rdfs:comment 'Indicates whether the assignment is eligible for overtime compensation. True if eligible for overtime pay under labor regulations.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Pay Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for compensation amounts. Specifies the currency in which base pay and other compensation are denominated.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payFrequency rdf:type rdf:Property ;
    rdfs:label 'Pay Frequency' ;
    rdfs:comment 'Frequency at which the base pay rate is applied. Indicates whether compensation is calculated hourly, daily, weekly, biweekly, monthly, or annually.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payGrade rdf:type rdf:Property ;
    rdfs:label 'Pay Grade' ;
    rdfs:comment 'Compensation grade or band assigned to this position. Used for pay equity analysis and compensation benchmarking.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probationEndDate rdf:type rdf:Property ;
    rdfs:label 'Probation End Date' ;
    rdfs:comment 'Date when the probationary period for this assignment ends. Null if no probation period applies.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rehireEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Rehire Eligible Flag' ;
    rdfs:comment 'Indicates whether the employee is eligible for rehire after assignment termination. True if eligible, false if not eligible. Null for active assignments.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledWeeklyHours rdf:type rdf:Property ;
    rdfs:label 'Scheduled Weekly Hours' ;
    rdfs:comment 'Standard number of hours the employee is scheduled to work per week under this assignment.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftPremiumEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Shift Premium Eligible Flag' ;
    rdfs:comment 'Indicates whether the assignment is eligible for shift premium pay. True if eligible for additional compensation for non-standard shifts.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeType rdf:type rdf:Property ;
    rdfs:label 'Time Type' ;
    rdfs:comment 'Classification of time tracking method for this assignment. Examples include salaried exempt, salaried non-exempt, hourly, or piece-rate.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionCode rdf:type rdf:Property ;
    rdfs:label 'Union Code' ;
    rdfs:comment 'Code identifying the labor union or collective bargaining unit covering this assignment. Null if not unionized.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionMembershipFlag rdf:type rdf:Property ;
    rdfs:label 'Union Membership Flag' ;
    rdfs:comment 'Indicates whether the assignment is covered by a collective bargaining agreement. True if the position is unionized.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workShiftCode rdf:type rdf:Property ;
    rdfs:label 'Work Shift Code' ;
    rdfs:comment 'Code identifying the standard work shift pattern for this assignment. Examples include day shift, night shift, rotating shift, or flexible schedule.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitPlanId rdf:type rdf:Property ;
    rdfs:label 'Benefit Plan Id' ;
    rdfs:comment 'Unique identifier for the benefit plan. Primary key.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offeringOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Offering Org Unit Id' ;
    rdfs:comment 'Foreign key linking to workforce.org_unit. Business justification: Benefit plans are offered by a specific organizational unit; adding offering_org_unit_id provides clear ownership and enables joins to org_unit for cost center and location context.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:acaCompliant rdf:type rdf:Property ;
    rdfs:label 'Aca Compliant' ;
    rdfs:comment 'Indicates whether this health benefit plan meets ACA minimum essential coverage and minimum value standards. Required for employer mandate reporting.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierPolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Policy Number' ;
    rdfs:comment 'Policy or contract number assigned by the insurance carrier to this benefit plan. Used for claims processing and carrier communications.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cobraEligible rdf:type rdf:Property ;
    rdfs:label 'Cobra Eligible' ;
    rdfs:comment 'Indicates whether this benefit plan is subject to COBRA continuation coverage requirements, allowing terminated employees to continue coverage at their own expense.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coinsurancePercentage rdf:type rdf:Property ;
    rdfs:label 'Coinsurance Percentage' ;
    rdfs:comment 'Percentage of covered service costs the employee pays after meeting the deductible (e.g., 20% coinsurance means employee pays 20%, plan pays 80%).' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contributionFrequency rdf:type rdf:Property ;
    rdfs:label 'Contribution Frequency' ;
    rdfs:comment 'Frequency at which employee and employer contributions are collected (e.g., biweekly aligns with payroll cycles).' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copayAmount rdf:type rdf:Property ;
    rdfs:label 'Copay Amount' ;
    rdfs:comment 'Fixed dollar amount the employee pays for a covered service (e.g., $25 for a doctor visit). Applies to health and dental plans.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageTier rdf:type rdf:Property ;
    rdfs:label 'Coverage Tier' ;
    rdfs:comment 'Level of coverage offered by the plan, determining who is covered (employee only, employee plus dependents, family coverage). Affects premium rates.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductibleAmount rdf:type rdf:Property ;
    rdfs:label 'Deductible Amount' ;
    rdfs:comment 'Annual deductible amount the employee must pay out-of-pocket before insurance coverage begins. Applies to health, dental, and vision plans.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dependentCoverageAllowed rdf:type rdf:Property ;
    rdfs:label 'Dependent Coverage Allowed' ;
    rdfs:comment 'Indicates whether this benefit plan allows employees to enroll eligible dependents (spouse, children, domestic partner).' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibilityRule rdf:type rdf:Property ;
    rdfs:label 'Eligibility Rule' ;
    rdfs:comment 'Business rule defining which employee classes or employment types are eligible for this benefit plan (e.g., \'Full-time employees with 90 days of service\', \'Salaried employees only\').' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employee Contribution Amount' ;
    rdfs:comment 'Amount the employee pays per pay period for this benefit plan coverage tier. Deducted from payroll pre-tax or post-tax depending on plan type.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employer Contribution Amount' ;
    rdfs:comment 'Amount the employer pays per pay period toward this benefit plan coverage tier. Represents labor cost allocation for financial reporting.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentCloseDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Close Date' ;
    rdfs:comment 'Last date employees can enroll in or make changes to this benefit plan during the annual open enrollment period.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentOpenDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Open Date' ;
    rdfs:comment 'First date employees can enroll in or make changes to this benefit plan during the annual open enrollment period.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:erisaPlanNumber rdf:type rdf:Property ;
    rdfs:label 'Erisa Plan Number' ;
    rdfs:comment 'Three-digit plan number assigned to this benefit plan for ERISA Form 5500 reporting. Required for all ERISA-covered plans.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hipaaCompliant rdf:type rdf:Property ;
    rdfs:label 'Hipaa Compliant' ;
    rdfs:comment 'Indicates whether this benefit plan complies with HIPAA privacy and security requirements for protected health information (PHI).' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxDependents rdf:type rdf:Property ;
    rdfs:label 'Max Dependents' ;
    rdfs:comment 'Maximum number of dependents an employee can enroll under this benefit plan. Null if no limit applies.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outOfPocketMax rdf:type rdf:Property ;
    rdfs:label 'Out Of Pocket Max' ;
    rdfs:comment 'Maximum amount an employee will pay out-of-pocket for covered services in a plan year. After this limit, the plan pays 100% of covered expenses.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planAdministratorEmail rdf:type rdf:Property ;
    rdfs:label 'Plan Administrator Email' ;
    rdfs:comment 'Email address for the plan administrator. Used for employee benefit inquiries and regulatory communications.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planAdministratorName rdf:type rdf:Property ;
    rdfs:label 'Plan Administrator Name' ;
    rdfs:comment 'Name of the individual or entity responsible for administering the benefit plan and handling employee inquiries, claims, and appeals.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planAdministratorPhone rdf:type rdf:Property ;
    rdfs:label 'Plan Administrator Phone' ;
    rdfs:comment 'Phone number for the plan administrator. Provided to employees for benefit support and claims assistance.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Plan Document Url' ;
    rdfs:comment 'URL or file path to the official Summary Plan Description (SPD) document required under ERISA. Provides employees with detailed plan terms and conditions.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planNotes rdf:type rdf:Property ;
    rdfs:label 'Plan Notes' ;
    rdfs:comment 'Free-text field for additional notes, special instructions, or administrative comments about this benefit plan. Used for internal HR reference.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planYear rdf:type rdf:Property ;
    rdfs:label 'Plan Year' ;
    rdfs:comment 'Calendar year for which this benefit plan configuration is effective. Benefit plans are typically versioned annually with new rates and terms.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:section125Eligible rdf:type rdf:Property ;
    rdfs:label 'Section 125 Eligible' ;
    rdfs:comment 'Indicates whether this benefit plan is eligible for pre-tax payroll deductions under an IRC Section 125 cafeteria plan.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxTreatment rdf:type rdf:Property ;
    rdfs:label 'Tax Treatment' ;
    rdfs:comment 'Tax treatment of employee contributions to this benefit plan. Pre-tax contributions reduce taxable income; post-tax contributions do not.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waitingPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Waiting Period Days' ;
    rdfs:comment 'Number of days a new hire must wait before becoming eligible to enroll in this benefit plan. Regulatory limits apply under ACA.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualSalary rdf:type rdf:Property ;
    rdfs:label 'Annual Salary' ;
    rdfs:comment 'Annual base salary for salaried employees. Used for budgeting, compensation analysis, and financial reporting. Null for hourly employees.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'Date of birth of the employee. Used for age verification, benefits eligibility, retirement planning, and compliance with labor laws.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:departmentName rdf:type rdf:Property ;
    rdfs:label 'Department Name' ;
    rdfs:comment 'Full name of the department. Examples: Assembly Line 1, Quality Control Lab, Maintenance Shop, Production Planning, Procurement. Provides human-readable context for organizational assignment.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactRelationship rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Relationship' ;
    rdfs:comment 'Relationship of the emergency contact to the employee. Examples: Spouse, Parent, Sibling, Friend. Used for emergency response protocols.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeNumber rdf:type rdf:Property ;
    rdfs:label 'Employee Number' ;
    rdfs:comment 'Human-readable employee number assigned by HR system. Used for payroll, timekeeping, and shop floor identification. Displayed on employee badges and MES (Manufacturing Execution System) terminals.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentStatus rdf:type rdf:Property ;
    rdfs:label 'Employment Status' ;
    rdfs:comment 'Current employment lifecycle status of the employee. Determines access rights, payroll processing, and system permissions. Active employees are eligible for work assignments and compensation.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hourlyRate rdf:type rdf:Property ;
    rdfs:label 'Hourly Rate' ;
    rdfs:comment 'Hourly wage rate for hourly employees. Used for payroll calculation, labor cost allocation, and OpEx (Operational Expenditure) tracking. Null for salaried employees.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jobCode rdf:type rdf:Property ;
    rdfs:label 'Job Code' ;
    rdfs:comment 'Standardized job classification code used for compensation planning, labor reporting, and workforce analytics. Maps to job families and pay grades in Workday HCM.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:middleName rdf:type rdf:Property ;
    rdfs:label 'Middle Name' ;
    rdfs:comment 'Middle name or initial of the employee. Optional field used for complete legal identification.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalIdNumber rdf:type rdf:Property ;
    rdfs:label 'National Id Number' ;
    rdfs:comment 'Government-issued national identification number (e.g., Social Security Number in USA, National Insurance Number in UK). Used for tax reporting, payroll processing, and legal compliance.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Safety Certification Status' ;
    rdfs:comment 'Status of required safety certifications for the employee\'s role. Used for ISO 45001 compliance, OSHA safety requirements, and work authorization on shop floor and hazardous areas.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingHoursYtd rdf:type rdf:Property ;
    rdfs:label 'Training Hours Ytd' ;
    rdfs:comment 'Total training hours completed by the employee in the current calendar year. Used for compliance with training requirements, skills development tracking, and ISO 9001 competency management.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workLocationCode rdf:type rdf:Property ;
    rdfs:label 'Work Location Code' ;
    rdfs:comment 'Code identifying the primary physical work location (plant, facility, office). Used for shift scheduling, safety compliance, and geographic labor reporting.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workLocationName rdf:type rdf:Property ;
    rdfs:label 'Work Location Name' ;
    rdfs:comment 'Full name of the work location. Examples: Springfield Manufacturing Plant, Chicago Distribution Center, Detroit Assembly Facility. Provides geographic context for workforce distribution.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPermitExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Work Permit Expiry Date' ;
    rdfs:comment 'Date when the employee\'s work permit or visa expires. Used for renewal tracking and compliance with immigration regulations. Null if no work permit required.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workPermitRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Work Permit Required Flag' ;
    rdfs:comment 'Indicates whether the employee requires a work permit or visa to work in the current location. Used for immigration compliance and work authorization tracking.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Responsible Org Unit Id' ;
    rdfs:comment 'Foreign key linking to workforce.org_unit. Business justification: Job profiles are defined at the organizational unit level; adding responsible_org_unit_id links each job_profile to its owning org_unit, eliminating the need for duplicate org-unit descriptive columns' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:basePayType rdf:type rdf:Property ;
    rdfs:label 'Base Pay Type' ;
    rdfs:comment 'Primary compensation structure for this job profile: Hourly (paid per hour worked), Salary (fixed annual amount), or Piece Rate (paid per unit produced).' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flsaClassification rdf:type rdf:Property ;
    rdfs:label 'Flsa Classification' ;
    rdfs:comment 'FLSA overtime eligibility classification: Exempt (salaried, not eligible for overtime) or Non-Exempt (hourly, eligible for overtime).' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobProfileStatus rdf:type rdf:Property ;
    rdfs:label 'Job Profile Status' ;
    rdfs:comment 'Current lifecycle status of the job profile: Active (in use), Inactive (temporarily suspended), Draft (under development), Obsolete (retired).' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occupationalClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Occupational Classification Code' ;
    rdfs:comment 'Standard Occupational Classification (SOC) code aligning this job profile to national occupational taxonomy (format: XX-XXXX).' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalRequirements rdf:type rdf:Property ;
    rdfs:label 'Physical Requirements' ;
    rdfs:comment 'Description of physical demands and working conditions for this job profile (e.g., \'Ability to lift 50 lbs, stand for extended periods, work in noisy environment, exposure to chemicals\').' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proficiencyLevelRequired rdf:type rdf:Property ;
    rdfs:label 'Proficiency Level Required' ;
    rdfs:comment 'Overall skill proficiency level expected for this job profile (e.g., Basic, Intermediate, Advanced, Expert).' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileCode rdf:type rdf:Property ;
    rdfs:label 'Profile Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code identifying the job profile across the enterprise. Used in HR systems, requisitions, and organizational planning.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileDescription rdf:type rdf:Property ;
    rdfs:label 'Profile Description' ;
    rdfs:comment 'Detailed narrative describing the purpose, scope, and key responsibilities of the job profile.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileName rdf:type rdf:Property ;
    rdfs:label 'Profile Name' ;
    rdfs:comment 'Human-readable name of the job profile (e.g., \'Senior CNC Machinist\', \'Production Supervisor\', \'Quality Engineer\').' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteWorkEligible rdf:type rdf:Property ;
    rdfs:label 'Remote Work Eligible' ;
    rdfs:comment 'Indicates whether this job profile is eligible for remote or hybrid work arrangements.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredCertifications rdf:type rdf:Property ;
    rdfs:label 'Required Certifications' ;
    rdfs:comment 'Comma-separated list of mandatory professional certifications, licenses, or credentials required for this job profile (e.g., \'CNC Operator Certification, OSHA 30-Hour, Forklift License\').' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Required Education Level' ;
    rdfs:comment 'Minimum educational attainment required for this job profile (e.g., High School, Associate, Bachelor, Master, Doctorate, Vocational, None). [ENUM-REF-CANDIDATE: high_school|associate|bachelor|master|doctorate|vocational|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetySensitivePosition rdf:type rdf:Property ;
    rdfs:label 'Safety Sensitive Position' ;
    rdfs:comment 'Indicates whether this job profile is classified as safety-sensitive, requiring additional screening, training, and compliance monitoring under OSHA and ISO 45001.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salaryRangeMaximum rdf:type rdf:Property ;
    rdfs:label 'Salary Range Maximum' ;
    rdfs:comment 'Maximum annual base salary for this job profile in the enterprise default currency.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salaryRangeMidpoint rdf:type rdf:Property ;
    rdfs:label 'Salary Range Midpoint' ;
    rdfs:comment 'Midpoint annual base salary for this job profile, representing the target compensation for fully competent performance.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salaryRangeMinimum rdf:type rdf:Property ;
    rdfs:label 'Salary Range Minimum' ;
    rdfs:comment 'Minimum annual base salary for this job profile in the enterprise default currency.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftPremiumEligible rdf:type rdf:Property ;
    rdfs:label 'Shift Premium Eligible' ;
    rdfs:comment 'Indicates whether positions under this job profile are eligible for shift differential pay (e.g., night shift, weekend premium).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:softSkillsRequired rdf:type rdf:Property ;
    rdfs:label 'Soft Skills Required' ;
    rdfs:comment 'Comma-separated list of interpersonal and behavioral competencies required for this job profile (e.g., \'Leadership, Communication, Problem Solving, Teamwork, Attention to Detail\').' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successionPlanningCritical rdf:type rdf:Property ;
    rdfs:label 'Succession Planning Critical' ;
    rdfs:comment 'Indicates whether this job profile is designated as critical for succession planning and talent pipeline development.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technicalSkillsRequired rdf:type rdf:Property ;
    rdfs:label 'Technical Skills Required' ;
    rdfs:comment 'Comma-separated list of technical skills and competencies required for this job profile (e.g., \'CNC Programming, PLC Troubleshooting, Welding, CAD, SAP MM, Statistical Process Control\').' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelRequirementPercentage rdf:type rdf:Property ;
    rdfs:label 'Travel Requirement Percentage' ;
    rdfs:comment 'Expected percentage of work time requiring business travel for this job profile (e.g., 10.00 represents 10% travel).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionEligible rdf:type rdf:Property ;
    rdfs:label 'Union Eligible' ;
    rdfs:comment 'Indicates whether positions under this job profile are eligible for union membership and collective bargaining representation.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:yearsExperienceMinimum rdf:type rdf:Property ;
    rdfs:label 'Years Experience Minimum' ;
    rdfs:comment 'Minimum number of years of relevant work experience required for this job profile.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:laborAgreementId rdf:type rdf:Property ;
    rdfs:label 'Labor Agreement Id' ;
    rdfs:comment 'Primary key for labor_agreement' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Agreement Document Url' ;
    rdfs:comment 'URL or file path to the full legal text of the labor agreement. Links to document management system or shared repository.' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementNotes rdf:type rdf:Property ;
    rdfs:label 'Agreement Notes' ;
    rdfs:comment 'Free-text field for additional notes, special provisions, or context about the agreement not captured in structured fields.' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualWageIncreasePercentage rdf:type rdf:Property ;
    rdfs:label 'Annual Wage Increase Percentage' ;
    rdfs:comment 'Negotiated annual percentage increase in base wages. May be fixed or tied to cost-of-living adjustments (COLA).' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arbitrationClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Arbitration Clause Flag' ;
    rdfs:comment 'Indicates whether the agreement includes binding arbitration as the final step in the grievance process.' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bargainingUnitCode rdf:type rdf:Property ;
    rdfs:label 'Bargaining Unit Code' ;
    rdfs:comment 'Code identifying the bargaining unit or employee group covered by this agreement. Used for payroll, benefits administration, and labor cost allocation.' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseWageScaleReference rdf:type rdf:Property ;
    rdfs:label 'Base Wage Scale Reference' ;
    rdfs:comment 'Reference to the wage scale or pay table defined in the agreement. Links to detailed wage schedules by job classification and seniority.' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colaProvisionFlag rdf:type rdf:Property ;
    rdfs:label 'Cola Provision Flag' ;
    rdfs:comment 'Indicates whether the agreement includes a cost-of-living adjustment provision that ties wage increases to inflation indices.' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coveredEmployeeGroup rdf:type rdf:Property ;
    rdfs:label 'Covered Employee Group' ;
    rdfs:comment 'Description of the employee population covered by this agreement. May reference job families, locations, business units, or other grouping criteria.' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grievanceProcedureSummary rdf:type rdf:Property ;
    rdfs:label 'Grievance Procedure Summary' ;
    rdfs:comment 'Summary of the multi-step grievance and arbitration process defined in the agreement for resolving disputes between management and union.' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthBenefitsSummary rdf:type rdf:Property ;
    rdfs:label 'Health Benefits Summary' ;
    rdfs:comment 'Summary of health insurance, medical, dental, and vision benefits provided under the agreement, including employer contribution levels.' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobSecurityClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Job Security Clause Flag' ;
    rdfs:comment 'Indicates whether the agreement includes job security provisions such as no-layoff guarantees, advance notice requirements, or severance terms.' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadNegotiatorName rdf:type rdf:Property ;
    rdfs:label 'Lead Negotiator Name' ;
    rdfs:comment 'Name of the primary management representative who led negotiations for this agreement. Used for accountability and historical reference.' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementRightsClause rdf:type rdf:Property ;
    rdfs:label 'Management Rights Clause' ;
    rdfs:comment 'Text or summary of the management rights clause, which reserves certain decision-making authority to the employer outside the scope of collective bargaining.' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Negotiation Completion Date' ;
    rdfs:comment 'Date when negotiations concluded and a tentative agreement was reached, prior to ratification.' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:negotiationStartDate rdf:type rdf:Property ;
    rdfs:label 'Negotiation Start Date' ;
    rdfs:comment 'Date when formal negotiations for this agreement began. Used for tracking negotiation timelines and labor relations history.' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:noStrikeClauseFlag rdf:type rdf:Property ;
    rdfs:label 'No Strike Clause Flag' ;
    rdfs:comment 'Indicates whether the agreement includes a no-strike provision prohibiting work stoppages during the term of the contract.' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paidHolidaysCount rdf:type rdf:Property ;
    rdfs:label 'Paid Holidays Count' ;
    rdfs:comment 'Number of paid holidays per year guaranteed under the agreement. Supports benefits administration and labor cost planning.' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pensionPlanReference rdf:type rdf:Property ;
    rdfs:label 'Pension Plan Reference' ;
    rdfs:comment 'Reference to the pension or retirement plan covered by this agreement. May link to defined benefit or defined contribution plan documents.' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantLocationCode rdf:type rdf:Property ;
    rdfs:label 'Plant Location Code' ;
    rdfs:comment 'Code identifying the manufacturing plant or facility where this agreement applies. Supports multi-site labor relations management.' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratificationApprovalPercentage rdf:type rdf:Property ;
    rdfs:label 'Ratification Approval Percentage' ;
    rdfs:comment 'Percentage of votes in favor of ratifying the agreement. Expressed as a decimal (e.g., 87.50 for 87.5%).' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratificationDate rdf:type rdf:Property ;
    rdfs:label 'Ratification Date' ;
    rdfs:comment 'Date when the agreement was formally ratified by union membership vote or other approval process. Critical for legal enforceability.' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratificationVoteCount rdf:type rdf:Property ;
    rdfs:label 'Ratification Vote Count' ;
    rdfs:comment 'Total number of votes cast in the ratification vote. Used for transparency and compliance documentation.' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reopenerClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Reopener Clause Flag' ;
    rdfs:comment 'Indicates whether the agreement includes a reopener clause allowing renegotiation of specific terms (e.g., wages) before the contract expiration date.' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyProvisionsSummary rdf:type rdf:Property ;
    rdfs:label 'Safety Provisions Summary' ;
    rdfs:comment 'Summary of occupational health and safety provisions, including personal protective equipment (PPE) requirements, safety committee structure, and hazard reporting procedures.' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seniorityRuleDescription rdf:type rdf:Property ;
    rdfs:label 'Seniority Rule Description' ;
    rdfs:comment 'Description of seniority provisions governing layoffs, recalls, promotions, shift bidding, and vacation scheduling as defined in the agreement.' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftDifferentialAmount rdf:type rdf:Property ;
    rdfs:label 'Shift Differential Amount' ;
    rdfs:comment 'Additional compensation per hour for non-standard shifts (e.g., night shift, weekend shift) as defined in the agreement.' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subcontractingRestrictions rdf:type rdf:Property ;
    rdfs:label 'Subcontracting Restrictions' ;
    rdfs:comment 'Description of any restrictions on the employers ability to subcontract work covered by the bargaining unit, protecting union jobs.' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successorClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Successor Clause Flag' ;
    rdfs:comment 'Indicates whether the agreement includes a successor clause requiring a new owner to honor the existing labor agreement in the event of a business sale or merger.' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionDuesDeductionFlag rdf:type rdf:Property ;
    rdfs:label 'Union Dues Deduction Flag' ;
    rdfs:comment 'Indicates whether the employer is required to deduct union dues from employee paychecks and remit them to the union (checkoff provision).' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionLocalNumber rdf:type rdf:Property ;
    rdfs:label 'Union Local Number' ;
    rdfs:comment 'Local chapter or branch number of the union. Used to identify the specific union local that negotiated and is covered by this agreement.' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionName rdf:type rdf:Property ;
    rdfs:label 'Union Name' ;
    rdfs:comment 'Name of the labor union or bargaining unit that is party to this agreement. Null for individual labor agreements not involving a union.' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionSecurityClauseType rdf:type rdf:Property ;
    rdfs:label 'Union Security Clause Type' ;
    rdfs:comment 'Type of union security provision in the agreement. Defines whether union membership or dues payment is required as a condition of employment.' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vacationAccrualRate rdf:type rdf:Property ;
    rdfs:label 'Vacation Accrual Rate' ;
    rdfs:comment 'Rate at which vacation time accrues per pay period or year of service, as defined in the agreement. Expressed in hours per year or similar unit.' ;
    rdfs:domain ind:LaborAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Parent Org Unit Id' ;
    rdfs:comment 'Reference to the parent organizational unit in the hierarchy. Null for top-level corporate entity. Enables multi-level hierarchical structures.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:budgetAmountAnnual rdf:type rdf:Property ;
    rdfs:label 'Budget Amount Annual' ;
    rdfs:comment 'Annual operating budget allocated to this organizational unit in base currency. Used for financial planning and variance analysis.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessFunction rdf:type rdf:Property ;
    rdfs:label 'Business Function' ;
    rdfs:comment 'Primary business function or operational area of this organizational unit. Used for functional reporting and cross-functional analysis. [ENUM-REF-CANDIDATE: production|quality|maintenance|engineering|supply_chain|sales|finance|hr|it|r_and_d — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUtilizationTargetPct rdf:type rdf:Property ;
    rdfs:label 'Capacity Utilization Target Pct' ;
    rdfs:comment 'Target capacity utilization percentage for production organizational units. Used for Overall Equipment Effectiveness (OEE) and Key Performance Indicator (KPI) tracking.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalCertificationIso14001 rdf:type rdf:Property ;
    rdfs:label 'Environmental Certification Iso14001' ;
    rdfs:comment 'Indicates whether this organizational unit holds ISO 14001 environmental management system certification. Used for environmental compliance reporting.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalCode rdf:type rdf:Property ;
    rdfs:label 'External Code' ;
    rdfs:comment 'Identifier used in external systems or legacy systems for data integration and cross-system reconciliation.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountActual rdf:type rdf:Property ;
    rdfs:label 'Headcount Actual' ;
    rdfs:comment 'Current actual number of employees assigned to this organizational unit. Updated from employee assignment transactions.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headcountPlanned rdf:type rdf:Property ;
    rdfs:label 'Headcount Planned' ;
    rdfs:comment 'Planned or budgeted number of employees for this organizational unit. Used for workforce planning and budget variance analysis.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isProductionUnit rdf:type rdf:Property ;
    rdfs:label 'Is Production Unit' ;
    rdfs:comment 'Indicates whether this organizational unit is directly involved in manufacturing production activities. Used for production reporting and Manufacturing Execution System (MES) integration.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orgUnitCode rdf:type rdf:Property ;
    rdfs:label 'Org Unit Code' ;
    rdfs:comment 'Business identifier code for the organizational unit used across enterprise systems. Typically alphanumeric code assigned by ERP system.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitDescription rdf:type rdf:Property ;
    rdfs:label 'Org Unit Description' ;
    rdfs:comment 'Detailed description of the organizational units purpose, responsibilities, and scope of operations.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitName rdf:type rdf:Property ;
    rdfs:label 'Org Unit Name' ;
    rdfs:comment 'Full name of the organizational unit (e.g., \'Assembly Line 3\', \'Quality Control Department\', \'North American Division\').' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitStatus rdf:type rdf:Property ;
    rdfs:label 'Org Unit Status' ;
    rdfs:comment 'Current lifecycle status of the organizational unit. Active units are operational and can have employees assigned. Planned units are future entities not yet operational.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitType rdf:type rdf:Property ;
    rdfs:label 'Org Unit Type' ;
    rdfs:comment 'Classification of the organizational unit within the enterprise hierarchy. Defines the level and function of the unit.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCertificationIso9001 rdf:type rdf:Property ;
    rdfs:label 'Quality Certification Iso9001' ;
    rdfs:comment 'Indicates whether this organizational unit holds ISO 9001 quality management system certification. Required for quality compliance reporting.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated name or acronym for the organizational unit used in reports and displays.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionRepresentation rdf:type rdf:Property ;
    rdfs:label 'Union Representation' ;
    rdfs:comment 'Indicates whether this organizational unit has union representation. Used for labor relations and collective bargaining agreement compliance.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payrollResultId rdf:type rdf:Property ;
    rdfs:label 'Payroll Result Id' ;
    rdfs:comment 'Unique identifier for the payroll calculation result record. Primary key.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payrollRunId rdf:type rdf:Property ;
    rdfs:label 'Payroll Run Id' ;
    rdfs:comment 'Identifier of the payroll processing batch or run that generated this result. Used for traceability and audit purposes.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Run .

ind:primaryPayrollEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Payroll Employee Id' ;
    rdfs:comment 'Unique identifier of the employee for whom this payroll result was calculated. Links to employee master data in Workday HCM.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allowanceAmount rdf:type rdf:Property ;
    rdfs:label 'Allowance Amount' ;
    rdfs:comment 'Total allowances paid to the employee (housing, transportation, meal allowances, etc.).' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankAccountLastFour rdf:type rdf:Property ;
    rdfs:label 'Bank Account Last Four' ;
    rdfs:comment 'Last four digits of the bank account number used for direct deposit payment. Stored for verification purposes only.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basePayAmount rdf:type rdf:Property ;
    rdfs:label 'Base Pay Amount' ;
    rdfs:comment 'The base salary or hourly wage earnings for the pay period before any additional earnings or deductions.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Amount' ;
    rdfs:comment 'One-time or periodic bonus payments included in this payroll result (performance bonus, retention bonus, etc.).' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capexAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Capex Allocation Percentage' ;
    rdfs:comment 'Percentage of total labor cost allocated to capital expenditure projects for this pay period. Used for financial capitalization of labor costs.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionAmount rdf:type rdf:Property ;
    rdfs:label 'Commission Amount' ;
    rdfs:comment 'Sales commission or incentive earnings included in this payroll result.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerBenefitsCostAmount rdf:type rdf:Property ;
    rdfs:label 'Employer Benefits Cost Amount' ;
    rdfs:comment 'Total employer-paid benefits costs (employer contribution to health insurance, retirement matching, etc.) for this payroll result. Used for total labor cost calculation.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Employer Tax Amount' ;
    rdfs:comment 'Total employer-paid payroll taxes (employer portion of Social Security, Medicare, unemployment insurance, etc.) for this payroll result. Used for CapEx/OpEx labor cost allocation.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:federalTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Federal Tax Amount' ;
    rdfs:comment 'Federal income tax withheld from the employee\'s gross pay for this pay period.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:garnishmentAmount rdf:type rdf:Property ;
    rdfs:label 'Garnishment Amount' ;
    rdfs:comment 'Court-ordered wage garnishments deducted from gross pay (child support, tax levies, creditor garnishments).' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossPayAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Pay Amount' ;
    rdfs:comment 'Total earnings before any deductions. Sum of base pay, overtime, bonuses, commissions, allowances, and other earnings.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:healthInsuranceDeductionAmount rdf:type rdf:Property ;
    rdfs:label 'Health Insurance Deduction Amount' ;
    rdfs:comment 'Employee contribution to health insurance premiums deducted from gross pay.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Local Tax Amount' ;
    rdfs:comment 'Local or municipal tax withheld from the employee\'s gross pay for this pay period.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medicareTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Medicare Tax Amount' ;
    rdfs:comment 'Medicare tax withheld from the employee\'s gross pay for this pay period.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPayAmount rdf:type rdf:Property ;
    rdfs:label 'Net Pay Amount' ;
    rdfs:comment 'The final take-home pay amount after all deductions. This is the amount paid to the employee.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:opexAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Opex Allocation Percentage' ;
    rdfs:comment 'Percentage of total labor cost allocated to operational expenditure for this pay period. Used for financial expense reporting.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherBenefitsDeductionAmount rdf:type rdf:Property ;
    rdfs:label 'Other Benefits Deduction Amount' ;
    rdfs:comment 'Total deductions for other employee benefits (dental, vision, life insurance, disability insurance, etc.).' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherDeductionAmount rdf:type rdf:Property ;
    rdfs:label 'Other Deduction Amount' ;
    rdfs:comment 'Total of all other miscellaneous deductions not categorized above (loan repayments, charitable contributions, etc.).' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeHoursWorked rdf:type rdf:Property ;
    rdfs:label 'Overtime Hours Worked' ;
    rdfs:comment 'Total overtime hours worked by the employee during the pay period.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimePayAmount rdf:type rdf:Property ;
    rdfs:label 'Overtime Pay Amount' ;
    rdfs:comment 'Total overtime earnings for the pay period, calculated based on hours worked beyond standard schedule.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidTimeOffHours rdf:type rdf:Property ;
    rdfs:label 'Paid Time Off Hours' ;
    rdfs:comment 'Total paid time off hours (vacation, sick leave, personal days) used during the pay period.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payGroup rdf:type rdf:Property ;
    rdfs:label 'Pay Group' ;
    rdfs:comment 'The pay group to which the employee belongs, determining pay schedule and processing rules.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period End Date' ;
    rdfs:comment 'The last date of the pay period covered by this payroll result.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period Start Date' ;
    rdfs:comment 'The first date of the pay period covered by this payroll result.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payrollCalculationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Payroll Calculation Timestamp' ;
    rdfs:comment 'The date and time when this payroll result was calculated by the payroll system.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:payrollStatus rdf:type rdf:Property ;
    rdfs:label 'Payroll Status' ;
    rdfs:comment 'Current lifecycle status of the payroll result indicating its processing stage.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regularHoursWorked rdf:type rdf:Property ;
    rdfs:label 'Regular Hours Worked' ;
    rdfs:comment 'Total regular hours worked by the employee during the pay period, excluding overtime.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retirementContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Retirement Contribution Amount' ;
    rdfs:comment 'Employee contribution to retirement savings plan (401k, pension) deducted from gross pay.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Shift Premium Amount' ;
    rdfs:comment 'Additional compensation for working non-standard shifts (night shift, weekend shift) as per labor agreements.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialSecurityTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Social Security Tax Amount' ;
    rdfs:comment 'Social Security (FICA) tax withheld from the employee\'s gross pay for this pay period.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stateTaxAmount rdf:type rdf:Property ;
    rdfs:label 'State Tax Amount' ;
    rdfs:comment 'State income tax withheld from the employee\'s gross pay for this pay period.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDeductionAmount rdf:type rdf:Property ;
    rdfs:label 'Total Deduction Amount' ;
    rdfs:comment 'Sum of all deductions (taxes, benefits, garnishments, etc.) subtracted from gross pay.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLaborCostAmount rdf:type rdf:Property ;
    rdfs:label 'Total Labor Cost Amount' ;
    rdfs:comment 'Total fully-loaded labor cost including gross pay, employer taxes, and employer benefits. Used for CapEx/OpEx allocation and financial reporting.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unionDuesAmount rdf:type rdf:Property ;
    rdfs:label 'Union Dues Amount' ;
    rdfs:comment 'Union membership dues deducted from gross pay as per collective bargaining agreement.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceReviewId rdf:type rdf:Property ;
    rdfs:label 'Performance Review Id' ;
    rdfs:comment 'Unique identifier for the performance review record. Primary key.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPerformanceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Performance Employee Id' ;
    rdfs:comment 'Unique identifier of the employee being reviewed. Links to employee master data.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reviewer Employee Id' ;
    rdfs:comment 'Unique identifier of the manager or supervisor conducting the performance review.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:competencyRating rdf:type rdf:Property ;
    rdfs:label 'Competency Rating' ;
    rdfs:comment 'Rating reflecting the employees demonstration of core competencies and behavioral skills (expert, proficient, developing, basic, not demonstrated).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyScore rdf:type rdf:Property ;
    rdfs:label 'Competency Score' ;
    rdfs:comment 'Numeric score representing competency assessment, typically on a scale (e.g., 1.0 to 5.0).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceTrainingCompleted rdf:type rdf:Property ;
    rdfs:label 'Compliance Training Completed' ;
    rdfs:comment 'Flag indicating whether the employee completed all required compliance training during the review period, relevant for ISO 45001 occupational health and safety compliance.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:departmentAtReview rdf:type rdf:Property ;
    rdfs:label 'Department At Review' ;
    rdfs:comment 'Department or organizational unit of the employee at the time the review was conducted.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developmentPlan rdf:type rdf:Property ;
    rdfs:label 'Development Plan' ;
    rdfs:comment 'Documented plan outlining specific development actions, training, and growth opportunities for the employee going forward.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeAcknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgement Date' ;
    rdfs:comment 'Date when the employee acknowledged receipt and review of their performance evaluation.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employeeAcknowledgementStatus rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgement Status' ;
    rdfs:comment 'Status indicating whether the employee has acknowledged the review (pending, acknowledged, disputed).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeRebuttalComments rdf:type rdf:Property ;
    rdfs:label 'Employee Rebuttal Comments' ;
    rdfs:comment 'Optional comments provided by the employee if they disagree with or wish to provide additional context to the performance review.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeSelfAssessment rdf:type rdf:Property ;
    rdfs:label 'Employee Self Assessment' ;
    rdfs:comment 'Employees self-evaluation narrative describing their own performance, accomplishments, and development needs during the review period.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalAchievementRating rdf:type rdf:Property ;
    rdfs:label 'Goal Achievement Rating' ;
    rdfs:comment 'Rating reflecting the employees achievement of individual goals and objectives set for the review period.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalAchievementScore rdf:type rdf:Property ;
    rdfs:label 'Goal Achievement Score' ;
    rdfs:comment 'Numeric score representing goal achievement performance, typically on a scale (e.g., 1.0 to 5.0).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jobProfileAtReview rdf:type rdf:Property ;
    rdfs:label 'Job Profile At Review' ;
    rdfs:comment 'Job profile or position title of the employee at the time the review was conducted.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationAtReview rdf:type rdf:Property ;
    rdfs:label 'Location At Review' ;
    rdfs:comment 'Work location or site of the employee at the time the review was conducted.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerComments rdf:type rdf:Property ;
    rdfs:label 'Manager Comments' ;
    rdfs:comment 'Detailed narrative comments and feedback provided by the reviewing manager regarding employee performance, strengths, and development areas.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meritIncreaseEligible rdf:type rdf:Property ;
    rdfs:label 'Merit Increase Eligible' ;
    rdfs:comment 'Flag indicating whether the employee is eligible for merit-based salary increase based on this performance review outcome.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overallRating rdf:type rdf:Property ;
    rdfs:label 'Overall Rating' ;
    rdfs:comment 'Overall performance rating assigned to the employee for the review period (exceeds expectations, meets expectations, needs improvement, unsatisfactory, outstanding).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallRatingScore rdf:type rdf:Property ;
    rdfs:label 'Overall Rating Score' ;
    rdfs:comment 'Numeric score representing the overall performance rating, typically on a scale (e.g., 1.0 to 5.0).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceImprovementPlanRequired rdf:type rdf:Property ;
    rdfs:label 'Performance Improvement Plan Required' ;
    rdfs:comment 'Flag indicating whether a formal Performance Improvement Plan is required due to unsatisfactory performance.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionRecommended rdf:type rdf:Property ;
    rdfs:label 'Promotion Recommended' ;
    rdfs:comment 'Flag indicating whether the reviewing manager recommends the employee for promotion based on performance.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Review Completion Date' ;
    rdfs:comment 'Date when the performance review was finalized and marked as complete.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewCycleYear rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Year' ;
    rdfs:comment 'Calendar year in which the performance review cycle occurred.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewLanguage rdf:type rdf:Property ;
    rdfs:label 'Review Language' ;
    rdfs:comment 'Language in which the performance review was conducted and documented, using ISO 639-2 three-letter codes. [ENUM-REF-CANDIDATE: ENG|SPA|FRA|DEU|ZHO|JPN|POR — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Review Period End Date' ;
    rdfs:comment 'End date of the performance evaluation period being assessed.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Period Start Date' ;
    rdfs:comment 'Start date of the performance evaluation period being assessed.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewTemplateName rdf:type rdf:Property ;
    rdfs:label 'Review Template Name' ;
    rdfs:comment 'Name of the performance review template or form used for this evaluation (e.g., standard annual review, leadership review).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Reviewer Signature Date' ;
    rdfs:comment 'Date when the reviewing manager signed or approved the performance review.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:secondLevelReviewerComments rdf:type rdf:Property ;
    rdfs:label 'Second Level Reviewer Comments' ;
    rdfs:comment 'Comments provided by the second-level reviewer regarding the performance evaluation.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successionPlanCandidate rdf:type rdf:Property ;
    rdfs:label 'Succession Plan Candidate' ;
    rdfs:comment 'Flag indicating whether the employee has been identified as a candidate for succession planning based on performance and potential.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supervisorPositionId rdf:type rdf:Property ;
    rdfs:label 'Supervisor Position Id' ;
    rdfs:comment 'Reference to the position that supervises this position in the organizational hierarchy.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:budgetedHeadcount rdf:type rdf:Property ;
    rdfs:label 'Budgeted Headcount' ;
    rdfs:comment 'Approved headcount allocation for this position in the annual budget, used for workforce planning and gap analysis.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalPositionFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Position Flag' ;
    rdfs:comment 'Indicates whether this position is classified as business-critical for succession planning and talent management purposes.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employmentCategory rdf:type rdf:Property ;
    rdfs:label 'Employment Category' ;
    rdfs:comment 'Employment category indicating the work schedule pattern: full-time, part-time, casual, or on-call.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptStatus rdf:type rdf:Property ;
    rdfs:label 'Exempt Status' ;
    rdfs:comment 'FLSA classification indicating whether the position is exempt or non-exempt from overtime pay requirements.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fteAllocation rdf:type rdf:Property ;
    rdfs:label 'Fte Allocation' ;
    rdfs:comment 'Full-time equivalent allocation for this position, representing the proportion of a full-time workload (e.g., 1.00 for full-time, 0.50 for half-time).' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isSafetySensitive rdf:type rdf:Property ;
    rdfs:label 'Is Safety Sensitive' ;
    rdfs:comment 'Indicates whether this position is classified as safety-sensitive, requiring additional health and safety compliance per ISO 45001 and OSHA regulations.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:justification rdf:type rdf:Property ;
    rdfs:label 'Justification' ;
    rdfs:comment 'Business justification for creating or maintaining this position, used for budget approval and workforce planning.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastFilledDate rdf:type rdf:Property ;
    rdfs:label 'Last Filled Date' ;
    rdfs:comment 'Date when this position was most recently filled by an employee. Null if never filled.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Minimum Education Level' ;
    rdfs:comment 'Minimum educational qualification required for this position (e.g., high school, associate degree, bachelor degree, master degree).' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumExperienceYears rdf:type rdf:Property ;
    rdfs:label 'Minimum Experience Years' ;
    rdfs:comment 'Minimum number of years of relevant work experience required for this position.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:positionCode rdf:type rdf:Property ;
    rdfs:label 'Position Code' ;
    rdfs:comment 'Business-assigned unique code for the position, used for external identification and reporting.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionDescription rdf:type rdf:Property ;
    rdfs:label 'Position Description' ;
    rdfs:comment 'Detailed description of the position responsibilities, duties, and key accountabilities.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionStatus rdf:type rdf:Property ;
    rdfs:label 'Position Status' ;
    rdfs:comment 'Current lifecycle status of the position indicating whether it is filled, vacant, frozen for budget reasons, pending approval, closed, or suspended.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionType rdf:type rdf:Property ;
    rdfs:label 'Position Type' ;
    rdfs:comment 'Classification of the position based on employment type: regular (permanent), temporary, contract, seasonal, or intern.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementPositionFlag rdf:type rdf:Property ;
    rdfs:label 'Replacement Position Flag' ;
    rdfs:comment 'Indicates whether this position is a replacement for a previously closed position or a net-new headcount addition.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresCertification rdf:type rdf:Property ;
    rdfs:label 'Requires Certification' ;
    rdfs:comment 'Indicates whether this position requires specific professional certifications, licenses, or qualifications to perform the role.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vacancyStartDate rdf:type rdf:Property ;
    rdfs:label 'Vacancy Start Date' ;
    rdfs:comment 'Date when this position became vacant, used for time-to-fill metrics and workforce gap analysis.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workScheduleHours rdf:type rdf:Property ;
    rdfs:label 'Work Schedule Hours' ;
    rdfs:comment 'Standard number of hours per week assigned to this position for scheduling and labor tracking purposes.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Last Modified By Employee Id' ;
    rdfs:comment 'Reference to the employee who last modified the requisition record.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:requisitionApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Requisition Approved By Employee Id' ;
    rdfs:comment 'Reference to the employee who approved the requisition for opening.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:requisitionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Requisition Employee Id' ;
    rdfs:comment 'Reference to the employee who is the hiring manager responsible for this requisition.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:requisitionRecruiterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Requisition Recruiter Employee Id' ;
    rdfs:comment 'Reference to the HR recruiter assigned to manage the candidate pipeline for this requisition.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicantCount rdf:type rdf:Property ;
    rdfs:label 'Applicant Count' ;
    rdfs:comment 'Total number of candidates who have applied to this requisition.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backgroundCheckRequired rdf:type rdf:Property ;
    rdfs:label 'Background Check Required' ;
    rdfs:comment 'Indicates whether a background check is mandatory for candidates selected for this position.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalPostingOnly rdf:type rdf:Property ;
    rdfs:label 'Internal Posting Only' ;
    rdfs:comment 'Indicates whether the requisition is restricted to internal candidates only.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfOpenings rdf:type rdf:Property ;
    rdfs:label 'Number Of Openings' ;
    rdfs:comment 'Total number of positions to be filled under this requisition.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openedDate rdf:type rdf:Property ;
    rdfs:label 'Opened Date' ;
    rdfs:comment 'Date when the requisition was officially opened and approved for recruiting.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:positionsFilled rdf:type rdf:Property ;
    rdfs:label 'Positions Filled' ;
    rdfs:comment 'Number of positions that have been successfully filled under this requisition.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postingDescription rdf:type rdf:Property ;
    rdfs:label 'Posting Description' ;
    rdfs:comment 'Detailed description of the role, responsibilities, and qualifications for external job postings.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingEndDate rdf:type rdf:Property ;
    rdfs:label 'Posting End Date' ;
    rdfs:comment 'Date when the job posting is scheduled to be removed from public visibility.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postingStartDate rdf:type rdf:Property ;
    rdfs:label 'Posting Start Date' ;
    rdfs:comment 'Date when the job posting becomes publicly visible on job boards and career sites.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postingTitle rdf:type rdf:Property ;
    rdfs:label 'Posting Title' ;
    rdfs:comment 'Public-facing job title used in external job postings and advertisements.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Requisition Number' ;
    rdfs:comment 'Business identifier for the requisition, externally visible and used for tracking and communication.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Requisition Status' ;
    rdfs:comment 'Current lifecycle status of the requisition indicating its progress through the recruiting workflow.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionType rdf:type rdf:Property ;
    rdfs:label 'Requisition Type' ;
    rdfs:comment 'Classification of the requisition indicating whether it is for a new position, replacement, or other hiring scenario.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryRangeMax rdf:type rdf:Property ;
    rdfs:label 'Salary Range Max' ;
    rdfs:comment 'Maximum annual salary or hourly rate for the position in local currency.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salaryRangeMin rdf:type rdf:Property ;
    rdfs:label 'Salary Range Min' ;
    rdfs:comment 'Minimum annual salary or hourly rate for the position in local currency.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:screeningRequired rdf:type rdf:Property ;
    rdfs:label 'Screening Required' ;
    rdfs:comment 'Indicates whether formal candidate screening or assessment is required for this requisition.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:securityClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Security Clearance Required' ;
    rdfs:comment 'Indicates whether the position requires a security clearance or special authorization.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourcingChannel rdf:type rdf:Property ;
    rdfs:label 'Sourcing Channel' ;
    rdfs:comment 'Primary channel or method used to source candidates for this requisition. [ENUM-REF-CANDIDATE: internal|external|referral|agency|campus|job_board|social_media — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStartDate rdf:type rdf:Property ;
    rdfs:label 'Target Start Date' ;
    rdfs:comment 'Desired date for the selected candidate to begin employment.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:timeToFillDays rdf:type rdf:Property ;
    rdfs:label 'Time To Fill Days' ;
    rdfs:comment 'Number of calendar days from requisition opening to position being filled, used for recruiting KPI tracking.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shiftScheduleId rdf:type rdf:Property ;
    rdfs:label 'Shift Schedule Id' ;
    rdfs:comment 'Unique identifier for the shift schedule record. Primary key for the shift schedule entity.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryShiftEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Shift Employee Id' ;
    rdfs:comment 'Unique identifier of the employee assigned to this shift. Links to the employee master record in Workday HCM.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:shiftPatternId rdf:type rdf:Property ;
    rdfs:label 'Shift Pattern Id' ;
    rdfs:comment 'Unique identifier of the shift pattern template applied to this schedule (e.g., 3-shift rotation, 4-on-4-off). Links to shift pattern reference data.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShiftPattern .

ind:cancelledDatetime rdf:type rdf:Property ;
    rdfs:label 'Cancelled Datetime' ;
    rdfs:comment 'Date and time when the shift schedule was cancelled. Populated only when schedule_status is cancelled. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmedDatetime rdf:type rdf:Property ;
    rdfs:label 'Confirmed Datetime' ;
    rdfs:comment 'Date and time when the employee acknowledged or confirmed the shift assignment. Used for tracking employee acceptance and attendance planning. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:createdDatetime rdf:type rdf:Property ;
    rdfs:label 'Created Datetime' ;
    rdfs:comment 'Date and time when this shift schedule record was first created in the system. Used for audit trail and data lineage. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isHoliday rdf:type rdf:Property ;
    rdfs:label 'Is Holiday' ;
    rdfs:comment 'Boolean flag indicating whether the shift occurs on a recognized company or statutory holiday. Used for premium pay calculation and compliance reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNightShift rdf:type rdf:Property ;
    rdfs:label 'Is Night Shift' ;
    rdfs:comment 'Boolean flag indicating whether the shift occurs during night hours (typically 10 PM to 6 AM). Used for shift differential pay and occupational health compliance.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWeekend rdf:type rdf:Property ;
    rdfs:label 'Is Weekend' ;
    rdfs:comment 'Boolean flag indicating whether the shift occurs on a weekend (Saturday or Sunday). Used for premium pay calculation and workforce analytics.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborCostCenter rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Center' ;
    rdfs:comment 'Cost center code to which labor hours and costs for this shift are allocated. Used for financial reporting and cost accounting in SAP S/4HANA CO.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedDatetime rdf:type rdf:Property ;
    rdfs:label 'Modified Datetime' ;
    rdfs:comment 'Date and time when this shift schedule record was last modified. Used for audit trail and change tracking. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:netProductiveHours rdf:type rdf:Property ;
    rdfs:label 'Net Productive Hours' ;
    rdfs:comment 'Net available labor hours after deducting break time from scheduled duration. Used for capacity planning and Overall Equipment Effectiveness (OEE) calculations.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publishedDatetime rdf:type rdf:Property ;
    rdfs:label 'Published Datetime' ;
    rdfs:comment 'Date and time when the shift schedule was published and communicated to the employee. Used for compliance with advance notice requirements. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduleDate rdf:type rdf:Property ;
    rdfs:label 'Schedule Date' ;
    rdfs:comment 'Calendar date on which the shift occurs. Used for day-level aggregation and reporting. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleExceptionFlag rdf:type rdf:Property ;
    rdfs:label 'Schedule Exception Flag' ;
    rdfs:comment 'Boolean flag indicating whether this shift has any exceptions or deviations from the standard shift pattern (e.g., early start, late end, split shift).' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduleMonth rdf:type rdf:Property ;
    rdfs:label 'Schedule Month' ;
    rdfs:comment 'Month number (1-12) of the scheduled shift. Used for monthly labor cost allocation and workforce planning.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduleWeek rdf:type rdf:Property ;
    rdfs:label 'Schedule Week' ;
    rdfs:comment 'ISO week number of the year for the scheduled shift. Used for weekly labor planning and reporting.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduleYear rdf:type rdf:Property ;
    rdfs:label 'Schedule Year' ;
    rdfs:comment 'Calendar year of the scheduled shift. Used for annual labor reporting and compliance.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledDurationHours rdf:type rdf:Property ;
    rdfs:label 'Scheduled Duration Hours' ;
    rdfs:comment 'Total planned duration of the shift in hours, calculated as the difference between scheduled end and start datetime. Used for labor capacity planning and payroll calculation.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Datetime' ;
    rdfs:comment 'Planned end date and time of the shift. Represents the clock-out time for the employee at the assigned work center. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Datetime' ;
    rdfs:comment 'Planned start date and time of the shift. Represents the clock-in time for the employee at the assigned work center. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:schedulingHorizonWeeks rdf:type rdf:Property ;
    rdfs:label 'Scheduling Horizon Weeks' ;
    rdfs:comment 'Number of weeks in advance that this shift was scheduled. Used for workforce planning analytics and compliance with advance notice regulations.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shiftPriority rdf:type rdf:Property ;
    rdfs:label 'Shift Priority' ;
    rdfs:comment 'Business priority level of the shift assignment. Critical shifts support high-priority production orders; high-priority shifts support key customer deliveries; normal shifts are standard operations; low-priority shifts are for non-urgent tasks.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillRequirement rdf:type rdf:Property ;
    rdfs:label 'Skill Requirement' ;
    rdfs:comment 'Required skill or certification for the employee to perform this shift (e.g., CNC Operator, Forklift Certified, Quality Inspector). Used for skill-based scheduling and compliance.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeEntryId rdf:type rdf:Property ;
    rdfs:label 'Time Entry Id' ;
    rdfs:comment 'Unique identifier for the time entry record. Primary key for the time entry transaction.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTimeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Time Employee Id' ;
    rdfs:comment 'Unique identifier of the employee who recorded this time entry. Links to the employee master record in Workday HCM.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryTimeModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Time Modified By Employee Id' ;
    rdfs:comment 'Unique identifier of the user or employee who last modified this time entry record. Used for audit trail and accountability.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:absenceType rdf:type rdf:Property ;
    rdfs:label 'Absence Type' ;
    rdfs:comment 'Type of paid or unpaid absence if this time entry represents non-working time. Set to \'none\' for regular working time entries. [ENUM-REF-CANDIDATE: none|sick_leave|vacation|personal|bereavement|jury_duty|training|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clockInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clock In Timestamp' ;
    rdfs:comment 'The exact date and time when the employee clocked in or started work for this time entry. Captured from MES shop floor terminals or Workday HCM time tracking.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:clockOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clock Out Timestamp' ;
    rdfs:comment 'The exact date and time when the employee clocked out or ended work for this time entry. Used to calculate total hours worked.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceVerified rdf:type rdf:Property ;
    rdfs:label 'Compliance Verified' ;
    rdfs:comment 'Indicates whether this time entry has been verified for compliance with labor regulations, union agreements, and ISO 45001 occupational health and safety requirements (e.g., maximum consecutive hours, mandatory rest periods).' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceptionNotes rdf:type rdf:Property ;
    rdfs:label 'Exception Notes' ;
    rdfs:comment 'Free-text notes or comments explaining any time entry exception, correction, or special circumstance. Used for audit trail and dispute resolution.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborRate rdf:type rdf:Property ;
    rdfs:label 'Labor Rate' ;
    rdfs:comment 'The hourly labor rate applied to this time entry for cost calculation purposes. May differ from actual employee pay rate for standard costing purposes.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborType rdf:type rdf:Property ;
    rdfs:label 'Labor Type' ;
    rdfs:comment 'Classification of the labor time for payroll and costing purposes. Determines the pay rate multiplier and labor cost calculation method.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oeeProductiveTime rdf:type rdf:Property ;
    rdfs:label 'Oee Productive Time' ;
    rdfs:comment 'Indicates whether this time entry represents productive manufacturing time that should be included in OEE (Overall Equipment Effectiveness) labor efficiency calculations. False for indirect labor, breaks, or non-productive activities.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payrollProcessed rdf:type rdf:Property ;
    rdfs:label 'Payroll Processed' ;
    rdfs:comment 'Indicates whether this time entry has been processed and included in a payroll run. Once true, the time entry is locked from further edits.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeEntrySource rdf:type rdf:Property ;
    rdfs:label 'Time Entry Source' ;
    rdfs:comment 'The system or method through which this time entry was captured (e.g., MES shop floor terminal, Workday mobile app, manual supervisor entry).' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCourseId rdf:type rdf:Property ;
    rdfs:label 'Training Course Id' ;
    rdfs:comment 'Unique identifier for the training course. Primary key for the training course master catalog.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:instructorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Instructor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Training management tracks internal instructors delivering courses to ensure qualification and cost allocation.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ownerOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Owner Org Unit Id' ;
    rdfs:comment 'Foreign key linking to workforce.org_unit. Business justification: Each training course is owned by a department; linking to org_unit provides hierarchy and removes redundant owner_department string.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:accreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Accreditation Number' ;
    rdfs:comment 'Official accreditation or approval number issued by the regulatory body or industry association for the training course. Used for compliance audit trails.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentRequired rdf:type rdf:Property ;
    rdfs:label 'Assessment Required' ;
    rdfs:comment 'Indicates whether a formal assessment (test, exam, practical demonstration) is required to complete the course. True if assessment is mandatory; false if completion is based on attendance only.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationAwarded rdf:type rdf:Property ;
    rdfs:label 'Certification Awarded' ;
    rdfs:comment 'Indicates whether successful completion of the course results in a formal certification or credential being awarded to the employee.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costPerParticipant rdf:type rdf:Property ;
    rdfs:label 'Cost Per Participant' ;
    rdfs:comment 'Standard cost per employee for delivering the training course, including instructor fees, materials, facility costs, and external vendor charges. Used for training budget planning and labor cost allocation.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:courseCategory rdf:type rdf:Property ;
    rdfs:label 'Course Category' ;
    rdfs:comment 'Primary classification of the training course by subject area. Safety includes ISO 45001 and OSHA training; technical covers CNC, PLC, SCADA, welding; quality includes SPC, FMEA, PPAP; leadership covers management development; compliance covers regulatory requirements; operational covers MES, ERP, and process training.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseCode rdf:type rdf:Property ;
    rdfs:label 'Course Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the training course in the learning management system. Used for course catalog reference and enrollment processing.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseDescription rdf:type rdf:Property ;
    rdfs:label 'Course Description' ;
    rdfs:comment 'Detailed description of the training course content, learning objectives, target audience, and prerequisites.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseMaterialsUrl rdf:type rdf:Property ;
    rdfs:label 'Course Materials Url' ;
    rdfs:comment 'Web address or document management system link to access course materials, handouts, presentations, and reference documents.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseStatus rdf:type rdf:Property ;
    rdfs:label 'Course Status' ;
    rdfs:comment 'Current lifecycle status of the training course. Active courses are available for enrollment; inactive courses are temporarily unavailable; draft courses are under development; retired courses are no longer offered; under review courses are being updated or audited.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseTitle rdf:type rdf:Property ;
    rdfs:label 'Course Title' ;
    rdfs:comment 'Full descriptive title of the training course as displayed in the learning catalog and on certificates.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseType rdf:type rdf:Property ;
    rdfs:label 'Course Type' ;
    rdfs:comment 'Classification indicating whether the course is mandatory for specific roles, elective for employee development, or recommended for career progression.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseVersion rdf:type rdf:Property ;
    rdfs:label 'Course Version' ;
    rdfs:comment 'Version number of the training course content. Incremented when course materials, objectives, or assessments are updated. Used for version control and compliance tracking.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'Method by which the training course is delivered. Classroom is in-person instructor-led; e-learning is online self-paced; OJT (On-the-Job Training) is hands-on workplace training; blended combines multiple methods; virtual instructor-led is live online; self-paced is asynchronous learning.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructorRequired rdf:type rdf:Property ;
    rdfs:label 'Instructor Required' ;
    rdfs:comment 'Indicates whether the course requires a qualified instructor to deliver the training. True for classroom, OJT, and virtual instructor-led courses; false for self-paced e-learning.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxParticipants rdf:type rdf:Property ;
    rdfs:label 'Max Participants' ;
    rdfs:comment 'Maximum number of employees that can be enrolled in a single course session. Used for capacity planning and session scheduling. Null for unlimited enrollment courses such as self-paced e-learning.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minParticipants rdf:type rdf:Property ;
    rdfs:label 'Min Participants' ;
    rdfs:comment 'Minimum number of enrolled employees required to run a scheduled course session. Sessions below this threshold may be cancelled or rescheduled. Null for self-paced courses.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passingScore rdf:type rdf:Property ;
    rdfs:label 'Passing Score' ;
    rdfs:comment 'Minimum score required to successfully complete the course, expressed as a percentage (0-100). Used to determine pass/fail status and certification eligibility.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prerequisiteCourses rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Courses' ;
    rdfs:comment 'Comma-separated list of course codes that must be completed before enrolling in this course. Null if no prerequisites exist.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceIntervalMonths rdf:type rdf:Property ;
    rdfs:label 'Recurrence Interval Months' ;
    rdfs:comment 'Number of months between required course repetitions for recurrent training. Null if recurrence is not required. Common values include 12 (annual), 24 (biennial), or 36 (triennial) for safety and compliance training.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recurrenceRequired rdf:type rdf:Property ;
    rdfs:label 'Recurrence Required' ;
    rdfs:comment 'Indicates whether the training course must be repeated periodically to maintain competence or compliance. True for courses with expiration requirements such as safety training, regulatory compliance, or equipment certifications.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subjectMatterExpert rdf:type rdf:Property ;
    rdfs:label 'Subject Matter Expert' ;
    rdfs:comment 'Name of the subject matter expert responsible for course content accuracy and technical review. Used for course maintenance and update coordination.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudience rdf:type rdf:Property ;
    rdfs:label 'Target Audience' ;
    rdfs:comment 'Description of the intended audience for the training course, including job roles, departments, or skill levels. Used for course recommendation and enrollment planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workforceCertificationId rdf:type rdf:Property ;
    rdfs:label 'Workforce Certification Id' ;
    rdfs:comment 'Unique identifier for the workforce certification record. Primary key for the workforce certification entity.' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:typeId rdf:type rdf:Property ;
    rdfs:label 'Type Id' ;
    rdfs:comment 'Unique identifier of the certification type from the master catalog. Defines the regulatory, safety, or professional certification standard (e.g., ISO 45001, OSHA 10/30, forklift operator, electrical safety, AWS/ASME welding qualifications, quality auditor).' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CertificationType .

ind:certificationCategory rdf:type rdf:Property ;
    rdfs:label 'Certification Category' ;
    rdfs:comment 'High-level classification of the certification domain: safety (OSHA, ISO 45001), quality (ISO 9001, Six Sigma), technical (welding, electrical), regulatory (EPA, FDA), professional (PMP, CPA), or operational (forklift, crane operator).' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationCode rdf:type rdf:Property ;
    rdfs:label 'Certification Code' ;
    rdfs:comment 'Standardized code or abbreviation for the certification type used for internal classification and reporting (e.g., \'OSHA-30\', \'AWS-CWI\', \'ISO9001-LA\').' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentAuthorization rdf:type rdf:Property ;
    rdfs:label 'Equipment Authorization' ;
    rdfs:comment 'Comma-separated list of equipment types or asset classes the employee is authorized to operate or work on with this certification (e.g., \'Overhead Crane, Gantry Crane\', \'MIG Welder, TIG Welder\', \'High Voltage Switchgear\').' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinationDate rdf:type rdf:Property ;
    rdfs:label 'Examination Date' ;
    rdfs:comment 'Date on which the employee took the certification examination or assessment. Null if no examination is required.' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:examinationScore rdf:type rdf:Property ;
    rdfs:label 'Examination Score' ;
    rdfs:comment 'Numerical score or percentage achieved by the employee on the certification examination. Null if no examination is required or score is not recorded.' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issuingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the jurisdiction where the certification was issued (e.g., \'USA\', \'DEU\', \'CHN\').' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobRoleApplicability rdf:type rdf:Property ;
    rdfs:label 'Job Role Applicability' ;
    rdfs:comment 'Comma-separated list of job roles or job families for which this certification is required or recommended (e.g., \'Welder, Fabricator\', \'Quality Inspector, Auditor\', \'Forklift Operator, Material Handler\').' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Last Renewal Date' ;
    rdfs:comment 'Date of the most recent renewal or recertification event. Null if the certification has never been renewed.' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:passFailStatus rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Status' ;
    rdfs:comment 'Result of the certification examination or assessment: pass (met requirements), fail (did not meet requirements), pending (awaiting results), or not_applicable (no examination required).' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'Name of the regulatory standard or framework that mandates this certification (e.g., \'ISO 45001\', \'OSHA 1910.147\', \'IEC 61131\', \'EPA 40 CFR 112\'). Null for non-regulatory certifications.' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalCount rdf:type rdf:Property ;
    rdfs:label 'Renewal Count' ;
    rdfs:comment 'Total number of times this certification has been renewed for this employee. Zero for initial certifications that have not yet been renewed.' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingHoursCompleted rdf:type rdf:Property ;
    rdfs:label 'Training Hours Completed' ;
    rdfs:comment 'Number of training or continuing education hours the employee has completed toward this certification. Used to track progress for in-progress certifications.' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingHoursRequired rdf:type rdf:Property ;
    rdfs:label 'Training Hours Required' ;
    rdfs:comment 'Total number of training or continuing education hours required to obtain or maintain this certification. Null if not applicable.' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingProvider rdf:type rdf:Property ;
    rdfs:label 'Training Provider' ;
    rdfs:comment 'Name of the organization or institution that provided the training or preparation for this certification (e.g., \'Internal Training Center\', \'American Welding Society\', \'TUV Rheinland\'). May differ from the issuing authority.' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validityPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Validity Period Months' ;
    rdfs:comment 'Standard validity period of the certification in months from the issue date (e.g., 12, 24, 36). Null for lifetime certifications.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workLocationRestriction rdf:type rdf:Property ;
    rdfs:label 'Work Location Restriction' ;
    rdfs:comment 'Geographic or facility-level restrictions on where this certification is valid (e.g., \'USA only\', \'EU member states\', \'Plant 101 only\'). Null if valid globally.' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workforceCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Workforce Certification Status' ;
    rdfs:comment 'Current lifecycle status of the certification: active (valid and in effect), expired (past expiry date), suspended (temporarily invalid), revoked (permanently invalidated), pending (awaiting approval), or in_progress (training/testing underway).' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderAllocationId rdf:type rdf:Property ;
    rdfs:label 'Work Order Allocation Id' ;
    rdfs:comment 'Primary key for the work_order_allocation association' ;
    rdfs:domain ind:WorkOrderAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Allocation Timestamp' ;
    rdfs:comment 'Date and time when the allocation was created or last updated' ;
    rdfs:domain ind:WorkOrderAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:componentInstallationId rdf:type rdf:Property ;
    rdfs:label 'Component Installation Id' ;
    rdfs:comment 'Primary key for the component_installation association' ;
    rdfs:domain ind:ComponentInstallation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:installDate rdf:type rdf:Property ;
    rdfs:label 'Install Date' ;
    rdfs:comment 'Date when the component was installed on the equipment' ;
    rdfs:domain ind:ComponentInstallation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:installationStatus rdf:type rdf:Property ;
    rdfs:label 'Installation Status' ;
    rdfs:comment 'Current status of the installation record' ;
    rdfs:domain ind:ComponentInstallation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionOnEquipment rdf:type rdf:Property ;
    rdfs:label 'Position On Equipment' ;
    rdfs:comment 'Physical location or slot identifier on the equipment where the component is installed' ;
    rdfs:domain ind:ComponentInstallation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectMaterialAllocationId rdf:type rdf:Property ;
    rdfs:label 'Project Material Allocation Id' ;
    rdfs:comment 'Primary key for the project_material_allocation association' ;
    rdfs:domain ind:ProjectMaterialAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:opportunityComponentId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Component Id' ;
    rdfs:comment 'Primary key for the opportunity_component association' ;
    rdfs:domain ind:OpportunityComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedQuantity rdf:type rdf:Property ;
    rdfs:label 'Estimated Quantity' ;
    rdfs:comment 'Quantity of the component expected to be sold in the opportunity' ;
    rdfs:domain ind:OpportunityComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestLevel rdf:type rdf:Property ;
    rdfs:label 'Interest Level' ;
    rdfs:comment 'Qualitative level of interest (high, medium, low) expressed by the sales team for the component within the opportunity' ;
    rdfs:domain ind:OpportunityComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Target Delivery Date' ;
    rdfs:comment 'Planned delivery date for the component as promised in the opportunity' ;
    rdfs:domain ind:OpportunityComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:equipmentAllocationId rdf:type rdf:Property ;
    rdfs:label 'Equipment Allocation Id' ;
    rdfs:comment 'Primary key for the equipment_allocation association' ;
    rdfs:domain ind:EquipmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationEndDate rdf:type rdf:Property ;
    rdfs:label 'Allocation End Date' ;
    rdfs:comment 'Date when the equipment allocation ends for the order line' ;
