    rdfs:comment 'Weighted average score derived from checklist item results (0-100 scale).' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionDeadline rdf:type rdf:Property ;
