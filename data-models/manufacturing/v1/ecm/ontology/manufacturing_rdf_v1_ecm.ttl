ind:paymentTermId rdf:type rdf:Property ;
    rdfs:label 'Payment Term Id' ;
    rdfs:comment 'Foreign key linking to billing.payment_term. Business justification: Billing accounts use a payment term; linking to the payment_term master eliminates the free-text code and enforces referential integrity.' ;
    rdfs:domain ind:Manufacturing ;
