    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissioningChecklistStatus rdf:type rdf:Property ;
    rdfs:label 'Commissioning Checklist Status' ;
    rdfs:comment 'Current lifecycle state of the checklist.' ;
    rdfs:domain ind:CommissioningChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionDate rdf:type rdf:Property ;
