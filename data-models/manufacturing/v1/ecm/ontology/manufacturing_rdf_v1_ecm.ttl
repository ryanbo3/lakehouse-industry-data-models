ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Unique identifier for the invoice record.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:complianceProductCertificationId rdf:type rdf:Property ;
    rdfs:label 'Compliance Product Certification Id' ;
    rdfs:comment 'Foreign key linking to compliance.product_certification. Business justification: Certification bodies charge fees; invoices must reference the product certification they cover for traceability.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceProductCertification .

ind:creditNoteInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Credit Note Invoice Id' ;
    rdfs:comment 'Identifier of the related credit note, if this invoice is a credit note.' ;
