    rdfs:comment 'Number of manual control actions (e.g., start/stop) executed by the operator.' ;
    rdfs:domain ind:ScadaSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loginMethod rdf:type rdf:Property ;
    rdfs:label 'Login Method' ;
    rdfs:comment 'Authentication mechanism used for the session.' ;
    rdfs:domain ind:ScadaSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loginTimestamp rdf:type rdf:Property ;
    rdfs:label 'Login Timestamp' ;
    rdfs:comment 'Date-time when the operator successfully logged into the SCADA system.' ;
    rdfs:domain ind:ScadaSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:logoutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Logout Timestamp' ;
    rdfs:comment 'Date-time when the session ended, either by logout, timeout or forced termination.' ;
    rdfs:domain ind:ScadaSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:osVersion rdf:type rdf:Property ;
    rdfs:label 'Os Version' ;
    rdfs:comment 'Operating system version of the workstation hosting the SCADA client.' ;
    rdfs:domain ind:ScadaSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Session Duration Seconds' ;
    rdfs:comment 'Total length of the session measured in seconds (logout_timestamp – login_timestamp).' ;
    rdfs:domain ind:ScadaSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sessionIdentifier rdf:type rdf:Property ;
    rdfs:label 'Session Identifier' ;
    rdfs:comment 'Human-readable identifier or code for the session, often displayed in audit logs.' ;
    rdfs:domain ind:ScadaSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionNotes rdf:type rdf:Property ;
    rdfs:label 'Session Notes' ;
    rdfs:comment 'Free-form notes entered by the operator or system during the session.' ;
    rdfs:domain ind:ScadaSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionSource rdf:type rdf:Property ;
    rdfs:label 'Session Source' ;
    rdfs:comment 'Physical source of the session interface.' ;
    rdfs:domain ind:ScadaSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionStatus rdf:type rdf:Property ;
    rdfs:label 'Session Status' ;
    rdfs:comment 'Current lifecycle status of the session.' ;
    rdfs:domain ind:ScadaSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionType rdf:type rdf:Property ;
    rdfs:label 'Session Type' ;
    rdfs:comment 'Classification of the session purpose.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setpointChangeCount rdf:type rdf:Property ;
    rdfs:label 'Setpoint Change Count' ;
    rdfs:comment 'Number of setpoint modifications made by the operator.' ;
    rdfs:domain ind:ScadaSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Reason why the session was terminated.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userRole rdf:type rdf:Property ;
    rdfs:label 'User Role' ;
    rdfs:comment 'Role of the operator within the organization for this session.' ;
    rdfs:domain ind:ScadaSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workstationReference rdf:type rdf:Property ;
    rdfs:label 'Workstation Reference' ;
    rdfs:comment 'Identifier of the SCADA workstation or HMI panel used for the session.' ;
    rdfs:domain ind:ScadaSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:setpointChangeId rdf:type rdf:Property ;
    rdfs:label 'Setpoint Change Id' ;
    rdfs:comment 'Unique surrogate key for each setpoint change event.' ;
    rdfs:domain ind:SetpointChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalWorkflowId rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Id' ;
    rdfs:comment 'Identifier of the approval record when dual-authorization is required for safety-critical setpoint changes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApprovalWorkflow .

ind:changeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Change Reason Code' ;
    rdfs:comment 'Standardized code describing the business reason for the setpoint modification.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeStatus rdf:type rdf:Property ;
    rdfs:label 'Change Status' ;
    rdfs:comment 'Result of the setpoint change operation (e.g., completed, failed, pending).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comment rdf:type rdf:Property ;
    rdfs:label 'Comment' ;
    rdfs:comment 'Free-text field for operators or systems to add contextual notes about the change.' ;
    rdfs:domain ind:SetpointChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedByType rdf:type rdf:Property ;
    rdfs:label 'Initiated By Type' ;
    rdfs:comment 'Indicates whether the change was triggered by a human operator or an automated system.' ;
    rdfs:domain ind:SetpointChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isApproved rdf:type rdf:Property ;
    rdfs:label 'Is Approved' ;
    rdfs:comment 'Indicates whether the setpoint change has received required approvals.' ;
    rdfs:domain ind:SetpointChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newSetpointValue rdf:type rdf:Property ;
    rdfs:label 'New Setpoint Value' ;
    rdfs:comment 'Numeric value of the setpoint after the change.' ;
    rdfs:domain ind:SetpointChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousSetpointValue rdf:type rdf:Property ;
    rdfs:label 'Previous Setpoint Value' ;
    rdfs:comment 'Numeric value of the setpoint before the change was applied.' ;
    rdfs:domain ind:SetpointChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withinNormalLimits rdf:type rdf:Property ;
    rdfs:label 'Within Normal Limits' ;
    rdfs:comment 'True if the new setpoint remains within predefined normal operating limits; otherwise false.' ;
    rdfs:domain ind:SetpointChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Product Specification Id' ;
    rdfs:comment 'Foreign key linking to product.product_specification. Business justification: Tag definitions are used to monitor compliance with product specifications (e.g., voltage, temperature).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductSpecification .

ind:euRangeHigh rdf:type rdf:Property ;
    rdfs:label 'Eu Range High' ;
    rdfs:comment 'Upper bound of the engineering unit range.' ;
    rdfs:domain ind:TagDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:euRangeLow rdf:type rdf:Property ;
    rdfs:label 'Eu Range Low' ;
    rdfs:comment 'Lower bound of the engineering unit range.' ;
    rdfs:domain ind:TagDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tagDefinitionDescription rdf:type rdf:Property ;
    rdfs:label 'Tag Definition Description' ;
    rdfs:comment 'Detailed description of the tag purpose and usage.' ;
    rdfs:domain ind:TagDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagDefinitionStatus rdf:type rdf:Property ;
    rdfs:label 'Tag Definition Status' ;
    rdfs:comment 'Current lifecycle status of the tag definition.' ;
    rdfs:domain ind:TagDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagPath rdf:type rdf:Property ;
    rdfs:label 'Tag Path' ;
    rdfs:comment 'Fully qualified OPC-UA node identifier locating the tag in the address space.' ;
    rdfs:domain ind:TagDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedBy rdf:type rdf:Property ;
    rdfs:label 'Updated By' ;
    rdfs:comment 'User or system that performed the last update.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advancePaymentId rdf:type rdf:Property ;
    rdfs:label 'Advance Payment Id' ;
    rdfs:comment 'System-generated unique identifier for the advance payment record.' ;
    rdfs:domain ind:AdvancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bankAccountId rdf:type rdf:Property ;
    rdfs:label 'Bank Account Id' ;
    rdfs:comment 'Identifier of the bank account where the advance payment was deposited.' ;
