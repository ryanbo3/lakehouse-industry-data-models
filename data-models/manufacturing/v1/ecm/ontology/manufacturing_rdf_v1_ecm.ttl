    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:debitNoteInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Debit Note Invoice Id' ;
    rdfs:comment 'Identifier of the related debit note, if this invoice is a debit note.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:hazardousSubstanceId rdf:type rdf:Property ;
    rdfs:label 'Hazardous Substance Id' ;
    rdfs:comment 'Foreign key linking to compliance.hazardous_substance. Business justification: Handling of hazardous substances incurs fees; invoicing requires linking to the specific substance record.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
