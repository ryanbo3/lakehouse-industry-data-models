    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlModeEventId rdf:type rdf:Property ;
    rdfs:label 'Control Mode Event Id' ;
    rdfs:comment 'System-generated unique identifier for each control mode change event.' ;
