# RDFS Schema for Business: Real Estate

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ind: <http://datamodel.lakehouse.org/business/real_estate#> .

# --- Root Business Class ---
ind:Business rdf:type rdfs:Class ;
    rdfs:label 'Business' ;
    rdfs:comment 'Root class for all business entities' .

# --- Specific Business: Real Estate ---
ind:RealEstate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Business ;
    rdfs:label 'Real Estate' ;
    rdfs:comment 'Real Estate is a capital-intensive industry encompassing commercial and residential property sales, leasing, valuations, property management, development, and investment advisory services for owners, investors, and tenants.' .

# --- Domain Classes ---
ind:Property rdf:type rdfs:Class ;
    rdfs:subClassOf ind:RealEstate ;
    rdfs:label 'Property' ;
    rdfs:comment 'Core operational domain and master registry for all real estate assets — commercial, residential, and mixed-use properties, buildings, land parcels, units, and spaces. Owns physical attributes (GLA, NLA, SQF/SQM, FAR), building specifications, GIS coordinates, zoning classifications, COO status, LEED/BREEAM certifications, BIM references, title information, and ownership hierarchy. Single source of truth for every asset the enterprise owns, manages, or brokers.' .

ind:Tenant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:RealEstate ;
    rdfs:label 'Tenant' ;
    rdfs:comment 'SSOT for all tenant and prospect identities across commercial and residential portfolios. Manages tenant profiles, contact hierarchies, credit profiles, HOA memberships, occupancy history, lease history, and CRM-linked prospect pipelines. Supports both B2B corporate tenants and B2C residential occupants with comprehensive tenant lifecycle and relationship management.' .

ind:Lease rdf:type rdfs:Class ;
    rdfs:subClassOf ind:RealEstate ;
    rdfs:label 'Lease' ;
    rdfs:comment 'Governs the full lifecycle of lease agreements — LOIs, executed leases, amendments, renewals, and terminations. Owns lease terms (NNN, gross, modified gross), TI allowances, CAM schedules, rent escalation clauses, WALT/WALE metrics, SNDA agreements, and renewal options. Authoritative source for ASC 842 / IFRS 16 lease accounting data including lease classification, measurement, and disclosure.' .

ind:Transaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:RealEstate ;
    rdfs:label 'Transaction' ;
    rdfs:comment 'Records all property acquisition, disposition, and sale events — purchase agreements, closing statements, title transfers (ALTA), REO transactions, 1031 exchanges, and financing transactions. Tracks deal economics including PSF pricing, LTV ratios, earnest money, cash flows, and settlement details. Integrates with MLS and CoStar comparable sales data.' .

ind:Owner rdf:type rdfs:Class ;
    rdfs:subClassOf ind:RealEstate ;
    rdfs:label 'Owner' ;
    rdfs:comment 'SSOT for property owner and investor identities — individual owners, institutional investors, REITs, joint-venture entities, and partnerships. Manages ownership structures, equity stakes, beneficial ownership records, investor onboarding KYC data, contact information, and ownership agreements. Distinct from tenant domain; owners may also be investors tracked in the investment domain.' .

ind:Valuation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:RealEstate ;
    rdfs:label 'Valuation' ;
    rdfs:comment 'Manages property appraisals, BPOs, CMAs, and DCF-based valuations. Stores CAP rates, NOI inputs, IRR/NPV outputs, GAV/NAV calculations, and Argus Enterprise model references. Tracks appraisal history, certified appraiser credentials (Appraisal Institute), IVSC-compliant methodology metadata, and market value assessments supporting investment decision-making and financial reporting.' .

ind:Development rdf:type rdfs:Class ;
    rdfs:subClassOf ind:RealEstate ;
    rdfs:label 'Development' ;
    rdfs:comment 'Tracks real estate development and construction oversight from entitlement through COO issuance. Manages Procore project data, RFIs, submittals, construction budgets, CAPEX draw schedules, FAR compliance, BIM model references, permits, zoning approvals, contractor management, and milestone tracking. Covers ground-up development and major capital improvement programs.' .

ind:Investment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:RealEstate ;
    rdfs:label 'Investment' ;
    rdfs:comment 'Manages real estate investment portfolios, fund structures, and investment performance. Captures investment vehicles (REITs, funds, partnerships, CMBS/RMBS), portfolio composition, AUM, investment strategies, IRR/NPV/ROI calculations, FFO/AFFO reporting, NAV/GAV calculations, and investment advisory relationships. Supports institutional and individual investor portfolio management with comprehensive performance analytics.' .

ind:Maintenance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:RealEstate ;
    rdfs:label 'Maintenance' ;
    rdfs:comment 'Owns all facility operations and building services data — work orders, preventive maintenance schedules, HVAC and O&M records, tenant service requests, vendor dispatch, service contracts, and asset condition tracking. Sourced from Building Engines CMMS. Tracks CAPEX vs. OPEX classification for maintenance activities, OSHA safety compliance, and building equipment lifecycle.' .

ind:Brokerage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:RealEstate ;
    rdfs:label 'Brokerage' ;
    rdfs:comment 'Manages sales and leasing brokerage activity including deal pipelines, listing agreements, commission structures, co-broker arrangements, MLS/CoStar listing syndication, and agent/broker licensing. Tracks production metrics, prospect management, brokerage agreements, and Salesforce CRM deal stages from prospect to close. Supports both buy-side and sell-side brokerage operations.' .

ind:Finance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:RealEstate ;
    rdfs:label 'Finance' ;
    rdfs:comment 'Enterprise financial backbone covering GL, AP, AR, budgeting, forecasting, and financial reporting as sourced from Yardi Voyager and SAP S/4HANA. Owns cost centers, chart of accounts, NOI statements, EGI/PGI/GOI calculations, EBITDA roll-ups, DSCR calculations, cash management, financial consolidation, and SOX-compliant financial controls. Authoritative source for all property-level and portfolio-level P&L data.' .

ind:Compliance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:RealEstate ;
    rdfs:label 'Compliance' ;
    rdfs:comment 'Manages regulatory compliance obligations across the portfolio — EPA environmental assessments, OSHA building safety records, HUD fair housing filings, GDPR tenant data privacy controls, SEC reporting for publicly traded REITs, ESG metrics, LEED/BREEAM certification tracking, audit trails, and regulatory filing deadlines. Supports multi-jurisdictional compliance across federal, state, and local regulations.' .

ind:Reference rdf:type rdfs:Class ;
    rdfs:subClassOf ind:RealEstate ;
    rdfs:label 'Reference' ;
    rdfs:comment 'Centralized repository for all enterprise reference and lookup data — property types, lease types, transaction types, geographic hierarchies, market segments, zoning codes, currency codes, unit-of-measure standards (PSF, SQF/SQM), industry classification codes, and business taxonomies. Provides controlled vocabularies and standardized code sets that ensure data consistency across all operational and analytical domains.' .

ind:Marketing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:RealEstate ;
    rdfs:label 'Marketing' ;
    rdfs:comment 'Manages property marketing campaigns, digital listings, lead generation, market research, brand management, and advertising spend across commercial and residential portfolios. Tracks marketing channels, campaign performance, lead attribution, and competitive market intelligence.' .

# --- Data Product Classes (Tables) ---
ind:Owner rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Owner ;
    rdfs:label 'Owner' ;
    rdfs:comment 'SSOT master registry for all property owner and investor identities — individuals, institutional investors, REITs, corporations, trusts, family offices, and sovereign wealth funds. Captures legal entity type, registration details, domicile jurisdiction, tax identification numbers (EIN/SSN/TIN), beneficial ownership flags, AUM classification, onboarding status, and owner preferences (target asset classes, risk tolerance, IRR hurdles, ESG mandates). This is the authoritative golden record for every owner entity across the portfolio, sourced from Yardi Voyager and MRI Software.' .

ind:OwnerContact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Owner ;
    rdfs:label 'Owner Contact' ;
    rdfs:comment 'Contact information records for owner entities — primary and secondary contacts, mailing addresses, email addresses, phone numbers, preferred communication channels, and contact role types (primary, legal, financial, operational). Supports multi-contact hierarchies for institutional owners with multiple authorized representatives.' .

ind:OwnerOwnershipInterest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Owner ;
    rdfs:label 'Owner Ownership Interest' ;
    rdfs:comment 'Records the equity stake or ownership interest held by an owner in a specific property or investment vehicle, including full status lifecycle and audit history. Captures ownership percentage, interest type (fee simple, leasehold, fractional, beneficial), acquisition date, cost basis, vesting schedule, co-ownership arrangement flags, current status (pending, active, encumbered, disputed, transferred, terminated), and complete status transition history with previous status, new status, effective dates, change reasons, changed-by user, and supporting document references. Central to tracking fractional ownership, JV structures, and REIT unit holdings at the property level. Enables full ownership lifecycle traceability for legal, compliance, and audit purposes.' .

ind:OwnershipStructure rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Owner ;
    rdfs:label 'Ownership Structure' ;
    rdfs:comment 'Defines the legal and organizational structure through which ownership is held — single owner, joint venture, limited partnership (LP), LLC, REIT, tenancy-in-common (TIC), or trust. Captures structure type, formation date, governing jurisdiction, operating agreement reference, managing member designation, and dissolution date. Enables modeling of complex multi-tier ownership hierarchies.' .

ind:OwnerAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Owner ;
    rdfs:label 'Owner Agreement' ;
    rdfs:comment 'Ownership and investor agreements governing the relationship between the owner entity and the property management/asset management firm — including property management agreements (PMAs), asset management mandates, JV operating agreements, co-ownership agreements, SNDA agreements, and subscription agreements. Captures agreement type, effective and expiration dates, governing law, fee structures (management fee %, incentive fee tiers), termination clauses, renewal terms, and DocuSign CLM execution reference.' .

ind:OwnerDistribution rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Owner ;
    rdfs:label 'Owner Distribution' ;
    rdfs:comment 'SSOT for income and capital distributions made to owners from property operations, including disbursement banking instructions. This is the owner-perspective distribution record, distinct from finance domain GL entries which record the accounting impact. Captures distribution type (NOI, FFO/AFFO, capital gain, return of capital, preferred return), calculation period, gross amount, withholding tax, net disbursement amount, distribution date, payment method, and Yardi GL cross-reference. Also stores owner bank account and disbursement details: bank name, account type, routing number (masked/tokenized), SWIFT/IBAN for international owners, preferred disbursement method, and account verification status. Supports investor reporting, tax K-1 preparation, and AP reconciliation.' .

ind:CapitalContribution rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Owner ;
    rdfs:label 'Capital Contribution' ;
    rdfs:comment 'SSOT for equity capital contributions made by owners and investors into properties, JV structures, or investment vehicles — recorded from the owner/investor perspective. Distinct from finance domain GL entries which record the accounting debit/credit impact. Captures contribution date, amount, currency, contribution type (initial equity, capital call response, preferred equity injection, co-invest), ownership percentage impact, funding source, wire confirmation reference, and capital account balance impact. Tracks CAPEX funding events, equity waterfall inputs, and unfunded commitment drawdowns. Linked to ownership_interest for pro-rata tracking.' .

ind:OwnershipTransfer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Owner ;
    rdfs:label 'Ownership Transfer' ;
    rdfs:comment 'Records the transfer of ownership interests between parties — including equity stake transfers, JV buyouts, inheritance transfers, 1031 exchanges, and foreclosure/REO transfers. Captures transfer type, transferor (owner FK), transferee (owner FK), transfer date, consideration amount, transfer percentage, title instrument reference, ALTA settlement statement reference, recording jurisdiction, and tax implications. Distinct from the transaction domain which records full property acquisition/disposition events; this product tracks interest-level transfers within existing ownership structures.' .

ind:TaxRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Owner ;
    rdfs:label 'Tax Record' ;
    rdfs:comment 'SSOT for owner-perspective tax records — property tax obligations by jurisdiction, tax identification numbers, withholding tax rates for foreign owners (FIRPTA), tax treaty elections, K-1 partnership income allocations, and annual tax reporting status. Distinct from finance domain tax accounting (GL tax entries) and compliance domain regulatory filings; this product captures the owner-specific tax profile and obligations. Captures tax year, jurisdiction, tax type, assessed amount, filing status, and SAP S/4HANA tax cross-reference. Supports SOX compliance and SEC reporting for publicly traded REITs.' .

ind:EntityHierarchy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Owner ;
    rdfs:label 'Entity Hierarchy' ;
    rdfs:comment 'Models the parent-child organizational hierarchy among owner entities — holding companies, subsidiaries, SPVs, fund-of-funds structures, and REIT umbrella partnerships. Captures parent entity, child entity, hierarchy level, relationship type (wholly owned, majority controlled, minority interest), effective date, and consolidation flag. Enables roll-up reporting of AUM, NAV, and GAV across complex multi-tier ownership structures.' .

ind:WorkOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Work Order' ;
    rdfs:comment 'Core transactional entity representing a maintenance work order issued for a property or building asset. Captures the full lifecycle from creation through completion — including work type (corrective, preventive, emergency), priority level, CAPEX vs. OPEX classification, assigned trade/vendor, scheduled and actual completion dates, and safety compliance flags (OSHA, HSE, or equivalent jurisdiction-specific standards). Includes embedded cost line items for labor (technician hours, trade type, hourly rates, overtime) and materials (parts consumed, quantities, unit costs, supplier references). Tracks status transitions as an immutable audit trail for SLA breach analysis and compliance. Sourced from CMMS platforms (e.g., Building Engines, Corrigo, Angus). The primary operational record for all facility maintenance activity.' .

ind:ServiceRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Service Request' ;
    rdfs:comment 'Tenant-initiated service request submitted through a tenant portal, help desk, or mobile app. Captures the originating tenant, property, suite, request category (HVAC, plumbing, electrical, janitorial, access), description, urgency, submission timestamp, SLA target response and resolution times, and current status. Distinct from a work order — a service request is the tenant-facing intake record that may spawn one or more work orders. Supports tenant relationship management and CAM charge-back tracking.' .

ind:PmSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Pm Schedule' ;
    rdfs:comment 'Preventive Maintenance (PM) schedule master record defining the recurring maintenance program for a building asset or equipment item. Stores the PM frequency (daily, weekly, monthly, annual), task checklist template, assigned trade category, estimated labor hours, required parts, next due date, last completed date, and compliance flag (OSHA/HSE, LEED, manufacturer warranty). Drives automated work order generation in the CMMS. Distinct from a work order — this is the standing schedule, not the execution record.' .

ind:BuildingAsset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Building Asset' ;
    rdfs:comment 'Master registry of all physical building equipment and infrastructure assets subject to maintenance management — HVAC units, elevators, boilers, generators, fire suppression systems, electrical panels, plumbing systems, roofing, and other O&M-tracked components. Captures asset tag, manufacturer, model, serial number, installation date, expected useful life, replacement cost, current condition rating, and BIM reference ID. Includes warranty records (manufacturer, extended, labor warranties with coverage dates and claim history) and periodic condition assessment history (condition ratings, remaining useful life estimates, recommended capital replacement year). SSOT for maintainable building equipment within the maintenance domain.' .

ind:VendorDispatch rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Vendor Dispatch' ;
    rdfs:comment 'Transactional record of a vendor or contractor dispatched to a property to fulfill a work order. Captures the dispatched vendor, dispatch timestamp, estimated arrival window, actual arrival and departure times, work performed summary, sign-off status, and invoice reference. Tracks vendor performance against SLA commitments and supports CAM reconciliation for billable maintenance costs. Multiple dispatches may occur per work order (e.g., return visits, multi-trade coordination).' .

ind:ServiceContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Service Contract' ;
    rdfs:comment 'Master record for a maintenance service contract or vendor agreement governing recurring facility services — HVAC maintenance contracts, elevator service agreements, janitorial contracts, landscaping, pest control, and security. Captures contract number, vendor, covered properties, service scope, contract start/end dates, renewal terms, annual contract value, SLA terms, insurance certificate requirements, and CAPEX vs. OPEX classification. Distinct from individual work orders — this is the standing contractual framework.' .

ind:OpsInspection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Ops Inspection' ;
    rdfs:comment 'Record of a formal property or equipment inspection event — fire safety inspections, elevator certifications, HVAC commissioning, roof inspections, ADA/accessibility compliance walkthroughs, and workplace safety audits (OSHA, HSE, or equivalent). Captures inspection type, inspecting party (internal or third-party), inspection date, pass/fail result, and regulatory citation reference. Includes individual deficiency findings with severity classification (critical, major, minor), affected asset or area, recommended corrective action, responsible party, target and actual remediation dates, and remediation work order references. Supports regulatory compliance, certificate of occupancy maintenance obligations, and tracking of open deficiencies through to resolution.' .

ind:CapexProject rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Capex Project' ;
    rdfs:comment 'Capital expenditure project record for major building improvements, equipment replacements, or infrastructure upgrades classified as CAPEX rather than OPEX. Captures project name, description, property reference, asset reference, approved budget, actual spend to date, project start and end dates, funding source, approval authority, ERP project system reference, and capitalization date. Distinct from routine work orders — CAPEX projects involve asset capitalization and fixed asset creation in the GL.' .

ind:BillableCharge rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Billable Charge' ;
    rdfs:comment 'Billable maintenance charge record generated when maintenance costs are recoverable from tenants under NNN or modified gross lease structures as part of CAM reconciliation. Captures the originating work order or service contract, tenant reference, charge amount, charge category (HVAC, janitorial, repairs, landscaping), billing period, CAM pool allocation method, and invoice reference in the property management accounting system. Bridges the maintenance domain to the finance and lease domains for CAM charge-back processing.' .

ind:SafetyIncident rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Safety Incident' ;
    rdfs:comment 'Safety incident or near-miss event occurring at a managed property during maintenance or facility operations activities. Captures incident date and time, property location, incident type (injury, near-miss, property damage, environmental), description, injured party details, regulatory recordability flag (OSHA 300 log in US, RIDDOR in UK, or equivalent jurisdiction-specific reporting), first aid vs. medical treatment classification, root cause, corrective actions taken, and regulatory filing reference. Supports workplace safety compliance and building safety governance across jurisdictions.' .

ind:Listing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Brokerage ;
    rdfs:label 'Listing' ;
    rdfs:comment 'Master record for all property listings managed by the brokerage — commercial and residential, for sale or lease. Captures listing type (exclusive, open, co-exclusive), listing status (active, pending, expired, withdrawn, sold/leased), MLS/CoStar syndication flags, listing price/rate PSF, GLA/NLA, property class, submarket, listing start and expiration dates, days on market, and the originating source system (Salesforce CRM, CoStar). Serves as the SSOT for all brokerage-managed property offerings.' .

ind:ListingAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Brokerage ;
    rdfs:label 'Listing Agreement' ;
    rdfs:comment 'Formal contractual agreement between the brokerage and a property owner/seller authorizing the brokerage to market and transact on their behalf. Captures agreement type (exclusive right to sell, exclusive agency, open listing, net listing), term start and end dates, agreed commission rate or flat fee, co-broker split authorization, listing price, and execution status. Sourced from DocuSign CLM and Salesforce CRM. Distinct from a lease agreement (owned by the lease domain) — this governs the brokerage engagement itself.' .

ind:BrokerageDeal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Brokerage ;
    rdfs:label 'Brokerage Deal' ;
    rdfs:comment 'Core transactional record representing a brokerage deal from prospect to close, sourced from Salesforce CRM opportunity pipeline. Tracks deal type (sale, lease, sublease, assignment), deal stage (prospect, LOI, under contract, due diligence, closed, dead), property reference, deal size (SF/SQM, total consideration), projected and actual close dates, probability percentage, deal source, assigned broker/agent, and exclusivity periods. Includes immutable stage transition history as child records capturing prior stage, new stage, transition timestamp, reason for change, and triggering broker — enabling pipeline velocity analysis, stage duration tracking, and CRM workflow compliance auditing. Serves as the SSOT for brokerage deal pipeline activity and deal stage audit trail across buy-side and sell-side operations.' .

ind:BrokerageProspect rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Brokerage ;
    rdfs:label 'Brokerage Prospect' ;
    rdfs:comment 'Brokerage-specific record for a prospective buyer, tenant, or investor tracked in the Salesforce CRM deal pipeline before they become a confirmed counterparty on a deal. Captures prospect type (buyer, tenant, investor, owner/seller), contact details, requirement profile (target SF range, budget PSF, preferred submarket, property type, move-in timeline), source of introduction (referral, cold call, marketing campaign, CoStar lead, walk-in), qualification status (unqualified, MQL, SQL, nurturing, converted, lost), assigned broker, last contact date, next follow-up date, and CRM lead/contact reference. Distinct from the tenant domain\'s tenant master — this is a pre-transaction brokerage pipeline entity that converts into a deal counterparty upon qualification.' .

ind:Showing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Brokerage ;
    rdfs:label 'Showing' ;
    rdfs:comment 'Records each property showing or tour event conducted as part of the brokerage sales or leasing process. Captures showing date and time, property and listing reference, prospect or counterparty attending, broker conducting the showing, showing type (in-person, virtual), feedback notes, follow-up action required, and outcome (interested, not interested, offer pending). Sourced from Salesforce CRM activity tracking.' .

ind:Commission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Brokerage ;
    rdfs:label 'Commission' ;
    rdfs:comment 'Master record defining the commission structure and earned commission for each brokerage deal or listing agreement. Captures commission type (percentage of consideration, flat fee, PSF-based), gross commission amount, co-broker split percentage, referral fee deductions, net commission to house, commission trigger event (lease execution, closing, LOI acceptance), payment schedule (upfront, installment), and commission status (pending, approved, paid, disputed). Sourced from Yardi Voyager AR and Salesforce CRM.' .

ind:CommissionSplit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Brokerage ;
    rdfs:label 'Commission Split' ;
    rdfs:comment 'Detailed allocation and disbursement record breaking down how a gross commission is split among participating brokers, agents, co-brokers, and the brokerage house, and tracking actual payment execution through to settlement. Captures recipient type (in-house agent, co-broker firm, referral partner, brokerage house), recipient identity, split percentage, split dollar amount, override adjustments, disbursement date, payment method (wire, ACH, check), bank account reference, disbursement status (scheduled, processed, failed, reversed), and Yardi Voyager AP transaction reference. Serves as the SSOT for both commission allocation and disbursement — each row represents one payee\'s share of a commission and the payment lifecycle for that share. Supports multi-party commission disbursement workflows, agent production tracking, 1099 reporting, and provides the financial audit trail for all commission payments.' .

ind:CoBrokerAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Brokerage ;
    rdfs:label 'Co Broker Agreement' ;
    rdfs:comment 'Formal co-brokerage arrangement record between the listing brokerage and a cooperating broker firm for a specific deal or listing. Captures cooperating broker firm name, license number, designated agent, agreed co-broker commission split percentage, SNDA requirements, MLS cooperation flag, agreement execution date, and deal or listing reference. Governs the legal and financial terms of inter-firm brokerage cooperation.' .

ind:Broker rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Brokerage ;
    rdfs:label 'Broker' ;
    rdfs:comment 'Master record for licensed brokers and agents operating within or on behalf of the brokerage. Captures broker type (principal broker, associate broker, managing broker, leasing agent, buyer\'s agent, seller\'s agent), state license number, license expiration date, NAR/CCIM/SIOR membership status, MLS membership ID, designated market areas, production tier (based on GCI thresholds), hire date, employment type (W-2, 1099 independent contractor), team/desk assignment, and commission plan reference. Distinct from the workforce domain\'s employee record — this is the brokerage-specific professional identity, licensing, and production tracking record. Serves as the SSOT for broker identity referenced by deals, listings, commissions, showings, and prospect assignments.' .

ind:BrokerLicense rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Brokerage ;
    rdfs:label 'Broker License' ;
    rdfs:comment 'Tracks all real estate licenses held by each broker or agent, including state-by-state licensing, license type (salesperson, broker, managing broker), issuing authority, license number, issue date, expiration date, renewal status, CE (continuing education) hours completed, and disciplinary flags. Supports NAR and state regulatory compliance. A broker may hold multiple licenses across jurisdictions.' .

ind:Referral rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Brokerage ;
    rdfs:label 'Referral' ;
    rdfs:comment 'Records inbound and outbound referral arrangements between the brokerage and external parties (other brokers, relocation companies, affinity networks). Captures referral direction (inbound, outbound), referring party name and firm, referred prospect or deal, referral fee percentage or flat amount, referral agreement date, referral status (pending, active, closed, paid), and deal outcome. Supports referral fee tracking and network relationship management.' .

ind:BuyerRepresentation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Brokerage ;
    rdfs:label 'Buyer Representation' ;
    rdfs:comment 'Buyer or tenant representation agreement record formalizing the brokerage\'s engagement to represent a buyer or tenant in a property search and acquisition or leasing transaction. Captures representation type (exclusive buyer rep, exclusive tenant rep, non-exclusive), client identity, target property criteria (type, size, submarket, budget), agreement term, agreed commission or fee structure, exclusivity clause, and agreement status. Sourced from DocuSign CLM.' .

ind:Tenant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Tenant ;
    rdfs:label 'Tenant' ;
    rdfs:comment 'SSOT master record for all tenant and prospect identities across commercial and residential portfolios. Captures legal name, entity type (B2B corporate vs B2C residential), tax identification, incorporation details, credit tier, CRM account linkage, property management system tenant code, onboarding status, and lifecycle stage (prospect, applicant, active tenant, former tenant). Serves as the authoritative golden record for every occupant and prospective occupant across the enterprise.' .

ind:TenantContact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Tenant ;
    rdfs:label 'Tenant Contact' ;
    rdfs:comment 'Individual contact persons associated with a tenant profile — primary contacts, authorized signatories, emergency contacts, billing contacts, and property access contacts. Supports both B2B corporate tenant hierarchies (multiple contacts per corporate entity) and B2C residential occupants (household members). Stores full name, role, phone, email, preferred communication channel, and CRM contact linkage.' .

ind:CorporateEntity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Tenant ;
    rdfs:label 'Corporate Entity' ;
    rdfs:comment 'Master record for B2B corporate tenants capturing legal entity structure — parent company, subsidiaries, joint ventures, and affiliated entities. Stores DUNS number, SIC/NAICS industry code, annual revenue, employee headcount, publicly traded flag, stock ticker, credit rating agency scores, and corporate hierarchy linkage. Enables enterprise-wide exposure tracking across multiple leased premises for institutional and corporate occupiers.' .

ind:CreditProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Tenant ;
    rdfs:label 'Credit Profile' ;
    rdfs:comment 'Tenant credit and financial qualification record capturing credit bureau scores, credit check authorization date, debt-to-income ratio, income verification status, bankruptcy history, prior eviction flag, guarantor requirement flag, security deposit multiplier, and credit review expiry date. Sourced from third-party credit bureaus and stored as the authoritative credit qualification record per tenant for leasing underwriting decisions.' .

ind:TenantProspect rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Tenant ;
    rdfs:label 'Tenant Prospect' ;
    rdfs:comment 'CRM-linked prospect pipeline record for prospective tenants in the leasing funnel. Captures lead source, inquiry date, property of interest, unit type preference, desired move-in date, budget range (PSF or monthly), pipeline stage (inquiry, tour scheduled, application submitted, LOI issued, lease negotiation), assigned leasing agent, and conversion probability. Bridges brokerage activity and tenant onboarding.' .

ind:Application rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Tenant ;
    rdfs:label 'Application' ;
    rdfs:comment 'Formal tenancy application submitted by a prospect or existing tenant for a specific unit or premises. Captures application date, applicant type (individual, corporate, guarantor), requested GLA/NLA, proposed lease term, submitted financial documents checklist, application fee amount, application status (submitted, under review, approved, declined, withdrawn), decline reason code, and approval authority. Tracks the formal qualification workflow prior to lease execution.' .

ind:Occupancy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Tenant ;
    rdfs:label 'Occupancy' ;
    rdfs:comment 'Active and historical occupancy record linking a tenant to a specific property unit or premises for a defined period. Captures occupancy start date, end date, occupancy type (primary, sublease, holdover, license), actual occupied area (SQF/SQM), certificate of occupancy reference, move-in and move-out inspection dates, key handover date, occupancy status, and vacate reason code. Serves as the SSOT for physical possession across the entire portfolio — both current and historical — distinct from the legal lease agreement owned by the lease domain. Supports tenant lifecycle analytics, re-leasing decisions, reference checks, and portfolio occupancy reporting.' .

ind:Guarantor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Tenant ;
    rdfs:label 'Guarantor' ;
    rdfs:comment 'Guarantor record for tenants requiring a co-signer or financial guarantor on a lease — common in residential tenancies for students/first-time renters and for corporate tenants with insufficient credit history or foreign entities. Captures guarantor type (individual, corporate, institutional), legal name, tax ID, relationship to tenant, guaranteed amount or percentage of lease obligation, guarantee instrument type (personal guarantee, letter of credit, surety bond, cash deposit), guarantee effective and expiry dates, credit qualification status, and guarantor contact details. Supports lease underwriting, guarantee enforcement, and portfolio credit risk assessment.' .

ind:Notice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Tenant ;
    rdfs:label 'Notice' ;
    rdfs:comment 'Formal notice record issued to or received from a tenant covering the full spectrum of landlord-tenant legal communications: notice to vacate, lease renewal notice, rent increase notice, cure/default notice, lease termination notice, HOA violation notice, and estoppel certificate requests. Captures notice type, direction (inbound/outbound), issue date, effective date, statutory response deadline, delivery method (certified mail, email, portal, in-person), delivery confirmation status, response received flag, and digital signature reference. Supports lease administration, statutory compliance with state/local notice period requirements, and litigation readiness.' .

ind:Document rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Tenant ;
    rdfs:label 'Document' ;
    rdfs:comment 'Tenant document repository record tracking all documents associated with a tenant profile — identification documents, incorporation certificates, financial statements, tax returns, signed lease abstracts, LOIs, SNDA agreements, and digitally executed documents. Captures document type, document name, version, upload date, expiry date, storage reference, and document status (active, expired, superseded, archived). Supports lease administration, regulatory compliance, and tenant onboarding documentation requirements.' .

ind:CostCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Master registry of cost centers used for financial allocation and reporting across the real estate portfolio. Each cost center maps to a property, department, or business unit and serves as the foundational dimension for GL posting, NOI statements, and OPEX/CAPEX tracking. Attributes include cost center code, name, type (property-level, corporate, departmental), responsible manager, active status, effective dates, hierarchy parent, and functional currency.' .

ind:ChartOfAccounts rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Chart Of Accounts' ;
    rdfs:comment 'Enterprise chart of accounts defining the full GL account hierarchy used across all properties and legal entities. Establishes the authoritative account structure for income, expense, asset, liability, and equity classifications. Supports FASB ASC 842 lease accounting and SOX-compliant financial controls. Attributes include account code, account name, account type (asset, liability, equity, revenue, expense), sub-type, normal balance, parent account, IFRS 16 mapping flag, and active status.' .

ind:LegalEntity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Legal Entity' ;
    rdfs:comment 'Master registry of all legal entities within the real estate enterprise — including property-owning SPEs, REITs, joint-venture entities, holding companies, and operating subsidiaries. Serves as the consolidation anchor for financial reporting and SOX compliance. Attributes include entity name, entity type (REIT, LLC, LP, JV), EIN/tax ID, jurisdiction, functional currency, consolidation method, parent entity, REIT election status, and SEC reporting flag.' .

ind:JournalEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry' ;
    rdfs:comment 'Core GL transactional record capturing all financial postings across the real estate portfolio with embedded debit/credit line items. Each entry is a balanced posting event with line-level detail mapped to GL accounts, cost centers, and properties. Supports property-level P&L, NOI statements, CAM allocations, EBITDA roll-ups, and SOX audit trails. Sourced from Yardi Voyager and SAP S/4HANA. Attributes include journal entry number, posting date, period, document type, source system, approval status, reversal flag, and per-line: debit/credit indicator, amount, functional currency amount, GL account, cost center, property reference, profit center, segment, tax code, and line description.' .

ind:JournalEntryLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry Line' ;
    rdfs:comment 'Individual debit or credit line items within a journal entry, each mapped to a GL account, cost center, and property. Provides the granular posting detail required for property-level NOI statements, CAM reconciliations, and OPEX/CAPEX allocations. Attributes include line number, debit/credit indicator, amount, functional currency amount, account code, cost center, property reference, profit center, segment, tax code, and line description.' .

ind:ApInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Ap Invoice' ;
    rdfs:comment 'Accounts payable records covering the full procure-to-pay cycle for vendor payments related to property operations, construction, maintenance, and corporate services. Captures vendor invoices and associated disbursements (check runs, ACH, wire transfers) from Yardi Voyager AP and SAP S/4HANA. Invoice attributes include invoice number, vendor ID, invoice date, due date, payment terms, gross amount, tax amount, net amount, currency, property/cost center allocation, approval status, PO reference, and source system. Payment attributes include payment number, payment date, payment method, bank account, payment amount, cleared date, void flag, and void date.' .

ind:ApPayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Ap Payment' ;
    rdfs:comment 'Records of actual disbursements made to vendors against AP invoices, including check runs, ACH transfers, and wire payments. Tracks payment execution for property operating expenses, TI allowances, construction draws, and corporate payables. Attributes include payment number, payment date, payment method (check, ACH, wire), bank account, payment amount, currency, cleared date, void flag, void date, and associated invoice references.' .

ind:ArInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Ar Invoice' ;
    rdfs:comment 'Accounts receivable records covering the full order-to-cash cycle for tenant charges and cash receipts — rent billings, CAM reconciliations, percentage rent, TI reimbursements, and miscellaneous property income. Sourced from Yardi Voyager AR. Invoice attributes include invoice number, tenant reference, lease reference, property reference, invoice date, due date, billing period, charge type (base rent, CAM, percentage rent, parking, utility, late fee), gross amount, tax amount, net amount, currency, and aging bucket. Receipt attributes include receipt number, receipt date, payment method, bank deposit reference, amount received, applied amount, unapplied amount, and NSF flag. Supports EGI/PGI calculations and tenant receivable aging reports.' .

ind:ArReceipt rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Ar Receipt' ;
    rdfs:comment 'Records of cash receipts and tenant payments applied against AR invoices, including rent payments, security deposit receipts, and miscellaneous income. Tracks EGI realization at the property level. Attributes include receipt number, receipt date, payment method, bank deposit reference, amount received, currency, applied amount, unapplied amount, tenant reference, property reference, and NSF flag.' .

ind:Budget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Budget' ;
    rdfs:comment 'Annual and multi-year operating and capital budgets at the property, cost center, and portfolio level with embedded line-item detail by GL account and period. Serves as the baseline for NOI variance analysis, OPEX/CAPEX planning, and investor reporting. Sourced from Yardi Voyager Budgeting and SAP S/4HANA. Attributes include budget name, type (operating, capital, reforecast), fiscal year, version, status, approval chain, and per-line: GL account, cost center, property reference, period, budgeted amount, prior year actual, variance amount, variance percentage, and line description.' .

ind:BudgetLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Budget Line' ;
    rdfs:comment 'Granular budget line items by GL account, cost center, and period within an approved budget. Enables property-level and portfolio-level variance analysis between actual and budgeted NOI, EGI, PGI, and OPEX. Attributes include budget line number, GL account, cost center, property reference, period, budgeted amount, prior year actual, variance amount, variance percentage, and line description.' .

ind:NoiStatement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Noi Statement' ;
    rdfs:comment 'Property-level Net Operating Income statement capturing the full income waterfall — PGI, vacancy and credit loss, concessions, EGI, itemized operating expenses, and NOI — for a given reporting period. Serves as the authoritative financial performance record for each property and the primary input for CAP rate valuation, DSCR calculations, and investor reporting. Attributes include statement period, property reference, PGI, vacancy loss, concessions, EGI, operating expense categories, NOI, management fee, CAP rate applied, and reporting currency.' .

ind:FixedAsset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Fixed Asset' ;
    rdfs:comment 'Fixed asset register for all capitalized real estate assets including buildings, land improvements, tenant improvements (TI), HVAC systems, and capital equipment. Supports CAPEX tracking, depreciation schedules, and FASB ASC 360 asset impairment testing. Sourced from Yardi Voyager Fixed Assets and SAP S/4HANA FA. Attributes include asset number, asset description, asset class, property reference, acquisition date, acquisition cost, useful life, depreciation method, accumulated depreciation, net book value, disposal date, and disposal proceeds.' .

ind:BankAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Bank Account' ;
    rdfs:comment 'Master registry of all corporate and property-level bank accounts used for cash management, rent collection, operating disbursements, and escrow. Supports cash position monitoring and bank reconciliation. Attributes include account number (masked), bank name, bank routing number, account type (operating, escrow, security deposit, reserve), currency, property or entity reference, account status, and signatory details.' .

ind:DebtInstrument rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Debt Instrument' ;
    rdfs:comment 'Master registry of all property-level and portfolio-level debt instruments — mortgages, construction loans, mezzanine debt, CMBS, and credit facilities — with embedded debt service payment history. Supports LTV monitoring, DSCR covenant tracking, amortization schedules, and lender reporting. Attributes include loan number, lender, loan type, original principal, outstanding balance, interest rate, rate type (fixed/variable), maturity date, LTV ratio, DSCR covenant threshold, collateral property reference, and per-payment: scheduled/actual principal and interest amounts, payment date, payment status, outstanding balance after payment, escrow amount, and late fees.' .

ind:DebtServicePayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Debt Service Payment' ;
    rdfs:comment 'Records of scheduled and actual debt service payments (principal and interest) made against debt instruments. Supports DSCR calculations, cash flow modeling, and lender covenant reporting. Attributes include payment date, scheduled date, payment type (principal, interest, escrow), scheduled principal amount, scheduled interest amount, actual principal paid, actual interest paid, outstanding balance after payment, payment status, and late fee amount.' .

ind:LeaseAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Lease ;
    rdfs:label 'Lease Agreement' ;
    rdfs:comment 'Master record for every executed lease agreement across commercial and residential portfolios. Captures lease type (NNN, gross, modified gross, full-service, ground), commencement and expiration dates, base rent, rent escalation structure, security deposit terms, TI allowance, CAM obligations, permitted use, holdover provisions, and key lease abstract data (critical dates, exclusivity, co-tenancy, assignment/subletting rights, insurance requirements). Stores WALT/WALE metrics, ASC 842/IFRS 16 classification (operating vs. finance), right-of-use asset value, lease liability, and discount rate. Authoritative SSOT for all lease terms. Sourced from Yardi Voyager Lease Administration and MRI Lease Management modules. Links to property, tenant, and owner domains via FK.' .

ind:Amendment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Lease ;
    rdfs:label 'Amendment' ;
    rdfs:comment 'Records all executed amendments to a base lease agreement, including expansion options exercised, contraction events, rent modifications, term extensions, TI re-allowances, and permitted use changes. Tracks amendment number, effective date, amendment type, changed clauses with before/after values, revised rent, revised GLA/NLA, and DocuSign execution metadata. Each amendment is a distinct legal instrument modifying the parent agreement and triggers ASC 842 lease modification assessment. Sourced from Yardi Voyager and DocuSign CLM.' .

ind:RenewalOption rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Lease ;
    rdfs:label 'Renewal Option' ;
    rdfs:comment 'Defines contractual renewal options embedded within a lease agreement, including option number, notice deadline, option term length, rent reset mechanism (fixed, CPI, fair market value), exercise status (unexercised, exercised, expired, waived), and exercise date. Enables WALT/WALE forecasting and lease expiry pipeline management. Sourced from Yardi Voyager lease abstract data.' .

ind:Termination rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Lease ;
    rdfs:label 'Termination' ;
    rdfs:comment 'Records lease termination events — early terminations, mutual surrenders, lease expirations, default-driven terminations, and holdover resolutions. Captures termination type, effective termination date, termination fee, notice date, cure period, holdover status at termination, final possession return date, and space condition at surrender. Triggers downstream AR settlement, security deposit return processing, and ASC 842 derecognition entries. Sourced from Yardi Voyager and DocuSign CLM.' .

ind:RentSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Lease ;
    rdfs:label 'Rent Schedule' ;
    rdfs:comment 'Stores the full rent escalation schedule for a lease agreement, including each rent step period, effective start and end dates, base rent amount, rent PSF, escalation type (fixed step, CPI, percentage of sales), escalation rate or index, and free-rent periods. Enables accurate ASC 842 straight-line rent calculation and cash flow forecasting in Argus Enterprise. One agreement may have many rent schedule rows.' .

ind:CamSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Lease ;
    rdfs:label 'Cam Schedule' ;
    rdfs:comment 'Annual CAM (Common Area Maintenance) reconciliation record comparing estimated CAM charges billed to tenants against actual operating expenses incurred. Captures reconciliation year, estimated CAM per lease, actual CAM allocated, gross-up factor, tenant pro-rata share, reconciliation variance, credit or additional charge due, and reconciliation status. Sourced from Yardi Voyager CAM module. Critical for NNN and modified gross lease portfolios.' .

ind:TiAllowance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Lease ;
    rdfs:label 'Ti Allowance' ;
    rdfs:comment 'Tenant Improvement (TI) allowance record tracking the negotiated TI budget, disbursement schedule, approved spend, invoiced amounts, and remaining balance for a lease. Captures TI amount PSF, total TI budget, disbursement milestones, landlord work vs. tenant work scope, TI expiry date, and amortization terms if TI is structured as a loan. Sourced from Yardi Voyager and Procore project cost data.' .

ind:Clause rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Lease ;
    rdfs:label 'Clause' ;
    rdfs:comment 'Granular repository of individual lease clauses and special provisions extracted from executed agreements. Captures clause type (exclusivity, co-tenancy, kick-out, ROFO, ROFR, force majeure, assignment, subletting, audit rights), clause text summary, effective date, expiry date, and whether the clause is currently triggered or active. Enables portfolio-wide clause screening and risk management. Sourced from DocuSign CLM and Yardi Voyager lease abstract.' .

ind:DemisedSpace rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Lease ;
    rdfs:label 'Demised Space' ;
    rdfs:comment 'Defines the specific demised premises (suite, floor, unit, or land parcel) covered by a lease agreement. Stores suite number, floor, GLA, NLA, usable area SQF/SQM, space type (office, retail, industrial, residential unit, storage), load factor, and space configuration. A single lease may cover multiple spaces (e.g., multi-floor tenants). Sourced from Yardi Voyager unit/space master. Bridges the lease domain to the property domain.' .

ind:Payment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Lease ;
    rdfs:label 'Payment' ;
    rdfs:comment 'Records individual rent and charge payments received from tenants against a lease agreement. Captures payment date, payment type (base rent, CAM, TI reimbursement, security deposit, late fee, percentage rent), payment amount, payment method, applied period, outstanding balance, and delinquency flag. Sourced from Yardi Voyager Accounts Receivable module. This is the lease-domain AR transaction record tracking tenant payment performance; the finance domain GL owns the double-entry journal posting. Delineation: this product owns the tenant-facing billing/collection view; finance domain owns the enterprise accounting view.' .

ind:SecurityDeposit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Lease ;
    rdfs:label 'Security Deposit' ;
    rdfs:comment 'Tracks security deposit obligations and balances for each lease agreement. Captures deposit type (cash, letter of credit, surety bond), required deposit amount, held amount, letter of credit issuer and expiry, deposit reduction schedule, applied deductions, and return status upon lease termination. Sourced from Yardi Voyager. Critical for tenant credit risk management and lease-end settlement.' .

ind:PercentageRent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Lease ;
    rdfs:label 'Percentage Rent' ;
    rdfs:comment 'Manages percentage rent (overage rent) obligations for retail leases where rent is partially based on tenant gross sales. Stores natural breakpoint, artificial breakpoint, percentage rate, reporting period, reported gross sales, calculated percentage rent due, and reconciliation status. Sourced from Yardi Voyager percentage rent module. Applicable to retail NNN and gross leases with sales-based rent components.' .

ind:AccountingEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Lease ;
    rdfs:label 'Accounting Entry' ;
    rdfs:comment 'ASC 842 / IFRS 16 lease accounting and disclosure compliance records. Captures initial recognition and subsequent measurement of right-of-use (ROU) assets and lease liabilities: lease classification (operating, finance), ROU asset value, accumulated amortization, lease liability balance, interest expense, principal reduction, straight-line rent expense, period-end carrying values, and aggregated disclosure data (maturity analysis, weighted-average remaining term, weighted-average discount rate, operating/finance/variable lease costs, sublease income). Supports FASB/IASB quarterly and annual disclosure requirements for public REITs. Sourced from Yardi Voyager lease accounting module and SAP S/4HANA.' .

ind:Sublease rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Lease ;
    rdfs:label 'Sublease' ;
    rdfs:comment 'Records sublease arrangements where a primary tenant sublets all or part of their demised premises to a subtenant. Captures sublease commencement, expiration, sublet area SQF, sublease rent, subtenant identity, landlord consent date and status, sublease type (full assignment, partial sublease), profit/loss on sublease relative to head lease rent, and ASC 842 sublease classification (operating vs. finance for lessor accounting). Sourced from Yardi Voyager and DocuSign CLM. Distinct from the head lease agreement; linked to parent agreement via FK.' .

ind:Asset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Property ;
    rdfs:label 'Asset' ;
    rdfs:comment 'Master registry and single source of truth for every real estate asset the enterprise owns, manages, or brokers — the root anchor for the entire property domain. Each record represents one distinct property (commercial, residential, or mixed-use). Captures canonical identity: asset class (office, retail, industrial, multifamily, land, hospitality, self-storage), portfolio assignment, legal entity ownership, acquisition date, disposition date, asset status (active, disposed, under development, held for sale), GIS coordinates (latitude/longitude), legal description, APN (Assessor Parcel Number), FIPS code, market/submarket classification, and BIM model reference. All other property-domain products reference this entity as their parent.' .

ind:Building rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Property ;
    rdfs:label 'Building' ;
    rdfs:comment 'Physical building structure record associated with a real estate asset. One asset may contain multiple buildings (e.g., campus, mixed-use development). Captures building name, year built/renovated, floors above and below grade, total GLA/NLA (SQF and SQM), building class (A/B/C), construction type, structural system, building status (operational, under construction, demolished), COO number and date, fire suppression type, elevator count, parking stalls, and BIM reference. SSOT for building-level sustainability certifications (LEED level/date, BREEAM rating, ENERGY STAR score, WELL, FITWEL) with certifying body, certification number, expiration, and ESG reporting flags. SSOT for building amenity inventory (fitness, parking, F&B, conference, outdoor, technology, security) with capacity, hours, ADA compliance, and fee details. SSOT for floor plan records (as-built, current, proposed) with area breakdowns, load factors, and CAD/BIM file references. The comprehensive physical structure record and single source of truth for all building attributes, certifications, amenities, and floor plans in the portfolio.' .

ind:Parcel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Property ;
    rdfs:label 'Parcel' ;
    rdfs:comment 'Land parcel record representing a legally defined unit of land as recorded by the county assessor. Captures APN (Assessor Parcel Number), legal description, lot size in acres and SQF, zoning classification code, zoning description, FAR (Floor Area Ratio) allowed, maximum building height, setback requirements, flood zone designation (FEMA), soil classification, environmental designation (Superfund, brownfield), GIS polygon boundary (WKT or GeoJSON), county, municipality, state, country, and parcel status (active, subdivided, merged). Serves as the authoritative land record underpinning title and ownership data.' .

ind:Unit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Property ;
    rdfs:label 'Unit' ;
    rdfs:comment 'Leasable or saleable unit within a building — apartment unit, office suite, retail bay, industrial bay, or storage unit. Captures unit number, floor number, unit type (studio, 1BR, 2BR, office suite, retail bay), rentable area in SQF and SQM, usable area, efficiency ratio, unit status (vacant, occupied, under renovation, offline), asking rent PSF, market rent PSF, unit configuration (open plan, private offices), ADA compliance flag, balcony/patio flag, view type, and date last renovated. The SSOT for all leasable space inventory within the portfolio.' .

ind:Space rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Property ;
    rdfs:label 'Space' ;
    rdfs:comment 'Sub-unit space or common area within a building, supporting multi-tenant floor configurations, co-working arrangements, and common area maintenance (CAM) allocations. Captures space number, space type (private office, conference room, common corridor, lobby, mechanical room, parking bay, storage), rentable area SQF, usable area SQF, load factor, CAM-eligible flag, space status (available, occupied, under build-out, offline), floor number, floor plan reference, and suite assignment. Enables precise GLA/NLA reconciliation, CAM charge calculations, and tenant improvement (TI) space planning across the portfolio.' .

ind:Address rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Property ;
    rdfs:label 'Address' ;
    rdfs:comment 'Standardized physical address record for properties, buildings, parcels, and units. Captures address line 1, address line 2, city, county, state/province, postal code, country, USPS standardization status, geocode latitude, geocode longitude, geocode accuracy level, MSA (Metropolitan Statistical Area) code, submarket name, neighborhood name, and address validation timestamp. Supports GIS integration, market analysis, and regulatory reporting. One asset or building may have multiple addresses (e.g., corner properties with multiple street frontages).' .

ind:PropertyOwnershipInterest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Property ;
    rdfs:label 'Property Ownership Interest' ;
    rdfs:comment 'Records the ownership interest structure for each real estate asset — capturing who owns what percentage of each property and under what legal structure. Supports complex ownership arrangements including joint ventures, tenancy-in-common (TIC), REIT structures, and fund ownership. Captures owner entity reference, ownership percentage, ownership type (fee simple, leasehold, ground lease, easement), legal entity name, legal entity type (LLC, LP, REIT, individual), acquisition date, disposition date, ownership status (active, transferred, dissolved), and title vesting language. Bridges the property domain to the owner domain.' .

ind:TitleRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Property ;
    rdfs:label 'Title Record' ;
    rdfs:comment 'Title, deed, and encumbrance registry for each real estate asset — the single source of truth for chain of title, all recorded encumbrances, and title insurance details. Stores deed type (warranty, quitclaim, grant, special warranty), deed book and page reference, recording date and number, county recorder jurisdiction, title company, policy number, policy type (ALTA owner, ALTA lender), policy amount, effective date, and title status (clear, encumbered, in dispute). SSOT for all encumbrances recorded against the asset: liens (mortgage lien, mechanics lien, tax lien), easements, deed restrictions, CC&Rs, rights-of-way, and ground lease encumbrances — with recording details, priority position, grantor/grantee, encumbrance amounts, maturity dates, release dates, and encumbrance status (active, released, expired, disputed). Critical for transaction due diligence, lender underwriting, SNDA management, and regulatory compliance.' .

ind:Inspection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Property ;
    rdfs:label 'Inspection' ;
    rdfs:comment 'Physical property and building inspection records capturing scheduled and ad-hoc inspections for due diligence, regulatory compliance, insurance requirements, and condition assessment. Captures inspection type (property condition assessment, fire safety, elevator, HVAC, environmental Phase I/II, ADA compliance, roof, structural, seismic), inspection date, inspector name, inspector company, inspection status (scheduled, in progress, completed, failed), overall condition rating (1-5 scale), deficiency count, critical deficiency flag, estimated remediation cost, report document reference, next scheduled inspection date, and regulatory authority (OSHA, EPA, local fire marshal). Distinct from maintenance work orders — inspections are formal assessments that may trigger work orders but are not repair events themselves.' .

ind:OccupancyRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Property ;
    rdfs:label 'Occupancy Record' ;
    rdfs:comment 'Point-in-time and period occupancy snapshots for buildings and units — the transactional record capturing physical and economic occupancy rates for NOI calculations, investor reporting, and portfolio performance monitoring. Each record represents one reporting period (month or quarter) for one building or unit. Captures total leasable area SQF, occupied area SQF, vacant area SQF, physical occupancy rate, economic occupancy rate, occupied unit count, vacant unit count, units under notice, net absorption SQF, and data source system (Yardi Voyager, MRI, RealPage). Supports WALE/WALT calculations, REIT FFO/AFFO reporting, same-store NOI comparisons, rent roll reconciliation, and asset management dashboards.' .

ind:PropertyType rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reference ;
    rdfs:label 'Property Type' ;
    rdfs:comment 'Enterprise-wide property classification taxonomy organized as a self-referencing multi-level hierarchy. Level 1: asset class (commercial, residential, mixed-use, land, special-purpose). Level 2: sub-category (office, retail, industrial, hospitality, single-family, multifamily, condo). Level 3: quality tier / building class (Class A/B/C, trophy, institutional-grade, luxury, affordable). Level 4: space use type (office, retail, restaurant, medical, fitness, storage, parking). Level 5: construction method (wood frame, steel, concrete, masonry, modular). Level 6: amenity classification (building-level, unit-level, community). Each node carries applicable attributes: GLA applicability flags, zoning compatibility codes, fire resistance ratings (IBC Type I–V), ESG/LEED relevance indicators, CAM inclusion rules, TI allowance benchmarks, and measurement methodology (GLA/NLA/GFA). Aligned with RESO, CoStar, BOMA, and NAIOP standards. Referenced by property, lease, valuation, brokerage, development, and maintenance domains as the single source of truth for all property classification.' .

ind:LeaseType rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reference ;
    rdfs:label 'Lease Type' ;
    rdfs:comment 'Standardized classification of lease structures used across commercial and residential leasing — NNN (Triple Net), gross lease, modified gross, percentage lease, ground lease, sublease, and short-term/month-to-month. Defines rent calculation methodology, CAM/OpEx responsibility allocation, and applicable accounting treatment under ASC 842 / IFRS 16. Includes escalation method indicators (CPI, fixed-step, market reset) and renewal option classification. Serves as the authoritative lookup for lease administration across Yardi Voyager, MRI Software, and all operational domains requiring lease structure classification.' .

ind:TransactionType rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reference ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Controlled vocabulary for all real estate transaction categories — acquisition, disposition, 1031 exchange, REO sale, foreclosure, short sale, ground lease assignment, joint venture formation, and portfolio trade. Includes transaction sub-types, applicable regulatory reporting flags (SEC, HUD), and required documentation checklists per transaction category. Used by the transaction domain and brokerage domain as the authoritative classification source.' .

ind:GeographicHierarchy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reference ;
    rdfs:label 'Geographic Hierarchy' ;
    rdfs:comment 'Enterprise geographic hierarchy defining the spatial organization of the real estate portfolio — country, region, state/province, metropolitan statistical area (MSA), submarket, city, zip/postal code, and micro-location. Supports GIS-based portfolio analysis, market segmentation, and regulatory jurisdiction mapping. Aligns with CoStar submarket definitions and HUD geographic designations. Each node carries market tier classification (primary, secondary, tertiary) and applicable regulatory jurisdiction codes.' .

ind:MarketSegment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reference ;
    rdfs:label 'Market Segment' ;
    rdfs:comment 'Standardized market segment and investment strategy classifications used for portfolio analysis, deal sourcing, and performance benchmarking. Commercial segments: core, core-plus, value-add, opportunistic, and distressed. Residential segments: affordable, workforce, market-rate, and luxury. Each segment defines risk profile descriptors, target IRR and CAP rate ranges, typical hold period benchmarks, leverage parameters, and exit strategy indicators. Referenced by investment, valuation, brokerage, and transaction domains for deal classification, portfolio allocation analysis, and investor reporting against NCREIF and INREV benchmarks.' .

ind:ZoningCode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reference ;
    rdfs:label 'Zoning Code' ;
    rdfs:comment 'Authoritative registry of municipal and county zoning designations applicable to portfolio properties — residential (R1–R5), commercial (C1–C3), industrial (I1–I2), mixed-use (MU), agricultural (A), and special overlay districts. Captures FAR limits, height restrictions, permitted uses, conditional use requirements, and variance history. Sourced from municipal GIS databases and maintained for regulatory compliance and development feasibility analysis.' .

ind:CurrencyCode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reference ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'ISO 4217 currency code registry supporting multi-currency financial operations across international real estate portfolios. Stores currency code, name, symbol, decimal precision, and active status. Includes exchange rate source reference and functional currency designation for REIT and fund-level financial consolidation under SAP S/4HANA. Supports AP/AR multi-currency processing in Yardi Voyager and financial reporting under FASB/IASB standards.' .

ind:Uom rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reference ;
    rdfs:label 'Uom' ;
    rdfs:comment 'Enterprise unit-of-measure registry for all measurement dimensions in real estate operations — area (SQF, SQM, GLA, NLA, GFA), linear (LF, LM), volume (CF, CM), weight (LB, KG), and rate-based measures (PSF/year, PSM/month). Defines conversion factors between imperial and metric systems, default UOM by geographic region, and applicable property types per measure. Critical for consistent rent calculations, valuation metrics, cross-border portfolio reporting, and regulatory area disclosures.' .

ind:IndustryClassification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reference ;
    rdfs:label 'Industry Classification' ;
    rdfs:comment 'Standard industry classification codes for tenant and occupier categorization — NAICS (North American Industry Classification System), SIC (Standard Industrial Classification), and GICS (Global Industry Classification Standard). Used to classify tenant business types for portfolio diversification analysis, lease underwriting, and regulatory reporting. Supports retail tenant mix analysis (anchor vs. inline), office tenant sector concentration, and industrial occupier type tracking.' .

ind:AmenityType rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reference ;
    rdfs:label 'Amenity Type' ;
    rdfs:comment 'Controlled vocabulary for property and building amenities used in property marketing, tenant attraction, and asset valuation — fitness centers, rooftop terraces, parking structures, EV charging stations, conference facilities, concierge services, green spaces, and smart building features. Categorized by amenity class (building, unit-level, community), applicable property types, and ESG/LEED relevance flags. Used by property, lease, and brokerage domains for listing enrichment and comparable analysis.' .

ind:BuildingClass rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reference ;
    rdfs:label 'Building Class' ;
    rdfs:comment 'Standardized building quality classification system for commercial and residential assets — Class A, B, C for office and industrial; luxury, mid-market, affordable for residential; trophy, institutional-grade for investment-grade CRE. Defines classification criteria including age thresholds, construction quality standards, location grade, amenity requirements, and typical CAP rate ranges per class. Aligned with BOMA, NAIOP, and CoStar building class definitions.' .

ind:ConstructionType rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reference ;
    rdfs:label 'Construction Type' ;
    rdfs:comment 'Reference classification for building construction methods and structural systems — wood frame, steel frame, concrete (cast-in-place, precast, tilt-up), masonry, modular, and mixed construction. Includes fire resistance rating (Type I–V per IBC), structural system description, typical span capabilities, and applicable property type compatibility. Used by development, maintenance, and valuation domains for construction cost estimation, insurance underwriting, and building condition assessment.' .

ind:SpaceUseType rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reference ;
    rdfs:label 'Space Use Type' ;
    rdfs:comment 'Controlled vocabulary for leasable space use classifications within a building — office, retail, restaurant/food and beverage, medical/dental, fitness, storage, parking, rooftop, signage, and common area. Defines GLA/NLA measurement methodology per use type, applicable lease structures, TI allowance benchmarks, and CAM inclusion/exclusion rules. Used by lease, property, and brokerage domains for space inventory management and rent roll reporting.' .

ind:Country rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reference ;
    rdfs:label 'Country' ;
    rdfs:comment 'ISO 3166-1 country registry supporting international real estate portfolio operations. Stores country code (alpha-2, alpha-3, numeric), country name, region/continent grouping, default currency, applicable regulatory frameworks (GDPR, local property law), and tax treaty status. Serves as the top-level node in the geographic hierarchy and is referenced by all domains requiring country-level jurisdiction identification.' .

ind:DevProject rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Development ;
    rdfs:label 'Dev Project' ;
    rdfs:comment 'Master record for each real estate development or major capital improvement project — ground-up construction, redevelopment, or large-scale CAPEX programs. Captures project name, type (ground-up, renovation, mixed-use), current phase (entitlement, design, construction, closeout), total GLA/NLA targets, zoning classification, project address, estimated and actual start/completion dates, total project budget, and project manager assignment. Includes closeout lifecycle attributes: COO number and issuance date, as-built document delivery date, warranty registration, final retainage release date, O&M manual submission status, and closeout package completion. Also records Procore project ID for source-system traceability. SSOT for all development project identity and full lifecycle from inception through closeout and handoff to asset management.' .

ind:Entitlement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Development ;
    rdfs:label 'Entitlement' ;
    rdfs:comment 'Tracks all entitlement activities and FAR compliance calculations for a development project — zoning approvals, variances, conditional use permits, environmental impact reviews, and planning commission decisions. Captures entitlement type, jurisdiction, application date, approval date, conditions of approval, and entitlement status. Includes FAR compliance detail: zoning district, base FAR allowance, bonus FAR mechanisms (affordable housing, open space, transit), total allowable FAR, proposed gross floor area, proposed FAR, as-built FAR, and FAR compliance status. Also records density limits, height restrictions, and the governing regulatory authority. Links to the parent dev_project. SSOT for all entitlement and zoning compliance data within the development domain.' .

ind:ConstructionPermit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Development ;
    rdfs:label 'Construction Permit' ;
    rdfs:comment 'Records all building and construction permits associated with a development project — grading, foundation, structural, MEP, and final occupancy permits. Captures permit number, permit type, issuing authority (municipality/jurisdiction), application date, issuance date, expiration date, inspection status, COO linkage, fee amounts, and permit conditions or restrictions. SSOT for construction permit tracking within the development domain. Critical for regulatory compliance, inspection scheduling, and certificate of occupancy issuance workflow.' .

ind:ConstructionContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Development ;
    rdfs:label 'Construction Contract' ;
    rdfs:comment 'Master record for each construction contract executed on a development project — GC agreements, subcontractor contracts, design-build contracts, and owner-architect agreements. Captures contract type (GMP, lump sum, cost-plus), contractor entity reference, contract value, executed date, substantial completion date, retainage percentage, bonding requirements, insurance certificates, change order allowance, and contract status. Sourced from DocuSign CLM and Procore.' .

ind:Contractor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Development ;
    rdfs:label 'Contractor' ;
    rdfs:comment 'Master registry of all contractors, subcontractors, and design professionals engaged on development projects — general contractors, specialty subcontractors, architects, engineers, and consultants. Captures company name, license number, license type, bonding capacity, insurance expiration, prequalification status, trade specialty, MBE/WBE/DBE certification, default contact, and historical performance rating. SSOT for contractor identity within the development domain. Supports prequalification workflows, insurance compliance tracking, and contractor performance evaluation across projects.' .

ind:ConstructionBudget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Development ;
    rdfs:label 'Construction Budget' ;
    rdfs:comment 'Tracks the approved CAPEX budget for each development project at both summary and cost-code-level detail. Summary level captures original budget, approved budget, current budget (including approved change orders), committed costs, actual costs to date, forecast at completion, and variance by category (hard costs, soft costs, land, financing, contingency). Line-item level captures individual cost codes (CSI division or custom WBS element), cost category, original and revised budget amounts, committed and actual spend, and remaining budget per line. Enables CAPEX draw schedule management, cost control, variance analysis, and investor reporting. Aligned with Procore budget module and SAP S/4HANA project systems for source-system integration.' .

ind:ChangeOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Development ;
    rdfs:label 'Change Order' ;
    rdfs:comment 'Records all change orders issued against construction contracts — owner-initiated changes, contractor-initiated scope modifications, unforeseen conditions, and design revisions. Captures change order number, originating contract, change type, description of scope change, cost impact, schedule impact (days), approval status, approval date, approving authority, and cumulative change order total against the contract. SSOT for construction change order tracking within the development domain. Critical for contract value management, budget variance analysis, and dispute documentation.' .

ind:DrawRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Development ;
    rdfs:label 'Draw Request' ;
    rdfs:comment 'Captures each CAPEX draw request (AIA G702/G703 pay application) submitted for payment against a construction contract, along with all associated lien waivers. Draw-level data: draw number, billing period, scheduled value, work completed to date, materials stored, total earned, retainage withheld, net payment due, lender approval status, title company review status, and disbursement date. Lien waiver detail per draw: waiver type (conditional/unconditional, progress/final), executing party (contractor or subcontractor), waiver amount, through-date, execution date, notarization status, and document storage reference. SSOT for construction payment applications and lien waiver compliance within the development domain. Critical for construction loan administration, CAPEX cash flow management, and lender/title requirements.' .

ind:InspectionEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Development ;
    rdfs:label 'Inspection Event' ;
    rdfs:comment 'Records all construction inspections conducted on a development project — municipal building inspections, third-party special inspections, lender inspections, and owner quality control inspections. Captures inspection type, inspection date, inspector name and affiliation, areas inspected, pass/fail result, deficiencies noted, corrective action required, re-inspection date, and final sign-off. Supports COO issuance tracking and OSHA compliance documentation.' .

ind:ProjectSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Development ;
    rdfs:label 'Project Schedule' ;
    rdfs:comment 'Master schedule record for a development project — the baseline and current CPM (Critical Path Method) schedule with integrated milestone tracking. Schedule-level data: schedule version, baseline and current start/finish dates, total float, critical path activities count, schedule performance index (SPI), percent complete, last update date, and scheduling software reference (Primavera P6, MS Project). Milestone-level data: milestone name and type (entitlement approval, groundbreaking, foundation pour, topping out, substantial completion, COO issuance), planned date, forecast date, actual date, days variance, responsible party, predecessor relationships, and completion status. SSOT for project scheduling and milestone tracking within the development domain. Enables critical path analysis, schedule performance reporting, and investor milestone updates.' .

ind:RegulatoryObligation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Regulatory Obligation' ;
    rdfs:comment 'Master registry of all regulatory obligations applicable to the portfolio — federal, state, and local requirements including EPA environmental mandates, OSHA building safety codes, HUD fair housing rules, GDPR tenant data privacy, SEC REIT reporting, and municipal zoning compliance. Each obligation captures the governing body, regulation reference, jurisdiction, applicability scope (property type, asset class), effective dates, and renewal cadence. Serves as the authoritative catalog against which compliance activities are tracked.' .

ind:Requirement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Requirement' ;
    rdfs:comment 'Granular, actionable compliance requirements derived from regulatory obligations — specific tasks, controls, or submissions that must be completed (e.g., annual fire inspection, quarterly OSHA safety audit, annual HUD fair housing certification, GDPR data subject access request process, SEC 10-K REIT disclosure). Links to the parent regulatory obligation and compliance program. Captures requirement type, frequency, responsible party role, due date logic, and applicable property or jurisdiction scope.' .

ind:RegulatoryFiling rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Regulatory Filing' ;
    rdfs:comment 'Transactional record of every regulatory filing submitted to a governing body — SEC REIT filings (10-K, 10-Q, 8-K), HUD fair housing reports, EPA environmental disclosures, OSHA incident reports, state and local permit applications, and municipal zoning filings. Captures filing type, governing body, jurisdiction, filing date, submission method, filing status (draft, submitted, accepted, rejected), reference number assigned by the regulator, and the property or portfolio scope covered.' .

ind:Assessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Assessment' ;
    rdfs:comment 'Records the results of all compliance assessments, audits, inspections, and formal audit engagements conducted against properties or business units. Covers OSHA safety inspections, EPA environmental site assessments (Phase I/II), HUD fair housing audits, fire marshal inspections, building code compliance reviews, internal compliance audits, external financial audits, SOX audits, regulatory examinations, and third-party compliance audits. Captures assessment/audit type, assessor or auditing firm, scope (properties, business units, processes), assessment period, fieldwork dates, findings summary with severity classification, overall compliance status or audit opinion, report issuance date, and remediation requirements. Serves as the single master log of all formal compliance evaluation activities.' .

ind:RemediationAction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Remediation Action' ;
    rdfs:comment 'Tracks corrective and preventive actions (CAPAs) required to resolve compliance assessment findings, regulatory violations, and enforcement actions. Each action captures the triggering event (assessment finding or violation), action description, responsible party, target and actual completion dates, estimated remediation cost, status (open, in-progress, completed, verified), and verification method. Supports OSHA corrective action plans, EPA remediation programs, HUD consent decree actions, SEC comment letter responses, and internal audit follow-up workflows. After merging assessment_finding into assessment, remediation actions link directly to the parent assessment or violation.' .

ind:FairHousingRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Fair Housing Record' ;
    rdfs:comment 'Tracks HUD fair housing compliance activities across residential and commercial leasing operations — fair housing training completions, accommodation requests (ADA/FHA), discrimination complaints received, investigation outcomes, and HUD audit responses. Captures protected class categories involved, complaint type, resolution status, settlement terms if applicable, and HUD case reference numbers. Supports compliance with the Fair Housing Act, Americans with Disabilities Act (ADA), and Equal Credit Opportunity Act (ECOA).' .

ind:EsgMetric rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Esg Metric' ;
    rdfs:comment 'Captures ESG (Environmental, Social, and Governance) performance metrics at the property and portfolio level for investor reporting and regulatory disclosure. Environmental metrics include energy consumption (kWh), water usage, GHG emissions (Scope 1/2/3 in CO2e), waste diversion rates, and renewable energy percentage. Social metrics cover affordable housing units, community investment, and tenant satisfaction. Governance metrics track board diversity, ethics violations, and anti-corruption measures. Each metric record captures the reporting period, measurement methodology, data source, and verification status. Supports ESG reporting frameworks (GRI, SASB, TCFD, GRESB) and REIT investor ESG disclosure requirements.' .

ind:GreenCertification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Green Certification' ;
    rdfs:comment 'Master record for green building certifications obtained or pursued for properties — LEED (Leadership in Energy and Environmental Design), BREEAM (Building Research Establishment Environmental Assessment Method), ENERGY STAR, WELL Building Standard, and Fitwel certifications. Captures certification type, certifying body (USGBC, BRE, EPA), certification level (LEED Platinum/Gold/Silver/Certified), certification date, expiry date, points scored, prerequisites met, and renewal requirements. Supports ESG reporting and green lease obligations.' .

ind:Permit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Permit' ;
    rdfs:comment 'Master registry of all permits required and obtained for properties — building permits, certificates of occupancy (COO), environmental permits, fire safety permits, elevator operating permits, demolition permits, and zoning variances. Captures permit type, issuing authority, jurisdiction, permit number, issue date, expiry date, renewal requirements, permit conditions, inspection history, and current status (active, expired, pending renewal, revoked). Critical for development, operations, and disposition compliance. Includes inspection records associated with permit issuance and renewal.' .

ind:Violation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Violation' ;
    rdfs:comment 'Records confirmed regulatory violations, non-compliance events, enforcement actions, and OSHA-reportable workplace safety incidents across all compliance programs. Covers EPA notices of violation, OSHA citations and recordable incidents (injuries, illnesses, near-misses, fatalities with 300/300A log classification), HUD enforcement actions, SEC comment letters, building code violations, and zoning violations. Captures violation/incident type, regulatory body, citation reference, date, severity (willful, serious, other-than-serious, de minimis), OSHA recordability classification, days away from work, root cause analysis, penalty amount assessed, contest status, and resolution outcome. Drives remediation workflows, regulatory response management, and mandatory incident reporting.' .

ind:Jurisdiction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'Reference master for all regulatory jurisdictions applicable to the real estate portfolio — federal agencies (EPA, OSHA, HUD, SEC, CFPB), state regulatory bodies, county authorities, and municipal/city agencies. Each jurisdiction record captures the jurisdiction level (federal, state, county, city, special district), jurisdiction name, governing body, geographic boundaries, applicable regulatory frameworks, key contact information, and filing portal details. Serves as the authoritative lookup for multi-jurisdictional compliance mapping and is referenced by obligations, filings, permits, and violations to assign jurisdictional scope.' .

ind:Fund rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Investment ;
    rdfs:label 'Fund' ;
    rdfs:comment 'Master registry of real estate investment funds, REITs, and pooled investment vehicles. Captures fund name, type (open-end, closed-end, REIT, partnership, CMBS/RMBS trust), domicile jurisdiction, base currency, target and actual AUM, inception date, fund status, investment strategy (core, core-plus, value-add, opportunistic), target return metrics (IRR, equity multiple), fee terms (management fee rate, carried interest, preferred return hurdle, fee basis, fee cap, fee waiver conditions), fund term and extension options, GP entity, regulatory classification, ESG mandate, and investment mandate parameters (target property types, geographies, leverage range, deal size range, concentration limits). SSOT for fund identity, strategy, terms, fee structures, and mandate parameters.' .

ind:Portfolio rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Investment ;
    rdfs:label 'Portfolio' ;
    rdfs:comment 'Master record for an investment portfolio — a named collection of real estate assets managed under a unified strategy. Captures portfolio name, portfolio type (core, diversified, sector-specific), associated fund, asset manager (AM), benchmark index, target GAV, target NAV, target NOI, geographic focus, property type focus, WALT target, WALE target, portfolio inception date, reporting currency, consolidation entity, and portfolio status. Serves as the SSOT for portfolio-level identity and strategy. Sourced from MRI Software and Argus Enterprise.' .

ind:Investor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Investment ;
    rdfs:label 'Investor' ;
    rdfs:comment 'SSOT for institutional and individual investor identities participating in real estate funds and portfolios. Captures investor legal name, investor type (institutional, HNWI, family office, pension fund, sovereign wealth fund, endowment, retail), KYC/AML status, accreditation status, domicile country, tax identification, preferred currency, investor tier, relationship manager, onboarding date, and investor status. Distinct from the owner domain (which tracks property ownership) — this entity tracks capital contributors to investment vehicles.' .

ind:Commitment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Investment ;
    rdfs:label 'Commitment' ;
    rdfs:comment 'Records the formal capital commitment made by an investor to a fund or investment vehicle. Captures commitment amount, commitment currency, commitment date, commitment status (pending, executed, funded, defaulted), subscription agreement reference, capital call schedule, total called capital, uncalled capital (dry powder), total distributed capital, and co-investment flag. Tracks the lifecycle from LOI through full deployment. Sourced from MRI Software Investment Management.' .

ind:CapitalCall rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Investment ;
    rdfs:label 'Capital Call' ;
    rdfs:comment 'Transactional record of each capital call notice issued to investors, requesting funded capital from committed but uncalled amounts. Captures call number, call date, call amount, call percentage of commitment, due date, purpose (acquisition, capex, fees, reserves), funding status, actual funded amount, shortfall amount, default flag, and wire transfer reference. Linked to commitment and fund. Supports LP capital account reconciliation and fund cash management. Sourced from MRI Software.' .

ind:InvestmentDistribution rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Investment ;
    rdfs:label 'Investment Distribution' ;
    rdfs:comment 'Records capital and income distributions made from a fund or investment vehicle to investors. Captures distribution date, distribution type (return of capital, income, capital gain, preferred return, carried interest), gross distribution amount, withholding tax amount, net distribution amount, distribution per unit/share, distribution frequency, reinvestment election flag, and payment method. Supports FFO/AFFO reporting and investor waterfall calculations. Sourced from MRI Software and Yardi Voyager.' .

ind:PortfolioAsset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Investment ;
    rdfs:label 'Portfolio Asset' ;
    rdfs:comment 'Association entity linking a property asset to an investment portfolio, capturing the investment-specific attributes of that holding. Records acquisition cost, acquisition date, current book value, appraised value, ownership percentage, hold strategy (core hold, value-add, disposition target), target exit date, allocated debt, equity invested, unrealized gain/loss, and asset manager assignment. Distinct from the property domain master record — this entity captures the investment lens on each asset within a portfolio context. Cross-references property_id from the property domain.' .

ind:FundPerformance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Investment ;
    rdfs:label 'Fund Performance' ;
    rdfs:comment 'Period-level investment performance and valuation record for a fund — the operational SSOT for how a fund performed and was valued in a given measurement period. Captures period dates, period type (quarterly, annual, trailing-12, since-inception), gross/net IRR, equity multiple (MOIC), NPV, DPI, RVPI, TVPI, TWR, MWR, benchmark return, alpha, GAV (sum of appraised values), NAV (GAV minus liabilities), NAV per unit/share, units outstanding, premium/discount to NAV, AUM, total revenue, NOI, FFO, AFFO, OPEX, CAPEX, leverage ratio, NAV calculation methodology, auditor sign-off status, and period status (open, closed, audited). Supports REIT reporting, investor redemption pricing, SEC filings, and ILPA reporting standards. Sourced from Argus Enterprise and MRI Software.' .

ind:AssetPerformance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Investment ;
    rdfs:label 'Asset Performance' ;
    rdfs:comment 'Period-level performance, valuation, and DCF modeling record for an individual portfolio asset. Captures actual results (NOI, EGI, PGI, vacancy rate, CAP rate, cash-on-cash return, unlevered/levered IRR, NPV, DSCR, LTV, total return, OPEX PSF, revenue PSF, occupancy rate, WALT, WALE) and DCF model parameters (model version, discount rate, hold period, projected NOI by year, projected growth rates, exit CAP rate, terminal value, sensitivity scenario). Enables asset-level attribution, scenario analysis, and roll-up to portfolio and fund performance. SSOT for investment-oriented asset analytics. Sourced from Argus Enterprise and Yardi Voyager.' .

ind:DebtFacility rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Investment ;
    rdfs:label 'Debt Facility' ;
    rdfs:comment 'Master record for debt financing instruments secured against investment assets or portfolios — mortgage loans, construction loans, bridge loans, mezzanine debt, CMBS/RMBS, and credit facilities. Captures lender, facility type, principal amounts, interest rate terms, maturity, amortization, LTV, collateral references, recourse type, facility status, and full covenant details: covenant type (LTV, DSCR, occupancy, NOI, debt yield), threshold values, measurement frequency, last measured values, compliance status (compliant, waiver, breach), cure periods, and lender notification requirements. SSOT for investment-level debt instruments and covenant compliance monitoring.' .

ind:DebtCovenant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Investment ;
    rdfs:label 'Debt Covenant' ;
    rdfs:comment 'Tracks financial and operational covenants associated with debt facilities. Captures covenant type (LTV, DSCR, occupancy, NOI, debt yield), covenant threshold value, measurement frequency, last measured value, last measurement date, covenant status (compliant, waiver, breach), cure period, and lender notification requirement. Enables proactive covenant compliance monitoring across the debt portfolio. Sourced from MRI Software and SAP S/4HANA.' .

ind:InvestmentDeal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Investment ;
    rdfs:label 'Investment Deal' ;
    rdfs:comment 'Tracks prospective investment opportunities from initial sourcing through IC approval and closing or rejection. Captures deal name, deal type (acquisition, disposition, recapitalization, JV formation), property type, market/submarket, asking price, underwritten value, target CAP rate, target IRR, deal stage (sourced, LOI, due diligence, IC review, under contract, closed, dead), deal source (broker, off-market, auction), assigned AM, LOI date, contract date, projected close date, IC memo details (recommendation, underwritten equity/debt, key risks, conditions of approval, IC decision, approving members, approval date), and deal status. SSOT for the investment pipeline and IC governance audit trail.' .

ind:CapitalAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Investment ;
    rdfs:label 'Capital Account' ;
    rdfs:comment 'Periodic investor capital account statement summarizing each investor\'s position in a fund. Captures statement period, beginning capital account balance, capital contributions in period, distributions in period, allocated income/loss, management fees charged, carried interest allocated, ending capital account balance, ownership percentage, unrealized gain/loss, and cumulative IRR since inception. Supports LP reporting obligations and ILPA transparency standards. SSOT for investor-level fund position reporting.' .

ind:Appraisal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Valuation ;
    rdfs:label 'Appraisal' ;
    rdfs:comment 'Master record for a formal property appraisal engagement, its deliverable report(s), and status lifecycle. Captures the appraisal order, assigned certified appraiser (MAI, SRA, AI-GRS), appraisal type (full, limited, desktop, drive-by), purpose (financing, disposition, insurance, tax appeal, portfolio review, litigation), USPAP/IVSC-compliant methodology, engagement and report delivery dates, status lifecycle (ordered → in-progress → review → completed/rejected), concluded market value, value date, report format (URAR, narrative, restricted, summary), value type (market, investment, liquidation, insurable), report version (as-is, as-stabilized, as-complete), engagement letter reference, fee, turnaround SLA, and Argus Enterprise model ID where applicable. SSOT for all formal appraisal engagements and their output reports across the portfolio.' .

ind:AppraisalReport rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Valuation ;
    rdfs:label 'Appraisal Report' ;
    rdfs:comment 'The formal deliverable output of an appraisal engagement. Stores report format (URAR, narrative, restricted, summary), concluded market value, value date (effective date of value), report date, value type (market value, investment value, liquidation value, insurable value), IVSC standard applied, report file reference (DocuSign CLM document ID), review status, and reviewer sign-off. One appraisal engagement may produce one or more reports (e.g., as-is vs. as-stabilized).' .

ind:Bpo rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Valuation ;
    rdfs:label 'Bpo' ;
    rdfs:comment 'Broker Price Opinion record capturing informal property value estimates prepared by licensed real estate brokers. Stores BPO type (drive-by, interior, desktop), requesting party, intended use, broker license number, opinion of value (point estimate and low/high range), effective date, market conditions narrative, days-on-market estimate, recommended list price, basis for opinion, engagement fee, turnaround SLA, requester reference, and comparable evidence references. Used for quick portfolio valuations, REO pricing, pre-listing assessments, and lender loss mitigation where a full USPAP appraisal is not required.' .

ind:Cma rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Valuation ;
    rdfs:label 'Cma' ;
    rdfs:comment 'Comparative Market Analysis record used by brokers and agents to estimate property value based on recent comparable sales and active listings. Stores subject property reference, analysis date, analyst (broker/agent), concluded value range, number of comparables used, market trend assessment (appreciating, stable, declining), absorption rate, average PSF of comparables, recommended pricing strategy, and engagement context. Distinct from BPO (less formal, agent-prepared, not broker-licensed requirement) and from full appraisal (not USPAP-compliant). Self-contained engagement record used primarily for listing price recommendations and seller consultations.' .

ind:ComparableSale rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Valuation ;
    rdfs:label 'Comparable Sale' ;
    rdfs:comment 'Individual comparable sale (comp) record used as evidence in appraisals, BPOs, and CMAs. Stores comp property address, sale date, sale price, price PSF, GLA/NLA, property type, year built, condition, location adjustments, physical adjustments, time adjustments, adjusted sale price, data source (CoStar, MLS, public record), and verification status. Supports the sales comparison approach in USPAP/IVSC-compliant valuations. Sourced from CoStar Suite and MLS data feeds.' .

ind:ComparableLease rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Valuation ;
    rdfs:label 'Comparable Lease' ;
    rdfs:comment 'Comparable lease transaction record used as market evidence in income capitalization and rent analysis. Stores comp property address, tenant name, lease execution date, lease commencement date, lease term (months), base rent PSF, rent type (NNN, gross, modified gross), TI allowance PSF, free rent period, lease size (SQF/SQM), property class, submarket, data source (CoStar, MLS, direct), and verification status. Supports market rent conclusions in income approach valuations.' .

ind:Approach rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Valuation ;
    rdfs:label 'Approach' ;
    rdfs:comment 'Valuation approach model record capturing the quantitative analysis for income capitalization and cost approach methodologies. For income capitalization: stores PGI, vacancy/credit loss rate, EGI, total OPEX, NOI, CAP rate, direct capitalization value, terminal CAP rate, discount rate, hold period, IRR/NPV outputs, and concluded market rent inputs. For cost approach: stores land value, replacement cost new (RCN), depreciation components (physical, functional, external obsolescence), depreciated cost of improvements, effective age, economic life, and cost index source (Marshall & Swift, RSMeans). Includes approach type discriminator (direct_cap, DCF, cost, sales_comparison, GRM) and approach weight in final reconciliation. Supports IVSC IVS 105 compliance. After merge with cost_approach, this is the unified approach model for all valuation methodologies.' .

ind:DcfModel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Valuation ;
    rdfs:label 'Dcf Model' ;
    rdfs:comment 'Discounted Cash Flow model record linked to an Argus Enterprise model file. Stores Argus model ID, model version, hold period start and end dates, annual cash flow projections (year 1–10+), reversion/terminal value, discount rate (IRR target), NPV at various discount rates, levered vs. unlevered IRR, equity multiple, DSCR per period, LTV at acquisition, and model assumptions narrative. Serves as the quantitative backbone for investment-grade valuations and acquisition underwriting.' .

ind:CapRateBenchmark rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Valuation ;
    rdfs:label 'Cap Rate Benchmark' ;
    rdfs:comment 'Market CAP rate benchmark record by property type, submarket, and asset class sourced from industry surveys. Stores survey date, property type (office, retail, industrial, multifamily, hotel, data center), submarket/MSA, asset class (Class A/B/C), CAP rate range (low, mid, high), source (CoStar, CBRE, JLL, Cushman & Wakefield, NCREIF, PwC/Korpacz), survey methodology, sample size, and trend direction (compressing, stable, expanding). Used to validate appraiser CAP rate selections, support portfolio-level NAV/GAV calculations, and provide market context for investment committee presentations.' .

ind:NavCalculation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Valuation ;
    rdfs:label 'Nav Calculation' ;
    rdfs:comment 'Net Asset Value (NAV) and Gross Asset Value (GAV) calculation record at the portfolio or fund level. Stores calculation date, portfolio/fund reference, total GAV (sum of market values), total debt outstanding, NAV (GAV minus debt), NAV per unit/share, AFFO adjustment, FFO, methodology (direct capitalization, DCF, third-party appraisal blend), number of properties included, and calculation preparer. Supports REIT financial reporting (SEC), investor reporting, and ASC 820 fair value disclosures.' .

ind:TaxAssessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Valuation ;
    rdfs:label 'Tax Assessment' ;
    rdfs:comment 'Property tax assessment record capturing the assessed value assigned by the taxing authority for ad valorem tax purposes. Stores assessment year, assessed land value, assessed improvement value, total assessed value, assessment ratio, effective tax rate, annual tax liability, taxing jurisdiction, assessment notice date, appeal deadline, and appeal status. Distinct from market value appraisals — assessed value often differs materially from market value and drives property tax expense (a key OPEX component in NOI calculations).' .

ind:PropertySale rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Transaction ;
    rdfs:label 'Property Sale' ;
    rdfs:comment 'Core master record for every property sale or disposition transaction — acquisition, disposition, REO sale, short sale, portfolio trade, or sale-leaseback — capturing executed purchase price, PSF pricing, earnest money terms, closing date, deal type classification, transaction status, and key deal economics (price, PSF, cap rate). Serves as the SSOT hub to which all transaction detail entities (PSA, closing statement, title, deed, financing, escrow, due diligence, parties, offers, documents) are linked via FK. Sourced from Yardi Voyager and CoStar comparable sales data.' .

ind:PurchaseAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Transaction ;
    rdfs:label 'Purchase Agreement' ;
    rdfs:comment 'Records the executed purchase and sale agreement (PSA) for a property transaction, including offer price, contingency terms and deadlines (inspection, financing, appraisal, environmental, zoning, sale of existing home), earnest money terms, due diligence period, closing timeline, and agreement status (LOI, under contract, executed, terminated). Tracks all amendments, addenda, and contingency resolutions through the PSA lifecycle. Integrates with DocuSign CLM for digital execution.' .

ind:ClosingStatement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Transaction ;
    rdfs:label 'Closing Statement' ;
    rdfs:comment 'Captures the final settlement statement (HUD-1 / ALTA Settlement Statement) for a property transaction at closing, including gross sale price, prorations, credits, commissions, title insurance premiums, transfer taxes, loan payoffs, net proceeds to seller, and cash to close for buyer. Represents the authoritative financial record of the closing event. Sourced from title company and Yardi Voyager.' .

ind:TitleSearch rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Transaction ;
    rdfs:label 'Title Search' ;
    rdfs:comment 'Tracks the title search, title commitment, and title insurance policy for a property transaction. Captures ALTA title policy number, insurer, coverage amount, effective date, exceptions and exclusions, lien search results, encumbrances, easements, and COO status. Serves as the authoritative record of title transfer and chain of title. Integrates with ALTA standards.' .

ind:DeedTransfer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Transaction ;
    rdfs:label 'Deed Transfer' ;
    rdfs:comment 'Records the legal deed transfer event for a property, capturing deed type (warranty, quitclaim, special warranty, trustee), grantor, grantee, recording date, county recorder document number, legal description, consideration amount, transfer tax paid, and recording jurisdiction. Represents the official conveyance of real property ownership. Linked to ALTA title records.' .

ind:Financing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Transaction ;
    rdfs:label 'Financing' ;
    rdfs:comment 'Captures the financing structure for a property transaction, including loan type (ARM, FRM, CMBS, bridge, construction), lender name, loan amount, LTV ratio, interest rate, DSCR, loan-to-cost ratio, origination fees, PMI indicator, loan commitment date, and funding date. Tracks both acquisition financing and assumption of existing debt. Supports CMBS and RMBS reporting.' .

ind:Exchange1031 rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Transaction ;
    rdfs:label 'Exchange 1031' ;
    rdfs:comment 'Manages IRS Section 1031 like-kind exchange transactions for tax-deferred property dispositions. Captures relinquished property details, replacement property identification (up to 3-property rule or 200% rule), qualified intermediary (QI) name and account, exchange deadlines (45-day identification period, 180-day closing deadline), boot amount, deferred gain calculation, exchange type (simultaneous, delayed, reverse, Improvement/construction), and IRS compliance status. Tracks exchange fund balances held by QI. Critical for tax-deferred disposition strategies and IRS Form 8824 reporting.' .

ind:DueDiligenceItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Transaction ;
    rdfs:label 'Due Diligence Item' ;
    rdfs:comment 'Tracks individual due diligence tasks, inspections, and findings for a property transaction — environmental Phase I/II, structural/MEP inspection, zoning and entitlement review, ALTA survey, title search, financial audit, rent roll verification, estoppel review, and tenant interview. Captures responsible party, due date, completion date, finding summary, risk rating (red/yellow/green), remediation requirement, cost estimate, and go/no-go recommendation. Enables systematic tracking of all pre-closing diligence obligations and supports investment committee reporting and PSA contingency resolution.' .

ind:DealParty rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Transaction ;
    rdfs:label 'Deal Party' ;
    rdfs:comment 'Association entity capturing all parties and their roles in a property transaction — buyer, seller, buyer\'s broker, seller\'s broker, lender, title company, escrow agent, qualified intermediary (QI), attorney, appraiser, and guarantor. Records role type, entity classification (individual, corporation, REIT, trust, partnership, LLC), contact reference (FK to owner or external party), participation status, and commission split percentage where applicable. Enables multi-party deal tracking, commission allocation, and 1099-S reporting.' .

ind:Offer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Transaction ;
    rdfs:label 'Offer' ;
    rdfs:comment 'Records individual purchase offers submitted on a property, capturing offer price, offer date, financing contingency amount, inspection contingency period, closing date proposed, earnest money offered, escalation clause details, offer status (submitted, countered, accepted, rejected, withdrawn), and competing offer indicator. Supports multi-offer scenario management and deal pipeline tracking in Salesforce CRM.' .

ind:EscrowAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Transaction ;
    rdfs:label 'Escrow Account' ;
    rdfs:comment 'Manages escrow accounts and the complete ledger of fund movements for property transactions — earnest money deposits, impound holds, disbursements (commissions, title fees, transfer taxes, loan payoffs, net proceeds), and releases. Captures escrow account number, escrow holder, escrow type (purchase, impound, reserve), opening balance, current balance, and account status. Each fund event records date, payee/payor, amount, payment method, reference number, authorization status, and release conditions. Provides a complete audit trail from account opening through final disbursement. Integrates with Yardi Voyager AP/AR for trust account reconciliation.' .

ind:EscrowDisbursement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Transaction ;
    rdfs:label 'Escrow Disbursement' ;
    rdfs:comment 'Records individual disbursement events from an escrow account, including disbursement date, payee, disbursement amount, disbursement type (commission, title fee, transfer tax, loan payoff, net proceeds), payment method, reference number, and authorization status. Provides a complete audit trail of all funds released from escrow at or after closing.' .

ind:Guaranty rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Lease ;
    rdfs:label 'Guaranty' ;
    rdfs:comment 'Tracks lease guaranty and guarantor obligations for commercial lease agreements. Captures guarantor identity (individual, corporate parent, or entity), guaranty type (full, limited, good-guy, rolling), guaranteed amount or period, burn-down schedule, guarantor financial covenants, guaranty expiration triggers, and enforcement status. Critical for landlord credit risk management on commercial leases where tenant creditworthiness depends on a third-party guarantee. Sourced from DocuSign CLM and Yardi Voyager.' .

ind:Screening rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Tenant ;
    rdfs:label 'Screening' ;
    rdfs:comment 'Tenant background screening and reference verification record capturing the results of employment verification, landlord reference checks, criminal background checks, identity verification (SSN/ITIN validation), and sex offender registry checks performed during the application qualification process. Records screening vendor (e.g., RentPrep, TransUnion SmartMove), screening request date, completion date, pass/fail determination per check type, adverse action notice requirement, and FCRA compliance status. Supports fair housing compliance, consistent screening criteria enforcement, and audit trail for adverse action decisions.' .

ind:Amenity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Property ;
    rdfs:label 'Amenity' ;
    rdfs:comment 'Physical amenity record for a property or building — pools, fitness centers, parking structures, concierge services, rooftop decks, conference rooms, and other value-add features. Captures amenity type, location within property, capacity, operating hours, condition, and maintenance responsibility.' .

ind:Campaign rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Campaign' ;
    rdfs:comment 'Master record for every marketing campaign executed across commercial and residential portfolios. Captures campaign name, type (digital, print, OOH, email, social, event), objective (lead generation, brand awareness, listing promotion, market penetration), target audience segment, geographic market, property type focus, campaign status (draft, active, paused, completed), planned start and end dates, actual run dates, total approved budget, total spend to date, campaign owner, and associated brand or sub-brand. SSOT for campaign identity across all marketing activities.' .

ind:CampaignFlight rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Campaign Flight' ;
    rdfs:comment 'Transactional record representing a discrete execution flight or burst within a parent campaign — a specific channel activation, media buy, or ad run period. Captures flight name, channel type (Google Ads, Meta, CoStar, Zillow, LoopNet, email, direct mail, billboard), flight start and end dates, flight budget, impressions delivered, clicks, spend, placement details, creative asset reference, and flight status. Enables multi-channel campaign decomposition and channel-level performance tracking.' .

ind:AdCreative rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Ad Creative' ;
    rdfs:comment 'Master record for all marketing creative assets used in campaigns — property listing photos, virtual tour links, brochure PDFs, video walkthroughs, banner ads, email templates, social media graphics, and signage artwork. Captures creative name, format (image, video, PDF, HTML5, copy), dimensions or specs, file URL or DAM reference, associated property or portfolio, brand compliance status, approval status, version number, expiry date, and creative performance metadata. SSOT for creative asset inventory.' .

ind:ListingSyndication rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Listing Syndication' ;
    rdfs:comment 'Transactional record tracking the syndication of a property listing to external marketing portals and platforms — Zillow, Realtor.com, LoopNet, CoStar, Apartments.com, MLS, and proprietary websites. Captures listing reference, target platform, syndication status (pending, live, expired, pulled), publish date, expiry date, listing URL on platform, feed type (RETS, RESO Web API, IDX, manual), last sync timestamp, and any platform-specific override fields. Distinct from brokerage.mls_syndication which is brokerage-owned; this entity is marketing-owned for campaign-driven syndication.' .

ind:Lead rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Lead' ;
    rdfs:comment 'SSOT master record for every inbound marketing lead generated across all channels — web inquiries, portal leads (Zillow, CoStar, LoopNet), email responses, open house sign-ins, social media DMs, referral submissions, and event registrations. Captures lead source, channel, campaign attribution, lead type (buyer, tenant, investor, seller), property of interest, contact details, lead status (new, contacted, qualified, disqualified, converted), lead score, assigned agent or leasing rep, first contact date, and last activity date. Distinct from brokerage.prospect (brokerage-owned pipeline) and tenant.prospect (tenancy-specific).' .

ind:LeadActivity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Lead Activity' ;
    rdfs:comment 'Transactional record capturing every discrete activity or touchpoint associated with a marketing lead — email opens, link clicks, portal page views, call attempts, SMS responses, chatbot interactions, and form submissions. Captures lead reference, activity type, activity timestamp, channel, campaign flight reference, content or page viewed, outcome, and agent or system that performed the action. Enables lead nurture tracking, attribution modeling, and conversion funnel analysis.' .

ind:MarketResearch rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Market Research' ;
    rdfs:comment 'Master record for formal market research studies, competitive intelligence reports, and market analysis engagements commissioned or produced by the marketing team. Captures research title, research type (submarket analysis, competitive landscape, demand study, absorption study, rent survey, buyer sentiment), geographic market or submarket, property type focus, research date, research provider (internal or third-party firm), key findings summary, report file URL, data sources used, and publication status. SSOT for market intelligence assets.' .

ind:MarketSurvey rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Market Survey' ;
    rdfs:comment 'Transactional record of a periodic market survey event capturing point-in-time competitive market data for a defined submarket or competitive set — rent surveys, vacancy surveys, absorption surveys, and concession surveys. Captures survey date, submarket or geographic area, property type, survey type, surveyor name, number of properties surveyed, average asking rent, average effective rent, vacancy rate, absorption rate, average concession value, and survey notes. Enables trend tracking and market positioning decisions.' .

ind:Event rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Event' ;
    rdfs:comment 'Master record for marketing events organized or sponsored by the real estate enterprise — open houses, broker previews, investor days, property launch events, community outreach events, trade show participations, and webinars. Captures event name, event type, property or portfolio reference, venue, event date and time, target audience, expected attendance, actual attendance, registration count, event status, event owner, associated campaign reference, and total event cost. Enables event-driven lead generation tracking.' .

ind:EventRegistration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Event Registration' ;
    rdfs:comment 'Transactional record of an individual registrant or attendee for a marketing event — capturing registration date, registrant contact details, registrant type (prospect, broker, investor, tenant, media), registration source, attendance status (registered, attended, no-show, cancelled), lead reference if converted, and post-event follow-up status. Enables event ROI measurement and lead capture from event-driven marketing activities.' .

ind:Channel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Channel' ;
    rdfs:comment 'Reference master for all marketing channels used to reach prospects, tenants, buyers, and investors — defining the standardized channel taxonomy across the enterprise. Captures channel name, channel category (digital paid, digital organic, social media, email, direct mail, OOH, events, referral, broker network, MLS/portal), channel description, platform or vendor name, tracking capability (UTM, pixel, call tracking), cost model (CPM, CPC, CPL, flat fee), and channel status. Enables consistent channel attribution and spend categorization.' .

ind:EnergyMeter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Energy Meter' ;
    rdfs:comment 'Master record for utility meters and energy monitoring devices installed at managed properties — electric, gas, water, and steam meters. Captures meter ID, meter type, utility provider account number, installation location (building, floor, unit), read frequency, and current status. Supports utility cost allocation, energy benchmarking, and sustainability reporting.' .

ind:PurchaseOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Purchase Order' ;
    rdfs:comment 'Master reference table for purchase_order. Referenced by purchase_order_id.' .

ind:PaymentRun rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Payment Run' ;
    rdfs:comment 'Master reference table for payment_run. Referenced by payment_run_id.' .

ind:Lender rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Lender' ;
    rdfs:comment 'Master reference table for lender. Referenced by lender_id.' .

ind:Ledger rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Ledger' ;
    rdfs:comment 'Master reference table for ledger. Referenced by ledger_id.' .

ind:ReportingPeriod rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Reporting Period' ;
    rdfs:comment 'Master reference table for reporting_period. Referenced by reporting_period_id.' .

ind:Floor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Property ;
    rdfs:label 'Floor' ;
    rdfs:comment 'Master reference table for floor. Referenced by floor_id.' .

ind:NavAppraisalInput rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Valuation ;
    rdfs:label 'Nav Appraisal Input' ;
    rdfs:comment 'This association product represents the formal input record (Contract/Schedule) between a NAV calculation and a constituent appraisal. It captures which appraisal values were used as inputs to a specific NAV/GAV calculation, at what proportional weight, and what dollar contribution each appraisal made to the total GAV. Each record links one nav_calculation to one appraisal and carries attributes that exist only in the context of this specific input relationship — the weight, contribution, effective date used, and coverage flag. This is the operational record that fund accountants and valuation teams manage to support REIT financial reporting, SEC disclosures, and ASC 820 fair value documentation.. Existence Justification: In real estate fund management, NAV calculations are formal periodic exercises (monthly, quarterly, annually) that aggregate appraised values across all portfolio properties — a single NAV calculation genuinely consumes many appraisals as inputs. Conversely, a single appraisal (e.g., a Q3 independent appraisal of a Class A office building) feeds into multiple NAV calculations over time: the current period\'s fund-level NAV, a prior-period restatement, and potentially multiple fund structures that hold the same asset. This is an operationally managed relationship — fund accountants and valuation teams actively track which appraisals were used in which NAV calculation, at what weight, and what value contribution each appraisal made.' .

ind:SiteCoverage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Property ;
    rdfs:label 'Site Coverage' ;
    rdfs:comment 'This association product represents the Site Coverage relationship between a building and a land parcel. It captures the legally and operationally significant fact that a building\'s physical footprint may span one or more legal parcels, and that a parcel may host one or more buildings. Each record links one building to one parcel and carries attributes — coverage percentage, covered square footage, primary parcel designation, and effective date — that exist only in the context of this specific building-parcel pairing. Used by tax assessment, title, GIS, and zoning compliance teams.. Existence Justification: In commercial real estate, a single building can physically span multiple legal parcels (e.g., a large office tower or campus straddling two or more APN-delineated lots), and a single parcel can contain multiple buildings (e.g., a mixed-use development or industrial park). This is an operationally managed relationship: tax assessors apportion assessed value across parcels, title companies track which parcels are encumbered by which structures, and GIS/site teams track coverage percentages for zoning compliance and FAR calculations. The relationship is actively created, updated, and queried by real estate operations, legal, and tax teams.' .

ind:ContractAssetCoverage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Contract Asset Coverage' ;
    rdfs:comment 'This association product represents the Contract between service_contract and building_asset. It captures the formal coverage relationship defining which specific building equipment assets are in scope for a given maintenance service contract. Each record links one service_contract to one building_asset and carries attributes — coverage scope, effective dates, and primary-contract designation — that exist only in the context of this specific contract-asset pairing. Operationally managed by facility managers when contracts are executed, amended, or when assets are added/removed from scope.. Existence Justification: In real estate facility management, a single service contract (e.g., an HVAC maintenance agreement) routinely covers a portfolio of specific building assets — multiple rooftop units, air handling units, and chillers — while a single building asset (e.g., a chiller) may be covered by multiple contracts over time or simultaneously by overlapping agreements (e.g., a manufacturer warranty-backed service contract AND a full-coverage HVAC contract). The business actively manages which assets are in scope for each contract, adds or removes assets when scope changes, and tracks coverage dates and primary-contract designation per asset. This is not derivable from existing FKs — the `asset_id` on `service_contract` is described as a reference to the \'primary property\', not to individual equipment assets.' .

# --- Attribute Properties ---
ind:ownerId rdf:type rdf:Property ;
    rdfs:label 'Owner Id' ;
    rdfs:comment 'Unique surrogate identifier for each property owner or investor entity in the master registry. Primary key for the owner data product, sourced from Yardi Voyager and MRI Software.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Owner .

ind:domicileCountryId rdf:type rdf:Property ;
    rdfs:label 'Domicile Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Owner domicile country drives FATCA/CRS classification, foreign ownership restrictions, withholding tax rates, and tax treaty eligibility. Compliance officers and relationship managers require this li' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:domicileGeographicHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Domicile Geographic Hierarchy Id' ;
    rdfs:comment 'Foreign key linking to reference.geographic_hierarchy. Business justification: Investor domicile geographic hierarchy is used in AML/KYC geographic risk scoring, investor concentration reporting by market, and regulatory jurisdiction mapping. A real estate domain expert expects ' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeographicHierarchy .

ind:functionalCurrencyCodeId rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Code Id' ;
    rdfs:comment 'Foreign key linking to reference.currency_code. Business justification: Owner\'s functional/reporting currency drives multi-currency distribution calculations, K-1 preparation, and investor reporting. Real estate fund administrators must know each owner\'s functional curren' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CurrencyCode .

ind:jurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Id' ;
    rdfs:comment 'Foreign key linking to compliance.jurisdiction. Business justification: Owner domicile determines which jurisdiction\'s KYC, FATCA, CRS, and AML regulations apply. Compliance officers use this link to identify applicable regulatory obligations per owner for investor onboar' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:marketSegmentId rdf:type rdf:Property ;
    rdfs:label 'Market Segment Id' ;
    rdfs:comment 'Foreign key linking to reference.market_segment. Business justification: Investor classification by market segment (core, value-add, opportunistic) drives deal matching, IRR benchmarking, and portfolio reporting. Relationship managers use this to align owner investment pre' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketSegment .

ind:mriInvestorId rdf:type rdf:Property ;
    rdfs:label 'Mri Investor Id' ;
    rdfs:comment 'Source system investor identifier assigned in MRI Software\'s Investment Management module. Used for cross-system reconciliation and data lineage tracking between MRI Software and the Databricks silver layer master registry.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Investor .

ind:accreditedInvestorFlag rdf:type rdf:Property ;
    rdfs:label 'Accredited Investor Flag' ;
    rdfs:comment 'Indicates whether the owner entity qualifies as an accredited investor under SEC Regulation D. True = meets net worth or income thresholds; False = does not qualify. Determines eligibility for private placement offerings and Regulation D exempt securities.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:aumTier rdf:type rdf:Property ;
    rdfs:label 'Aum Tier' ;
    rdfs:comment 'Classification tier based on the owner entity\'s total Assets Under Management (AUM). Used for investor segmentation, relationship management prioritization, and fee schedule assignment. Micro = <$10M; Small = $10M-$100M; Mid = $100M-$1B; Large = $1B-$10B; Mega = >$10B.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountRef rdf:type rdf:Property ;
    rdfs:label 'Bank Account Ref' ;
    rdfs:comment 'Masked or tokenized reference to the owner entity\'s designated bank account for distribution payments and capital call receipts. Full account details are stored in the secure payment vault; this field holds only the reference token or last-4 identifier for operational use.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficialOwnerFlag rdf:type rdf:Property ;
    rdfs:label 'Beneficial Owner Flag' ;
    rdfs:comment 'Indicates whether this entity is identified as a beneficial owner (i.e., the natural person who ultimately owns or controls the entity) per FinCEN Customer Due Diligence rules. True = beneficial owner identified and disclosed; False = entity is an intermediary or nominee. Critical for AML compliance.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:beneficialOwnershipPct rdf:type rdf:Property ;
    rdfs:label 'Beneficial Ownership Pct' ;
    rdfs:comment 'Percentage of beneficial ownership held by this entity in the associated investment vehicle or property. Used for FinCEN reporting (25% threshold rule), equity distribution calculations, and waterfall modeling. Expressed as a percentage (e.g., 25.00 = 25%).' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Timestamp when the owner record was first created in the system, in ISO 8601 format with timezone offset (yyyy-MM-ddTHH:mm:ss.SSSXXX). Serves as the authoritative audit trail creation marker for data governance and SOX compliance.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:distributionFrequency rdf:type rdf:Property ;
    rdfs:label 'Distribution Frequency' ;
    rdfs:comment 'Frequency at which investment distributions (income and/or return of capital) are made to the owner entity. Drives cash flow scheduling in Yardi Voyager AR module and investor reporting cycles.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionMethod rdf:type rdf:Property ;
    rdfs:label 'Distribution Method' ;
    rdfs:comment 'Preferred method for receiving investment distributions. Wire Transfer = international/domestic wire; ACH = Automated Clearing House electronic transfer; Check = paper check; DRIP = Distribution Reinvestment Plan (reinvest distributions into additional units).' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:domicileState rdf:type rdf:Property ;
    rdfs:label 'Domicile State' ;
    rdfs:comment 'State or province of legal domicile or incorporation for the owner entity. Used for state-level tax compliance, regulatory filings, and jurisdictional reporting. Expressed as ISO 3166-2 subdivision code where applicable.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'Legal classification of the owner entity. Determines applicable regulatory, tax, and reporting obligations. [ENUM-REF-CANDIDATE: individual|corporation|partnership|trust|reit|sovereign_wealth_fund|family_office|joint_venture|llc|government_entity — promote to reference product]' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgMandateFlag rdf:type rdf:Property ;
    rdfs:label 'Esg Mandate Flag' ;
    rdfs:comment 'Indicates whether the owner entity has a formal ESG (Environmental, Social, and Governance) investment mandate requiring portfolio properties to meet specific sustainability criteria (e.g., LEED, BREEAM certifications). True = ESG mandate in place; False = no formal ESG requirement.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fatcaStatus rdf:type rdf:Property ;
    rdfs:label 'Fatca Status' ;
    rdfs:comment 'FATCA (Foreign Account Tax Compliance Act) classification of the owner entity. US Person = US citizen/resident/entity; FFI = Foreign Financial Institution; NFFE = Non-Financial Foreign Entity; Exempt = exempt from FATCA reporting; Unknown = not yet determined. Drives IRS Form W-8/W-9 requirements.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycStatus rdf:type rdf:Property ;
    rdfs:label 'Kyc Status' ;
    rdfs:comment 'Current status of the Know Your Customer (KYC) due diligence process for the owner entity. Required for AML compliance and investor onboarding. Tracks whether identity verification, beneficial ownership disclosure, and sanctions screening have been completed.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Verified Date' ;
    rdfs:comment 'Date on which the KYC verification was last successfully completed and approved for this owner entity. Used to track compliance currency and trigger periodic re-verification workflows.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'Full legal name of the owner or investor entity as registered with the relevant government authority. For individuals, this is the full legal name; for entities, this is the registered corporate or trust name. Used as the authoritative identity label across all portfolio records.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leiCode rdf:type rdf:Property ;
    rdfs:label 'Lei Code' ;
    rdfs:comment '20-character alphanumeric Legal Entity Identifier (LEI) code assigned by a GLEIF-accredited Local Operating Unit. Required for institutional investors and publicly traded REITs for regulatory reporting and counterparty identification in financial transactions.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddressCity rdf:type rdf:Property ;
    rdfs:label 'Mailing Address City' ;
    rdfs:comment 'City component of the owner entity\'s primary mailing address. Used in conjunction with state and postal code for address validation and regulatory correspondence.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddressCountry rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the owner entity\'s primary mailing address. Determines applicable postal regulations, cross-border tax withholding, and FATCA/CRS reporting.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Line1' ;
    rdfs:comment 'First line of the owner entity\'s primary mailing address, including street number and street name. Used for legal notices, distribution checks, K-1 tax forms, and investor correspondence.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offboardingDate rdf:type rdf:Property ;
    rdfs:label 'Offboarding Date' ;
    rdfs:comment 'Date on which the owner entity was formally offboarded or terminated from the platform, following full disposition of holdings and settlement of obligations. Null if the owner is still active.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'Date on which the owner entity was formally onboarded and activated in the platform, completing all KYC, AML, and documentation requirements. Marks the start of the active relationship lifecycle.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingStatus rdf:type rdf:Property ;
    rdfs:label 'Onboarding Status' ;
    rdfs:comment 'Current lifecycle status of the owner entity within the platform. Drives access controls, KYC compliance gating, and operational workflows in Yardi Voyager and MRI Software. Pending = KYC in progress; Active = fully onboarded; Suspended = compliance hold; Inactive = no current holdings; Terminated = relationship ended.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerClass rdf:type rdf:Property ;
    rdfs:label 'Owner Class' ;
    rdfs:comment 'High-level investor classification used for portfolio segmentation, AUM (Assets Under Management) reporting, and investment advisory targeting. Distinguishes institutional investors from private individuals, public REITs, family offices, and sovereign wealth funds.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:politicallyExposedFlag rdf:type rdf:Property ;
    rdfs:label 'Politically Exposed Flag' ;
    rdfs:comment 'Indicates whether the owner entity or its beneficial owners are classified as Politically Exposed Persons (PEPs) — individuals who hold or have held prominent public positions. True = PEP identified; False = no PEP association. Triggers enhanced due diligence (EDD) requirements under AML regulations.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredAssetClasses rdf:type rdf:Property ;
    rdfs:label 'Preferred Asset Classes' ;
    rdfs:comment 'Comma-delimited list of real estate asset classes preferred by the owner for investment (e.g., office, retail, multifamily, industrial, hospitality, mixed-use). Used for deal matching, investment advisory targeting, and portfolio strategy alignment in Argus Enterprise and Salesforce CRM.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredHoldPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Preferred Hold Period Years' ;
    rdfs:comment 'Owner\'s stated preferred investment hold period in years. Used for portfolio strategy alignment, DCF (Discounted Cash Flow) modeling in Argus Enterprise, and WALT (Weighted Average Lease Term) matching during acquisition underwriting.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Email' ;
    rdfs:comment 'Primary email address for official communications with the owner entity. Used for investor reporting, distribution notices, KYC correspondence, and portal access credentials. Sourced from Yardi Voyager and Salesforce CRM.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Phone' ;
    rdfs:comment 'Primary telephone number for the owner entity, stored in E.164 international format. Used for investor relations, KYC verification callbacks, and urgent operational communications.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifiedPurchaserFlag rdf:type rdf:Property ;
    rdfs:label 'Qualified Purchaser Flag' ;
    rdfs:comment 'Indicates whether the owner entity qualifies as a qualified purchaser under the Investment Company Act of 1940 (Section 2(a)(51)), typically requiring $5M+ in investments. Determines eligibility for Section 3(c)(7) fund offerings.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'Official registration or incorporation number issued by the relevant government authority (e.g., Secretary of State, Companies House). Used to verify legal existence and cross-reference with public registries. Applicable to corporations, LLCs, partnerships, and trusts.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTolerance rdf:type rdf:Property ;
    rdfs:label 'Risk Tolerance' ;
    rdfs:comment 'Owner\'s stated investment risk tolerance profile, aligned with standard CRE (Commercial Real Estate) investment strategy classifications. Core = low risk/stable income; Core Plus = moderate risk; Value Add = higher risk/repositioning; Opportunistic = highest risk/development. Used in Argus Enterprise for portfolio strategy modeling.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsScreenedFlag rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screened Flag' ;
    rdfs:comment 'Indicates whether the owner entity has been screened against OFAC SDN (Specially Designated Nationals) list, EU sanctions lists, and other applicable sanctions databases. True = screening completed with no match; False = not yet screened or match found requiring review.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetCapRatePct rdf:type rdf:Property ;
    rdfs:label 'Target Cap Rate Pct' ;
    rdfs:comment 'Owner\'s stated target Capitalization Rate (CAP Rate) for property acquisitions, expressed as a percentage (e.g., 5.50 = 5.5%). Used for deal screening and investment underwriting in Argus Enterprise. CAP Rate = NOI / Property Value.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetIrrPct rdf:type rdf:Property ;
    rdfs:label 'Target Irr Pct' ;
    rdfs:comment 'Owner\'s stated minimum target Internal Rate of Return (IRR) hurdle rate for investment decisions, expressed as a percentage (e.g., 12.00 = 12%). Used in Argus Enterprise for deal screening, investment committee approvals, and portfolio performance benchmarking.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxExemptFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Flag' ;
    rdfs:comment 'Indicates whether the owner entity holds tax-exempt status (e.g., pension funds, endowments, sovereign wealth funds, charitable organizations). True = tax-exempt; False = taxable entity. Affects UBTI (Unrelated Business Taxable Income) calculations and withholding tax obligations.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxIdType rdf:type rdf:Property ;
    rdfs:label 'Tax Id Type' ;
    rdfs:comment 'Classifies the type of tax identification number stored in tax_id. Determines applicable IRS reporting forms and withholding rules. EIN = Employer Identification Number; SSN = Social Security Number; TIN = Tax Identification Number (generic); ITIN = Individual Taxpayer Identification Number.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'Government-issued tax identification number for the owner entity. For US entities: Employer Identification Number (EIN) for corporations/partnerships or Social Security Number (SSN) for individuals. For non-US entities: equivalent Tax Identification Number (TIN). Used for IRS 1099 reporting, withholding tax, and FATCA compliance.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingName rdf:type rdf:Property ;
    rdfs:label 'Trading Name' ;
    rdfs:comment 'Operating or trade name (Doing Business As) used by the owner entity in commercial dealings, if different from the legal name. Common for partnerships, family offices, and REITs operating under a brand name.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to the owner record, in ISO 8601 format with timezone offset (yyyy-MM-ddTHH:mm:ss.SSSXXX). Used for change data capture (CDC), data lineage tracking, and audit compliance.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:yardiEntityCode rdf:type rdf:Property ;
    rdfs:label 'Yardi Entity Code' ;
    rdfs:comment 'Source system entity code assigned to this owner in Yardi Voyager. Used for cross-system reconciliation between the silver layer master registry and the Yardi Voyager operational system of record. Enables traceability back to the source.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerContactId rdf:type rdf:Property ;
    rdfs:label 'Owner Contact Id' ;
    rdfs:comment 'Unique surrogate identifier for each owner contact record in the Silver Layer lakehouse. Primary key for the owner_contact data product.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OwnerContact .

ind:mailingCountryId rdf:type rdf:Property ;
    rdfs:label 'Mailing Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Contact mailing country determines GDPR applicability, sanctions screening jurisdiction, and communication compliance requirements. Compliance teams require normalized country reference for cross-bord' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:consentObtainedDate rdf:type rdf:Property ;
    rdfs:label 'Consent Obtained Date' ;
    rdfs:comment 'Date on which explicit consent was obtained from this contact for electronic communications and data processing. Required for GDPR Article 6 lawful basis documentation and CAN-SPAM/TCPA compliance for marketing and investor communications.' ;
    rdfs:domain ind:OwnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentType rdf:type rdf:Property ;
    rdfs:label 'Consent Type' ;
    rdfs:comment 'Type of legal basis or consent obtained for processing and communicating with this contact under GDPR Article 6. Explicit: affirmative opt-in consent. Implied: consent inferred from business relationship. Legitimate_interest: processing based on legitimate business interest. Not_obtained: consent not yet collected.' ;
    rdfs:domain ind:OwnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactSource rdf:type rdf:Property ;
    rdfs:label 'Contact Source' ;
    rdfs:comment 'Originating system or channel from which this contact record was created or imported. Supports data lineage tracking and master data management reconciliation across Yardi Voyager, MRI Software, and Salesforce CRM.' ;
    rdfs:domain ind:OwnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of this contact record. Active: contact is current and reachable. Inactive: contact is no longer in use but retained for historical reference. Do_not_contact: contact has opted out or is legally restricted. Pending_verification: contact details awaiting KYC/AML validation. Deceased: individual contact is deceased.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'Indicates whether this contact record represents an individual person (e.g., named representative) or an organizational entity (e.g., law firm, accounting firm) acting on behalf of the owner.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'Business unit or department within the owner\'s organization that this contact represents (e.g., Legal, Finance, Asset Management, Investor Relations, Operations). Supports targeted communication routing for institutional owners.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotContactReason rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact Reason' ;
    rdfs:comment 'Reason code explaining why this contact has been flagged as do-not-contact. Applicable when contact_status is \'do_not_contact\'. Supports GDPR right-to-erasure and CAN-SPAM opt-out compliance tracking.' ;
    rdfs:domain ind:OwnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Date from which this contact record is considered active and valid for the owner entity. Supports temporal validity tracking for contact records, particularly relevant when contacts change roles or when new authorized representatives are designated.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'Date on which this contact record ceases to be active for the owner entity. Null indicates the contact is currently active with no defined end date. Used to manage contact record lifecycle and historical audit trails.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalContactRef rdf:type rdf:Property ;
    rdfs:label 'External Contact Ref' ;
    rdfs:comment 'Identifier for this contact record in the originating source system (e.g., Yardi Voyager contact ID, Salesforce CRM contact ID, MRI contact code). Supports cross-system reconciliation and data lineage in the Silver Layer.' ;
    rdfs:domain ind:OwnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Given name of the individual contact person. Applicable when contact_type is \'individual\'. Used for personalized correspondence and legal documentation.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAuthorizedSignatory rdf:type rdf:Property ;
    rdfs:label 'Is Authorized Signatory' ;
    rdfs:comment 'Indicates whether this contact is authorized to execute legal documents, contracts, and agreements on behalf of the owner entity. Critical for DocuSign CLM workflow routing and lease execution authorization under SNDA and ALTA requirements.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isKycVerified rdf:type rdf:Property ;
    rdfs:label 'Is Kyc Verified' ;
    rdfs:comment 'Indicates whether this contact has completed the Know Your Customer (KYC) identity verification process as part of investor onboarding. Required for AML compliance and regulatory reporting for REIT investors and institutional owners.' ;
    rdfs:domain ind:OwnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Indicates whether this contact record is designated as the primary point of contact for the owner entity. Only one contact per owner should have this flag set to True. Used to determine default routing for communications and notifications.' ;
    rdfs:domain ind:OwnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'Professional title or designation of the individual contact (e.g., Chief Financial Officer, Asset Manager, General Counsel, Investor Relations Director). Supports routing of communications to the appropriate decision-maker.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Expiry Date' ;
    rdfs:comment 'Date on which the current KYC verification for this contact expires and re-verification is required. Supports proactive compliance management and automated re-verification workflow triggers.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Verification Date' ;
    rdfs:comment 'Date on which the KYC identity verification was completed for this contact. Used to track compliance currency and trigger re-verification workflows when KYC records expire per regulatory requirements.' ;
    rdfs:domain ind:OwnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Family name or surname of the individual contact person. Applicable when contact_type is \'individual\'. Used in combination with first_name for full legal name construction.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedinUrl rdf:type rdf:Property ;
    rdfs:label 'Linkedin Url' ;
    rdfs:comment 'LinkedIn professional profile URL for this contact. Used by brokerage and investor relations teams for professional background verification, relationship management, and deal sourcing activities tracked in Salesforce CRM.' ;
    rdfs:domain ind:OwnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Line2' ;
    rdfs:comment 'Second line of the mailing address for this contact, typically containing suite, unit, floor, or building number. Supplements mailing_address_line1 for complete address specification.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCity rdf:type rdf:Property ;
    rdfs:label 'Mailing City' ;
    rdfs:comment 'City or municipality of the mailing address for this contact. Used in conjunction with mailing_state and mailing_postal_code for complete address validation and geographic reporting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Mailing Postal Code' ;
    rdfs:comment 'ZIP code or postal code of the mailing address for this contact. Used for mail delivery, geographic segmentation, and regulatory jurisdiction determination.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingState rdf:type rdf:Property ;
    rdfs:label 'Mailing State' ;
    rdfs:comment 'State, province, or territory of the mailing address for this contact. For US addresses, use the two-letter USPS state abbreviation (e.g., CA, NY, TX). For international addresses, use the appropriate regional subdivision code.' ;
    rdfs:domain ind:OwnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for capturing additional context, special instructions, or relationship notes about this contact. Examples include communication preferences, relationship history, or special handling instructions for investor relations. Classified confidential due to potential sensitivity of relationship notes.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationName rdf:type rdf:Property ;
    rdfs:label 'Organization Name' ;
    rdfs:comment 'Legal or trading name of the organization acting as the contact, applicable when contact_type is \'organization\' (e.g., law firm, accounting firm, property management company). Also used for the employer/firm name when the contact is an individual representative of an institution.' ;
    rdfs:domain ind:OwnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommunicationChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Channel' ;
    rdfs:comment 'The contact\'s preferred method for receiving communications from the real estate organization. Drives automated notification routing in Yardi Voyager and Salesforce CRM. Options: email (electronic mail), phone (voice call), mail (postal mail), portal (owner/investor portal), fax.' ;
    rdfs:domain ind:OwnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'BCP 47 language tag representing the contact\'s preferred language for communications (e.g., en-US, fr-FR, es-MX, zh-CN). Supports multilingual correspondence for international investors and cross-border real estate transactions.' ;
    rdfs:domain ind:OwnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhoneType rdf:type rdf:Property ;
    rdfs:label 'Primary Phone Type' ;
    rdfs:comment 'Classification of the primary phone number indicating the type of line: mobile (cell phone), office (main switchboard), direct (direct dial line), home (residential), or fax. Supports appropriate communication channel selection.' ;
    rdfs:domain ind:OwnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleType rdf:type rdf:Property ;
    rdfs:label 'Role Type' ;
    rdfs:comment 'Functional role of this contact within the owner entity hierarchy. Determines routing of communications: primary (main point of contact), legal (attorney or legal counsel), financial (CFO, accountant, or investor relations), operational (property or asset manager), emergency (24/7 escalation), secondary (backup contact). [ENUM-REF-CANDIDATE: primary|legal|financial|operational|emergency|secondary — promote to reference product if additional roles are needed]' ;
    rdfs:domain ind:OwnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salutation rdf:type rdf:Property ;
    rdfs:label 'Salutation' ;
    rdfs:comment 'Formal salutation or honorific prefix for the individual contact (e.g., Mr., Ms., Dr., Prof.). Used in formal correspondence, legal notices, and investor communications to ensure appropriate professional address.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suffix rdf:type rdf:Property ;
    rdfs:label 'Suffix' ;
    rdfs:comment 'Name suffix for the individual contact (e.g., Jr., Sr., III, Esq., CPA, CFA). Used in formal legal and financial correspondence to accurately represent the contact\'s full legal name.' ;
    rdfs:domain ind:OwnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the contact\'s primary location (e.g., America/New_York, Europe/London, Asia/Singapore). Used to schedule communications, meetings, and automated notifications at appropriate local times for international investors and cross-border transactions.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerOwnershipInterestId rdf:type rdf:Property ;
    rdfs:label 'Owner Ownership Interest Id' ;
    rdfs:comment 'Unique system-generated surrogate identifier for each ownership interest record. Primary key for the ownership_interest data product.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OwnerOwnershipInterest .

ind:appraisalId rdf:type rdf:Property ;
    rdfs:label 'Appraisal Id' ;
    rdfs:comment 'Foreign key linking to valuation.appraisal. Business justification: Ownership interests require appraisal-backed fair market value at acquisition and periodic revaluation for audit, lender covenant compliance, and equity value reporting. A domain expert expects each i' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Appraisal .

ind:assetId rdf:type rdf:Property ;
    rdfs:label 'Asset Id' ;
    rdfs:comment 'Reference to the specific property or real estate asset in which the ownership interest is held. Enables property-level ownership attribution and portfolio aggregation.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:commitmentId rdf:type rdf:Property ;
    rdfs:label 'Commitment Id' ;
    rdfs:comment 'Foreign key linking to investment.commitment. Business justification: An owner\'s fund ownership interest is established through their subscription commitment. Linking ownership_interest to commitment enables ownership percentage calculation from committed capital, capit' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Commitment .

ind:currencyCodeId rdf:type rdf:Property ;
    rdfs:label 'Currency Code Id' ;
    rdfs:comment 'Foreign key linking to reference.currency_code. Business justification: Ownership interest currency drives multi-currency equity valuation, FX rate lookups for USD reporting, and investor capital account statements. Fund accountants require normalized currency reference f' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CurrencyCode .

ind:devProjectId rdf:type rdf:Property ;
    rdfs:label 'Dev Project Id' ;
    rdfs:comment 'Foreign key linking to development.dev_project. Business justification: JV equity interests and promote structures in development are tracked at the project level, often before a stabilized asset exists. Linking ownership_interest to dev_project enables promote waterfall ' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DevProject .

ind:fundId rdf:type rdf:Property ;
    rdfs:label 'Fund Id' ;
    rdfs:comment 'Foreign key linking to investment.fund. Business justification: Direct fund investments (without an intermediate vehicle) require ownership_interest to reference the fund for K-1 allocation, IRR attribution, and LP capital account statements. Real estate fund oper' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fund .

ind:ledgerId rdf:type rdf:Property ;
    rdfs:label 'Ledger Id' ;
    rdfs:comment 'Foreign key linking to finance.ledger. Business justification: Each ownership interest is maintained on a specific accounting ledger for capital account tracking. Fund administrators assign ledgers to ownership interests for GAAP/tax basis reporting and investor ' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ledger .

ind:listingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Listing Agreement Id' ;
    rdfs:comment 'Foreign key linking to brokerage.listing_agreement. Business justification: When an ownership interest is being marketed for disposition, a listing agreement governs that process. Disposition management teams track which listing agreement covers which specific equity stake be' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ListingAgreement .

ind:ownerAgreementId rdf:type rdf:Property ;
    rdfs:label 'Owner Agreement Id' ;
    rdfs:comment 'Foreign key linking to owner.owner_agreement. Business justification: owner_ownership_interest has an ownership_agreement_reference STRING column that stores a free-text reference to the governing ownership agreement. This is a clear normalization gap — it should be a p' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OwnerAgreement .

ind:ownershipStructureId rdf:type rdf:Property ;
    rdfs:label 'Ownership Structure Id' ;
    rdfs:comment 'Foreign key linking to owner.ownership_structure. Business justification: An ownership interest (equity stake in a property or investment) is held WITHIN a specific legal/organizational ownership structure (LLC, JV, REIT, partnership). ownership_structure is the parent enti' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OwnershipStructure .

ind:portfolioAssetId rdf:type rdf:Property ;
    rdfs:label 'Portfolio Asset Id' ;
    rdfs:comment 'Foreign key linking to investment.portfolio_asset. Business justification: An ownership interest in a property corresponds to a portfolio_asset record in the investment domain. This link enables cross-domain reconciliation of equity ownership percentages, acquisition costs, ' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortfolioAsset .

ind:transactionTypeId rdf:type rdf:Property ;
    rdfs:label 'Transaction Type Id' ;
    rdfs:comment 'Foreign key linking to reference.transaction_type. Business justification: Ownership interest acquisition transaction type (arm\'s length purchase, 1031 exchange, foreclosure, contribution) determines tax basis treatment, SEC reportability, and due diligence requirements. Tax' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransactionType .

ind:unitId rdf:type rdf:Property ;
    rdfs:label 'Unit Id' ;
    rdfs:comment 'Foreign key linking to property.unit. Business justification: In condominium and co-op regimes, owners hold title to specific units. Unit-level ownership tracking is required for condo association governance, unit-level title insurance, and HOA fee allocation. A' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'The date on which the ownership interest was legally acquired or became effective. Used for cost basis calculation, holding period determination, capital gains tax reporting, and IRR (Internal Rate of Return) analysis.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coOwnershipFlag rdf:type rdf:Property ;
    rdfs:label 'Co Ownership Flag' ;
    rdfs:comment 'Indicates whether this ownership interest exists within a co-ownership arrangement (True), meaning multiple owners hold interests in the same property simultaneously. Triggers co-owner reconciliation and consent requirement workflows.' ;
    rdfs:domain ind:OwnerOwnershipInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controllingInterestFlag rdf:type rdf:Property ;
    rdfs:label 'Controlling Interest Flag' ;
    rdfs:comment 'Indicates whether this ownership interest constitutes a controlling interest (True), typically defined as ownership exceeding 50% or as defined by the governing JV or partnership agreement. Triggers consolidation requirements under FASB ASC 810.' ;
    rdfs:domain ind:OwnerOwnershipInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costBasisAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Basis Amount' ;
    rdfs:comment 'The original acquisition cost of the ownership interest, including purchase price, transaction costs, and capitalized improvements attributable to this interest. Used for depreciation schedules, capital gains calculation, and CAPEX (Capital Expenditure) tracking. Expressed in the operating currency.' ;
    rdfs:domain ind:OwnerOwnershipInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dispositionDate rdf:type rdf:Property ;
    rdfs:label 'Disposition Date' ;
    rdfs:comment 'The date on which the ownership interest was disposed of, transferred, or terminated. Nullable for active interests. Used for capital gains computation, REIT disposition reporting, and portfolio lifecycle tracking.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'The date from which this ownership interest record version is legally and operationally effective. Supports bi-temporal modeling and ownership history reconstruction for audit and compliance purposes.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'The date until which this ownership interest record version is legally and operationally effective. Null indicates the record is currently active with no known end date. Supports bi-temporal modeling and ownership history reconstruction.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encumbranceAmount rdf:type rdf:Property ;
    rdfs:label 'Encumbrance Amount' ;
    rdfs:comment 'The outstanding monetary value of the encumbrance (e.g., mortgage balance, lien amount) against this ownership interest. Used for LTV (Loan-to-Value Ratio) calculation, net equity determination, and DSCR (Debt Service Coverage Ratio) reporting. Null when encumbrance_type is none.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:encumbranceType rdf:type rdf:Property ;
    rdfs:label 'Encumbrance Type' ;
    rdfs:comment 'The type of encumbrance or lien affecting this ownership interest, if any. None indicates a clear title. Mortgage, lien, easement, covenant, and pledge represent common encumbrance categories affecting transferability and value. Used for title due diligence and DSCR (Debt Service Coverage Ratio) analysis.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equityValueAmount rdf:type rdf:Property ;
    rdfs:label 'Equity Value Amount' ;
    rdfs:comment 'The current estimated equity value of the ownership interest, representing the owner\'s proportional share of the property\'s NAV (Net Asset Value) net of encumbrances. Updated upon revaluation events. Used for investor reporting, LTV (Loan-to-Value Ratio) calculations, and portfolio NAV reporting.' ;
    rdfs:domain ind:OwnerOwnershipInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Interest Reference Number' ;
    rdfs:comment 'Externally-known business identifier for this ownership interest record, used in legal documents, title records, and investor reporting. Sourced from Yardi Voyager or MRI Software ownership module.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestType rdf:type rdf:Property ;
    rdfs:label 'Interest Type' ;
    rdfs:comment 'Classification of the legal form of ownership interest held. Fee simple denotes absolute ownership; leasehold denotes ownership of a lease term; fractional denotes partial undivided interest; beneficial denotes equitable ownership without legal title; tenancy in common and joint tenancy denote co-ownership structures. [ENUM-REF-CANDIDATE: fee_simple|leasehold|fractional|beneficial|tenancy_in_common|joint_tenancy|usufruct|ground_lease — promote to reference product]' ;
    rdfs:domain ind:OwnerOwnershipInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jvStructureFlag rdf:type rdf:Property ;
    rdfs:label 'Jv Structure Flag' ;
    rdfs:comment 'Indicates whether this ownership interest is held through a Joint Venture (JV) structure (True). Enables identification of JV-governed interests requiring separate JV agreement compliance, promote calculations, and consolidated reporting under FASB ASC 810.' ;
    rdfs:domain ind:OwnerOwnershipInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownerOwnershipInterestStatus rdf:type rdf:Property ;
    rdfs:label 'Owner Ownership Interest Status' ;
    rdfs:comment 'Current lifecycle status of the ownership interest record. Pending: interest recorded but not yet legally effective. Active: interest is legally valid and in force. Encumbered: interest is subject to a lien, mortgage, or other encumbrance. Disputed: interest is subject to legal challenge. Transferred: interest has been conveyed to another party. Terminated: interest has been extinguished.' ;
    rdfs:domain ind:OwnerOwnershipInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'The percentage equity stake held by the owner in the subject property or investment vehicle, expressed as a decimal percentage (e.g., 25.0000 = 25%). Must sum to 100% across all active co-owners of the same property. Critical for NOI (Net Operating Income) distribution, capital call allocation, and investor reporting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Status' ;
    rdfs:comment 'The status of the ownership interest immediately prior to the most recent status transition. Supports full status transition history and audit trail requirements without requiring a separate history table for the latest transition.' ;
    rdfs:domain ind:OwnerOwnershipInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Identifies the operational system of record from which this ownership interest record was originated or last updated (e.g., YARDI for Yardi Voyager, MRI for MRI Software, ARGUS for Argus Enterprise). Supports data lineage and reconciliation in the Silver Layer lakehouse.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'The native primary key or record identifier of this ownership interest in the originating operational system (e.g., Yardi entity ID, MRI ownership record ID). Enables bi-directional traceability between the Silver Layer and source systems for reconciliation and audit.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusChangeDate rdf:type rdf:Property ;
    rdfs:label 'Status Change Date' ;
    rdfs:comment 'The effective date of the most recent status transition for this ownership interest record. Used for audit trail reconstruction, compliance reporting, and ownership lifecycle analytics.' ;
    rdfs:domain ind:OwnerOwnershipInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statusChangeReason rdf:type rdf:Property ;
    rdfs:label 'Status Change Reason' ;
    rdfs:comment 'Free-text or coded reason describing why the ownership interest status was changed (e.g., \'Mortgage recorded against title\', \'Ownership transferred via sale\', \'Legal dispute filed\'). Required for audit trail completeness and compliance documentation.' ;
    rdfs:domain ind:OwnerOwnershipInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusChangedBy rdf:type rdf:Property ;
    rdfs:label 'Status Changed By' ;
    rdfs:comment 'The username or user identifier of the individual who executed the most recent status change on this ownership interest record. Required for SOX audit trail and data governance accountability.' ;
    rdfs:domain ind:OwnerOwnershipInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Reference' ;
    rdfs:comment 'Reference identifier or URL to the supporting legal document (deed, transfer instrument, court order, JV agreement amendment) that substantiates the most recent status change. Links to DocuSign CLM or document management repository.' ;
    rdfs:domain ind:OwnerOwnershipInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:titleInsurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Title Insurance Policy Number' ;
    rdfs:comment 'The policy number of the title insurance policy covering this ownership interest. Issued by an ALTA-compliant title insurer. Used for claims management, due diligence documentation, and legal dispute resolution.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vestingEndDate rdf:type rdf:Property ;
    rdfs:label 'Vesting End Date' ;
    rdfs:comment 'The date on which the ownership interest becomes fully vested under the vesting schedule. Applicable only when vesting_schedule_flag is True. Null if vesting is perpetual or not applicable.' ;
    rdfs:domain ind:OwnerOwnershipInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vestingScheduleFlag rdf:type rdf:Property ;
    rdfs:label 'Vesting Schedule Flag' ;
    rdfs:comment 'Indicates whether this ownership interest is subject to a vesting schedule (True) or is fully vested at acquisition (False). Relevant for employee equity programs, JV promote structures, and deferred ownership arrangements.' ;
    rdfs:domain ind:OwnerOwnershipInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vestingStartDate rdf:type rdf:Property ;
    rdfs:label 'Vesting Start Date' ;
    rdfs:comment 'The date on which the vesting schedule for this ownership interest commences. Applicable only when vesting_schedule_flag is True. Used to calculate vested percentage over time for JV promote and equity program tracking.' ;
    rdfs:domain ind:OwnerOwnershipInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vestingType rdf:type rdf:Property ;
    rdfs:label 'Vesting Type' ;
    rdfs:comment 'The legal manner in which title to the ownership interest is held (vested). Determines rights of survivorship, transferability, and tax treatment. [ENUM-REF-CANDIDATE: sole_ownership|community_property|tenancy_in_common|joint_tenancy|trust|corporate|partnership|llc|reit_unit — promote to reference product]' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Ownership structures (funds, JVs) are mapped to cost centers for AUM tracking, management fee allocation, and financial reporting. Fund administrators assign cost centers to ownership structures for G' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:governingGeographicHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Governing Geographic Hierarchy Id' ;
    rdfs:comment 'Foreign key linking to reference.geographic_hierarchy. Business justification: Ownership structure formation jurisdiction determines applicable state/local tax obligations, LLC/LP filing requirements, and regulatory oversight. Legal and tax teams require normalized geographic hi' ;
    rdfs:domain ind:OwnershipStructure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeographicHierarchy .

ind:legalEntityId rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to finance.legal_entity. Business justification: Ownership structures (LLCs, LPs, REITs, JVs) are registered as legal entities. Financial consolidation, NOI reporting, tax filings, and NAV calculations are produced at the legal entity level. A real ' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:managingMemberOwnerId rdf:type rdf:Property ;
    rdfs:label 'Managing Member Owner Id' ;
    rdfs:comment 'Foreign key linking to owner.owner. Business justification: ownership_structure has managing_member_name (STRING) and managing_member_entity_type fields. The managing member of an LLC, JV, or partnership is typically a registered owner entity in the system. Ad' ;
    rdfs:domain ind:OwnershipStructure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Owner .

ind:primaryPropertyTypeId rdf:type rdf:Property ;
    rdfs:label 'Primary Property Type Id' ;
    rdfs:comment 'Foreign key linking to reference.property_type. Business justification: Ownership structures (funds, JVs, SPEs) have a primary property type focus used in REIT qualification testing, fund mandate compliance, and investor allocation reporting. The existing asset_class plai' ;
    rdfs:domain ind:OwnershipStructure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PropertyType .

ind:reportingPeriodId rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Id' ;
    rdfs:comment 'Foreign key linking to finance.reporting_period. Business justification: Ownership structures (funds, JVs) produce periodic NAV calculations and investor reports tied to reporting periods. Linking ownership_structure to reporting_period enables period-based fund reporting ' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReportingPeriod .

ind:aum rdf:type rdf:Property ;
    rdfs:label 'Aum' ;
    rdfs:comment 'The total gross asset value of real estate assets held within this ownership structure, representing Assets Under Management (AUM). Used for fee calculations, portfolio reporting, and SEC/regulatory disclosures.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beneficialOwnershipDisclosed rdf:type rdf:Property ;
    rdfs:label 'Beneficial Ownership Disclosed' ;
    rdfs:comment 'Indicates whether beneficial ownership information (individuals owning 25%+ equity) has been disclosed per FinCEN\'s Corporate Transparency Act requirements. Mandatory for AML compliance and investor onboarding.' ;
    rdfs:domain ind:OwnershipStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dissolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dissolution Date' ;
    rdfs:comment 'The date on which the ownership structure was legally dissolved or wound down. Null for active structures. Used for lifecycle tracking, tax reporting, and portfolio close-out analytics.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:esgClassification rdf:type rdf:Property ;
    rdfs:label 'Esg Classification' ;
    rdfs:comment 'The ESG rating or classification tier assigned to the ownership structure based on environmental, social, and governance criteria. Increasingly required for institutional investor mandates, LEED/BREEAM alignment, and SEC climate disclosure rules.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extensionOptionYears rdf:type rdf:Property ;
    rdfs:label 'Extension Option Years' ;
    rdfs:comment 'The number of years by which the fund term may be extended at the managing member\'s discretion, as specified in the operating agreement. Used for investment horizon modeling and investor communication.' ;
    rdfs:domain ind:OwnershipStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:formationDate rdf:type rdf:Property ;
    rdfs:label 'Formation Date' ;
    rdfs:comment 'The date on which the ownership structure was legally formed or incorporated. Used to calculate entity age, determine applicable regulatory frameworks, and validate operating agreement timelines.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fundTermYears rdf:type rdf:Property ;
    rdfs:label 'Fund Term Years' ;
    rdfs:comment 'The contractual term length of the ownership structure in years, as defined in the operating agreement. Applicable primarily to closed-end funds, LPs, and JV structures. Used for WALT/WALE calculations and investment horizon planning.' ;
    rdfs:domain ind:OwnershipStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:investmentStrategy rdf:type rdf:Property ;
    rdfs:label 'Investment Strategy' ;
    rdfs:comment 'The risk-return investment strategy classification of the ownership structure. Determines underwriting assumptions, target IRR thresholds, and portfolio reporting categories in Argus Enterprise and MRI Software.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managingMemberEntityType rdf:type rdf:Property ;
    rdfs:label 'Managing Member Entity Type' ;
    rdfs:comment 'Classification of the managing member as an individual person or a legal entity type. Determines KYC/AML requirements, beneficial ownership disclosure obligations, and governance structure.' ;
    rdfs:domain ind:OwnershipStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managingMemberName rdf:type rdf:Property ;
    rdfs:label 'Managing Member Name' ;
    rdfs:comment 'The name of the designated managing member, general partner, or trustee responsible for day-to-day decisions and fiduciary obligations of the ownership structure. Critical for governance, legal notices, and investor communications.' ;
    rdfs:domain ind:OwnershipStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfMembers rdf:type rdf:Property ;
    rdfs:label 'Number Of Members' ;
    rdfs:comment 'The total count of equity members, partners, or beneficial owners participating in the ownership structure. Used for governance quorum calculations, K-1 distribution processing, and regulatory reporting thresholds.' ;
    rdfs:domain ind:OwnershipStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatingAgreementRef rdf:type rdf:Property ;
    rdfs:label 'Operating Agreement Ref' ;
    rdfs:comment 'Reference identifier or document number for the governing operating agreement, partnership agreement, or trust deed associated with this ownership structure. Links to DocuSign CLM or document management system for full document retrieval.' ;
    rdfs:domain ind:OwnershipStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipStructureStatus rdf:type rdf:Property ;
    rdfs:label 'Ownership Structure Status' ;
    rdfs:comment 'Current lifecycle state of the ownership structure. Drives eligibility for new property acquisitions, investor distributions, and regulatory filings. Active structures are operational; dissolved structures have completed wind-down.' ;
    rdfs:domain ind:OwnershipStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredReturnRate rdf:type rdf:Property ;
    rdfs:label 'Preferred Return Rate' ;
    rdfs:comment 'The annual preferred return percentage (hurdle rate) guaranteed to limited partners or preferred equity holders before the managing member participates in profits. Expressed as a decimal (e.g., 0.0800 = 8%). Key input for IRR and DCF waterfall modeling in Argus Enterprise.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotePercentage rdf:type rdf:Property ;
    rdfs:label 'Promote Percentage' ;
    rdfs:comment 'The percentage of profits allocated to the managing member or general partner above the preferred return threshold, commonly known as the carried interest or promote. Expressed as a decimal (e.g., 0.2000 = 20%). Used in waterfall distribution modeling.' ;
    rdfs:domain ind:OwnershipStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publiclyTraded rdf:type rdf:Property ;
    rdfs:label 'Publicly Traded' ;
    rdfs:comment 'Indicates whether the ownership structure\'s equity interests are publicly traded on a stock exchange. Determines SEC reporting obligations (10-K, 10-Q), SOX compliance requirements, and CMBS/RMBS disclosure rules.' ;
    rdfs:domain ind:OwnershipStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registeredAddress rdf:type rdf:Property ;
    rdfs:label 'Registered Address' ;
    rdfs:comment 'The official registered address of the ownership structure entity as filed with the governing jurisdiction\'s secretary of state or equivalent authority. Used for legal notices, regulatory filings, and tax correspondence.' ;
    rdfs:domain ind:OwnershipStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reitQualified rdf:type rdf:Property ;
    rdfs:label 'Reit Qualified' ;
    rdfs:comment 'Indicates whether this ownership structure qualifies as a Real Estate Investment Trust (REIT) under IRS Section 856-860 and SEC regulations. Drives tax treatment, distribution requirements (90% of taxable income), and SEC reporting obligations.' ;
    rdfs:domain ind:OwnershipStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemName rdf:type rdf:Property ;
    rdfs:label 'Source System Name' ;
    rdfs:comment 'The name of the operational system of record from which this ownership structure record was sourced. Used for data lineage, audit trails, and Silver layer reconciliation in the Databricks Lakehouse.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structureCode rdf:type rdf:Property ;
    rdfs:label 'Structure Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the ownership structure across systems such as Yardi Voyager, MRI Software, and Argus Enterprise. Used for cross-system reconciliation and reporting.' ;
    rdfs:domain ind:OwnershipStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structureName rdf:type rdf:Property ;
    rdfs:label 'Structure Name' ;
    rdfs:comment 'The full legal name of the ownership structure entity (e.g., \'Maple Grove Realty LLC\', \'Westside JV Partners LP\'). Used in legal documents, operating agreements, and investor reporting.' ;
    rdfs:domain ind:OwnershipStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structureType rdf:type rdf:Property ;
    rdfs:label 'Structure Type' ;
    rdfs:comment 'Legal and organizational classification of the ownership structure. Determines governance rules, tax treatment, and reporting obligations. [ENUM-REF-CANDIDATE: single_owner|joint_venture|limited_partnership|llc|reit|tenancy_in_common|trust|general_partnership — promote to reference product]' ;
    rdfs:domain ind:OwnershipStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetEquityMultiple rdf:type rdf:Property ;
    rdfs:label 'Target Equity Multiple' ;
    rdfs:comment 'The target equity multiple (total distributions divided by total invested capital) for the ownership structure as underwritten. Expressed as a ratio (e.g., 2.0000 = 2.0x). Used alongside IRR for investor return benchmarking.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetIrr rdf:type rdf:Property ;
    rdfs:label 'Target Irr' ;
    rdfs:comment 'The target Internal Rate of Return (IRR) for the ownership structure as underwritten in the investment thesis. Expressed as a decimal (e.g., 0.1500 = 15%). Used for performance benchmarking and investor reporting in Argus Enterprise.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'The federal Employer Identification Number (EIN) or equivalent tax identification number assigned to the ownership structure entity. Required for IRS filings, K-1 distributions, and REIT qualification reporting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tickerSymbol rdf:type rdf:Property ;
    rdfs:label 'Ticker Symbol' ;
    rdfs:comment 'The stock exchange ticker symbol for publicly traded ownership structures (REITs). Null for private structures. Used for market data integration with CoStar Suite and financial reporting.' ;
    rdfs:domain ind:OwnershipStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCommittedCapital rdf:type rdf:Property ;
    rdfs:label 'Total Committed Capital' ;
    rdfs:comment 'The total capital committed by all equity partners or members to the ownership structure, expressed in the base currency. Used for LTV calculations, DSCR analysis, and investor reporting in Argus Enterprise and MRI Software.' ;
    rdfs:domain ind:OwnershipStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalContributedCapital rdf:type rdf:Property ;
    rdfs:label 'Total Contributed Capital' ;
    rdfs:comment 'The total capital actually funded and contributed by all equity partners or members to date. Distinct from committed capital; the difference represents uncalled capital. Used for NAV calculations and investor reporting.' ;
    rdfs:domain ind:OwnershipStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalEquityInterests rdf:type rdf:Property ;
    rdfs:label 'Total Equity Interests' ;
    rdfs:comment 'The total number of authorized equity interests, units, shares, or membership interests in the ownership structure. Used to calculate individual ownership percentages and dilution analysis.' ;
    rdfs:domain ind:OwnershipStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizedSignatoryOwnerContactId rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory Owner Contact Id' ;
    rdfs:comment 'Foreign key linking to owner.owner_contact. Business justification: owner_agreement governs the relationship between owner entities and properties/structures. Agreements require an authorized signatory — a specific contact person who signs on behalf of the owner entit' ;
    rdfs:domain ind:OwnerAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OwnerContact .

ind:brokerId rdf:type rdf:Property ;
    rdfs:label 'Broker Id' ;
    rdfs:comment 'Foreign key linking to brokerage.broker. Business justification: Owner agreements for leasing and advisory services are executed with a specific licensed broker. Linking enables broker license compliance checks, relationship management reporting, and fee calculatio' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Broker .

ind:budgetId rdf:type rdf:Property ;
    rdfs:label 'Budget Id' ;
    rdfs:comment 'Foreign key linking to finance.finance_budget. Business justification: Owner management agreements define capex/opex approval thresholds directly tied to budgets. Linking owner_agreement to finance_budget enables budget compliance checking against agreement-defined thres' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Budget .

ind:buildingId rdf:type rdf:Property ;
    rdfs:label 'Building Id' ;
    rdfs:comment 'Foreign key linking to property.building. Business justification: Property management agreements are frequently scoped to a specific building within a multi-building asset (e.g., a campus or mixed-use development). Building-level PM agreements are standard in commer' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Building .

ind:complianceViolationId rdf:type rdf:Property ;
    rdfs:label 'Compliance Violation Id' ;
    rdfs:comment 'Foreign key linking to compliance.violation. Business justification: Management and operating agreements can be the source of compliance violations — unauthorized fee charges, RESPA violations, undisclosed conflicts of interest. Compliance officers link violations dire' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Violation .

ind:governingLawCountryId rdf:type rdf:Property ;
    rdfs:label 'Governing Law Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Owner agreement governing law country determines applicable contract enforcement standards, dispute resolution jurisdiction, and cross-border legal compliance. Legal teams require normalized country r' ;
    rdfs:domain ind:OwnerAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:investmentDealId rdf:type rdf:Property ;
    rdfs:label 'Investment Deal Id' ;
    rdfs:comment 'Foreign key linking to investment.investment_deal. Business justification: JV agreements and co-investment agreements are executed at deal close. Linking owner_agreement to investment_deal supports deal-to-close document tracking, IC approval traceability, and post-close agr' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestmentDeal .

ind:listingId rdf:type rdf:Property ;
    rdfs:label 'Listing Id' ;
    rdfs:comment 'Foreign key linking to brokerage.listing. Business justification: Owner agreements authorize specific listings; commission reconciliation and deal attribution reporting require tracing which listing was produced under which owner agreement. Real estate asset manager' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Listing .

ind:portfolioId rdf:type rdf:Property ;
    rdfs:label 'Portfolio Id' ;
    rdfs:comment 'Foreign key linking to investment.portfolio. Business justification: Portfolio-level management agreements and JV agreements govern entire portfolios in real estate investment management. owner_agreement has fund_id but not portfolio_id; portfolio-level agreements (e.g' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Portfolio .

ind:regulatoryObligationId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_obligation. Business justification: Owner management agreements must comply with specific regulatory obligations (state property management licensing laws, RESPA, ESG disclosure mandates). Compliance teams track which regulatory obligat' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryObligation .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known unique reference number or code assigned to this agreement, as recorded in Yardi Voyager or DocuSign CLM. Used for cross-system reconciliation and correspondence.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle state of the owner agreement. Drives operational workflows in Yardi Voyager and DocuSign CLM — e.g., only \'active\' agreements generate management fee invoices.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'Number of formal amendments or addenda executed against this agreement since its original execution. Supports version control and audit trail requirements.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capexApprovalThreshold rdf:type rdf:Property ;
    rdfs:label 'Capex Approval Threshold' ;
    rdfs:comment 'Maximum Capital Expenditure (CAPEX) amount the property or asset manager is authorized to approve without seeking owner consent, as stipulated in the agreement. Amounts above this threshold require owner sign-off.' ;
    rdfs:domain ind:OwnerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidentialityClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Clause Flag' ;
    rdfs:comment 'Indicates whether the agreement contains a confidentiality or non-disclosure clause restricting the sharing of agreement terms, financial data, or owner information with third parties.' ;
    rdfs:domain ind:OwnerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeResolutionMechanism rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Mechanism' ;
    rdfs:comment 'Contractually specified mechanism for resolving disputes arising under the agreement. Informs legal risk management and compliance reporting.' ;
    rdfs:domain ind:OwnerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:docusignEnvelopeCode rdf:type rdf:Property ;
    rdfs:label 'Docusign Envelope Code' ;
    rdfs:comment 'Unique envelope identifier from DocuSign CLM corresponding to the executed agreement. Enables direct retrieval of the signed document and audit trail from the contract lifecycle management system.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Date on which the agreement becomes legally binding and operational obligations commence. Aligns with the commencement date field in Yardi Voyager contract records.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:esgComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Esg Compliance Flag' ;
    rdfs:comment 'Indicates whether the agreement includes Environmental, Social, and Governance (ESG) compliance obligations, such as LEED certification maintenance, BREEAM targets, or ESG reporting requirements.' ;
    rdfs:domain ind:OwnerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Flag' ;
    rdfs:comment 'Indicates whether the agreement grants the management or advisory firm exclusive rights to manage or transact on behalf of the owner for the covered properties or portfolio.' ;
    rdfs:domain ind:OwnerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'Date on which all parties formally signed and executed the agreement. May differ from effective_date for agreements with retroactive or future commencement. Sourced from DocuSign CLM completion timestamp.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Date on which the agreement is scheduled to expire or terminate. Null for open-ended or evergreen agreements. Used for WALT/WALE calculations and renewal pipeline management.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feePaymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Fee Payment Frequency' ;
    rdfs:comment 'Frequency at which management and other recurring fees are invoiced and payable under the agreement. Drives Accounts Receivable (AR) billing cycles in Yardi Voyager.' ;
    rdfs:domain ind:OwnerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'The legal jurisdiction whose laws govern interpretation and enforcement of this agreement (e.g., \'New York, USA\', \'England and Wales\'). Critical for dispute resolution and regulatory compliance reporting.' ;
    rdfs:domain ind:OwnerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveFeeFlag rdf:type rdf:Property ;
    rdfs:label 'Incentive Fee Flag' ;
    rdfs:comment 'Indicates whether the agreement includes a performance-based incentive or promote fee structure in addition to the base management fee.' ;
    rdfs:domain ind:OwnerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incentiveFeeHurdleRatePct rdf:type rdf:Property ;
    rdfs:label 'Incentive Fee Hurdle Rate Pct' ;
    rdfs:comment 'Minimum return threshold (hurdle rate) that must be achieved before the incentive or promote fee becomes payable to the asset manager. Expressed as an annual percentage (e.g., IRR or ROI threshold).' ;
    rdfs:domain ind:OwnerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentiveFeePct rdf:type rdf:Property ;
    rdfs:label 'Incentive Fee Pct' ;
    rdfs:comment 'Percentage of outperformance above the hurdle rate payable as an incentive or promote fee to the asset manager. Null if incentive_fee_flag is false.' ;
    rdfs:domain ind:OwnerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirement Flag' ;
    rdfs:comment 'Indicates whether the agreement specifies mandatory insurance coverage requirements (e.g., property insurance, liability, E&O) that the manager must maintain.' ;
    rdfs:domain ind:OwnerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'Date of the most recent formal amendment or addendum executed against this agreement. Null if no amendments have been made.' ;
    rdfs:domain ind:OwnerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:managementFeeBasis rdf:type rdf:Property ;
    rdfs:label 'Management Fee Basis' ;
    rdfs:comment 'The income or revenue base upon which the management fee percentage is applied. EGI = Effective Gross Income; GRI = Gross Rental Income; NOI = Net Operating Income; NRI = Net Rental Income; GOI = Gross Operating Income; fixed = flat fee not tied to income.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementFeeFixedAmount rdf:type rdf:Property ;
    rdfs:label 'Management Fee Fixed Amount' ;
    rdfs:comment 'Fixed periodic management fee amount in the agreement currency, applicable when management_fee_basis is \'fixed\'. Null when fee is percentage-based.' ;
    rdfs:domain ind:OwnerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managementFeePct rdf:type rdf:Property ;
    rdfs:label 'Management Fee Pct' ;
    rdfs:comment 'Base property or asset management fee expressed as a percentage of Effective Gross Income (EGI) or Gross Rental Income (GRI) as defined in the agreement. Core commercial term tracked in Yardi Voyager and MRI Software.' ;
    rdfs:domain ind:OwnerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mriAgreementRef rdf:type rdf:Property ;
    rdfs:label 'Mri Agreement Ref' ;
    rdfs:comment 'Source system agreement or mandate reference number from MRI Software, used for investment management and property accounting reconciliation.' ;
    rdfs:domain ind:OwnerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opexApprovalThreshold rdf:type rdf:Property ;
    rdfs:label 'Opex Approval Threshold' ;
    rdfs:comment 'Maximum Operating Expenditure (OPEX) or single-transaction spend the property manager is authorized to approve without owner consent. Drives procurement controls in SAP S/4HANA and Yardi Voyager.' ;
    rdfs:domain ind:OwnerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of calendar days prior to expiration by which notice of renewal or non-renewal must be provided. Drives automated alerts in Yardi Voyager and DocuSign CLM.' ;
    rdfs:domain ind:OwnerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Flag' ;
    rdfs:comment 'Indicates whether the agreement contains a renewal or extension option clause that either party may exercise prior to expiration.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalTermMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Term Months' ;
    rdfs:comment 'Duration in months of each renewal period if the renewal option is exercised. Null if renewal_option_flag is false.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'Frequency at which the property or asset manager is contractually required to deliver financial and operational performance reports to the owner. Drives reporting obligations in Argus Enterprise and MRI Software.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Narrative description of the services, properties, or investment mandate covered by this agreement. Captures the business scope as defined in the agreement body.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Actual date on which the agreement was terminated early, if applicable. Null if the agreement expired naturally or is still active. Distinct from expiration_date which is the scheduled end.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Termination Fee Amount' ;
    rdfs:comment 'Monetary penalty or break fee payable upon early termination of the agreement without cause, in the agreement currency. Null if no termination fee applies.' ;
    rdfs:domain ind:OwnerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationForCauseFlag rdf:type rdf:Property ;
    rdfs:label 'Termination For Cause Flag' ;
    rdfs:comment 'Indicates whether the agreement contains a termination-for-cause clause allowing immediate termination upon material breach, insolvency, or other specified events.' ;
    rdfs:domain ind:OwnerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of calendar days of advance written notice required by either party to terminate the agreement without cause. Key contractual protection term.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yardiContractRef rdf:type rdf:Property ;
    rdfs:label 'Yardi Contract Ref' ;
    rdfs:comment 'Source system contract or vendor agreement reference number from Yardi Voyager, used for cross-system reconciliation of fee billing, AP/AR entries, and General Ledger (GL) postings.' ;
    rdfs:domain ind:OwnerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerDistributionId rdf:type rdf:Property ;
    rdfs:label 'Owner Distribution Id' ;
    rdfs:comment 'Unique surrogate identifier for each owner distribution record in the Silver layer lakehouse. Primary key for the owner_distribution data product.' ;
    rdfs:domain ind:OwnerDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capitalAccountId rdf:type rdf:Property ;
    rdfs:label 'Capital Account Id' ;
    rdfs:comment 'Foreign key linking to investment.capital_account. Business justification: Fund administration requires reconciling owner distributions against LP capital account statements. capital_account tracks cumulative distributions per investor/fund; linking owner_distribution to cap' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapitalAccount .

ind:disbursementBankAccountId rdf:type rdf:Property ;
    rdfs:label 'Disbursement Bank Account Id' ;
    rdfs:comment 'Foreign key linking to finance.bank_account. Business justification: Distributions are disbursed from a specific operating or distribution bank account. Treasury reconciliation and bank statement matching require linking each distribution run to the source bank account' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:investmentDistributionId rdf:type rdf:Property ;
    rdfs:label 'Investment Distribution Id' ;
    rdfs:comment 'Foreign key linking to investment.distribution. Business justification: Owner-level disbursements are sourced from fund-level distributions. This link enables reconciliation between fund waterfall distributions and actual owner disbursements — critical for K-1 preparation' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestmentDistribution .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.journal_entry. Business justification: Each distribution disbursement triggers a journal entry (debit distributions payable, credit cash). Linking owner_distribution to journal_entry provides the GL audit trail required for fund accounting' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:noiStatementId rdf:type rdf:Property ;
    rdfs:label 'Noi Statement Id' ;
    rdfs:comment 'Foreign key linking to finance.noi_statement. Business justification: Owner distributions are calculated from distributable NOI per the NOI statement for the period. Linking distribution to the source NOI statement supports distribution waterfall auditing, investor repo' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NoiStatement .

ind:originalDistributionOwnerDistributionId rdf:type rdf:Property ;
    rdfs:label 'Original Distribution Owner Distribution Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the original distribution record that this record corrects or reverses. Null for original distributions; populated for reversal or correction entries. Enables distribution lineage tracking.' ;
    rdfs:domain ind:OwnerDistribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OwnerDistribution .

ind:taxTreatyCountryId rdf:type rdf:Property ;
    rdfs:label 'Tax Treaty Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Tax treaty country determines reduced withholding tax rates applicable to foreign investor distributions. Tax compliance teams require normalized country reference to apply correct treaty rates and ge' ;
    rdfs:domain ind:OwnerDistribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:valuationNavCalculationId rdf:type rdf:Property ;
    rdfs:label 'Valuation Nav Calculation Id' ;
    rdfs:comment 'Foreign key linking to valuation.nav_calculation. Business justification: Fund distributions are calculated based on NAV per unit. Linking each distribution record to the NAV calculation that drove it is a standard fund accounting requirement, enabling auditors and investor' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NavCalculation .

ind:accountNumberToken rdf:type rdf:Property ;
    rdfs:label 'Account Number Token' ;
    rdfs:comment 'Tokenized or masked representation of the owner\'s bank account number for disbursement. The actual account number is stored in a secure vault; this token is used for display, reconciliation, and audit trail only.' ;
    rdfs:domain ind:OwnerDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Authorization state of the distribution within the internal approval workflow. Pending = awaiting approver action; approved = authorized for disbursement; rejected = denied and requires revision. Supports dual-control SOX financial controls.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Date and time when the distribution was formally approved by the authorized approver. Part of the SOX-compliant audit trail for financial disbursements.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bankAccountType rdf:type rdf:Property ;
    rdfs:label 'Bank Account Type' ;
    rdfs:comment 'Type of bank account designated for receiving distributions. Determines ACH transaction code and payment processing rules.' ;
    rdfs:domain ind:OwnerDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Bank Account Verification Status' ;
    rdfs:comment 'Current verification state of the owner\'s bank account on file. Verified accounts are eligible for disbursement; unverified or failed accounts trigger a hold. Supports KYC/AML compliance and fraud prevention.' ;
    rdfs:domain ind:OwnerDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Bank Account Verified Date' ;
    rdfs:comment 'Date on which the owner\'s bank account was last successfully verified through micro-deposit, Plaid, or manual confirmation. Used to determine if re-verification is required per policy.' ;
    rdfs:domain ind:OwnerDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'Name of the financial institution holding the owner\'s disbursement account. Used for payment routing, AP reconciliation, and audit trail. Sourced from owner banking instructions on file.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Calculation Period End Date' ;
    rdfs:comment 'Last day of the operating period over which the distributable income was earned and calculated. Together with calculation_period_start_date defines the distribution window for income attribution.' ;
    rdfs:domain ind:OwnerDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calculationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Calculation Period Start Date' ;
    rdfs:comment 'First day of the operating period over which the distributable income was earned and calculated (e.g., start of the quarter or month). Used for investor reporting, K-1 allocation, and WALE/WALT analytics.' ;
    rdfs:domain ind:OwnerDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disbursementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disbursement Timestamp' ;
    rdfs:comment 'Exact date and time when the funds were electronically transferred or check was issued to the owner. Distinct from distribution_date (scheduled); this is the actual execution timestamp. Null if not yet disbursed.' ;
    rdfs:domain ind:OwnerDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:distributableNoiAmount rdf:type rdf:Property ;
    rdfs:label 'Distributable Noi Amount' ;
    rdfs:comment 'The total property-level Net Operating Income (NOI) available for distribution during the calculation period, before applying the owner\'s ownership percentage. Supports NOI-based distribution calculations and investor reporting.' ;
    rdfs:domain ind:OwnerDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionDate rdf:type rdf:Property ;
    rdfs:label 'Distribution Date' ;
    rdfs:comment 'The scheduled or actual date on which the distribution is to be paid to the owner. Used for cash flow forecasting, investor reporting, and AP scheduling. Corresponds to the Yardi distribution run date.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distributionNumber rdf:type rdf:Property ;
    rdfs:label 'Distribution Number' ;
    rdfs:comment 'Externally-known business identifier for this distribution event, used in investor statements, K-1 tax packages, and AP reconciliation. Format: DIST-YYYY-NNNNNN.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Status' ;
    rdfs:comment 'Current lifecycle state of the distribution record. Drives AP workflow, investor portal visibility, and reconciliation processes. Values: pending (calculated, awaiting approval), approved (authorized for payment), disbursed (funds transferred), on_hold (suspended pending review), cancelled (voided before payment), reversed (clawback or correction applied).' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionType rdf:type rdf:Property ;
    rdfs:label 'Distribution Type' ;
    rdfs:comment 'Classification of the distribution by economic source. NOI = Net Operating Income distribution; FFO/AFFO = Funds From Operations per NAREIT definition; capital_gain = proceeds from asset disposition; return_of_capital = non-taxable return of invested principal; preferred_return = priority return to preferred equity holders; special = one-time or extraordinary distribution. [ENUM-REF-CANDIDATE: noi|ffo|affo|capital_gain|return_of_capital|preferred_return|special — promote to reference product]' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'The scheduled cadence at which distributions are made to this owner from this property or investment entity. Drives distribution calendar planning and investor expectation management.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossDistributionAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Distribution Amount' ;
    rdfs:comment 'Total pre-tax distribution amount calculated for the owner before any withholding tax, fees, or adjustments. Expressed in the distribution currency. Core monetary component of the MONETARY_TRIPLET.' ;
    rdfs:domain ind:OwnerDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iban rdf:type rdf:Property ;
    rdfs:label 'Iban' ;
    rdfs:comment 'International Bank Account Number (IBAN) for SEPA or cross-border distributions to international owners. Used in conjunction with SWIFT code for foreign disbursements. Null for domestic payments.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isForeignOwner rdf:type rdf:Property ;
    rdfs:label 'Is Foreign Owner' ;
    rdfs:comment 'Indicates whether the owner is a foreign person or entity subject to FIRPTA withholding and IRS Form 1042-S reporting requirements. True = foreign owner; False = domestic US owner. Drives withholding tax logic and international payment routing.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:k1TaxYear rdf:type rdf:Property ;
    rdfs:label 'K1 Tax Year' ;
    rdfs:comment 'The IRS tax year (YYYY) to which this distribution is attributed for Schedule K-1 reporting purposes. Partnerships and REITs must issue K-1s to partners/investors annually. Used for tax package preparation and investor tax reporting.' ;
    rdfs:domain ind:OwnerDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netDisbursementAmount rdf:type rdf:Property ;
    rdfs:label 'Net Disbursement Amount' ;
    rdfs:comment 'Actual amount transferred to the owner after deducting withholding tax and any other adjustments from the gross distribution amount. This is the cash received by the owner. Core net total of the MONETARY_TRIPLET.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'The disbursement method used to transfer funds to the owner. ACH = Automated Clearing House domestic transfer; wire = domestic wire transfer; check = physical check; swift = international SWIFT wire; iban_transfer = SEPA or IBAN-based international transfer.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredDisbursementMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Disbursement Method' ;
    rdfs:comment 'The owner\'s standing preferred method for receiving distributions, as recorded in their disbursement instructions. May differ from the actual payment_method used for a specific distribution if the preferred method was unavailable.' ;
    rdfs:domain ind:OwnerDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'Free-text explanation for why a distribution was reversed or cancelled. Required when distribution_status is \'reversed\' or \'cancelled\'. Supports audit trail and investor communication.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingNumberToken rdf:type rdf:Property ;
    rdfs:label 'Routing Number Token' ;
    rdfs:comment 'Tokenized or masked representation of the ABA routing number for the owner\'s disbursement bank account. The actual routing number is stored in a secure vault; this token is used for display and audit purposes only. Required for ACH and domestic wire processing.' ;
    rdfs:domain ind:OwnerDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swiftCode rdf:type rdf:Property ;
    rdfs:label 'Swift Code' ;
    rdfs:comment 'SWIFT Business Identifier Code (BIC) for international wire transfers to foreign owners. Required for SWIFT-based disbursements. Null for domestic ACH/wire payments.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'Amount of income tax withheld from the gross distribution at source, including federal, state, or foreign withholding as applicable. Deducted from gross to arrive at net disbursement. Required for K-1 and 1042-S tax reporting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingTaxRate rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Rate' ;
    rdfs:comment 'The applicable withholding tax rate applied to the gross distribution, expressed as a decimal (e.g., 0.300000 = 30%). Determined by owner tax residency, treaty status, and distribution type. Used for K-1 and 1042-S preparation.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yardiDistributionRunCode rdf:type rdf:Property ;
    rdfs:label 'Yardi Distribution Run Code' ;
    rdfs:comment 'Identifier of the Yardi Voyager distribution batch run that generated this distribution record. Used for batch-level reconciliation, reprocessing, and audit trail back to the source system.' ;
    rdfs:domain ind:OwnerDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yardiGlReference rdf:type rdf:Property ;
    rdfs:label 'Yardi Gl Reference' ;
    rdfs:comment 'Cross-reference identifier linking this distribution record to the corresponding General Ledger (GL) journal entry in Yardi Voyager. Enables AP reconciliation between the owner distribution record and the accounting entry. Supports SOX financial controls.' ;
    rdfs:domain ind:OwnerDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalContributionId rdf:type rdf:Property ;
    rdfs:label 'Capital Contribution Id' ;
    rdfs:comment 'Unique system-generated identifier for each capital contribution record. Primary key for the capital_contribution data product in the owner domain.' ;
    rdfs:domain ind:CapitalContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brokerageDealId rdf:type rdf:Property ;
    rdfs:label 'Brokerage Deal Id' ;
    rdfs:comment 'Foreign key linking to brokerage.deal. Business justification: Capital contributions fund property acquisitions originated through brokerage deals. Linking enables capital call reconciliation against deal close dates, acquisition cost basis tracking, and investor' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BrokerageDeal .

ind:capexProjectId rdf:type rdf:Property ;
    rdfs:label 'Capex Project Id' ;
    rdfs:comment 'Foreign key linking to maintenance.capex_project. Business justification: Capital call management: owner capital contributions are frequently tied to specific capex projects (renovations, TI buildouts). This link supports investor reporting, K-1 cost basis allocation, and c' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapexProject .

ind:capitalCallId rdf:type rdf:Property ;
    rdfs:label 'Capital Call Id' ;
    rdfs:comment 'Foreign key linking to investment.capital_call. Business justification: Capital contributions are triggered by capital call notices. Linking contribution to the originating capital_call is required for cash management, default tracking, funded/shortfall reconciliation, an' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapitalCall .

ind:capitalCommitmentId rdf:type rdf:Property ;
    rdfs:label 'Capital Commitment Id' ;
    rdfs:comment 'Foreign key linking to investment.commitment. Business justification: Each capital contribution reduces the uncalled commitment balance. This link is required for unfunded commitment tracking, LP capital account statements, and commitment compliance reporting — standard' ;
    rdfs:domain ind:CapitalContribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Commitment .

ind:chartOfAccountsId rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Id' ;
    rdfs:comment 'Foreign key linking to finance.chart_of_accounts. Business justification: Capital contributions are coded to specific GL accounts (contributed capital, additional paid-in capital). Direct chart_of_accounts assignment on capital_contribution enables GL coding at contribution' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChartOfAccounts .

ind:constructionBudgetId rdf:type rdf:Property ;
    rdfs:label 'Construction Budget Id' ;
    rdfs:comment 'Foreign key linking to development.construction_budget. Business justification: Equity capital contributions fund specific construction budget line items. Linking capital_contribution to construction_budget enables equity-vs-budget reconciliation reports, tracks funded vs. unfund' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConstructionBudget .

ind:drawRequestId rdf:type rdf:Property ;
    rdfs:label 'Draw Request Id' ;
    rdfs:comment 'Foreign key linking to development.draw_request. Business justification: Equity capital contributions are directly triggered by construction draw requests. Lenders and equity investors fund draws in tandem; linking capital_contribution to draw_request enables reconciliatio' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrawRequest .

ind:receivingBankAccountId rdf:type rdf:Property ;
    rdfs:label 'Receiving Bank Account Id' ;
    rdfs:comment 'Foreign key linking to finance.bank_account. Business justification: Capital contributions (equity calls) are received into a designated capital call or operating bank account. Treasury and capital account reconciliation require linking each contribution to the receivi' ;
    rdfs:domain ind:CapitalContribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:accountingPeriod rdf:type rdf:Property ;
    rdfs:label 'Accounting Period' ;
    rdfs:comment 'The fiscal accounting period (YYYY-MM format) in which this capital contribution is recognized for financial reporting purposes. May differ from contribution_date if the contribution is received near a period boundary.' ;
    rdfs:domain ind:CapitalContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calledAmount rdf:type rdf:Property ;
    rdfs:label 'Called Amount' ;
    rdfs:comment 'The amount of capital formally called or requested from the investor via a capital call notice. May differ from contribution_amount if the investor funded partially or over-funded. Used to track unfunded commitment drawdown progress.' ;
    rdfs:domain ind:CapitalContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capexCategory rdf:type rdf:Property ;
    rdfs:label 'Capex Category' ;
    rdfs:comment 'The CAPEX category that this capital contribution is intended to fund. Acquisition covers property purchase equity; development covers ground-up construction; renovation covers value-add improvements; tenant_improvement covers TI allowances; infrastructure covers building systems and utilities.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalAccountBalanceAfter rdf:type rdf:Property ;
    rdfs:label 'Capital Account Balance After' ;
    rdfs:comment 'The investor\'s capital account balance immediately after this contribution event is applied. Used for equity waterfall inputs, NAV calculations, and investor reporting.' ;
    rdfs:domain ind:CapitalContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalAccountBalanceBefore rdf:type rdf:Property ;
    rdfs:label 'Capital Account Balance Before' ;
    rdfs:comment 'The investor\'s capital account balance immediately prior to this contribution event. Provides a point-in-time snapshot for audit trail, reconciliation, and equity waterfall analysis.' ;
    rdfs:domain ind:CapitalContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalCallDueDate rdf:type rdf:Property ;
    rdfs:label 'Capital Call Due Date' ;
    rdfs:comment 'The date by which the investor was required to fund the capital call per the capital call notice. Used to identify late contributions, calculate default interest, and monitor investor compliance with funding obligations.' ;
    rdfs:domain ind:CapitalContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capitalCallNoticeRef rdf:type rdf:Property ;
    rdfs:label 'Capital Call Notice Ref' ;
    rdfs:comment 'Reference number or identifier of the formal capital call notice issued to the investor that triggered this contribution. Links the funding event back to the capital call document for audit and compliance purposes.' ;
    rdfs:domain ind:CapitalContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributionAmount rdf:type rdf:Property ;
    rdfs:label 'Contribution Amount' ;
    rdfs:comment 'Gross amount of capital contributed by the owner or investor in the transaction currency. This is the base monetary amount before any adjustments, fees, or withholdings. Core component of the MONETARY_TRIPLET for this transaction.' ;
    rdfs:domain ind:CapitalContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contributionAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Contribution Amount Usd' ;
    rdfs:comment 'Contribution amount converted to USD at the applicable exchange rate on the contribution date. Used for consolidated portfolio reporting, NAV calculations, and AUM tracking across multi-currency investment vehicles.' ;
    rdfs:domain ind:CapitalContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contributionDate rdf:type rdf:Property ;
    rdfs:label 'Contribution Date' ;
    rdfs:comment 'The actual business date on which the capital contribution was received and recorded, i.e., the value date of the equity funding event. Used for equity waterfall calculations and capital account balance updates.' ;
    rdfs:domain ind:CapitalContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contributionReference rdf:type rdf:Property ;
    rdfs:label 'Contribution Reference' ;
    rdfs:comment 'Externally-known business reference number or code assigned to this capital contribution event, used for cross-referencing with investor notices, capital call letters, and wire instructions. Sourced from Yardi Voyager or MRI Software capital account module.' ;
    rdfs:domain ind:CapitalContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributionStatus rdf:type rdf:Property ;
    rdfs:label 'Contribution Status' ;
    rdfs:comment 'Current lifecycle status of the capital contribution record. Pending indicates a capital call has been issued but funds not yet received; funded indicates wire confirmed; partially_funded indicates only a portion of the called amount was received; returned indicates capital was returned to investor; cancelled indicates the contribution was voided.' ;
    rdfs:domain ind:CapitalContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributionType rdf:type rdf:Property ;
    rdfs:label 'Contribution Type' ;
    rdfs:comment 'Classification of the nature of the capital contribution. Initial equity is the founding equity injection; capital_call is a drawdown against an unfunded commitment; preferred_equity is a senior equity tranche injection; co_invest is a co-investment alongside a primary fund; return_of_capital is a distribution classified as capital return; additional_equity is a supplemental equity injection post-initial close. [ENUM-REF-CANDIDATE: initial_equity|capital_call|preferred_equity|co_invest|return_of_capital|additional_equity — promote to reference product]' ;
    rdfs:domain ind:CapitalContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultInterestAmount rdf:type rdf:Property ;
    rdfs:label 'Default Interest Amount' ;
    rdfs:comment 'The default interest or penalty amount charged to the investor for late funding of a capital call, as specified in the partnership or JV agreement. Applicable only when is_late_funding is True.' ;
    rdfs:domain ind:CapitalContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equityTier rdf:type rdf:Property ;
    rdfs:label 'Equity Tier' ;
    rdfs:comment 'The equity tranche or tier classification of this capital contribution within the investment vehicle\'s capital stack. Determines priority in the equity waterfall distribution model (e.g., preferred equity receives distributions before common equity).' ;
    rdfs:domain ind:CapitalContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingSourceType rdf:type rdf:Property ;
    rdfs:label 'Funding Source Type' ;
    rdfs:comment 'The mechanism or instrument used to fund the capital contribution. Wire transfer and ACH are cash funding methods; in_kind indicates a non-cash asset contribution; debt_conversion indicates conversion of a loan to equity; reinvestment indicates distribution proceeds reinvested as new capital.' ;
    rdfs:domain ind:CapitalContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fxRate rdf:type rdf:Property ;
    rdfs:label 'Fx Rate' ;
    rdfs:comment 'Exchange rate applied to convert the contribution amount from the transaction currency to USD on the contribution date. Sourced from the reference data FX rate table. A value of 1.0 indicates the contribution is already in USD.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'The GL account code in the chart of accounts to which this capital contribution is posted in the accounting system (Yardi Voyager or SAP S/4HANA). Enables reconciliation between the owner domain capital account and the finance domain GL entries.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investorEntityType rdf:type rdf:Property ;
    rdfs:label 'Investor Entity Type' ;
    rdfs:comment 'Classification of the investor or owner entity type making the contribution. Determines applicable regulatory reporting requirements, tax treatment, and KYC/AML obligations. [ENUM-REF-CANDIDATE: individual|institutional|reit|jv_entity|partnership|fund|family_office|sovereign_wealth — promote to reference product]' ;
    rdfs:domain ind:CapitalContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLateFunding rdf:type rdf:Property ;
    rdfs:label 'Is Late Funding' ;
    rdfs:comment 'Indicates whether the capital contribution was received after the capital call due date. True if contribution_date is after capital_call_due_date. Used to trigger default interest calculations and investor compliance monitoring.' ;
    rdfs:domain ind:CapitalContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kycVerified rdf:type rdf:Property ;
    rdfs:label 'Kyc Verified' ;
    rdfs:comment 'Indicates whether the contributing investor has completed KYC verification as required by AML regulations prior to this contribution being accepted. True indicates KYC is current and verified; False indicates KYC is pending or expired.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Net Contribution Amount' ;
    rdfs:comment 'The net amount of capital credited to the investor\'s capital account after deducting tax withholdings, default interest charges, or other adjustments from the gross contribution_amount. Represents the net total in the MONETARY_TRIPLET.' ;
    rdfs:domain ind:CapitalContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownershipPctAfter rdf:type rdf:Property ;
    rdfs:label 'Ownership Pct After' ;
    rdfs:comment 'The investor\'s pro-rata ownership percentage in the investment vehicle or property immediately after this capital contribution is applied. Reflects any dilution or accretion resulting from the contribution event.' ;
    rdfs:domain ind:CapitalContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownershipPctBefore rdf:type rdf:Property ;
    rdfs:label 'Ownership Pct Before' ;
    rdfs:comment 'The investor\'s pro-rata ownership percentage in the investment vehicle or property immediately before this capital contribution. Expressed as a decimal (e.g., 0.25 = 25%). Used to track dilution or accretion events.' ;
    rdfs:domain ind:CapitalContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredReturnAccrualMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Return Accrual Method' ;
    rdfs:comment 'The method by which the preferred return accrues on this capital contribution. Simple interest accrues on the original contribution only; compound accrues on the outstanding balance including accrued return; cumulative_non_compounding tracks unpaid preferred return without compounding.' ;
    rdfs:domain ind:CapitalContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'The operational system of record from which this capital contribution record was originated or ingested. Used for data lineage tracking and reconciliation in the Databricks Silver Layer.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRef rdf:type rdf:Property ;
    rdfs:label 'Source System Ref' ;
    rdfs:comment 'The native record identifier from the originating source system (e.g., Yardi Voyager transaction ID, MRI Software capital account entry ID). Enables traceability and reconciliation back to the system of record.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxWithholdingAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Withholding Amount' ;
    rdfs:comment 'The amount withheld from the capital contribution for tax purposes, applicable to foreign investors subject to FIRPTA withholding or other tax withholding obligations. Part of the MONETARY_TRIPLET adjustment component.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unfundedCommitmentAfter rdf:type rdf:Property ;
    rdfs:label 'Unfunded Commitment After' ;
    rdfs:comment 'The investor\'s remaining unfunded commitment balance immediately after this capital contribution event is applied. Calculated as unfunded_commitment_before minus contribution_amount. Stored for audit trail and point-in-time reporting.' ;
    rdfs:domain ind:CapitalContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unfundedCommitmentBefore rdf:type rdf:Property ;
    rdfs:label 'Unfunded Commitment Before' ;
    rdfs:comment 'The investor\'s remaining unfunded commitment balance immediately prior to this capital contribution event. Used to validate that the called amount does not exceed the outstanding commitment and to track drawdown progress.' ;
    rdfs:domain ind:CapitalContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:useOfProceeds rdf:type rdf:Property ;
    rdfs:label 'Use Of Proceeds' ;
    rdfs:comment 'Narrative description of the intended use of the contributed capital, as specified in the capital call notice or investment agreement. Examples include property acquisition down payment, construction draw funding, debt paydown, or working capital reserve.' ;
    rdfs:domain ind:CapitalContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wireConfirmationRef rdf:type rdf:Property ;
    rdfs:label 'Wire Confirmation Ref' ;
    rdfs:comment 'The bank wire confirmation number, ACH trace number, or payment reference provided by the investor\'s financial institution upon funding. Used for reconciliation against bank statements and to confirm receipt of funds.' ;
    rdfs:domain ind:CapitalContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipTransferId rdf:type rdf:Property ;
    rdfs:label 'Ownership Transfer Id' ;
    rdfs:comment 'Unique system-generated identifier for each ownership interest transfer record. Primary key for the ownership_transfer data product.' ;
    rdfs:domain ind:OwnershipTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assumedDebtInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Assumed Debt Instrument Id' ;
    rdfs:comment 'Foreign key linking to finance.debt_instrument. Business justification: Property ownership transfers frequently involve loan assumptions or defeasance of existing debt. Linking the transfer to the specific debt instrument is required for lender consent tracking, ALTA clos' ;
    rdfs:domain ind:OwnershipTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DebtInstrument .

ind:bpoId rdf:type rdf:Property ;
    rdfs:label 'Bpo Id' ;
    rdfs:comment 'Foreign key linking to valuation.bpo. Business justification: Ownership transfers, particularly distressed or smaller residential transactions, use a BPO in lieu of a full appraisal to establish consideration amount. Lenders and servicers require the BPO referen' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bpo .

ind:complianceAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Compliance Assessment Id' ;
    rdfs:comment 'Foreign key linking to compliance.assessment. Business justification: Property transfers require compliance assessments — environmental Phase I/II due diligence, title compliance reviews, and AML/KYC assessments for the transaction. Real estate attorneys and compliance ' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Assessment .

ind:lenderId rdf:type rdf:Property ;
    rdfs:label 'Lender Id' ;
    rdfs:comment 'Reference to the financing institution providing acquisition financing for the transferee in connection with this transfer. Relevant for Loan-to-Value (LTV) ratio tracking and Debt Service Coverage Ratio (DSCR) analysis. Null for all-cash transfers.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lender .

ind:opsInspectionId rdf:type rdf:Property ;
    rdfs:label 'Ops Inspection Id' ;
    rdfs:comment 'Foreign key linking to maintenance.ops_inspection. Business justification: Pre-acquisition and pre-sale property condition assessments (PCA) are standard due diligence in real estate ownership transfers. Linking the ops_inspection to ownership_transfer records the physical c' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OpsInspection .

ind:parcelId rdf:type rdf:Property ;
    rdfs:label 'Parcel Id' ;
    rdfs:comment 'Foreign key linking to property.parcel. Business justification: Ownership transfers (deed conveyances) are legally recorded at the parcel level in county recorder offices. Title examiners and closing attorneys must link each transfer to the specific parcel(s) bein' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Parcel .

ind:primaryOwnershipTransferorOwnerId rdf:type rdf:Property ;
    rdfs:label 'Primary Ownership Transferor Owner Id' ;
    rdfs:comment 'Reference to the owner or investor entity relinquishing the ownership interest. Represents the selling or transferring party in the transaction.' ;
    rdfs:domain ind:OwnershipTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Owner .

ind:proceedsBankAccountId rdf:type rdf:Property ;
    rdfs:label 'Proceeds Bank Account Id' ;
    rdfs:comment 'Foreign key linking to finance.bank_account. Business justification: Ownership transfer sale proceeds are deposited into specific bank accounts (escrow or operating). Role-prefixed \'proceeds_\' to distinguish from assumed_debt and lender FKs. Required for proceeds track' ;
    rdfs:domain ind:OwnershipTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:propertySaleId rdf:type rdf:Property ;
    rdfs:label 'Property Sale Id' ;
    rdfs:comment 'Foreign key linking to transaction.property_sale. Business justification: When a property sale closes, an ownership transfer record is created to reflect the change in ownership interest. Linking ownership_transfer to the triggering property_sale enables reconciliation of o' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PropertySale .

ind:recordingGeographicHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Recording Geographic Hierarchy Id' ;
    rdfs:comment 'Foreign key linking to reference.geographic_hierarchy. Business justification: Recording jurisdiction determines applicable transfer taxes, deed recording fees, and title registration requirements. Title officers and closing attorneys require normalized geographic hierarchy to a' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeographicHierarchy .

ind:titleRecordId rdf:type rdf:Property ;
    rdfs:label 'Title Record Id' ;
    rdfs:comment 'Foreign key linking to property.title_record. Business justification: Every ownership transfer produces a recorded deed captured in title_record. Linking ownership_transfer to title_record is essential for chain-of-title tracking, closing reconciliation, and title insur' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TitleRecord .

ind:transferPermitId rdf:type rdf:Property ;
    rdfs:label 'Transfer Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: Property transfers require specific permits — change-of-ownership permits, certificate of occupancy transfers, and municipal transfer clearances. Title officers and closing attorneys must verify the a' ;
    rdfs:domain ind:OwnershipTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:agreementExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Execution Date' ;
    rdfs:comment 'The date on which the purchase and sale agreement, assignment agreement, or other binding transfer instrument was signed by all parties. May precede the transfer_date (closing date) by days or weeks during the due diligence period.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocatedPropertyValue rdf:type rdf:Property ;
    rdfs:label 'Allocated Property Value' ;
    rdfs:comment 'The total assessed or agreed fair market value of the underlying property at the time of transfer, used to compute the proportional value of the interest being transferred. Sourced from Argus Enterprise valuation models or appraisal reports.' ;
    rdfs:domain ind:OwnershipTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:altaSettlementStatementRef rdf:type rdf:Property ;
    rdfs:label 'Alta Settlement Statement Ref' ;
    rdfs:comment 'Reference identifier for the ALTA Uniform Settlement Statement (HUD-1 or ALTA Settlement Statement) associated with this transfer. Documents all financial terms, prorations, and closing costs. Used for audit and tax basis calculations.' ;
    rdfs:domain ind:OwnershipTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'The date on which the ownership transfer was formally approved by the designated approval authority. Distinct from the agreement execution date and transfer date. Required for SOX controls and investment committee governance documentation.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:beneficialOwnerDisclosed rdf:type rdf:Property ;
    rdfs:label 'Beneficial Owner Disclosed' ;
    rdfs:comment 'Indicates whether the ultimate beneficial owner(s) of the transferee entity have been disclosed and verified as part of the KYC/AML onboarding process. True when beneficial ownership disclosure is complete and on file. Required for FinCEN Geographic Targeting Orders and AML compliance.' ;
    rdfs:domain ind:OwnershipTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capitalGainsFlag rdf:type rdf:Property ;
    rdfs:label 'Capital Gains Flag' ;
    rdfs:comment 'Indicates whether the transfer is expected to generate a taxable capital gain or loss for the transferor. True when the consideration amount exceeds the transferor\'s adjusted tax basis in the interest. Drives tax provision calculations and investor reporting.' ;
    rdfs:domain ind:OwnershipTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:considerationAmount rdf:type rdf:Property ;
    rdfs:label 'Consideration Amount' ;
    rdfs:comment 'The gross monetary consideration paid by the transferee to the transferor for the ownership interest. Represents the agreed purchase price or fair market value of the interest transferred. Used for stamp duty, transfer tax, and capital gains calculations. Null for gift or inheritance transfers.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dueDiligenceEndDate rdf:type rdf:Property ;
    rdfs:label 'Due Diligence End Date' ;
    rdfs:comment 'The contractual deadline by which the transferee must complete all due diligence activities (title search, environmental review, financial audit) and either proceed with or cancel the transfer. Tracks deal timeline milestones.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exchange1031CaseNumber rdf:type rdf:Property ;
    rdfs:label 'Exchange 1031 Case Number' ;
    rdfs:comment 'The qualified intermediary case or exchange reference number assigned when this transfer is part of a Section 1031 like-kind exchange. Null for non-exchange transfers. Required for IRS compliance documentation and deferred gain tracking.' ;
    rdfs:domain ind:OwnershipTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Kyc Verification Status' ;
    rdfs:comment 'The current status of the Know Your Customer (KYC) and Anti-Money Laundering (AML) identity verification process for the transferee party. Required for regulatory compliance on all ownership transfers above reporting thresholds.' ;
    rdfs:domain ind:OwnershipTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'The timestamp when this ownership transfer record was most recently modified in the data platform. Used for incremental data processing, change detection, and audit trail maintenance. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loanAmount rdf:type rdf:Property ;
    rdfs:label 'Loan Amount' ;
    rdfs:comment 'The principal amount of the mortgage or acquisition loan obtained by the transferee to finance this ownership interest transfer. Used for Loan-to-Value (LTV) ratio computation and debt covenant monitoring.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ltvRatio rdf:type rdf:Property ;
    rdfs:label 'Ltv Ratio' ;
    rdfs:comment 'The ratio of the acquisition loan amount to the allocated property value at the time of transfer, expressed as a percentage (e.g., 65.0000 = 65% LTV). Key underwriting metric for lenders and portfolio risk management.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postTransferOwnershipPct rdf:type rdf:Property ;
    rdfs:label 'Post Transfer Ownership Pct' ;
    rdfs:comment 'The transferor\'s remaining ownership percentage in the property immediately after this transfer event. Computed as pre_transfer_ownership_pct minus transfer_percentage. Stored for audit trail and consolidation analysis.' ;
    rdfs:domain ind:OwnershipTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preTransferOwnershipPct rdf:type rdf:Property ;
    rdfs:label 'Pre Transfer Ownership Pct' ;
    rdfs:comment 'The transferor\'s ownership percentage in the property immediately before this transfer event. Provides the baseline for computing post-transfer ownership stakes and validating that transfer_percentage does not exceed the transferor\'s held interest.' ;
    rdfs:domain ind:OwnershipTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordingBookPage rdf:type rdf:Property ;
    rdfs:label 'Recording Book Page' ;
    rdfs:comment 'The official book and page number (or document number in electronic recording systems) assigned by the recording jurisdiction upon filing of the title instrument. Used for public records retrieval and chain-of-title verification.' ;
    rdfs:domain ind:OwnershipTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordingDate rdf:type rdf:Property ;
    rdfs:label 'Recording Date' ;
    rdfs:comment 'The date on which the title instrument was officially recorded with the relevant governmental authority (county recorder, land registry). May differ from the transfer_date; recording establishes constructive notice to third parties.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sndaAgreementRef rdf:type rdf:Property ;
    rdfs:label 'Snda Agreement Ref' ;
    rdfs:comment 'Reference identifier for the Subordination, Non-Disturbance and Attornment (SNDA) agreement executed in connection with this transfer, protecting existing tenant leases from disruption due to the ownership change. Sourced from DocuSign CLM.' ;
    rdfs:domain ind:OwnershipTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxBasisAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Basis Amount' ;
    rdfs:comment 'The transferor\'s adjusted tax basis in the ownership interest at the time of transfer. Used to compute realized gain or loss for income tax purposes. For 1031 exchanges, the carryover basis is tracked here.' ;
    rdfs:domain ind:OwnershipTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferCostsAmount rdf:type rdf:Property ;
    rdfs:label 'Transfer Costs Amount' ;
    rdfs:comment 'Total transaction costs incurred in executing the ownership transfer, including legal fees, title search fees, recording fees, broker commissions, and due diligence costs. Capitalized as part of the cost basis per FASB ASC 805.' ;
    rdfs:domain ind:OwnershipTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferDate rdf:type rdf:Property ;
    rdfs:label 'Transfer Date' ;
    rdfs:comment 'The principal real-world effective date on which the ownership interest legally transferred from transferor to transferee. This is the date of record for title and tax purposes, distinct from the agreement execution date.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transferPercentage rdf:type rdf:Property ;
    rdfs:label 'Transfer Percentage' ;
    rdfs:comment 'The percentage of the total ownership interest being transferred, expressed as a decimal (e.g., 25.0000 = 25%). Enables partial interest transfers within joint-venture and partnership structures. Must be between 0.0001 and 100.0000.' ;
    rdfs:domain ind:OwnershipTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Reference Number' ;
    rdfs:comment 'Externally-known business identifier for the ownership transfer event, used in correspondence, legal documents, and system cross-references. Sourced from Yardi Voyager or MRI Software ownership module.' ;
    rdfs:domain ind:OwnershipTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Status' ;
    rdfs:comment 'Current lifecycle state of the ownership transfer workflow. Tracks progression from initiation through legal completion. Values: pending (initiated, awaiting documentation), in_review (under legal/compliance review), approved (authorized for execution), completed (title recorded and transfer finalized), cancelled (transfer voided before completion), reversed (completed transfer subsequently unwound).' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Transfer Tax Amount' ;
    rdfs:comment 'The total real estate transfer tax, documentary stamp tax, or conveyance tax assessed on the ownership transfer by the applicable jurisdiction. Computed based on consideration amount and local tax rates. Required for tax compliance reporting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxRecordId rdf:type rdf:Property ;
    rdfs:label 'Tax Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each owner tax record in the Silver Layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:apInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ap Invoice Id' ;
    rdfs:comment 'Foreign key linking to finance.ap_invoice. Business justification: Property tax payments generate AP invoices. Linking tax_record to ap_invoice enables reconciliation between tax liability records and actual payment invoices, required for tax expense verification, au' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApInvoice .

ind:jurisdictionCountryId rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Tax jurisdiction country determines applicable tax rates, treaty benefits, FIRPTA withholding requirements, and foreign tax credit eligibility. Tax compliance teams require normalized country referenc' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:taxGeographicHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Tax Geographic Hierarchy Id' ;
    rdfs:comment 'Foreign key linking to reference.geographic_hierarchy. Business justification: Tax jurisdiction state/county maps to geographic hierarchy for multi-jurisdiction tax apportionment, state income tax filing, and property tax assessment reporting. Tax teams require normalized geogra' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeographicHierarchy .

ind:valuationTaxAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Valuation Tax Assessment Id' ;
    rdfs:comment 'Foreign key linking to valuation.tax_assessment. Business justification: Owner tax records are directly derived from property tax assessments. K-1 preparation, tax reporting, and appeal tracking require linking the owner\'s tax obligation to the specific assessment record. ' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxAssessment .

ind:appealFiledDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Date' ;
    rdfs:comment 'Date on which a formal tax assessment appeal was filed with the taxing authority or appeals board. Null if no appeal has been filed. Used to track appeal deadlines and resolution timelines.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealStatus rdf:type rdf:Property ;
    rdfs:label 'Appeal Status' ;
    rdfs:comment 'Current status of any formal appeal or contest filed against the taxing authority\'s assessed value or tax bill. Tracks the appeal lifecycle from filing through resolution. A successful appeal may result in a tax abatement.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessedTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Assessed Tax Amount' ;
    rdfs:comment 'Gross tax amount assessed or levied by the taxing authority for this tax year and jurisdiction, expressed in the record currency. For property tax, this is the annual tax bill amount. For withholding tax, this is the amount withheld. For K-1 allocations, this is the allocated taxable income amount.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:filingDate rdf:type rdf:Property ;
    rdfs:label 'Filing Date' ;
    rdfs:comment 'Actual date on which the tax return or filing was submitted to the taxing authority. Compared against filing_deadline_date to determine compliance. Supports SOX audit trail and SEC reporting for publicly traded REITs.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Filing Deadline Date' ;
    rdfs:comment 'Statutory or regulatory deadline for submitting the tax return or filing to the relevant authority. Distinct from the payment due date. Supports compliance monitoring and SOX control tracking.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingStatus rdf:type rdf:Property ;
    rdfs:label 'Filing Status' ;
    rdfs:comment 'Current lifecycle status of the tax filing associated with this record. Tracks progression from not filed through submission, amendment, and acceptance or rejection by the taxing authority. Supports SOX compliance monitoring and SEC reporting for publicly traded REITs.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firptaWithholdingRate rdf:type rdf:Property ;
    rdfs:label 'Firpta Withholding Rate' ;
    rdfs:comment 'Applicable FIRPTA withholding tax rate for foreign owners on disposition of US real property interests. Standard rate is 15% (0.1500) for amounts realized over $1M; reduced rates may apply per IRS withholding certificates. Expressed as a decimal (e.g., 0.1500 = 15%).' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestAmount rdf:type rdf:Property ;
    rdfs:label 'Interest Amount' ;
    rdfs:comment 'Interest charges accrued on unpaid or underpaid tax balances as assessed by the taxing authority. Tracked separately from penalties and base tax for accurate OPEX and NOI reporting.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jurisdictionCountyDistrict rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction County District' ;
    rdfs:comment 'County, municipality, or special tax district within the state where the property tax is levied. Relevant for local property tax assessments and special assessment districts.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:k1CapitalGainAmount rdf:type rdf:Property ;
    rdfs:label 'K1 Capital Gain Amount' ;
    rdfs:comment 'Partner\'s or investor\'s share of net capital gain allocated via IRS Schedule K-1 (Form 1065). Includes short-term and long-term capital gains from property dispositions within the partnership. Null for non-partnership structures.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:k1DepreciationAmount rdf:type rdf:Property ;
    rdfs:label 'K1 Depreciation Amount' ;
    rdfs:comment 'Partner\'s or investor\'s share of depreciation deductions allocated via IRS Schedule K-1. Relevant for REIT FFO (Funds From Operations) and AFFO (Adjusted Funds From Operations) calculations and investor tax planning.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:k1OrdinaryIncomeAmount rdf:type rdf:Property ;
    rdfs:label 'K1 Ordinary Income Amount' ;
    rdfs:comment 'Partner\'s or investor\'s share of ordinary business income allocated via IRS Schedule K-1 (Form 1065) for partnership entities. Applicable for JV entities, limited partnerships, and REIT operating partnerships. Null for non-partnership ownership structures.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'Monetary penalty assessed by the taxing authority for late filing, late payment, or underpayment of taxes. Tracked separately from the base tax obligation for OPEX reporting and NOI impact analysis.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when this owner tax record was first created in the Silver Layer lakehouse. Supports audit trail, SOX IT general controls, and data lineage tracking.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to this owner tax record in the Silver Layer lakehouse. Supports change tracking, SOX audit controls, and incremental data pipeline processing.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taxAbatementAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Abatement Amount' ;
    rdfs:comment 'Amount of tax reduction granted through formal abatement, exemption, or appeal decision by the taxing authority. Reduces the net tax obligation. Common in development projects with tax incentive agreements or successful assessment appeals.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxDueDate rdf:type rdf:Property ;
    rdfs:label 'Tax Due Date' ;
    rdfs:comment 'The statutory deadline by which the tax payment must be remitted to the taxing authority to avoid penalties and interest. May reflect installment due dates for jurisdictions with semi-annual or quarterly payment schedules.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxExemptStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Status' ;
    rdfs:comment 'Indicates whether the owner or property qualifies for a full or partial tax exemption under applicable law (e.g., nonprofit ownership, government entity, REIT structural exemption, homestead exemption). Drives tax obligation calculation.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxPaidAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Paid Amount' ;
    rdfs:comment 'Actual amount of tax remitted or paid to the taxing authority for this record period. May differ from assessed amount due to appeals, abatements, installment payments, or partial payments. Supports cash flow reporting and DSCR calculations.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Tax Payment Date' ;
    rdfs:comment 'Actual date on which the tax payment was remitted to the taxing authority. Used to determine timeliness of payment, calculate penalty and interest exposure, and support cash flow reporting.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Tax Period End Date' ;
    rdfs:comment 'End date of the tax assessment or reporting period covered by this record. For annual property tax, typically December 31 of the tax year. Defines the boundary of the tax obligation period.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Tax Period Start Date' ;
    rdfs:comment 'Start date of the tax assessment or reporting period covered by this record. For annual property tax, typically January 1 of the tax year. For withholding tax, the start of the applicable withholding period.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxRate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate' ;
    rdfs:comment 'The effective tax rate or mill rate applied by the taxing jurisdiction to the assessed property value to compute the property tax bill. Expressed as a decimal (e.g., 0.012500 = 1.25% or 12.5 mills). Also used for income or withholding tax rates where applicable.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Record Number' ;
    rdfs:comment 'Externally-known reference number assigned by the taxing jurisdiction or internal tax administration system for this specific tax obligation record. Used for correspondence with tax authorities and audit trails.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxTreatyArticle rdf:type rdf:Property ;
    rdfs:label 'Tax Treaty Article' ;
    rdfs:comment 'Specific article or provision of the applicable bilateral tax treaty under which the owner claims reduced withholding or exemption (e.g., \'Article 6 — Income from Immovable Property\'). Required for IRS Form W-8BEN treaty benefit claims.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxTreatyCountryCode rdf:type rdf:Property ;
    rdfs:label 'Tax Treaty Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the treaty country under which the owner claims a reduced withholding rate or tax exemption. Null if no treaty election applies. Used in conjunction with IRS Form W-8BEN treaty claims.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxType rdf:type rdf:Property ;
    rdfs:label 'Tax Type' ;
    rdfs:comment 'Classification of the tax obligation captured in this record. Covers property tax obligations by jurisdiction, income tax, withholding tax for foreign owners (FIRPTA), transfer tax on disposition, capital gains tax, and K-1 partnership income allocations. [ENUM-REF-CANDIDATE: property_tax|income_tax|withholding_tax|transfer_tax|capital_gains_tax|k1_partnership_allocation|excise_tax|franchise_tax — promote to reference product]' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxYear rdf:type rdf:Property ;
    rdfs:label 'Tax Year' ;
    rdfs:comment 'The calendar or fiscal year to which this tax record applies (e.g., 2024). Used for annual tax reporting, K-1 allocations, and SOX compliance period alignment.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tinType rdf:type rdf:Property ;
    rdfs:label 'Tin Type' ;
    rdfs:comment 'Classification of the tax identification number provided — EIN (Employer Identification Number) for entities, SSN (Social Security Number) for US individuals, ITIN (Individual Taxpayer Identification Number) for non-resident individuals, or foreign TIN for international owners.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Withholding Certificate Number' ;
    rdfs:comment 'IRS-issued withholding certificate number (from Form 8288-B application) that authorizes a reduced or zero FIRPTA withholding rate for a foreign owner. Null if no certificate has been obtained. Required for FIRPTA compliance tracking.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yardiTaxEntityCode rdf:type rdf:Property ;
    rdfs:label 'Yardi Tax Entity Code' ;
    rdfs:comment 'Cross-reference code identifying the corresponding tax entity or property record in Yardi Voyager Property Management and General Ledger modules. Enables reconciliation between the owner tax record and Yardi GL tax entries and AR/AP tax transactions.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Entity Hierarchy Id' ;
    rdfs:comment 'Unique surrogate identifier for each parent-child ownership hierarchy relationship record in the Silver Layer. Primary key for this data product.' ;
    rdfs:domain ind:EntityHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:childEntityLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Child Entity Legal Entity Id' ;
    rdfs:comment 'Identifier of the child owner entity in the hierarchy (e.g., subsidiary, SPV, operating partnership, joint-venture entity). References the owner entity that sits below the parent in the ownership structure.' ;
    rdfs:domain ind:EntityHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:governingOwnerAgreementId rdf:type rdf:Property ;
    rdfs:label 'Governing Owner Agreement Id' ;
    rdfs:comment 'Foreign key linking to owner.owner_agreement. Business justification: entity_hierarchy has a governing_agreement_ref STRING column that stores a reference to the governing agreement for the hierarchy relationship. This should be normalized into a proper FK to owner_agre' ;
    rdfs:domain ind:EntityHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OwnerAgreement .

ind:parentOwnerId rdf:type rdf:Property ;
    rdfs:label 'Parent Owner Id' ;
    rdfs:comment 'Foreign key linking to owner.owner. Business justification: entity_hierarchy models the parent-child organizational hierarchy among owner entities. The parent entity in the hierarchy IS an owner record. Adding parent_owner_id FK normalizes the parent side of t' ;
    rdfs:domain ind:EntityHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Owner .

ind:primaryLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Primary Legal Entity Id' ;
    rdfs:comment 'Identifier of the parent owner entity in the hierarchy (e.g., holding company, REIT umbrella partnership, fund-of-funds). References the owner entity that sits above the child in the ownership structure.' ;
    rdfs:domain ind:EntityHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:aumAttributionPct rdf:type rdf:Property ;
    rdfs:label 'Aum Attribution Pct' ;
    rdfs:comment 'Percentage of the child entity\'s Assets Under Management (AUM) attributable to the parent entity for portfolio-level AUM reporting. May differ from equity ownership percentage due to management fee structures or co-investment arrangements.' ;
    rdfs:domain ind:EntityHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consolidationMethod rdf:type rdf:Property ;
    rdfs:label 'Consolidation Method' ;
    rdfs:comment 'Accounting consolidation method applied to this parent-child relationship for financial reporting purposes. Determines how the child entity\'s financials are incorporated into the parent\'s consolidated statements.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalDate rdf:type rdf:Property ;
    rdfs:label 'Disposal Date' ;
    rdfs:comment 'Date on which the parent entity disposed of or transferred its ownership interest in the child entity. Null for currently active relationships. Used for realized gain/loss reporting and portfolio disposition tracking.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:economicInterestPct rdf:type rdf:Property ;
    rdfs:label 'Economic Interest Pct' ;
    rdfs:comment 'Percentage of economic interest (profit/loss participation) held by the parent entity in the child entity. Relevant for joint ventures and operating partnerships where economic interest differs from voting rights or equity ownership.' ;
    rdfs:domain ind:EntityHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entityStructureType rdf:type rdf:Property ;
    rdfs:label 'Entity Structure Type' ;
    rdfs:comment 'Legal or organizational structure type of the child entity within the hierarchy. Drives applicable regulatory reporting, tax treatment, and consolidation rules. [ENUM-REF-CANDIDATE: holding_company|spv|reit|operating_partnership|joint_venture|fund|partnership|subsidiary — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:EntityHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equityOwnershipPct rdf:type rdf:Property ;
    rdfs:label 'Equity Ownership Pct' ;
    rdfs:comment 'Percentage of equity interest held by the parent entity in the child entity, expressed as a decimal percentage (e.g., 100.0000 for wholly owned, 51.0000 for majority controlled). Critical for NAV, GAV, and AUM roll-up calculations.' ;
    rdfs:domain ind:EntityHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gavAttributionPct rdf:type rdf:Property ;
    rdfs:label 'Gav Attribution Pct' ;
    rdfs:comment 'Percentage of the child entity\'s Gross Asset Value (GAV) attributable to the parent entity for consolidated GAV reporting. Supports portfolio-level investment performance analysis.' ;
    rdfs:domain ind:EntityHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Code' ;
    rdfs:comment 'Externally-known business code uniquely identifying this parent-child hierarchy relationship, used for cross-system reconciliation with Yardi Voyager, MRI Software, and Argus Enterprise portfolio structures.' ;
    rdfs:domain ind:EntityHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric depth of the child entity within the ownership hierarchy tree, where level 1 represents a direct subsidiary of the ultimate parent. Enables roll-up reporting of AUM, NAV, and GAV across multi-tier structures.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Path' ;
    rdfs:comment 'Materialized path string representing the full ancestry chain from the ultimate root entity to the child entity (e.g., \'/RootHoldCo/SubHoldCo/SPV-001\'). Enables efficient tree traversal and roll-up queries in Databricks without recursive CTEs.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyPurpose rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Purpose' ;
    rdfs:comment 'Business purpose for which this hierarchy relationship is defined. A single pair of entities may have multiple hierarchy records serving different purposes (e.g., legal ownership vs. management reporting vs. tax consolidation).' ;
    rdfs:domain ind:EntityHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyStatus rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Status' ;
    rdfs:comment 'Current lifecycle state of the parent-child hierarchy relationship. Active indicates the relationship is currently in force; dissolved indicates the child entity has been wound down or the relationship terminated.' ;
    rdfs:domain ind:EntityHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyVersion rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Version' ;
    rdfs:comment 'Sequential version number of this hierarchy relationship record, incremented each time the relationship is modified (e.g., ownership percentage change, consolidation method change). Supports temporal versioning and audit trail.' ;
    rdfs:domain ind:EntityHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isConsolidationEntity rdf:type rdf:Property ;
    rdfs:label 'Is Consolidation Entity' ;
    rdfs:comment 'Indicates whether the child entity is included in the parent\'s consolidated financial statements for regulatory and statutory reporting purposes. True if consolidated; False if excluded (e.g., minority interest below consolidation threshold).' ;
    rdfs:domain ind:EntityHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryHierarchy rdf:type rdf:Property ;
    rdfs:label 'Is Primary Hierarchy' ;
    rdfs:comment 'Indicates whether this relationship represents the primary (canonical) parent-child link for the child entity. A child entity may have multiple hierarchy records (e.g., legal vs. management reporting), but only one is designated primary.' ;
    rdfs:domain ind:EntityHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionStateCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction State Code' ;
    rdfs:comment 'ISO 3166-2 two-letter state or province code of the sub-national jurisdiction governing this ownership relationship. Used for state-level regulatory filings and tax reporting.' ;
    rdfs:domain ind:EntityHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minorityInterestFlag rdf:type rdf:Property ;
    rdfs:label 'Minority Interest Flag' ;
    rdfs:comment 'Indicates whether this relationship represents a non-controlling (minority) interest position where the parent holds less than 50% equity or voting rights. Drives non-controlling interest disclosure in consolidated financial statements.' ;
    rdfs:domain ind:EntityHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:navAttributionPct rdf:type rdf:Property ;
    rdfs:label 'Nav Attribution Pct' ;
    rdfs:comment 'Percentage of the child entity\'s Net Asset Value (NAV) attributable to the parent entity for consolidated NAV reporting. Used in REIT and fund-of-funds NAV roll-up calculations.' ;
    rdfs:domain ind:EntityHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reitQualifyingFlag rdf:type rdf:Property ;
    rdfs:label 'Reit Qualifying Flag' ;
    rdfs:comment 'Indicates whether the child entity qualifies as a Real Estate Investment Trust (REIT) or REIT subsidiary for tax and regulatory purposes. Drives REIT compliance testing and SEC reporting obligations.' ;
    rdfs:domain ind:EntityHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'Classification of the ownership relationship between parent and child entities. Drives consolidation treatment and financial reporting. [ENUM-REF-CANDIDATE: wholly_owned|majority_controlled|minority_interest|joint_venture|fund_of_funds|operating_partnership — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:EntityHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemHierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Source System Hierarchy Code' ;
    rdfs:comment 'Native identifier of this hierarchy relationship record in the originating source system (e.g., Yardi entity tree node ID, MRI entity relationship ID). Enables traceability back to the system of record.' ;
    rdfs:domain ind:EntityHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxTransparentFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Transparent Flag' ;
    rdfs:comment 'Indicates whether the child entity is tax-transparent (pass-through) for income tax purposes (e.g., partnership, LLC treated as disregarded entity). Affects tax consolidation and investor-level tax reporting.' ;
    rdfs:domain ind:EntityHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:variableInterestEntityFlag rdf:type rdf:Property ;
    rdfs:label 'Variable Interest Entity Flag' ;
    rdfs:comment 'Indicates whether the child entity qualifies as a Variable Interest Entity (VIE) under FASB ASC 810, requiring consolidation by the primary beneficiary regardless of voting interest percentage.' ;
    rdfs:domain ind:EntityHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:votingRightsPct rdf:type rdf:Property ;
    rdfs:label 'Voting Rights Pct' ;
    rdfs:comment 'Percentage of voting rights held by the parent entity in the child entity. May differ from equity ownership percentage in structures with preferred equity, non-voting shares, or dual-class share arrangements.' ;
    rdfs:domain ind:EntityHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workOrderId rdf:type rdf:Property ;
    rdfs:label 'Work Order Id' ;
    rdfs:comment 'Unique system-generated surrogate identifier for the work order record in the maintenance management system. Primary key for the work_order data product.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:amenityId rdf:type rdf:Property ;
    rdfs:label 'Amenity Id' ;
    rdfs:comment 'Foreign key linking to property.amenity. Business justification: Amenity maintenance (pool, gym, rooftop terrace) generates work orders that must link to the specific amenity for amenity-level operating expense reporting and CAM cost allocation.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Amenity .

ind:buildingAssetId rdf:type rdf:Property ;
    rdfs:label 'Building Asset Id' ;
    rdfs:comment 'Reference to the specific building equipment or infrastructure asset (e.g., HVAC unit, elevator, boiler) against which the work order is raised. Supports equipment lifecycle tracking and O&M history.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BuildingAsset .

ind:compliancePermitId rdf:type rdf:Property ;
    rdfs:label 'Compliance Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: Work orders for construction, renovation, or major repairs require building permits. Facilities managers track permit compliance per work order for certificate-of-occupancy and code enforcement purpos' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:complianceRemediationActionId rdf:type rdf:Property ;
    rdfs:label 'Compliance Remediation Action Id' ;
    rdfs:comment 'Foreign key linking to compliance.remediation_action. Business justification: Work orders are the operational execution of compliance remediation actions. Compliance officers track which work order is fulfilling each remediation action to manage regulatory deadlines, verify cor' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RemediationAction .

ind:complianceRequirementId rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirement Id' ;
    rdfs:comment 'Foreign key linking to compliance.requirement. Business justification: Work orders are executed to fulfill specific compliance requirements (distinct from higher-level regulatory_obligation). Compliance managers link work orders to requirements to verify fulfillment, gen' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Requirement .

ind:constructionContractId rdf:type rdf:Property ;
    rdfs:label 'Construction Contract Id' ;
    rdfs:comment 'Foreign key linking to development.construction_contract. Business justification: Warranty work orders executed under construction contract warranty provisions must reference the originating contract to enforce contractor recall obligations, track warranty claim costs against the c' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConstructionContract .

ind:constructionPermitId rdf:type rdf:Property ;
    rdfs:label 'Construction Permit Id' ;
    rdfs:comment 'Foreign key linking to development.construction_permit. Business justification: Work orders for permitted maintenance activities (electrical panel replacement, structural repairs) must reference the governing construction permit for regulatory compliance and inspection sign-off. ' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConstructionPermit .

ind:demisedSpaceId rdf:type rdf:Property ;
    rdfs:label 'Demised Space Id' ;
    rdfs:comment 'Foreign key linking to lease.lease_demised_space. Business justification: Work orders for tenant space maintenance must reference the specific demised space to allocate maintenance costs per leased area, support CAM pro-rata calculations, and track lease maintenance respons' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemisedSpace .

ind:floorId rdf:type rdf:Property ;
    rdfs:label 'Floor Id' ;
    rdfs:comment 'Foreign key linking to property.floor. Business justification: Work orders are routinely scoped to a specific floor (e.g., HVAC repair on floor 12). Facility managers filter and report work orders by floor for building operations. Existing FKs cover building/unit' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Floor .

ind:occupancyId rdf:type rdf:Property ;
    rdfs:label 'Occupancy Id' ;
    rdfs:comment 'Foreign key linking to tenant.occupancy. Business justification: Tenant-billable work orders, TI completion verification, and move-out damage assessments must be linked to the specific occupancy. Property managers use this to track maintenance costs per occupancy p' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Occupancy .

ind:pmScheduleId rdf:type rdf:Property ;
    rdfs:label 'Pm Schedule Id' ;
    rdfs:comment 'Reference to the preventive maintenance schedule that generated this work order, if applicable. Null for reactive or ad-hoc work orders. Links the work order to the PM program for compliance tracking and schedule adherence reporting.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PmSchedule .

ind:propertySpaceId rdf:type rdf:Property ;
    rdfs:label 'Property Space Id' ;
    rdfs:comment 'Foreign key linking to property.space. Business justification: Commercial real estate work orders are scoped to specific leasable spaces (suites) for CAM cost allocation and tenant billing. Space-level maintenance cost tracking is required for CAM reconciliation ' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Space .

ind:propertyTypeId rdf:type rdf:Property ;
    rdfs:label 'Property Type Id' ;
    rdfs:comment 'Foreign key linking to reference.property_type. Business justification: Work order SLA targets, priority rules, and operational reporting are segmented by property type (residential vs commercial vs industrial). Property managers run work order performance dashboards by p' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PropertyType .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to finance.purchase_order. Business justification: Work orders are executed against purchase orders for vendor payment authorization. Direct FK enables PO-to-work-order matching for 3-way match and spend control. work_order.purchase_order_number is a ' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:serviceContractId rdf:type rdf:Property ;
    rdfs:label 'Service Contract Id' ;
    rdfs:comment 'Reference to the service contract under which this work order is executed. Enables contract utilization tracking, SLA enforcement, and vendor performance measurement.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceContract .

ind:serviceRequestId rdf:type rdf:Property ;
    rdfs:label 'Service Request Id' ;
    rdfs:comment 'Foreign key linking to maintenance.service_request. Business justification: A work order is frequently generated in response to a tenant service request. This FK normalizes the originating service request relationship on the work order, enabling traceability from request subm' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceRequest .

ind:tenantId rdf:type rdf:Property ;
    rdfs:label 'Tenant Id' ;
    rdfs:comment 'Reference to the tenant who submitted or is associated with the service request that generated this work order. Null for landlord-initiated or preventive maintenance work orders.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tenant .

ind:terminationId rdf:type rdf:Property ;
    rdfs:label 'Termination Id' ;
    rdfs:comment 'Foreign key linking to lease.termination. Business justification: Lease termination restoration process: when a lease terminates, multiple work orders are created for space restoration, remediation, and condition assessment. Property managers track termination-spawn' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Termination .

ind:triggeringInspectionId rdf:type rdf:Property ;
    rdfs:label 'Triggering Inspection Id' ;
    rdfs:comment 'Foreign key linking to property.inspection. Business justification: Property inspections trigger deficiency-remediation work orders. Linking work orders back to the triggering inspection supports inspection close-out tracking, regulatory compliance reporting, and audi' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Inspection .

ind:actualCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Timestamp' ;
    rdfs:comment 'The actual date and time when the work order was fully completed and signed off. Used for SLA breach analysis, mean time to repair (MTTR) calculation, and vendor performance reporting.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualLaborCost rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Cost' ;
    rdfs:comment 'The actual cost of labor incurred to complete the work order, including regular and overtime technician hours multiplied by applicable trade rates. Sourced from time-tracking entries in the CMMS or payroll system.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Actual Material Cost' ;
    rdfs:comment 'The actual cost of parts, supplies, and materials consumed to complete the work order. Sourced from inventory consumption records or vendor invoices.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'The actual date and time when work physically commenced on site. Compared against scheduled_start_date to measure dispatch punctuality and SLA adherence.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualTotalCost rdf:type rdf:Property ;
    rdfs:label 'Actual Total Cost' ;
    rdfs:comment 'The total actual cost of the work order combining labor and materials costs. Used for CAPEX/OPEX reporting, GL posting, and budget variance analysis. Equals actual_labor_cost + actual_material_cost plus any additional charges.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capexOpexClassification rdf:type rdf:Property ;
    rdfs:label 'Capex Opex Classification' ;
    rdfs:comment 'Financial classification of the work order as either Capital Expenditure (CAPEX) — costs that extend asset life or add value — or Operating Expenditure (OPEX) — routine maintenance and repair costs. Critical for financial reporting, GL coding, and FASB/IFRS compliance.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost' ;
    rdfs:comment 'The pre-work estimated total cost of the work order including labor and materials, in the local operating currency. Used for budget approval workflows, CAPEX/OPEX forecasting, and purchase order generation.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:followUpRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required' ;
    rdfs:comment 'Indicates whether additional work, a follow-up inspection, or a new work order is required after this work order is closed. True = a subsequent work order or inspection should be scheduled.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborHours rdf:type rdf:Property ;
    rdfs:label 'Labor Hours' ;
    rdfs:comment 'Total number of technician labor hours expended on the work order, including regular and overtime hours. Used for workforce utilization analysis, trade cost benchmarking, and O&M reporting.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationDetail rdf:type rdf:Property ;
    rdfs:label 'Location Detail' ;
    rdfs:comment 'Specific location within the property where the work is to be performed (e.g., floor number, suite, room, mechanical room, rooftop). Supplements the property-level reference for precise dispatch and asset tracking.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaSafetyFlag rdf:type rdf:Property ;
    rdfs:label 'Osha Safety Flag' ;
    rdfs:comment 'Indicates whether this work order involves activities subject to OSHA safety regulations (e.g., confined space entry, lockout/tagout, working at heights, hazardous materials). True = OSHA-regulated activity requiring safety documentation and compliance sign-off.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overtimeHours rdf:type rdf:Property ;
    rdfs:label 'Overtime Hours' ;
    rdfs:comment 'Number of overtime labor hours charged to the work order. Separated from regular hours for payroll cost allocation, budget variance analysis, and emergency response cost tracking.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permitRequired rdf:type rdf:Property ;
    rdfs:label 'Permit Required' ;
    rdfs:comment 'Indicates whether a building permit, hot work permit, or other regulatory permit is required before work can commence. True = permit must be obtained and documented prior to execution.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Urgency classification assigned to the work order at creation or triage. Drives SLA target times, dispatch sequencing, and escalation rules. Critical typically indicates life-safety or building-critical system failure.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reported Timestamp' ;
    rdfs:comment 'The real-world date and time when the maintenance issue or service request was first reported by the tenant or building staff. May differ from created_timestamp if there is a lag in CMMS entry. The principal business event time for SLA measurement.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestedBy rdf:type rdf:Property ;
    rdfs:label 'Requested By' ;
    rdfs:comment 'Name or identifier of the person who submitted the service request or initiated the work order — may be a tenant contact, property manager, or building engineer. Captured for accountability and tenant relationship management.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Free-text field capturing the technician\'s or vendor\'s description of the work performed, root cause identified, parts replaced, and any follow-up actions recommended. Critical for asset maintenance history and recurring issue analysis.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Completion Date' ;
    rdfs:comment 'The planned date by which the work order is expected to be completed. Used as the SLA target date for on-time completion measurement and tenant communication.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'The planned date on which work is scheduled to begin. Used for resource planning, vendor scheduling, and preventive maintenance calendar management.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaBreached rdf:type rdf:Property ;
    rdfs:label 'Sla Breached' ;
    rdfs:comment 'Indicates whether the work order exceeded its SLA completion target. True = SLA was breached; False = completed within SLA. Used for vendor performance scorecards, tenant reporting, and contract penalty triggers.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaCompletionTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Completion Target Hours' ;
    rdfs:comment 'The contractually or operationally defined maximum number of hours within which the work order must be fully completed from the time of reporting. Used for SLA breach detection and vendor penalty calculations.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaResponseTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Response Target Hours' ;
    rdfs:comment 'The contractually or operationally defined maximum number of hours within which a technician or vendor must respond to the work order, based on priority level and service contract terms.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenantBillable rdf:type rdf:Property ;
    rdfs:label 'Tenant Billable' ;
    rdfs:comment 'Indicates whether the cost of this work order is billable to the tenant under the terms of their lease (e.g., tenant-caused damage, above-standard services). True = costs to be included in tenant billing or CAM reconciliation.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradeCategory rdf:type rdf:Property ;
    rdfs:label 'Trade Category' ;
    rdfs:comment 'The skilled trade or building systems discipline required to execute the work order (e.g., HVAC, electrical, plumbing). Used for vendor dispatch routing, workforce planning, and trade-level cost analysis. [ENUM-REF-CANDIDATE: hvac|electrical|plumbing|structural|elevator|fire_life_safety|janitorial|landscaping|general — promote to reference product]' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyClaim rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim' ;
    rdfs:comment 'Indicates whether the work order is being executed under an active equipment or construction warranty. True = costs may be recoverable from the manufacturer or contractor; affects CAPEX/OPEX classification and cost recovery tracking.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workOrderDescription rdf:type rdf:Property ;
    rdfs:label 'Work Order Description' ;
    rdfs:comment 'Free-text narrative describing the nature of the maintenance issue, the scope of work required, or the service request details as entered by the requestor or dispatcher.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'Externally visible, human-readable business identifier for the work order as assigned by the CMMS (e.g., Building Engines). Used in tenant communications, vendor dispatch, and audit trails.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Work Order Status' ;
    rdfs:comment 'Current lifecycle state of the work order. Tracks progression from creation through assignment, active execution, hold, completion, and final closure. Used for SLA breach analysis and operational dashboards. [ENUM-REF-CANDIDATE: draft|open|assigned|in_progress|on_hold|completed|cancelled|closed — promote to reference product]' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderType rdf:type rdf:Property ;
    rdfs:label 'Work Order Type' ;
    rdfs:comment 'Classification of the work order by its operational nature. Corrective = reactive repair; Preventive = scheduled PM; Emergency = life-safety or critical system failure; Inspection = condition assessment; Capital Improvement = CAPEX project work; Tenant Improvement (TI) = tenant-specific fit-out or modification. [ENUM-REF-CANDIDATE: corrective|preventive|emergency|inspection|capital_improvement|tenant_improvement — promote to reference product]' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseAgreementId rdf:type rdf:Property ;
    rdfs:label 'Lease Agreement Id' ;
    rdfs:comment 'Identifier of the active lease associated with the tenant and suite at the time of the service request. Used for CAM charge-back allocation and lease-level reporting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LeaseAgreement .

ind:primaryServicePropertyAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Service Property Asset Id' ;
    rdfs:comment 'Identifier of the property (building or complex) where the service request originated. Links to the property master record.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:tenantContactId rdf:type rdf:Property ;
    rdfs:label 'Tenant Contact Id' ;
    rdfs:comment 'Foreign key linking to tenant.tenant_contact. Business justification: service_request stores tenant_contact_name, tenant_contact_phone, tenant_contact_email as denormalized plain columns. A proper FK to tenant_contact enforces referential integrity, eliminates data dupl' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TenantContact .

ind:acknowledgedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledged Timestamp' ;
    rdfs:comment 'Date and time when the property management team or assigned technician formally acknowledged receipt of the service request. Used to measure SLA response time compliance.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'Actual cost incurred to fulfill the service request upon completion, in the local operating currency. Populated from work order actuals or vendor invoice. Used for CAM reconciliation, OPEX/CAPEX reporting, and budget variance analysis.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:camChargeable rdf:type rdf:Property ;
    rdfs:label 'Cam Chargeable' ;
    rdfs:comment 'Indicates whether the cost of fulfilling this service request is eligible for CAM charge-back to the tenant under the terms of their lease (True = CAM chargeable). Drives accounts receivable and CAM reconciliation processes.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Date and time when the service request was formally closed after tenant confirmation or automatic closure policy. May differ from resolved_timestamp if a tenant sign-off or satisfaction confirmation period applies.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recurrenceFlag rdf:type rdf:Property ;
    rdfs:label 'Recurrence Flag' ;
    rdfs:comment 'Indicates whether this service request is a recurrence of a previously reported issue at the same location or for the same asset (True = recurring issue). Supports root cause analysis, asset lifecycle decisions, and preventive maintenance program adjustments.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestCategory rdf:type rdf:Property ;
    rdfs:label 'Request Category' ;
    rdfs:comment 'Primary classification of the service request by building system or trade (e.g., HVAC, plumbing, electrical, janitorial, access control). Drives routing to the appropriate technician or vendor and supports CAM charge-back categorization. [ENUM-REF-CANDIDATE: HVAC|plumbing|electrical|janitorial|access|structural|elevator|fire_safety|pest_control|general — promote to reference product]' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestDescription rdf:type rdf:Property ;
    rdfs:label 'Request Description' ;
    rdfs:comment 'Free-text narrative provided by the tenant describing the issue, fault, or service needed. Captures the tenant\'s own words for context and is used by technicians to prepare for the job.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Externally visible, human-readable reference number assigned to the service request at submission (e.g., SR-2024-000123). Used by tenants and property management staff to track and reference the request across communications and portals.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current lifecycle status of the service request workflow. Tracks progression from tenant submission through resolution and closure. [ENUM-REF-CANDIDATE: submitted|acknowledged|in_progress|on_hold|resolved|closed|cancelled — promote to reference product]' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestSubcategory rdf:type rdf:Property ;
    rdfs:label 'Request Subcategory' ;
    rdfs:comment 'Secondary classification providing more granular detail within the request category (e.g., within HVAC: thermostat, air handler, ductwork; within plumbing: leak, drain, fixture). Supports detailed maintenance analytics and vendor specialization routing.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolved Timestamp' ;
    rdfs:comment 'Date and time when the service request issue was fully resolved and the work was completed. Used to calculate actual resolution time against SLA resolution target.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaResolutionBreached rdf:type rdf:Property ;
    rdfs:label 'Sla Resolution Breached' ;
    rdfs:comment 'Indicates whether the SLA resolution target was breached for this service request (True = breach occurred). Populated at closure. Supports SLA compliance reporting and potential lease penalty calculations.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaResolutionTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Resolution Target Hours' ;
    rdfs:comment 'The contracted or policy-defined maximum number of hours within which the service request must be fully resolved, based on urgency level and lease SLA terms. Distinct from response target — this measures full closure.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaResponseBreached rdf:type rdf:Property ;
    rdfs:label 'Sla Response Breached' ;
    rdfs:comment 'Indicates whether the SLA response target was breached for this service request (True = breach occurred). Populated at acknowledgement or closure. Supports SLA compliance reporting and tenant relationship management.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionChannel rdf:type rdf:Property ;
    rdfs:label 'Submission Channel' ;
    rdfs:comment 'The channel or interface through which the tenant submitted the service request (e.g., tenant portal, mobile app, help desk call, email). Supports channel analytics and tenant engagement reporting.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted Timestamp' ;
    rdfs:comment 'Date and time when the tenant submitted the service request through the portal, help desk, or mobile app. This is the principal business event timestamp and the anchor for all SLA calculations.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tenantFeedbackNotes rdf:type rdf:Property ;
    rdfs:label 'Tenant Feedback Notes' ;
    rdfs:comment 'Free-text comments provided by the tenant in the post-resolution satisfaction survey. Captures qualitative feedback for property management quality improvement and tenant retention analysis.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenantSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Tenant Satisfaction Score' ;
    rdfs:comment 'Numeric satisfaction rating provided by the tenant upon closure of the service request, typically on a 1–5 or 1–10 scale. Supports tenant relationship management KPIs and property management performance reviews.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:urgencyLevel rdf:type rdf:Property ;
    rdfs:label 'Urgency Level' ;
    rdfs:comment 'Tenant-declared or property-manager-assessed urgency of the service request. Determines SLA tier assignment and dispatch prioritization. Emergency requests may trigger immediate vendor dispatch and OSHA safety protocols.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderCount rdf:type rdf:Property ;
    rdfs:label 'Work Order Count' ;
    rdfs:comment 'Number of work orders spawned from this service request. A single service request may generate multiple work orders for different trades or vendors. Supports complexity analysis and operational reporting.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Work Started Timestamp' ;
    rdfs:comment 'Date and time when physical work or active remediation on the service request commenced. Marks the transition from dispatched/acknowledged to in-progress status.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceGreenCertificationId rdf:type rdf:Property ;
    rdfs:label 'Compliance Green Certification Id' ;
    rdfs:comment 'Foreign key linking to compliance.green_certification. Business justification: LEED O+M and BREEAM In-Use certifications require specific maintenance protocols (filter changes, commissioning, water treatment). Sustainability managers link PM schedules to the green certification ' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GreenCertification .

ind:contractorId rdf:type rdf:Property ;
    rdfs:label 'Contractor Id' ;
    rdfs:comment 'Reference to the contracted vendor or service provider assigned to execute this PM schedule. Used for vendor dispatch, service contract linkage, and AP processing.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contractor .

ind:primaryPmAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Pm Asset Id' ;
    rdfs:comment 'Reference to the building asset or equipment item this PM schedule governs (e.g., HVAC unit, elevator, fire panel, generator). Links to the asset master in the Fixed Assets or CMMS system.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:advanceNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Advance Notice Days' ;
    rdfs:comment 'Number of days before the next_due_date that the CMMS should generate the work order or send a notification alert. Allows time for parts procurement, vendor scheduling, and tenant notification.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetSystemType rdf:type rdf:Property ;
    rdfs:label 'Asset System Type' ;
    rdfs:comment 'Classification of the building system or equipment category this PM schedule covers (e.g., HVAC, Electrical, Plumbing, Fire & Life Safety, Elevator, BMS, Generator, Roofing). Supports portfolio-level maintenance analytics. [ENUM-REF-CANDIDATE: HVAC|Electrical|Plumbing|Fire & Life Safety|Elevator|BMS|Generator|Roofing|Structural — promote to reference product]' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breeamRelevant rdf:type rdf:Property ;
    rdfs:label 'Breeam Relevant' ;
    rdfs:comment 'Indicates whether this PM schedule contributes to BREEAM certification maintenance for the property. Supports international green building compliance tracking alongside LEED.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Indicates whether this PM schedule is mandated by a regulatory, safety, or warranty compliance requirement (OSHA, HSE, LEED, manufacturer warranty). True = compliance-driven; False = discretionary maintenance.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costClassification rdf:type rdf:Property ;
    rdfs:label 'Cost Classification' ;
    rdfs:comment 'Accounting classification of the maintenance activity as CAPEX (capital expenditure — extends asset life or adds value) or OPEX (operating expenditure — routine maintenance). Critical for financial reporting, GL coding, and REIT compliance.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'The date on which this PM schedule expires or is decommissioned. Null for open-ended schedules. Used to sunset PM programs when assets are retired or service contracts expire.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'The date from which this PM schedule becomes active and begins generating work orders. Typically aligned with asset commissioning date, lease commencement, or service contract start.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:esgCategory rdf:type rdf:Property ;
    rdfs:label 'Esg Category' ;
    rdfs:comment 'ESG classification of the PM activity indicating its environmental impact category. Used for sustainability reporting, LEED compliance, and GRESB (Global Real Estate Sustainability Benchmark) submissions.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedLaborCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Labor Cost' ;
    rdfs:comment 'Estimated cost of labor per PM execution in the local currency. Used for OPEX budgeting, CAPEX vs. OPEX classification, and service contract benchmarking.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedLaborHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Labor Hours' ;
    rdfs:comment 'Estimated number of labor hours required to complete one execution of this PM task. Used for workforce scheduling, OPEX budgeting, and service contract cost estimation.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedPartsCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Parts Cost' ;
    rdfs:comment 'Estimated cost of materials and replacement parts required per PM execution. Used for OPEX/CAPEX budgeting and procurement planning.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frequencyInterval rdf:type rdf:Property ;
    rdfs:label 'Frequency Interval' ;
    rdfs:comment 'Numeric multiplier applied to the frequency_type to define the exact recurrence (e.g., frequency_type=\'weekly\' with frequency_interval=2 means every 2 weeks). Allows sub-type granularity beyond standard frequency buckets.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyType rdf:type rdf:Property ;
    rdfs:label 'Frequency Type' ;
    rdfs:comment 'Recurrence interval for the PM schedule defining how often the maintenance task must be performed. Drives automated work order generation cadence in the CMMS.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Inspection Required' ;
    rdfs:comment 'Indicates whether a formal inspection report or third-party certification is required upon completion of this PM task (e.g., elevator annual inspection certificate, fire suppression test report).' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Last Completed Date' ;
    rdfs:comment 'The most recent date on which the PM task was fully executed and closed. Used to calculate next_due_date and to assess compliance with the maintenance schedule.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leedRequired rdf:type rdf:Property ;
    rdfs:label 'Leed Required' ;
    rdfs:comment 'Indicates whether this PM task is required to maintain LEED certification for the property. Supports ESG reporting and green building compliance tracking.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationDescription rdf:type rdf:Property ;
    rdfs:label 'Location Description' ;
    rdfs:comment 'Detailed physical location description of the asset within the building (e.g., \'Mechanical Room 3B, East Wall\', \'Rooftop AHU-7 adjacent to cooling tower\'). Aids technician dispatch and asset identification.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Due Date' ;
    rdfs:comment 'The next calendar date on which a work order must be generated and the PM task executed. Recalculated automatically after each completion. Critical for scheduling and compliance tracking.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oshaRequired rdf:type rdf:Property ;
    rdfs:label 'Osha Required' ;
    rdfs:comment 'Indicates whether this PM task is specifically required under OSHA regulations (e.g., lockout/tagout, confined space, fire suppression). Drives safety compliance reporting and audit trails.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredPartsList rdf:type rdf:Property ;
    rdfs:label 'Required Parts List' ;
    rdfs:comment 'Comma-separated list or description of parts, materials, and consumables required to execute this PM task (e.g., \'MERV-13 filter 20x20x2, belt drive V-belt, lubricant grease\'). Used for inventory pre-staging and procurement.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleName rdf:type rdf:Property ;
    rdfs:label 'Schedule Name' ;
    rdfs:comment 'Human-readable name or title of the PM schedule (e.g., \'Annual HVAC Filter Replacement – Tower A\', \'Monthly Fire Suppression Inspection\'). Used for display in CMMS dashboards and reporting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the PM schedule, used in work order generation, vendor communications, and CMMS references. Sourced from Building Engines PM module.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle state of the PM schedule. \'active\' means the schedule is generating work orders; \'suspended\' means temporarily paused (e.g., asset offline); \'archived\' means decommissioned.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskChecklistTemplate rdf:type rdf:Property ;
    rdfs:label 'Task Checklist Template' ;
    rdfs:comment 'Name or code reference to the standardized task checklist template used for this PM schedule. The template defines the step-by-step inspection and maintenance procedures to be followed during execution.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskDescription rdf:type rdf:Property ;
    rdfs:label 'Task Description' ;
    rdfs:comment 'Detailed narrative description of the maintenance work to be performed under this PM schedule. Includes scope of work, inspection points, and any special instructions for the assigned technician or vendor.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyRequired rdf:type rdf:Property ;
    rdfs:label 'Warranty Required' ;
    rdfs:comment 'Indicates whether this PM task is required to maintain the manufacturer\'s equipment warranty. Failure to execute may void warranty coverage and expose the organization to uninsured repair costs.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workOrderAutoGenerate rdf:type rdf:Property ;
    rdfs:label 'Work Order Auto Generate' ;
    rdfs:comment 'Indicates whether the CMMS should automatically generate a work order when the next_due_date is reached. If False, a facilities manager must manually trigger work order creation.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:constructionTypeId rdf:type rdf:Property ;
    rdfs:label 'Construction Type Id' ;
    rdfs:comment 'Foreign key linking to reference.construction_type. Business justification: Building assets (structural systems, envelope components, fire suppression) are classified by construction type for insurance rating, fire resistance compliance, and replacement cost estimation. Insur' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConstructionType .

ind:fixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Fixed Asset Id' ;
    rdfs:comment 'Foreign key linking to finance.fixed_asset. Business justification: Every capitalized building asset has a corresponding fixed asset record for depreciation and book value tracking. RE asset managers require the physical-to-financial asset link for depreciation schedu' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:assetCategory rdf:type rdf:Property ;
    rdfs:label 'Asset Category' ;
    rdfs:comment 'High-level classification grouping of the asset type used for portfolio-level O&M reporting and CAPEX planning (e.g., HVAC, Electrical, Plumbing, Vertical Transportation, Fire Life Safety, Roofing, Structural, Generator, Building Envelope). [ENUM-REF-CANDIDATE: HVAC|Electrical|Plumbing|Vertical Transportation|Fire Life Safety|Roofing|Structural|Generator|Building Envelope|Other — promote to reference product]' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetCriticality rdf:type rdf:Property ;
    rdfs:label 'Asset Criticality' ;
    rdfs:comment 'Business criticality classification of the asset based on its impact on building operations, tenant services, and life safety if it fails. \'critical\' = life safety or total building operations impact; \'high\' = major tenant disruption; \'medium\' = partial service impact; \'low\' = minimal operational impact. Drives work order priority and PM frequency.' ;
    rdfs:domain ind:BuildingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Status' ;
    rdfs:comment 'Current operational lifecycle status of the asset. \'active\' = in normal service; \'inactive\' = temporarily out of service; \'decommissioned\' = permanently removed; \'under_repair\' = currently being serviced; \'pending_replacement\' = approved for capital replacement.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTag rdf:type rdf:Property ;
    rdfs:label 'Asset Tag' ;
    rdfs:comment 'Externally-visible physical label or barcode affixed to the asset for field identification during inspections, work orders, and preventive maintenance rounds. Unique within a property. Sourced from Building Engines asset registry.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetType rdf:type rdf:Property ;
    rdfs:label 'Asset Type' ;
    rdfs:comment 'Specific equipment type within the asset category (e.g., \'Air Handling Unit\', \'Chiller\', \'Boiler\', \'Fire Suppression Sprinkler System\', \'Hydraulic Elevator\', \'Standby Generator\'). Drives preventive maintenance task templates in Building Engines. [ENUM-REF-CANDIDATE: promote to reference product given high cardinality]' ;
    rdfs:domain ind:BuildingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bimReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Bim Reference Code' ;
    rdfs:comment 'Unique object identifier linking this asset to its corresponding component in the Building Information Modeling (BIM) model (e.g., Revit GUID or IFC GlobalId). Enables spatial visualization, clash detection, and digital twin integration.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionRating rdf:type rdf:Property ;
    rdfs:label 'Condition Rating' ;
    rdfs:comment 'Current physical condition rating of the asset as assessed during the most recent condition assessment. Drives prioritization of CAPEX replacement and preventive maintenance frequency. Scale: excellent=new/like-new; good=minor wear; fair=moderate wear; poor=significant deterioration; critical=imminent failure risk.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method' ;
    rdfs:comment 'Accounting depreciation method applied to this asset for financial reporting purposes. \'straight_line\' is most common for real estate equipment. Aligns with Yardi Voyager Fixed Assets and SAP S/4HANA asset accounting configuration.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energyEfficiencyRating rdf:type rdf:Property ;
    rdfs:label 'Energy Efficiency Rating' ;
    rdfs:comment 'Manufacturer-specified energy efficiency rating or metric for the asset (e.g., SEER rating for HVAC, EER, COP, kW/ton). Null if not applicable. Used for ESG reporting, LEED documentation, and energy benchmarking under EPA ENERGY STAR.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energyRated rdf:type rdf:Property ;
    rdfs:label 'Energy Rated' ;
    rdfs:comment 'Indicates whether this asset has an energy efficiency rating or certification (e.g., ENERGY STAR, LEED-qualifying equipment). Supports ESG reporting, LEED certification tracking, and sustainability benchmarking.' ;
    rdfs:domain ind:BuildingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extendedWarrantyExpiry rdf:type rdf:Property ;
    rdfs:label 'Extended Warranty Expiry' ;
    rdfs:comment 'Date on which any purchased extended warranty coverage expires. Null if no extended warranty is in place. Used alongside manufacturer warranty to determine warranty claim eligibility for repair work orders.' ;
    rdfs:domain ind:BuildingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date the asset was physically installed and commissioned at the property. Anchors useful life calculations, warranty start dates, and CAPEX replacement year projections.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isTenantOwned rdf:type rdf:Property ;
    rdfs:label 'Is Tenant Owned' ;
    rdfs:comment 'Indicates whether the asset is owned by a tenant rather than the property owner. Tenant-owned assets are tracked for maintenance coordination but excluded from owner CAPEX planning and depreciation schedules. Relevant for Tenant Improvement (TI) assets.' ;
    rdfs:domain ind:BuildingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborWarrantyExpiry rdf:type rdf:Property ;
    rdfs:label 'Labor Warranty Expiry' ;
    rdfs:comment 'Date on which the installation contractor\'s labor warranty expires. Covers defects in workmanship separate from equipment manufacturer warranty. Null if no labor warranty applies.' ;
    rdfs:domain ind:BuildingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastConditionAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Condition Assessment Date' ;
    rdfs:comment 'Date of the most recent formal property condition assessment (PCA) or engineering inspection that produced the current condition rating. Indicates data freshness for capital planning purposes.' ;
    rdfs:domain ind:BuildingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPmDate rdf:type rdf:Property ;
    rdfs:label 'Last Pm Date' ;
    rdfs:comment 'Date the most recent preventive maintenance (PM) service was completed on this asset. Used to calculate next scheduled PM date and identify overdue maintenance items.' ;
    rdfs:domain ind:BuildingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRegulatoryInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Regulatory Inspection Date' ;
    rdfs:comment 'Date of the most recent mandatory regulatory inspection or certification for this asset. Null if regulatory_inspection_required is false. Used for compliance reporting and COO maintenance.' ;
    rdfs:domain ind:BuildingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastWarrantyClaimDate rdf:type rdf:Property ;
    rdfs:label 'Last Warranty Claim Date' ;
    rdfs:comment 'Date of the most recent warranty claim submitted for this asset. Null if no warranty claims have been filed. Used to track warranty utilization and vendor responsiveness.' ;
    rdfs:domain ind:BuildingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturer rdf:type rdf:Property ;
    rdfs:label 'Manufacturer' ;
    rdfs:comment 'Name of the original equipment manufacturer (OEM) of the asset. Used for warranty claims, spare parts procurement, and vendor dispatch coordination.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerWarrantyExpiry rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Warranty Expiry' ;
    rdfs:comment 'Date on which the original equipment manufacturer (OEM) warranty expires. After this date, repair costs are no longer recoverable from the manufacturer. Critical for work order cost routing decisions.' ;
    rdfs:domain ind:BuildingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modelNumber rdf:type rdf:Property ;
    rdfs:label 'Model Number' ;
    rdfs:comment 'Manufacturer-assigned model or part number for the asset. Required for ordering replacement parts, scheduling OEM-certified service, and cross-referencing BIM component libraries.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextPmDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Pm Due Date' ;
    rdfs:comment 'Scheduled due date for the next preventive maintenance (PM) service on this asset, calculated from last PM date and PM schedule frequency. Drives work order scheduling and compliance reporting in Building Engines.' ;
    rdfs:domain ind:BuildingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pmScheduleFrequency rdf:type rdf:Property ;
    rdfs:label 'Pm Schedule Frequency' ;
    rdfs:comment 'Required frequency of preventive maintenance (PM) inspections and servicing for this asset as defined in the O&M program. Drives automated PM work order generation in Building Engines CMMS.' ;
    rdfs:domain ind:BuildingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseCost rdf:type rdf:Property ;
    rdfs:label 'Purchase Cost' ;
    rdfs:comment 'Original acquisition cost of the asset in USD at time of purchase or installation. Used as the cost basis for fixed asset depreciation schedules in Yardi Voyager and SAP S/4HANA Fixed Assets module.' ;
    rdfs:domain ind:BuildingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedReplacementYear rdf:type rdf:Property ;
    rdfs:label 'Recommended Replacement Year' ;
    rdfs:comment 'Calendar year in which the asset is recommended for capital replacement based on condition assessment findings and remaining useful life estimate. Used to populate CAPEX schedules in Argus Enterprise and SAP S/4HANA project systems.' ;
    rdfs:domain ind:BuildingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:refrigerantType rdf:type rdf:Property ;
    rdfs:label 'Refrigerant Type' ;
    rdfs:comment 'Type of refrigerant used in HVAC or cooling equipment (e.g., R-410A, R-22, R-134a, R-32). Null for non-refrigerant assets. Required for EPA Section 608 refrigerant management compliance and ESG greenhouse gas reporting.' ;
    rdfs:domain ind:BuildingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryInspectionExpiry rdf:type rdf:Property ;
    rdfs:label 'Regulatory Inspection Expiry' ;
    rdfs:comment 'Date on which the current regulatory inspection certificate or permit expires. Null if not applicable. Expiry triggers mandatory re-inspection scheduling to maintain compliance and avoid operational shutdowns.' ;
    rdfs:domain ind:BuildingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Inspection Required' ;
    rdfs:comment 'Indicates whether this asset is subject to mandatory regulatory inspection and certification (e.g., elevators, boilers, fire suppression systems, pressure vessels). True triggers compliance tracking and certificate of occupancy (COO) dependencies.' ;
    rdfs:domain ind:BuildingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remainingUsefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Remaining Useful Life Years' ;
    rdfs:comment 'Estimated number of years remaining before the asset requires capital replacement, as determined by the most recent condition assessment. Decimal precision supports mid-year estimates. Key input for CAPEX reserve modeling and Argus Enterprise cash flow projections.' ;
    rdfs:domain ind:BuildingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replacementCost rdf:type rdf:Property ;
    rdfs:label 'Replacement Cost' ;
    rdfs:comment 'Current estimated cost in USD to replace the asset with a new equivalent unit, inclusive of equipment, labor, and installation. Used for CAPEX budgeting, insurance valuation, and reserve fund analysis. Expressed in base currency (USD).' ;
    rdfs:domain ind:BuildingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roomOrZone rdf:type rdf:Property ;
    rdfs:label 'Room Or Zone' ;
    rdfs:comment 'Specific room number, mechanical room designation, or building zone where the asset is installed (e.g., \'MER-301\', \'Penthouse Mechanical\', \'Zone A West Wing\'). Supports precise technician navigation and BIM spatial coordination.' ;
    rdfs:domain ind:BuildingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Manufacturer-assigned unique serial number for the specific asset unit. Required for warranty registration, insurance claims, and regulatory compliance inspections (e.g., elevator certificates, boiler permits).' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'Manufacturer or engineering-estimated useful life of the asset in years from installation date. Used for depreciation schedules (FASB ASC 360), CAPEX reserve planning, and remaining useful life calculations.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyClaimCount rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Count' ;
    rdfs:comment 'Total number of warranty claims filed against any warranty (manufacturer, extended, or labor) for this asset since installation. Indicates reliability history and supports vendor performance evaluation.' ;
    rdfs:domain ind:BuildingAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorDispatchId rdf:type rdf:Property ;
    rdfs:label 'Vendor Dispatch Id' ;
    rdfs:comment 'Unique system-generated identifier for each vendor dispatch record. Primary key for the vendor_dispatch data product in the maintenance domain.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorDispatch .

ind:actualArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Timestamp' ;
    rdfs:comment 'Date and time the vendor technician physically arrived on-site at the property. Compared against estimated arrival window to measure SLA on-time arrival performance.' ;
    rdfs:domain ind:VendorDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualCostAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Amount' ;
    rdfs:comment 'Actual invoiced or confirmed cost of the vendor dispatch upon completion. Compared against estimated cost for budget variance reporting and vendor cost performance analysis.' ;
    rdfs:domain ind:VendorDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Timestamp' ;
    rdfs:comment 'Date and time the vendor technician departed the property after completing or suspending work. Used to calculate on-site duration and supports OSHA site safety records.' ;
    rdfs:domain ind:VendorDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:buildingAccessRequired rdf:type rdf:Property ;
    rdfs:label 'Building Access Required' ;
    rdfs:comment 'Indicates whether the vendor requires escorted or key-controlled building access to perform the work. Drives property operations coordination and tenant notification requirements.' ;
    rdfs:domain ind:VendorDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'Date and time at which the vendor confirmed all work was completed and the dispatch was closed. Used for SLA resolution-time measurement and work order closure workflow.' ;
    rdfs:domain ind:VendorDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispatchNumber rdf:type rdf:Property ;
    rdfs:label 'Dispatch Number' ;
    rdfs:comment 'Externally-visible, human-readable dispatch reference number used in vendor communications, purchase orders, and invoice matching. Format: DSP-YYYY-NNNNNN.' ;
    rdfs:domain ind:VendorDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Dispatch Sequence Number' ;
    rdfs:comment 'Sequential number of this dispatch within the parent work order (e.g., 1 for initial visit, 2 for return visit). Supports multi-trade coordination tracking and return visit analysis.' ;
    rdfs:domain ind:VendorDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispatchStatus rdf:type rdf:Property ;
    rdfs:label 'Dispatch Status' ;
    rdfs:comment 'Current lifecycle state of the vendor dispatch. Tracks progression from initial dispatch through on-site work completion or cancellation. Used for SLA monitoring and vendor performance reporting.' ;
    rdfs:domain ind:VendorDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispatch Timestamp' ;
    rdfs:comment 'Date and time at which the vendor or contractor was formally dispatched to the property. Serves as the principal business event timestamp for SLA response-time measurement.' ;
    rdfs:domain ind:VendorDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedArrivalEnd rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival End' ;
    rdfs:comment 'End of the estimated arrival window communicated to the property manager and tenant at time of dispatch. Together with estimated_arrival_start defines the committed arrival window for SLA tracking.' ;
    rdfs:domain ind:VendorDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedArrivalStart rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Start' ;
    rdfs:comment 'Start of the estimated arrival window communicated to the property manager and tenant at time of dispatch. Used for SLA compliance measurement and tenant communication.' ;
    rdfs:domain ind:VendorDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Amount' ;
    rdfs:comment 'Estimated cost of the vendor dispatch at time of scheduling, in the property\'s operating currency. Used for budget variance analysis and OPEX/CAPEX forecasting.' ;
    rdfs:domain ind:VendorDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCamBillable rdf:type rdf:Property ;
    rdfs:label 'Is Cam Billable' ;
    rdfs:comment 'Indicates whether the cost of this dispatch is billable to tenants as part of CAM (Common Area Maintenance) reconciliation under NNN (Triple Net Lease) or gross lease structures.' ;
    rdfs:domain ind:VendorDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReturnVisit rdf:type rdf:Property ;
    rdfs:label 'Is Return Visit' ;
    rdfs:comment 'Indicates whether this dispatch is a return visit to address incomplete or unsatisfactory work from a prior dispatch on the same work order. Used for vendor quality and rework rate analysis.' ;
    rdfs:domain ind:VendorDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partsUsedDescription rdf:type rdf:Property ;
    rdfs:label 'Parts Used Description' ;
    rdfs:comment 'Description of parts, materials, or consumables used during the dispatch. Supports CAPEX vs. OPEX classification, warranty tracking, and invoice reconciliation.' ;
    rdfs:domain ind:VendorDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'Calendar date on which the vendor dispatch is scheduled to occur. Used for day-level planning, preventive maintenance scheduling, and property operations calendaring.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceCategory rdf:type rdf:Property ;
    rdfs:label 'Service Category' ;
    rdfs:comment 'High-level classification of the maintenance service type. Drives CAPEX vs. OPEX accounting treatment and CAM (Common Area Maintenance) billability determination. Preventive and corrective map to OPEX; capital improvement maps to CAPEX.' ;
    rdfs:domain ind:VendorDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signoffStatus rdf:type rdf:Property ;
    rdfs:label 'Signoff Status' ;
    rdfs:comment 'Status of the work completion sign-off by the property manager or authorized representative. Required for invoice approval and work order closure. Disputed status triggers a return visit or escalation.' ;
    rdfs:domain ind:VendorDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Signoff Timestamp' ;
    rdfs:comment 'Date and time at which the authorized representative signed off on the completed dispatch work. Triggers invoice approval workflow and work order closure in Building Engines.' ;
    rdfs:domain ind:VendorDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaResolutionMet rdf:type rdf:Property ;
    rdfs:label 'Sla Resolution Met' ;
    rdfs:comment 'Indicates whether the vendor met the contracted SLA resolution time target (work completed within sla_resolution_target_hours of dispatch). Populated upon dispatch completion. Drives vendor performance scorecarding.' ;
    rdfs:domain ind:VendorDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaResponseMet rdf:type rdf:Property ;
    rdfs:label 'Sla Response Met' ;
    rdfs:comment 'Indicates whether the vendor met the contracted SLA response time target (arrival within sla_response_target_hours of dispatch). Populated upon actual arrival. Drives vendor performance KPI reporting.' ;
    rdfs:domain ind:VendorDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tenantNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Tenant Notification Required' ;
    rdfs:comment 'Indicates whether the tenant must be notified prior to the vendor accessing the leased premises. Driven by lease terms, building rules, and tenant service request origin.' ;
    rdfs:domain ind:VendorDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradeType rdf:type rdf:Property ;
    rdfs:label 'Trade Type' ;
    rdfs:comment 'Classification of the trade or technical discipline of the dispatched vendor (e.g., HVAC, plumbing, electrical, elevator, janitorial, roofing, fire safety). Used for multi-trade coordination and CAPEX vs. OPEX classification. [ENUM-REF-CANDIDATE: hvac|plumbing|electrical|elevator|fire_safety|roofing|janitorial|structural|landscaping|pest_control — promote to reference product]' ;
    rdfs:domain ind:VendorDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContactName rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Name' ;
    rdfs:comment 'Full name of the individual technician or field representative dispatched on behalf of the vendor. Used for on-site sign-off and OSHA safety compliance records.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContactPhone rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Phone' ;
    rdfs:comment 'Mobile or direct phone number of the dispatched technician or vendor representative for on-site coordination and emergency contact.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'Legal or trade name of the vendor or contractor dispatched. Captured at dispatch time for historical accuracy independent of vendor master updates.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPerformedSummary rdf:type rdf:Property ;
    rdfs:label 'Work Performed Summary' ;
    rdfs:comment 'Free-text narrative description of the work performed by the vendor during this dispatch. Captured by the technician or property manager at completion. Supports maintenance history, asset condition tracking, and audit documentation.' ;
    rdfs:domain ind:VendorDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Geographic Hierarchy Id' ;
    rdfs:comment 'Foreign key linking to reference.geographic_hierarchy. Business justification: Multi-property service contracts (flagged by multi_property_flag) are scoped to geographic markets — e.g., a janitorial contract covering all properties in a metro submarket. Procurement teams negotia' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeographicHierarchy .

ind:annualContractValue rdf:type rdf:Property ;
    rdfs:label 'Annual Contract Value' ;
    rdfs:comment 'Total annualized monetary value of the service contract in the operating currency. Used for OPEX/CAPEX budgeting, vendor spend analytics, and portfolio-level O&M cost reporting. Expressed in the property\'s functional currency.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether this contract automatically renews at expiration unless notice of termination is provided within the required notice period. Critical for contract management and avoiding unintended renewals.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:buildingEnginesContractCode rdf:type rdf:Property ;
    rdfs:label 'Building Engines Contract Code' ;
    rdfs:comment 'Source system identifier for this contract record in Building Engines CMMS. Used for data lineage, ETL reconciliation, and bi-directional sync between the lakehouse silver layer and the operational system.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commencementDate rdf:type rdf:Property ;
    rdfs:label 'Commencement Date' ;
    rdfs:comment 'The date on which the service contract becomes effective and the vendor is authorized to begin providing services. Aligns with FASB ASC 842 and IFRS 16 contract start date concepts for service agreement accounting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Contract Document Url' ;
    rdfs:comment 'Secure URL or document management system path to the fully executed contract document. Provides direct access to the contract for legal review, audit, and compliance purposes.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractName rdf:type rdf:Property ;
    rdfs:label 'Contract Name' ;
    rdfs:comment 'Descriptive name of the service contract (e.g., \'Annual HVAC Maintenance Agreement — Tower A\', \'Janitorial Services Contract — Portfolio Wide\'). Used for display and search in Building Engines and Yardi.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNotes rdf:type rdf:Property ;
    rdfs:label 'Contract Notes' ;
    rdfs:comment 'Free-text field for operational notes, special conditions, exceptions, or amendments not captured in structured fields. Used by property managers and asset managers for contract administration context.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Externally-known, human-readable contract reference number assigned at execution. Used for vendor correspondence, purchase orders, and audit trails. Sourced from DocuSign CLM or Building Engines contract module.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle state of the service contract. Drives operational workflows: active contracts authorize vendor dispatch; expired/terminated contracts block new work orders against this contract.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Classification of the service contract by the type of facility service covered. Drives routing to the appropriate operations team and CAPEX/OPEX classification rules. [ENUM-REF-CANDIDATE: hvac|elevator|janitorial|landscaping|pest_control|security|fire_life_safety|plumbing|electrical|roofing|general_maintenance|other — promote to reference product]' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgSustainabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Esg Sustainability Flag' ;
    rdfs:comment 'Indicates whether this contract includes ESG or green building sustainability requirements (e.g., use of eco-friendly cleaning products, LEED-compliant HVAC maintenance practices, EPA-compliant pest control methods).' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Expiration Date' ;
    rdfs:comment 'Expiration date of the vendor\'s current certificate of insurance (COI) on file. Triggers compliance alerts when insurance is approaching expiration to prevent lapsed coverage during active contract period.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceLiabilityLimit rdf:type rdf:Property ;
    rdfs:label 'Insurance Liability Limit' ;
    rdfs:comment 'Minimum required general liability insurance coverage amount (in contract currency) that the vendor must maintain throughout the contract term. Used for risk management and compliance verification.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Required Flag' ;
    rdfs:comment 'Indicates whether the vendor is contractually required to provide a certificate of insurance (COI) as a condition of performing services. Supports OSHA compliance and risk management workflows.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to this service contract record. Used for change data capture (CDC) in the Databricks lakehouse silver layer pipeline and SOX audit trail.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lienWaiverRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Lien Waiver Required Flag' ;
    rdfs:comment 'Indicates whether the vendor must provide a lien waiver upon payment as a condition of this contract. Relevant for CAPEX-classified contracts and construction-adjacent maintenance work to protect property title.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:multiPropertyFlag rdf:type rdf:Property ;
    rdfs:label 'Multi Property Flag' ;
    rdfs:comment 'Indicates whether this service contract covers multiple properties in the portfolio (e.g., a portfolio-wide janitorial contract). When true, additional covered properties are tracked in a separate association table.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oshaComplianceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Osha Compliance Required Flag' ;
    rdfs:comment 'Indicates whether the vendor must comply with specific OSHA safety standards as a condition of this contract (e.g., confined space entry, lockout/tagout, fall protection). Drives safety documentation requirements in Building Engines.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Payment Frequency' ;
    rdfs:comment 'Frequency at which the vendor invoices and payment is due under the contract terms. Drives AP (Accounts Payable) accrual schedules in Yardi Voyager and SAP S/4HANA.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceBondRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Required Flag' ;
    rdfs:comment 'Indicates whether the vendor is required to provide a performance bond guaranteeing contract completion. Typically required for high-value CAPEX contracts or critical building systems.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preventiveMaintenanceFrequency rdf:type rdf:Property ;
    rdfs:label 'Preventive Maintenance Frequency' ;
    rdfs:comment 'Scheduled frequency of preventive maintenance visits or inspections required under this contract. Drives PM schedule generation in Building Engines CMMS and supports OSHA and equipment warranty compliance.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceScopeDescription rdf:type rdf:Property ;
    rdfs:label 'Service Scope Description' ;
    rdfs:comment 'Detailed narrative description of the services covered under this contract, including specific equipment, systems, buildings, or areas included. Defines the scope of work (SOW) for vendor dispatch and work order validation in Building Engines.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResolutionTimeHours rdf:type rdf:Property ;
    rdfs:label 'Sla Resolution Time Hours' ;
    rdfs:comment 'Contractually committed maximum time in hours from service request submission to full resolution and sign-off. Distinct from response time — measures end-to-end resolution commitment for SLA compliance reporting.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaResponseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Sla Response Time Hours' ;
    rdfs:comment 'Contractually committed maximum response time in hours from service request submission to vendor on-site arrival for emergency or priority calls. Key SLA metric tracked in Building Engines for vendor performance management.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Reason code for early contract termination. Used for vendor performance analytics, procurement strategy, and regulatory compliance reporting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalContractValue rdf:type rdf:Property ;
    rdfs:label 'Total Contract Value' ;
    rdfs:comment 'Total monetary value of the service contract over its full term, including all renewal options if exercised. Used for capital planning, vendor spend management, and CAPEX vs. OPEX threshold analysis.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorContractReference rdf:type rdf:Property ;
    rdfs:label 'Vendor Contract Reference' ;
    rdfs:comment 'The vendor\'s own internal contract or purchase order reference number for this agreement. Enables cross-referencing between the property manager\'s system and the vendor\'s billing system.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventId rdf:type rdf:Property ;
    rdfs:label 'Event Id' ;
    rdfs:comment 'Foreign key linking to marketing.event. Business justification: Pre-event property readiness inspections are conducted before open houses, broker tours, and grand opening events to ensure show-ready condition. Property managers create ops_inspections specifically ' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Event .

ind:primaryOpsPropertyAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Ops Property Asset Id' ;
    rdfs:comment 'Reference to the property at which the inspection was conducted. Links to the property master record in the property domain.' ;
    rdfs:domain ind:OpsInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:tiAllowanceId rdf:type rdf:Property ;
    rdfs:label 'Ti Allowance Id' ;
    rdfs:comment 'Foreign key linking to lease.ti_allowance. Business justification: Post-construction inspections gate TI allowance disbursement milestones. ti_allowance tracks `milestones_completed_count` and `coo_received_date` that depend on inspection sign-off. Property managers ' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TiAllowance .

ind:actualRemediationCost rdf:type rdf:Property ;
    rdfs:label 'Actual Remediation Cost' ;
    rdfs:comment 'Actual total cost incurred to remediate all deficiencies identified in this inspection, recorded upon completion of corrective work orders. Compared against estimated_remediation_cost for budget variance analysis.' ;
    rdfs:domain ind:OpsInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buildingArea rdf:type rdf:Property ;
    rdfs:label 'Building Area' ;
    rdfs:comment 'Specific floor, zone, wing, or common area of the building where the inspection was performed (e.g., \'Floor 3 East Wing\', \'Basement Mechanical Room\', \'Rooftop\'). Supports spatial analysis of deficiency patterns.' ;
    rdfs:domain ind:OpsInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Expiry Date' ;
    rdfs:comment 'Expiration date of the compliance certificate or permit issued as a result of a passed inspection (e.g., elevator operating certificate, fire safety certificate). Null if no certificate is issued.' ;
    rdfs:domain ind:OpsInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cooComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Coo Compliance Flag' ;
    rdfs:comment 'Indicates whether this inspection is required to maintain or renew the Certificate of Occupancy (COO) for the property. True when the inspection is a COO-mandated compliance event.' ;
    rdfs:domain ind:OpsInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalDeficiencyCount rdf:type rdf:Property ;
    rdfs:label 'Critical Deficiency Count' ;
    rdfs:comment 'Number of deficiency findings classified as critical severity — those posing immediate life-safety risk or requiring emergency corrective action. Drives escalation workflows and OSHA reporting obligations.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deficiencyCount rdf:type rdf:Property ;
    rdfs:label 'Deficiency Count' ;
    rdfs:comment 'Total number of individual deficiency findings identified during the inspection across all severity levels. Provides a summary count for compliance dashboards and trend analysis.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:esgRelevantFlag rdf:type rdf:Property ;
    rdfs:label 'Esg Relevant Flag' ;
    rdfs:comment 'Indicates whether this inspection has ESG reporting relevance (e.g., LEED commissioning, BREEAM assessment, EPA environmental compliance inspection). Supports ESG portfolio reporting for REITs and institutional investors.' ;
    rdfs:domain ind:OpsInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedRemediationCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Remediation Cost' ;
    rdfs:comment 'Estimated total cost in the base currency to remediate all deficiencies identified in this inspection. Used for CAPEX/OPEX budgeting and asset lifecycle planning.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectingPartyType rdf:type rdf:Property ;
    rdfs:label 'Inspecting Party Type' ;
    rdfs:comment 'Indicates whether the inspection was conducted by internal facility staff, an external third-party inspection firm, or a government/regulatory authority (e.g., fire marshal, building department).' ;
    rdfs:domain ind:OpsInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Date' ;
    rdfs:comment 'The actual calendar date on which the inspection was conducted. This is the principal real-world business event date for the inspection record.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionEndTime rdf:type rdf:Property ;
    rdfs:label 'Inspection End Time' ;
    rdfs:comment 'Precise date and time when the inspection was concluded on-site. Combined with inspection_start_time to derive inspection duration for O&M analytics.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionFirmName rdf:type rdf:Property ;
    rdfs:label 'Inspection Firm Name' ;
    rdfs:comment 'Name of the third-party inspection company or regulatory agency that conducted the inspection. Null for internal inspections.' ;
    rdfs:domain ind:OpsInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionNotes rdf:type rdf:Property ;
    rdfs:label 'Inspection Notes' ;
    rdfs:comment 'Free-text narrative notes recorded by the inspector or internal reviewer providing additional context, observations, or recommendations not captured in structured fields. Sourced from Building Engines work order comments.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned to the inspection event, sourced from Building Engines or the inspecting authority. Used for cross-referencing with regulatory filings, certificates, and work orders.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionReportRef rdf:type rdf:Property ;
    rdfs:label 'Inspection Report Ref' ;
    rdfs:comment 'Document reference number or URL path to the formal inspection report issued by the inspecting party. Supports document management integration with DocuSign CLM or Building Engines document store.' ;
    rdfs:domain ind:OpsInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionResult rdf:type rdf:Property ;
    rdfs:label 'Inspection Result' ;
    rdfs:comment 'Overall pass/fail outcome of the inspection as determined by the inspecting party. \'Conditional pass\' indicates the property passed subject to minor corrective actions within a defined timeframe.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionScope rdf:type rdf:Property ;
    rdfs:label 'Inspection Scope' ;
    rdfs:comment 'Narrative description of the areas, systems, or equipment covered by the inspection (e.g., \'All fire suppression systems on floors 1-10\', \'Rooftop HVAC units RTU-01 through RTU-06\'). Sourced from Building Engines work order scope.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStartTime rdf:type rdf:Property ;
    rdfs:label 'Inspection Start Time' ;
    rdfs:comment 'Precise date and time when the inspection commenced on-site. Used for duration tracking and scheduling conflict analysis.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Current lifecycle state of the inspection event workflow within Building Engines. Tracks progression from scheduling through completion or cancellation.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionSubtype rdf:type rdf:Property ;
    rdfs:label 'Inspection Subtype' ;
    rdfs:comment 'Further granular classification within the inspection type (e.g., \'Annual Fire Sprinkler Test\', \'Five-Year Elevator Full Load Test\', \'Pre-Occupancy HVAC Commissioning\'). Supports detailed regulatory citation mapping.' ;
    rdfs:domain ind:OpsInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionType rdf:type rdf:Property ;
    rdfs:label 'Inspection Type' ;
    rdfs:comment 'Classification of the inspection category. Covers fire safety inspections, elevator certifications, HVAC commissioning, roof inspections, ADA/accessibility compliance walkthroughs, and workplace safety audits. [ENUM-REF-CANDIDATE: fire_safety|elevator_certification|hvac_commissioning|roof|ada_accessibility|workplace_safety|environmental|plumbing|electrical|general_property — promote to reference product]' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Inspector License Number' ;
    rdfs:comment 'Professional license or certification number of the inspector as issued by the relevant regulatory or licensing authority (e.g., state elevator inspector license, fire protection engineer PE number).' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorName rdf:type rdf:Property ;
    rdfs:label 'Inspector Name' ;
    rdfs:comment 'Full name of the individual inspector or lead inspector who conducted the inspection. May be an internal employee or a licensed third-party inspector.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leedBreeamReference rdf:type rdf:Property ;
    rdfs:label 'Leed Breeam Reference' ;
    rdfs:comment 'Reference code or credit identifier linking this inspection to a specific LEED or BREEAM certification credit or prerequisite (e.g., \'LEED EA Prerequisite 1 — Fundamental Commissioning\'). Null when not ESG-relevant.' ;
    rdfs:domain ind:OpsInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorDeficiencyCount rdf:type rdf:Property ;
    rdfs:label 'Major Deficiency Count' ;
    rdfs:comment 'Number of deficiency findings classified as major severity — significant non-conformances requiring corrective action within a defined regulatory or contractual timeframe.' ;
    rdfs:domain ind:OpsInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorDeficiencyCount rdf:type rdf:Property ;
    rdfs:label 'Minor Deficiency Count' ;
    rdfs:comment 'Number of deficiency findings classified as minor severity — low-risk observations that should be addressed in routine maintenance cycles but do not pose immediate safety or compliance risk.' ;
    rdfs:domain ind:OpsInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due Date' ;
    rdfs:comment 'The date by which the next recurring inspection of this type must be completed to maintain regulatory compliance and Certificate of Occupancy (COO) obligations.' ;
    rdfs:domain ind:OpsInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openDeficiencyCount rdf:type rdf:Property ;
    rdfs:label 'Open Deficiency Count' ;
    rdfs:comment 'Number of deficiency findings from this inspection that remain unresolved (not yet remediated or closed). Key metric for tracking open compliance obligations and COO maintenance.' ;
    rdfs:domain ind:OpsInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oshaReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Osha Reportable Flag' ;
    rdfs:comment 'Indicates whether any findings from this inspection trigger mandatory OSHA reporting obligations (e.g., imminent danger, serious violations under 29 CFR 1910). Drives compliance escalation workflows.' ;
    rdfs:domain ind:OpsInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Date on which the internal reviewer acknowledged and accepted the inspection report and findings. Marks the start of the internal remediation planning cycle.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entitlementId rdf:type rdf:Property ;
    rdfs:label 'Entitlement Id' ;
    rdfs:comment 'Foreign key linking to development.entitlement. Business justification: Significant maintenance CAPEX projects (major additions, change-of-use renovations) require zoning entitlements. Linking capex_project to entitlement enables regulatory compliance tracking and ensures' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Entitlement .

ind:marketResearchId rdf:type rdf:Property ;
    rdfs:label 'Market Research Id' ;
    rdfs:comment 'Foreign key linking to marketing.market_research. Business justification: Capital improvement decisions (amenity additions, building system upgrades) are formally justified by market research identifying competitive gaps. Real-estate asset managers reference specific market' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketResearch .

ind:primaryCapexAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Capex Asset Id' ;
    rdfs:comment 'Reference to the property where the capital project is being executed. Links the CAPEX project to the property master record for portfolio-level CAPEX reporting, NOI impact analysis, and asset register updates.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'Date on which the capital project reached substantial completion and was accepted. Triggers the capitalization process and fixed asset creation in the GL. Compared against planned completion for schedule variance reporting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualSpendToDate rdf:type rdf:Property ;
    rdfs:label 'Actual Spend To Date' ;
    rdfs:comment 'Cumulative actual expenditure incurred on the project to date, sourced from SAP S/4HANA cost collection or Yardi AP postings. Used for budget variance analysis, cash flow forecasting, and CAPEX vs. OPEX classification reporting.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'Date on which project construction or installation activities actually commenced. Compared against planned start date for schedule variance analysis and contractor performance evaluation.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'Level of organizational authority that approved this capital project. Reflects the delegation of authority matrix for CAPEX approvals. Used for SOX controls documentation and audit trail. [ENUM-REF-CANDIDATE: property_manager|asset_manager|vp_operations|cfo|investment_committee|board — promote to reference product]' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Budget Amount' ;
    rdfs:comment 'Board or investment committee approved budget for the capital project in the operating currency. Represents the authorized CAPEX spend ceiling. Used for variance analysis against actual spend and DSCR/LTV covenant compliance reporting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalizationDate rdf:type rdf:Property ;
    rdfs:label 'Capitalization Date' ;
    rdfs:comment 'Date on which the completed project costs were capitalized and transferred to the fixed asset register in the GL. Marks the start of the depreciation schedule. Critical for FASB ASC 360 compliance and balance sheet accuracy.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:changeOrderAmount rdf:type rdf:Property ;
    rdfs:label 'Change Order Amount' ;
    rdfs:comment 'Cumulative value of all approved change orders against the primary construction contract. Added to the original contract value to determine the revised contract sum. Used for budget variance analysis.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeOrderCount rdf:type rdf:Property ;
    rdfs:label 'Change Order Count' ;
    rdfs:comment 'Total number of approved change orders issued against the primary construction contract. Indicates project scope stability and contractor performance. High change order counts may signal design deficiency or scope creep.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:committedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Cost Amount' ;
    rdfs:comment 'Total value of purchase orders and contracts committed but not yet invoiced or paid for this project. Represents financial obligations already incurred. Used in cash flow forecasting and budget-to-complete analysis.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractValueAmount rdf:type rdf:Property ;
    rdfs:label 'Contract Value Amount' ;
    rdfs:comment 'Total contracted value with the primary general contractor for execution of the capital project. May differ from approved budget due to contingency reserves or owner-direct procurement. Used for commitment tracking and lien exposure management.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cooIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Coo Issued Date' ;
    rdfs:comment 'Date on which the Certificate of Occupancy (COO) was issued by the relevant authority, confirming the completed improvement meets all building code and safety requirements. Required before tenant occupancy and asset capitalization.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:erpProjectCode rdf:type rdf:Property ;
    rdfs:label 'Erp Project Code' ;
    rdfs:comment 'Project code assigned in SAP S/4HANA Project Systems (PS module) for cost collection, procurement integration, and financial consolidation. Used to reconcile CAPEX spend between the maintenance CMMS and the ERP general ledger.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingSource rdf:type rdf:Property ;
    rdfs:label 'Funding Source' ;
    rdfs:comment 'Source of funds financing the capital project. Determines accounting treatment, loan covenant implications, and investor reporting requirements. Insurance proceeds and tenant reimbursements have distinct revenue recognition rules. [ENUM-REF-CANDIDATE: operating_reserves|debt_financing|equity_contribution|insurance_proceeds|tenant_reimbursement|government_grant|refinancing_proceeds — promote to reference product]' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEsgInitiative rdf:type rdf:Property ;
    rdfs:label 'Is Esg Initiative' ;
    rdfs:comment 'Indicates whether this capital project is classified as an ESG initiative (e.g., LEED certification upgrade, BREEAM improvement, energy efficiency retrofit, EV charging installation). Supports ESG portfolio reporting and green financing eligibility.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTenantImprovement rdf:type rdf:Property ;
    rdfs:label 'Is Tenant Improvement' ;
    rdfs:comment 'Indicates whether this capital project constitutes a Tenant Improvement (TI) as defined under ASC 842 or IFRS 16. TI projects have distinct lease accounting treatment, amortization rules, and may be partially reimbursed by tenants.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leedCertificationTarget rdf:type rdf:Property ;
    rdfs:label 'Leed Certification Target' ;
    rdfs:comment 'Target LEED certification level sought for this capital project, if applicable. Relevant for green building upgrades and ESG-linked financing. Null or \'none\' if LEED certification is not a project objective.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Osha Compliance Required' ;
    rdfs:comment 'Indicates whether this capital project has mandatory OSHA safety compliance requirements (e.g., asbestos abatement, fall protection systems, electrical safety upgrades). Triggers safety inspection and documentation workflows.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Completion Date' ;
    rdfs:comment 'Originally scheduled date for substantial completion of the capital project. Used for tenant coordination, COO applications, and fixed asset capitalization planning.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'Originally scheduled start date for project construction or installation activities. Used for project scheduling, contractor mobilization planning, and tenant disruption coordination.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:procoreProjectCode rdf:type rdf:Property ;
    rdfs:label 'Procore Project Code' ;
    rdfs:comment 'External project identifier from Procore construction management system. Enables cross-system traceability for RFIs, submittals, change orders, and document control records associated with this CAPEX project.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectDescription rdf:type rdf:Property ;
    rdfs:label 'Project Description' ;
    rdfs:comment 'Detailed narrative describing the scope of work, business justification, and expected outcome of the capital project. Supports investment committee review, LOI documentation, and regulatory compliance reporting.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectName rdf:type rdf:Property ;
    rdfs:label 'Project Name' ;
    rdfs:comment 'Descriptive short name for the capital project (e.g., \'HVAC Chiller Replacement — Tower A\', \'Roof Membrane Renewal — Building 3\'). Used in reporting dashboards, budget approvals, and fixed asset registers.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectNumber rdf:type rdf:Property ;
    rdfs:label 'Project Number' ;
    rdfs:comment 'Externally-known, human-readable project identifier assigned at project initiation. Used across Procore, SAP S/4HANA Project Systems, and Yardi Fixed Assets for cross-system reference and audit trail. Format: CAPEX-{YYYY}-{NNNNN}.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectStatus rdf:type rdf:Property ;
    rdfs:label 'Project Status' ;
    rdfs:comment 'Current lifecycle state of the capital project workflow. Drives approval routing, budget release, and fixed asset capitalization triggers. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|in_progress|on_hold|completed|cancelled — promote to reference product]' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectType rdf:type rdf:Property ;
    rdfs:label 'Project Type' ;
    rdfs:comment 'Classification of the capital project by nature of work. Determines accounting treatment, depreciation schedule, and regulatory reporting category. Tenant Improvement (TI) projects may have separate amortization rules under ASC 842. [ENUM-REF-CANDIDATE: new_construction|renovation|equipment_replacement|infrastructure_upgrade|tenant_improvement|environmental_remediation|safety_compliance — promote to reference product]' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Revised Budget Amount' ;
    rdfs:comment 'Most recent approved revision to the original project budget, reflecting change orders, scope changes, or cost escalations. Null if no revision has been approved. Supports change order management and budget variance reporting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billableChargeId rdf:type rdf:Property ;
    rdfs:label 'Billable Charge Id' ;
    rdfs:comment 'Primary key for billable_charge' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillableCharge .

ind:arInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ar Invoice Id' ;
    rdfs:comment 'Foreign key linking to finance.ar_invoice. Business justification: Maintenance billable charges (tenant repairs, CAM charges) are invoiced through AR. The billable_charge.invoice_number is a denormalized reference to ar_invoice. This FK enables tenant billing reconci' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:camScheduleId rdf:type rdf:Property ;
    rdfs:label 'Cam Schedule Id' ;
    rdfs:comment 'Foreign key linking to lease.cam_schedule. Business justification: billable_charge has `is_cam_reconciliation_charge` and `cam_allocation_method` fields. Linking to cam_schedule enables the annual CAM reconciliation process to aggregate all billable charges within a ' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CamSchedule .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'End date of the billing period to which this charge is allocated. Together with billing_period_start_date defines the CAM reconciliation window for this charge.' ;
    rdfs:domain ind:BillableCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'Start date of the billing period to which this charge is allocated. Used in CAM reconciliation to match charges to the correct annual or monthly reconciliation cycle.' ;
    rdfs:domain ind:BillableCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:camAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Cam Allocation Method' ;
    rdfs:comment 'Method used to allocate the CAM pool charge to this tenant. Pro-rata NLA/GLA allocates based on the tenant\'s proportionate share of leasable area; fixed percentage uses a lease-defined rate; direct assignment charges the full amount to one tenant.' ;
    rdfs:domain ind:BillableCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeCategory rdf:type rdf:Property ;
    rdfs:label 'Charge Category' ;
    rdfs:comment 'Classification of the maintenance activity type that generated this billable charge. Used for CAM pool segmentation, tenant billing transparency, and OPEX vs. CAPEX reporting. [ENUM-REF-CANDIDATE: HVAC|janitorial|repairs|landscaping|security|electrical|plumbing|pest_control|elevator|general_maintenance — promote to reference product]' ;
    rdfs:domain ind:BillableCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeDate rdf:type rdf:Property ;
    rdfs:label 'Charge Date' ;
    rdfs:comment 'The principal business event date on which the billable maintenance charge was incurred or the service was rendered. Used as the basis for billing period assignment and CAM pool allocation.' ;
    rdfs:domain ind:BillableCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chargeNumber rdf:type rdf:Property ;
    rdfs:label 'Charge Number' ;
    rdfs:comment 'Externally-visible, human-readable charge reference number used in tenant invoices, CAM reconciliation statements, and property management accounting systems such as Yardi Voyager AR. Format: BC-YYYY-NNNNNN.' ;
    rdfs:domain ind:BillableCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeStatus rdf:type rdf:Property ;
    rdfs:label 'Charge Status' ;
    rdfs:comment 'Current lifecycle state of the billable charge from creation through collection or write-off. Drives workflow routing in Yardi Voyager AR and CAM reconciliation processing. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|invoiced|collected|disputed|written_off|voided — promote to reference product]' ;
    rdfs:domain ind:BillableCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeType rdf:type rdf:Property ;
    rdfs:label 'Charge Type' ;
    rdfs:comment 'Distinguishes the nature of the billable charge: CAM recoverable (pooled allocation), direct tenant charge (tenant-caused damage or exclusive service), capital improvement (CAPEX), emergency response, or warranty claim. Drives GL coding and lease compliance.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Date' ;
    rdfs:comment 'Date on which the tenant formally raised a dispute against this charge. Used to track dispute resolution timelines and SLA compliance for tenant relations.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Free-text description of the tenant\'s stated reason for disputing this charge. Populated when charge_status is \'disputed\'. Used for dispute resolution tracking and lease compliance review.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCamPaid rdf:type rdf:Property ;
    rdfs:label 'Estimated Cam Paid' ;
    rdfs:comment 'Total estimated CAM payments already collected from the tenant during the reconciliation period. Used to calculate the reconciliation true-up amount (over- or under-collection) at year-end.' ;
    rdfs:domain ind:BillableCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Charge Amount' ;
    rdfs:comment 'Total gross cost of the maintenance activity before any tenant allocation, CAM pool proration, or adjustments. Represents the full vendor invoice or internal cost amount in the property\'s operating currency.' ;
    rdfs:domain ind:BillableCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'Date on which the tenant invoice containing this charge was issued. Used for payment due date calculation and aging analysis in Accounts Receivable.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isCamReconciliationCharge rdf:type rdf:Property ;
    rdfs:label 'Is Cam Reconciliation Charge' ;
    rdfs:comment 'Indicates whether this charge is part of an annual CAM reconciliation adjustment (true) or a current-period direct billing (false). CAM reconciliation charges arise when actual expenses differ from estimated CAM payments collected during the year.' ;
    rdfs:domain ind:BillableCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaseStructureType rdf:type rdf:Property ;
    rdfs:label 'Lease Structure Type' ;
    rdfs:comment 'The lease structure under which this charge is recoverable from the tenant. NNN (Triple Net) leases pass through all operating expenses; modified gross leases recover specific categories; gross leases are typically non-recoverable. Determines billing eligibility.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'Date by which the tenant is required to remit payment for this charge per the lease agreement terms. Used for AR aging, late fee assessment, and cash flow forecasting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationYear rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Year' ;
    rdfs:comment 'The calendar or fiscal year for which the CAM reconciliation is being performed. Applicable only when is_cam_reconciliation_charge is true. Used to match reconciliation charges to the correct operating year.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'Date on which a disputed charge was resolved, either through adjustment, credit, or confirmation of the original amount. Marks the closure of the dispute lifecycle.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemChargeCode rdf:type rdf:Property ;
    rdfs:label 'Source System Charge Code' ;
    rdfs:comment 'The native identifier of this charge record in the originating source system (e.g., Building Engines charge ID or Yardi Voyager transaction ID). Used for data lineage, reconciliation, and deduplication in the Silver Layer.' ;
    rdfs:domain ind:BillableCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Applicable sales or use tax assessed on the billable maintenance charge, where required by jurisdiction. Included in the tenant invoice and tracked separately for tax remittance compliance.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenantAllocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Tenant Allocated Amount' ;
    rdfs:comment 'The portion of the gross charge amount allocated to the specific tenant after applying the CAM pool allocation method (pro-rata share, fixed percentage, or direct assignment). This is the net amount billed to the tenant.' ;
    rdfs:domain ind:BillableCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenantProRataShare rdf:type rdf:Property ;
    rdfs:label 'Tenant Pro Rata Share' ;
    rdfs:comment 'The tenant\'s proportionate share of the CAM pool expressed as a decimal fraction (e.g., 0.125000 = 12.5%). Derived from the ratio of the tenant\'s Net Leasable Area (NLA) to the total building NLA or applicable pool area as defined in the lease.' ;
    rdfs:domain ind:BillableCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalInvoicedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Invoiced Amount' ;
    rdfs:comment 'Net total amount invoiced to the tenant, equal to the tenant_allocated_amount plus tax_amount. Represents the final receivable amount recorded in Yardi Voyager AR for this charge.' ;
    rdfs:domain ind:BillableCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Invoice Number' ;
    rdfs:comment 'The vendor\'s own invoice reference number for the maintenance service. Used to reconcile the billable charge against the corresponding Accounts Payable entry in Yardi Voyager AP.' ;
    rdfs:domain ind:BillableCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyIncidentId rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Id' ;
    rdfs:comment 'Unique system-generated identifier for each safety incident or near-miss event recorded at a managed property. Primary key for the safety_incident data product.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetyIncident .

ind:bodyPartAffected rdf:type rdf:Property ;
    rdfs:label 'Body Part Affected' ;
    rdfs:comment 'The specific body part injured or affected in the safety incident, as required for OSHA 300 log recordkeeping. Examples include head, back, hand, foot, eye. Nullable for non-injury incident types such as near-miss or property damage.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureNotes rdf:type rdf:Property ;
    rdfs:label 'Closure Notes' ;
    rdfs:comment 'Free-text notes recorded at the time of incident closure, summarizing the final outcome, verification of corrective actions, and any residual risk considerations. Provides a complete audit trail for the incident lifecycle.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributingFactors rdf:type rdf:Property ;
    rdfs:label 'Contributing Factors' ;
    rdfs:comment 'Narrative description of secondary or contributing factors that contributed to the safety incident beyond the primary root cause. May include environmental conditions, time pressure, staffing levels, or equipment age. Supports comprehensive incident investigation.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Completed Date' ;
    rdfs:comment 'Actual date on which all corrective and preventive actions were completed and verified. Null if corrective actions are still pending. Used to measure remediation timeliness and close the incident lifecycle.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Due Date' ;
    rdfs:comment 'Target completion date by which all corrective and preventive actions identified in the incident investigation must be implemented. Used for tracking remediation progress and accountability.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActions rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions' ;
    rdfs:comment 'Description of the corrective and preventive actions taken or planned in response to the safety incident to prevent recurrence. May include equipment repair, procedural updates, additional training, or physical modifications to the facility.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysAwayFromWork rdf:type rdf:Property ;
    rdfs:label 'Days Away From Work' ;
    rdfs:comment 'Number of calendar days the injured party was away from work as a result of the safety incident. Required for OSHA 300 log (Column K) and OSHA 300A annual summary. Zero for incidents not resulting in lost time.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysJobTransferRestriction rdf:type rdf:Property ;
    rdfs:label 'Days Job Transfer Restriction' ;
    rdfs:comment 'Number of calendar days the injured party was on job transfer or work restriction as a result of the safety incident. Required for OSHA 300 log (Column L). Distinct from days_away_from_work.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:equipmentInvolved rdf:type rdf:Property ;
    rdfs:label 'Equipment Involved' ;
    rdfs:comment 'Description or identifier of the building equipment, machinery, or system involved in the safety incident, such as HVAC unit, elevator, electrical panel, or scaffolding. Supports equipment lifecycle analysis and O&M safety reviews.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgReportable rdf:type rdf:Property ;
    rdfs:label 'Esg Reportable' ;
    rdfs:comment 'Indicates whether the safety incident is material for ESG reporting purposes, including sustainability disclosures, GRESB assessments, or SEC climate and social risk disclosures for publicly traded REITs. Supports ESG portfolio-level safety metrics.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incidentCategory rdf:type rdf:Property ;
    rdfs:label 'Incident Category' ;
    rdfs:comment 'Secondary classification providing more granular categorization of the incident type, such as slip/trip/fall, struck-by object, electrical hazard, chemical exposure, equipment failure, or structural failure. [ENUM-REF-CANDIDATE: slip_trip_fall|struck_by|electrical|chemical_exposure|equipment_failure|structural|ergonomic|fire_explosion|environmental_release|other — promote to reference product]' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentDescription rdf:type rdf:Property ;
    rdfs:label 'Incident Description' ;
    rdfs:comment 'Detailed narrative description of the safety incident or near-miss event, including what happened, the sequence of events, conditions at the time, and any immediate actions taken. Free-text field captured by the reporting party.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentLocationDetail rdf:type rdf:Property ;
    rdfs:label 'Incident Location Detail' ;
    rdfs:comment 'Specific location within the property where the incident occurred, such as floor number, suite, common area, rooftop, parking garage, mechanical room, or stairwell. Complements the property_id with sub-property granularity.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Number' ;
    rdfs:comment 'Externally-known, human-readable reference number assigned to the safety incident at the time of reporting. Used for cross-referencing with regulatory filings, insurance claims, and Building Engines work order records. Format: INC-YYYY-NNNNNN.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentStatus rdf:type rdf:Property ;
    rdfs:label 'Incident Status' ;
    rdfs:comment 'Current workflow state of the safety incident record, tracking its lifecycle from initial report through investigation, corrective action, and closure. Valid values: open, under_investigation, corrective_action_pending, closed, voided.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Incident Timestamp' ;
    rdfs:comment 'The precise date and time at which the safety incident or near-miss event occurred at the property. This is the principal real-world event timestamp, distinct from the record creation timestamp. Stored in ISO 8601 format with timezone offset.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:incidentType rdf:type rdf:Property ;
    rdfs:label 'Incident Type' ;
    rdfs:comment 'Primary classification of the safety incident by nature of the event. Drives regulatory recordability determination and reporting pathway. Valid values: injury, near_miss, property_damage, environmental, fire, security.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuredPartyType rdf:type rdf:Property ;
    rdfs:label 'Injured Party Type' ;
    rdfs:comment 'Classification of the person involved in the safety incident by their relationship to the property or organization. Determines applicable regulatory reporting obligations and insurance coverage. Valid values: employee, contractor, tenant, visitor, vendor.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuryNature rdf:type rdf:Property ;
    rdfs:label 'Injury Nature' ;
    rdfs:comment 'Description of the nature of the injury or occupational illness sustained, such as laceration, fracture, sprain, burn, or respiratory condition. Required for OSHA 300 log and workers compensation filings. [ENUM-REF-CANDIDATE: laceration|fracture|sprain_strain|burn|contusion|respiratory|eye_injury|amputation|fatality|other — promote to reference product]' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigatingOfficer rdf:type rdf:Property ;
    rdfs:label 'Investigating Officer' ;
    rdfs:comment 'Name or identifier of the property manager, safety officer, or facility operations lead responsible for conducting the incident investigation. Supports accountability and audit trail for the investigation process.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Completed Date' ;
    rdfs:comment 'Date on which the formal incident investigation was completed and findings were documented. Marks the transition from investigation to corrective action phase in the incident lifecycle.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isEnvironmentalRelease rdf:type rdf:Property ;
    rdfs:label 'Is Environmental Release' ;
    rdfs:comment 'Indicates whether the safety incident involved a release of hazardous materials, chemicals, or pollutants into the environment. Triggers EPA reporting obligations and environmental compliance review when True.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOshaRecordable rdf:type rdf:Property ;
    rdfs:label 'Is Osha Recordable' ;
    rdfs:comment 'Indicates whether the safety incident meets OSHA recordability criteria under 29 CFR Part 1904 and must be entered on the OSHA 300 log. True if the incident resulted in medical treatment beyond first aid, days away from work, restricted work, job transfer, loss of consciousness, or diagnosis of a significant injury by a healthcare professional.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRiddorReportable rdf:type rdf:Property ;
    rdfs:label 'Is Riddor Reportable' ;
    rdfs:comment 'Indicates whether the safety incident is reportable under the UK Reporting of Injuries, Diseases and Dangerous Occurrences Regulations 2013 (RIDDOR). Applicable for properties under UK jurisdiction. Null for non-UK properties.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:osha300LogEntryDate rdf:type rdf:Property ;
    rdfs:label 'Osha 300 Log Entry Date' ;
    rdfs:comment 'The date on which the safety incident was entered onto the OSHA 300 log. OSHA requires recordable incidents to be logged within seven calendar days of receiving information that a recordable case occurred. Nullable for non-OSHA-recordable incidents.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction' ;
    rdfs:comment 'The country jurisdiction governing the regulatory reporting obligations for this safety incident. Determines which reporting framework applies (OSHA 300 for USA, RIDDOR for GBR, etc.). Uses ISO 3166-1 alpha-3 country codes. [ENUM-REF-CANDIDATE: USA|GBR|CAN|AUS|DEU|FRA|SGP|ARE|OTHER — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedBy rdf:type rdf:Property ;
    rdfs:label 'Reported By' ;
    rdfs:comment 'Name or identifier of the person who initially reported the safety incident to the facility management team. May be the injured party, a witness, or a property manager. Supports incident reporting accountability.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'The identified root cause of the safety incident as determined through investigation. Describes the underlying systemic or behavioral factor that allowed the incident to occur, such as inadequate PPE, equipment malfunction, procedural non-compliance, or environmental hazard.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentType rdf:type rdf:Property ;
    rdfs:label 'Treatment Type' ;
    rdfs:comment 'Classification of the medical treatment provided following the safety incident. Determines OSHA recordability: first aid cases are generally not OSHA recordable, while medical treatment beyond first aid triggers recordability. Valid values: first_aid, medical_treatment, hospitalization, fatality, no_treatment.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessNames rdf:type rdf:Property ;
    rdfs:label 'Witness Names' ;
    rdfs:comment 'Names of individuals who witnessed the safety incident. Recorded as a comma-separated list or narrative. Used during incident investigation and may be required for regulatory filings or legal proceedings. Classified as confidential due to sensitivity of witness information.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingClassId rdf:type rdf:Property ;
    rdfs:label 'Building Class Id' ;
    rdfs:comment 'Foreign key linking to reference.building_class. Business justification: Building class (A/B/C) on a listing drives rent benchmarking, cap rate expectations, REIT eligibility assessment, and investor targeting. Brokers use standardized building class to position listings i' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BuildingClass .

ind:marketSurveyId rdf:type rdf:Property ;
    rdfs:label 'Market Survey Id' ;
    rdfs:comment 'Foreign key linking to marketing.market_survey. Business justification: Listings are priced against current market survey data (avg asking rent PSF, vacancy rates, concessions). Linking a listing to the market survey used for pricing is standard brokerage practice and sup' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketSurvey .

ind:referenceLeaseTypeId rdf:type rdf:Property ;
    rdfs:label 'Reference Lease Type Id' ;
    rdfs:comment 'Foreign key linking to reference.lease_type. Business justification: Lease type on a listing drives CAM recovery rules, TI allowance benchmarks, ASC 842 classification, and commission structure. Brokers and tenants rely on standardized lease type definitions to price a' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LeaseType .

ind:spaceUseTypeId rdf:type rdf:Property ;
    rdfs:label 'Space Use Type Id' ;
    rdfs:comment 'Foreign key linking to reference.space_use_type. Business justification: CoStar/MLS syndication and market analytics reports require space use type (office, retail, industrial) classification on listings. A real estate domain expert expects listings to carry a structured s' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpaceUseType .

ind:submarketGeographicHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Submarket Geographic Hierarchy Id' ;
    rdfs:comment 'Foreign key linking to reference.geographic_hierarchy. Business justification: Market and submarket classification drives CoStar reporting, competitive market analysis, broker performance dashboards, and investment benchmarking. Standardized geographic hierarchy is required for ' ;
    rdfs:domain ind:Brokerage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeographicHierarchy .

ind:zoningCodeId rdf:type rdf:Property ;
    rdfs:label 'Zoning Code Id' ;
    rdfs:comment 'Foreign key linking to reference.zoning_code. Business justification: Zoning classification on a listing is required for permitted-use disclosure, buyer/tenant due diligence, and regulatory compliance. Brokers must reference standardized zoning definitions to confirm pe' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ZoningCode .

ind:camRatePsf rdf:type rdf:Property ;
    rdfs:label 'Cam Rate Psf' ;
    rdfs:comment 'Estimated annual Common Area Maintenance (CAM) charge per square foot applicable to the lease listing. Used in total occupancy cost analysis for tenant prospects.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closeDate rdf:type rdf:Property ;
    rdfs:label 'Close Date' ;
    rdfs:comment 'The date on which the transaction was completed — sale closed or lease executed. Null for active or pending listings. Used for production reporting and commission trigger.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closePrice rdf:type rdf:Property ;
    rdfs:label 'Close Price' ;
    rdfs:comment 'The final agreed transaction price at which the property was sold or the lease was executed. Used for comparable sales analysis, commission calculation, and investment performance reporting.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coBrokerCommissionPct rdf:type rdf:Property ;
    rdfs:label 'Co Broker Commission Pct' ;
    rdfs:comment 'The portion of the total commission allocated to the cooperating or buy-side broker in a co-brokerage arrangement. Null if no co-broker is involved.' ;
    rdfs:domain ind:Brokerage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionRatePct rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Pct' ;
    rdfs:comment 'The agreed brokerage commission rate expressed as a percentage of the transaction price or lease value. Drives commission payable calculations and co-broker split agreements.' ;
    rdfs:domain ind:Brokerage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costarCode rdf:type rdf:Property ;
    rdfs:label 'Costar Code' ;
    rdfs:comment 'CoStar Suite-assigned identifier for this listing, used for commercial property syndication, market research, and comparable data alignment.' ;
    rdfs:domain ind:Brokerage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysOnMarket rdf:type rdf:Property ;
    rdfs:label 'Days On Market' ;
    rdfs:comment 'Number of calendar days the listing has been active on the market, calculated from listing_start_date to the current date or close date. Key performance metric for brokerage production reporting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dealStage rdf:type rdf:Property ;
    rdfs:label 'Deal Stage' ;
    rdfs:comment 'Salesforce CRM deal pipeline stage tracking the progression of the listing from initial prospect through close. Aligns with brokerage workflow from Letter of Intent (LOI) submission through contract execution. [ENUM-REF-CANDIDATE: prospecting|qualification|loi_submitted|under_contract|due_diligence|closed_won|closed_lost — promote to reference product]' ;
    rdfs:domain ind:Brokerage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glaSqft rdf:type rdf:Property ;
    rdfs:label 'Gla Sqft' ;
    rdfs:comment 'Total Gross Leasable Area (GLA) of the property or space being listed, measured in square feet. Used for PSF rate calculations, market comparables, and FAR compliance.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCostarSyndicated rdf:type rdf:Property ;
    rdfs:label 'Is Costar Syndicated' ;
    rdfs:comment 'Indicates whether this listing has been published and syndicated to the CoStar Suite commercial property database for market exposure.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isExclusive rdf:type rdf:Property ;
    rdfs:label 'Is Exclusive' ;
    rdfs:comment 'Indicates whether the brokerage holds an exclusive listing agreement, granting sole marketing rights for the property during the listing term.' ;
    rdfs:domain ind:Brokerage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMlsSyndicated rdf:type rdf:Property ;
    rdfs:label 'Is Mls Syndicated' ;
    rdfs:comment 'Indicates whether this listing has been syndicated to the Multiple Listing Service (MLS) network. Drives listing visibility and co-broker cooperation eligibility.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaseRatePsf rdf:type rdf:Property ;
    rdfs:label 'Lease Rate Psf' ;
    rdfs:comment 'Annual or monthly asking lease rate expressed on a Per Square Foot (PSF) basis for lease listings. Null for for-sale listings. Used for market comparables and deal underwriting.' ;
    rdfs:domain ind:Brokerage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:listingStatus rdf:type rdf:Property ;
    rdfs:label 'Listing Status' ;
    rdfs:comment 'Current lifecycle state of the listing. Active indicates available for marketing; pending indicates an accepted offer under contract; expired/withdrawn indicate the listing has ended without a transaction; sold/leased indicate a completed deal. [ENUM-REF-CANDIDATE: active|pending|expired|withdrawn|sold|leased|on_hold|draft — promote to reference product]' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listingType rdf:type rdf:Property ;
    rdfs:label 'Listing Type' ;
    rdfs:comment 'Classification of the listing agreement type governing the brokerage relationship. Exclusive grants sole marketing rights; open allows multiple brokers; co-exclusive is shared between two brokers. [ENUM-REF-CANDIDATE: exclusive|open|co_exclusive|exclusive_agency|net — promote to reference product]' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlsNumber rdf:type rdf:Property ;
    rdfs:label 'Mls Number' ;
    rdfs:comment 'The externally-known Multiple Listing Service (MLS) identifier assigned to this listing upon syndication to the MLS network. Used for cross-brokerage identification and public-facing search.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nlaSqft rdf:type rdf:Property ;
    rdfs:label 'Nla Sqft' ;
    rdfs:comment 'Net Leasable Area (NLA) of the property, excluding common areas and structural elements. Used for tenant space calculations and lease rate benchmarking.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfFloors rdf:type rdf:Property ;
    rdfs:label 'Number Of Floors' ;
    rdfs:comment 'Total number of above-grade floors in the building. Used for property classification, elevator requirement analysis, and comparable selection.' ;
    rdfs:domain ind:Listing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parkingRatio rdf:type rdf:Property ;
    rdfs:label 'Parking Ratio' ;
    rdfs:comment 'Number of parking spaces per 1,000 square feet of rentable area. A key amenity metric for commercial lease listings and tenant prospect qualification.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:price rdf:type rdf:Property ;
    rdfs:label 'Price' ;
    rdfs:comment 'The asking or offering price for a for-sale listing, expressed in the local currency. For lease listings, this field is null and lease_rate_psf is used instead.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesforceOpportunityCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Opportunity Code' ;
    rdfs:comment 'The corresponding Salesforce CRM opportunity or deal record ID that tracks the brokerage pipeline activity associated with this listing.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'The date on which the listing became active and was authorized for marketing. Used to calculate Days on Market (DOM) and listing agreement compliance.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tenantImprovementAllowance rdf:type rdf:Property ;
    rdfs:label 'Tenant Improvement Allowance' ;
    rdfs:comment 'The landlord-offered Tenant Improvement (TI) allowance in absolute dollar terms for lease listings. Represents the capital contribution toward tenant fit-out and is a key deal negotiation lever.' ;
    rdfs:domain ind:Brokerage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yearBuilt rdf:type rdf:Property ;
    rdfs:label 'Year Built' ;
    rdfs:comment 'The year in which the property was originally constructed. Used for property age analysis, capital expenditure planning, and market comparable filtering.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCostarListingId rdf:type rdf:Property ;
    rdfs:label 'Primary Costar Listing Id' ;
    rdfs:comment 'The unique identifier assigned by CoStar Suite when the property listing is syndicated to the CoStar commercial real estate (CRE) platform for market exposure and comparable tracking.' ;
    rdfs:domain ind:ListingAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Listing .

ind:propertyOwnershipInterestId rdf:type rdf:Property ;
    rdfs:label 'Property Ownership Interest Id' ;
    rdfs:comment 'Foreign key linking to property.property_ownership_interest. Business justification: Listing agreements must identify which ownership interest authorizes the listing (managing member, controlling interest). This is a legal/compliance requirement — only the authorized ownership interes' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PropertyOwnershipInterest .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the listing agreement defining the scope of brokerage authority and commission entitlement. Exclusive Right to Sell grants the broker commission regardless of who procures the buyer. Exclusive Agency allows the owner to sell without commission if they find the buyer themselves. Open Listing allows multiple brokers with commission only to the procuring broker. Net Listing pays the broker any amount above the owner\'s net price. Exclusive Right to Lease applies to leasing engagements.' ;
    rdfs:domain ind:Brokerage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Broker License Number' ;
    rdfs:comment 'The state-issued real estate broker license number of the brokerage firm executing this listing agreement, required for regulatory compliance and agreement validity under state licensing laws.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerLicenseState rdf:type rdf:Property ;
    rdfs:label 'Broker License State' ;
    rdfs:comment 'The two-letter US state code in which the broker\'s license is issued and under whose laws this listing agreement is governed.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerageSide rdf:type rdf:Property ;
    rdfs:label 'Brokerage Side' ;
    rdfs:comment 'Identifies the brokerage\'s role in the transaction: sell-side (representing the seller/landlord), buy-side (representing the buyer/tenant), lease listing (marketing a property for lease), tenant representation, or dual agency (representing both parties with disclosed consent).' ;
    rdfs:domain ind:Brokerage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coBrokerAuthorized rdf:type rdf:Property ;
    rdfs:label 'Co Broker Authorized' ;
    rdfs:comment 'Indicates whether the listing agreement authorizes the listing broker to cooperate with and compensate a co-broker (buyer\'s agent or tenant\'s representative) from the total commission. True enables MLS co-broker cooperation.' ;
    rdfs:domain ind:ListingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coBrokerSplitRate rdf:type rdf:Property ;
    rdfs:label 'Co Broker Split Rate' ;
    rdfs:comment 'The portion of the total commission allocated to the cooperating co-broker (buyer\'s agent), expressed as a decimal percentage of the total commission or of the transaction price, as specified in the agreement. Null when co-broker authorization is false.' ;
    rdfs:domain ind:ListingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionFlatFee rdf:type rdf:Property ;
    rdfs:label 'Commission Flat Fee' ;
    rdfs:comment 'The agreed fixed brokerage commission amount in the agreement currency, applicable when the commission structure is a flat fee rather than a percentage. Null when a percentage-based commission rate is used.' ;
    rdfs:domain ind:Brokerage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionRate rdf:type rdf:Property ;
    rdfs:label 'Commission Rate' ;
    rdfs:comment 'The agreed brokerage commission expressed as a decimal percentage of the transaction price (e.g., 0.0600 = 6.00%). Applicable when the commission structure is percentage-based. Null when a flat fee structure is used.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionStructure rdf:type rdf:Property ;
    rdfs:label 'Commission Structure' ;
    rdfs:comment 'Defines the method by which the brokerage commission is calculated: percentage of transaction price, flat fee, tiered based on price thresholds, or net above a reserve price (net listing).' ;
    rdfs:domain ind:Brokerage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dualAgencyConsent rdf:type rdf:Property ;
    rdfs:label 'Dual Agency Consent' ;
    rdfs:comment 'Indicates whether the property owner has provided informed written consent for the broker to act as a dual agent, representing both the seller/landlord and the buyer/tenant in the same transaction, as required by state licensing laws.' ;
    rdfs:domain ind:Brokerage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:esgDisclosureRequired rdf:type rdf:Property ;
    rdfs:label 'Esg Disclosure Required' ;
    rdfs:comment 'Indicates whether the listing agreement requires the broker to include Environmental, Social, and Governance (ESG) disclosures or sustainability certifications (e.g., LEED, BREEAM, ENERGY STAR) in the property marketing materials.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAmendedDate rdf:type rdf:Property ;
    rdfs:label 'Last Amended Date' ;
    rdfs:comment 'The date of the most recent formal amendment to the listing agreement. Null if no amendments have been executed.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lockboxAuthorized rdf:type rdf:Property ;
    rdfs:label 'Lockbox Authorized' ;
    rdfs:comment 'Indicates whether the property owner has authorized the broker to install a lockbox on the property to facilitate agent showings without requiring the owner to be present.' ;
    rdfs:domain ind:ListingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingBudget rdf:type rdf:Property ;
    rdfs:label 'Marketing Budget' ;
    rdfs:comment 'The agreed marketing expenditure budget allocated for promoting the listed property, covering advertising, photography, virtual tours, signage, and digital syndication costs as specified in the listing agreement.' ;
    rdfs:domain ind:ListingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumAcceptablePrice rdf:type rdf:Property ;
    rdfs:label 'Minimum Acceptable Price' ;
    rdfs:comment 'The lowest transaction price the owner has authorized the broker to accept or present for consideration, as agreed in the listing agreement. Used to guide offer evaluation and negotiation boundaries.' ;
    rdfs:domain ind:ListingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownerDisclosureCompleted rdf:type rdf:Property ;
    rdfs:label 'Owner Disclosure Completed' ;
    rdfs:comment 'Indicates whether the property owner has completed and delivered all required property disclosure statements (e.g., seller\'s disclosure, lead paint, environmental hazards) as mandated by applicable state and federal regulations.' ;
    rdfs:domain ind:ListingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceReductionAuthorized rdf:type rdf:Property ;
    rdfs:label 'Price Reduction Authorized' ;
    rdfs:comment 'Indicates whether the listing agreement grants the broker authority to reduce the listing price within defined parameters without requiring a formal amendment, enabling faster market responsiveness.' ;
    rdfs:domain ind:ListingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:protectionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Protection Period Days' ;
    rdfs:comment 'The number of days after the listing agreement expires during which the broker retains the right to earn a commission if the property is sold or leased to a prospect introduced by the broker during the listing term. Also known as the safety clause or tail period.' ;
    rdfs:domain ind:Brokerage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:showingInstructions rdf:type rdf:Property ;
    rdfs:label 'Showing Instructions' ;
    rdfs:comment 'Free-text instructions governing how and when the property may be shown to prospective buyers or tenants, including notice requirements, access restrictions, and contact protocols as specified by the owner.' ;
    rdfs:domain ind:ListingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerageProspectId rdf:type rdf:Property ;
    rdfs:label 'Brokerage Prospect Id' ;
    rdfs:comment 'Foreign key linking to brokerage.brokerage_prospect. Business justification: A brokerage deal originates from a prospect tracked in the CRM. Adding brokerage_prospect_id normalizes the relationship and eliminates the denormalized prospect_name and prospect_company string field' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BrokerageProspect .

ind:buyerRepresentationId rdf:type rdf:Property ;
    rdfs:label 'Buyer Representation Id' ;
    rdfs:comment 'Foreign key linking to brokerage.buyer_representation. Business justification: A brokerage deal on the buy-side is governed by a buyer representation agreement. Linking brokerage_deal to buyer_representation enables direct validation of commission structure, exclusivity terms, a' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BuyerRepresentation .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Foreign key linking to marketing.campaign. Business justification: Direct campaign-to-deal attribution is required for marketing ROI reporting when deals are sourced directly from campaigns without a lead record (e.g., inbound from a digital campaign). deal.deal_sour' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:tenantIndustryClassificationId rdf:type rdf:Property ;
    rdfs:label 'Tenant Industry Classification Id' ;
    rdfs:comment 'Foreign key linking to reference.industry_classification. Business justification: Tenant credit risk assessment and tenant mix analysis reports require industry classification of the tenant/buyer on each deal. Landlords and lenders require tenant industry classification for underwr' ;
    rdfs:domain ind:Brokerage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IndustryClassification .

ind:actualCloseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Close Date' ;
    rdfs:comment 'Date on which the deal was formally closed and the transaction was completed. Populated upon deal_stage transition to \'closed\'. Drives commission income recognition and production metric reporting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coBrokerFirm rdf:type rdf:Property ;
    rdfs:label 'Co Broker Firm' ;
    rdfs:comment 'Name of the cooperating brokerage firm participating in the deal on the opposing side. Required for co-brokerage commission disbursement, MLS reporting, and NAR cooperative compensation compliance.' ;
    rdfs:domain ind:BrokerageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionAmount rdf:type rdf:Property ;
    rdfs:label 'Commission Amount' ;
    rdfs:comment 'Calculated gross commission dollar amount payable upon deal close, derived from commission_rate_pct applied to total_consideration. Stored as a business field for commission tracking, AP processing, and broker production reporting. Not a KPI — represents the contractual commission obligation.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deadDate rdf:type rdf:Property ;
    rdfs:label 'Dead Date' ;
    rdfs:comment 'Date on which the deal was marked as dead or terminated. Populated when deal_stage transitions to \'dead\'. Used for pipeline attrition analysis and dead deal reason reporting.' ;
    rdfs:domain ind:BrokerageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deadReason rdf:type rdf:Property ;
    rdfs:label 'Dead Reason' ;
    rdfs:comment 'Reason code explaining why the deal was terminated or lost. Populated when deal_stage = \'dead\'. Used for pipeline loss analysis, broker coaching, and CRM closed-lost reporting. [ENUM-REF-CANDIDATE: price_gap|financing_failed|due_diligence_failure|client_withdrew|competing_offer|market_conditions|regulatory_issue|other — promote to reference product]' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealName rdf:type rdf:Property ;
    rdfs:label 'Deal Name' ;
    rdfs:comment 'Descriptive name of the deal as entered in the CRM pipeline (e.g., \'Acme Corp — 50 Hudson Yards — Office Lease\'). Used for quick identification in pipeline reports and dashboards.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealNumber rdf:type rdf:Property ;
    rdfs:label 'Deal Number' ;
    rdfs:comment 'Human-readable, externally-known business identifier for the deal (e.g., BRK-2024-00412). Used in correspondence, reporting, and CRM references. Distinct from the surrogate deal_id.' ;
    rdfs:domain ind:BrokerageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealSource rdf:type rdf:Property ;
    rdfs:label 'Deal Source' ;
    rdfs:comment 'Origin channel through which the deal opportunity was identified or generated. Used for lead source attribution, marketing ROI analysis, and broker prospecting effectiveness reporting. [ENUM-REF-CANDIDATE: inbound_referral|outbound_prospecting|mls|costar|repeat_client|broker_network|marketing_campaign|cold_call|website|other — promote to reference product]' ;
    rdfs:domain ind:BrokerageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealType rdf:type rdf:Property ;
    rdfs:label 'Deal Type' ;
    rdfs:comment 'Classification of the brokerage transaction type. Determines applicable commission structures, regulatory requirements, and pipeline reporting categories. [ENUM-REF-CANDIDATE: sale|lease|sublease|assignment|renewal|expansion|ground_lease|sale_leaseback — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:BrokerageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityEndDate rdf:type rdf:Property ;
    rdfs:label 'Exclusivity End Date' ;
    rdfs:comment 'End date of the exclusivity period. After this date, the broker\'s exclusive representation rights expire. Used to trigger listing agreement renewal workflows and pipeline expiry alerts.' ;
    rdfs:domain ind:BrokerageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusivityStartDate rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Start Date' ;
    rdfs:comment 'Start date of the exclusivity period during which the broker has the exclusive right to represent the property or client for this deal. Governs competing offer restrictions and listing agreement compliance.' ;
    rdfs:domain ind:BrokerageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isCoBrokerage rdf:type rdf:Property ;
    rdfs:label 'Is Co Brokerage' ;
    rdfs:comment 'Indicates whether a cooperating (co-broker) firm is involved in this deal. True = co-brokerage arrangement exists, triggering commission split processing and co-broker disclosure requirements.' ;
    rdfs:domain ind:BrokerageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaseTermMonths rdf:type rdf:Property ;
    rdfs:label 'Lease Term Months' ;
    rdfs:comment 'Total duration of the lease agreement in months. Applicable for lease, sublease, and renewal deal types. Used to compute total lease consideration and Weighted Average Lease Term (WALT) portfolio metrics.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loiDate rdf:type rdf:Property ;
    rdfs:label 'Loi Date' ;
    rdfs:comment 'Date on which the Letter of Intent (LOI) was executed between the parties. Marks the transition from prospect to LOI stage in the pipeline. Key milestone for pipeline velocity and stage duration analysis.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:probabilityPct rdf:type rdf:Property ;
    rdfs:label 'Probability Pct' ;
    rdfs:comment 'Estimated probability (0.00–100.00%) that the deal will close successfully, as assessed by the assigned broker or CRM workflow automation. Used for weighted pipeline value calculations and revenue forecasting.' ;
    rdfs:domain ind:BrokerageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedCloseDate rdf:type rdf:Property ;
    rdfs:label 'Projected Close Date' ;
    rdfs:comment 'Broker-estimated date by which the deal is expected to close. Used for pipeline forecasting, revenue recognition planning, and CRM opportunity management. Distinct from actual_close_date.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salePrice rdf:type rdf:Property ;
    rdfs:label 'Sale Price' ;
    rdfs:comment 'Agreed or listed purchase price for sale transaction deals. Null for lease-only deals. Used for CAP Rate analysis, LTV calculations, and comparable sales (CMA/BPO) benchmarking.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:side rdf:type rdf:Property ;
    rdfs:label 'Side' ;
    rdfs:comment 'Indicates which side of the transaction the brokerage firm represents. Critical for commission split calculations, conflict-of-interest disclosures, and regulatory compliance. Dual agency requires specific disclosure per NAR ethics rules.' ;
    rdfs:domain ind:BrokerageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeSqft rdf:type rdf:Property ;
    rdfs:label 'Size Sqft' ;
    rdfs:comment 'Total rentable or saleable area covered by this deal, expressed in square feet (SQF). For lease deals, represents the leased premises area. For sale deals, represents the total building or unit area transacted. Key metric for Per Square Foot (PSF) analysis.' ;
    rdfs:domain ind:BrokerageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'Current stage of the deal in the brokerage pipeline lifecycle. Maps directly to Salesforce CRM opportunity stages. Drives pipeline velocity analysis and CRM workflow compliance auditing. Values: prospect (initial identification), loi (Letter of Intent executed), under_contract (purchase/lease agreement signed), due_diligence (inspection/review period), closed (transaction completed), dead (deal terminated).' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalConsideration rdf:type rdf:Property ;
    rdfs:label 'Total Consideration' ;
    rdfs:comment 'Gross total monetary value of the transaction. For sale deals: total purchase price. For lease deals: total lease value over the full lease term (base rent × term). Expressed in the deal currency. Core metric for pipeline value reporting and commission base calculation.' ;
    rdfs:domain ind:BrokerageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelId rdf:type rdf:Property ;
    rdfs:label 'Channel Id' ;
    rdfs:comment 'Foreign key linking to marketing.channel. Business justification: Prospect channel attribution is a named CRM process in real estate: brokerages track which marketing channel (portal, referral, social, email) originated each prospect for ROI reporting and channel bu' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:industryClassificationId rdf:type rdf:Property ;
    rdfs:label 'Industry Classification Id' ;
    rdfs:comment 'Foreign key linking to reference.industry_classification. Business justification: Tenant prospect qualification and credit screening require industry classification to assess creditworthiness and compatibility with property tenant mix requirements. Landlords and leasing brokers scr' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IndustryClassification .

ind:preferredSubmarketGeographicHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Preferred Submarket Geographic Hierarchy Id' ;
    rdfs:comment 'Foreign key linking to reference.geographic_hierarchy. Business justification: Prospect geographic preference drives listing matching, broker territory assignment, and market demand analytics. Standardized geographic hierarchy enables cross-market prospect analysis. Role prefix ' ;
    rdfs:domain ind:BrokerageProspect ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeographicHierarchy .

ind:primaryBrokerageBrokerId rdf:type rdf:Property ;
    rdfs:label 'Primary Brokerage Broker Id' ;
    rdfs:comment 'Identifier of the licensed broker or agent assigned to manage this prospect relationship and advance the deal pipeline. Links to the broker/agent master record.' ;
    rdfs:domain ind:BrokerageProspect ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Broker .

ind:salesforceLeadId rdf:type rdf:Property ;
    rdfs:label 'Salesforce Lead Id' ;
    rdfs:comment 'Reference identifier for the corresponding Lead or Contact record in Salesforce CRM, enabling cross-system traceability between the lakehouse silver layer and the operational CRM.' ;
    rdfs:domain ind:BrokerageProspect ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lead .

ind:budgetPsf rdf:type rdf:Property ;
    rdfs:label 'Budget Psf' ;
    rdfs:comment 'Prospect\'s stated budget or target lease rate expressed in dollars per square foot (PSF) per annum for lease prospects, or acquisition price PSF for buyers. Key qualifier for deal viability assessment.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capRateTarget rdf:type rdf:Property ;
    rdfs:label 'Cap Rate Target' ;
    rdfs:comment 'Investor prospect\'s target CAP Rate (Capitalization Rate) expressed as a decimal (e.g., 0.0550 = 5.50%). Used to filter investment listings and assess deal viability against NOI-based valuations.' ;
    rdfs:domain ind:BrokerageProspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:email rdf:type rdf:Property ;
    rdfs:label 'Email' ;
    rdfs:comment 'Primary email address used for brokerage outreach and CRM communication with the prospect.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'Full legal name of the prospective buyer, tenant, investor, or owner/seller as captured in the CRM at the time of introduction.' ;
    rdfs:domain ind:Brokerage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentDate rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Date' ;
    rdfs:comment 'Date on which the prospect provided GDPR data processing consent. Required for audit trail and regulatory compliance documentation.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdprConsentGiven rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Given' ;
    rdfs:comment 'Indicates whether the prospect has provided explicit consent for personal data processing under GDPR. Required for EU-based prospects; must be True before marketing communications are sent.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irrTarget rdf:type rdf:Property ;
    rdfs:label 'Irr Target' ;
    rdfs:comment 'Investor prospect\'s minimum required Internal Rate of Return (IRR) expressed as a decimal (e.g., 0.1200 = 12.00%). Used in DCF-based investment screening and portfolio advisory.' ;
    rdfs:domain ind:BrokerageProspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDoNotContact rdf:type rdf:Property ;
    rdfs:label 'Is Do Not Contact' ;
    rdfs:comment 'Indicates whether the prospect has requested to be removed from all brokerage outreach. True suppresses all automated and manual contact attempts, ensuring compliance with GDPR and CAN-SPAM opt-out requirements.' ;
    rdfs:domain ind:BrokerageProspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Contact Date' ;
    rdfs:comment 'Most recent date on which the assigned broker made contact with the prospect (call, email, meeting, or site tour). Used to monitor engagement cadence and identify stale prospects.' ;
    rdfs:domain ind:BrokerageProspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadSource rdf:type rdf:Property ;
    rdfs:label 'Lead Source' ;
    rdfs:comment 'Channel or method through which the prospect was introduced to the brokerage. Used for marketing attribution, ROI analysis on lead generation spend, and broker performance reporting. [ENUM-REF-CANDIDATE: referral|cold_call|marketing_campaign|costar_lead|walk_in|mls_inquiry|website|broker_network|other — promote to reference product]' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lostReason rdf:type rdf:Property ;
    rdfs:label 'Lost Reason' ;
    rdfs:comment 'Reason the prospect was marked as lost or disqualified in the CRM pipeline. Used for win/loss analysis and brokerage strategy refinement. Null when qualification_status is not \'lost\'. [ENUM-REF-CANDIDATE: price|location|size|competitor|no_requirement|timing|financing|other — promote to reference product]' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxSizeSqft rdf:type rdf:Property ;
    rdfs:label 'Max Size Sqft' ;
    rdfs:comment 'Maximum space requirement in square feet (SQF) as stated by the prospect. Upper bound for listing matching against GLA/NLA of available properties.' ;
    rdfs:domain ind:Brokerage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minSizeSqft rdf:type rdf:Property ;
    rdfs:label 'Min Size Sqft' ;
    rdfs:comment 'Minimum space requirement in square feet (SQF) as stated by the prospect. Used for listing matching against GLA/NLA of available properties.' ;
    rdfs:domain ind:Brokerage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextFollowupDate rdf:type rdf:Property ;
    rdfs:label 'Next Followup Date' ;
    rdfs:comment 'Scheduled date for the next broker outreach or follow-up action with the prospect. Drives CRM task management and pipeline hygiene reporting.' ;
    rdfs:domain ind:BrokerageProspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phone rdf:type rdf:Property ;
    rdfs:label 'Phone' ;
    rdfs:comment 'Primary contact phone number for the prospect, used by the assigned broker for outreach and follow-up.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectType rdf:type rdf:Property ;
    rdfs:label 'Prospect Type' ;
    rdfs:comment 'Categorizes the prospect\'s role in the anticipated transaction: buyer (acquisition), tenant (leasing), investor (capital deployment), or owner/seller (disposition). Drives deal pipeline routing and broker assignment logic.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Status' ;
    rdfs:comment 'Current qualification stage of the prospect in the brokerage CRM pipeline. MQL (Marketing Qualified Lead) indicates marketing-sourced interest; SQL (Sales Qualified Lead) indicates broker-validated readiness. Converted means the prospect has become a confirmed deal counterparty; Lost means the prospect has disengaged.' ;
    rdfs:domain ind:BrokerageProspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralSourceName rdf:type rdf:Property ;
    rdfs:label 'Referral Source Name' ;
    rdfs:comment 'Name of the individual, firm, or campaign that referred this prospect to the brokerage. Applicable when lead_source = \'referral\'. Used for referral fee tracking and relationship management.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteToursCount rdf:type rdf:Property ;
    rdfs:label 'Site Tours Count' ;
    rdfs:comment 'Total number of property site tours conducted with this prospect to date. Indicates engagement depth and deal progression velocity.' ;
    rdfs:domain ind:BrokerageProspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetLeaseTermMonths rdf:type rdf:Property ;
    rdfs:label 'Target Lease Term Months' ;
    rdfs:comment 'Prospect\'s preferred lease duration in months. Applicable for tenant prospects. Used to assess WALT impact and match against landlord minimum term requirements.' ;
    rdfs:domain ind:BrokerageProspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetMoveInDate rdf:type rdf:Property ;
    rdfs:label 'Target Move In Date' ;
    rdfs:comment 'Prospect\'s desired move-in or occupancy commencement date. For buyers, this represents the target closing/possession date. Critical for matching against available listing dates and lease commencement scheduling.' ;
    rdfs:domain ind:BrokerageProspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tiRequirement rdf:type rdf:Property ;
    rdfs:label 'Ti Requirement' ;
    rdfs:comment 'Indicates whether the prospect requires a Tenant Improvement (TI) allowance as part of the deal structure. True signals that TI negotiation will be a material deal term.' ;
    rdfs:domain ind:BrokerageProspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalBudget rdf:type rdf:Property ;
    rdfs:label 'Total Budget' ;
    rdfs:comment 'Total maximum budget or investment capital the prospect is prepared to deploy, expressed in the deal currency. For buyers and investors, this is the maximum acquisition price; for tenants, the total lease commitment ceiling.' ;
    rdfs:domain ind:BrokerageProspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:showingId rdf:type rdf:Property ;
    rdfs:label 'Showing Id' ;
    rdfs:comment 'Unique system-generated identifier for each property showing or tour event record in the brokerage pipeline.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Showing .

ind:leadId rdf:type rdf:Property ;
    rdfs:label 'Lead Id' ;
    rdfs:comment 'Foreign key linking to marketing.lead. Business justification: Lead-to-showing conversion rate is a named real estate marketing KPI. Showings are frequently booked directly from inbound portal leads before a prospect record exists. Linking showing to the originat' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lead .

ind:showingBrokerId rdf:type rdf:Property ;
    rdfs:label 'Showing Broker Id' ;
    rdfs:comment 'Reference to the licensed broker or agent who conducted or hosted the showing on behalf of the listing side.' ;
    rdfs:domain ind:Showing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Broker .

ind:showingBuyerAgentBrokerBrokerageBrokerId rdf:type rdf:Property ;
    rdfs:label 'Showing Buyer Agent Broker Brokerage Broker Id' ;
    rdfs:comment 'Reference to the co-broker or buyer\'s/tenant\'s agent who accompanied the prospect during the showing, supporting co-broker commission tracking.' ;
    rdfs:domain ind:Showing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Broker .

ind:accessMethod rdf:type rdf:Property ;
    rdfs:label 'Access Method' ;
    rdfs:comment 'Method used to access the property for the showing, such as lockbox, agent-accompanied entry, or electronic access system, relevant for security and compliance tracking.' ;
    rdfs:domain ind:Showing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualEnd rdf:type rdf:Property ;
    rdfs:label 'Actual End' ;
    rdfs:comment 'The actual date and time the showing concluded, enabling calculation of actual showing duration for productivity analytics.' ;
    rdfs:domain ind:Showing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStart rdf:type rdf:Property ;
    rdfs:label 'Actual Start' ;
    rdfs:comment 'The actual date and time the showing commenced, which may differ from the scheduled start due to delays or early arrivals.' ;
    rdfs:domain ind:Showing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:attendeeCount rdf:type rdf:Property ;
    rdfs:label 'Attendee Count' ;
    rdfs:comment 'Total number of individuals who attended the showing, including the prospect, their representatives, and any accompanying decision-makers.' ;
    rdfs:domain ind:Showing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Reason for cancellation or no-show when showing_status is \'cancelled\' or \'no_show\', used for pipeline analytics and agent performance reporting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackNotes rdf:type rdf:Property ;
    rdfs:label 'Feedback Notes' ;
    rdfs:comment 'Free-text broker or prospect feedback captured after the showing, including property impressions, objections, pricing comments, and space suitability observations.' ;
    rdfs:domain ind:Showing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpAction rdf:type rdf:Property ;
    rdfs:label 'Follow Up Action' ;
    rdfs:comment 'Specific next-step action to be taken following the showing, such as sending a Letter of Intent (LOI), scheduling a second showing, or submitting comparable market analysis (CMA). [ENUM-REF-CANDIDATE: send_proposal|schedule_second_showing|submit_loi|send_comps|no_action_required|other — promote to reference product]' ;
    rdfs:domain ind:Showing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpDueDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Due Date' ;
    rdfs:comment 'Target date by which the follow-up action must be completed, used for agent task management and pipeline velocity tracking.' ;
    rdfs:domain ind:Showing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isConfidentialListing rdf:type rdf:Property ;
    rdfs:label 'Is Confidential Listing' ;
    rdfs:comment 'Indicates whether the property listing is confidential (off-market or pocket listing), requiring restricted disclosure of property details during the showing process.' ;
    rdfs:domain ind:Showing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ndaExecuted rdf:type rdf:Property ;
    rdfs:label 'Nda Executed' ;
    rdfs:comment 'Indicates whether a Non-Disclosure Agreement (NDA) was executed by the prospect prior to the showing, required for confidential or off-market listings.' ;
    rdfs:domain ind:Showing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'Recorded outcome of the showing event indicating the prospect\'s level of interest or next action, used to advance the deal pipeline in Salesforce CRM.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceFeedback rdf:type rdf:Property ;
    rdfs:label 'Price Feedback' ;
    rdfs:comment 'Prospect\'s qualitative feedback on the asking price or lease rate per square foot (PSF) relative to their expectations, informing pricing strategy.' ;
    rdfs:domain ind:Showing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectCompany rdf:type rdf:Property ;
    rdfs:label 'Prospect Company' ;
    rdfs:comment 'Name of the company or organization the prospect represents, relevant for commercial real estate (CRE) leasing and investment transactions.' ;
    rdfs:domain ind:Showing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectInterestLevel rdf:type rdf:Property ;
    rdfs:label 'Prospect Interest Level' ;
    rdfs:comment 'Broker\'s qualitative assessment of the prospect\'s interest level following the showing, used for pipeline prioritization and follow-up scheduling.' ;
    rdfs:domain ind:Showing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectSide rdf:type rdf:Property ;
    rdfs:label 'Prospect Side' ;
    rdfs:comment 'Identifies the brokerage representation side of the attending prospect — buy-side (buyer/tenant) or sell-side (seller/landlord) — for dual-agency and commission tracking.' ;
    rdfs:domain ind:Showing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredSqft rdf:type rdf:Property ;
    rdfs:label 'Required Sqft' ;
    rdfs:comment 'Prospect\'s stated space requirement in square feet (SQF) at the time of the showing, used to assess property-to-requirement fit and qualify the lead.' ;
    rdfs:domain ind:Showing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesforceActivityCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Activity Code' ;
    rdfs:comment 'External identifier of the corresponding activity record in Salesforce CRM from which this showing was sourced, enabling bi-directional traceability.' ;
    rdfs:domain ind:Showing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEnd rdf:type rdf:Property ;
    rdfs:label 'Scheduled End' ;
    rdfs:comment 'The planned date and time at which the property showing was scheduled to conclude, used to calculate planned duration.' ;
    rdfs:domain ind:Showing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStart rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start' ;
    rdfs:comment 'The planned date and time at which the property showing was scheduled to begin, as recorded in the CRM calendar event.' ;
    rdfs:domain ind:Showing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sequence rdf:type rdf:Property ;
    rdfs:label 'Sequence' ;
    rdfs:comment 'Sequential count of showings conducted for this prospect on this listing, indicating whether this is the first, second, or subsequent showing — a key pipeline velocity metric.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:showingNumber rdf:type rdf:Property ;
    rdfs:label 'Showing Number' ;
    rdfs:comment 'Human-readable business identifier for the showing event, used in broker communications, reporting, and CRM deal tracking (e.g., SHW-000123456).' ;
    rdfs:domain ind:Showing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:showingStatus rdf:type rdf:Property ;
    rdfs:label 'Showing Status' ;
    rdfs:comment 'Current lifecycle state of the showing event, tracking progression from scheduling through completion or cancellation.' ;
    rdfs:domain ind:Showing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:showingType rdf:type rdf:Property ;
    rdfs:label 'Showing Type' ;
    rdfs:comment 'Classification of the showing format: in-person physical tour, virtual video tour, self-guided access, open house event, or broker preview/caravan.' ;
    rdfs:domain ind:Showing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spaceFeedback rdf:type rdf:Property ;
    rdfs:label 'Space Feedback' ;
    rdfs:comment 'Prospect\'s qualitative feedback on the physical space, including size, layout, and configuration relative to their requirements.' ;
    rdfs:domain ind:Showing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:virtualPlatform rdf:type rdf:Property ;
    rdfs:label 'Virtual Platform' ;
    rdfs:comment 'Technology platform used to conduct a virtual showing (e.g., Zoom, Matterport 3D tour). Populated only when showing_type is \'virtual\'; otherwise not applicable. [ENUM-REF-CANDIDATE: zoom|microsoft_teams|google_meet|matterport|facetime|other|not_applicable — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionId rdf:type rdf:Property ;
    rdfs:label 'Commission Id' ;
    rdfs:comment 'Unique system-generated identifier for the commission record. Primary key for the brokerage.commission data product.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Commission .

ind:amendmentId rdf:type rdf:Property ;
    rdfs:label 'Amendment Id' ;
    rdfs:comment 'Foreign key linking to lease.amendment. Business justification: Commissions are earned on brokered lease amendments (expansions, renewals). Linking commission to the specific amendment enables commission calculation based on amended lease terms and provides an aud' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Amendment .

ind:payingLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Paying Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to finance.legal_entity. Business justification: Commission payments are issued by a specific legal entity (brokerage firm entity) for 1099-MISC tax reporting, intercompany accounting, and AP disbursement. IRS requires the paying legal entity to be ' ;
    rdfs:domain ind:Brokerage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:purchaseAgreementId rdf:type rdf:Property ;
    rdfs:label 'Purchase Agreement Id' ;
    rdfs:comment 'Foreign key linking to transaction.purchase_agreement. Business justification: Commission is legally earned upon executed purchase agreement, not just at closing. Commission dispute resolution and earned-vs-paid tracking require direct reference to the triggering purchase agreem' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseAgreement .

ind:renewalOptionId rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Id' ;
    rdfs:comment 'Foreign key linking to lease.renewal_option. Business justification: Commissions earned on renewal option exercises require direct reference to the specific option to verify rent reset terms, area, and option conditions used as the commission calculation basis. The dea' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RenewalOption .

ind:agentCommissionAmount rdf:type rdf:Property ;
    rdfs:label 'Agent Commission Amount' ;
    rdfs:comment 'Dollar amount of the net commission allocated to the primary listing or transaction agent per the agent\'s commission split agreement with the brokerage house.' ;
    rdfs:domain ind:Commission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agentSplitPct rdf:type rdf:Property ;
    rdfs:label 'Agent Split Pct' ;
    rdfs:comment 'Percentage of the net commission to house allocated to the primary agent per their individual commission split agreement. Expressed as a decimal (e.g., 70.0000 = 70%).' ;
    rdfs:domain ind:Commission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or identifier of the brokerage manager or finance officer who authorized the commission for payment. Supports SOX audit trail and internal controls.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coBrokerCommissionAmount rdf:type rdf:Property ;
    rdfs:label 'Co Broker Commission Amount' ;
    rdfs:comment 'Dollar amount of the gross commission payable to the cooperating broker, derived from gross_commission_amount × co_broker_split_pct. Tracked separately for co-broker payment processing and 1099 reporting.' ;
    rdfs:domain ind:Commission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coBrokerSplitPct rdf:type rdf:Property ;
    rdfs:label 'Co Broker Split Pct' ;
    rdfs:comment 'Percentage of the gross commission allocated to the cooperating/co-broker in a co-brokerage arrangement. Expressed as a decimal (e.g., 50.0000 = 50%). Null if no co-broker is involved.' ;
    rdfs:domain ind:Commission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionNumber rdf:type rdf:Property ;
    rdfs:label 'Commission Number' ;
    rdfs:comment 'Externally-known business identifier for the commission record, used in Yardi Voyager AR and Salesforce CRM for cross-system reference and audit trail. Format: COMM-YYYY-NNNNNN.' ;
    rdfs:domain ind:Commission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionStatus rdf:type rdf:Property ;
    rdfs:label 'Commission Status' ;
    rdfs:comment 'Current lifecycle state of the commission record: pending (awaiting trigger event), approved (authorized for payment), paid (disbursed), disputed (under review), or voided (cancelled).' ;
    rdfs:domain ind:Commission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionType rdf:type rdf:Property ;
    rdfs:label 'Commission Type' ;
    rdfs:comment 'Classification of how the commission is calculated: percentage of total consideration (sale price or lease value), flat fee, Per Square Foot (PSF)-based, or hybrid combining multiple methods.' ;
    rdfs:domain ind:Commission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Date' ;
    rdfs:comment 'Date on which a disputed commission was formally resolved, enabling tracking of dispute lifecycle duration and compliance with NAR arbitration timelines.' ;
    rdfs:domain ind:Commission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstPaymentDueDate rdf:type rdf:Property ;
    rdfs:label 'First Payment Due Date' ;
    rdfs:comment 'The date on which the first (or only) commission payment is contractually due. Used for Accounts Receivable (AR) aging and cash flow forecasting.' ;
    rdfs:domain ind:Commission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:flatFee rdf:type rdf:Property ;
    rdfs:label 'Flat Fee' ;
    rdfs:comment 'Fixed dollar amount of commission agreed upon in the listing agreement, applicable when commission_type is \'flat_fee\'. Mutually exclusive with commission_rate_pct for pure flat-fee structures.' ;
    rdfs:domain ind:Commission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossCommissionAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Commission Amount' ;
    rdfs:comment 'Total gross commission earned before any co-broker splits, referral fee deductions, or internal adjustments. Calculated as consideration_amount × commission_rate_pct or as a flat fee or PSF-based amount per the commission type.' ;
    rdfs:domain ind:Brokerage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:installmentCount rdf:type rdf:Property ;
    rdfs:label 'Installment Count' ;
    rdfs:comment 'Total number of installment payments scheduled for this commission when payment_schedule is \'installment\'. Null for upfront or deferred payment schedules.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isCoBroker rdf:type rdf:Property ;
    rdfs:label 'Is Co Broker' ;
    rdfs:comment 'Indicates whether this commission involves a co-brokerage arrangement with an outside cooperating broker. True when a co-broker split applies; False for in-house transactions.' ;
    rdfs:domain ind:Commission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReferral rdf:type rdf:Property ;
    rdfs:label 'Is Referral' ;
    rdfs:comment 'Indicates whether a referral fee deduction applies to this commission record, signaling that a portion of gross commission is payable to a referring party per a referral agreement.' ;
    rdfs:domain ind:Commission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netCommissionToHouse rdf:type rdf:Property ;
    rdfs:label 'Net Commission To House' ;
    rdfs:comment 'Net commission retained by the brokerage firm after deducting co-broker split and referral fees from the gross commission. Represents the firm\'s earned revenue for GL recognition. Calculated as gross_commission_amount − co_broker_commission_amount − referral_fee_amount.' ;
    rdfs:domain ind:Commission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidAmount rdf:type rdf:Property ;
    rdfs:label 'Paid Amount' ;
    rdfs:comment 'Cumulative dollar amount of commission payments actually received and applied to this commission record to date. Used to calculate outstanding balance and track payment progress.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidDate rdf:type rdf:Property ;
    rdfs:label 'Paid Date' ;
    rdfs:comment 'Date on which the commission was fully paid (status transitions to \'paid\'). Null if commission has not yet been fully disbursed.' ;
    rdfs:domain ind:Commission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentSchedule rdf:type rdf:Property ;
    rdfs:label 'Payment Schedule' ;
    rdfs:comment 'Defines the timing structure for commission disbursement: upfront (single payment at trigger event), installment (multiple scheduled payments), deferred (payment after a future condition), or milestone-based (tied to specific project milestones).' ;
    rdfs:domain ind:Commission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePct rdf:type rdf:Property ;
    rdfs:label 'Rate Pct' ;
    rdfs:comment 'The agreed commission rate expressed as a percentage of total consideration, applicable when commission_type is \'percentage\'. Stored as a decimal (e.g., 3.0000 = 3%).' ;
    rdfs:domain ind:Commission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratePsf rdf:type rdf:Property ;
    rdfs:label 'Rate Psf' ;
    rdfs:comment 'Commission rate expressed as a dollar amount Per Square Foot (PSF) of Gross Leasable Area (GLA), applicable when commission_type is \'psf_based\'. Common in commercial leasing brokerage.' ;
    rdfs:domain ind:Commission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referralFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Referral Fee Amount' ;
    rdfs:comment 'Dollar amount of referral fees deducted from the gross commission payable to a referring party (agent, broker, or third-party referral source) per a referral agreement. Reduces net commission to house.' ;
    rdfs:domain ind:Commission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggerEvent rdf:type rdf:Property ;
    rdfs:label 'Trigger Event' ;
    rdfs:comment 'The contractual business event that activates the commission obligation: lease execution, property closing, Letter of Intent (LOI) acceptance, tenant occupancy, or loan funding.' ;
    rdfs:domain ind:Commission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerEventDate rdf:type rdf:Property ;
    rdfs:label 'Trigger Event Date' ;
    rdfs:comment 'The date on which the commission trigger event occurred (e.g., lease execution date, closing date, LOI acceptance date), establishing the commission earned date for revenue recognition purposes.' ;
    rdfs:domain ind:Commission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:yardiCommissionCode rdf:type rdf:Property ;
    rdfs:label 'Yardi Commission Code' ;
    rdfs:comment 'Source system identifier for the commission record in Yardi Voyager Accounts Receivable module, used for reconciliation and data lineage.' ;
    rdfs:domain ind:Commission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionSplitId rdf:type rdf:Property ;
    rdfs:label 'Commission Split Id' ;
    rdfs:comment 'Unique surrogate identifier for each commission split disbursement record. Each row represents one payee\'s share of a gross commission and its full payment lifecycle.' ;
    rdfs:domain ind:CommissionSplit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closingStatementId rdf:type rdf:Property ;
    rdfs:label 'Closing Statement Id' ;
    rdfs:comment 'Foreign key linking to transaction.closing_statement. Business justification: Commission splits are funded at closing. Linking commission_split to closing_statement enables reconciliation of each agent\'s split disbursement against the HUD/ALTA closing statement, a standard brok' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClosingStatement .

ind:coBrokerAgreementId rdf:type rdf:Property ;
    rdfs:label 'Co Broker Agreement Id' ;
    rdfs:comment 'Reference to the co-brokerage agreement governing the split terms for an external co-broker firm. Null for in-house agent splits. Links to the executed co-broker contract.' ;
    rdfs:domain ind:Brokerage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CoBrokerAgreement .

ind:disbursingLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Disbursing Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to finance.legal_entity. Business justification: Commission splits are disbursed by a specific legal entity; the is_1099_reportable flag on commission_split confirms IRS 1099-MISC reporting is required. The disbursing legal entity must be identified' ;
    rdfs:domain ind:CommissionSplit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:actualDisbursementDate rdf:type rdf:Property ;
    rdfs:label 'Actual Disbursement Date' ;
    rdfs:comment 'Date on which the commission payment was actually transmitted and confirmed as processed. Null until payment is executed. Used for financial close reconciliation and 1099 reporting.' ;
    rdfs:domain ind:CommissionSplit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bankAccountReference rdf:type rdf:Property ;
    rdfs:label 'Bank Account Reference' ;
    rdfs:comment 'Tokenized or masked reference to the recipient\'s bank account used for ACH or wire disbursement. Actual account details are stored in the secure banking vault; this field holds only the reference token.' ;
    rdfs:domain ind:CommissionSplit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deskFeeDeduction rdf:type rdf:Property ;
    rdfs:label 'Desk Fee Deduction' ;
    rdfs:comment 'Dollar amount of brokerage desk fee or franchise fee deducted from the agent\'s gross split prior to net disbursement. Applicable for desk-fee brokerage models.' ;
    rdfs:domain ind:CommissionSplit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disbursementStatus rdf:type rdf:Property ;
    rdfs:label 'Disbursement Status' ;
    rdfs:comment 'Current lifecycle status of the commission payment for this split record. Drives AP workflow actions and financial reconciliation. [ENUM-REF-CANDIDATE: scheduled|processed|failed|reversed|on_hold|cancelled — promote to reference product]' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorsOmissionsDeduction rdf:type rdf:Property ;
    rdfs:label 'Errors Omissions Deduction' ;
    rdfs:comment 'Dollar amount deducted from the agent\'s commission split for Errors and Omissions (E&O) insurance contribution. Reduces the net disbursement amount.' ;
    rdfs:domain ind:CommissionSplit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:is1099Reportable rdf:type rdf:Property ;
    rdfs:label 'Is 1099 Reportable' ;
    rdfs:comment 'Indicates whether this commission payment is subject to IRS Form 1099-MISC or 1099-NEC reporting. True for independent contractors and co-broker firms; False for W-2 employees.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Override Adjustment Amount' ;
    rdfs:comment 'Dollar amount of any manual override or adjustment applied to the base split amount. May be positive (bonus/incentive) or negative (clawback/deduction). Requires management authorization.' ;
    rdfs:domain ind:CommissionSplit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideReason rdf:type rdf:Property ;
    rdfs:label 'Override Reason' ;
    rdfs:comment 'Narrative explanation for any override adjustment applied to the base split amount. Required for audit trail and management approval documentation.' ;
    rdfs:domain ind:CommissionSplit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Recipient License Number' ;
    rdfs:comment 'State-issued real estate license number of the receiving agent or broker. Required for regulatory compliance verification and brokerage audit documentation.' ;
    rdfs:domain ind:CommissionSplit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientLicenseState rdf:type rdf:Property ;
    rdfs:label 'Recipient License State' ;
    rdfs:comment 'Two-letter US state code where the recipient\'s real estate license is issued. Used for multi-state compliance tracking and license verification.' ;
    rdfs:domain ind:CommissionSplit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientName rdf:type rdf:Property ;
    rdfs:label 'Recipient Name' ;
    rdfs:comment 'Full legal name of the individual agent, co-broker firm, or entity receiving this commission split. Used for 1099 reporting, remittance advices, and audit trails.' ;
    rdfs:domain ind:CommissionSplit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientType rdf:type rdf:Property ;
    rdfs:label 'Recipient Type' ;
    rdfs:comment 'Classification of the payee receiving this commission split. Determines disbursement workflow, 1099 reporting obligations, and GL coding. [ENUM-REF-CANDIDATE: in_house_agent|co_broker_firm|referral_partner|brokerage_house|team_lead|franchise_fee — promote to reference product]' ;
    rdfs:domain ind:CommissionSplit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'Date on which a reversed commission disbursement was officially reversed in the AP system. Null unless disbursement_status is \'reversed\'.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledDisbursementDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Disbursement Date' ;
    rdfs:comment 'Date on which the commission payment is scheduled to be released to the recipient. Used for AP cash flow planning and agent expectation management.' ;
    rdfs:domain ind:CommissionSplit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:splitAmount rdf:type rdf:Property ;
    rdfs:label 'Split Amount' ;
    rdfs:comment 'Gross dollar amount allocated to this recipient based on the split percentage applied to the gross commission. Pre-override base allocation amount.' ;
    rdfs:domain ind:CommissionSplit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:splitNumber rdf:type rdf:Property ;
    rdfs:label 'Split Number' ;
    rdfs:comment 'Sequential line number of this split record within the parent commission. Used to order and identify individual payee allocations within a multi-party commission disbursement.' ;
    rdfs:domain ind:CommissionSplit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:splitPct rdf:type rdf:Property ;
    rdfs:label 'Split Pct' ;
    rdfs:comment 'Contractual percentage of the gross commission allocated to this recipient, expressed as a decimal (e.g., 0.5000 = 50%). Defined by the agent commission plan or co-broker agreement.' ;
    rdfs:domain ind:CommissionSplit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:splitReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Split Reference Number' ;
    rdfs:comment 'Externally visible alphanumeric reference number assigned to this split disbursement record, used in AP workflows, remittance advices, and audit correspondence.' ;
    rdfs:domain ind:CommissionSplit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdReference rdf:type rdf:Property ;
    rdfs:label 'Tax Id Reference' ;
    rdfs:comment 'Tokenized reference to the recipient\'s IRS Tax Identification Number (TIN/EIN/SSN) used for 1099 reporting. Actual TIN is stored in the secure tax vault; this field holds only the reference token.' ;
    rdfs:domain ind:CommissionSplit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCloseDate rdf:type rdf:Property ;
    rdfs:label 'Transaction Close Date' ;
    rdfs:comment 'Date on which the underlying real estate transaction (sale or lease execution) closed, triggering the commission earning event. The principal business event timestamp for this commission split.' ;
    rdfs:domain ind:CommissionSplit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:withholdingAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Amount' ;
    rdfs:comment 'Dollar amount of IRS backup withholding deducted from the commission disbursement when the recipient has not provided a valid TIN or is subject to backup withholding per IRS rules.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yardiApTransactionRef rdf:type rdf:Property ;
    rdfs:label 'Yardi Ap Transaction Ref' ;
    rdfs:comment 'Yardi Voyager Accounts Payable transaction identifier for this commission disbursement. Provides the financial system audit trail linking the commission split to the GL posting and AP check run.' ;
    rdfs:domain ind:CommissionSplit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coBrokerCommissionFlatFee rdf:type rdf:Property ;
    rdfs:label 'Co Broker Commission Flat Fee' ;
    rdfs:comment 'Fixed flat-fee dollar amount agreed as the co-broker commission, used when the arrangement is structured as a flat fee rather than a percentage split. Nullable when percentage-based structure applies.' ;
    rdfs:domain ind:CoBrokerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coBrokerCommissionSplitPct rdf:type rdf:Property ;
    rdfs:label 'Co Broker Commission Split Pct' ;
    rdfs:comment 'Agreed percentage of the total gross commission to be paid to the cooperating broker firm upon successful transaction close. Expressed as a decimal (e.g., 0.5000 = 50%). Governs commission disbursement in Yardi Voyager AR.' ;
    rdfs:domain ind:CoBrokerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionPaidDate rdf:type rdf:Property ;
    rdfs:label 'Commission Paid Date' ;
    rdfs:comment 'Date on which the co-broker commission was disbursed to the cooperating broker firm. Nullable until payment is made. Reconciled against Yardi Voyager General Ledger.' ;
    rdfs:domain ind:CoBrokerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commissionPaidFlag rdf:type rdf:Property ;
    rdfs:label 'Commission Paid Flag' ;
    rdfs:comment 'Indicates whether the co-broker commission has been disbursed following transaction close. True = commission paid; False = pending payment. Supports Yardi Voyager AP commission disbursement tracking.' ;
    rdfs:domain ind:CoBrokerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cooperatingFirmLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Cooperating Firm License Number' ;
    rdfs:comment 'State-issued real estate brokerage license number for the cooperating firm. Required for regulatory compliance and commission disbursement validation.' ;
    rdfs:domain ind:CoBrokerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cooperatingFirmLicenseState rdf:type rdf:Property ;
    rdfs:label 'Cooperating Firm License State' ;
    rdfs:comment 'Two-letter US state code in which the cooperating broker firm holds its primary real estate brokerage license (e.g., CA, NY, TX).' ;
    rdfs:domain ind:CoBrokerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cooperatingFirmName rdf:type rdf:Property ;
    rdfs:label 'Cooperating Firm Name' ;
    rdfs:comment 'Legal registered name of the cooperating (co-broker) brokerage firm participating in this arrangement. Sourced from Salesforce CRM and verified against state licensing records.' ;
    rdfs:domain ind:CoBrokerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designatedAgentEmail rdf:type rdf:Property ;
    rdfs:label 'Designated Agent Email' ;
    rdfs:comment 'Primary business email address for the designated cooperating agent, used for deal communications, DocuSign CLM routing, and Salesforce CRM contact management.' ;
    rdfs:domain ind:CoBrokerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designatedAgentLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Designated Agent License Number' ;
    rdfs:comment 'State-issued individual real estate salesperson or broker license number for the designated cooperating agent. Required for commission payment and regulatory compliance.' ;
    rdfs:domain ind:CoBrokerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designatedAgentLicenseState rdf:type rdf:Property ;
    rdfs:label 'Designated Agent License State' ;
    rdfs:comment 'Two-letter US state code in which the designated cooperating agent holds their individual real estate license.' ;
    rdfs:domain ind:CoBrokerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designatedAgentName rdf:type rdf:Property ;
    rdfs:label 'Designated Agent Name' ;
    rdfs:comment 'Full legal name of the individual real estate agent designated by the cooperating broker firm to represent the co-broker side of this transaction.' ;
    rdfs:domain ind:CoBrokerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designatedAgentPhone rdf:type rdf:Property ;
    rdfs:label 'Designated Agent Phone' ;
    rdfs:comment 'Primary business phone number for the designated cooperating agent for deal coordination and showing scheduling.' ;
    rdfs:domain ind:CoBrokerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Method' ;
    rdfs:comment 'Contractually agreed method for resolving disputes arising from this co-brokerage arrangement, as specified in the agreement terms.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlsCooperationFlag rdf:type rdf:Property ;
    rdfs:label 'Mls Cooperation Flag' ;
    rdfs:comment 'Indicates whether this co-brokerage arrangement is governed by MLS cooperation rules and the cooperating broker was procured through MLS. True = MLS cooperation applies; False = off-MLS or private arrangement.' ;
    rdfs:domain ind:CoBrokerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sndaExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Snda Execution Date' ;
    rdfs:comment 'Date on which the required SNDA agreement was executed, confirming lender consent to the co-brokerage arrangement. Nullable when SNDA is not required.' ;
    rdfs:domain ind:CoBrokerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sndaRequired rdf:type rdf:Property ;
    rdfs:label 'Snda Required' ;
    rdfs:comment 'Indicates whether a Subordination, Non-Disturbance and Attornment (SNDA) agreement is required as a condition of this co-brokerage arrangement, typically applicable in commercial lease transactions.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryMarketGeographicHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Primary Market Geographic Hierarchy Id' ;
    rdfs:comment 'Foreign key linking to reference.geographic_hierarchy. Business justification: Broker territory management, deal assignment, and production reporting require a structured geographic hierarchy reference for each broker\'s primary market area. The existing designated_market_areas p' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeographicHierarchy .

ind:specializationPropertyTypeId rdf:type rdf:Property ;
    rdfs:label 'Specialization Property Type Id' ;
    rdfs:comment 'Foreign key linking to reference.property_type. Business justification: Broker performance reporting, deal assignment, and MLS board membership tracking require structured property type specialization for each broker. The existing plain-text specialization column is a den' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PropertyType .

ind:backgroundCheckDate rdf:type rdf:Property ;
    rdfs:label 'Background Check Date' ;
    rdfs:comment 'Date the most recent background check was completed for the broker. Used to determine recency of compliance verification and schedule periodic re-checks per brokerage policy.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backgroundCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Background Check Status' ;
    rdfs:comment 'Status of the broker\'s most recent background check conducted as part of onboarding or periodic compliance review. Required for NAR membership, state licensing, and brokerage risk management.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerType rdf:type rdf:Property ;
    rdfs:label 'Broker Type' ;
    rdfs:comment 'Classification of the broker\'s role and authority level within the brokerage. Determines supervisory responsibilities, permissible transaction types, and commission split eligibility. [ENUM-REF-CANDIDATE: principal_broker|managing_broker|associate_broker|leasing_agent|buyers_agent|sellers_agent — promote to reference product]' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccimDesignation rdf:type rdf:Property ;
    rdfs:label 'Ccim Designation' ;
    rdfs:comment 'Indicates whether the broker holds the CCIM designation from the CCIM Institute, signifying advanced expertise in commercial and investment real estate. Used for deal team assembly and marketing credentials.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:continuingEducationDueDate rdf:type rdf:Property ;
    rdfs:label 'Continuing Education Due Date' ;
    rdfs:comment 'Date by which the broker must complete state-mandated continuing education (CE) credits to maintain their real estate license. Used to trigger CE completion reminders and license renewal workflows.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:continuingEducationHoursCompleted rdf:type rdf:Property ;
    rdfs:label 'Continuing Education Hours Completed' ;
    rdfs:comment 'Number of continuing education (CE) credit hours completed by the broker in the current license renewal cycle. Tracked against state-mandated CE requirements for license renewal compliance.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dualAgencyAuthorized rdf:type rdf:Property ;
    rdfs:label 'Dual Agency Authorized' ;
    rdfs:comment 'Indicates whether the broker is authorized to act as a dual agent (representing both buyer/tenant and seller/landlord in the same transaction) per state law and brokerage policy. Drives compliance checks on deal assignments.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employmentType rdf:type rdf:Property ;
    rdfs:label 'Employment Type' ;
    rdfs:comment 'Classification of the broker\'s employment relationship with the brokerage. Determines payroll processing method (W-2 via ADP vs. 1099 independent contractor), benefits eligibility, and commission payout structure.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorsOmissionsExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Errors Omissions Expiration Date' ;
    rdfs:comment 'Expiration date of the broker\'s E&O insurance policy. Used to trigger renewal alerts and enforce compliance gates before deal assignment or listing agreement execution.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:errorsOmissionsInsurer rdf:type rdf:Property ;
    rdfs:label 'Errors Omissions Insurer' ;
    rdfs:comment 'Name of the insurance carrier providing Errors and Omissions (E&O) professional liability coverage for the broker. Required for brokerage compliance and risk management. Tracked for policy renewal monitoring.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorsOmissionsPolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Errors Omissions Policy Number' ;
    rdfs:comment 'Policy number for the broker\'s Errors and Omissions (E&O) professional liability insurance. Required for compliance verification, co-broker agreements, and listing agreement execution.' ;
    rdfs:domain ind:Brokerage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gciPriorYear rdf:type rdf:Property ;
    rdfs:label 'Gci Prior Year' ;
    rdfs:comment 'Total Gross Commission Income (GCI) earned by the broker in the prior full calendar or fiscal year. Used for year-over-year production benchmarking, tier assignment at year-start, and historical performance analytics.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gciYtd rdf:type rdf:Property ;
    rdfs:label 'Gci Ytd' ;
    rdfs:comment 'Total Gross Commission Income (GCI) earned by the broker in the current calendar or fiscal year to date. Used for production tier evaluation, commission plan threshold tracking, and annual performance reporting. Sourced from closed transaction records.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'Date the broker was formally engaged by the brokerage, either as a W-2 employee or 1099 independent contractor. Used for tenure calculations, production tier eligibility, and commission plan assignment.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether the broker is currently active and eligible to be assigned to deals, listings, showings, and prospect records. Set to false upon termination, license suspension, or voluntary leave.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mlsBoardName rdf:type rdf:Property ;
    rdfs:label 'Mls Board Name' ;
    rdfs:comment 'Name of the MLS board or association through which the broker holds membership. Determines listing syndication scope, co-broker cooperation rules, and MLS data feed access.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlsMemberNumber rdf:type rdf:Property ;
    rdfs:label 'Mls Member Number' ;
    rdfs:comment 'Unique membership identifier assigned by the broker\'s primary Multiple Listing Service (MLS) board. Required for listing syndication, MLS data access, and co-broker cooperation agreements.' ;
    rdfs:domain ind:Brokerage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mriAgentCode rdf:type rdf:Property ;
    rdfs:label 'Mri Agent Code' ;
    rdfs:comment 'Agent or broker code assigned in MRI Software for lease management and residential management commission tracking. Used for cross-system reconciliation of commission payouts.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:narMemberNumber rdf:type rdf:Property ;
    rdfs:label 'Nar Member Number' ;
    rdfs:comment 'NAR-assigned membership number confirming the broker holds active REALTOR® designation. Required for MLS access, NAR Code of Ethics compliance, and use of the REALTOR® trademark.' ;
    rdfs:domain ind:Brokerage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeLocation rdf:type rdf:Property ;
    rdfs:label 'Office Location' ;
    rdfs:comment 'Name or code of the brokerage office or branch to which the broker is physically assigned. Used for geographic market coverage reporting, desk assignment, and regional production analytics.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionTier rdf:type rdf:Property ;
    rdfs:label 'Production Tier' ;
    rdfs:comment 'Broker\'s current production tier classification based on Gross Commission Income (GCI) thresholds defined in the commission plan. Determines commission split rates, marketing support eligibility, and recognition program participation.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceUserCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce User Code' ;
    rdfs:comment 'Unique user identifier assigned to the broker in Salesforce CRM. Used to link deal pipeline records, prospect assignments, showing activity, and brokerage opportunity stages to the broker master record.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siorDesignation rdf:type rdf:Property ;
    rdfs:label 'Sior Designation' ;
    rdfs:comment 'Indicates whether the broker holds the SIOR designation, signifying top-tier expertise in industrial and office commercial real estate. Used for deal team assembly and client-facing credentials.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:teamName rdf:type rdf:Property ;
    rdfs:label 'Team Name' ;
    rdfs:comment 'Name of the brokerage team or desk to which the broker is assigned. Teams share leads, listings, and commission splits. Used for production reporting, deal routing, and organizational hierarchy in Salesforce CRM.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionSide rdf:type rdf:Property ;
    rdfs:label 'Transaction Side' ;
    rdfs:comment 'Indicates whether the broker primarily operates on the buy-side (tenant/buyer representation), sell-side (landlord/seller representation), or both. Used for deal pipeline segmentation and commission structure determination.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yardiAgentCode rdf:type rdf:Property ;
    rdfs:label 'Yardi Agent Code' ;
    rdfs:comment 'Agent or broker code assigned in Yardi Voyager for lease administration and accounts receivable commission tracking. Used to reconcile commission payables and link broker activity to property management records.' ;
    rdfs:domain ind:Brokerage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerLicenseId rdf:type rdf:Property ;
    rdfs:label 'Broker License Id' ;
    rdfs:comment 'Unique surrogate identifier for each broker or agent license record in the system. Primary key for the broker_license data product.' ;
    rdfs:domain ind:BrokerLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licenseGeographicHierarchyId rdf:type rdf:Property ;
    rdfs:label 'License Geographic Hierarchy Id' ;
    rdfs:comment 'Foreign key linking to reference.geographic_hierarchy. Business justification: Broker license compliance reporting and reciprocal license tracking require geographic hierarchy to map license jurisdiction to market areas. The issuing_state and primary_practice_state plain-text fi' ;
    rdfs:domain ind:BrokerLicense ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeographicHierarchy .

ind:ceComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Ce Compliance Status' ;
    rdfs:comment 'Current compliance status for continuing education (CE) requirements in the current renewal cycle. Deficient status triggers remediation workflows. Waived status applies when a state grants an exemption (e.g., first-time renewal, military service).' ;
    rdfs:domain ind:BrokerLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Ce Deadline Date' ;
    rdfs:comment 'The date by which all required continuing education (CE) hours must be completed for the current renewal cycle. Typically aligns with or precedes the license expiration date. Drives CE completion alerts and compliance reporting.' ;
    rdfs:domain ind:BrokerLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ceHoursCompleted rdf:type rdf:Property ;
    rdfs:label 'Ce Hours Completed' ;
    rdfs:comment 'Total number of continuing education (CE) hours completed by the agent in the current renewal cycle. Compared against ce_hours_required to determine CE compliance status. Sourced from state CE tracking systems.' ;
    rdfs:domain ind:BrokerLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ceHoursRequired rdf:type rdf:Property ;
    rdfs:label 'Ce Hours Required' ;
    rdfs:comment 'Total number of continuing education (CE) hours required by the issuing state for the current renewal cycle. Varies by state and license type. Used to track CE compliance obligations.' ;
    rdfs:domain ind:BrokerLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disciplinaryActionDate rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Action Date' ;
    rdfs:comment 'The date on which the most recent disciplinary action was recorded or imposed by the regulatory authority. Populated only when disciplinary_flag is True. Used for compliance timeline tracking.' ;
    rdfs:domain ind:BrokerLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disciplinaryActionType rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Action Type' ;
    rdfs:comment 'Type of disciplinary action recorded against this license. Populated only when disciplinary_flag is True. Used for compliance risk scoring and regulatory reporting to NAR and state commissions.' ;
    rdfs:domain ind:BrokerLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disciplinaryFlag rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Flag' ;
    rdfs:comment 'Indicates whether the agent has an active or historical disciplinary action, complaint, or sanction on record with the issuing state commission or NAR. True triggers compliance review before deal assignment or listing authorization.' ;
    rdfs:domain ind:BrokerLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:errorsOmissionsExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Errors Omissions Expiry Date' ;
    rdfs:comment 'Expiration date of the agent\'s Errors and Omissions (E&O) insurance policy. Drives automated alerts for policy renewal to ensure continuous coverage and brokerage compliance.' ;
    rdfs:domain ind:BrokerLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:errorsOmissionsInsured rdf:type rdf:Property ;
    rdfs:label 'Errors Omissions Insured' ;
    rdfs:comment 'Indicates whether the agent holds active Errors and Omissions (E&O) professional liability insurance coverage. E&O insurance is required by many brokerages and some states as a condition of active licensure. Supports risk management and brokerage compliance.' ;
    rdfs:domain ind:BrokerLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'The date on which the license was originally issued by the regulatory authority. Used to calculate license tenure, renewal cycles, and continuing education (CE) compliance windows.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'Full name of the state real estate commission or regulatory body that issued the license (e.g., California Department of Real Estate, New York Department of State Division of Licensing Services). Supports regulatory correspondence and audit trails.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseClass rdf:type rdf:Property ;
    rdfs:label 'License Class' ;
    rdfs:comment 'Indicates whether the license authorizes residential brokerage, commercial real estate (CRE) brokerage, or both. Determines which transaction types and listings the agent is authorized to handle under this license.' ;
    rdfs:domain ind:BrokerLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseEndorsements rdf:type rdf:Property ;
    rdfs:label 'License Endorsements' ;
    rdfs:comment 'Comma-separated list of specialty endorsements or designations attached to this license (e.g., ABR — Accredited Buyer\'s Representative, CRS — Certified Residential Specialist, CCIM — Certified Commercial Investment Member, SIOR). Supports agent capability matching for deal assignments.' ;
    rdfs:domain ind:BrokerLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseNotes rdf:type rdf:Property ;
    rdfs:label 'License Notes' ;
    rdfs:comment 'Free-text field for compliance officers or brokerage administrators to record additional context about this license record, such as pending reinstatement conditions, special restrictions, or correspondence with the state commission.' ;
    rdfs:domain ind:BrokerLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'The official license number assigned by the issuing state or regulatory authority. Used for NAR compliance verification, MLS access, and co-broker arrangement validation. Corresponds to the license number tracked in Salesforce CRM brokerage activity records.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseStatus rdf:type rdf:Property ;
    rdfs:label 'License Status' ;
    rdfs:comment 'Current lifecycle status of the license as reported by the issuing authority. Active licenses are required for brokerage activity. Suspended or revoked licenses trigger compliance flags and must be reported to NAR and state commissions.' ;
    rdfs:domain ind:BrokerLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseType rdf:type rdf:Property ;
    rdfs:label 'License Type' ;
    rdfs:comment 'Classification of the license held by the agent or broker, indicating their level of authority and responsibility. Salesperson licenses require broker supervision; broker and managing broker licenses allow independent practice and supervision of others.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseVerificationDate rdf:type rdf:Property ;
    rdfs:label 'License Verification Date' ;
    rdfs:comment 'The most recent date on which the license status was verified against the issuing state commission\'s public license lookup or ARELLO (Association of Real Estate License Law Officials) database. Supports ongoing compliance monitoring.' ;
    rdfs:domain ind:BrokerLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseVerificationSource rdf:type rdf:Property ;
    rdfs:label 'License Verification Source' ;
    rdfs:comment 'The source used to verify the license status during the most recent verification. State portal refers to the issuing state\'s online license lookup; ARELLO is the national license law officials database; manual indicates staff-verified; third_party indicates a vendor verification service.' ;
    rdfs:domain ind:BrokerLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalIssueDate rdf:type rdf:Property ;
    rdfs:label 'Original Issue Date' ;
    rdfs:comment 'The date the license was first ever issued to this agent in this jurisdiction, regardless of subsequent renewals. Distinct from issue_date which reflects the current license term start. Used to calculate total years licensed in a state for seniority and compliance reporting.' ;
    rdfs:domain ind:BrokerLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reciprocalHomeState rdf:type rdf:Property ;
    rdfs:label 'Reciprocal Home State' ;
    rdfs:comment 'Two-letter US state code of the agent\'s primary licensing state from which reciprocity was granted. Populated only when reciprocal_license is True. Required for multi-state compliance tracking.' ;
    rdfs:domain ind:BrokerLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reciprocalLicense rdf:type rdf:Property ;
    rdfs:label 'Reciprocal License' ;
    rdfs:comment 'Indicates whether this license was obtained through a reciprocity agreement between states, rather than by passing the full state licensing examination. Reciprocal licenses may carry additional restrictions in some jurisdictions.' ;
    rdfs:domain ind:BrokerLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'The date on which the license was most recently renewed by the issuing authority. Null if the license has never been renewed (original issuance still active). Supports renewal cycle tracking and CE compliance verification.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'Current status of the license renewal process. Tracks whether a renewal application has been initiated, submitted to the state commission, approved, or lapsed due to non-action before the expiration date.' ;
    rdfs:domain ind:BrokerLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceContactCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Contact Code' ;
    rdfs:comment 'The unique identifier of the corresponding agent or broker contact record in Salesforce CRM. Enables cross-system traceability between the broker license compliance record and the CRM brokerage activity tracking profile.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsoringBrokerLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Sponsoring Broker License Number' ;
    rdfs:comment 'The official license number of the sponsoring broker or brokerage firm. Used to validate the sponsorship relationship with the state commission and to cross-reference brokerage firm licensing records.' ;
    rdfs:domain ind:BrokerLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsoringBrokerName rdf:type rdf:Property ;
    rdfs:label 'Sponsoring Broker Name' ;
    rdfs:comment 'The name of the licensed broker or brokerage firm under whose sponsorship this salesperson or associate broker license is held. Required for salesperson-level licenses in most states. Null for independent broker licenses.' ;
    rdfs:domain ind:BrokerLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralId rdf:type rdf:Property ;
    rdfs:label 'Referral Id' ;
    rdfs:comment 'Unique system-generated identifier for the referral record. Primary key for the brokerage.referral data product.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualDealValue rdf:type rdf:Property ;
    rdfs:label 'Actual Deal Value' ;
    rdfs:comment 'Final closed transaction value (sale price or total lease value) of the referred deal upon closing, used for accurate fee calculation.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agreementDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Date' ;
    rdfs:comment 'The date on which the referral agreement was formally executed between the brokerage and the referring or receiving party.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dealCloseDate rdf:type rdf:Property ;
    rdfs:label 'Deal Close Date' ;
    rdfs:comment 'Date on which the referred deal was formally closed (sale completed or lease executed), triggering the referral fee obligation.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dealOutcome rdf:type rdf:Property ;
    rdfs:label 'Deal Outcome' ;
    rdfs:comment 'Final outcome of the referred deal, indicating whether it closed successfully, was lost to competition, remains pending, or was withdrawn.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:direction rdf:type rdf:Property ;
    rdfs:label 'Direction' ;
    rdfs:comment 'Indicates whether the referral is inbound (an external party referring a prospect to this brokerage) or outbound (this brokerage referring a prospect to an external party).' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDealValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Deal Value' ;
    rdfs:comment 'Estimated transaction value (sale price or total lease value) of the referred deal at the time of referral, used for pipeline forecasting and fee estimation.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Amount' ;
    rdfs:comment 'Calculated or agreed referral fee amount payable to or receivable from the referring party, derived from fee_pct applied to GCI or the flat fee amount.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeFlatAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Flat Amount' ;
    rdfs:comment 'Fixed dollar amount agreed upon as the referral fee, applicable when fee_structure is \'flat_fee\'.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feePaidDate rdf:type rdf:Property ;
    rdfs:label 'Fee Paid Date' ;
    rdfs:comment 'Date on which the referral fee was disbursed to the referring party or received from the receiving party, confirming payment completion.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feePct rdf:type rdf:Property ;
    rdfs:label 'Fee Pct' ;
    rdfs:comment 'Referral fee expressed as a percentage of the gross commission income (GCI) earned on the referred deal. Applicable when fee_structure is \'percentage\'. Stored as a decimal (e.g., 0.2500 = 25%).' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeStructure rdf:type rdf:Property ;
    rdfs:label 'Fee Structure' ;
    rdfs:comment 'Indicates whether the referral fee is calculated as a percentage of the commission, a flat dollar amount, or a tiered schedule.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossCommissionIncome rdf:type rdf:Property ;
    rdfs:label 'Gross Commission Income' ;
    rdfs:comment 'Total gross commission income (GCI) earned by the brokerage on the referred deal, from which the referral fee is calculated.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isReciprocal rdf:type rdf:Property ;
    rdfs:label 'Is Reciprocal' ;
    rdfs:comment 'Indicates whether this referral is part of a reciprocal arrangement where both parties agree to exchange referrals mutually.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentDirection rdf:type rdf:Property ;
    rdfs:label 'Payment Direction' ;
    rdfs:comment 'Indicates whether the referral fee is payable by this brokerage to an external party (outbound referral) or receivable from an external party (inbound referral).' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralNumber rdf:type rdf:Property ;
    rdfs:label 'Referral Number' ;
    rdfs:comment 'Externally-known business identifier for the referral, used in correspondence, agreements, and commission tracking. Format: REF-YYYY-NNNNNN.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralStatus rdf:type rdf:Property ;
    rdfs:label 'Referral Status' ;
    rdfs:comment 'Current lifecycle state of the referral arrangement. [ENUM-REF-CANDIDATE: pending|active|closed|paid|cancelled|expired — promote to reference product]' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralType rdf:type rdf:Property ;
    rdfs:label 'Referral Type' ;
    rdfs:comment 'Categorizes the source or channel of the referral arrangement. [ENUM-REF-CANDIDATE: broker|relocation|affinity_network|corporate|online_lead|other — promote to reference product]' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referringBrokerLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Referring Broker License Number' ;
    rdfs:comment 'State-issued real estate broker or agent license number of the referring party, required for regulatory compliance and commission disbursement.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referringBrokerLicenseState rdf:type rdf:Property ;
    rdfs:label 'Referring Broker License State' ;
    rdfs:comment 'Two-letter US state code in which the referring broker or agent holds their real estate license.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referringFirmName rdf:type rdf:Property ;
    rdfs:label 'Referring Firm Name' ;
    rdfs:comment 'Name of the brokerage firm, relocation company, affinity network, or organization from which the referral originates.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referringPartyName rdf:type rdf:Property ;
    rdfs:label 'Referring Party Name' ;
    rdfs:comment 'Full legal name of the individual or entity that originated the referral (e.g., the referring broker, relocation company representative, or affinity network contact).' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceDealStage rdf:type rdf:Property ;
    rdfs:label 'Salesforce Deal Stage' ;
    rdfs:comment 'Current CRM pipeline stage of the referred deal as tracked in Salesforce (e.g., Prospect, Qualified, LOI Submitted, Under Contract, Closed). Reflects the deal progression from prospect to close.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceReferralCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Referral Code' ;
    rdfs:comment 'Unique identifier of the corresponding referral or opportunity record in Salesforce CRM, enabling cross-system traceability.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceNetwork rdf:type rdf:Property ;
    rdfs:label 'Source Network' ;
    rdfs:comment 'Name of the referral network, relocation program, or affinity organization through which the referral was channeled (e.g., Leading RE, Cartus, USAA MoversAdvantage).' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingLeadId rdf:type rdf:Property ;
    rdfs:label 'Originating Lead Id' ;
    rdfs:comment 'Foreign key linking to marketing.lead. Business justification: Lead-to-representation conversion is a named pipeline KPI in real estate CRM: tracking which marketing lead converted into a signed buyer representation agreement is required for marketing ROI and age' ;
    rdfs:domain ind:BuyerRepresentation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lead .

ind:targetBuildingClassId rdf:type rdf:Property ;
    rdfs:label 'Target Building Class Id' ;
    rdfs:comment 'Foreign key linking to reference.building_class. Business justification: Buyer/tenant representation search criteria and property matching require building class specification to filter suitable properties. Representation agreements explicitly define target building class ' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BuildingClass .

ind:targetSubmarketGeographicHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Target Submarket Geographic Hierarchy Id' ;
    rdfs:comment 'Foreign key linking to reference.geographic_hierarchy. Business justification: Target market and submarket in a buyer rep agreement define the geographic scope of representation and drive listing search, broker territory assignment, and market demand analytics. Role prefix \'targ' ;
    rdfs:domain ind:BuyerRepresentation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeographicHierarchy .

ind:clientType rdf:type rdf:Property ;
    rdfs:label 'Client Type' ;
    rdfs:comment 'Legal entity classification of the buyer or tenant client being represented. Informs KYC/AML obligations and commission structuring. [ENUM-REF-CANDIDATE: individual|corporation|partnership|llc|reit|trust|government|other — promote to reference product]' ;
    rdfs:domain ind:BuyerRepresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxBudget rdf:type rdf:Property ;
    rdfs:label 'Max Budget' ;
    rdfs:comment 'Maximum purchase price or total lease commitment budget the client is authorized to commit to, as disclosed in the representation agreement.' ;
    rdfs:domain ind:BuyerRepresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxLeaseRatePsf rdf:type rdf:Property ;
    rdfs:label 'Max Lease Rate Psf' ;
    rdfs:comment 'Maximum annual or monthly lease rate per square foot the tenant client is willing to pay, used as a search filter criterion in tenant representation engagements.' ;
    rdfs:domain ind:BuyerRepresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxLeaseTermMonths rdf:type rdf:Property ;
    rdfs:label 'Max Lease Term Months' ;
    rdfs:comment 'Maximum lease term in months the tenant client is willing to commit to.' ;
    rdfs:domain ind:BuyerRepresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minBudget rdf:type rdf:Property ;
    rdfs:label 'Min Budget' ;
    rdfs:comment 'Minimum purchase price or total lease commitment budget the client is prepared to consider, expressed in the agreement currency.' ;
    rdfs:domain ind:BuyerRepresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minLeaseTermMonths rdf:type rdf:Property ;
    rdfs:label 'Min Lease Term Months' ;
    rdfs:comment 'Minimum acceptable lease term in months that the tenant client is willing to commit to, used as a search filter in tenant representation.' ;
    rdfs:domain ind:BuyerRepresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:representationType rdf:type rdf:Property ;
    rdfs:label 'Representation Type' ;
    rdfs:comment 'Classification of the brokerage engagement type: exclusive buyer representation, exclusive tenant representation, non-exclusive buyer representation, non-exclusive tenant representation, or dual agency. Governs the scope of fiduciary duty and exclusivity obligations.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPropertyUse rdf:type rdf:Property ;
    rdfs:label 'Target Property Use' ;
    rdfs:comment 'Intended use of the target property by the buyer or tenant client, distinguishing between owner-occupied, investment, owner-user, or redevelopment purposes.' ;
    rdfs:domain ind:BuyerRepresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingGeographicHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Billing Geographic Hierarchy Id' ;
    rdfs:comment 'Foreign key linking to reference.geographic_hierarchy. Business justification: Tenant billing address geographic hierarchy enables market-level tenant reporting, regulatory jurisdiction assignment for tax and compliance, and portfolio segmentation by submarket. Role-prefixed \'bi' ;
    rdfs:domain ind:Tenant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeographicHierarchy .

ind:corporateEntityId rdf:type rdf:Property ;
    rdfs:label 'Corporate Entity Id' ;
    rdfs:comment 'Foreign key linking to tenant.corporate_entity. Business justification: B2B tenant profiles represent corporate tenants whose legal entity details are mastered in corporate_entity. tenant.entity_type distinguishes corporate from individual tenants. Linking tenant.corporat' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorporateEntity .

ind:incorporationCountryId rdf:type rdf:Property ;
    rdfs:label 'Incorporation Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Tenant incorporation country is required for KYC/AML compliance, foreign ownership restriction checks, tax treaty applicability, and FATF risk assessment. \'incorporation_country\' is a denormalized cou' ;
    rdfs:domain ind:Tenant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:annualRevenue rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue' ;
    rdfs:comment 'Most recently reported annual gross revenue of the corporate tenant in USD. Used for commercial lease underwriting, rent-to-revenue ratio analysis, and portfolio credit risk assessment. Null for residential individual tenants.' ;
    rdfs:domain ind:Tenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingAddressCity rdf:type rdf:Property ;
    rdfs:label 'Billing Address City' ;
    rdfs:comment 'City component of the tenant\'s billing address. Used in conjunction with billing_address_line1, billing_address_state, billing_address_postal_code, and billing_address_country for complete invoice addressing.' ;
    rdfs:domain ind:Tenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressCountry rdf:type rdf:Property ;
    rdfs:label 'Billing Address Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the tenant\'s billing address. Required for international tenant invoicing, VAT/GST determination, and FATCA/CRS cross-border reporting.' ;
    rdfs:domain ind:Tenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line1' ;
    rdfs:comment 'First line of the tenant\'s billing address used for invoice delivery, rent statements, and CAM reconciliation notices. May differ from the occupied premises address for corporate tenants with centralised accounts payable.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Address Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the tenant\'s billing address. Used for geographic segmentation, tax jurisdiction mapping, and mail delivery of rent statements and legal notices.' ;
    rdfs:domain ind:Tenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressState rdf:type rdf:Property ;
    rdfs:label 'Billing Address State' ;
    rdfs:comment 'State or province component of the tenant\'s billing address. Used for state tax nexus determination, sales tax applicability on CAM charges, and jurisdictional compliance reporting.' ;
    rdfs:domain ind:Tenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditScore rdf:type rdf:Property ;
    rdfs:label 'Credit Score' ;
    rdfs:comment 'Numeric credit score obtained from a third-party credit bureau (e.g., Experian, Equifax, TransUnion) or commercial credit agency (e.g., Dun & Bradstreet PAYDEX). Used for residential applicant screening and commercial tenant underwriting. Range typically 300–850 for consumer; 0–100 for commercial PAYDEX.' ;
    rdfs:domain ind:Tenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditScoreDate rdf:type rdf:Property ;
    rdfs:label 'Credit Score Date' ;
    rdfs:comment 'Date on which the most recent credit score was obtained. Used to determine whether the credit assessment is current (typically valid for 90 days for residential, 12 months for commercial) and to trigger re-screening workflows.' ;
    rdfs:domain ind:Tenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditTier rdf:type rdf:Property ;
    rdfs:label 'Credit Tier' ;
    rdfs:comment 'Internal credit quality classification assigned to the tenant following underwriting review. Tier A represents investment-grade or highest creditworthiness; Tier D represents sub-investment-grade or high-risk. Drives lease security deposit requirements, guarantor obligations, and portfolio risk reporting.' ;
    rdfs:domain ind:Tenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmAccountCode rdf:type rdf:Property ;
    rdfs:label 'Crm Account Code' ;
    rdfs:comment 'Salesforce CRM Account record identifier linked to this tenant or prospect. Enables bi-directional synchronization of deal pipeline, contact activity, and tenant relationship data between the CRM and the property management system.' ;
    rdfs:domain ind:Tenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotContact rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact' ;
    rdfs:comment 'Indicates that the tenant has opted out of non-essential marketing and promotional communications. When True, outbound CRM campaigns and marketing emails must be suppressed. Does not suppress legally required notices (rent demands, eviction notices).' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeeCount rdf:type rdf:Property ;
    rdfs:label 'Employee Count' ;
    rdfs:comment 'Approximate number of employees of the corporate tenant at the time of lease underwriting. Used to assess space utilisation requirements, parking demand, and building amenity capacity planning. Null for residential tenants.' ;
    rdfs:domain ind:Tenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:esgConsentGiven rdf:type rdf:Property ;
    rdfs:label 'Esg Consent Given' ;
    rdfs:comment 'Indicates whether the tenant has provided consent to share utility consumption, energy usage, and sustainability data for ESG reporting purposes. Required for LEED, BREEAM, and GRESB portfolio-level sustainability disclosures. Drives data sharing agreements with utility providers.' ;
    rdfs:domain ind:Tenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstLeaseStartDate rdf:type rdf:Property ;
    rdfs:label 'First Lease Start Date' ;
    rdfs:comment 'Date on which the tenant\'s earliest lease with the enterprise commenced. Used to calculate total tenure, loyalty tier classification, and long-term tenant relationship analytics. Populated from Yardi Voyager lease history.' ;
    rdfs:domain ind:Tenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guarantorRequired rdf:type rdf:Property ;
    rdfs:label 'Guarantor Required' ;
    rdfs:comment 'Indicates whether a personal or corporate guarantor is required as a condition of the lease based on the tenant\'s credit tier or underwriting outcome. When True, a guaranty agreement must be executed prior to lease commencement.' ;
    rdfs:domain ind:Tenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hoaCode rdf:type rdf:Property ;
    rdfs:label 'Hoa Code' ;
    rdfs:comment 'Membership identifier assigned by the Homeowners Association (HOA) to the residential tenant. Used to reconcile HOA dues payments, violation notices, and community access credentials. Null when hoa_member is False.' ;
    rdfs:domain ind:Tenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hoaMember rdf:type rdf:Property ;
    rdfs:label 'Hoa Member' ;
    rdfs:comment 'Indicates whether the residential tenant is subject to a Homeowners Association (HOA) membership obligation as part of their occupancy agreement. When True, HOA dues, rules, and compliance obligations are tracked separately. Applicable to residential portfolio only.' ;
    rdfs:domain ind:Tenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incorporationState rdf:type rdf:Property ;
    rdfs:label 'Incorporation State' ;
    rdfs:comment 'U.S. state (or equivalent jurisdiction) in which the corporate tenant is legally incorporated or registered. Used for entity verification, lien searches, and compliance with state-specific landlord-tenant statutes. Null for individual/residential tenants.' ;
    rdfs:domain ind:Tenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseCount rdf:type rdf:Property ;
    rdfs:label 'Lease Count' ;
    rdfs:comment 'Number of currently active lease agreements associated with this tenant across the portfolio. Supports multi-tenancy analytics, portfolio concentration risk reporting, and WALT/WALE calculations. Derived from the lease domain but stored here as a denormalised operational indicator for CRM and AM dashboards.' ;
    rdfs:domain ind:Tenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'Current stage of the tenant in the enterprise lifecycle pipeline: prospect (CRM lead), applicant (application submitted), active (occupying under a lease), former (lease ended in good standing), evicted (lease terminated for cause). Drives workflow routing, data retention policies, and CRM pipeline reporting.' ;
    rdfs:domain ind:Tenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mostRecentLeaseExpiry rdf:type rdf:Property ;
    rdfs:label 'Most Recent Lease Expiry' ;
    rdfs:comment 'Expiry date of the tenant\'s most recently executed or currently active lease. Used for Weighted Average Lease Expiry (WALE) reporting, renewal pipeline management, and vacancy forecasting in Argus Enterprise.' ;
    rdfs:domain ind:Tenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mriTenantCode rdf:type rdf:Property ;
    rdfs:label 'Mri Tenant Code' ;
    rdfs:comment 'Tenant identifier assigned by MRI Software for residential or investment-managed portfolios. Populated when the tenant record originates from or is co-managed in MRI; null for Yardi-only portfolios.' ;
    rdfs:domain ind:Tenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portalAccessEnabled rdf:type rdf:Property ;
    rdfs:label 'Portal Access Enabled' ;
    rdfs:comment 'Indicates whether the tenant has been provisioned access to the self-service tenant portal (Yardi RentCafe or equivalent). When True, the tenant can view statements, submit maintenance requests via Building Engines, and execute documents via DocuSign CLM.' ;
    rdfs:domain ind:Tenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredContactMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Method' ;
    rdfs:comment 'Tenant\'s stated preference for receiving communications including rent notices, maintenance updates, and lease renewal offers. Drives communication channel selection in Yardi Voyager, Building Engines, and Salesforce CRM outreach workflows.' ;
    rdfs:domain ind:Tenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Primary email address for tenant communications including rent notices, lease renewal offers, maintenance updates, and regulatory disclosures. Serves as the principal digital contact channel in Yardi Voyager and Salesforce CRM.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Primary telephone number for the tenant contact, stored in E.164 international format. Used for lease administration communications, emergency notifications, and Building Engines tenant service request follow-up.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectSource rdf:type rdf:Property ;
    rdfs:label 'Prospect Source' ;
    rdfs:comment 'Lead origination channel through which the prospect was first introduced to the portfolio. Used for brokerage commission attribution, marketing ROI analysis, and CRM pipeline source reporting. Populated from Salesforce CRM deal pipeline. [ENUM-REF-CANDIDATE: referral|broker|website|mls|direct|costar|social_media|event|other — promote to reference product]' ;
    rdfs:domain ind:Tenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityDepositAmount rdf:type rdf:Property ;
    rdfs:label 'Security Deposit Amount' ;
    rdfs:comment 'Total security deposit amount held by the landlord in USD as collateral against the tenant\'s lease obligations. Determined by credit tier and lease terms. Subject to state-specific statutory limits and interest accrual requirements. Tracked in Yardi Voyager AR module.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yardiTenantCode rdf:type rdf:Property ;
    rdfs:label 'Yardi Tenant Code' ;
    rdfs:comment 'The native tenant identifier assigned by Yardi Voyager (e.g., \'T-00012345\'). Used to reconcile the golden record back to the property management system of record for AR, lease administration, and GL posting.' ;
    rdfs:domain ind:Tenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessCardNumber rdf:type rdf:Property ;
    rdfs:label 'Access Card Number' ;
    rdfs:comment 'Physical access card or key fob identifier issued to this contact for building entry. Tracked for security audit purposes and deactivated upon lease termination or contact status change.' ;
    rdfs:domain ind:TenantContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactRole rdf:type rdf:Property ;
    rdfs:label 'Contact Role' ;
    rdfs:comment 'Functional role of this contact in relation to the tenant account and lease. Drives routing logic for communications, work orders, and legal notices. [ENUM-REF-CANDIDATE: primary|authorized_signatory|emergency|billing|property_access|legal|guarantor|accounts_payable|facilities_manager — promote to reference product]' ;
    rdfs:domain ind:TenantContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmContactCode rdf:type rdf:Property ;
    rdfs:label 'Crm Contact Code' ;
    rdfs:comment 'External identifier for this contact in Salesforce CRM, enabling bi-directional synchronization between the lakehouse tenant contact record and the CRM contact object for prospect pipeline and tenant relationship management.' ;
    rdfs:domain ind:TenantContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'Date of birth of the contact individual. Required for identity verification, background screening, credit checks, and age-restricted housing compliance (e.g., 55+ communities under HUD Fair Housing Act).' ;
    rdfs:domain ind:TenantContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isEmergencyContact rdf:type rdf:Property ;
    rdfs:label 'Is Emergency Contact' ;
    rdfs:comment 'Indicates whether this contact should be notified in emergency situations such as building incidents, fire alarms, or urgent maintenance events. Used by Building Engines for emergency notification workflows.' ;
    rdfs:domain ind:TenantContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Indicates whether this contact is the designated primary contact for the tenant account. Only one contact per tenant should carry this flag as True. Used to determine the default recipient for lease notices, invoices, and property management communications.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mailingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Mailing State Province' ;
    rdfs:comment 'State or province component of the contact\'s mailing address using ISO 3166-2 subdivision codes. Determines applicable landlord-tenant law jurisdiction for legal notices.' ;
    rdfs:domain ind:TenantContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingOptIn rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In' ;
    rdfs:comment 'Indicates whether the contact has opted in to receive marketing communications including property listings, investment opportunities, and promotional content. Distinct from operational communications which are governed by lease terms.' ;
    rdfs:domain ind:TenantContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:middleName rdf:type rdf:Property ;
    rdfs:label 'Middle Name' ;
    rdfs:comment 'Middle name or initial of the contact person. Required for identity verification, background checks, and legal documentation such as lease execution and SNDA agreements.' ;
    rdfs:domain ind:TenantContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalIdLast4 rdf:type rdf:Property ;
    rdfs:label 'National Id Last4' ;
    rdfs:comment 'Last four digits of the contact\'s government-issued national identifier (e.g., last 4 of SSN). Stored as a masked reference for identity verification workflows without retaining the full identifier in the Silver Layer.' ;
    rdfs:domain ind:TenantContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalIdType rdf:type rdf:Property ;
    rdfs:label 'National Id Type' ;
    rdfs:comment 'Type of government-issued national identifier provided by the contact for identity verification and background screening purposes (e.g., SSN, passport, driver\'s license). The actual identifier value is stored separately in a restricted vault.' ;
    rdfs:domain ind:TenantContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneExtension rdf:type rdf:Property ;
    rdfs:label 'Phone Extension' ;
    rdfs:comment 'Internal telephone extension associated with the contact\'s office phone number. Required for direct routing within large corporate tenant organizations.' ;
    rdfs:domain ind:TenantContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneMobile rdf:type rdf:Property ;
    rdfs:label 'Phone Mobile' ;
    rdfs:comment 'Mobile (cell) phone number for the contact in E.164 international format. Primary channel for SMS notifications, two-factor authentication for tenant portal access, and urgent property management communications.' ;
    rdfs:domain ind:TenantContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneOffice rdf:type rdf:Property ;
    rdfs:label 'Phone Office' ;
    rdfs:comment 'Office or direct-dial business phone number for the contact in E.164 format. Used for formal business communications, lease negotiations, and property management inquiries for B2B corporate tenants.' ;
    rdfs:domain ind:TenantContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portalUsername rdf:type rdf:Property ;
    rdfs:label 'Portal Username' ;
    rdfs:comment 'Username or login identifier used by the contact to access the tenant self-service portal. Stored for account management and support purposes. Passwords are never stored in this product.' ;
    rdfs:domain ind:TenantContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Comm Channel' ;
    rdfs:comment 'The contact\'s preferred channel for receiving communications from property management, including lease notices, maintenance updates, and billing statements. Drives automated notification routing in Yardi Voyager and Building Engines.' ;
    rdfs:domain ind:TenantContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Comm Language' ;
    rdfs:comment 'ISO 639-1 language code (optionally with ISO 3166-1 country subtag) representing the contact\'s preferred language for all written and verbal communications. Supports multilingual tenant portfolios and GDPR-compliant consent documentation.' ;
    rdfs:domain ind:TenantContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertyAccessLevel rdf:type rdf:Property ;
    rdfs:label 'Property Access Level' ;
    rdfs:comment 'Level of physical access granted to this contact for the leased property and building facilities. Used by Building Engines for access control management and security compliance. Relevant for contacts designated as property access contacts.' ;
    rdfs:domain ind:TenantContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipEndDate rdf:type rdf:Property ;
    rdfs:label 'Relationship End Date' ;
    rdfs:comment 'Date on which this contact\'s association with the tenant account was terminated or deactivated. Null for currently active contacts. Used for historical reporting and GDPR data retention scheduling.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipStartDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Start Date' ;
    rdfs:comment 'Date on which this contact was first associated with the tenant account. Supports WALT and WALE calculations for long-standing tenant relationships and tracks the duration of the contact\'s association with the portfolio.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:yardiContactCode rdf:type rdf:Property ;
    rdfs:label 'Yardi Contact Code' ;
    rdfs:comment 'Source system identifier for this contact record as maintained in Yardi Voyager property management and lease administration modules. Used for reconciliation and lineage tracing.' ;
    rdfs:domain ind:TenantContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentEntityCorporateEntityId rdf:type rdf:Property ;
    rdfs:label 'Parent Entity Corporate Entity Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediate parent company in the corporate hierarchy. Enables enterprise-wide exposure tracking across subsidiaries, joint ventures, and affiliated entities leasing multiple premises.' ;
    rdfs:domain ind:CorporateEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorporateEntity .

ind:registeredGeographicHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Registered Geographic Hierarchy Id' ;
    rdfs:comment 'Foreign key linking to reference.geographic_hierarchy. Business justification: Corporate entity registered address geographic hierarchy enables market-level corporate tenant reporting, regulatory jurisdiction assignment, and tax jurisdiction determination. Role-prefix \'registere' ;
    rdfs:domain ind:CorporateEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeographicHierarchy .

ind:revenueCurrencyCodeId rdf:type rdf:Property ;
    rdfs:label 'Revenue Currency Code Id' ;
    rdfs:comment 'Foreign key linking to reference.currency_code. Business justification: Corporate entity revenue currency is required for credit assessment, financial analysis, and multi-currency portfolio reporting. \'revenue_currency\' is a denormalized currency reference; role-prefix \'r' ;
    rdfs:domain ind:CorporateEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CurrencyCode .

ind:annualRevenueUsd rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Usd' ;
    rdfs:comment 'Most recently reported annual gross revenue of the corporate entity in US dollars. Key input for credit underwriting, lease affordability analysis, and enterprise exposure assessment.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'Most recent credit rating assigned to the corporate entity by the designated credit rating agency (e.g., AAA, Baa2, BB+). Critical input for lease underwriting, security deposit determination, and portfolio risk management.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditRatingAgency rdf:type rdf:Property ;
    rdfs:label 'Credit Rating Agency' ;
    rdfs:comment 'Name of the credit rating agency that issued the most recent credit rating for the corporate entity (e.g., Moody\'s, S&P, Fitch). Used alongside the credit rating score for lease underwriting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditRatingDate rdf:type rdf:Property ;
    rdfs:label 'Credit Rating Date' ;
    rdfs:comment 'Date on which the current credit rating was issued or last affirmed by the rating agency. Enables staleness detection and triggers re-underwriting workflows when ratings are outdated.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Nine-digit Dun & Bradstreet Data Universal Numbering System (DUNS) number uniquely identifying the corporate entity globally. Used for credit risk assessment, enterprise exposure tracking, and corporate hierarchy linkage.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeHeadcount rdf:type rdf:Property ;
    rdfs:label 'Employee Headcount' ;
    rdfs:comment 'Total number of full-time equivalent employees reported by the corporate entity. Used for space planning, lease sizing, and tenant creditworthiness assessment.' ;
    rdfs:domain ind:CorporateEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:entityStatus rdf:type rdf:Property ;
    rdfs:label 'Entity Status' ;
    rdfs:comment 'Current lifecycle status of the corporate entity within the tenant portfolio. Drives CRM pipeline management, lease eligibility, and reporting segmentation.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgRating rdf:type rdf:Property ;
    rdfs:label 'Esg Rating' ;
    rdfs:comment 'Most recent Environmental, Social, and Governance (ESG) rating or score assigned to the corporate entity by a recognized ESG rating provider (e.g., MSCI, Sustainalytics). Supports sustainable leasing strategies and LEED/BREEAM-aligned tenant selection.' ;
    rdfs:domain ind:CorporateEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyType rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Type' ;
    rdfs:comment 'Classification of the entity\'s role within the corporate ownership structure (e.g., ultimate parent, subsidiary, joint venture, affiliate). Used for enterprise exposure aggregation and group lease covenant analysis.' ;
    rdfs:domain ind:CorporateEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationDate rdf:type rdf:Property ;
    rdfs:label 'Incorporation Date' ;
    rdfs:comment 'Date on which the corporate entity was legally incorporated or registered with the relevant authority. Used for credit underwriting and entity age assessment.' ;
    rdfs:domain ind:CorporateEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isPubliclyTraded rdf:type rdf:Property ;
    rdfs:label 'Is Publicly Traded' ;
    rdfs:comment 'Indicates whether the corporate entity\'s securities are listed and traded on a public stock exchange. Publicly traded entities are subject to additional SEC disclosure and SOX compliance requirements.' ;
    rdfs:domain ind:CorporateEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReit rdf:type rdf:Property ;
    rdfs:label 'Is Reit' ;
    rdfs:comment 'Indicates whether the corporate entity is structured as a Real Estate Investment Trust (REIT). REITs are subject to specific SEC, IRS, and FASB reporting requirements that affect lease structuring and investment analysis.' ;
    rdfs:domain ind:CorporateEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalEntityName rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name' ;
    rdfs:comment 'Full registered legal name of the corporate entity as recorded with the relevant government or regulatory authority. Used for lease execution, invoicing, and compliance documentation.' ;
    rdfs:domain ind:CorporateEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:naicsCode rdf:type rdf:Property ;
    rdfs:label 'Naics Code' ;
    rdfs:comment 'Six-digit North American Industry Classification System (NAICS) code representing the corporate entity\'s primary business activity. Preferred over SIC for modern industry segmentation and analytics.' ;
    rdfs:domain ind:CorporateEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary business contact person at the corporate entity (e.g., CFO, Real Estate Director). Used for lease negotiations, CRM pipeline management, and tenant relationship management.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressCity rdf:type rdf:Property ;
    rdfs:label 'Registered Address City' ;
    rdfs:comment 'City of the corporate entity\'s official registered address. Used for jurisdictional compliance, tax nexus determination, and geographic portfolio analytics.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressCountry rdf:type rdf:Property ;
    rdfs:label 'Registered Address Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the corporate entity\'s official registered address. Supports international portfolio management and cross-border compliance.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line1' ;
    rdfs:comment 'First line of the corporate entity\'s official registered address as filed with the relevant government authority. Used for legal notices, lease execution, and regulatory correspondence.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressPostalCode rdf:type rdf:Property ;
    rdfs:label 'Registered Address Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the corporate entity\'s official registered address. Supports geographic analytics, market area mapping, and GIS-based portfolio reporting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressState rdf:type rdf:Property ;
    rdfs:label 'Registered Address State' ;
    rdfs:comment 'State or province of the corporate entity\'s official registered address. Used for state tax nexus, regulatory filings, and geographic segmentation.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueFiscalYear rdf:type rdf:Property ;
    rdfs:label 'Revenue Fiscal Year' ;
    rdfs:comment 'The fiscal year (four-digit integer) to which the reported annual revenue figure corresponds. Ensures temporal accuracy when comparing revenue across entities.' ;
    rdfs:domain ind:CorporateEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sicCode rdf:type rdf:Property ;
    rdfs:label 'Sic Code' ;
    rdfs:comment 'Four-digit Standard Industrial Classification (SIC) code identifying the primary industry sector of the corporate entity. Used for tenant mix analysis, portfolio diversification reporting, and market benchmarking.' ;
    rdfs:domain ind:CorporateEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockExchange rdf:type rdf:Property ;
    rdfs:label 'Stock Exchange' ;
    rdfs:comment 'Name of the primary stock exchange on which the corporate entity\'s securities are listed (e.g., NYSE, NASDAQ, LSE). Relevant for publicly traded tenants subject to SEC or equivalent regulatory oversight.' ;
    rdfs:domain ind:CorporateEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockTicker rdf:type rdf:Property ;
    rdfs:label 'Stock Ticker' ;
    rdfs:comment 'Exchange-listed stock ticker symbol for publicly traded corporate entities. Used for market data integration, credit monitoring, and investor relations tracking.' ;
    rdfs:domain ind:CorporateEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditProfileId rdf:type rdf:Property ;
    rdfs:label 'Credit Profile Id' ;
    rdfs:comment 'Unique surrogate identifier for the tenant credit profile record. Primary key for the credit_profile data product within the tenant domain.' ;
    rdfs:domain ind:Tenant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditProfile .

ind:creditCurrencyCodeId rdf:type rdf:Property ;
    rdfs:label 'Credit Currency Code Id' ;
    rdfs:comment 'Foreign key linking to reference.currency_code. Business justification: Credit profile financial thresholds (recommended_max_rent, monthly_gross_income) are denominated in a specific currency. Underwriting decisions and credit review reports require proper currency contex' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CurrencyCode .

ind:guarantorId rdf:type rdf:Property ;
    rdfs:label 'Guarantor Id' ;
    rdfs:comment 'Reference to the guarantor entity (individual or corporate) associated with this credit profile when a guarantor is required. Links to the guarantor record for lease underwriting and documentation.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Guarantor .

ind:adverseActionDate rdf:type rdf:Property ;
    rdfs:label 'Adverse Action Date' ;
    rdfs:comment 'Date on which the adverse action notice was sent to the tenant. Required for FCRA compliance tracking and regulatory audit purposes.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adverseActionNoticeFlag rdf:type rdf:Property ;
    rdfs:label 'Adverse Action Notice Flag' ;
    rdfs:comment 'Indicates whether an adverse action notice was issued to the tenant following a declined or conditioned underwriting decision, as required by the Fair Credit Reporting Act. True = adverse action notice sent. Critical for FCRA compliance.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizationDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Date' ;
    rdfs:comment 'Date on which the tenant provided written authorization for the credit check. Establishes the legal basis for the credit inquiry under FCRA and GDPR consent requirements.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Authorization Document Ref' ;
    rdfs:comment 'Reference identifier for the signed credit check authorization document stored in DocuSign CLM or the document management system. Supports audit trail and FCRA/GDPR compliance documentation.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankruptcyChapter rdf:type rdf:Property ;
    rdfs:label 'Bankruptcy Chapter' ;
    rdfs:comment 'Type of bankruptcy filing (e.g., Chapter 7 liquidation, Chapter 11 reorganization, Chapter 13 repayment plan). Relevant for commercial tenants where Chapter 11 reorganization may indicate ongoing business viability.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankruptcyDischargeDate rdf:type rdf:Property ;
    rdfs:label 'Bankruptcy Discharge Date' ;
    rdfs:comment 'Date on which the tenant\'s bankruptcy was discharged, if applicable. Used to assess the elapsed time since discharge and determine eligibility under leasing underwriting policies that impose waiting periods post-bankruptcy.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bankruptcyFlag rdf:type rdf:Property ;
    rdfs:label 'Bankruptcy Flag' ;
    rdfs:comment 'Indicates whether the tenant has a bankruptcy filing on record as reported by the credit bureau. True = bankruptcy history present. Used as a disqualifying or conditional factor in leasing underwriting decisions.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bureauName rdf:type rdf:Property ;
    rdfs:label 'Bureau Name' ;
    rdfs:comment 'Name of the third-party credit bureau that provided the credit report and score used for leasing underwriting. Supports multi-bureau comparison and audit traceability.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bureauReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Bureau Reference Number' ;
    rdfs:comment 'Externally assigned reference number returned by the credit bureau (e.g., Equifax, Experian, TransUnion) for the credit inquiry. Used to trace the report back to the originating bureau pull for audit and dispute resolution.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionsAmount rdf:type rdf:Property ;
    rdfs:label 'Collections Amount' ;
    rdfs:comment 'Total outstanding balance across all accounts in collections as reported by the credit bureau. Provides a quantitative measure of the tenant\'s delinquent debt exposure for underwriting risk assessment.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionsFlag rdf:type rdf:Property ;
    rdfs:label 'Collections Flag' ;
    rdfs:comment 'Indicates whether the tenant has one or more accounts in collections as reported by the credit bureau. True = active or recent collections present. Used as a risk factor in leasing underwriting.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditAuthorizationFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Authorization Flag' ;
    rdfs:comment 'Indicates whether the tenant has provided explicit written authorization for the credit bureau check to be performed. True = authorization obtained. Required for FCRA compliance before initiating any credit inquiry.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditCheckDate rdf:type rdf:Property ;
    rdfs:label 'Credit Check Date' ;
    rdfs:comment 'Date on which the tenant authorized and the credit bureau check was performed. Establishes the temporal validity window of the credit report for leasing underwriting purposes.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditScoreModel rdf:type rdf:Property ;
    rdfs:label 'Credit Score Model' ;
    rdfs:comment 'Scoring model used by the credit bureau to generate the credit score (e.g., FICO 8, VantageScore 3.0). Required for accurate interpretation of the score range and underwriting thresholds.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dtiRatio rdf:type rdf:Property ;
    rdfs:label 'Dti Ratio' ;
    rdfs:comment 'Ratio of the tenant\'s total monthly debt obligations to gross monthly income, expressed as a decimal (e.g., 0.3500 = 35%). A key underwriting metric used to assess the tenant\'s ability to service rent obligations alongside existing debt. Aligns with DTI as defined in common real estate financial qualification standards.' ;
    rdfs:domain ind:Tenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evictionCount rdf:type rdf:Property ;
    rdfs:label 'Eviction Count' ;
    rdfs:comment 'Total number of prior eviction records identified for the tenant during the screening process. Provides granularity beyond the binary eviction flag for risk tiering and underwriting policy application.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:guarantorRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Guarantor Required Flag' ;
    rdfs:comment 'Indicates whether a personal or corporate guarantor is required as a condition of lease approval based on the tenant\'s credit profile assessment. True = guarantor required. Drives lease structuring and documentation requirements.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incomeVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Income Verification Method' ;
    rdfs:comment 'Method used to verify the tenant\'s income during the credit qualification process. Supports audit trail and underwriting documentation requirements.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomeVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Income Verification Status' ;
    rdfs:comment 'Status of the income verification process for the tenant. \'verified\' indicates income has been confirmed via pay stubs, tax returns, or bank statements; \'unverified\' indicates income was self-reported without documentation; \'pending\' indicates verification is in progress; \'waived\' indicates verification was waived per leasing policy.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlyGrossIncome rdf:type rdf:Property ;
    rdfs:label 'Monthly Gross Income' ;
    rdfs:comment 'Tenant\'s verified gross monthly income in the operating currency, as submitted and validated during the credit qualification process. Used as the denominator in DTI calculation and the income-to-rent ratio assessment.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingJudgmentsFlag rdf:type rdf:Property ;
    rdfs:label 'Outstanding Judgments Flag' ;
    rdfs:comment 'Indicates whether the tenant has outstanding civil judgments (e.g., unpaid court-ordered debts) as identified in the credit or public records check. True = outstanding judgments present. A significant risk factor in leasing underwriting.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorEvictionFlag rdf:type rdf:Property ;
    rdfs:label 'Prior Eviction Flag' ;
    rdfs:comment 'Indicates whether the tenant has a prior eviction record as identified through the credit check or tenant screening process. True = prior eviction on record. A critical risk indicator in residential and commercial leasing underwriting.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current lifecycle status of the credit profile record. \'active\' indicates the profile is valid for underwriting; \'expired\' indicates the review expiry date has passed; \'pending\' indicates the credit check is in progress; \'withdrawn\' indicates the tenant withdrew consent; \'under_review\' indicates a dispute or re-evaluation is in progress.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedMaxRent rdf:type rdf:Property ;
    rdfs:label 'Recommended Max Rent' ;
    rdfs:comment 'Maximum monthly rent amount recommended by the underwriting model based on the tenant\'s verified income and DTI ratio. Typically calculated as a percentage of gross monthly income (e.g., 30% rule). Used by leasing agents to qualify tenants for specific units.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Review Expiry Date' ;
    rdfs:comment 'Date on which the current credit profile assessment expires and a new credit check is required before lease execution or renewal. Typically set 30–90 days from the credit check date per leasing policy.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:securityDepositMultiplier rdf:type rdf:Property ;
    rdfs:label 'Security Deposit Multiplier' ;
    rdfs:comment 'Multiplier applied to the monthly rent amount to calculate the required security deposit based on the tenant\'s credit tier and risk profile (e.g., 1.00 = one month\'s rent, 2.00 = two months\' rent). Drives lease financial structuring and AR setup in Yardi Voyager.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenantType rdf:type rdf:Property ;
    rdfs:label 'Tenant Type' ;
    rdfs:comment 'Classification of the tenant as residential (B2C individual occupant) or commercial/industrial/retail (B2B corporate entity). Determines the applicable underwriting criteria, scoring model, and regulatory framework for the credit assessment.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underwritingDecision rdf:type rdf:Property ;
    rdfs:label 'Underwriting Decision' ;
    rdfs:comment 'Outcome of the leasing underwriting review based on the credit profile assessment. \'approved\' = tenant qualifies unconditionally; \'approved_with_conditions\' = tenant qualifies subject to guarantor, higher deposit, or other conditions; \'declined\' = tenant does not meet minimum credit criteria; \'pending\' = decision not yet rendered.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underwritingDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Underwriting Decision Date' ;
    rdfs:comment 'Date on which the underwriting decision was rendered for this credit profile. Used for audit trail, compliance reporting, and tracking decision turnaround times.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:underwritingNotes rdf:type rdf:Property ;
    rdfs:label 'Underwriting Notes' ;
    rdfs:comment 'Free-text notes entered by the underwriter or leasing manager documenting the rationale for the underwriting decision, any conditions imposed, or exceptions granted. Supports audit trail and Fair Housing Act compliance documentation.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenantProspectId rdf:type rdf:Property ;
    rdfs:label 'Tenant Prospect Id' ;
    rdfs:comment 'Unique system-generated identifier for the tenant prospect record in the CRM-linked leasing pipeline. Primary key for the tenant_prospect data product.' ;
    rdfs:domain ind:Tenant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TenantProspect .

ind:cmaId rdf:type rdf:Property ;
    rdfs:label 'Cma Id' ;
    rdfs:comment 'Foreign key linking to valuation.cma. Business justification: Leasing agents use a CMA to advise prospects on market rent competitiveness and pricing strategy. Linking the CMA to the prospect record enables pipeline reporting on market-supported pricing and conv' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cma .

ind:crmLeadId rdf:type rdf:Property ;
    rdfs:label 'Crm Lead Id' ;
    rdfs:comment 'External identifier for this prospect record as maintained in Salesforce CRM (Tenant and Prospect Management module). Used to cross-reference the leasing pipeline record with the originating CRM lead or contact object.' ;
    rdfs:domain ind:TenantProspect ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lead .

ind:applicationSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Application Submitted Date' ;
    rdfs:comment 'Date on which the prospect formally submitted a tenancy application. Marks the transition from prospect to applicant in the leasing lifecycle and triggers credit and background screening workflows.' ;
    rdfs:domain ind:TenantProspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetMaxMonthly rdf:type rdf:Property ;
    rdfs:label 'Budget Max Monthly' ;
    rdfs:comment 'Prospect\'s maximum acceptable monthly rent budget in the portfolio\'s base currency. Defines the upper bound of the prospect\'s affordability range for residential unit matching and pricing negotiations.' ;
    rdfs:domain ind:TenantProspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetMinMonthly rdf:type rdf:Property ;
    rdfs:label 'Budget Min Monthly' ;
    rdfs:comment 'Prospect\'s minimum acceptable monthly rent budget in the portfolio\'s base currency. Used for unit matching and pricing strategy. Applicable primarily to residential prospects where monthly rent is the standard pricing unit.' ;
    rdfs:domain ind:TenantProspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conversionProbabilityPct rdf:type rdf:Property ;
    rdfs:label 'Conversion Probability Pct' ;
    rdfs:comment 'Estimated probability (0.00–100.00%) that this prospect will convert to a signed lease. Assigned by the leasing agent or derived from CRM scoring models. Used for pipeline forecasting and leasing velocity reporting.' ;
    rdfs:domain ind:TenantProspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Check Status' ;
    rdfs:comment 'Status of the credit screening process for the prospect. Tracks whether a credit check has been initiated, is pending results, has passed, failed, or been waived. Relevant after application submission stage.' ;
    rdfs:domain ind:TenantProspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:desiredLeaseTermMonths rdf:type rdf:Property ;
    rdfs:label 'Desired Lease Term Months' ;
    rdfs:comment 'Prospect\'s preferred lease duration expressed in months. Used to assess fit with available lease structures and to inform Weighted Average Lease Term (WALT) projections for the portfolio.' ;
    rdfs:domain ind:TenantProspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:desiredMoveInDate rdf:type rdf:Property ;
    rdfs:label 'Desired Move In Date' ;
    rdfs:comment 'Prospect\'s preferred or requested commencement date for occupancy. Used for unit availability matching, lease scheduling, and Weighted Average Lease Expiry (WALE) planning.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:desiredSizeMaxSqft rdf:type rdf:Property ;
    rdfs:label 'Desired Size Max Sqft' ;
    rdfs:comment 'Maximum acceptable space size in square feet (SQF) as specified by the prospect. Used alongside desired_size_min_sqft to define the prospect\'s space requirement range for inventory matching.' ;
    rdfs:domain ind:TenantProspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:desiredSizeMinSqft rdf:type rdf:Property ;
    rdfs:label 'Desired Size Min Sqft' ;
    rdfs:comment 'Minimum acceptable space size in square feet (SQF) as specified by the prospect. Used for unit matching against available Gross Leasable Area (GLA) and Net Leasable Area (NLA) inventory.' ;
    rdfs:domain ind:TenantProspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedLeaseValue rdf:type rdf:Property ;
    rdfs:label 'Expected Lease Value' ;
    rdfs:comment 'Estimated total lease value for the prospect\'s anticipated tenancy, calculated as the product of expected monthly rent, lease term, and any known escalations. Used for pipeline revenue forecasting and portfolio planning.' ;
    rdfs:domain ind:TenantProspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:followUpDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Date' ;
    rdfs:comment 'Next scheduled follow-up date for the assigned leasing agent to contact the prospect. Used for CRM task management and pipeline activity tracking to ensure timely engagement.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inquiryDate rdf:type rdf:Property ;
    rdfs:label 'Inquiry Date' ;
    rdfs:comment 'Date on which the prospect first made contact or submitted an inquiry for a property or unit. Marks the entry point into the leasing funnel and is used to measure pipeline velocity and lead response time.' ;
    rdfs:domain ind:TenantProspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isMarketingConsent rdf:type rdf:Property ;
    rdfs:label 'Is Marketing Consent' ;
    rdfs:comment 'Indicates whether the prospect has provided explicit consent to receive marketing communications from the leasing team. Required for GDPR-compliant outreach and CRM campaign targeting.' ;
    rdfs:domain ind:TenantProspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadSourceDetail rdf:type rdf:Property ;
    rdfs:label 'Lead Source Detail' ;
    rdfs:comment 'Supplementary detail describing the specific lead source, such as the referring broker name, campaign name, listing platform URL, or event name. Provides granularity beyond the lead_source category for marketing attribution analysis.' ;
    rdfs:domain ind:TenantProspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineNotes rdf:type rdf:Property ;
    rdfs:label 'Pipeline Notes' ;
    rdfs:comment 'Free-text notes entered by the leasing agent capturing key interactions, prospect preferences, negotiation points, or other contextual information relevant to advancing the prospect through the pipeline.' ;
    rdfs:domain ind:TenantProspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineStage rdf:type rdf:Property ;
    rdfs:label 'Pipeline Stage' ;
    rdfs:comment 'Current stage of the prospect in the leasing funnel pipeline. Tracks progression from initial inquiry through tour, application, Letter of Intent (LOI) issuance, lease negotiation, and final execution or disqualification. [ENUM-REF-CANDIDATE: inquiry|tour_scheduled|application_submitted|loi_issued|lease_negotiation|lease_executed|lost|withdrawn — promote to reference product]' ;
    rdfs:domain ind:TenantProspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineStatus rdf:type rdf:Property ;
    rdfs:label 'Pipeline Status' ;
    rdfs:comment 'Current lifecycle status of the prospect record within the leasing pipeline. Indicates whether the prospect is actively being pursued, placed on hold, converted to a tenant, or lost/disqualified.' ;
    rdfs:domain ind:TenantProspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectName rdf:type rdf:Property ;
    rdfs:label 'Prospect Name' ;
    rdfs:comment 'Full legal name of the prospective tenant individual or primary contact person for a corporate tenant prospect. Used for identification and communication throughout the leasing funnel.' ;
    rdfs:domain ind:TenantProspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segment rdf:type rdf:Property ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Business segment classification of the prospect, distinguishing B2B corporate tenants (enterprise or SME) from B2C individual residential occupants, nonprofits, and government entities. Supports targeted leasing strategies and CRM segmentation.' ;
    rdfs:domain ind:TenantProspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialRequirements rdf:type rdf:Property ;
    rdfs:label 'Special Requirements' ;
    rdfs:comment 'Free-text field capturing any specific requirements or preferences stated by the prospect, such as accessibility needs, parking requirements, fit-out specifications, Tenant Improvement (TI) expectations, or amenity preferences.' ;
    rdfs:domain ind:TenantProspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tourCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Tour Completed Date' ;
    rdfs:comment 'Date on which the property or unit tour was actually completed by the prospect. Distinct from tour_scheduled_date to capture no-shows and rescheduling. Used to measure conversion from tour to application.' ;
    rdfs:domain ind:TenantProspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tourScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Tour Scheduled Date' ;
    rdfs:comment 'Date on which a property or unit tour is scheduled for the prospect. Null if no tour has been arranged. Used to track pipeline progression from inquiry to physical showing.' ;
    rdfs:domain ind:TenantProspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicationId rdf:type rdf:Property ;
    rdfs:label 'Application Id' ;
    rdfs:comment 'Unique system-generated identifier for the tenancy application record. Primary key for the application data product within the tenant domain.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Application .

ind:annualIncome rdf:type rdf:Property ;
    rdfs:label 'Annual Income' ;
    rdfs:comment 'Declared annual gross income of the applicant (individual) or annual gross revenue (corporate). Used to calculate Debt-to-Income Ratio (DTI) and assess rent affordability against standard income-to-rent thresholds (typically 3x monthly rent).' ;
    rdfs:domain ind:Tenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicantEmail rdf:type rdf:Property ;
    rdfs:label 'Applicant Email' ;
    rdfs:comment 'Primary email address of the applicant used for application correspondence, status notifications, and DocuSign lease execution workflows.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicantLegalName rdf:type rdf:Property ;
    rdfs:label 'Applicant Legal Name' ;
    rdfs:comment 'Full legal name of the primary applicant as it appears on government-issued identification or corporate registration documents. For corporate applicants, this is the registered legal entity name.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicantPhone rdf:type rdf:Property ;
    rdfs:label 'Applicant Phone' ;
    rdfs:comment 'Primary contact phone number for the applicant, used for screening interviews, verification calls, and application status communication.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicantType rdf:type rdf:Property ;
    rdfs:label 'Applicant Type' ;
    rdfs:comment 'Classification of the applicant entity type. Individual: natural person (B2C residential occupant); Corporate: legal business entity (B2B commercial tenant); Guarantor: third-party financial guarantor supporting the primary applicant; Co-applicant: joint applicant sharing tenancy obligations.' ;
    rdfs:domain ind:Tenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationNumber rdf:type rdf:Property ;
    rdfs:label 'Application Number' ;
    rdfs:comment 'Externally visible, human-readable reference number assigned to the tenancy application at submission. Used in all correspondence with applicants and approval authorities (e.g., APP-2024-000123).' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationStatus rdf:type rdf:Property ;
    rdfs:label 'Application Status' ;
    rdfs:comment 'Current lifecycle state of the tenancy application within the qualification workflow. Valid states: submitted (received but not yet reviewed), under_review (active screening in progress), approved (qualified and approved for lease execution), declined (application rejected), withdrawn (applicant voluntarily withdrew).' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmOpportunityCode rdf:type rdf:Property ;
    rdfs:label 'Crm Opportunity Code' ;
    rdfs:comment 'The Salesforce CRM opportunity or deal record identifier linked to this tenancy application. Enables bi-directional traceability between the formal application workflow and the brokerage deal pipeline.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionDate rdf:type rdf:Property ;
    rdfs:label 'Decision Date' ;
    rdfs:comment 'The date on which a final approval or decline decision was rendered on the application by the designated approval authority. Drives SLA compliance tracking and applicant notification timelines.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:declineReasonCode rdf:type rdf:Property ;
    rdfs:label 'Decline Reason Code' ;
    rdfs:comment 'Standardized reason code explaining why the application was declined. Required for FCRA adverse action notices and Fair Housing compliance reporting. [ENUM-REF-CANDIDATE: insufficient_income|poor_credit|criminal_history|incomplete_docs|rental_history|guarantor_declined|unit_unavailable|policy_violation — promote to reference product]' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feePaid rdf:type rdf:Property ;
    rdfs:label 'Fee Paid' ;
    rdfs:comment 'Indicates whether the application processing fee has been received and confirmed. Applications with unpaid fees may be placed on hold pending payment confirmation in Yardi Voyager AR.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialDocsChecklist rdf:type rdf:Property ;
    rdfs:label 'Financial Docs Checklist' ;
    rdfs:comment 'Structured checklist of financial documents submitted by the applicant as part of the qualification package. Tracks submission status of required documents such as bank statements, tax returns, pay stubs, audited financials, and corporate financial statements. Stored as a serialized status string (e.g., \'bank_statements:Y|tax_returns:Y|pay_stubs:N\').' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freeRentMonthsRequested rdf:type rdf:Property ;
    rdfs:label 'Free Rent Months Requested' ;
    rdfs:comment 'Number of rent-free months requested by the applicant as a lease incentive concession. Common in commercial leasing during tenant fit-out periods. Impacts EGI (Effective Gross Income) and NOI calculations in Argus Enterprise.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:portfolioType rdf:type rdf:Property ;
    rdfs:label 'Portfolio Type' ;
    rdfs:comment 'Indicates whether the application pertains to a commercial or residential portfolio, driving applicable screening criteria, regulatory requirements, and lease structures.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedBaseRentMonthly rdf:type rdf:Property ;
    rdfs:label 'Proposed Base Rent Monthly' ;
    rdfs:comment 'The monthly base rent amount proposed by the applicant in the application. Represents the gross base rent before CAM charges, operating expense pass-throughs, or percentage rent adjustments. Used in deal pipeline valuation and NOI (Net Operating Income) forecasting.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedLeaseEndDate rdf:type rdf:Property ;
    rdfs:label 'Proposed Lease End Date' ;
    rdfs:comment 'The applicant\'s requested lease expiry date. Drives WALT (Weighted Average Lease Term) calculations, portfolio planning, and WALE (Weighted Average Lease Expiry) reporting.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proposedLeaseStartDate rdf:type rdf:Property ;
    rdfs:label 'Proposed Lease Start Date' ;
    rdfs:comment 'The applicant\'s requested lease commencement date. Used in scheduling unit availability, coordinating tenant improvement (TI) work, and planning lease execution timelines.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proposedLeaseTermMonths rdf:type rdf:Property ;
    rdfs:label 'Proposed Lease Term Months' ;
    rdfs:comment 'The total duration of the proposed lease in months as requested by the applicant. Used for WALT analysis, lease expiry scheduling, and investment portfolio modeling in Argus Enterprise.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proposedRentPsf rdf:type rdf:Property ;
    rdfs:label 'Proposed Rent Psf' ;
    rdfs:comment 'The proposed annual rent rate expressed on a Per Square Foot (PSF) basis. Standard commercial real estate pricing metric used for market comparables (CMA), CoStar benchmarking, and deal negotiation.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Reference Check Status' ;
    rdfs:comment 'Status of the landlord and personal reference verification process. Completed: all required references contacted and verified; Pending: references not yet contacted; Not Required: waived per leasing policy (e.g., corporate tenant with established credit).' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedGlaSqft rdf:type rdf:Property ;
    rdfs:label 'Requested Gla Sqft' ;
    rdfs:comment 'The total Gross Leasable Area (GLA) in square feet (SQF) requested by the applicant. For commercial tenants, this drives PSF (Per Square Foot) rent calculations, CAM (Common Area Maintenance) allocations, and space planning.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedNlaSqft rdf:type rdf:Property ;
    rdfs:label 'Requested Nla Sqft' ;
    rdfs:comment 'The Net Leasable Area (NLA) in square feet requested by the applicant, excluding common areas and structural elements. Used for net rent calculations and space efficiency analysis.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceChannel rdf:type rdf:Property ;
    rdfs:label 'Source Channel' ;
    rdfs:comment 'The channel through which the tenancy application was originated. Online Portal: self-service web application; Broker Referral: submitted via a licensed broker; Direct Inquiry: direct contact with leasing team; MLS (Multiple Listing Service): originated from MLS listing; Walk-in: in-person inquiry; Corporate Relocation: employer-sponsored relocation program.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'The calendar date on which the tenancy application was formally submitted by the applicant. Represents the principal business event date for the application lifecycle.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tiAllowanceRequested rdf:type rdf:Property ;
    rdfs:label 'Ti Allowance Requested' ;
    rdfs:comment 'The Tenant Improvement (TI) allowance amount requested by the applicant for fit-out or renovation of the premises. A key commercial lease negotiation term tracked in the deal pipeline and CAPEX planning.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yardiApplicationRef rdf:type rdf:Property ;
    rdfs:label 'Yardi Application Ref' ;
    rdfs:comment 'The native application record identifier from Yardi Voyager Lease Administration module. Enables reconciliation between the lakehouse silver layer and the operational system of record for audit and data lineage purposes.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaUomId rdf:type rdf:Property ;
    rdfs:label 'Area Uom Id' ;
    rdfs:comment 'Foreign key linking to reference.uom. Business justification: Occupancy area measurement standard (BOMA, IPMS, GLA, NLA) is required for lease compliance, rent calculation, and valuation reporting. \'area_measurement_standard\' is a denormalized UOM reference; lin' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Uom .

ind:subleaseId rdf:type rdf:Property ;
    rdfs:label 'Sublease Id' ;
    rdfs:comment 'Foreign key linking to lease.sublease. Business justification: tenant_occupancy has an is_sublease flag indicating sublease occupancy. When a tenant occupies space under a sublease, the occupancy record must reference the governing sublease agreement for CAM pror' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sublease .

ind:violationId rdf:type rdf:Property ;
    rdfs:label 'Violation Id' ;
    rdfs:comment 'Foreign key linking to compliance.violation. Business justification: Property managers track compliance violations (overcrowding, unpermitted use, ADA breach) against specific occupancy records. This link supports enforcement tracking and regulatory reporting by identi' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Violation .

ind:accessCardCount rdf:type rdf:Property ;
    rdfs:label 'Access Card Count' ;
    rdfs:comment 'The number of physical access cards or digital access credentials issued to the tenant for the occupied premises. Used for building security management, key control audits, and move-out reconciliation.' ;
    rdfs:domain ind:Occupancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetClass rdf:type rdf:Property ;
    rdfs:label 'Asset Class' ;
    rdfs:comment 'The real estate asset class of the occupied property. Determines applicable lease structures, CAM (Common Area Maintenance) obligations, and industry benchmarking comparables. [ENUM-REF-CANDIDATE: office|retail|industrial|multifamily|mixed_use|hospitality|land|healthcare|self_storage|data_center — promote to reference product]' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'The date on which the tenant vacated or is scheduled to vacate the premises. Nullable for active occupancies with no confirmed end date. Used for WALE (Weighted Average Lease Expiry) calculations and re-leasing pipeline planning.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdoverStartDate rdf:type rdf:Property ;
    rdfs:label 'Holdover Start Date' ;
    rdfs:comment 'The date on which the tenant transitioned into holdover status, i.e., the day after the original lease or occupancy end date. Populated only when is_holdover is True. Used to calculate holdover duration and associated penalty rent periods.' ;
    rdfs:domain ind:Occupancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isHoldover rdf:type rdf:Property ;
    rdfs:label 'Is Holdover' ;
    rdfs:comment 'Flag indicating whether the tenant is currently in holdover status — continuing to occupy the premises after the lease expiry date without a new or renewed lease agreement. Triggers holdover rent calculations and legal notification workflows.' ;
    rdfs:domain ind:Occupancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSublease rdf:type rdf:Property ;
    rdfs:label 'Is Sublease' ;
    rdfs:comment 'Flag indicating whether this occupancy record represents a sublease arrangement where the occupying tenant is not the primary leaseholder. Supports sublease tracking, consent management, and NNN (Triple Net Lease) obligation pass-through analysis.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keyHandoverDate rdf:type rdf:Property ;
    rdfs:label 'Key Handover Date' ;
    rdfs:comment 'The date on which physical keys, access cards, or digital access credentials were formally handed over to the tenant at commencement, or returned by the tenant at vacation. Critical for establishing the precise moment of physical possession transfer.' ;
    rdfs:domain ind:Occupancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:moveInConditionRating rdf:type rdf:Property ;
    rdfs:label 'Move In Condition Rating' ;
    rdfs:comment 'Standardised rating of the premises condition at the time of tenant move-in, as recorded during the move-in inspection. Establishes the baseline for dilapidations assessment at move-out and supports deposit reconciliation.' ;
    rdfs:domain ind:Occupancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moveInInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Move In Inspection Date' ;
    rdfs:comment 'The date on which the pre-occupancy condition inspection of the premises was conducted. Establishes the baseline condition of the unit at the time of handover to the tenant, supporting deposit reconciliation and maintenance liability determination.' ;
    rdfs:domain ind:Occupancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:moveOutConditionRating rdf:type rdf:Property ;
    rdfs:label 'Move Out Condition Rating' ;
    rdfs:comment 'Standardised rating of the premises condition at the time of tenant move-out, as recorded during the move-out inspection. Compared against move_in_condition_rating to determine dilapidations liability and deposit deduction amounts.' ;
    rdfs:domain ind:Occupancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moveOutInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Move Out Inspection Date' ;
    rdfs:comment 'The date on which the post-occupancy condition inspection of the premises was conducted upon tenant vacation. Used to assess dilapidations, damage beyond fair wear and tear, and to support deposit deduction decisions.' ;
    rdfs:domain ind:Occupancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:numOccupants rdf:type rdf:Property ;
    rdfs:label 'Num Occupants' ;
    rdfs:comment 'The total number of individuals or employees physically occupying the premises. Used for density analysis, building services planning, HVAC (Heating Ventilation and Air Conditioning) load calculations, and ESG (Environmental Social and Governance) reporting.' ;
    rdfs:domain ind:Occupancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:occupancyStatus rdf:type rdf:Property ;
    rdfs:label 'Occupancy Status' ;
    rdfs:comment 'Current lifecycle state of the occupancy record. \'active\' indicates the tenant is in physical possession; \'vacated\' indicates the tenant has surrendered possession; \'pending_handover\' indicates keys have not yet been formally exchanged; \'holdover\' indicates possession continues beyond the agreed end date; \'terminated\' indicates the occupancy was ended early; \'scheduled\' indicates a future occupancy not yet commenced.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occupancyType rdf:type rdf:Property ;
    rdfs:label 'Occupancy Type' ;
    rdfs:comment 'Classification of the nature of physical possession. \'primary\' indicates the main lease-backed occupancy; \'sublease\' indicates a sub-tenant arrangement; \'holdover\' indicates continued possession after lease expiry without a new agreement; \'license\' indicates a short-term or non-exclusive right to occupy; \'co_occupancy\' indicates shared possession; \'temporary\' indicates a short-term or interim arrangement.' ;
    rdfs:domain ind:Occupancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occupiedAreaSqf rdf:type rdf:Property ;
    rdfs:label 'Occupied Area Sqf' ;
    rdfs:comment 'The actual net leasable area (NLA) physically occupied by the tenant, measured in square feet (SQF). May differ from the leased area if partial occupation, expansion, or contraction has occurred. Used for PSF (Per Square Foot) analytics and portfolio occupancy rate calculations.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:occupiedAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Occupied Area Sqm' ;
    rdfs:comment 'The actual net leasable area (NLA) physically occupied by the tenant, measured in square metres (SQM). Supports international portfolio reporting and compliance with IFRS 16 disclosures for non-US properties.' ;
    rdfs:domain ind:Occupancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parkingBaysAllocated rdf:type rdf:Property ;
    rdfs:label 'Parking Bays Allocated' ;
    rdfs:comment 'The number of parking bays or spaces allocated to the tenant as part of the occupancy arrangement. Supports facility operations planning, parking revenue tracking, and tenant service management.' ;
    rdfs:domain ind:Occupancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:premisesIdentifier rdf:type rdf:Property ;
    rdfs:label 'Premises Identifier' ;
    rdfs:comment 'The human-readable identifier of the specific suite, unit, or premises being occupied (e.g., \'Suite 1201\', \'Unit 4B\', \'Bay 3\'). Complements the unit_id system reference with the operational label used in correspondence and building directories.' ;
    rdfs:domain ind:Occupancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledVacateDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Vacate Date' ;
    rdfs:comment 'The contractually agreed or operationally planned date by which the tenant is expected to vacate the premises. May differ from the actual end_date if the tenant vacates early or holds over. Used for re-leasing planning and portfolio vacancy forecasting.' ;
    rdfs:domain ind:Occupancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tiCompleted rdf:type rdf:Property ;
    rdfs:label 'Ti Completed' ;
    rdfs:comment 'Flag indicating whether all agreed Tenant Improvement (TI) works were completed prior to or during the occupancy commencement. Supports CAPEX (Capital Expenditure) tracking, lease incentive accounting under ASC 842/IFRS 16, and handover readiness confirmation.' ;
    rdfs:domain ind:Occupancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tiCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Ti Completion Date' ;
    rdfs:comment 'The date on which all Tenant Improvement (TI) works were formally completed and signed off. Used to reconcile TI allowance disbursements, confirm lease commencement triggers, and support CAPEX project close-out in Procore.' ;
    rdfs:domain ind:Occupancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vacateReasonCode rdf:type rdf:Property ;
    rdfs:label 'Vacate Reason Code' ;
    rdfs:comment 'Standardised code indicating the reason the tenant vacated the premises. Supports tenant lifecycle analytics, re-leasing strategy, and churn analysis. [ENUM-REF-CANDIDATE: lease_expiry|early_termination|default|relocation|downsizing|upsizing|business_closure|eviction|mutual_agreement — promote to reference product]' ;
    rdfs:domain ind:Occupancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vacateReasonNotes rdf:type rdf:Property ;
    rdfs:label 'Vacate Reason Notes' ;
    rdfs:comment 'Free-text narrative providing additional context for the vacate reason beyond the standardised code. Captures qualitative intelligence for tenant relationship management and re-leasing decisions.' ;
    rdfs:domain ind:Occupancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryId rdf:type rdf:Property ;
    rdfs:label 'Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Guarantor jurisdiction determines applicable guarantee law, KYC/AML requirements, and cross-border enforcement rules. Domain experts expect a proper country FK on guarantor records for legal and compl' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'First line of the guarantor\'s legal mailing or registered address. Used for legal notices, guarantee enforcement correspondence, and identity verification.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Second line of the guarantor\'s legal mailing or registered address (suite, unit, floor, or additional address detail). Optional field.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashDepositAccount rdf:type rdf:Property ;
    rdfs:label 'Cash Deposit Account' ;
    rdfs:comment 'Reference to the escrow or trust account holding the cash deposit when guarantee_instrument_type is \'cash_deposit\'. Used for deposit tracking, interest accrual, and return-of-deposit workflows.' ;
    rdfs:domain ind:Guarantor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City of the guarantor\'s legal mailing or registered address. Used for legal notices and jurisdictional compliance.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditBureau rdf:type rdf:Property ;
    rdfs:label 'Credit Bureau' ;
    rdfs:comment 'Name of the credit reporting agency or rating agency from which the guarantor\'s credit score or creditworthiness rating was obtained. [ENUM-REF-CANDIDATE: Equifax|Experian|TransUnion|Dun_and_Bradstreet|Moody|SP_Global|other — promote to reference product]' ;
    rdfs:domain ind:Guarantor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditQualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Qualification Status' ;
    rdfs:comment 'Outcome of the credit underwriting review for this guarantor: approved (meets credit standards), conditionally_approved (approved with conditions), declined (does not meet standards), pending_review (under assessment), or expired (prior approval has lapsed and requires renewal).' ;
    rdfs:domain ind:Guarantor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditReviewDate rdf:type rdf:Property ;
    rdfs:label 'Credit Review Date' ;
    rdfs:comment 'Date on which the most recent credit qualification review was completed for this guarantor. Used to determine whether the credit assessment is current and to schedule renewal reviews.' ;
    rdfs:domain ind:Guarantor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentRefNumber rdf:type rdf:Property ;
    rdfs:label 'Document Ref Number' ;
    rdfs:comment 'Reference number of the executed guarantee instrument document as recorded in DocuSign CLM or the contract lifecycle management system. Enables direct retrieval of the signed guarantee agreement.' ;
    rdfs:domain ind:Guarantor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Date on which the guarantee instrument expires and the guarantor\'s obligation terminates. Null for open-ended guarantees that run for the full lease term. Critical for guarantee renewal tracking and portfolio credit risk management.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guaranteeInstrumentType rdf:type rdf:Property ;
    rdfs:label 'Guarantee Instrument Type' ;
    rdfs:comment 'Type of financial instrument used to secure the guarantee obligation: personal guarantee (individual liability), letter of credit (bank-issued), surety bond (insurance-backed), cash deposit (held in escrow), or corporate guarantee (entity-level obligation).' ;
    rdfs:domain ind:Guarantor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteeNotes rdf:type rdf:Property ;
    rdfs:label 'Guarantee Notes' ;
    rdfs:comment 'Free-text field for underwriters and property managers to record special conditions, exceptions, or observations related to the guarantee instrument. Supports lease underwriting documentation and guarantee enforcement context.' ;
    rdfs:domain ind:Guarantor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteeStatus rdf:type rdf:Property ;
    rdfs:label 'Guarantee Status' ;
    rdfs:comment 'Current lifecycle state of the guarantee instrument: active (in force), expired (past expiry date), released (landlord released guarantor), called (guarantee has been drawn upon), pending (awaiting execution), or cancelled.' ;
    rdfs:domain ind:Guarantor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteedAmount rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Amount' ;
    rdfs:comment 'Fixed monetary amount the guarantor is liable for under the guarantee instrument. Applicable when the guarantee is capped at a specific dollar value rather than a percentage of the total lease obligation. Used in portfolio credit risk assessment.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteedPct rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Pct' ;
    rdfs:comment 'Percentage of the total lease obligation covered by this guarantor\'s guarantee. Used when the guarantee is expressed as a proportion of total rent rather than a fixed amount. Supports partial guarantee structures common in commercial leases.' ;
    rdfs:domain ind:Guarantor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guarantorType rdf:type rdf:Property ;
    rdfs:label 'Guarantor Type' ;
    rdfs:comment 'Classification of the guarantor entity: individual (personal guarantor), corporate (company guarantor), institutional (bank or fund), government, or trust. Drives underwriting and credit qualification workflows.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isForeignEntity rdf:type rdf:Property ;
    rdfs:label 'Is Foreign Entity' ;
    rdfs:comment 'Indicates whether the guarantor is a foreign individual or entity (incorporated or domiciled outside the domestic jurisdiction). Foreign guarantors typically require enhanced underwriting, additional security instruments, and SNDA agreements.' ;
    rdfs:domain ind:Guarantor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lcExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Lc Expiry Date' ;
    rdfs:comment 'Expiry date of the letter of credit as stated on the LC instrument. May differ from the guarantee expiry date if the LC has a shorter term and requires periodic renewal. Critical for proactive renewal management.' ;
    rdfs:domain ind:Guarantor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lcIssuingBank rdf:type rdf:Property ;
    rdfs:label 'Lc Issuing Bank' ;
    rdfs:comment 'Name of the financial institution that issued the letter of credit, when guarantee_instrument_type is \'letter_of_credit\'. Required for LC verification, renewal tracking, and draw procedures.' ;
    rdfs:domain ind:Guarantor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lcNumber rdf:type rdf:Property ;
    rdfs:label 'Lc Number' ;
    rdfs:comment 'Unique reference number assigned by the issuing bank to the letter of credit instrument. Used for LC draw requests, renewals, and bank correspondence when guarantee_instrument_type is \'letter_of_credit\'.' ;
    rdfs:domain ind:Guarantor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netWorth rdf:type rdf:Property ;
    rdfs:label 'Net Worth' ;
    rdfs:comment 'Declared or verified net worth of the guarantor at the time of credit qualification. Represents total assets minus total liabilities. Key underwriting metric for assessing guarantor financial strength relative to the guaranteed lease obligation.' ;
    rdfs:domain ind:Guarantor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the guarantor\'s legal mailing or registered address.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipToTenant rdf:type rdf:Property ;
    rdfs:label 'Relationship To Tenant' ;
    rdfs:comment 'Nature of the relationship between the guarantor and the primary tenant. Used in lease underwriting to assess the strength and reliability of the guarantee. [ENUM-REF-CANDIDATE: parent|spouse|sibling|employer|investor|parent_company|other — promote to reference product]' ;
    rdfs:domain ind:Guarantor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date on which the landlord formally released the guarantor from their obligation, prior to the natural expiry date. Populated only when guarantee_status is \'released\'. Supports legal compliance and audit trail requirements.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State or province of the guarantor\'s legal mailing or registered address. Used for jurisdictional determination of guarantee enforceability and applicable law.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yardiGuarantorCode rdf:type rdf:Property ;
    rdfs:label 'Yardi Guarantor Code' ;
    rdfs:comment 'Source system identifier for this guarantor record as assigned in Yardi Voyager. Used for data lineage, reconciliation, and cross-system integration between the lakehouse silver layer and the operational property management system.' ;
    rdfs:domain ind:Guarantor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeId rdf:type rdf:Property ;
    rdfs:label 'Notice Id' ;
    rdfs:comment 'Unique system-generated identifier for the formal notice record. Primary key for the tenant.notice data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Notice .

ind:jurisdictionGeographicHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Geographic Hierarchy Id' ;
    rdfs:comment 'Foreign key linking to reference.geographic_hierarchy. Business justification: Notices are governed by jurisdiction-specific legal requirements (notice periods, cure deadlines, eviction procedures). Linking to geographic_hierarchy enables jurisdiction-based compliance reporting ' ;
    rdfs:domain ind:Notice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeographicHierarchy .

ind:screeningId rdf:type rdf:Property ;
    rdfs:label 'Screening Id' ;
    rdfs:comment 'Foreign key linking to tenant.screening. Business justification: Adverse action notices are a required output of the screening process (FCRA compliance). notice.notice_type can be \'adverse_action\'. Linking notice.screening_id → screening.screening_id connects the a' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Screening .

ind:taxAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Tax Assessment Id' ;
    rdfs:comment 'Foreign key linking to valuation.tax_assessment. Business justification: In NNN leases, landlords issue formal notices to tenants passing through property tax obligations, referencing the specific tax assessment. Tax assessment appeal notices and payment demand notices mus' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxAssessment .

ind:cureDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Cure Deadline Date' ;
    rdfs:comment 'The date by which the tenant must remedy or cure the identified default or violation to avoid further legal action, applicable for cure/default notices. Distinct from the statutory response deadline.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:curedFlag rdf:type rdf:Property ;
    rdfs:label 'Cured Flag' ;
    rdfs:comment 'Indicates whether the tenant has successfully cured the default or violation identified in a cure/default notice prior to the cure deadline. True = cured; False = not cured or not applicable.' ;
    rdfs:domain ind:Notice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defaultDescription rdf:type rdf:Property ;
    rdfs:label 'Default Description' ;
    rdfs:comment 'Narrative description of the lease default, HOA violation, or breach of covenant that triggered the notice, applicable for cure/default notices, termination notices, and HOA violation notices. Supports litigation readiness.' ;
    rdfs:domain ind:Notice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryConfirmationDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Confirmation Date' ;
    rdfs:comment 'The date on which delivery of the notice was confirmed, such as the date a certified mail receipt was signed or a portal read receipt was generated. Supports statutory compliance and litigation documentation.' ;
    rdfs:domain ind:Notice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryConfirmed rdf:type rdf:Property ;
    rdfs:label 'Delivery Confirmed' ;
    rdfs:comment 'Indicates whether delivery of the notice has been confirmed through a receipt, read receipt, certified mail tracking, or in-person acknowledgement. True = delivery confirmed; False = delivery unconfirmed or pending.' ;
    rdfs:domain ind:Notice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'The channel or mechanism used to deliver the notice to the recipient, as required by applicable landlord-tenant statutes. Supports statutory compliance verification and litigation readiness.' ;
    rdfs:domain ind:Notice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTrackingReference rdf:type rdf:Property ;
    rdfs:label 'Delivery Tracking Reference' ;
    rdfs:comment 'External tracking identifier for the notice delivery, such as a USPS certified mail tracking number, courier waybill number, or portal message thread ID. Supports proof-of-delivery documentation for litigation readiness.' ;
    rdfs:domain ind:Notice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalSignatureReference rdf:type rdf:Property ;
    rdfs:label 'Digital Signature Reference' ;
    rdfs:comment 'Reference identifier for the digital signature envelope or transaction in DocuSign CLM or equivalent contract lifecycle management system, linking the notice to its executed digital signature record.' ;
    rdfs:domain ind:Notice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReference rdf:type rdf:Property ;
    rdfs:label 'Document Reference' ;
    rdfs:comment 'Reference to the physical or digital document file associated with this notice, such as a document management system path, SharePoint URL, or Yardi document attachment ID.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estoppelDueDate rdf:type rdf:Property ;
    rdfs:label 'Estoppel Due Date' ;
    rdfs:comment 'The date by which the tenant must return the completed and signed estoppel certificate, applicable when notice_type is \'estoppel_request\'. Supports transaction closing timelines and CMBS compliance.' ;
    rdfs:domain ind:Notice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estoppelRequestedBy rdf:type rdf:Property ;
    rdfs:label 'Estoppel Requested By' ;
    rdfs:comment 'Name of the party (lender, buyer, or investor) requesting an estoppel certificate from the tenant, applicable when notice_type is \'estoppel_request\'. Supports transaction due diligence and CMBS/RMBS compliance.' ;
    rdfs:domain ind:Notice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalCounselEngaged rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Engaged' ;
    rdfs:comment 'Indicates whether legal counsel has been engaged in connection with this notice, relevant for default, termination, and eviction-related notices. True = legal counsel engaged; False = no legal counsel engaged.' ;
    rdfs:domain ind:Notice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:litigationHold rdf:type rdf:Property ;
    rdfs:label 'Litigation Hold' ;
    rdfs:comment 'Indicates whether this notice record is subject to a litigation hold, preventing deletion or modification of the record for legal discovery purposes. True = litigation hold active; False = no hold.' ;
    rdfs:domain ind:Notice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newRentAmount rdf:type rdf:Property ;
    rdfs:label 'New Rent Amount' ;
    rdfs:comment 'The revised rent amount that will be payable following the rent increase notice, expressed in the lease currency. Supports lease administration, AR forecasting, and NOI reporting.' ;
    rdfs:domain ind:Notice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:noticeNumber rdf:type rdf:Property ;
    rdfs:label 'Notice Number' ;
    rdfs:comment 'Externally-visible, human-readable reference number assigned to this notice for tracking in lease administration systems such as Yardi Voyager and MRI Software. Format: NTC-YYYY-NNNNNN.' ;
    rdfs:domain ind:Notice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeStatus rdf:type rdf:Property ;
    rdfs:label 'Notice Status' ;
    rdfs:comment 'Current lifecycle state of the notice record, tracking progression from draft through issuance, delivery confirmation, tenant response, and final closure or withdrawal. [ENUM-REF-CANDIDATE: draft|issued|delivered|acknowledged|responded|expired|withdrawn|closed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Notice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeType rdf:type rdf:Property ;
    rdfs:label 'Notice Type' ;
    rdfs:comment 'Classification of the formal notice by its legal or administrative purpose. [ENUM-REF-CANDIDATE: vacate|renewal|rent_increase|cure_default|termination|hoa_violation|estoppel_request|lease_extension|entry_notice|other — promote to reference product]' ;
    rdfs:domain ind:Notice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodDays rdf:type rdf:Property ;
    rdfs:label 'Period Days' ;
    rdfs:comment 'The number of calendar days constituting the legally required notice period for this notice type under applicable state or local landlord-tenant statutes (e.g., 3, 30, 60, 90 days). Supports statutory compliance validation.' ;
    rdfs:domain ind:Notice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalOfferRentAmount rdf:type rdf:Property ;
    rdfs:label 'Renewal Offer Rent Amount' ;
    rdfs:comment 'The proposed rent amount offered to the tenant in a lease renewal notice, expressed in the lease currency. Supports lease administration, NOI forecasting, and deal pipeline management.' ;
    rdfs:domain ind:Notice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalOfferTermMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Offer Term Months' ;
    rdfs:comment 'The proposed lease renewal term in months offered to the tenant in a lease renewal notice. Supports WALT and WALE (Weighted Average Lease Term/Expiry) analytics and portfolio lease expiry management.' ;
    rdfs:domain ind:Notice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rentIncreaseAmount rdf:type rdf:Property ;
    rdfs:label 'Rent Increase Amount' ;
    rdfs:comment 'The dollar amount by which the rent is being increased, applicable when notice_type is \'rent_increase\'. Expressed in the lease currency. Supports lease administration and financial reporting.' ;
    rdfs:domain ind:Notice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rentIncreasePct rdf:type rdf:Property ;
    rdfs:label 'Rent Increase Pct' ;
    rdfs:comment 'The percentage by which the rent is being increased, applicable when notice_type is \'rent_increase\'. Expressed as a decimal (e.g., 0.0350 = 3.50%). Supports lease administration and CPI-linked rent escalation analysis.' ;
    rdfs:domain ind:Notice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseDate rdf:type rdf:Property ;
    rdfs:label 'Response Date' ;
    rdfs:comment 'The date on which the tenant or landlord formally responded to the notice. Used to assess timeliness of response relative to the statutory response deadline.' ;
    rdfs:domain ind:Notice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Response Deadline Date' ;
    rdfs:comment 'The legally mandated deadline by which the recipient must respond to or comply with the notice, calculated per applicable state or local landlord-tenant statutes (e.g., 3-day, 30-day, 60-day notice periods).' ;
    rdfs:domain ind:Notice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseReceived rdf:type rdf:Property ;
    rdfs:label 'Response Received' ;
    rdfs:comment 'Indicates whether a formal response has been received from the notice recipient within the statutory response period. True = response received; False = no response received.' ;
    rdfs:domain ind:Notice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseSummary rdf:type rdf:Property ;
    rdfs:label 'Response Summary' ;
    rdfs:comment 'Brief narrative description of the response received from the notice recipient, capturing the nature of the response (e.g., tenant agreed to vacate, tenant disputed the default, tenant requested cure extension).' ;
    rdfs:domain ind:Notice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vacateDate rdf:type rdf:Property ;
    rdfs:label 'Vacate Date' ;
    rdfs:comment 'The date by which the tenant is required to vacate the premises, applicable for notice-to-vacate and lease termination notices. Supports occupancy planning, unit turnover scheduling, and portfolio management.' ;
    rdfs:domain ind:Notice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentId rdf:type rdf:Property ;
    rdfs:label 'Document Id' ;
    rdfs:comment 'Primary key for document' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:guarantyId rdf:type rdf:Property ;
    rdfs:label 'Guaranty Id' ;
    rdfs:comment 'Foreign key linking to lease.guaranty. Business justification: Personal guarantee instruments, corporate guarantee letters, and guaranty enforcement documents must be retrievable against the guaranty record for enforcement proceedings and credit risk management. ' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Guaranty .

ind:issuingCountryId rdf:type rdf:Property ;
    rdfs:label 'Issuing Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Document validity, regulatory compliance, and retention rules depend on the issuing country (e.g., GDPR applicability, AML requirements, foreign document authentication). Domain experts expect a prope' ;
    rdfs:domain ind:Document ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:previousVersionDocumentId rdf:type rdf:Property ;
    rdfs:label 'Previous Version Document Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediately preceding version of this document. Enables full version chain traversal for audit and compliance purposes. Null for first-version documents.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:accessRestrictionNotes rdf:type rdf:Property ;
    rdfs:label 'Access Restriction Notes' ;
    rdfs:comment 'Free-text notes describing specific access restrictions, need-to-know limitations, or legal holds applied to the document beyond standard confidentiality level controls.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'Data classification level assigned to the document based on its sensitivity and access control requirements. Drives role-based access permissions within the document repository and compliance with GDPR and SOX data governance policies.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalSignatureStatus rdf:type rdf:Property ;
    rdfs:label 'Digital Signature Status' ;
    rdfs:comment 'Current status of the digital signature workflow for the document within DocuSign CLM. Tracks whether all required signatories have executed the document electronically.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentCategory rdf:type rdf:Property ;
    rdfs:label 'Document Category' ;
    rdfs:comment 'High-level grouping of the document for portfolio-wide reporting and access control. Segments documents into legal, financial, identity, compliance, operational, and correspondence buckets.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDescription rdf:type rdf:Property ;
    rdfs:label 'Document Description' ;
    rdfs:comment 'Free-text narrative describing the content, purpose, and context of the document. Provides additional detail beyond document_name and document_type for search, discovery, and review workflows.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentName rdf:type rdf:Property ;
    rdfs:label 'Document Name' ;
    rdfs:comment 'Human-readable title or name of the document as displayed in the tenant document repository (e.g., \'Lease Abstract — Suite 400\', \'Certificate of Incorporation — ABC Corp\').' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'Externally-known unique business identifier assigned to the document, used for cross-referencing in DocuSign CLM, Yardi Voyager, and MRI Software. Supports audit trails and regulatory compliance tracking.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStatus rdf:type rdf:Property ;
    rdfs:label 'Document Status' ;
    rdfs:comment 'Current lifecycle state of the document record. \'active\' indicates the document is current and valid; \'expired\' indicates the document has passed its expiry date; \'superseded\' indicates a newer version has replaced it; \'archived\' indicates the document is retained for historical purposes; \'pending_review\' indicates the document is awaiting approval or verification.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'File format or MIME type of the stored document. Supports rendering, conversion, and archival compatibility checks within the document management system. [ENUM-REF-CANDIDATE: PDF|DOCX|XLSX|JPEG|PNG|TIFF|MSG — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeKb rdf:type rdf:Property ;
    rdfs:label 'File Size Kb' ;
    rdfs:comment 'Size of the document file in kilobytes at the time of upload. Used for storage capacity planning and document repository management.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCurrentVersion rdf:type rdf:Property ;
    rdfs:label 'Is Current Version' ;
    rdfs:comment 'Indicates whether this document record represents the most current active version. True when this is the latest version; False when superseded by a newer version. Supports version chain navigation.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVerified rdf:type rdf:Property ;
    rdfs:label 'Is Verified' ;
    rdfs:comment 'Indicates whether the document has been verified for authenticity and completeness by an authorized reviewer (e.g., property manager, compliance officer, or legal counsel). True when verified; False when pending verification.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'ISO 639-1 language code indicating the primary language of the document (e.g., \'en\', \'fr\', \'es\'). Supports multilingual tenant portfolios and translation workflow management.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pageCount rdf:type rdf:Property ;
    rdfs:label 'Page Count' ;
    rdfs:comment 'Total number of pages in the document. Supports document completeness validation and review effort estimation for lease administration and compliance teams.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:purgeEligibleDate rdf:type rdf:Property ;
    rdfs:label 'Purge Eligible Date' ;
    rdfs:comment 'Earliest date on which the document may be permanently deleted in compliance with the applicable retention policy. Calculated from upload_date or execution_date plus retention_period_years. Supports GDPR right-to-erasure workflows.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'Date on which the document was physically or electronically received from the tenant or counterparty. Distinct from upload_date; supports SLA tracking for tenant onboarding and lease administration workflows.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Retention Period Years' ;
    rdfs:comment 'Mandatory retention period in years for the document as required by applicable regulatory frameworks (e.g., IRS tax records — 7 years, FASB ASC 842 lease records — lease term plus 5 years). Drives automated archival and purge scheduling.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signatoryCount rdf:type rdf:Property ;
    rdfs:label 'Signatory Count' ;
    rdfs:comment 'Total number of signatories required to fully execute the document. Used to track completion status of multi-party agreements such as SNDA agreements and lease amendments.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageReference rdf:type rdf:Property ;
    rdfs:label 'Storage Reference' ;
    rdfs:comment 'Fully qualified path, URI, or object key pointing to the physical document file in the enterprise content management or cloud storage system (e.g., Azure Blob Storage, SharePoint, Yardi Document Management). Enables direct retrieval of the document binary.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uploadDate rdf:type rdf:Property ;
    rdfs:label 'Upload Date' ;
    rdfs:comment 'Calendar date on which the document was uploaded or ingested into the tenant document repository. Used for document age tracking and onboarding completeness reporting.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verified Timestamp' ;
    rdfs:comment 'Date and time at which the document verification was completed by the authorized reviewer. Provides a precise audit timestamp for compliance and regulatory reporting.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Version identifier of the document following semantic versioning conventions (e.g., \'1.0\', \'2.1\'). Enables tracking of document revisions and supersession history within the tenant repository.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Parent Cost Center Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent cost center in the cost center hierarchy. Enables hierarchical roll-up of financial data for portfolio-level P&L, EBITDA consolidation, and management reporting. Null for top-level cost centers.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'Method used to allocate costs from this cost center to other cost centers or properties. \'direct\' = direct charge; \'percentage\' = fixed percentage split; \'square_footage\' = allocated by GLA/NLA; \'headcount\' = allocated by employee count; \'none\' = no allocation (standalone center).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocation Percentage' ;
    rdfs:comment 'Fixed percentage used when allocation_method is \'percentage\'. Represents the share of this cost center\'s costs to be allocated to downstream cost centers or properties. Value between 0.00 and 100.00.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Budget Amount' ;
    rdfs:comment 'Total approved annual budget for this cost center in the functional currency. Represents the planned OPEX and/or CAPEX for the fiscal year as approved in Yardi Voyager or SAP S/4HANA budgeting module. Used for variance analysis and NOI forecasting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessUnit rdf:type rdf:Property ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'The business unit or division to which this cost center is assigned (e.g., Commercial Real Estate, Residential, Development, Investment Advisory). Supports segment-level P&L reporting and portfolio analytics.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:camPoolIndicator rdf:type rdf:Property ;
    rdfs:label 'Cam Pool Indicator' ;
    rdfs:comment 'Indicates whether this cost center is designated as a Common Area Maintenance (CAM) expense pool. When True, costs accumulated here are subject to CAM reconciliation and tenant recovery billing per lease agreements.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capexEligible rdf:type rdf:Property ;
    rdfs:label 'Capex Eligible' ;
    rdfs:comment 'Indicates whether Capital Expenditure (CAPEX) postings are permitted against this cost center. Controls GL posting rules to ensure proper OPEX vs. CAPEX segregation for fixed asset accounting and financial reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:centerType rdf:type rdf:Property ;
    rdfs:label 'Center Type' ;
    rdfs:comment 'Classification of the cost center by its organizational scope. \'property\' = property-level cost center tied to a specific asset; \'corporate\' = enterprise-wide overhead; \'departmental\' = functional department (e.g., Finance, HR); \'development\' = active construction or development project; \'investment\' = investment vehicle or fund-level tracking.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'SAP S/4HANA or Yardi Voyager company code representing the legal entity or organizational unit to which this cost center belongs. Used for financial consolidation, statutory reporting, and SOX-compliant entity-level controls.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'SAP S/4HANA controlling area code that governs the management accounting rules, currency, and fiscal year variant applicable to this cost center. Defines the scope of internal cost accounting and allocation cycles.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Center Category' ;
    rdfs:comment 'Financial category indicating the primary nature of expenditures tracked by this cost center. \'opex\' = Operating Expenditure (OPEX) only; \'capex\' = Capital Expenditure (CAPEX) only; \'mixed\' = both OPEX and CAPEX; \'overhead\' = corporate overhead allocation; \'revenue\' = revenue-generating center for NOI tracking.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the cost center within the chart of accounts and GL posting structure. Used in Yardi Voyager and SAP S/4HANA for financial allocation, NOI statements, and OPEX/CAPEX tracking. Serves as the business-facing identifier across all financial systems.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Center Description' ;
    rdfs:comment 'Detailed narrative description of the cost center\'s business purpose, scope of financial activities, and any special accounting treatment or allocation rules. Used for financial reporting documentation and audit support.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'Full descriptive name of the cost center as displayed in financial reports, NOI statements, and budget documents. Examples: \'Downtown Office Tower — Property Operations\', \'Corporate Finance Department\', \'Residential Portfolio — Leasing\'.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center. \'active\' = open for GL postings; \'inactive\' = temporarily suspended; \'pending\' = awaiting activation; \'closed\' = permanently decommissioned; \'locked\' = frozen for period-end close or audit.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction where this cost center operates. Governs applicable tax regulations, statutory reporting requirements, and currency rules.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'Code identifying the functional department associated with this cost center (e.g., Finance, Property Management, Leasing, Development). Used for departmental OPEX allocation and headcount cost tracking.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveTo rdf:type rdf:Property ;
    rdfs:label 'Effective To' ;
    rdfs:comment 'Date on which the cost center ceases to be active. Null indicates an open-ended cost center with no planned closure. Used for period-accurate financial reporting and historical GL analysis.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:esgTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Esg Tracking Enabled' ;
    rdfs:comment 'Indicates whether Environmental, Social, and Governance (ESG) cost tracking is enabled for this cost center. When True, OPEX related to LEED certification, BREEAM compliance, energy efficiency, and sustainability initiatives are tracked separately.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'The fiscal year for which the cost center\'s budget and financial plan are defined. Enables year-over-year budget comparison and period-accurate financial reporting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalYearVariant rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Variant' ;
    rdfs:comment 'Code identifying the fiscal year variant (calendar year, April–March, October–September, etc.) applicable to this cost center. Sourced from SAP S/4HANA controlling area configuration. Ensures correct period mapping for financial consolidation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountGroup rdf:type rdf:Property ;
    rdfs:label 'Gl Account Group' ;
    rdfs:comment 'The GL account group or chart of accounts segment to which this cost center belongs. Governs which GL accounts are permissible for posting against this cost center. Sourced from SAP S/4HANA chart of accounts configuration and Yardi Voyager GL setup.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyIndicator rdf:type rdf:Property ;
    rdfs:label 'Intercompany Indicator' ;
    rdfs:comment 'Indicates whether this cost center is used for intercompany transactions between legal entities within the real estate portfolio. When True, intercompany elimination rules apply during financial consolidation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noiTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Noi Tracking Enabled' ;
    rdfs:comment 'Indicates whether this cost center is configured for Net Operating Income (NOI) statement generation. When True, the cost center participates in property-level P&L reporting including EGI, PGI, GOI, and NOI calculations.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'Code of the profit center to which this cost center is assigned for management accounting and P&L reporting. Enables NOI statement roll-up and EBITDA calculation at the profit center level in SAP S/4HANA.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleManager rdf:type rdf:Property ;
    rdfs:label 'Responsible Manager' ;
    rdfs:comment 'Full name of the manager or cost center owner accountable for financial performance, budget adherence, and OPEX/CAPEX approvals for this cost center. Used in SOX-compliant approval workflows and financial reporting sign-offs.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated display name for the cost center used in condensed financial reports, dashboards, and system interfaces where space is limited.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlRelevant rdf:type rdf:Property ;
    rdfs:label 'Sox Control Relevant' ;
    rdfs:comment 'Indicates whether this cost center is subject to Sarbanes-Oxley (SOX) internal control requirements. When True, all financial postings require documented approval workflows and are subject to SOX audit procedures.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountCode rdf:type rdf:Property ;
    rdfs:label 'Account Code' ;
    rdfs:comment 'The externally-known alphanumeric code that uniquely identifies the GL account within the enterprise chart of accounts. Used across Yardi Voyager and SAP S/4HANA for journal entry posting, financial reporting, and cross-system reconciliation. Serves as the business-facing natural key.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountDescription rdf:type rdf:Property ;
    rdfs:label 'Account Description' ;
    rdfs:comment 'Extended narrative description of the GL account\'s purpose, the types of transactions it captures, and any applicable posting rules or restrictions. Provides guidance to accountants and property managers on correct account usage. Sourced from the account master in Yardi Voyager and SAP S/4HANA.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountGroup rdf:type rdf:Property ;
    rdfs:label 'Account Group' ;
    rdfs:comment 'Organizational grouping of GL accounts used to control field selection, number range assignment, and reporting segmentation in SAP S/4HANA (e.g., \'Revenue Accounts\', \'Expense Accounts\', \'Balance Sheet Accounts\', \'Intercompany Accounts\'). Aligns with SAP account group configuration and Yardi Voyager account category groupings.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'Human-readable descriptive name of the GL account as displayed in financial statements, NOI reports, and budget templates (e.g., \'Rental Revenue – Office\', \'Common Area Maintenance Expense\', \'Tenant Improvement Allowance\'). Sourced from Yardi Voyager and SAP S/4HANA account master.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountShortName rdf:type rdf:Property ;
    rdfs:label 'Account Short Name' ;
    rdfs:comment 'Abbreviated account name (maximum 20 characters) used in space-constrained financial reports, trial balance printouts, and system interfaces where the full account name cannot be displayed. Sourced from SAP S/4HANA short text field and Yardi Voyager account abbreviation.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the GL account. \'active\' accounts accept journal postings; \'inactive\' accounts are retired and blocked from new postings; \'blocked\' accounts are temporarily suspended pending review; \'pending_review\' accounts are newly created and awaiting controller approval. Supports SOX-compliant financial controls over the chart of accounts.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountSubtype rdf:type rdf:Property ;
    rdfs:label 'Account Subtype' ;
    rdfs:comment 'Secondary classification providing granular categorization within the account type (e.g., \'current asset\', \'fixed asset\', \'operating revenue\', \'CAM expense\', \'capital expenditure\', \'right-of-use asset\', \'lease liability\'). Supports NOI statement line-item mapping, CAPEX vs. OPEX segregation, and FASB ASC 842 / IFRS 16 lease accounting classification. [ENUM-REF-CANDIDATE: current_asset|fixed_asset|right_of_use_asset|intangible_asset|current_liability|long_term_liability|lease_liability|operating_revenue|other_income|operating_expense|cam_expense|capex|depreciation|equity_contributed|retained_earnings — promote to reference product]' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'High-level classification of the GL account per the fundamental accounting equation: asset, liability, equity, revenue, or expense. Drives balance sheet vs. income statement placement and normal balance determination. Aligns with FASB and IFRS financial statement presentation requirements.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:argusLineItem rdf:type rdf:Property ;
    rdfs:label 'Argus Line Item' ;
    rdfs:comment 'The corresponding line item label in Argus Enterprise cash flow models. Maps GL accounts to Argus revenue and expense line items to enable reconciliation between actual financial results (Yardi/SAP) and Argus valuation model projections. Supports CAP rate validation, DCF analysis, and investment performance reporting.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetRelevant rdf:type rdf:Property ;
    rdfs:label 'Budget Relevant' ;
    rdfs:comment 'Indicates whether this GL account participates in the annual budgeting and forecasting process in Yardi Voyager and SAP S/4HANA. When True, budget amounts are planned against this account and actuals-vs-budget variance reporting is generated. When False, the account is excluded from budget templates (e.g., statistical or memo accounts).' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:camRecoverableFlag rdf:type rdf:Property ;
    rdfs:label 'Cam Recoverable Flag' ;
    rdfs:comment 'Indicates whether expenses posted to this GL account are recoverable from tenants as Common Area Maintenance (CAM) charges under NNN or modified gross lease structures. Drives CAM reconciliation calculations in Yardi Voyager and MRI Software, determining which operating expenses are billable to tenants versus landlord-absorbed.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capexOpexFlag rdf:type rdf:Property ;
    rdfs:label 'Capex Opex Flag' ;
    rdfs:comment 'Classifies the GL account as a Capital Expenditure (CAPEX) account, Operating Expenditure (OPEX) account, or not applicable (for balance sheet, equity, or revenue accounts). Drives capitalization policy enforcement, fixed asset creation workflows in Yardi Voyager Fixed Assets module, and budget segregation between capital and operating budgets.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashFlowCategory rdf:type rdf:Property ;
    rdfs:label 'Cash Flow Category' ;
    rdfs:comment 'Maps the GL account to its classification in the cash flow statement per FASB ASC 230: operating activities (rental receipts, CAM collections, operating disbursements), investing activities (property acquisitions, capital improvements, dispositions), financing activities (mortgage proceeds, loan repayments, equity distributions), or not applicable for non-cash accounts.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationAccountCode rdf:type rdf:Property ;
    rdfs:label 'Consolidation Account Code' ;
    rdfs:comment 'The standardized account code used in the group-level financial consolidation chart of accounts in SAP S/4HANA. Local entity accounts map to this consolidation account to enable automated elimination of intercompany transactions and production of consolidated financial statements across all legal entities in the real estate portfolio.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Element Category' ;
    rdfs:comment 'Classifies the GL account as a primary cost element (originating costs from external postings), secondary cost element (internal cost allocations and settlements), or not applicable (for balance sheet and revenue accounts). Used in SAP S/4HANA Controlling (CO) module for property-level cost center accounting and overhead allocation to real estate assets.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'The date on which this GL account was or will be deactivated and blocked from further journal entry postings. Null for currently active accounts. Supports account lifecycle management, chart of accounts rationalization, and SOX-compliant retirement of obsolete accounts.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ebitdaCategory rdf:type rdf:Property ;
    rdfs:label 'Ebitda Category' ;
    rdfs:comment 'Maps the GL account to its role in the EBITDA roll-up calculation used for investment analysis, DSCR calculations, and portfolio performance reporting. Distinguishes revenue, operating expense, EBITDA add-back items, interest, tax, depreciation, and amortization lines. Supports Argus Enterprise and SAP S/4HANA financial consolidation. [ENUM-REF-CANDIDATE: revenue|operating_expense|ebitda_addback|interest|tax|depreciation|amortization|below_ebitda — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fasbAsc842Flag rdf:type rdf:Property ;
    rdfs:label 'Fasb Asc842 Flag' ;
    rdfs:comment 'Indicates whether this GL account is specifically designated for FASB ASC 842 lease accounting entries, including right-of-use (ROU) asset recognition, lease liability amortization, operating lease expense, and finance lease interest. Enables automated identification of ASC 842-impacted accounts for lessee accounting compliance and audit trail.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ffoClassification rdf:type rdf:Property ;
    rdfs:label 'Ffo Classification' ;
    rdfs:comment 'Indicates whether the GL account is included in NAREIT-defined Funds From Operations (FFO), excluded from FFO, or treated as an Adjusted Funds From Operations (AFFO) adjustment item. Critical for REIT financial reporting to the SEC and investor relations disclosures. Null for non-REIT entities.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementLine rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Line' ;
    rdfs:comment 'The specific line item label on the published financial statement (income statement, balance sheet, or cash flow statement) to which this account maps. Supports automated financial statement generation, SEC reporting for publicly traded REITs, and FASB/IFRS presentation requirements (e.g., \'Rental Revenue\', \'Operating Expenses\', \'Right-of-Use Assets\', \'Lease Liabilities\').' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrs16Flag rdf:type rdf:Property ;
    rdfs:label 'Ifrs16 Flag' ;
    rdfs:comment 'Indicates whether this GL account is mapped to IFRS 16 lease accounting requirements, covering right-of-use asset recognition, lease liability measurement, depreciation of ROU assets, and interest on lease liabilities. Supports entities reporting under IFRS in international jurisdictions alongside FASB ASC 842 for dual-reporting entities.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intercompanyFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Flag' ;
    rdfs:comment 'Indicates whether this GL account is designated for intercompany transactions between legal entities within the real estate portfolio (e.g., management fee income/expense, intercompany loans, intercompany distributions). Intercompany accounts are eliminated during financial consolidation in SAP S/4HANA to produce consolidated financial statements.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPostingAccount rdf:type rdf:Property ;
    rdfs:label 'Is Posting Account' ;
    rdfs:comment 'Indicates whether this account is a leaf-level posting account that accepts direct journal entry postings (True) or a summary/header account used only for roll-up and reporting purposes (False). Enforces the accounting control that transactions are posted only to detail accounts, not to summary nodes.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalEntityCode rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Code' ;
    rdfs:comment 'Code identifying the legal entity (company code in SAP S/4HANA) to which this GL account belongs. In a multi-entity real estate portfolio, different legal entities (property-owning SPEs, management companies, REITs) may maintain separate charts of accounts or share a common chart with entity-specific account assignments.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mriAccountCode rdf:type rdf:Property ;
    rdfs:label 'Mri Account Code' ;
    rdfs:comment 'The corresponding account code as configured in MRI Software for investment management and residential property accounting. Supports cross-system reconciliation for portfolios managed in MRI alongside Yardi Voyager, ensuring consistent GL mapping across both property management platforms.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noiCategory rdf:type rdf:Property ;
    rdfs:label 'Noi Category' ;
    rdfs:comment 'Maps the GL account to its position in the real estate NOI waterfall: Potential Gross Income (PGI), vacancy/credit loss, Effective Gross Income (EGI), operating expense, Net Operating Income (NOI), or below-NOI items (debt service, depreciation, capital expenditures). Enables automated NOI statement generation and CAP rate calculations at property and portfolio level.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:normalBalance rdf:type rdf:Property ;
    rdfs:label 'Normal Balance' ;
    rdfs:comment 'Indicates whether the account\'s natural (expected) balance is a debit or credit per double-entry bookkeeping rules. Assets and expenses carry a debit normal balance; liabilities, equity, and revenue carry a credit normal balance. Used by Yardi Voyager and SAP S/4HANA to validate journal entry postings and detect sign reversals.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAccountCode rdf:type rdf:Property ;
    rdfs:label 'Parent Account Code' ;
    rdfs:comment 'The account code of the immediate parent account in the GL account hierarchy. Enables roll-up of financial data from detail accounts to summary accounts for NOI statements, EBITDA roll-ups, and portfolio-level P&L reporting. Null for top-level (root) accounts in the hierarchy.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterRelevant rdf:type rdf:Property ;
    rdfs:label 'Profit Center Relevant' ;
    rdfs:comment 'Indicates whether postings to this GL account require a profit center assignment in SAP S/4HANA, enabling property-level and portfolio-level profitability analysis. When True, all journal entries to this account must carry a profit center (typically mapped to a property or legal entity) to support segment reporting and NOI attribution.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soxControlFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Control Flag' ;
    rdfs:comment 'Indicates whether this GL account is subject to SOX Section 302/404 internal control over financial reporting (ICFR) requirements. Accounts flagged as SOX-relevant require documented controls, segregation of duties enforcement, and periodic management testing. Applicable to publicly traded REITs and their subsidiaries.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'Tax determination code assigned to the GL account for automated sales tax, VAT, or property tax calculation during transaction posting. Maps to the tax configuration in SAP S/4HANA and Yardi Voyager to ensure correct tax treatment on revenue and expense postings. Null for accounts not subject to tax determination.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yardiAccountCode rdf:type rdf:Property ;
    rdfs:label 'Yardi Account Code' ;
    rdfs:comment 'The corresponding account code as configured in Yardi Voyager Property Management system. Enables cross-system reconciliation between Yardi Voyager (operational source of record for property-level accounting) and SAP S/4HANA (financial consolidation system). Used for ETL mapping and data lineage tracking in the silver layer.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentEntityLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Parent Entity Legal Entity Id' ;
    rdfs:comment 'Reference to the immediate parent legal entity in the ownership hierarchy, enabling consolidation roll-ups for REIT structures, holding companies, and joint-venture entities. Null for top-level entities.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:primaryLegalFunctionalCurrencyCodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Legal Functional Currency Code Id' ;
    rdfs:comment 'Foreign key linking to reference.currency_code. Business justification: RE legal entities (REITs, LPs, JVs) have a designated functional currency for GAAP/IFRS consolidation, investor reporting, and currency translation adjustments. Role-prefixed \'functional_\' distinguish' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CurrencyCode .

ind:argusEntityCode rdf:type rdf:Property ;
    rdfs:label 'Argus Entity Code' ;
    rdfs:comment 'Entity identifier used in Argus Enterprise for valuation, cash flow modeling, and portfolio reporting. Links this legal entity to Argus DCF models and NAV calculations.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Audit Period End Date' ;
    rdfs:comment 'End date of the most recently completed external audit period for this entity. Tracks audit cycle completion for SOX compliance monitoring and financial statement issuance scheduling.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditorName rdf:type rdf:Property ;
    rdfs:label 'Auditor Name' ;
    rdfs:comment 'Name of the independent registered public accounting firm (PCAOB-registered) responsible for auditing the entity\'s financial statements. Required for SOX Section 404 attestation and SEC annual report disclosures.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aumUsd rdf:type rdf:Property ;
    rdfs:label 'Aum Usd' ;
    rdfs:comment 'Total gross asset value (GAV) of real estate assets owned or managed by this legal entity, expressed in USD. Key metric for fund reporting, investor disclosures, and management fee calculations. Sourced from Argus Enterprise or MRI portfolio reports.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ein rdf:type rdf:Property ;
    rdfs:label 'Ein' ;
    rdfs:comment 'IRS-assigned Employer Identification Number (EIN) / Federal Tax Identification Number for the entity. Required for tax filings (Form 1065, 1120-REIT, K-1), lender due diligence, and title company transactions.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityCode rdf:type rdf:Property ;
    rdfs:label 'Entity Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the legal entity across operational systems (Yardi company code, SAP company code). Used as the cross-system integration key for GL, AP, AR, and financial consolidation.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitySubtype rdf:type rdf:Property ;
    rdfs:label 'Entity Subtype' ;
    rdfs:comment 'Functional subclassification of the entity within the enterprise structure. Distinguishes Special Purpose Entities (SPEs) used for property ownership from operating companies, fund vehicles, and management entities. [ENUM-REF-CANDIDATE: HOLDING_CO|OPERATING_CO|SPE|FUND|MANAGEMENT_CO|DEVELOPMENT_CO|FINANCE_CO|ADVISORY_CO — promote to reference product]' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearEndMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year End Month' ;
    rdfs:comment 'Calendar month (1–12) in which the entity\'s fiscal year ends. Determines the period-end close schedule, annual report filing deadlines, and tax return due dates. Most US REITs use December (12) fiscal year end.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:glCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Gl Company Code' ;
    rdfs:comment 'Company code assigned to this legal entity in the General Ledger system (SAP S/4HANA BUKRS or Yardi company code). The primary integration key linking this master record to all financial transactions, journal entries, and trial balances.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isReitElected rdf:type rdf:Property ;
    rdfs:label 'Is Reit Elected' ;
    rdfs:comment 'Indicates whether the entity has made a valid REIT election under IRC Section 856. REIT-elected entities must distribute at least 90% of taxable income, qualify asset and income tests, and file Form 1120-REIT annually.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSecReporting rdf:type rdf:Property ;
    rdfs:label 'Is Sec Reporting' ;
    rdfs:comment 'Indicates whether the entity is a reporting company subject to SEC disclosure requirements (10-K, 10-Q, 8-K filings). Triggers SOX compliance obligations, XBRL tagging, and enhanced internal control requirements.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSoxInScope rdf:type rdf:Property ;
    rdfs:label 'Is Sox In Scope' ;
    rdfs:comment 'Indicates whether the entity is within scope for SOX Section 404 internal control over financial reporting (ICFR) assessments. Determines which entities require management assessment and external auditor attestation.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVariableInterestEntity rdf:type rdf:Property ;
    rdfs:label 'Is Variable Interest Entity' ;
    rdfs:comment 'Indicates whether the entity qualifies as a Variable Interest Entity (VIE) under FASB ASC 810, requiring consolidation by the primary beneficiary regardless of voting interest. Common for SPEs and certain JV structures in real estate.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mriEntityCode rdf:type rdf:Property ;
    rdfs:label 'Mri Entity Code' ;
    rdfs:comment 'Entity identifier assigned in MRI Software for investment management and property accounting. Enables cross-system reconciliation between MRI and SAP/Yardi financial records.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:navUsd rdf:type rdf:Property ;
    rdfs:label 'Nav Usd' ;
    rdfs:comment 'Net Asset Value of the entity calculated as total assets minus total liabilities, expressed in USD. Primary valuation metric for REIT and fund entities used in investor reporting, unit pricing, and performance benchmarking per INREV/NCREIF guidelines.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registeredAgentName rdf:type rdf:Property ;
    rdfs:label 'Registered Agent Name' ;
    rdfs:comment 'Name of the entity\'s designated registered agent responsible for receiving legal service of process, state notices, and annual report reminders on behalf of the entity.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'State Registration Number' ;
    rdfs:comment 'State-issued entity registration or charter number assigned by the Secretary of State in the jurisdiction of formation. Used for state tax filings, good-standing certificates, and title searches.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateTaxNexus rdf:type rdf:Property ;
    rdfs:label 'State Tax Nexus' ;
    rdfs:comment 'Comma-separated list of two-letter US state codes where the entity has established tax nexus through property ownership, operations, or employee presence. Drives multi-state apportionment and state tax filing obligations.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxClassification rdf:type rdf:Property ;
    rdfs:label 'Tax Classification' ;
    rdfs:comment 'IRS federal tax classification of the entity for income tax purposes. Determines the applicable tax return form (1120-REIT, 1065, Schedule C) and pass-through treatment for investors.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxYearEndMonth rdf:type rdf:Property ;
    rdfs:label 'Tax Year End Month' ;
    rdfs:comment 'Calendar month (1–12) in which the entity\'s tax year ends, which may differ from the fiscal year end for certain partnership structures. Drives K-1 issuance timing and estimated tax payment schedules.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'Operating or \'doing business as\' (DBA) name used in commercial transactions, marketing, and tenant-facing communications when different from the registered legal name.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:navCalculationId rdf:type rdf:Property ;
    rdfs:label 'Nav Calculation Id' ;
    rdfs:comment 'Foreign key linking to valuation.nav_calculation. Business justification: NAV calculations trigger journal entries for fair value adjustments (unrealized gains/losses) in fund accounting. Linking journal_entry to nav_calculation supports the audit trail from GL posting to t' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NavCalculation .

ind:regulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_filing. Business justification: Journal entries are created to record accruals and payments triggered by regulatory filings — filing fees, penalty accruals, remediation cost recognition. Real estate controllers need to link GL entri' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFiling .

ind:rentScheduleId rdf:type rdf:Property ;
    rdfs:label 'Rent Schedule Id' ;
    rdfs:comment 'Foreign key linking to lease.rent_schedule. Business justification: Journal entries for straight-line rent, lease liability amortization, and deferred rent are generated from rent schedules. Direct FK from journal_entry to rent_schedule provides the audit trail requir' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RentSchedule .

ind:reversedEntryJournalEntryId rdf:type rdf:Property ;
    rdfs:label 'Reversed Entry Journal Entry Id' ;
    rdfs:comment 'Reference to the original journal entry that this entry reverses. Populated only when is_reversal is True. Enables bidirectional audit trail linking reversal entries to their originating postings for SOX compliance.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The date of the original source document or business transaction that triggered the journal entry (e.g., invoice date, lease commencement date). May differ from posting date. Maps to SAP BKPF-BLDAT.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entryNumber rdf:type rdf:Property ;
    rdfs:label 'Entry Number' ;
    rdfs:comment 'Externally-known, human-readable document number assigned by the source system (e.g., Yardi Voyager journal number or SAP document number). Used for cross-system reconciliation and audit trail. Maps to SAP BKPF-BELNR or Yardi JE reference number.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'The foreign currency exchange rate applied to translate the transaction currency amount to the functional currency amount at the time of posting. Stored with six decimal precision to support accurate multi-currency financial consolidation.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'The accounting period (month) within the fiscal year to which this journal entry belongs, expressed as a two-digit period number (01–12 for regular periods; 13–16 for special closing periods). Used for period-end close, NOI statements, and financial reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Functional Credit Amount' ;
    rdfs:comment 'The sum of all credit line item amounts translated to the functional currency using the exchange_rate. Used for financial statement preparation, NOI reporting, and EBITDA roll-ups in the entity\'s reporting currency.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter code for the functional currency of the legal entity (company code) in which financial statements are prepared. Used for foreign currency translation and consolidation under FASB ASC 830 and IFRS 21.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalDebitAmount rdf:type rdf:Property ;
    rdfs:label 'Functional Debit Amount' ;
    rdfs:comment 'The sum of all debit line item amounts translated to the functional currency using the exchange_rate. Used for financial statement preparation, NOI reporting, and EBITDA roll-ups in the entity\'s reporting currency.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headerText rdf:type rdf:Property ;
    rdfs:label 'Header Text' ;
    rdfs:comment 'Free-text description at the journal entry header level explaining the business purpose or context of the posting (e.g., \'Q3 CAM Reconciliation Accrual\', \'Lease Commencement ROU Asset Recognition\'). Supports audit trail and business user understanding.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Intercompany Partner Code' ;
    rdfs:comment 'The company code of the intercompany trading partner entity. Populated when is_intercompany is True. Used for intercompany reconciliation and elimination entries during financial consolidation. Maps to SAP BKPF-VBUND.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBalanced rdf:type rdf:Property ;
    rdfs:label 'Is Balanced' ;
    rdfs:comment 'Indicates whether the journal entry is balanced (total debits equal total credits). A value of True confirms the entry satisfies double-entry bookkeeping requirements. Unbalanced entries (False) are flagged for correction before posting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isIntercompany rdf:type rdf:Property ;
    rdfs:label 'Is Intercompany' ;
    rdfs:comment 'Indicates whether this journal entry involves a transaction between two legal entities within the same corporate group (intercompany posting). True entries require elimination during financial consolidation for REIT and group-level reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReversal rdf:type rdf:Property ;
    rdfs:label 'Is Reversal' ;
    rdfs:comment 'Indicates whether this journal entry is a reversal of a previously posted entry. True means this entry was created to negate a prior posting (e.g., accrual reversal at period start). Used for period-end close management and audit trail.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The date on which the journal entry is posted to the General Ledger (GL). Determines the accounting period in which the transaction is recognized. Distinct from the document date and value date. Maps to SAP BKPF-BUDAT.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'Two-digit code controlling the debit/credit indicator, account type, and field selection for the journal entry posting. Maps to SAP posting key (BSEG-BSCHL). Common values include 40 (GL debit), 50 (GL credit), 01 (customer invoice), 31 (vendor invoice).' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'External reference number linking this journal entry to a related business document such as a lease agreement, invoice, purchase order, or contract. Supports cross-document traceability and audit trail. Maps to SAP BKPF-XBLNR.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Total Credit Amount' ;
    rdfs:comment 'The sum of all credit line item amounts in the transaction currency for this journal entry. Must equal total_debit_amount for the entry to be balanced per double-entry bookkeeping principles. Used for entry-level validation and reconciliation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDebitAmount rdf:type rdf:Property ;
    rdfs:label 'Total Debit Amount' ;
    rdfs:comment 'The sum of all debit line item amounts in the transaction currency for this journal entry. Must equal total_credit_amount for the entry to be balanced per double-entry bookkeeping principles. Used for entry-level validation and reconciliation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'The user ID or name of the individual who created or prepared this journal entry. Supports segregation of duties (preparer vs. approver vs. poster) required under SOX Section 404 internal controls.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual debit or credit line item within a journal entry. Primary key for this table in the Databricks Silver Layer.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalLineJournalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Original Line Journal Entry Line Id' ;
    rdfs:comment 'Reference to the original journal entry line that this line reverses or corrects. Populated only when reversal_flag is true. Enables audit trail linkage between original and reversal postings.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntryLine .

ind:assignmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Number' ;
    rdfs:comment 'Alphanumeric assignment field used for open item management, payment clearing, and AR/AP matching. In Yardi Voyager and SAP S/4HANA, this field links line items to specific invoices, payments, or clearing documents.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:camFlag rdf:type rdf:Property ;
    rdfs:label 'Cam Flag' ;
    rdfs:comment 'Indicates whether this line item is a Common Area Maintenance (CAM) expense eligible for tenant pass-through billing and CAM reconciliation under NNN or modified gross lease structures.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:debitCreditIndicator rdf:type rdf:Property ;
    rdfs:label 'Debit Credit Indicator' ;
    rdfs:comment 'Indicates whether this line item is a debit (D) or credit (C) posting per double-entry bookkeeping. Fundamental to GL balance verification and trial balance preparation.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Amount' ;
    rdfs:comment 'The posting amount translated into the entity\'s functional currency (typically USD for US-based REITs). Required for financial consolidation, EBITDA roll-ups, and SEC/FASB reporting when transaction currency differs from functional currency.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalOrderCode rdf:type rdf:Property ;
    rdfs:label 'Internal Order Code' ;
    rdfs:comment 'SAP internal order code used for collecting costs related to specific maintenance activities, tenant improvement projects, or short-term CAPEX initiatives. Complements WBS elements for granular cost object tracking.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineDescription rdf:type rdf:Property ;
    rdfs:label 'Line Description' ;
    rdfs:comment 'Free-text description of the individual journal entry line item explaining the nature of the posting (e.g., \'Q3 CAM reconciliation adjustment\', \'TI amortization — Suite 400\', \'CAPEX — HVAC replacement\'). Supports audit trail and financial review.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line item number within the parent journal entry. Establishes ordering of debit and credit postings and is used for audit trail reconstruction and reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineType rdf:type rdf:Property ;
    rdfs:label 'Line Type' ;
    rdfs:comment 'Classification of the journal entry line by its accounting nature. Distinguishes standard postings from accruals, reversals, period-end adjustments, intercompany eliminations, and consolidation entries. Critical for SOX-compliant financial controls and audit.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noiInclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Noi Inclusion Flag' ;
    rdfs:comment 'Indicates whether this line item is included in the property-level Net Operating Income (NOI) calculation. Excludes debt service, depreciation, and capital items from NOI per industry standard definitions.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:opexCapexIndicator rdf:type rdf:Property ;
    rdfs:label 'Opex Capex Indicator' ;
    rdfs:comment 'Classifies the line item as an operating expenditure (OPEX) or capital expenditure (CAPEX). Fundamental for property-level NOI statements, CAPEX budgeting, fixed asset capitalization, and REIT FFO/AFFO adjustments.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postedBy rdf:type rdf:Property ;
    rdfs:label 'Posted By' ;
    rdfs:comment 'The user ID or name of the individual who posted this journal entry line to the General Ledger. Supports SOX segregation of duties controls, audit trail, and financial close governance.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingAmount rdf:type rdf:Property ;
    rdfs:label 'Posting Amount' ;
    rdfs:comment 'The monetary amount of this line item in the transaction currency. Always a positive value; the debit_credit_indicator determines the direction of the posting. Used in NOI calculations, CAM reconciliations, and OPEX/CAPEX allocations.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Current lifecycle status of the journal entry line within the GL workflow. Indicates whether the line has been fully posted, reversed, parked for review, held pending approval, or cleared against an open item.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this line item is a reversal of a previously posted entry (e.g., accrual reversal at period start). Used to identify and exclude reversal pairs from period-end balance calculations.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Business segment identifier (e.g., commercial, residential, industrial, retail) used for segment-level financial reporting per FASB ASC 280 and SEC REIT disclosure requirements. Enables EBITDA and NOI roll-ups by portfolio segment.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'The effective date for cash flow and bank value purposes, particularly relevant for treasury postings, rent receipts, and loan disbursements. Used in DSCR calculations and cash management reporting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wbsElementCode rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Code' ;
    rdfs:comment 'Work Breakdown Structure (WBS) element code from SAP S/4HANA Project Systems or Procore, used to allocate CAPEX line items to specific development or renovation projects. Enables project-level cost tracking and CAPEX budget control.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountId rdf:type rdf:Property ;
    rdfs:label 'Bank Account Id' ;
    rdfs:comment 'Foreign key linking to finance.bank_account. Business justification: ap_invoice currently stores bank_account_number as a denormalized STRING. Adding a proper FK bank_account_id → finance.bank_account.bank_account_id normalizes the payment destination, enabling joins t' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:campaignFlightId rdf:type rdf:Property ;
    rdfs:label 'Campaign Flight Id' ;
    rdfs:comment 'Foreign key linking to marketing.campaign_flight. Business justification: Media vendor invoices in real estate are billed at the campaign flight level (specific placement periods). AP must reference the campaign flight to validate invoice amounts against flight budgets and ' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CampaignFlight .

ind:propertyInspectionId rdf:type rdf:Property ;
    rdfs:label 'Property Inspection Id' ;
    rdfs:comment 'Foreign key linking to property.inspection. Business justification: AP invoices for inspection-triggered remediation work reference the specific inspection that identified the deficiency. This supports work order to invoice matching, regulatory compliance documentatio' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Inspection .

ind:apInvoiceDescription rdf:type rdf:Property ;
    rdfs:label 'Ap Invoice Description' ;
    rdfs:comment 'Free-text description of the goods or services invoiced as provided by the vendor or entered by AP staff. Used for audit review, expense coding, and work order matching.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearedDate rdf:type rdf:Property ;
    rdfs:label 'Cleared Date' ;
    rdfs:comment 'The date on which the payment cleared the bank (check cashed, ACH settled, wire confirmed). Used for bank reconciliation and cash management reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'The discount amount available if payment is made within the early payment discount window as specified in the payment terms (e.g., 2/10 Net 30). Supports cash discount optimization.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'The date by which payment must be made to the vendor to comply with agreed payment terms and avoid late payment penalties. Derived from invoice date plus payment terms.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expenseCategory rdf:type rdf:Property ;
    rdfs:label 'Expense Category' ;
    rdfs:comment 'The business expense classification for this invoice (e.g., OPEX - Repairs and Maintenance, CAPEX - Building Improvement, CAM, Utilities, Insurance, Property Tax, Management Fees). Used for NOI statement line items and budget variance analysis. [ENUM-REF-CANDIDATE: opex_repairs|opex_utilities|opex_insurance|opex_property_tax|opex_management_fees|capex_improvement|cam|professional_services — promote to reference product]' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'The total invoice amount before any tax deductions or discounts, as stated on the vendor invoice. Represents the full obligation prior to adjustments.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'The externally-assigned invoice number as provided by the vendor on the invoice document. Used for vendor reconciliation, dispute resolution, and audit trail. Must be unique per vendor.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current workflow lifecycle state of the invoice within the procure-to-pay cycle. Drives approval routing, payment scheduling, and financial reporting. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|posted|paid|void|on_hold — promote to reference product]' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRecurring rdf:type rdf:Property ;
    rdfs:label 'Is Recurring' ;
    rdfs:comment 'Indicates whether this invoice is part of a recurring payment schedule (e.g., monthly service contracts, insurance premiums, property management fees). Supports automated recurring invoice processing.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVoid rdf:type rdf:Property ;
    rdfs:label 'Is Void' ;
    rdfs:comment 'Indicates whether this invoice has been voided. Voided invoices are retained for audit trail purposes but excluded from financial reporting and payment processing.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'The net payable amount after deducting applicable discounts and adjustments from the gross amount. Represents the actual cash obligation to the vendor.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The date on which payment was issued to the vendor. Used for cash flow reporting, vendor aging analysis, and DSCR calculations at the property level.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Number' ;
    rdfs:comment 'The check number, ACH transaction reference, or wire transfer confirmation number associated with the disbursement for this invoice. Populated upon payment execution.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'The agreed payment terms between the company and the vendor as stated on the invoice or vendor master (e.g., Net 30, Net 60, 2/10 Net 30, Due on Receipt). Drives due date calculation and cash flow forecasting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'The human-readable purchase order number referenced on the vendor invoice. Enables three-way match validation and procurement compliance. Nullable for non-PO invoices.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicePeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Service Period End' ;
    rdfs:comment 'The end date of the service period covered by this invoice. Used alongside service_period_start for accrual-basis expense recognition and period-over-period reporting.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:servicePeriodStart rdf:type rdf:Property ;
    rdfs:label 'Service Period Start' ;
    rdfs:comment 'The start date of the service period covered by this invoice. Critical for accrual accounting, period matching, and CAM reconciliation under GAAP.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemInvoiceCode rdf:type rdf:Property ;
    rdfs:label 'Source System Invoice Code' ;
    rdfs:comment 'The native primary key or unique identifier of this invoice record in the originating source system (Yardi Voyager or SAP S/4HANA). Enables traceability from the Silver layer back to the system of record.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorInvoiceRef rdf:type rdf:Property ;
    rdfs:label 'Vendor Invoice Ref' ;
    rdfs:comment 'Additional vendor-side reference number or remittance advice code provided on the invoice, distinct from the primary invoice number. Used for vendor reconciliation and dispute management.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidDate rdf:type rdf:Property ;
    rdfs:label 'Void Date' ;
    rdfs:comment 'The date on which the invoice was voided. Populated only when is_void is True. Required for audit trail and period-end reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:voidReason rdf:type rdf:Property ;
    rdfs:label 'Void Reason' ;
    rdfs:comment 'The reason code explaining why the invoice was voided. Required for SOX audit trail and AP quality control reporting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apPaymentId rdf:type rdf:Property ;
    rdfs:label 'Ap Payment Id' ;
    rdfs:comment 'Unique surrogate identifier for each AP payment disbursement record in the Silver Layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApPayment .

ind:paymentRunId rdf:type rdf:Property ;
    rdfs:label 'Payment Run Id' ;
    rdfs:comment 'Reference to the batch payment run or check run that generated this payment. Groups individual payments processed together in a single disbursement cycle. Used for batch reconciliation, audit trails, and payment run reporting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentRun .

ind:achTraceNumber rdf:type rdf:Property ;
    rdfs:label 'Ach Trace Number' ;
    rdfs:comment 'NACHA-assigned trace number for ACH electronic payments. Uniquely identifies the ACH transaction within the Federal Reserve or EPN clearing network. Used for ACH return resolution and bank reconciliation. Null for non-ACH payments.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankRoutingNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Routing Number' ;
    rdfs:comment 'ABA routing transit number of the vendor\'s receiving bank account. Required for ACH and wire payment processing. Stored for remittance and payment audit purposes. Classified confidential as it is a banking identifier.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkNumber rdf:type rdf:Property ;
    rdfs:label 'Check Number' ;
    rdfs:comment 'Physical or laser-printed check number for check-based payments. Null for ACH, wire, or virtual card payments. Used for positive pay file submission to the bank and check register reconciliation.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountTakenAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Taken Amount' ;
    rdfs:comment 'Early-payment discount amount deducted from the invoice balance at time of payment (e.g., 2/10 net 30 terms). Reduces the net cash disbursed and is tracked separately for GL posting to discount income accounts.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'The accounting date on which this payment is posted to the General Ledger. May differ from payment_date due to period-close cutoffs or accrual adjustments. Determines the accounting period for financial reporting and SOX-compliant period-end close.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isPartialPayment rdf:type rdf:Property ;
    rdfs:label 'Is Partial Payment' ;
    rdfs:comment 'Indicates whether this payment represents a partial settlement of the associated invoice(s) rather than full payment. True = partial payment; False = full payment. Used for open invoice aging and vendor statement reconciliation.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVoided rdf:type rdf:Property ;
    rdfs:label 'Is Voided' ;
    rdfs:comment 'Indicates whether this payment has been voided (cancelled after issuance but before or after clearing). True = payment is voided and should be excluded from cash disbursement totals. Used for audit trails and reissuance tracking.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payment Amount' ;
    rdfs:comment 'Actual net cash disbursed to the vendor after deducting any early-payment discounts or adjustments from the gross payment amount. Equals payment_amount minus discount_taken_amount. Used for bank reconciliation and cash management reporting.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'Gross amount disbursed to the vendor in the transaction currency. Represents the total funds transferred, before any discount adjustments. Core monetary field for AP cash disbursement reporting and DSCR calculations.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMemo rdf:type rdf:Property ;
    rdfs:label 'Payment Memo' ;
    rdfs:comment 'Free-text memo or description associated with the payment, as entered by the AP processor. Appears on check stubs, ACH addenda records, or wire instructions. Used for vendor communication and internal reference.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current lifecycle state of the AP payment. \'pending\' = approved but not yet disbursed; \'issued\' = check printed or ACH/wire initiated; \'cleared\' = confirmed settled by bank; \'voided\' = cancelled before clearing; \'stopped\' = stop-payment placed; \'returned\' = ACH/wire returned by receiving bank.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentType rdf:type rdf:Property ;
    rdfs:label 'Payment Type' ;
    rdfs:comment 'Business classification of the payment purpose. \'vendor_payment\' = standard operating expense vendor; \'ti_allowance\' = Tenant Improvement (TI) allowance disbursement to tenant or contractor; \'construction_draw\' = CAPEX draw for development/renovation; \'security_deposit_refund\' = return of tenant security deposit; \'owner_distribution\' = distribution to property owner; \'corporate_payable\' = non-property corporate expense. [ENUM-REF-CANDIDATE: vendor_payment|ti_allowance|construction_draw|security_deposit_refund|owner_distribution|corporate_payable — promote to reference product]' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positivePaySubmitted rdf:type rdf:Property ;
    rdfs:label 'Positive Pay Submitted' ;
    rdfs:comment 'Indicates whether this check payment has been submitted to the bank\'s positive pay fraud prevention service. True = submitted; False = not submitted. Applicable only to check payments. Used for fraud control compliance and bank reconciliation.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remittanceAdviceNumber rdf:type rdf:Property ;
    rdfs:label 'Remittance Advice Number' ;
    rdfs:comment 'Reference number of the remittance advice document sent to the vendor detailing which invoices are being paid and any discounts applied. Used for vendor reconciliation and dispute resolution.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemPaymentCode rdf:type rdf:Property ;
    rdfs:label 'Source System Payment Code' ;
    rdfs:comment 'Native payment identifier from the originating source system (e.g., Yardi Voyager internal payment key or SAP FI document number). Preserved for cross-system reconciliation, data lineage, and drill-back to the operational system of record.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wireReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Wire Reference Number' ;
    rdfs:comment 'Bank-assigned reference number for wire transfer payments (SWIFT/Fedwire). Used to trace and confirm wire settlement with the receiving bank. Null for non-wire payments.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agingBucket rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket' ;
    rdfs:comment 'Receivable aging classification based on days elapsed since the invoice due date. Used in tenant receivable aging reports, credit risk assessment, and property-level delinquency dashboards.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliedAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Amount' ;
    rdfs:comment 'Total cash receipts applied against this invoice to date. The difference between net_amount and applied_amount yields the outstanding balance. Critical for aging and delinquency reporting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankDepositReference rdf:type rdf:Property ;
    rdfs:label 'Bank Deposit Reference' ;
    rdfs:comment 'Bank deposit slip or batch reference number linking this receipt to the physical or electronic bank deposit. Supports bank reconciliation and treasury cash management.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Billing Period End' ;
    rdfs:comment 'Last day of the billing period covered by this invoice. Together with billing_period_start defines the service period for revenue recognition and CAM reconciliation.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start' ;
    rdfs:comment 'First day of the billing period covered by this invoice. Used for proration calculations, CAM reconciliation periods, and EGI/PGI period alignment.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:breakpointAmount rdf:type rdf:Property ;
    rdfs:label 'Breakpoint Amount' ;
    rdfs:comment 'Natural or artificial breakpoint threshold above which percentage rent is owed per the lease agreement. Used to calculate overage rent on percentage_rent charge type invoices.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:camReconciliationYear rdf:type rdf:Property ;
    rdfs:label 'Cam Reconciliation Year' ;
    rdfs:comment 'Calendar or fiscal year for which CAM charges on this invoice are being reconciled. Applicable only to CAM charge type invoices. Supports annual CAM true-up calculations per lease terms.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditMemoReference rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Reference' ;
    rdfs:comment 'Reference number of any credit memo issued against this invoice for adjustments, concessions, or billing corrections. Null if no credit memo applies.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysPastDue rdf:type rdf:Property ;
    rdfs:label 'Days Past Due' ;
    rdfs:comment 'Number of calendar days elapsed since the invoice due date as of the last refresh. Zero or negative indicates current. Drives aging bucket assignment and late fee eligibility.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lateFeeRate rdf:type rdf:Property ;
    rdfs:label 'Late Fee Rate' ;
    rdfs:comment 'Contractual late fee rate (as a decimal percentage) applied to overdue balances per the lease agreement. Used to calculate late fee invoice amounts when days_past_due exceeds the grace period.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nsfFlag rdf:type rdf:Property ;
    rdfs:label 'Nsf Flag' ;
    rdfs:comment 'Indicates whether the payment associated with this invoice was returned due to non-sufficient funds (NSF). True triggers reversal of the applied receipt and potential late fee assessment per lease terms.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:percentageRentSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Percentage Rent Sales Amount' ;
    rdfs:comment 'Tenant-reported gross sales amount used as the basis for percentage rent calculation. Applicable only to percentage_rent charge type invoices. Sourced from tenant sales reports per lease breakpoint provisions.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postDate rdf:type rdf:Property ;
    rdfs:label 'Post Date' ;
    rdfs:comment 'Date on which the invoice was posted to the General Ledger accounting period. May differ from invoice_date for accrual adjustments. Controls which fiscal period the revenue is recognized in.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postedFlag rdf:type rdf:Property ;
    rdfs:label 'Posted Flag' ;
    rdfs:comment 'Indicates whether this invoice has been posted to the General Ledger. Unposted invoices are excluded from financial reporting. SOX control point for period-end close.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'Date on which cash payment was received and recorded in Yardi Voyager AR. Used for cash flow reporting, bank deposit reconciliation, and DSO (Days Sales Outstanding) calculations.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receiptNumber rdf:type rdf:Property ;
    rdfs:label 'Receipt Number' ;
    rdfs:comment 'Reference number of the cash receipt applied to this invoice, as assigned by Yardi Voyager AR. Enables order-to-cash traceability and bank reconciliation. Null if no payment has been received.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unappliedAmount rdf:type rdf:Property ;
    rdfs:label 'Unapplied Amount' ;
    rdfs:comment 'Portion of received cash not yet applied to a specific invoice line. Represents tenant prepayments or unallocated receipts held in suspense pending application.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffAmount rdf:type rdf:Property ;
    rdfs:label 'Write Off Amount' ;
    rdfs:comment 'Amount of the invoice balance written off as uncollectible per the bad debt policy. Impacts NOI and requires GL journal entry. Subject to SOX controls and credit committee approval.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffDate rdf:type rdf:Property ;
    rdfs:label 'Write Off Date' ;
    rdfs:comment 'Date on which the bad debt write-off was approved and posted. Required for SOX-compliant audit trail and GL period close.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:arReceiptId rdf:type rdf:Property ;
    rdfs:label 'Ar Receipt Id' ;
    rdfs:comment 'Unique system-generated identifier for each AR cash receipt record in the finance domain. Primary key for the ar_receipt data product.' ;
    rdfs:domain ind:ArReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalReceiptArReceiptId rdf:type rdf:Property ;
    rdfs:label 'Original Receipt Ar Receipt Id' ;
    rdfs:comment 'Reference to the original ar_receipt_id that this record reverses or corrects. Populated only when reversal_flag = True. Enables audit trail linkage between original and reversal entries for SOX compliance.' ;
    rdfs:domain ind:ArReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArReceipt .

ind:bankDepositDate rdf:type rdf:Property ;
    rdfs:label 'Bank Deposit Date' ;
    rdfs:comment 'The date on which the payment was physically or electronically deposited into the bank account. Used for bank reconciliation and cash management reporting.' ;
    rdfs:domain ind:ArReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incomeCategory rdf:type rdf:Property ;
    rdfs:label 'Income Category' ;
    rdfs:comment 'The income classification of the receipt for EGI (Effective Gross Income) and NOI (Net Operating Income) reporting. Aligns with Argus Enterprise income line categories and property-level P&L structure. [ENUM-REF-CANDIDATE: base_rent|percentage_rent|cam|tax_recovery|insurance_recovery|parking|storage|other — promote to reference product]' ;
    rdfs:domain ind:ArReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isNsf rdf:type rdf:Property ;
    rdfs:label 'Is Nsf' ;
    rdfs:comment 'Indicates whether the payment was returned by the bank due to non-sufficient funds (NSF) or a dishonoured check/ACH. When True, triggers NSF fee assessment, AR reversal, and tenant credit risk review.' ;
    rdfs:domain ind:ArReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrepayment rdf:type rdf:Property ;
    rdfs:label 'Is Prepayment' ;
    rdfs:comment 'Indicates whether this receipt represents a prepayment for a future billing period. When True, the amount is held as a deferred liability until the applicable period, per FASB ASC 842 revenue recognition rules.' ;
    rdfs:domain ind:ArReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSecurityDeposit rdf:type rdf:Property ;
    rdfs:label 'Is Security Deposit' ;
    rdfs:comment 'Indicates whether this receipt is a security deposit payment. Security deposits are held in trust and are not recognized as income until forfeited or applied. Drives separate GL coding and regulatory compliance with state/local landlord-tenant laws.' ;
    rdfs:domain ind:ArReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nsfDate rdf:type rdf:Property ;
    rdfs:label 'Nsf Date' ;
    rdfs:comment 'The date on which the bank notified the company of the NSF return. Populated only when is_nsf = True. Used to calculate NSF fee due dates and initiate AR reversal processing.' ;
    rdfs:domain ind:ArReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentReference rdf:type rdf:Property ;
    rdfs:label 'Payment Reference' ;
    rdfs:comment 'The payer-provided reference number accompanying the payment (e.g., check number, ACH trace number, wire reference, remittance advice number). Used for remittance matching and dispute resolution.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'The end date of the billing period to which this receipt relates. Together with period_start_date, defines the revenue recognition window for the payment under FASB ASC 842 and IFRS 16.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'The start date of the billing period to which this receipt relates. Used to match receipts to the correct accounting period for EGI realization and accrual-basis reporting under FASB ASC 842.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receiptNotes rdf:type rdf:Property ;
    rdfs:label 'Receipt Notes' ;
    rdfs:comment 'Free-text notes entered by the AR processor regarding the receipt, such as tenant instructions, dispute context, partial payment explanations, or special handling instructions.' ;
    rdfs:domain ind:ArReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptStatus rdf:type rdf:Property ;
    rdfs:label 'Receipt Status' ;
    rdfs:comment 'Current lifecycle state of the cash receipt. \'posted\' indicates fully applied to AR; \'unposted\' is pending review; \'reversed\' indicates a reversal entry was created; \'nsf\' indicates a returned/bounced payment; \'on_account\' indicates unapplied credit; \'voided\' indicates the receipt was cancelled. [ENUM-REF-CANDIDATE: posted|unposted|reversed|nsf|on_account|voided — promote to reference product]' ;
    rdfs:domain ind:ArReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptType rdf:type rdf:Property ;
    rdfs:label 'Receipt Type' ;
    rdfs:comment 'Classification of the nature of the payment received. Distinguishes rent payments, security deposit receipts, CAM (Common Area Maintenance) reconciliation payments, late fees, prepayments, and miscellaneous income. Drives EGI component analysis and GL coding. [ENUM-REF-CANDIDATE: rent|security_deposit|cam_reconciliation|late_fee|miscellaneous|prepayment — promote to reference product]' ;
    rdfs:domain ind:ArReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedAmount rdf:type rdf:Property ;
    rdfs:label 'Received Amount' ;
    rdfs:comment 'The gross amount of cash received from the tenant or payer in the transaction currency. This is the total funds received before any application or allocation. Core component of EGI realization and cash flow reporting.' ;
    rdfs:domain ind:ArReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemReceiptCode rdf:type rdf:Property ;
    rdfs:label 'Source System Receipt Code' ;
    rdfs:comment 'The native receipt identifier from the originating system of record (e.g., Yardi Voyager receipt key or SAP document number). Enables traceability from the Silver Layer back to the source system for reconciliation and audit.' ;
    rdfs:domain ind:ArReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountCategory rdf:type rdf:Property ;
    rdfs:label 'Account Category' ;
    rdfs:comment 'High-level classification of the GL account for this budget line: revenue (PGI, EGI, GRI), opex (Operating Expenditure), capex (Capital Expenditure), debt_service (mortgage/loan payments), or reserve (replacement/capital reserve). Drives NOI, EBITDA, and DSCR roll-up logic.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'The calendar date on which the budget received its final approval. Used in SOX audit trails, investor reporting timelines, and budget lock-down processes.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetCode rdf:type rdf:Property ;
    rdfs:label 'Budget Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the budget within Yardi Voyager or SAP S/4HANA. Used for cross-system reconciliation and investor reporting references.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetName rdf:type rdf:Property ;
    rdfs:label 'Budget Name' ;
    rdfs:comment 'Human-readable descriptive name of the budget (e.g., \'2025 Annual Operating Budget – Portfolio A\', \'2025 Capital Budget – 123 Main St\'). Used in reports and approval workflows.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'Classification of the budget by purpose: operating (OPEX-focused NOI budget), capital (CAPEX project budget), reforecast (revised in-year estimate), cash_flow (treasury cash planning), or leasing (TI and leasing cost budget). [ENUM-REF-CANDIDATE: operating|capital|reforecast|cash_flow|leasing|master — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetedAmount rdf:type rdf:Property ;
    rdfs:label 'Budgeted Amount' ;
    rdfs:comment 'The planned monetary amount for this budget line in the reporting currency. Represents the baseline for NOI variance analysis, OPEX/CAPEX planning, and investor reporting. Expressed in the currency defined by currency_code.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financeBudgetStatus rdf:type rdf:Property ;
    rdfs:label 'Finance Budget Status' ;
    rdfs:comment 'Current lifecycle state of the budget record: draft (being prepared), in_review (submitted for approval), approved (authorized for use), locked (frozen for reporting), archived (superseded), or rejected (returned for revision). Drives SOX-compliant approval workflow controls.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConsolidated rdf:type rdf:Property ;
    rdfs:label 'Is Consolidated' ;
    rdfs:comment 'Indicates whether this budget record represents a consolidated roll-up across multiple properties or cost centers (True) versus a single property/cost center budget (False). Supports portfolio-level EBITDA and NOI consolidation in SAP S/4HANA.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLocked rdf:type rdf:Property ;
    rdfs:label 'Is Locked' ;
    rdfs:comment 'Indicates whether this budget version has been locked and is no longer editable (True = locked; False = editable). Locked budgets serve as the immutable baseline for variance reporting and SOX audit evidence.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'Granularity of the budget period: monthly (12 periods), quarterly (4 periods), or annual (1 period). Determines how budget amounts are distributed and compared against actuals in NOI and EBITDA reporting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparedBy rdf:type rdf:Property ;
    rdfs:label 'Prepared By' ;
    rdfs:comment 'Name or employee identifier of the individual who prepared and submitted this budget. Part of the SOX-compliant approval chain and audit trail. Sourced from Yardi Voyager or SAP S/4HANA workflow.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorYearActualAmount rdf:type rdf:Property ;
    rdfs:label 'Prior Year Actual Amount' ;
    rdfs:comment 'The actual amount recorded in the equivalent GL account and period in the prior fiscal year. Used as the baseline for year-over-year variance analysis and budget justification in investor and board reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submittedDate rdf:type rdf:Property ;
    rdfs:label 'Submitted Date' ;
    rdfs:comment 'The calendar date on which the budget was formally submitted for review and approval. Supports approval cycle time tracking and SOX control evidence.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'The absolute monetary difference between the budgeted amount and the prior year actual amount (budgeted_amount minus prior_year_actual_amount). Stored as a raw field to support NOI variance reporting without requiring runtime calculation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'The percentage change between the budgeted amount and the prior year actual amount, expressed as a decimal (e.g., 0.0500 = 5.00%). Stored as a sourced field from Yardi Voyager to support investor reporting and NOI variance dashboards.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:versionLabel rdf:type rdf:Property ;
    rdfs:label 'Version Label' ;
    rdfs:comment 'Descriptive label for the budget version stage (e.g., draft, preliminary, submitted, approved, reforecast_q1, final). Complements version_number with a human-readable stage indicator. [ENUM-REF-CANDIDATE: draft|preliminary|submitted|approved|reforecast_q1|reforecast_q2|reforecast_q3|final — promote to reference product]' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetLineId rdf:type rdf:Property ;
    rdfs:label 'Budget Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each budget line item record within the enterprise data lakehouse. Primary key for the budget_line product.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BudgetLine .

ind:primaryBudgetAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Budget Asset Id' ;
    rdfs:comment 'Reference to the property against which this budget line is allocated. Enables property-level NOI, EGI, and OPEX variance analysis.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:primaryBudgetChartOfAccountsId rdf:type rdf:Property ;
    rdfs:label 'Primary Budget Chart Of Accounts Id' ;
    rdfs:comment 'Reference to the GL account in the chart of accounts to which this budget line is posted. Drives financial consolidation and P&L reporting.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChartOfAccounts .

ind:actualAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Amount' ;
    rdfs:comment 'The actual posted GL amount for this account, cost center, and period as sourced from Yardi Voyager AR/AP/GL or SAP S/4HANA. Populated after period close; null for future periods.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCategory rdf:type rdf:Property ;
    rdfs:label 'Budget Category' ;
    rdfs:comment 'High-level financial category classifying the budget line. Revenue lines contribute to PGI/EGI/GOI; OPEX lines feed NOI calculations; CAPEX lines track capital expenditure; debt_service covers DSCR inputs; reserve lines track replacement reserves. [ENUM-REF-CANDIDATE: revenue|opex|capex|noi|debt_service|reserve — promote to reference product if additional categories are needed]' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetScenario rdf:type rdf:Property ;
    rdfs:label 'Budget Scenario' ;
    rdfs:comment 'The planning scenario under which this budget line was prepared. Base = most likely; optimistic = upside case; conservative = downside case; stress = adverse scenario for DSCR and LTV stress testing. Supports Argus Enterprise scenario analysis.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetVersion rdf:type rdf:Property ;
    rdfs:label 'Budget Version' ;
    rdfs:comment 'Version identifier for the budget iteration this line belongs to (e.g., \'ORIGINAL\', \'REV1\', \'REFORECAST_Q2\'). Supports multi-version budget comparison and rolling forecast workflows in Yardi Voyager and Argus Enterprise.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCamRecoverable rdf:type rdf:Property ;
    rdfs:label 'Is Cam Recoverable' ;
    rdfs:comment 'Indicates whether this expense budget line is recoverable from tenants as part of Common Area Maintenance (CAM) charges under NNN or modified gross lease structures. True = recoverable; False = landlord-absorbed.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCapex rdf:type rdf:Property ;
    rdfs:label 'Is Capex' ;
    rdfs:comment 'Indicates whether this budget line represents a capital expenditure (CAPEX) rather than an operating expenditure (OPEX). True = CAPEX (capitalized asset investment); False = OPEX (period expense). Drives fixed asset capitalization and depreciation scheduling.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineCode rdf:type rdf:Property ;
    rdfs:label 'Line Code' ;
    rdfs:comment 'Alphanumeric code uniquely identifying this budget line within the source system (Yardi Voyager or SAP S/4HANA). Used for cross-system reconciliation and audit trail.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current workflow status of the budget line. Draft = under preparation; submitted = pending approval; approved = authorized for use; rejected = returned for revision; locked = period-closed and immutable; superseded = replaced by a revised line. [ENUM-REF-CANDIDATE: draft|submitted|approved|rejected|locked|superseded — promote to reference product]' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noiComponent rdf:type rdf:Property ;
    rdfs:label 'Noi Component' ;
    rdfs:comment 'Indicates which NOI/EGI/PGI/GOI/EBITDA roll-up component this budget line contributes to. PGI = Potential Gross Income; EGI = Effective Gross Income; GOI = Gross Operating Income; NOI = Net Operating Income; EBITDA = Earnings Before Interest Taxes Depreciation and Amortization; excluded = not included in any standard roll-up.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemLineCode rdf:type rdf:Property ;
    rdfs:label 'Source System Line Code' ;
    rdfs:comment 'The native primary key or line identifier of this budget line in the originating source system (Yardi Voyager, SAP S/4HANA, or Argus Enterprise). Enables bi-directional traceability for reconciliation and audit.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variancePct rdf:type rdf:Property ;
    rdfs:label 'Variance Pct' ;
    rdfs:comment 'The variance expressed as a percentage of the budgeted amount ((actual - budget) / budget * 100). Enables proportional comparison across budget lines of different magnitudes for portfolio-level reporting.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:administrativeExpense rdf:type rdf:Property ;
    rdfs:label 'Administrative Expense' ;
    rdfs:comment 'Property-level administrative and general overhead costs including leasing commissions amortization, legal fees, accounting fees, and office expenses allocated to the property for the reporting period.' ;
    rdfs:domain ind:NoiStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:camRecovery rdf:type rdf:Property ;
    rdfs:label 'Cam Recovery' ;
    rdfs:comment 'Common Area Maintenance recovery income collected from tenants under NNN or modified gross leases for their pro-rata share of operating expenses. Included in EGI and offsets operating expenses.' ;
    rdfs:domain ind:NoiStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capRateApplied rdf:type rdf:Property ;
    rdfs:label 'Cap Rate Applied' ;
    rdfs:comment 'The capitalization rate used to derive implied property value from NOI (Value = NOI / CAP Rate). Expressed as a decimal (e.g., 0.0550 = 5.50%). Sourced from Argus Enterprise valuation models and CoStar market comparables.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capexReserve rdf:type rdf:Property ;
    rdfs:label 'Capex Reserve' ;
    rdfs:comment 'Capital expenditure reserve amount set aside for the reporting period for major building improvements, replacements, and non-recurring capital items. Deducted from NOI to arrive at AFFO in REIT reporting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concessions rdf:type rdf:Property ;
    rdfs:label 'Concessions' ;
    rdfs:comment 'Monetary value of rent-free periods, move-in incentives, and other lease concessions granted to tenants during the reporting period. Expressed as a positive deduction from PGI in the income waterfall.' ;
    rdfs:domain ind:NoiStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditLoss rdf:type rdf:Property ;
    rdfs:label 'Credit Loss' ;
    rdfs:comment 'Revenue lost due to tenant non-payment, bad debt write-offs, and collection shortfalls during the reporting period. Expressed as a positive deduction from PGI. Sourced from Yardi Voyager AR aging.' ;
    rdfs:domain ind:NoiStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debtService rdf:type rdf:Property ;
    rdfs:label 'Debt Service' ;
    rdfs:comment 'Total principal and interest payments on property-level debt obligations for the reporting period. Used as the denominator in DSCR calculations. Sourced from SAP S/4HANA loan schedules.' ;
    rdfs:domain ind:NoiStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dscr rdf:type rdf:Property ;
    rdfs:label 'Dscr' ;
    rdfs:comment 'Debt Service Coverage Ratio — NOI divided by total debt service for the reporting period (NOI / Debt Service). A DSCR below 1.0 indicates the property does not generate sufficient income to cover debt obligations. Critical for lender covenant compliance and CMBS reporting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:egi rdf:type rdf:Property ;
    rdfs:label 'Egi' ;
    rdfs:comment 'Effective Gross Income — PGI minus vacancy loss, credit loss, and concessions, plus other income. Represents the actual income collected or collectible from the property. Core input for NOI and CAP rate calculations.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impliedPropertyValue rdf:type rdf:Property ;
    rdfs:label 'Implied Property Value' ;
    rdfs:comment 'Estimated property value derived by dividing NOI by the applied CAP rate (NOI / CAP Rate). Used for investor reporting, portfolio NAV calculations, and REIT asset valuations. Not a formal appraisal value.' ;
    rdfs:domain ind:NoiStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceExpense rdf:type rdf:Property ;
    rdfs:label 'Insurance Expense' ;
    rdfs:comment 'Property and casualty insurance premiums allocated to the reporting period. Includes building, liability, and any specialized coverage (flood, earthquake). Component of total operating expenses.' ;
    rdfs:domain ind:NoiStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leasingCommissionExpense rdf:type rdf:Property ;
    rdfs:label 'Leasing Commission Expense' ;
    rdfs:comment 'Brokerage leasing commissions paid or accrued during the reporting period for new leases and renewals. Tracked separately for AFFO adjustments and amortized per FASB ASC 842 straight-line requirements.' ;
    rdfs:domain ind:NoiStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managementFeeExpense rdf:type rdf:Property ;
    rdfs:label 'Management Fee Expense' ;
    rdfs:comment 'Fee paid to the property manager (PM) for operational management services, typically calculated as a percentage of EGI or collected rents. Key line item for NOI sensitivity and management contract evaluation.' ;
    rdfs:domain ind:NoiStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managementFeeRate rdf:type rdf:Property ;
    rdfs:label 'Management Fee Rate' ;
    rdfs:comment 'Management fee expressed as a decimal percentage of EGI or collected rents (e.g., 0.0400 = 4.00%). Used to validate the management_fee_expense calculation and benchmark against market rates.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:noi rdf:type rdf:Property ;
    rdfs:label 'Noi' ;
    rdfs:comment 'Net Operating Income — EGI minus total operating expenses. The primary measure of a property\'s income-generating performance before debt service, capital expenditures, depreciation, and income taxes. Authoritative input for CAP rate valuation and DSCR calculations.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:noiPsf rdf:type rdf:Property ;
    rdfs:label 'Noi Psf' ;
    rdfs:comment 'NOI divided by GLA in square feet, expressed as a per-square-foot metric. Industry-standard benchmark for comparing property performance across the portfolio and against market comparables.' ;
    rdfs:domain ind:NoiStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:occupancyRate rdf:type rdf:Property ;
    rdfs:label 'Occupancy Rate' ;
    rdfs:comment 'Percentage of total leasable area that is occupied and generating rent during the reporting period, expressed as a decimal (e.g., 0.9200 = 92.00%). Complement of vacancy rate; used in investor dashboards and REIT disclosures.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodFrequency rdf:type rdf:Property ;
    rdfs:label 'Period Frequency' ;
    rdfs:comment 'Frequency granularity of this NOI statement — monthly for operational monitoring, quarterly for investor reporting, annual for REIT filings, year-to-date for cumulative tracking, or trailing 12 months for CAP rate valuation.' ;
    rdfs:domain ind:NoiStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pgi rdf:type rdf:Property ;
    rdfs:label 'Pgi' ;
    rdfs:comment 'Potential Gross Income — the maximum theoretical rental revenue achievable if the property were 100% occupied at market rents for the full reporting period. Top line of the NOI income waterfall. Sourced from Yardi Voyager lease schedules.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:propertyTaxExpense rdf:type rdf:Property ;
    rdfs:label 'Property Tax Expense' ;
    rdfs:comment 'Real estate tax and special assessment charges levied on the property for the reporting period. A primary component of operating expenses and a key driver of NOI sensitivity analysis.' ;
    rdfs:domain ind:NoiStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repairsMaintenanceExpense rdf:type rdf:Property ;
    rdfs:label 'Repairs Maintenance Expense' ;
    rdfs:comment 'Costs for routine repairs, preventive maintenance, and non-capital building upkeep during the reporting period. Sourced from Building Engines work orders and Yardi Voyager AP. Component of total operating expenses.' ;
    rdfs:domain ind:NoiStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End' ;
    rdfs:comment 'Last calendar date of the financial reporting period covered by this NOI statement (e.g., 2024-01-31 for a January monthly statement).' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start' ;
    rdfs:comment 'First calendar date of the financial reporting period covered by this NOI statement (e.g., 2024-01-01 for a January monthly statement).' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restatementReason rdf:type rdf:Property ;
    rdfs:label 'Restatement Reason' ;
    rdfs:comment 'Free-text explanation for why a previously published NOI statement was restated. Required when statement_status is \'restated\'. Supports SOX audit trail and SEC disclosure requirements for material restatements.' ;
    rdfs:domain ind:NoiStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementNumber rdf:type rdf:Property ;
    rdfs:label 'Statement Number' ;
    rdfs:comment 'Externally-known unique business identifier for this NOI statement, formatted as NOI-YYYY-MM-PropertyCode. Used in investor reports, audit trails, and regulatory submissions.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementStatus rdf:type rdf:Property ;
    rdfs:label 'Statement Status' ;
    rdfs:comment 'Current lifecycle state of the NOI statement. Draft indicates work-in-progress; under_review is pending approval; approved is finalized; published is distributed to investors; restated indicates a prior-period correction; voided is cancelled. [ENUM-REF-CANDIDATE: draft|under_review|approved|published|restated|voided — promote to reference product]' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementType rdf:type rdf:Property ;
    rdfs:label 'Statement Type' ;
    rdfs:comment 'Classification of the statement as actual reported results, approved budget, current forecast, reforecast, or prior-year actual for variance analysis. Drives how the statement is consumed in Argus Enterprise and investor reporting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tiAllowance rdf:type rdf:Property ;
    rdfs:label 'Ti Allowance' ;
    rdfs:comment 'Tenant Improvement allowance costs incurred or accrued during the reporting period for build-out and fit-out of leased spaces. Impacts AFFO calculations and is tracked separately from operating expenses per FASB ASC 842.' ;
    rdfs:domain ind:NoiStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOperatingExpenses rdf:type rdf:Property ;
    rdfs:label 'Total Operating Expenses' ;
    rdfs:comment 'Sum of all property-level operating expenditures for the reporting period, including management fees, repairs and maintenance, insurance, property taxes, utilities, and administrative costs. Deducted from EGI to arrive at NOI.' ;
    rdfs:domain ind:NoiStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilitiesExpense rdf:type rdf:Property ;
    rdfs:label 'Utilities Expense' ;
    rdfs:comment 'Landlord-paid utility costs for the reporting period including electricity, gas, water, sewer, and trash removal for common areas and vacant spaces. Component of total operating expenses.' ;
    rdfs:domain ind:NoiStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vacancyLoss rdf:type rdf:Property ;
    rdfs:label 'Vacancy Loss' ;
    rdfs:comment 'Revenue lost due to unoccupied units or spaces during the reporting period. Expressed as a positive deduction from PGI. Includes both physical vacancy and economic vacancy from lease-up periods.' ;
    rdfs:domain ind:NoiStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vacancyRate rdf:type rdf:Property ;
    rdfs:label 'Vacancy Rate' ;
    rdfs:comment 'Physical vacancy rate for the property during the reporting period, expressed as a decimal percentage of total leasable area that is unoccupied (e.g., 0.0800 = 8.00%). Key driver of PGI-to-EGI waterfall.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amenityTypeId rdf:type rdf:Property ;
    rdfs:label 'Amenity Type Id' ;
    rdfs:comment 'Foreign key linking to reference.amenity_type. Business justification: Real estate fixed assets include amenities (fitness centers, parking structures, rooftop terraces) classified by amenity type for CAM recovery allocation, capital expenditure planning, and LEED/ESG ce' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AmenityType .

ind:accumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Accumulated Depreciation' ;
    rdfs:comment 'Total depreciation expense charged against this asset from the in-service date through the current reporting period. Contra-asset balance used to compute net book value.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'Total capitalized cost of the fixed asset at the time of acquisition, including purchase price, transaction costs, and any costs necessary to bring the asset to its intended use. Represents the gross book value before depreciation.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Description' ;
    rdfs:comment 'Human-readable description of the fixed asset, such as \'HVAC Rooftop Unit — Building A\' or \'Lobby Renovation — Tenant Improvement Suite 400\'. Used for identification in financial reports and audits.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetLocation rdf:type rdf:Property ;
    rdfs:label 'Asset Location' ;
    rdfs:comment 'Physical location of the asset within the property, such as building name, floor, suite, or room number (e.g., \'Building A — Floor 3 — Mechanical Room\'). Supports physical inventory verification.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetSubClass rdf:type rdf:Property ;
    rdfs:label 'Asset Sub Class' ;
    rdfs:comment 'Secondary classification providing finer granularity within an asset class, such as \'Mechanical\' or \'Electrical\' within the HVAC class, or \'Structural\' within Building. Supports detailed CAPEX reporting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookTaxDifference rdf:type rdf:Property ;
    rdfs:label 'Book Tax Difference' ;
    rdfs:comment 'Cumulative difference between book depreciation and tax depreciation for this asset, representing the temporary timing difference used in deferred tax calculations under FASB ASC 740.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depreciationConvention rdf:type rdf:Property ;
    rdfs:label 'Depreciation Convention' ;
    rdfs:comment 'Timing convention applied to the first and last year of depreciation, determining how much depreciation is taken in the year of acquisition and disposal. Relevant for MACRS and book depreciation.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalMethod rdf:type rdf:Property ;
    rdfs:label 'Disposal Method' ;
    rdfs:comment 'Method by which the fixed asset was removed from the asset register. Determines the accounting treatment for the disposal transaction.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalProceeds rdf:type rdf:Property ;
    rdfs:label 'Disposal Proceeds' ;
    rdfs:comment 'Net cash proceeds received upon disposal or sale of the fixed asset. Used to calculate the gain or loss on disposal (disposal_proceeds minus net_book_value at disposal date).' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impairmentLoss rdf:type rdf:Property ;
    rdfs:label 'Impairment Loss' ;
    rdfs:comment 'Cumulative impairment charge recognized against this asset when its carrying amount exceeds its recoverable amount per FASB ASC 360 impairment testing. Reduces net book value below the normal depreciation schedule.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impairmentTestDate rdf:type rdf:Property ;
    rdfs:label 'Impairment Test Date' ;
    rdfs:comment 'Date on which the most recent FASB ASC 360 impairment test was performed for this asset. Required for SOX compliance documentation and audit trail.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inServiceDate rdf:type rdf:Property ;
    rdfs:label 'In Service Date' ;
    rdfs:comment 'Date the asset was placed into active service and depreciation commenced. May differ from acquisition_date for assets under construction that are capitalized upon completion.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Number' ;
    rdfs:comment 'Reference to the property or equipment insurance policy covering this fixed asset. Required for insurance claims processing and risk management reporting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuredValue rdf:type rdf:Property ;
    rdfs:label 'Insured Value' ;
    rdfs:comment 'Replacement cost or insured value of the fixed asset as declared on the insurance policy. May differ from net book value and is used for insurance adequacy reviews.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leedCertified rdf:type rdf:Property ;
    rdfs:label 'Leed Certified' ;
    rdfs:comment 'Indicates whether this asset or the improvement it represents has achieved LEED certification from the U.S. Green Building Council. Supports ESG reporting and green building compliance tracking.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netBookValue rdf:type rdf:Property ;
    rdfs:label 'Net Book Value' ;
    rdfs:comment 'Current carrying value of the fixed asset on the balance sheet, calculated as acquisition_cost minus accumulated_depreciation minus any impairment charges. Represents the asset\'s accounting value at the reporting date.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'Purchase order number associated with the acquisition of this fixed asset. Links the asset to the originating procurement transaction for three-way match and audit purposes.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salvageValue rdf:type rdf:Property ;
    rdfs:label 'Salvage Value' ;
    rdfs:comment 'Estimated residual value of the asset at the end of its useful life. Used in straight-line depreciation calculations as the floor below which book value is not depreciated.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemAssetCode rdf:type rdf:Property ;
    rdfs:label 'Source System Asset Code' ;
    rdfs:comment 'Native asset identifier from the originating source system (e.g., Yardi asset number or SAP asset master number). Used for cross-system reconciliation and audit trail back to the system of record.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxDepreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Tax Depreciation Method' ;
    rdfs:comment 'Depreciation method applied for US federal income tax purposes, which may differ from the book depreciation method. MACRS and bonus depreciation are common for real estate capital assets.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxUsefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Tax Useful Life Years' ;
    rdfs:comment 'Useful life assigned to the asset for tax depreciation purposes under IRS MACRS or ADS rules. May differ from the book useful_life_years used for GAAP reporting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiry Date' ;
    rdfs:comment 'Date on which the manufacturer or contractor warranty for this asset expires. Used to trigger preventive maintenance scheduling and warranty claim management before expiry.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ytdDepreciation rdf:type rdf:Property ;
    rdfs:label 'Ytd Depreciation' ;
    rdfs:comment 'Depreciation expense charged against this asset in the current fiscal year to date. Used for period-end financial reporting and budget-to-actual CAPEX variance analysis.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountNumberMasked rdf:type rdf:Property ;
    rdfs:label 'Account Number Masked' ;
    rdfs:comment 'Masked bank account number retaining only the last four digits for display and reconciliation purposes. Full account number must not be stored in the lakehouse per PCI-DSS controls. Format: XXXX1234.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountPurpose rdf:type rdf:Property ;
    rdfs:label 'Account Purpose' ;
    rdfs:comment 'Specific operational purpose of the bank account within the real estate business. Provides finer-grained classification beyond account_type for cash management and reconciliation. [ENUM-REF-CANDIDATE: rent_collection|vendor_disbursement|payroll|tax_escrow|insurance_escrow|capital_reserve|tenant_security_deposit|loan_proceeds|construction_draw|intercompany — promote to reference product]' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:achEnabled rdf:type rdf:Property ;
    rdfs:label 'Ach Enabled' ;
    rdfs:comment 'Indicates whether Automated Clearing House (ACH) electronic payments are enabled for this bank account. Supports automated rent collection and vendor disbursement workflows.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:balanceAsOfDate rdf:type rdf:Property ;
    rdfs:label 'Balance As Of Date' ;
    rdfs:comment 'The effective date of the current_balance figure. Indicates the point in time to which the reported balance applies, enabling accurate cash position reporting.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bankBranchAddress rdf:type rdf:Property ;
    rdfs:label 'Bank Branch Address' ;
    rdfs:comment 'Street address of the bank branch where the account is held. Used for official correspondence and audit documentation.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankBranchName rdf:type rdf:Property ;
    rdfs:label 'Bank Branch Name' ;
    rdfs:comment 'Name of the specific bank branch where the account is domiciled. Used for correspondence and relationship management with the banking institution.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankStatementDelivery rdf:type rdf:Property ;
    rdfs:label 'Bank Statement Delivery' ;
    rdfs:comment 'Method by which bank statements are delivered for this account. Electronic statements are imported directly into Yardi Voyager or SAP S/4HANA for automated reconciliation; paper statements require manual processing.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentBalance rdf:type rdf:Property ;
    rdfs:label 'Current Balance' ;
    rdfs:comment 'Most recently confirmed ledger balance of the bank account as of the last reconciliation or bank statement date. Used for cash position monitoring and liquidity management. Not a calculated aggregate — represents the point-in-time balance from the source system.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dualSignatureRequired rdf:type rdf:Property ;
    rdfs:label 'Dual Signature Required' ;
    rdfs:comment 'Indicates whether transactions on this account require dual authorization (two signatories). True for accounts with high transaction thresholds or escrow accounts per SOX internal controls.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:houseBankCode rdf:type rdf:Property ;
    rdfs:label 'House Bank Code' ;
    rdfs:comment 'SAP S/4HANA House Bank identifier representing the bank-level grouping under which this account is configured. Used for payment program configuration and bank statement processing.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestRate rdf:type rdf:Property ;
    rdfs:label 'Interest Rate' ;
    rdfs:comment 'Annual interest rate applicable to the bank account balance, expressed as a decimal (e.g., 0.045000 for 4.5%). Applicable for interest-bearing accounts such as money market or reserve accounts.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReconciledDate rdf:type rdf:Property ;
    rdfs:label 'Last Reconciled Date' ;
    rdfs:comment 'Date of the most recent completed bank reconciliation for this account. Critical for SOX-compliant financial controls and cash position accuracy monitoring.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lockboxNumber rdf:type rdf:Property ;
    rdfs:label 'Lockbox Number' ;
    rdfs:comment 'Bank-assigned lockbox number for accounts configured to receive tenant rent payments via lockbox processing. Enables automated AR cash application in Yardi Voyager.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumBalance rdf:type rdf:Property ;
    rdfs:label 'Minimum Balance' ;
    rdfs:comment 'Minimum balance required to be maintained in the account per bank agreement or internal policy (e.g., compensating balance requirements for credit facilities). Triggers alerts when balance falls below threshold.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openDate rdf:type rdf:Property ;
    rdfs:label 'Open Date' ;
    rdfs:comment 'Date on which the bank account was officially opened with the financial institution. Used for account lifecycle tracking and audit trail.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overdraftLimit rdf:type rdf:Property ;
    rdfs:label 'Overdraft Limit' ;
    rdfs:comment 'Maximum overdraft facility approved by the bank for this account. Zero or null if no overdraft facility exists. Used in cash management and liquidity risk monitoring.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positivePayEnrolled rdf:type rdf:Property ;
    rdfs:label 'Positive Pay Enrolled' ;
    rdfs:comment 'Indicates whether this account is enrolled in the bank\'s Positive Pay fraud prevention service, which validates issued checks against a transmitted file before clearing. Critical for AP disbursement fraud controls.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationFrequency rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Frequency' ;
    rdfs:comment 'Required frequency at which this bank account must be reconciled per internal controls policy. Drives automated reconciliation scheduling in Yardi Voyager.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ref rdf:type rdf:Property ;
    rdfs:label 'Ref' ;
    rdfs:comment 'Internal reference code or short identifier assigned to this bank account within Yardi Voyager or SAP S/4HANA for use in GL postings, bank reconciliation, and reporting. Distinct from the masked account number.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wireTransferEnabled rdf:type rdf:Property ;
    rdfs:label 'Wire Transfer Enabled' ;
    rdfs:comment 'Indicates whether outgoing wire transfers are enabled for this bank account. Controls payment method availability in AP disbursement workflows.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:yardiBankCode rdf:type rdf:Property ;
    rdfs:label 'Yardi Bank Code' ;
    rdfs:comment 'Source system identifier for this bank account record in Yardi Voyager. Used for data lineage, reconciliation between the lakehouse silver layer and the operational system, and audit traceability.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debtInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Debt Instrument Id' ;
    rdfs:comment 'Unique surrogate identifier for each debt instrument record in the master registry. Primary key for the debt_instrument data product.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DebtInstrument .

ind:amortizationPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Amortization Period Months' ;
    rdfs:comment 'Total number of months over which the loan principal is amortized for payment calculation purposes. May differ from the loan term for balloon loans (e.g., 30-year amortization with 10-year balloon).' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amortizationType rdf:type rdf:Property ;
    rdfs:label 'Amortization Type' ;
    rdfs:comment 'Describes the principal repayment structure of the debt instrument. Fully amortizing loans retire principal over the term; interest-only loans defer principal to maturity; balloon loans have a large final payment.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossCollateralized rdf:type rdf:Property ;
    rdfs:label 'Cross Collateralized' ;
    rdfs:comment 'Indicates whether this debt instrument is cross-collateralized with other properties or loans, meaning multiple properties secure the same debt obligation. Impacts disposition and refinancing strategies.' ;
    rdfs:domain ind:DebtInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:debtIssuanceCosts rdf:type rdf:Property ;
    rdfs:label 'Debt Issuance Costs' ;
    rdfs:comment 'Total capitalized costs incurred to obtain the debt financing including legal fees, title insurance, appraisal fees, and origination fees. Presented as a direct deduction from the carrying amount of the debt per FASB ASC 835-30.' ;
    rdfs:domain ind:DebtInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dscrCovenantThreshold rdf:type rdf:Property ;
    rdfs:label 'Dscr Covenant Threshold' ;
    rdfs:comment 'Minimum Debt Service Coverage Ratio (DSCR) required under the loan agreement. DSCR is Net Operating Income (NOI) divided by total debt service. Breach triggers lender notification and potential cash trap provisions.' ;
    rdfs:domain ind:DebtInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escrowRequired rdf:type rdf:Property ;
    rdfs:label 'Escrow Required' ;
    rdfs:comment 'Indicates whether the lender requires the borrower to maintain escrow accounts for taxes, insurance, and/or capital reserves as a condition of the loan.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extendedMaturityDate rdf:type rdf:Property ;
    rdfs:label 'Extended Maturity Date' ;
    rdfs:comment 'Revised maturity date if the borrower has exercised an extension option under the loan agreement. Null if no extension has been exercised.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guarantorName rdf:type rdf:Property ;
    rdfs:label 'Guarantor Name' ;
    rdfs:comment 'Legal name of the entity or individual providing a personal or corporate guarantee on the debt instrument. Applicable for recourse and partial-recourse loans. Required for credit risk and exposure reporting.' ;
    rdfs:domain ind:DebtInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentStatus rdf:type rdf:Property ;
    rdfs:label 'Instrument Status' ;
    rdfs:comment 'Current lifecycle status of the debt instrument. Drives covenant monitoring workflows, lender reporting, and portfolio risk dashboards. [ENUM-REF-CANDIDATE: active|paid_off|in_default|in_foreclosure|refinanced|cancelled — promote to reference product]' ;
    rdfs:domain ind:DebtInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentType rdf:type rdf:Property ;
    rdfs:label 'Instrument Type' ;
    rdfs:comment 'Classification of the debt instrument by its structural form. Determines applicable accounting treatment, covenant structures, and reporting requirements. [ENUM-REF-CANDIDATE: mortgage|construction_loan|mezzanine_debt|cmbs|credit_facility|bridge_loan — promote to reference product]' ;
    rdfs:domain ind:DebtInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestOnlyEndDate rdf:type rdf:Property ;
    rdfs:label 'Interest Only End Date' ;
    rdfs:comment 'Date on which the interest-only period expires and principal amortization payments commence. Applicable for hybrid and partial-amortization instruments. Null for fully amortizing loans.' ;
    rdfs:domain ind:DebtInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loanNumber rdf:type rdf:Property ;
    rdfs:label 'Loan Number' ;
    rdfs:comment 'Externally-known unique identifier assigned by the lender to this debt instrument. Used for lender correspondence, covenant reporting, and CMBS/RMBS pool identification. Maps to the loan reference number in Yardi Voyager Debt Management and SAP S/4HANA Finance.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loanTermMonths rdf:type rdf:Property ;
    rdfs:label 'Loan Term Months' ;
    rdfs:comment 'Contractual duration of the debt instrument in months from origination to scheduled maturity. Used for debt maturity ladder analysis and refinancing pipeline planning.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ltvCovenantThreshold rdf:type rdf:Property ;
    rdfs:label 'Ltv Covenant Threshold' ;
    rdfs:comment 'Maximum Loan-to-Value (LTV) ratio permitted under the loan agreement before a covenant breach is triggered. Drives automated covenant monitoring alerts and lender notification workflows.' ;
    rdfs:domain ind:DebtInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maturityDate rdf:type rdf:Property ;
    rdfs:label 'Maturity Date' ;
    rdfs:comment 'Contractual date on which the outstanding principal balance is due in full. Critical for refinancing planning, balloon payment scheduling, and WALT/WALE analysis in portfolio reporting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Next Payment Date' ;
    rdfs:comment 'Date on which the next scheduled debt service payment is due. Used for cash management, AP payment scheduling in Yardi Voyager, and covenant compliance monitoring.' ;
    rdfs:domain ind:DebtInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalPrincipal rdf:type rdf:Property ;
    rdfs:label 'Original Principal' ;
    rdfs:comment 'Total principal amount of the debt instrument at origination. Serves as the baseline for LTV calculations, amortization schedules, and historical debt capacity analysis.' ;
    rdfs:domain ind:DebtInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originationDate rdf:type rdf:Property ;
    rdfs:label 'Origination Date' ;
    rdfs:comment 'Date on which the debt instrument was originated and funds were first disbursed. Marks the effective start of the debt obligation and is used for amortization schedule calculations.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originationFee rdf:type rdf:Property ;
    rdfs:label 'Origination Fee' ;
    rdfs:comment 'Upfront fee paid to the lender at loan origination, typically expressed as points (percentage of loan amount). Capitalized as debt issuance cost and amortized over the loan term per FASB ASC 835.' ;
    rdfs:domain ind:DebtInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'Current unpaid principal balance of the debt instrument as of the most recent payment date. Used for LTV ratio monitoring, balance sheet reporting, and DSCR covenant compliance.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prepaymentLockoutEndDate rdf:type rdf:Property ;
    rdfs:label 'Prepayment Lockout End Date' ;
    rdfs:comment 'Date after which the borrower is permitted to prepay the loan without triggering a lockout penalty. Null if no lockout period applies. Critical for disposition and refinancing timing decisions.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prepaymentPenaltyType rdf:type rdf:Property ;
    rdfs:label 'Prepayment Penalty Type' ;
    rdfs:comment 'Type of prepayment restriction or penalty applicable to early loan payoff. Yield maintenance and defeasance are common in CMBS structures. Drives refinancing cost analysis and disposition planning.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateIndex rdf:type rdf:Property ;
    rdfs:label 'Rate Index' ;
    rdfs:comment 'Benchmark interest rate index to which a variable-rate instrument is tied (e.g., SOFR, Prime Rate, Treasury). Null for fixed-rate instruments. Required for interest rate risk management and hedging analysis.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateSpread rdf:type rdf:Property ;
    rdfs:label 'Rate Spread' ;
    rdfs:comment 'Contractual spread in basis points expressed as a decimal added to the benchmark index to determine the all-in interest rate for variable-rate instruments (e.g., 0.020000 for 200 bps over SOFR). Null for fixed-rate instruments.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateType rdf:type rdf:Property ;
    rdfs:label 'Rate Type' ;
    rdfs:comment 'Classification of the interest rate structure. Fixed Rate Mortgage (FRM) maintains a constant rate; variable/Adjustable Rate Mortgage (ARM) floats against a benchmark index; hybrid combines both periods.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recourseType rdf:type rdf:Property ;
    rdfs:label 'Recourse Type' ;
    rdfs:comment 'Indicates whether the lender has recourse to the borrower\'s other assets beyond the collateral property in the event of default. Non-recourse is standard for CMBS; full recourse is common for construction loans.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Scheduled Payment Amount' ;
    rdfs:comment 'Total scheduled periodic debt service payment amount including both principal and interest components. Used for cash flow forecasting, NOI impact analysis, and DSCR calculations.' ;
    rdfs:domain ind:DebtInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:servicerName rdf:type rdf:Property ;
    rdfs:label 'Servicer Name' ;
    rdfs:comment 'Name of the loan servicer responsible for collecting payments and managing escrow accounts, particularly relevant for CMBS instruments where the servicer differs from the originating lender.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemLoanCode rdf:type rdf:Property ;
    rdfs:label 'Source System Loan Code' ;
    rdfs:comment 'Native identifier of this debt instrument in the originating source system (Yardi Voyager or SAP S/4HANA). Enables bi-directional reconciliation between the lakehouse silver layer and operational systems.' ;
    rdfs:domain ind:DebtInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debtServicePaymentId rdf:type rdf:Property ;
    rdfs:label 'Debt Service Payment Id' ;
    rdfs:comment 'Unique system-generated identifier for each debt service payment record. Primary key for the debt_service_payment data product.' ;
    rdfs:domain ind:DebtServicePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:debtFacilityId rdf:type rdf:Property ;
    rdfs:label 'Debt Facility Id' ;
    rdfs:comment 'Foreign key linking to investment.debt_facility. Business justification: Debt service payments are made against specific investment-domain debt facilities. This link enables covenant compliance monitoring, DSCR calculation, and debt service coverage reporting by connecting' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DebtFacility .

ind:actualEscrowPaid rdf:type rdf:Property ;
    rdfs:label 'Actual Escrow Paid' ;
    rdfs:comment 'The actual escrow amount remitted to the lender for this payment period. Compared against scheduled_escrow_amount to identify escrow shortfalls or surpluses.' ;
    rdfs:domain ind:DebtServicePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualInterestPaid rdf:type rdf:Property ;
    rdfs:label 'Actual Interest Paid' ;
    rdfs:comment 'The actual interest amount remitted to the lender for this payment. Compared against scheduled_interest_amount to identify variances. Feeds into interest expense reporting on the P&L.' ;
    rdfs:domain ind:DebtServicePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Actual Payment Date' ;
    rdfs:comment 'The date on which the debt service payment was actually remitted to the lender. Compared against scheduled_payment_date to determine timeliness and trigger late fee calculations.' ;
    rdfs:domain ind:DebtServicePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualPrincipalPaid rdf:type rdf:Property ;
    rdfs:label 'Actual Principal Paid' ;
    rdfs:comment 'The actual principal amount remitted to the lender for this payment. Compared against scheduled_principal_amount to identify shortfalls or prepayments. Used to update the outstanding loan balance.' ;
    rdfs:domain ind:DebtServicePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:covenantBreachType rdf:type rdf:Property ;
    rdfs:label 'Covenant Breach Type' ;
    rdfs:comment 'Categorizes the type of lender covenant breach triggered by this payment event. Null or \'none\' when no breach occurred. Used for lender reporting and risk management escalation.' ;
    rdfs:domain ind:DebtServicePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Grace Period Days' ;
    rdfs:comment 'The number of calendar days after the scheduled payment date within which payment may be made without triggering a late fee or covenant breach, as defined in the loan agreement.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interestRateApplied rdf:type rdf:Property ;
    rdfs:label 'Interest Rate Applied' ;
    rdfs:comment 'The effective annual interest rate (as a decimal, e.g., 0.065 for 6.5%) applied to calculate the interest component of this payment. Captures the rate in effect for the period, which may vary for adjustable-rate mortgages (ARM).' ;
    rdfs:domain ind:DebtServicePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCovenantBreach rdf:type rdf:Property ;
    rdfs:label 'Is Covenant Breach' ;
    rdfs:comment 'Flag indicating whether this payment event triggered a lender covenant breach (e.g., missed payment, DSCR threshold violation, LTV breach). Drives escalation workflows and lender notification requirements.' ;
    rdfs:domain ind:DebtServicePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lateFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Late Fee Amount' ;
    rdfs:comment 'The penalty fee charged by the lender for a payment received after the scheduled due date or grace period. Tracked separately for covenant compliance reporting and expense analysis.' ;
    rdfs:domain ind:DebtServicePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingBalanceAfter rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance After' ;
    rdfs:comment 'The remaining outstanding principal balance of the debt instrument immediately after this payment is applied. Critical for Loan-to-Value (LTV) ratio monitoring, DSCR calculations, and lender covenant compliance.' ;
    rdfs:domain ind:DebtServicePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingBalanceBefore rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance Before' ;
    rdfs:comment 'The outstanding principal balance of the debt instrument immediately before this payment is applied. Used to verify interest calculations and track amortization progress.' ;
    rdfs:domain ind:DebtServicePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentPeriodNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Period Number' ;
    rdfs:comment 'The sequential payment period number within the loan amortization schedule (e.g., payment 1 of 360 for a 30-year mortgage). Used to track amortization progress and validate payment schedules.' ;
    rdfs:domain ind:DebtServicePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'Externally-known unique identifier for this debt service payment, as assigned by the source system (Yardi Voyager or SAP S/4HANA) or the lender\'s payment portal. Used for reconciliation and lender confirmation matching.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prepaymentPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Prepayment Penalty Amount' ;
    rdfs:comment 'The penalty amount charged by the lender for early repayment of principal beyond the scheduled amortization. Relevant for disposition planning and refinancing analysis.' ;
    rdfs:domain ind:DebtServicePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledEscrowAmount rdf:type rdf:Property ;
    rdfs:label 'Scheduled Escrow Amount' ;
    rdfs:comment 'The contractually scheduled escrow deposit amount due for this payment period, covering property taxes, insurance, and reserves as required by the lender. Included in total debt service obligation.' ;
    rdfs:domain ind:DebtServicePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledInterestAmount rdf:type rdf:Property ;
    rdfs:label 'Scheduled Interest Amount' ;
    rdfs:comment 'The contractually scheduled interest payment amount due for this payment period, calculated based on the outstanding loan balance and the applicable interest rate. Core component of total debt service for DSCR calculations.' ;
    rdfs:domain ind:DebtServicePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Payment Date' ;
    rdfs:comment 'The contractually agreed date on which the debt service payment is due to the lender, as defined in the loan agreement or amortization schedule. Used for cash flow modeling and covenant compliance tracking.' ;
    rdfs:domain ind:DebtServicePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledPrincipalAmount rdf:type rdf:Property ;
    rdfs:label 'Scheduled Principal Amount' ;
    rdfs:comment 'The contractually scheduled principal repayment amount due for this payment period, as defined in the loan amortization schedule. Used as the baseline for DSCR numerator calculations and variance analysis.' ;
    rdfs:domain ind:DebtServicePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Total Payment Amount' ;
    rdfs:comment 'The total amount actually remitted to the lender for this payment, representing the sum of actual principal, interest, escrow, and any late fees paid. Used for cash management reconciliation and lender statement matching.' ;
    rdfs:domain ind:DebtServicePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wireConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Wire Confirmation Number' ;
    rdfs:comment 'The bank-issued confirmation or transaction reference number for wire transfer or ACH payments. Used for payment reconciliation against lender statements and bank records.' ;
    rdfs:domain ind:DebtServicePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentPermitted rdf:type rdf:Property ;
    rdfs:label 'Assignment Permitted' ;
    rdfs:comment 'Indicates whether the tenant is contractually permitted to assign the lease to a third party, subject to landlord consent conditions. Relevant for M&A transactions and corporate restructurings.' ;
    rdfs:domain ind:LeaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseRentMonthly rdf:type rdf:Property ;
    rdfs:label 'Base Rent Monthly' ;
    rdfs:comment 'The contractual monthly base rent amount payable by the tenant, expressed in the agreement currency. Excludes CAM charges, taxes, and insurance. Core input for NOI and EGI calculations.' ;
    rdfs:domain ind:LeaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseRentPsfAnnual rdf:type rdf:Property ;
    rdfs:label 'Base Rent Psf Annual' ;
    rdfs:comment 'Annual base rent expressed on a per-square-foot (PSF) basis. Industry-standard metric used for market comparisons, CMA analysis, and CoStar benchmarking.' ;
    rdfs:domain ind:LeaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:camAnnualBudget rdf:type rdf:Property ;
    rdfs:label 'Cam Annual Budget' ;
    rdfs:comment 'The annual budgeted Common Area Maintenance (CAM) charge allocated to this lease. Used for NNN and modified gross leases to estimate tenant\'s pro-rata share of operating expenses.' ;
    rdfs:domain ind:LeaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:camReconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Cam Reconciliation Date' ;
    rdfs:comment 'The annual date on which CAM charges are reconciled against actual operating expenses and adjustments are billed or credited to the tenant.' ;
    rdfs:domain ind:LeaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coTenancyClause rdf:type rdf:Property ;
    rdfs:label 'Co Tenancy Clause' ;
    rdfs:comment 'Indicates whether the lease contains a co-tenancy clause allowing the tenant to reduce rent or terminate the lease if anchor tenants or a minimum occupancy threshold at the property is not maintained.' ;
    rdfs:domain ind:LeaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discountRate rdf:type rdf:Property ;
    rdfs:label 'Discount Rate' ;
    rdfs:comment 'The interest rate used to discount future lease payments to present value for ASC 842 / IFRS 16 measurement. Typically the implicit rate in the lease or the lessee\'s incremental borrowing rate (IBR), expressed as a decimal (e.g., 0.045000 = 4.5%).' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusivityClause rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Clause' ;
    rdfs:comment 'Indicates whether the lease contains an exclusivity clause restricting the landlord from leasing space to competing tenants within the same property. Common in retail leases.' ;
    rdfs:domain ind:LeaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freeRentMonths rdf:type rdf:Property ;
    rdfs:label 'Free Rent Months' ;
    rdfs:comment 'The number of months of rent abatement (free rent) granted to the tenant at lease commencement or during the lease term. Recognized as a lease incentive under ASC 842 and amortized over the lease term.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdoverRentMultiplier rdf:type rdf:Property ;
    rdfs:label 'Holdover Rent Multiplier' ;
    rdfs:comment 'The multiplier applied to the base rent if the tenant remains in occupancy beyond the lease expiration date without executing a renewal (holdover tenancy). Typically 1.25 to 1.50 (125%–150% of base rent).' ;
    rdfs:domain ind:LeaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceRequiredAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Required Amount' ;
    rdfs:comment 'The minimum general liability insurance coverage amount the tenant is contractually required to maintain and name the landlord as an additional insured, as specified in the lease abstract.' ;
    rdfs:domain ind:LeaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseClassification rdf:type rdf:Property ;
    rdfs:label 'Lease Classification' ;
    rdfs:comment 'ASC 842 / IFRS 16 accounting classification of the lease as either an operating lease or a finance lease (capital lease). Determines balance sheet treatment, amortization method, and income statement presentation for the lessee.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseLiability rdf:type rdf:Property ;
    rdfs:label 'Lease Liability' ;
    rdfs:comment 'The present value of future lease payments recognized as a liability on the balance sheet at lease commencement under ASC 842 / IFRS 16. Decreases as lease payments are made over the lease term.' ;
    rdfs:domain ind:LeaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseNumber rdf:type rdf:Property ;
    rdfs:label 'Lease Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier assigned to the lease agreement, as recorded in Yardi Voyager or MRI. Used for cross-system reference and tenant-facing communications.' ;
    rdfs:domain ind:LeaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseStatus rdf:type rdf:Property ;
    rdfs:label 'Lease Status' ;
    rdfs:comment 'Current lifecycle state of the lease agreement. Drives ASC 842 / IFRS 16 recognition, billing activation, and portfolio reporting. [ENUM-REF-CANDIDATE: draft|executed|active|expired|terminated|holdover — promote to reference product if additional states are required]' ;
    rdfs:domain ind:LeaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leasedAreaSqft rdf:type rdf:Property ;
    rdfs:label 'Leased Area Sqft' ;
    rdfs:comment 'The net leasable area (NLA) in square feet covered by this lease agreement. Used for PSF rent calculations, CAM pro-rata share computation, and GLA occupancy reporting.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permittedUse rdf:type rdf:Property ;
    rdfs:label 'Permitted Use' ;
    rdfs:comment 'The contractually defined purpose for which the tenant is permitted to use the leased premises (e.g., \'retail clothing store\', \'general office use\', \'restaurant and bar\'). Restricts tenant operations and is a key lease abstract field.' ;
    rdfs:domain ind:LeaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proRataShare rdf:type rdf:Property ;
    rdfs:label 'Pro Rata Share' ;
    rdfs:comment 'The tenant\'s proportionate share of the building\'s total rentable area, expressed as a decimal (e.g., 0.125000 = 12.5%). Used to allocate CAM, tax, and insurance charges in NNN and modified gross leases.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalOptionCount rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Count' ;
    rdfs:comment 'The number of renewal options available to the tenant under the lease agreement. Each option typically specifies a term length and rent determination method.' ;
    rdfs:domain ind:LeaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalOptionExercised rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Exercised' ;
    rdfs:comment 'Indicates whether the tenant has formally exercised a renewal option under this lease agreement. True when the renewal notice has been received and acknowledged by the landlord.' ;
    rdfs:domain ind:LeaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalOptionTermMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Term Months' ;
    rdfs:comment 'The duration in months of each renewal option period available to the tenant. Used in ASC 842 lease term assessment to determine if renewal options are reasonably certain to be exercised.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rentCommencementDate rdf:type rdf:Property ;
    rdfs:label 'Rent Commencement Date' ;
    rdfs:comment 'The date on which the tenant\'s obligation to pay base rent begins. May differ from the lease commencement date due to free-rent periods or tenant improvement construction periods.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rentEscalationRate rdf:type rdf:Property ;
    rdfs:label 'Rent Escalation Rate' ;
    rdfs:comment 'The percentage or fixed amount by which base rent escalates per the rent_escalation_type. Expressed as a decimal for percentage types (e.g., 0.0300 = 3%). Null when escalation type is none or CPI-linked.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rentEscalationType rdf:type rdf:Property ;
    rdfs:label 'Rent Escalation Type' ;
    rdfs:comment 'Method by which base rent increases over the lease term. Fixed percent applies a set annual percentage increase. CPI ties escalation to the Consumer Price Index. Fixed amount adds a set dollar increment. None indicates flat rent for the full term.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rouAssetValue rdf:type rdf:Property ;
    rdfs:label 'Rou Asset Value' ;
    rdfs:comment 'The initial measurement of the right-of-use (ROU) asset recognized on the balance sheet at lease commencement under ASC 842 / IFRS 16. Equals the present value of future lease payments plus initial direct costs and prepaid rent.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sndaExecuted rdf:type rdf:Property ;
    rdfs:label 'Snda Executed' ;
    rdfs:comment 'Indicates whether a Subordination, Non-Disturbance, and Attornment (SNDA) agreement has been executed between the tenant, landlord, and lender. Required by most commercial mortgage lenders to protect tenant occupancy rights in foreclosure.' ;
    rdfs:domain ind:LeaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sublettingPermitted rdf:type rdf:Property ;
    rdfs:label 'Subletting Permitted' ;
    rdfs:comment 'Indicates whether the tenant is contractually permitted to sublet all or part of the leased premises to a subtenant, subject to landlord consent conditions specified in the lease.' ;
    rdfs:domain ind:LeaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationOptionDate rdf:type rdf:Property ;
    rdfs:label 'Termination Option Date' ;
    rdfs:comment 'The contractual date on or before which the tenant may exercise an early termination option, if such a right exists in the lease. Null if no early termination option is granted.' ;
    rdfs:domain ind:LeaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Termination Penalty Amount' ;
    rdfs:comment 'The contractual fee or penalty payable by the tenant upon exercising an early termination option. Factored into ASC 842 lease term assessment and lease liability measurement.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tiAllowanceAmount rdf:type rdf:Property ;
    rdfs:label 'Ti Allowance Amount' ;
    rdfs:comment 'The total Tenant Improvement (TI) allowance granted by the landlord to fund tenant fit-out or renovation of the leased premises. Capitalized under FASB ASC 842 lease incentive accounting.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'Externally-known sequential identifier for the amendment as assigned in Yardi Voyager and DocuSign CLM (e.g., AMD-2024-000001). Used for legal referencing and audit trails.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentStatus rdf:type rdf:Property ;
    rdfs:label 'Amendment Status' ;
    rdfs:comment 'Current lifecycle state of the amendment instrument. \'executed\' indicates a fully signed legal document; \'superseded\' indicates a later amendment replaced this one; \'voided\' indicates the amendment was cancelled before execution.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentType rdf:type rdf:Property ;
    rdfs:label 'Amendment Type' ;
    rdfs:comment 'Classification of the primary business purpose of the amendment. Drives ASC 842 lease modification assessment workflow. [ENUM-REF-CANDIDATE: expansion|contraction|rent_modification|term_extension|term_reduction|permitted_use_change|ti_reallowance|snda_update|assignment_consent|other — promote to reference product]' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asc842ModificationType rdf:type rdf:Property ;
    rdfs:label 'Asc842 Modification Type' ;
    rdfs:comment 'Classification of the amendment under FASB ASC 842 lease modification guidance: \'separate_contract\' if the modification grants additional right-of-use at market rate; \'modification_of_existing\' if it changes the scope or consideration of the existing lease; \'not_applicable\' for non-US GAAP entities.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:camRevised rdf:type rdf:Property ;
    rdfs:label 'Cam Revised' ;
    rdfs:comment 'Indicates whether this amendment modifies the Common Area Maintenance (CAM) charge structure, caps, or reconciliation methodology applicable to the tenant.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:docusignStatus rdf:type rdf:Property ;
    rdfs:label 'Docusign Status' ;
    rdfs:comment 'The current status of the DocuSign CLM envelope for this amendment, reflecting the e-signature workflow state. \'completed\' confirms all parties have executed the document.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landlordSignedDate rdf:type rdf:Property ;
    rdfs:label 'Landlord Signed Date' ;
    rdfs:comment 'The date on which the landlord or authorized representative executed (signed) the amendment. Supports execution timeline tracking and legal enforceability confirmation.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lenderConsentDate rdf:type rdf:Property ;
    rdfs:label 'Lender Consent Date' ;
    rdfs:comment 'The date on which lender consent was obtained for this amendment. Null if lender_consent_required is False or consent is pending.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lenderConsentRequired rdf:type rdf:Property ;
    rdfs:label 'Lender Consent Required' ;
    rdfs:comment 'Indicates whether lender consent is required for this amendment under the terms of the property\'s financing agreements. Relevant for CMBS-encumbered properties and loan covenant compliance.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permittedUsePrior rdf:type rdf:Property ;
    rdfs:label 'Permitted Use Prior' ;
    rdfs:comment 'The permitted use clause as stated in the lease before this amendment. Provides the \'before\' value for permitted use change amendments, supporting legal and compliance review.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permittedUseRevised rdf:type rdf:Property ;
    rdfs:label 'Permitted Use Revised' ;
    rdfs:comment 'The revised permitted use clause introduced by this amendment. Defines the authorized business activities the tenant may conduct in the leased premises.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorBaseRentMonthly rdf:type rdf:Property ;
    rdfs:label 'Prior Base Rent Monthly' ;
    rdfs:comment 'The monthly base rent amount in effect under the lease immediately before this amendment. Provides the \'before\' value for rent modification amendments and supports variance analysis.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorGlaSqft rdf:type rdf:Property ;
    rdfs:label 'Prior Gla Sqft' ;
    rdfs:comment 'The Gross Leasable Area (GLA) in square feet as defined in the lease before this amendment. Provides the \'before\' value for expansion or contraction amendments.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remeasurementRequired rdf:type rdf:Property ;
    rdfs:label 'Remeasurement Required' ;
    rdfs:comment 'Indicates whether this amendment triggers a remeasurement of the right-of-use (ROU) asset and lease liability under ASC 842 / IFRS 16. Set to True when the modification is not accounted for as a separate contract.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalOptionRevised rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Revised' ;
    rdfs:comment 'Indicates whether this amendment modifies, adds, or removes renewal option rights for the tenant. Triggers update of renewal option tracking in Yardi Voyager.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rentAbatementMonths rdf:type rdf:Property ;
    rdfs:label 'Rent Abatement Months' ;
    rdfs:comment 'Number of months of free rent or rent abatement granted to the tenant under this amendment. Used in ASC 842 straight-line rent calculations and lease incentive accounting.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rentAbatementStartDate rdf:type rdf:Property ;
    rdfs:label 'Rent Abatement Start Date' ;
    rdfs:comment 'The date on which the rent abatement period granted by this amendment commences. Null if no abatement is included in this amendment.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisedBaseRentMonthly rdf:type rdf:Property ;
    rdfs:label 'Revised Base Rent Monthly' ;
    rdfs:comment 'The monthly base rent amount as revised by this amendment. Drives updated rent billing schedules in Yardi Voyager AR and ASC 842 lease liability remeasurement.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisedGlaSqft rdf:type rdf:Property ;
    rdfs:label 'Revised Gla Sqft' ;
    rdfs:comment 'The Gross Leasable Area (GLA) in square feet as revised by this amendment. Populated for expansion or contraction amendments. Used to update portfolio GLA reporting.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisedLeaseEndDate rdf:type rdf:Property ;
    rdfs:label 'Revised Lease End Date' ;
    rdfs:comment 'Updated lease expiration date resulting from this amendment. Populated for term extensions or reductions. Used to recalculate Weighted Average Lease Expiry (WALE) and Weighted Average Lease Term (WALT) metrics.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisedLeaseStartDate rdf:type rdf:Property ;
    rdfs:label 'Revised Lease Start Date' ;
    rdfs:comment 'Updated lease commencement date resulting from this amendment, if the amendment modifies the original start date (e.g., early possession or delayed commencement). Null if start date is unchanged.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisedRentPsfAnnual rdf:type rdf:Property ;
    rdfs:label 'Revised Rent Psf Annual' ;
    rdfs:comment 'The revised annual rent expressed on a Per Square Foot (PSF) basis following this amendment. Standard CRE metric used for market comparability and portfolio benchmarking.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sndaIncluded rdf:type rdf:Property ;
    rdfs:label 'Snda Included' ;
    rdfs:comment 'Indicates whether a Subordination, Non-Disturbance and Attornment (SNDA) agreement is included as part of or triggered by this amendment. Relevant for lender consent and financing compliance.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tenantSignedDate rdf:type rdf:Property ;
    rdfs:label 'Tenant Signed Date' ;
    rdfs:comment 'The date on which the tenant or authorized representative executed (signed) the amendment. Supports execution timeline tracking and legal enforceability confirmation.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tiAllowancePsf rdf:type rdf:Property ;
    rdfs:label 'Ti Allowance Psf' ;
    rdfs:comment 'The Tenant Improvement (TI) allowance expressed on a Per Square Foot (PSF) basis. Standard CRE metric for benchmarking TI packages against market norms.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yardiAmendmentRef rdf:type rdf:Property ;
    rdfs:label 'Yardi Amendment Ref' ;
    rdfs:comment 'The source system amendment reference code as recorded in Yardi Voyager Lease Administration. Used for reconciliation between the Silver Layer and the operational system of record.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:abstractSource rdf:type rdf:Property ;
    rdfs:label 'Abstract Source' ;
    rdfs:comment 'Identifies the operational system of record from which this renewal option data was abstracted — Yardi Voyager, MRI Software, manual entry, or DocuSign CLM. Supports data lineage and audit.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:abstractedBy rdf:type rdf:Property ;
    rdfs:label 'Abstracted By' ;
    rdfs:comment 'Name or identifier of the person or team responsible for abstracting the renewal option terms from the lease document. Used for quality control and accountability in the lease administration process.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:abstractedDate rdf:type rdf:Property ;
    rdfs:label 'Abstracted Date' ;
    rdfs:comment 'Date on which the renewal option terms were abstracted from the executed lease document and entered into the system of record. Supports data quality auditing and lease abstract workflow management.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:asc842AssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Asc842 Assessment Date' ;
    rdfs:comment 'Date on which the ASC 842 / IFRS 16 reasonably-certain assessment was last performed or reassessed for this renewal option. Required for lease accounting disclosure and audit trail.' ;
    rdfs:domain ind:RenewalOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:asc842ReasonablyCertain rdf:type rdf:Property ;
    rdfs:label 'Asc842 Reasonably Certain' ;
    rdfs:comment 'Accounting determination under FASB ASC 842 (and IFRS 16) as to whether the lessee is reasonably certain to exercise this renewal option. When True, the renewal term is included in the lease term for right-of-use (ROU) asset and lease liability measurement.' ;
    rdfs:domain ind:RenewalOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:asc842ReassessmentTrigger rdf:type rdf:Property ;
    rdfs:label 'Asc842 Reassessment Trigger' ;
    rdfs:comment 'Reason for the most recent reassessment of the reasonably-certain determination under ASC 842 / IFRS 16 — significant event, change in circumstances, periodic review, or none (initial assessment). Required for lease accounting audit trail.' ;
    rdfs:domain ind:RenewalOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:camApplicable rdf:type rdf:Property ;
    rdfs:label 'Cam Applicable' ;
    rdfs:comment 'Indicates whether Common Area Maintenance (CAM) charges are applicable to the tenant during the renewal term. Relevant for NNN and modified gross lease structures.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cpiBaseIndex rdf:type rdf:Property ;
    rdfs:label 'Cpi Base Index' ;
    rdfs:comment 'The baseline Consumer Price Index (CPI) value at lease commencement used as the reference point for CPI-linked rent escalation calculations during the renewal term.' ;
    rdfs:domain ind:RenewalOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpiCapPercent rdf:type rdf:Property ;
    rdfs:label 'Cpi Cap Percent' ;
    rdfs:comment 'Maximum percentage increase in rent allowed under a CPI-linked reset mechanism for the renewal term, expressed as a percentage. Protects the tenant from excessive rent escalation.' ;
    rdfs:domain ind:RenewalOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpiFloorPercent rdf:type rdf:Property ;
    rdfs:label 'Cpi Floor Percent' ;
    rdfs:comment 'Minimum percentage increase in rent guaranteed under a CPI-linked reset mechanism for the renewal term. Protects the landlord from rent reduction in deflationary environments.' ;
    rdfs:domain ind:RenewalOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exerciseDate rdf:type rdf:Property ;
    rdfs:label 'Exercise Date' ;
    rdfs:comment 'Actual date on which the tenant formally exercised the renewal option by delivering written notice to the landlord. Null if the option has not yet been exercised.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exerciseStatus rdf:type rdf:Property ;
    rdfs:label 'Exercise Status' ;
    rdfs:comment 'Current lifecycle state of the renewal option indicating whether the tenant has exercised, waived, allowed to expire, or has yet to act on the option. Drives WALT/WALE forecasting and lease expiry pipeline management.' ;
    rdfs:domain ind:RenewalOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedRenewalRentPsf rdf:type rdf:Property ;
    rdfs:label 'Fixed Renewal Rent Psf' ;
    rdfs:comment 'Pre-agreed base rent rate per square foot (PSF) applicable during the renewal term when the rent reset mechanism is \'fixed\'. Null for non-fixed reset mechanisms.' ;
    rdfs:domain ind:RenewalOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fmvAppraisalRequired rdf:type rdf:Property ;
    rdfs:label 'Fmv Appraisal Required' ;
    rdfs:comment 'Indicates whether a formal Fair Market Value (FMV) appraisal is contractually required to determine the renewal rent when the reset mechanism is \'fair_market_value\'. True if appraisal is mandated.' ;
    rdfs:domain ind:RenewalOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fmvDeterminationMethod rdf:type rdf:Property ;
    rdfs:label 'Fmv Determination Method' ;
    rdfs:comment 'Contractual process for determining Fair Market Value (FMV) rent during the renewal term — single appraiser, dual appraiser (each party appoints one), arbitration, or mutual agreement. Applicable only when rent_reset_mechanism is \'fair_market_value\'.' ;
    rdfs:domain ind:RenewalOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noDefaultCondition rdf:type rdf:Property ;
    rdfs:label 'No Default Condition' ;
    rdfs:comment 'Indicates whether the lease requires the tenant to be in good standing (no material default) at the time of notice and at the commencement of the renewal term as a condition of exercising the option.' ;
    rdfs:domain ind:RenewalOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noticeDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Notice Deadline Date' ;
    rdfs:comment 'The contractual deadline by which the tenant must provide written notice of intent to exercise or waive the renewal option. Failure to meet this date typically results in automatic expiry of the option.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:noticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Notice Period Days' ;
    rdfs:comment 'Number of calendar days prior to the option deadline by which the tenant must deliver written notice of exercise. Derived from lease abstract and used to trigger automated notice alerts.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optionEndDate rdf:type rdf:Property ;
    rdfs:label 'Option End Date' ;
    rdfs:comment 'Contractual expiration date of the renewal term if the option is exercised. Represents the last day of the renewed lease period. Critical for WALE (Weighted Average Lease Expiry) pipeline reporting.' ;
    rdfs:domain ind:RenewalOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optionNumber rdf:type rdf:Property ;
    rdfs:label 'Option Number' ;
    rdfs:comment 'Sequential ordinal number identifying this renewal option within the lease (e.g., 1st option, 2nd option). Used when a lease contains multiple successive renewal options.' ;
    rdfs:domain ind:RenewalOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optionReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Option Reference Code' ;
    rdfs:comment 'Externally-known alphanumeric code or identifier assigned to this renewal option in the source system (Yardi Voyager lease abstract). Used for cross-system reconciliation.' ;
    rdfs:domain ind:RenewalOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionStartDate rdf:type rdf:Property ;
    rdfs:label 'Option Start Date' ;
    rdfs:comment 'Contractual commencement date of the renewal term if the option is exercised. Represents the first day of the renewed lease period.' ;
    rdfs:domain ind:RenewalOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optionTermMonths rdf:type rdf:Property ;
    rdfs:label 'Option Term Months' ;
    rdfs:comment 'Duration of the renewal period expressed in whole months. Provides month-level precision for lease term calculations and ASC 842 / IFRS 16 measurement where fractional years are insufficient.' ;
    rdfs:domain ind:RenewalOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optionTermYears rdf:type rdf:Property ;
    rdfs:label 'Option Term Years' ;
    rdfs:comment 'Duration of the renewal period in years as stipulated in the lease agreement. Used in WALT (Weighted Average Lease Term) and WALE (Weighted Average Lease Expiry) calculations.' ;
    rdfs:domain ind:RenewalOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optionType rdf:type rdf:Property ;
    rdfs:label 'Option Type' ;
    rdfs:comment 'Classification of the contractual option embedded in the lease — renewal (new term), extension (continuation), holdover (month-to-month), or purchase option. Determines accounting treatment under ASC 842 / IFRS 16.' ;
    rdfs:domain ind:RenewalOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalGuaranteeRequired rdf:type rdf:Property ;
    rdfs:label 'Personal Guarantee Required' ;
    rdfs:comment 'Indicates whether a personal guarantee from the tenant principal is required as a condition of exercising the renewal option. Relevant for credit risk assessment and lease underwriting.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalRentEscalationRate rdf:type rdf:Property ;
    rdfs:label 'Renewal Rent Escalation Rate' ;
    rdfs:comment 'Annual rent escalation rate (as a percentage) applicable within the renewal term when escalation type is \'fixed_percent\'. Used in Argus Enterprise DCF cash flow modeling for the renewal period.' ;
    rdfs:domain ind:RenewalOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalRentEscalationType rdf:type rdf:Property ;
    rdfs:label 'Renewal Rent Escalation Type' ;
    rdfs:comment 'Type of annual rent escalation clause applicable within the renewal term — fixed percentage, CPI-linked, fixed dollar amount per year, or no escalation. Distinct from the initial rent reset mechanism.' ;
    rdfs:domain ind:RenewalOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rentResetMechanism rdf:type rdf:Property ;
    rdfs:label 'Rent Reset Mechanism' ;
    rdfs:comment 'Method by which the base rent is determined for the renewal term. Options include fixed (predetermined amount), CPI (Consumer Price Index-linked), fair market value (FMV appraisal), negotiated, or stepped escalation. Drives Argus Enterprise cash flow modeling.' ;
    rdfs:domain ind:RenewalOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tiAllowanceTotal rdf:type rdf:Property ;
    rdfs:label 'Ti Allowance Total' ;
    rdfs:comment 'Total dollar amount of Tenant Improvement (TI) allowance committed by the landlord for the renewal term. Calculated as TI PSF multiplied by the leased area, or specified as a lump sum in the lease abstract.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verifiedDate rdf:type rdf:Property ;
    rdfs:label 'Verified Date' ;
    rdfs:comment 'Date on which the abstracted renewal option terms were independently verified against the executed lease document by a second reviewer. Supports dual-control lease abstract quality standards.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:securityDepositId rdf:type rdf:Property ;
    rdfs:label 'Security Deposit Id' ;
    rdfs:comment 'Foreign key linking to lease.security_deposit. Business justification: termination has security_deposit_amount, security_deposit_return_amount, and security_deposit_forfeited_amount — denormalized fields that duplicate data from the security_deposit record. Linking termi' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SecurityDeposit .

ind:arSettlementComplete rdf:type rdf:Property ;
    rdfs:label 'Ar Settlement Complete' ;
    rdfs:comment 'Indicates whether all outstanding AR balances related to the terminated lease have been settled, written off, or transferred to collections.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:asc842DerecognitionComplete rdf:type rdf:Property ;
    rdfs:label 'Asc842 Derecognition Complete' ;
    rdfs:comment 'Indicates whether the ASC 842 / IFRS 16 derecognition journal entries for the ROU asset and lease liability have been posted in the general ledger upon termination.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:curePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Cure Period Days' ;
    rdfs:comment 'Number of days granted to the defaulting party to remedy a lease breach before the termination becomes final. Typically specified in the lease agreement.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:curePeriodExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Cure Period Expiry Date' ;
    rdfs:comment 'Date on which the cure period expires. Calculated as notice_date plus cure_period_days. Determines when default-driven termination becomes irrevocable.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feeWaived rdf:type rdf:Property ;
    rdfs:label 'Fee Waived' ;
    rdfs:comment 'Indicates whether the termination fee was waived as part of a negotiated mutual surrender or other agreement. Affects AR settlement processing.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gainLossOnTermination rdf:type rdf:Property ;
    rdfs:label 'Gain Loss On Termination' ;
    rdfs:comment 'Net gain or loss recognized in the income statement upon lease termination, calculated as the difference between the derecognized lease liability and ROU asset, adjusted for termination fees and other consideration.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdoverRentRate rdf:type rdf:Property ;
    rdfs:label 'Holdover Rent Rate' ;
    rdfs:comment 'Monthly rent rate per square foot (PSF) charged during the holdover period, typically a premium above the base lease rate as stipulated in the lease agreement.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdoverStatusAtTermination rdf:type rdf:Property ;
    rdfs:label 'Holdover Status At Termination' ;
    rdfs:comment 'Indicates whether the tenant was in holdover status (occupying the premises beyond the lease expiry without a new agreement) at the time the termination was processed.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initiatingParty rdf:type rdf:Property ;
    rdfs:label 'Initiating Party' ;
    rdfs:comment 'Identifies which party initiated the termination — landlord, tenant, mutual agreement, or court order. Affects legal rights, fee obligations, and accounting treatment.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keysReturned rdf:type rdf:Property ;
    rdfs:label 'Keys Returned' ;
    rdfs:comment 'Indicates whether the tenant has returned all physical access credentials (keys, access cards, fobs) for the leased premises upon surrender.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaseLiabilityDerecognitionAmount rdf:type rdf:Property ;
    rdfs:label 'Lease Liability Derecognition Amount' ;
    rdfs:comment 'Remaining lease liability balance derecognized from the balance sheet upon lease termination per ASC 842 / IFRS 16. Used to generate the derecognition journal entry.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:noticeDate rdf:type rdf:Property ;
    rdfs:label 'Notice Date' ;
    rdfs:comment 'Date on which the termination notice was formally issued by either the landlord or tenant. Triggers the notice period and cure period calculations.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalLeaseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Original Lease Expiry Date' ;
    rdfs:comment 'The originally scheduled lease expiration date before any termination event. Used to calculate early termination penalties and remaining lease term at termination.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outstandingArBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Ar Balance' ;
    rdfs:comment 'Total unpaid accounts receivable balance owed by the tenant at the time of termination, including rent arrears, CAM charges, and other lease obligations. Drives AR settlement workflow.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:possessionReturnDate rdf:type rdf:Property ;
    rdfs:label 'Possession Return Date' ;
    rdfs:comment 'Actual date on which the tenant physically vacated and returned possession of the leased premises to the landlord. May differ from the effective termination date.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Standardized code indicating the business reason for the termination (e.g., non-payment, lease breach, relocation, business closure, redevelopment). [ENUM-REF-CANDIDATE: non_payment|lease_breach|relocation|business_closure|redevelopment|condemnation|mutual_agreement|natural_expiry — promote to reference product]' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonNotes rdf:type rdf:Property ;
    rdfs:label 'Reason Notes' ;
    rdfs:comment 'Free-text narrative providing additional context or explanation for the termination reason, supplementing the standardized reason code.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restorationCostEstimate rdf:type rdf:Property ;
    rdfs:label 'Restoration Cost Estimate' ;
    rdfs:comment 'Estimated cost to restore the surrendered premises to the required condition for re-leasing. Informs CAPEX planning and security deposit deduction calculations.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restorationRequired rdf:type rdf:Property ;
    rdfs:label 'Restoration Required' ;
    rdfs:comment 'Indicates whether the tenant is contractually obligated to restore the premises to original condition upon surrender, as specified in the lease agreement.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rouAssetDerecognitionAmount rdf:type rdf:Property ;
    rdfs:label 'Rou Asset Derecognition Amount' ;
    rdfs:comment 'Net book value of the Right-of-Use (ROU) asset derecognized from the balance sheet upon lease termination per ASC 842 / IFRS 16 accounting requirements.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:securityDepositForfeitedAmount rdf:type rdf:Property ;
    rdfs:label 'Security Deposit Forfeited Amount' ;
    rdfs:comment 'Portion of the security deposit retained by the landlord to cover damages, unpaid rent, or other lease obligations not fulfilled by the tenant at termination.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:securityDepositProcessed rdf:type rdf:Property ;
    rdfs:label 'Security Deposit Processed' ;
    rdfs:comment 'Indicates whether the security deposit return or forfeiture has been fully processed and disbursed through Yardi Voyager Accounts Payable.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:securityDepositReturnAmount rdf:type rdf:Property ;
    rdfs:label 'Security Deposit Return Amount' ;
    rdfs:comment 'Amount of the security deposit to be returned to the tenant after deductions for damages, unpaid rent, or other charges. Triggers AP disbursement in Yardi Voyager.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spaceConditionAtSurrender rdf:type rdf:Property ;
    rdfs:label 'Space Condition At Surrender' ;
    rdfs:comment 'Assessed physical condition of the leased premises at the time of tenant surrender. Determines security deposit deductions and informs re-leasing capital expenditure planning.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationNumber rdf:type rdf:Property ;
    rdfs:label 'Termination Number' ;
    rdfs:comment 'Externally-known business reference number assigned to the termination event, used in correspondence with tenants, legal counsel, and DocuSign CLM workflows.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationStatus rdf:type rdf:Property ;
    rdfs:label 'Termination Status' ;
    rdfs:comment 'Current lifecycle state of the termination event, from initial notice through final possession return and accounting close-out.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationType rdf:type rdf:Property ;
    rdfs:label 'Termination Type' ;
    rdfs:comment 'Classification of the termination event. Drives downstream accounting treatment, ASC 842 derecognition methodology, and AR settlement workflows. [ENUM-REF-CANDIDATE: early_termination|mutual_surrender|lease_expiration|default_termination|holdover_resolution|condemnation — promote to reference product]' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unamortizedTiBalance rdf:type rdf:Property ;
    rdfs:label 'Unamortized Ti Balance' ;
    rdfs:comment 'Remaining unamortized balance of Tenant Improvement (TI) allowances at the time of termination. Triggers accelerated amortization or write-off entries under ASC 842 derecognition.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yardiTerminationRef rdf:type rdf:Property ;
    rdfs:label 'Yardi Termination Ref' ;
    rdfs:comment 'Source system reference identifier from Yardi Voyager for the termination transaction record. Used for reconciliation and audit trail between the lakehouse silver layer and the operational system of record.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualRentAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Rent Amount' ;
    rdfs:comment 'The annualized base rent amount for this rent step period (typically base_rent_amount × 12 for monthly leases). Used in Argus Enterprise cash flow modeling and portfolio-level NOI reporting.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseRentAmount rdf:type rdf:Property ;
    rdfs:label 'Base Rent Amount' ;
    rdfs:comment 'The gross monthly base rent amount payable by the tenant for this rent step period, expressed in the lease currency. Excludes CAM charges, operating expenses, and other pass-throughs. Core input for ASC 842 straight-line rent calculation.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpiBaseValue rdf:type rdf:Property ;
    rdfs:label 'Cpi Base Value' ;
    rdfs:comment 'The baseline CPI index value at the commencement of the lease or the start of the CPI measurement period. Used to calculate the percentage change for CPI-linked rent escalation. Null for non-CPI escalation types.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpiCapRate rdf:type rdf:Property ;
    rdfs:label 'Cpi Cap Rate' ;
    rdfs:comment 'The maximum annual CPI escalation rate permitted under the lease terms, expressed as a decimal (e.g., 0.0500 = 5.00% cap). Protects the tenant from excessive CPI-driven rent increases. Null for uncapped CPI or non-CPI escalation types.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpiFloorRate rdf:type rdf:Property ;
    rdfs:label 'Cpi Floor Rate' ;
    rdfs:comment 'The minimum annual CPI escalation rate guaranteed under the lease terms, expressed as a decimal (e.g., 0.0200 = 2.00% floor). Protects the landlord from zero or negative CPI adjustments. Null for non-CPI escalation types.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpiIndexName rdf:type rdf:Property ;
    rdfs:label 'Cpi Index Name' ;
    rdfs:comment 'The name of the CPI index used for rent escalation when escalation_type is \'cpi\' (e.g., \'US CPI-U All Items\', \'UK RPI\'). Null for non-CPI escalation types.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationAmount rdf:type rdf:Property ;
    rdfs:label 'Escalation Amount' ;
    rdfs:comment 'The fixed dollar increment added to the prior step\'s base rent to arrive at this step\'s base rent. Used when escalation_type is \'fixed_step\' with a dollar-denominated increase rather than a percentage. Null for percentage or CPI escalations.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationRate rdf:type rdf:Property ;
    rdfs:label 'Escalation Rate' ;
    rdfs:comment 'The escalation rate applied to derive this step\'s rent from the prior step. Expressed as a decimal percentage (e.g., 0.0300 = 3.00%). Applicable when escalation_type is \'fixed_step\' (percentage) or \'cpi\'. Null for fixed-dollar steps or percentage-of-sales.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationType rdf:type rdf:Property ;
    rdfs:label 'Escalation Type' ;
    rdfs:comment 'The mechanism by which rent increases from one step to the next. \'fixed_step\' = predetermined dollar or percentage increase; \'cpi\' = Consumer Price Index-linked; \'percentage_of_sales\' = percentage rent tied to tenant gross sales; \'market_review\' = reset to fair market value; \'none\' = flat rent with no escalation.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFreeRentPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Free Rent Period' ;
    rdfs:comment 'Indicates whether this rent step period is a free-rent (rent abatement) period during which no base rent is payable by the tenant. True = free-rent period; False = normal rent-paying period. Critical for ASC 842 straight-line rent calculation over the full lease term.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaseLiabilityAmount rdf:type rdf:Property ;
    rdfs:label 'Lease Liability Amount' ;
    rdfs:comment 'The present value of remaining lease payments attributable to this rent step period under ASC 842 / IFRS 16. Represents the lessee\'s financial obligation for this step. Required for balance sheet disclosure and debt covenant compliance reporting.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDueDay rdf:type rdf:Property ;
    rdfs:label 'Payment Due Day' ;
    rdfs:comment 'The day of the month on which rent payment is due (e.g., 1 = first of the month). Used to generate AR billing schedules in Yardi Voyager and to calculate late payment penalties.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:percentageRentBreakpoint rdf:type rdf:Property ;
    rdfs:label 'Percentage Rent Breakpoint' ;
    rdfs:comment 'The gross sales threshold above which percentage rent becomes payable by the tenant. Applicable when escalation_type is \'percentage_of_sales\'. Typically calculated as base_rent_amount divided by the percentage rent rate. Null for non-percentage-of-sales leases.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentageRentRate rdf:type rdf:Property ;
    rdfs:label 'Percentage Rent Rate' ;
    rdfs:comment 'The percentage of tenant gross sales above the breakpoint that is payable as additional rent. Expressed as a decimal (e.g., 0.0600 = 6.00%). Common in retail leases. Null for non-percentage-of-sales leases.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rentPsf rdf:type rdf:Property ;
    rdfs:label 'Rent Psf' ;
    rdfs:comment 'Base rent expressed on a per-square-foot (PSF) annual basis for this rent step period. Calculated as annual_rent_amount divided by the leased area in square feet. Standard CRE benchmarking metric used in CoStar comparable analysis.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rouAssetAmount rdf:type rdf:Property ;
    rdfs:label 'Rou Asset Amount' ;
    rdfs:comment 'The right-of-use (ROU) asset value attributable to this rent step period under ASC 842 / IFRS 16 lessee accounting. Represents the present value of lease payments allocated to this step. Required for balance sheet disclosure and fixed asset register in SAP S/4HANA.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stepSequence rdf:type rdf:Property ;
    rdfs:label 'Step Sequence' ;
    rdfs:comment 'Sequential integer ordering this rent step within the lease agreement\'s full escalation schedule. Step 1 is the initial rent period; subsequent steps represent each escalation event.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:straightLineRentAdjustment rdf:type rdf:Property ;
    rdfs:label 'Straight Line Rent Adjustment' ;
    rdfs:comment 'The difference between the straight-line rent amount and the cash base rent amount for this step period. A positive value indicates deferred rent (cash < straight-line); a negative value indicates prepaid rent. Required for ASC 842 deferred rent liability/asset tracking.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:straightLineRentAmount rdf:type rdf:Property ;
    rdfs:label 'Straight Line Rent Amount' ;
    rdfs:comment 'The ASC 842 / IFRS 16 straight-line rent amount for this step period, representing the equal monthly recognition amount calculated by spreading total lease payments evenly over the lease term. Used for GAAP/IFRS income statement recognition, distinct from cash rent.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualCamGross rdf:type rdf:Property ;
    rdfs:label 'Actual Cam Gross' ;
    rdfs:comment 'Total actual gross operating expenses incurred at the property level for the reconciliation period, before application of the gross-up factor or tenant pro-rata share. Sourced from the property general ledger via Yardi Voyager.' ;
    rdfs:domain ind:CamSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualCamGrossedUp rdf:type rdf:Property ;
    rdfs:label 'Actual Cam Grossed Up' ;
    rdfs:comment 'Actual CAM operating expenses after application of the gross-up factor. Represents the normalized total expense pool used as the basis for tenant pro-rata share allocation.' ;
    rdfs:domain ind:CamSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualCamPsf rdf:type rdf:Property ;
    rdfs:label 'Actual Cam Psf' ;
    rdfs:comment 'Actual CAM charge allocated to the tenant expressed on a per-square-foot basis (PSF). Calculated as tenant_cam_allocated divided by tenant_nla_sqft. Key metric for portfolio benchmarking and market comparisons.' ;
    rdfs:domain ind:CamSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adminFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Admin Fee Amount' ;
    rdfs:comment 'Calculated dollar amount of the landlord\'s administrative fee included in the tenant\'s CAM allocation for the reconciliation period. Derived from admin_fee_rate applied to the eligible CAM expense pool.' ;
    rdfs:domain ind:CamSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adminFeeRate rdf:type rdf:Property ;
    rdfs:label 'Admin Fee Rate' ;
    rdfs:comment 'Percentage rate charged by the landlord as an administrative or management fee on top of actual CAM expenses, expressed as a decimal (e.g., 0.15 = 15%). Permitted under many NNN leases. Null if no admin fee applies.' ;
    rdfs:domain ind:CamSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditRightExercised rdf:type rdf:Property ;
    rdfs:label 'Audit Right Exercised' ;
    rdfs:comment 'Indicates whether the tenant has exercised their contractual right to audit the landlord\'s CAM expense records for the reconciliation period. True if an audit has been formally requested or conducted.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:buildingGlaSqft rdf:type rdf:Property ;
    rdfs:label 'Building Gla Sqft' ;
    rdfs:comment 'Total Gross Leasable Area of the building in square feet used as the denominator for pro-rata share calculation. May differ from total building area if certain areas are excluded per lease terms.' ;
    rdfs:domain ind:CamSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:camCapApplied rdf:type rdf:Property ;
    rdfs:label 'Cam Cap Applied' ;
    rdfs:comment 'Indicates whether the CAM increase cap was triggered and applied during this reconciliation period. True if the calculated CAM increase exceeded the cap and was limited accordingly.' ;
    rdfs:domain ind:CamSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:camCapRate rdf:type rdf:Property ;
    rdfs:label 'Cam Cap Rate' ;
    rdfs:comment 'Maximum annual percentage increase in CAM charges permitted under the lease, expressed as a decimal (e.g., 0.05 = 5% cap). Limits the tenant\'s CAM exposure year-over-year. Null if no cap applies.' ;
    rdfs:domain ind:CamSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:camCapSavings rdf:type rdf:Property ;
    rdfs:label 'Cam Cap Savings' ;
    rdfs:comment 'Monetary amount by which the tenant\'s CAM charge was reduced due to the application of the CAM cap. Represents the difference between the uncapped allocated amount and the capped amount billed. Zero if cap was not applied.' ;
    rdfs:domain ind:CamSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:camCapType rdf:type rdf:Property ;
    rdfs:label 'Cam Cap Type' ;
    rdfs:comment 'Specifies whether the CAM increase cap is cumulative (unused cap carries forward to future years) or non-cumulative (cap resets each year). Determines how the cap is applied in multi-year reconciliations.' ;
    rdfs:domain ind:CamSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:camExclusionsAmount rdf:type rdf:Property ;
    rdfs:label 'Cam Exclusions Amount' ;
    rdfs:comment 'Total dollar value of operating expense line items excluded from the CAM pool per lease terms (e.g., capital expenditures, management fees above a threshold, leasing commissions). Reduces the gross CAM expense pool before tenant allocation.' ;
    rdfs:domain ind:CamSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditOrChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Or Charge Amount' ;
    rdfs:comment 'Net monetary amount due to or from the tenant as a result of the CAM reconciliation. A positive value represents an additional charge invoiced to the tenant; a negative value represents a credit applied to the tenant\'s account. Drives the AR billing or credit memo in Yardi Voyager.' ;
    rdfs:domain ind:CamSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditOrChargeType rdf:type rdf:Property ;
    rdfs:label 'Credit Or Charge Type' ;
    rdfs:comment 'Indicates whether the reconciliation outcome results in an additional charge to the tenant, a credit to the tenant, or a zero-balance settlement. Drives downstream AR and billing workflow routing in Yardi Voyager.' ;
    rdfs:domain ind:CamSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Indicates whether the tenant has formally disputed the CAM reconciliation statement. True if a dispute has been raised; False if no dispute exists. Triggers dispute management workflow.' ;
    rdfs:domain ind:CamSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeResolvedDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolved Date' ;
    rdfs:comment 'Date on which the CAM reconciliation dispute was formally resolved between landlord and tenant. Null if no dispute exists or dispute is still open.' ;
    rdfs:domain ind:CamSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedCamAnnual rdf:type rdf:Property ;
    rdfs:label 'Estimated Cam Annual' ;
    rdfs:comment 'Total estimated CAM charges billed to the tenant over the reconciliation year, based on the budgeted CAM rate established at lease commencement or annual budget cycle. Represents the sum of monthly estimated CAM payments collected from the tenant.' ;
    rdfs:domain ind:CamSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedCamPsf rdf:type rdf:Property ;
    rdfs:label 'Estimated Cam Psf' ;
    rdfs:comment 'Estimated annual CAM charge expressed on a per-square-foot basis (PSF). Calculated as estimated_cam_annual divided by tenant_nla_sqft. Used for benchmarking and lease comparison analytics.' ;
    rdfs:domain ind:CamSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossupFactor rdf:type rdf:Property ;
    rdfs:label 'Grossup Factor' ;
    rdfs:comment 'Multiplier applied to actual CAM expenses to normalize costs to a fully occupied building (typically to 90–100% occupancy). Ensures tenants pay their fair share of variable operating costs regardless of actual vacancy. Expressed as a decimal (e.g., 1.05 for a 5% gross-up).' ;
    rdfs:domain ind:CamSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Payment Received Date' ;
    rdfs:comment 'Date on which the tenant\'s additional CAM payment was received and applied in Yardi Voyager. Null if no additional charge was due or payment has not yet been received.' ;
    rdfs:domain ind:CamSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorYearEstimatedCam rdf:type rdf:Property ;
    rdfs:label 'Prior Year Estimated Cam' ;
    rdfs:comment 'Total estimated CAM charges billed to the tenant in the immediately preceding reconciliation year. Used for year-over-year variance analysis and CAM cap calculations.' ;
    rdfs:domain ind:CamSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationNumber rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Number' ;
    rdfs:comment 'Externally visible, human-readable identifier for this CAM reconciliation record as assigned by Yardi Voyager (e.g., CAMREC-2024-00123). Used in tenant correspondence, audit trails, and billing statements.' ;
    rdfs:domain ind:CamSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Period End' ;
    rdfs:comment 'Last day of the CAM reconciliation period. Defines the boundary of actual operating expenses included in the reconciliation calculation.' ;
    rdfs:domain ind:CamSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Period Start' ;
    rdfs:comment 'First day of the CAM reconciliation period. May differ from the calendar year start for leases with non-standard fiscal periods or mid-year commencement dates.' ;
    rdfs:domain ind:CamSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationSentDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Sent Date' ;
    rdfs:comment 'Date on which the CAM reconciliation statement was formally delivered to the tenant. Triggers the tenant\'s review and dispute window as defined in the lease.' ;
    rdfs:domain ind:CamSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Current workflow state of the CAM reconciliation record. Tracks progression from initial draft through tenant review, finalization, dispute resolution, and settlement. [ENUM-REF-CANDIDATE: draft|in_review|finalized|disputed|settled|voided — promote to reference product if additional states are required]' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationVariance rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Variance' ;
    rdfs:comment 'Difference between the tenant\'s allocated actual CAM charge and the estimated CAM billed during the reconciliation period (tenant_cam_allocated minus estimated_cam_annual). A positive value indicates an underpayment (additional charge due from tenant); a negative value indicates an overpayment (credit due to tenant).' ;
    rdfs:domain ind:CamSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenantCamAllocated rdf:type rdf:Property ;
    rdfs:label 'Tenant Cam Allocated' ;
    rdfs:comment 'Actual CAM expense allocated to this specific tenant, calculated as the grossed-up actual CAM multiplied by the tenant\'s pro-rata share. This is the amount the tenant is contractually obligated to pay for the reconciliation period.' ;
    rdfs:domain ind:CamSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenantNlaSqft rdf:type rdf:Property ;
    rdfs:label 'Tenant Nla Sqft' ;
    rdfs:comment 'The tenant\'s Net Leasable Area in square feet as defined in the lease and used for pro-rata share calculation. Captures the measurement basis for CAM allocation at the time of reconciliation.' ;
    rdfs:domain ind:CamSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenantProrataShare rdf:type rdf:Property ;
    rdfs:label 'Tenant Prorata Share' ;
    rdfs:comment 'The tenant\'s proportionate share of total building CAM expenses, expressed as a decimal fraction (e.g., 0.12500 = 12.5%). Typically calculated as the tenant\'s Net Leasable Area (NLA) divided by the total building NLA or Gross Leasable Area (GLA), as defined in the lease.' ;
    rdfs:domain ind:CamSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenantResponseDueDate rdf:type rdf:Property ;
    rdfs:label 'Tenant Response Due Date' ;
    rdfs:comment 'Deadline by which the tenant must respond to or dispute the CAM reconciliation statement, as stipulated in the lease agreement. Typically 30–90 days after the reconciliation statement is sent.' ;
    rdfs:domain ind:CamSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:yardiCamBatchCode rdf:type rdf:Property ;
    rdfs:label 'Yardi Cam Batch Code' ;
    rdfs:comment 'Source system batch identifier assigned by Yardi Voyager when the CAM reconciliation was processed or posted. Supports data lineage tracing back to the originating system batch run.' ;
    rdfs:domain ind:CamSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allowanceStatus rdf:type rdf:Property ;
    rdfs:label 'Allowance Status' ;
    rdfs:comment 'Current lifecycle state of the TI allowance record. Tracks progression from negotiation through full disbursement or expiry. [ENUM-REF-CANDIDATE: draft|approved|active|disbursing|completed|expired|cancelled — promote to reference product]' ;
    rdfs:domain ind:TiAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allowanceType rdf:type rdf:Property ;
    rdfs:label 'Allowance Type' ;
    rdfs:comment 'Classification of the TI allowance structure: landlord_work (landlord constructs improvements), tenant_work (tenant constructs with reimbursement), turnkey (landlord delivers finished space), cash_allowance (cash paid to tenant), loan_structured (TI structured as amortizing loan). [ENUM-REF-CANDIDATE: landlord_work|tenant_work|turnkey|cash_allowance|loan_structured — promote to reference product]' ;
    rdfs:domain ind:TiAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Spend Amount' ;
    rdfs:comment 'Cumulative dollar amount of TI expenditure formally approved by the landlord against submitted tenant work scopes and contractor bids. May be less than or equal to total_budget_amount.' ;
    rdfs:domain ind:TiAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:asc842LeaseIncentiveFlag rdf:type rdf:Property ;
    rdfs:label 'Asc842 Lease Incentive Flag' ;
    rdfs:comment 'Indicates whether this TI allowance is classified as a lease incentive under FASB ASC 842, requiring recognition as a reduction to the right-of-use asset on the lessee\'s balance sheet.' ;
    rdfs:domain ind:TiAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:constructionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Construction Completion Date' ;
    rdfs:comment 'Actual or projected date on which TI construction work was or is expected to be substantially completed. Triggers final disbursement eligibility.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:constructionStartDate rdf:type rdf:Property ;
    rdfs:label 'Construction Start Date' ;
    rdfs:comment 'Actual or scheduled date on which TI construction work commenced in the leased premises. Sourced from Procore project schedule.' ;
    rdfs:domain ind:TiAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cooReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Coo Received Date' ;
    rdfs:comment 'Date on which the Certificate of Occupancy (COO) was issued by the relevant authority for the TI-improved premises. Often a prerequisite for final TI disbursement.' ;
    rdfs:domain ind:TiAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disbursedAmount rdf:type rdf:Property ;
    rdfs:label 'Disbursed Amount' ;
    rdfs:comment 'Cumulative dollar amount actually paid out by the landlord to the tenant or contractor as TI reimbursement. Represents cash outflow against the TI commitment.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disbursementMethod rdf:type rdf:Property ;
    rdfs:label 'Disbursement Method' ;
    rdfs:comment 'Method by which TI funds are released to the tenant or contractor: lump_sum (single payment), milestone_based (tied to construction milestones), invoice_reimbursement (per submitted invoices), rent_credit (applied as rent offset), loan_advance (structured as a loan draw). [ENUM-REF-CANDIDATE: lump_sum|milestone_based|invoice_reimbursement|rent_credit|loan_advance — promote to reference product]' ;
    rdfs:domain ind:TiAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementMilestoneCount rdf:type rdf:Property ;
    rdfs:label 'Disbursement Milestone Count' ;
    rdfs:comment 'Total number of disbursement milestones defined in the TI disbursement schedule. Applicable when disbursement_method is milestone_based.' ;
    rdfs:domain ind:TiAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ifrs16LeaseIncentiveFlag rdf:type rdf:Property ;
    rdfs:label 'Ifrs16 Lease Incentive Flag' ;
    rdfs:comment 'Indicates whether this TI allowance is classified as a lease incentive under IFRS 16, requiring adjustment to the lease liability measurement for international reporting entities.' ;
    rdfs:domain ind:TiAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoicedAmount rdf:type rdf:Property ;
    rdfs:label 'Invoiced Amount' ;
    rdfs:comment 'Cumulative dollar amount of TI-related invoices submitted by the tenant or contractor to the landlord for reimbursement. Sourced from Procore and Yardi AP module.' ;
    rdfs:domain ind:TiAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isLoanStructured rdf:type rdf:Property ;
    rdfs:label 'Is Loan Structured' ;
    rdfs:comment 'Indicates whether the TI allowance is structured as an amortizing loan to the tenant rather than a grant. When true, amortization terms apply and the TI is treated as a lease incentive receivable under ASC 842.' ;
    rdfs:domain ind:TiAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:landlordApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Landlord Approval Date' ;
    rdfs:comment 'Date on which the landlord formally approved the tenant\'s TI construction plans and budget. Required before disbursement can commence.' ;
    rdfs:domain ind:TiAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:landlordWorkScope rdf:type rdf:Property ;
    rdfs:label 'Landlord Work Scope' ;
    rdfs:comment 'Narrative description of the improvements to be constructed or funded by the landlord as part of the TI package. Sourced from the lease work letter exhibit.' ;
    rdfs:domain ind:TiAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leasableAreaSqft rdf:type rdf:Property ;
    rdfs:label 'Leasable Area Sqft' ;
    rdfs:comment 'Net leasable area of the demised premises in square feet used as the basis for calculating the total TI budget from the PSF rate. Sourced from the lease exhibit.' ;
    rdfs:domain ind:TiAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lienWaiverReceived rdf:type rdf:Property ;
    rdfs:label 'Lien Waiver Received' ;
    rdfs:comment 'Indicates whether all required lien waivers have been received from contractors and subcontractors prior to the most recent TI disbursement.' ;
    rdfs:domain ind:TiAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lienWaiverRequired rdf:type rdf:Property ;
    rdfs:label 'Lien Waiver Required' ;
    rdfs:comment 'Indicates whether lien waivers from contractors and subcontractors are required as a condition of each TI disbursement. Standard risk management practice in commercial real estate construction.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loanAmortizationMonths rdf:type rdf:Property ;
    rdfs:label 'Loan Amortization Months' ;
    rdfs:comment 'Number of months over which the TI loan is amortized through rent payments or separate repayment schedule. Applicable only when is_loan_structured is true.' ;
    rdfs:domain ind:TiAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loanCommencementDate rdf:type rdf:Property ;
    rdfs:label 'Loan Commencement Date' ;
    rdfs:comment 'Date on which the TI loan amortization begins. Typically aligned with lease commencement or first disbursement date. Applicable only when is_loan_structured is true.' ;
    rdfs:domain ind:TiAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loanInterestRate rdf:type rdf:Property ;
    rdfs:label 'Loan Interest Rate' ;
    rdfs:comment 'Annual interest rate applied to the TI loan balance when the allowance is structured as an amortizing loan. Expressed as a decimal (e.g., 0.065 = 6.5%). Applicable only when is_loan_structured is true.' ;
    rdfs:domain ind:TiAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milestonesCompletedCount rdf:type rdf:Property ;
    rdfs:label 'Milestones Completed Count' ;
    rdfs:comment 'Number of disbursement milestones that have been completed and verified to date. Used to track TI disbursement progress against the agreed schedule.' ;
    rdfs:domain ind:TiAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remainingBalance rdf:type rdf:Property ;
    rdfs:label 'Remaining Balance' ;
    rdfs:comment 'Remaining undisbursed TI allowance balance calculated as total_budget_amount minus disbursed_amount. Represents the landlord\'s outstanding TI commitment at any point in time.' ;
    rdfs:domain ind:TiAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenantWorkScope rdf:type rdf:Property ;
    rdfs:label 'Tenant Work Scope' ;
    rdfs:comment 'Narrative description of the improvements to be constructed by the tenant using the TI allowance. Defines the boundary between landlord and tenant construction responsibilities.' ;
    rdfs:domain ind:TiAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tiAllowanceNumber rdf:type rdf:Property ;
    rdfs:label 'Ti Allowance Number' ;
    rdfs:comment 'Externally-known business identifier for the TI allowance record, used in lease exhibits, Procore project references, and Yardi Voyager TI tracking. Format: TIA- followed by alphanumeric characters.' ;
    rdfs:domain ind:TiAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tiAmountPsf rdf:type rdf:Property ;
    rdfs:label 'Ti Amount Psf' ;
    rdfs:comment 'TI allowance expressed as a dollar amount per square foot (PSF) of the leased premises. Standard industry metric used for benchmarking TI generosity across deals and markets.' ;
    rdfs:domain ind:TiAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Total Budget Amount' ;
    rdfs:comment 'Total negotiated TI allowance budget in the lease currency. Represents the maximum landlord commitment for tenant improvement expenditure as agreed in the lease exhibit.' ;
    rdfs:domain ind:TiAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workLetterReference rdf:type rdf:Property ;
    rdfs:label 'Work Letter Reference' ;
    rdfs:comment 'Reference number or exhibit identifier for the work letter attached to the lease that defines the TI scope, budget, and construction obligations. Sourced from DocuSign CLM or lease document management.' ;
    rdfs:domain ind:TiAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yardiTiCode rdf:type rdf:Property ;
    rdfs:label 'Yardi Ti Code' ;
    rdfs:comment 'TI allowance tracking code assigned in Yardi Voyager Lease Administration module. Used for reconciliation between the Silver layer and the Yardi source system.' ;
    rdfs:domain ind:TiAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseId rdf:type rdf:Property ;
    rdfs:label 'Clause Id' ;
    rdfs:comment 'Primary key for clause' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:areaThresholdSqf rdf:type rdf:Property ;
    rdfs:label 'Area Threshold Sqf' ;
    rdfs:comment 'Minimum or maximum square footage threshold relevant to this clause (e.g., co-tenancy anchor must occupy at least 50,000 SQF, expansion option covers up to 5,000 SQF of adjacent space). Expressed in square feet (SQF).' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:asc842ImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Asc842 Impact Flag' ;
    rdfs:comment 'Indicates whether this clause has a material impact on ASC 842 lease accounting classification, measurement, or disclosure (e.g., a purchase option, termination option, or variable rent clause that affects the right-of-use asset or lease liability calculation). True = material ASC 842 impact.' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clauseStatus rdf:type rdf:Property ;
    rdfs:label 'Clause Status' ;
    rdfs:comment 'Current lifecycle status of the clause indicating whether it is currently in force, has been triggered, waived by mutual agreement, expired by its own terms, or superseded by an amendment.' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseType rdf:type rdf:Property ;
    rdfs:label 'Clause Type' ;
    rdfs:comment 'Categorical classification of the lease clause by its legal and operational function. Common types include exclusivity, co-tenancy, kick-out, ROFO (Right of First Offer), ROFR (Right of First Refusal), force majeure, assignment, subletting, audit rights, termination option, expansion option, and holdover. [ENUM-REF-CANDIDATE: exclusivity|co_tenancy|kick_out|rofo|rofr|force_majeure|assignment|subletting|audit_rights|termination_option|expansion_option|holdover|relocation|demolition|condemnation|insurance|indemnification|estoppel|snda|other — promote to reference product]' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coTenancyAnchorTenant rdf:type rdf:Property ;
    rdfs:label 'Co Tenancy Anchor Tenant' ;
    rdfs:comment 'For co-tenancy clauses, the name of the anchor or key tenant whose continued occupancy is a condition of the co-tenancy provision. Vacancy or departure of this tenant may trigger rent abatement or termination rights.' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityUseCategory rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Use Category' ;
    rdfs:comment 'For exclusivity clauses, specifies the protected retail or business use category that the tenant holds exclusive rights to operate within the property or defined trade area (e.g., \'Coffee and Espresso Beverages\', \'Full-Service Pharmacy\'). Null for non-exclusivity clause types.' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exercisingParty rdf:type rdf:Property ;
    rdfs:label 'Exercising Party' ;
    rdfs:comment 'Identifies which party holds the right to exercise or invoke this clause — landlord, tenant, either party, or a specified third party (e.g., guarantor).' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrs16ImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Ifrs16 Impact Flag' ;
    rdfs:comment 'Indicates whether this clause has a material impact on IFRS 16 lease accounting classification, measurement, or disclosure. True = material IFRS 16 impact. Supports dual-standard reporting for international portfolios.' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMutual rdf:type rdf:Property ;
    rdfs:label 'Is Mutual' ;
    rdfs:comment 'Indicates whether the rights or obligations under this clause apply mutually to both landlord and tenant (True) or are unilateral in favor of one party (False). Relevant for indemnification, audit rights, and assignment clauses.' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNegotiated rdf:type rdf:Property ;
    rdfs:label 'Is Negotiated' ;
    rdfs:comment 'Indicates whether this clause was specifically negotiated and customized from the landlord\'s standard lease form (True) or is a standard boilerplate provision (False). Supports risk profiling and lease negotiation benchmarking.' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTriggered rdf:type rdf:Property ;
    rdfs:label 'Is Triggered' ;
    rdfs:comment 'Indicates whether the clause has been triggered or activated based on a qualifying event (e.g., co-tenancy failure, kick-out threshold breach, force majeure event). True = currently triggered; False = not triggered.' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaseSectionNumber rdf:type rdf:Property ;
    rdfs:label 'Lease Section Number' ;
    rdfs:comment 'Section, article, or exhibit number within the lease document where this clause is located (e.g., \'Article 14\', \'Section 22.3\', \'Exhibit D\'). Enables direct cross-reference to the source legal document.' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monetaryThreshold rdf:type rdf:Property ;
    rdfs:label 'Monetary Threshold' ;
    rdfs:comment 'Dollar amount threshold that governs the activation or measurement of this clause (e.g., minimum sales volume for co-tenancy, kick-out sales threshold PSF, TI allowance cap for assignment). Expressed in the lease currency.' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monetaryThresholdCurrency rdf:type rdf:Property ;
    rdfs:label 'Monetary Threshold Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code applicable to the monetary threshold value (e.g., USD, CAD, GBP). Supports multi-currency portfolio management.' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityOrder rdf:type rdf:Property ;
    rdfs:label 'Priority Order' ;
    rdfs:comment 'Numeric ordering of this clause relative to other clauses of the same type on the same lease, used when multiple clauses of the same type exist (e.g., multiple ROFR provisions with different priority rankings). Lower number = higher priority.' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referenceCode rdf:type rdf:Property ;
    rdfs:label 'Reference Code' ;
    rdfs:comment 'Externally-known alphanumeric code or section reference identifying this clause within the lease document (e.g., Section 12.4, Exhibit B-3). Sourced from DocuSign CLM or Yardi Voyager lease abstract.' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rentAbatementPercent rdf:type rdf:Property ;
    rdfs:label 'Rent Abatement Percent' ;
    rdfs:comment 'Percentage reduction in base rent applicable when this clause is triggered (e.g., co-tenancy failure entitles tenant to 50% rent abatement). Expressed as a percentage of base rent.' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Portfolio risk classification assigned to this clause based on its potential financial or operational impact if triggered. Used by asset managers (AM) for portfolio-wide clause risk screening and prioritization.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:textSummary rdf:type rdf:Property ;
    rdfs:label 'Text Summary' ;
    rdfs:comment 'Abstracted plain-language summary of the clause\'s key provisions, obligations, and rights. Captured during lease abstraction from DocuSign CLM or Yardi Voyager. Not the full legal text but sufficient for portfolio screening and risk management.' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Human-readable short title or heading of the clause as it appears in the lease document (e.g., \'Tenant Exclusivity Provision\', \'Co-Tenancy Requirement\'). Used for portfolio-wide clause screening and reporting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerDate rdf:type rdf:Property ;
    rdfs:label 'Trigger Date' ;
    rdfs:comment 'Date on which the clause was triggered or activated by a qualifying event. Null if the clause has not been triggered. Used for risk tracking and legal action timelines.' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:triggerDescription rdf:type rdf:Property ;
    rdfs:label 'Trigger Description' ;
    rdfs:comment 'Plain-language description of the event or condition that triggered or could trigger this clause (e.g., \'Anchor tenant vacancy exceeding 90 days\', \'Sales threshold below $X PSF for two consecutive quarters\').' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'Name or user identifier of the individual who verified the accuracy of the abstracted clause data against the original lease document. Supports SOX compliance and audit trail requirements.' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yardiClauseCode rdf:type rdf:Property ;
    rdfs:label 'Yardi Clause Code' ;
    rdfs:comment 'Native clause identifier assigned by Yardi Voyager lease abstract module. Supports reconciliation and lineage tracing between the silver layer data product and the Yardi Voyager system of record.' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asc842LeaseClassification rdf:type rdf:Property ;
    rdfs:label 'Asc842 Lease Classification' ;
    rdfs:comment 'Lease classification for this demised space under FASB ASC 842 — either Operating Lease or Finance Lease. Determines the accounting treatment for Right-of-Use (ROU) asset and lease liability recognition.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseRentAnnual rdf:type rdf:Property ;
    rdfs:label 'Base Rent Annual' ;
    rdfs:comment 'Total annual base rent amount for this demised space in the lease currency. Derived from base rent PSF multiplied by GLA but stored as a contractual figure from the lease abstract.' ;
    rdfs:domain ind:DemisedSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseRentPsf rdf:type rdf:Property ;
    rdfs:label 'Base Rent Psf' ;
    rdfs:comment 'Annual base rent rate per square foot (PSF) for this demised space as stipulated in the lease agreement. Primary rent metric used for PSF benchmarking, market comparisons, and NOI analysis.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:camEstimatePsf rdf:type rdf:Property ;
    rdfs:label 'Cam Estimate Psf' ;
    rdfs:comment 'Estimated annual Common Area Maintenance (CAM) charge per square foot for this demised space. Used for tenant billing estimates and year-end CAM reconciliation.' ;
    rdfs:domain ind:DemisedSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expansionOption rdf:type rdf:Property ;
    rdfs:label 'Expansion Option' ;
    rdfs:comment 'Indicates whether the lease agreement grants the tenant an expansion option for additional space adjacent to or within the same building as this demised space.' ;
    rdfs:domain ind:DemisedSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:glaSqf rdf:type rdf:Property ;
    rdfs:label 'Gla Sqf' ;
    rdfs:comment 'Total Gross Leasable Area (GLA) of the demised space measured in square feet (SQF) as defined in the lease agreement. GLA is the standard measurement basis for rent calculation in commercial leases.' ;
    rdfs:domain ind:DemisedSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glaSqm rdf:type rdf:Property ;
    rdfs:label 'Gla Sqm' ;
    rdfs:comment 'Total Gross Leasable Area (GLA) of the demised space measured in square meters (SQM). Used for international reporting, IFRS 16 disclosures, and cross-border portfolio analytics.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPrimarySpace rdf:type rdf:Property ;
    rdfs:label 'Is Primary Space' ;
    rdfs:comment 'Indicates whether this demised space is the primary (anchor) space under the lease agreement. Relevant for multi-space leases where one space is designated as the primary premises.' ;
    rdfs:domain ind:DemisedSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaseCommencementDate rdf:type rdf:Property ;
    rdfs:label 'Lease Commencement Date' ;
    rdfs:comment 'Date on which the tenant\'s lease term for this specific demised space commences. May differ from the master lease commencement date for multi-space leases with staggered delivery.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiry Date' ;
    rdfs:comment 'Date on which the tenant\'s lease term for this specific demised space expires. Used in WALT/WALE calculations and lease expiry schedule reporting.' ;
    rdfs:domain ind:DemisedSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseLiabilityValue rdf:type rdf:Property ;
    rdfs:label 'Lease Liability Value' ;
    rdfs:comment 'Initial lease liability recognized for this demised space at lease commencement under ASC 842 / IFRS 16. Represents the present value of future lease payments discounted at the incremental borrowing rate.' ;
    rdfs:domain ind:DemisedSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loadFactor rdf:type rdf:Property ;
    rdfs:label 'Load Factor' ;
    rdfs:comment 'Ratio of Gross Leasable Area (GLA) to Usable Area, representing the tenant\'s proportionate share of common areas added to their usable space. Calculated as GLA / Usable Area. Typical range 1.00–1.25 for office buildings.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nlaSqf rdf:type rdf:Property ;
    rdfs:label 'Nla Sqf' ;
    rdfs:comment 'Net Leasable Area (NLA) of the demised space in square feet, excluding common areas, structural elements, and mechanical spaces. Used for NLA-based rent calculations and PSF analysis.' ;
    rdfs:domain ind:DemisedSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:possessionDate rdf:type rdf:Property ;
    rdfs:label 'Possession Date' ;
    rdfs:comment 'Date on which the landlord delivered physical possession of the demised space to the tenant. Triggers the lease commencement measurement period under ASC 842 / IFRS 16.' ;
    rdfs:domain ind:DemisedSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rentCurrency rdf:type rdf:Property ;
    rdfs:label 'Rent Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for all rent and financial amounts associated with this demised space (e.g., USD, GBP, EUR, AUD).' ;
    rdfs:domain ind:DemisedSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightOfFirstRefusal rdf:type rdf:Property ;
    rdfs:label 'Right Of First Refusal' ;
    rdfs:comment 'Indicates whether the tenant holds a Right of First Refusal (ROFR) on adjacent or specified spaces within the property under this lease.' ;
    rdfs:domain ind:DemisedSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spaceAbstractNotes rdf:type rdf:Property ;
    rdfs:label 'Space Abstract Notes' ;
    rdfs:comment 'Free-text notes from the lease abstract specific to this demised space, including special provisions, exclusions, permitted use restrictions, or physical description details not captured in structured fields.' ;
    rdfs:domain ind:DemisedSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spaceConfiguration rdf:type rdf:Property ;
    rdfs:label 'Space Configuration' ;
    rdfs:comment 'Physical configuration or fit-out state of the demised space at lease commencement. Drives Tenant Improvement (TI) allowance requirements and construction scope.' ;
    rdfs:domain ind:DemisedSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spaceReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Space Reference Code' ;
    rdfs:comment 'Externally-known alphanumeric code identifying this demised space as assigned in Yardi Voyager (e.g., suite number, unit number, or space code). Used in lease documents and tenant correspondence.' ;
    rdfs:domain ind:DemisedSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spaceStatus rdf:type rdf:Property ;
    rdfs:label 'Space Status' ;
    rdfs:comment 'Current lifecycle status of the demised space within the lease. Indicates whether the space is actively occupied, vacant, under renovation, or has been surrendered.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usableAreaSqf rdf:type rdf:Property ;
    rdfs:label 'Usable Area Sqf' ;
    rdfs:comment 'Usable area of the demised space in square feet as defined by BOMA standards — the area exclusively occupied by the tenant, excluding shared corridors and common areas. Basis for load factor calculation.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yardiSpaceRef rdf:type rdf:Property ;
    rdfs:label 'Yardi Space Ref' ;
    rdfs:comment 'Source system identifier for this demised space record in Yardi Voyager (unit/space master). Used for data lineage, reconciliation, and integration with the system of record.' ;
    rdfs:domain ind:DemisedSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentId rdf:type rdf:Property ;
    rdfs:label 'Payment Id' ;
    rdfs:comment 'Primary key for payment' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:percentageRentId rdf:type rdf:Property ;
    rdfs:label 'Percentage Rent Id' ;
    rdfs:comment 'Foreign key linking to lease.percentage_rent. Business justification: Percentage rent (overage rent) obligations generate distinct payment records. Linking payment.percentage_rent_id → lease.percentage_rent.percentage_rent_id connects percentage rent payments to the cal' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PercentageRent .

ind:amountApplied rdf:type rdf:Property ;
    rdfs:label 'Amount Applied' ;
    rdfs:comment 'The portion of amount_paid that has been formally applied against the outstanding AR invoice balance. May differ from amount_paid if a portion is held unapplied (e.g., prepayment or overpayment held in suspense).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountDue rdf:type rdf:Property ;
    rdfs:label 'Amount Due' ;
    rdfs:comment 'The gross amount billed to the tenant for the charge type and applied period as stated on the AR invoice. Represents the contractual obligation before any payments, credits, or adjustments are applied.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountPaid rdf:type rdf:Property ;
    rdfs:label 'Amount Paid' ;
    rdfs:comment 'The actual monetary amount received from the tenant in this payment transaction. May be less than amount_due (partial payment) or equal to it (full payment). Core monetary fact for cash collection reporting.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appliedPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Applied Period End Date' ;
    rdfs:comment 'The last day of the billing period to which this payment is applied (e.g., 2024-01-31 for January rent). Together with applied_period_start_date defines the exact coverage window for the payment.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appliedPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Applied Period Start Date' ;
    rdfs:comment 'The first day of the billing period to which this payment is applied (e.g., 2024-01-01 for January rent). Used for period-level cash collection analysis and ASC 842 / IFRS 16 lease liability amortization reconciliation.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depositDate rdf:type rdf:Property ;
    rdfs:label 'Deposit Date' ;
    rdfs:comment 'The date on which the payment funds were deposited into the property\'s bank account. May differ from payment_date (receipt date) for checks held before deposit or lockbox processing delays. Used for bank reconciliation.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isDelinquent rdf:type rdf:Property ;
    rdfs:label 'Is Delinquent' ;
    rdfs:comment 'Indicates whether this payment was received after the contractual due date (True) or on time (False). Set to True when days_past_due > 0 at the time of receipt. Used for tenant delinquency reporting, arrears event triggering, and portfolio risk dashboards.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lateFeeAssessed rdf:type rdf:Property ;
    rdfs:label 'Late Fee Assessed' ;
    rdfs:comment 'The monetary amount of the late fee charged to the tenant as a result of this payment being received after the due date. Calculated per the late fee schedule in the lease agreement. Zero if payment was on time.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lateFeeWaived rdf:type rdf:Property ;
    rdfs:label 'Late Fee Waived' ;
    rdfs:comment 'Indicates whether the assessed late fee was waived by the property manager or asset manager (True = waived; False = not waived). Supports exception tracking and tenant relationship management reporting.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nsfReturnDate rdf:type rdf:Property ;
    rdfs:label 'Nsf Return Date' ;
    rdfs:comment 'The date on which the bank returned the payment due to NSF or other bank return reason. Populated only when nsf_flag is True. Used to calculate the effective delinquency period and trigger corrective AR actions.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'Externally visible, human-readable payment reference number assigned by Yardi Voyager AR at the time of receipt posting. Used for tenant remittance matching, bank reconciliation, and audit trail. Corresponds to the Yardi receipt number.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceReference rdf:type rdf:Property ;
    rdfs:label 'Remittance Reference' ;
    rdfs:comment 'The tenant-provided reference or memo field included with the payment remittance (e.g., wire transfer memo, ACH addenda, check memo line). Used to match incoming payments to open AR charges when the reference number is not automatically matched.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yardiBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Yardi Batch Number' ;
    rdfs:comment 'The batch or deposit batch number in Yardi Voyager under which this payment was grouped for posting. Supports batch-level reconciliation between Yardi AR and bank deposit records.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yardiReceiptCode rdf:type rdf:Property ;
    rdfs:label 'Yardi Receipt Code' ;
    rdfs:comment 'The native receipt or transaction identifier assigned by Yardi Voyager AR at the time of payment posting. Used for source system traceability, reconciliation between the Silver layer and the operational system, and audit trail.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySecurityAgreementLeaseAgreementId rdf:type rdf:Property ;
    rdfs:label 'Primary Security Agreement Lease Agreement Id' ;
    rdfs:comment 'Reference to the parent lease agreement for which this security deposit is held. Links the deposit record to its governing lease contract.' ;
    rdfs:domain ind:SecurityDeposit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LeaseAgreement .

ind:tertiarySecurityLeaseLeaseAgreementId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Security Lease Lease Agreement Id' ;
    rdfs:comment 'FK to lease.agreement' ;
    rdfs:domain ind:SecurityDeposit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LeaseAgreement .

ind:accruedInterestAmount rdf:type rdf:Property ;
    rdfs:label 'Accrued Interest Amount' ;
    rdfs:comment 'The cumulative interest accrued on the cash security deposit balance to date. Must be returned to the tenant along with the principal deposit amount where legally required.' ;
    rdfs:domain ind:SecurityDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditRiskRating rdf:type rdf:Property ;
    rdfs:label 'Credit Risk Rating' ;
    rdfs:comment 'Credit risk classification of the tenant at the time the security deposit was established. Influences the required deposit amount and instrument type. Used for portfolio-level credit exposure reporting.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionNotes rdf:type rdf:Property ;
    rdfs:label 'Deduction Notes' ;
    rdfs:comment 'Free-text narrative describing the specific basis for deductions applied against the security deposit. Supports itemized deduction statements required by landlord-tenant law and dispute resolution.' ;
    rdfs:domain ind:SecurityDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionReason rdf:type rdf:Property ;
    rdfs:label 'Deduction Reason' ;
    rdfs:comment 'Categorized reason code for any deduction applied against the security deposit. Required for itemized deduction statements provided to tenants and for audit trail compliance. [ENUM-REF-CANDIDATE: unpaid_rent|property_damage|cleaning_charges|lease_break_fee|outstanding_cam|other — promote to reference product if additional categories are needed]' ;
    rdfs:domain ind:SecurityDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositMonthsRent rdf:type rdf:Property ;
    rdfs:label 'Deposit Months Rent' ;
    rdfs:comment 'The number of months of base rent that the required security deposit represents (e.g., 2.00 = two months\' rent). A standard metric used in lease underwriting and tenant credit risk assessment.' ;
    rdfs:domain ind:SecurityDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Deposit Received Date' ;
    rdfs:comment 'The date on which the initial security deposit was received from the tenant. Used for interest accrual calculations and compliance with jurisdictional deposit holding requirements.' ;
    rdfs:domain ind:SecurityDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depositReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Deposit Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the security deposit record as assigned in Yardi Voyager or the governing lease document. Used for cross-system reconciliation and tenant correspondence.' ;
    rdfs:domain ind:SecurityDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositReturnDate rdf:type rdf:Property ;
    rdfs:label 'Deposit Return Date' ;
    rdfs:comment 'The actual or scheduled date on which the security deposit (or net balance) was or is to be returned to the tenant following lease termination. Subject to jurisdictional statutory return deadlines.' ;
    rdfs:domain ind:SecurityDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depositStatus rdf:type rdf:Property ;
    rdfs:label 'Deposit Status' ;
    rdfs:comment 'Current lifecycle status of the security deposit. Tracks whether the deposit is actively held, partially or fully applied against tenant obligations, returned to the tenant, or forfeited upon lease termination.' ;
    rdfs:domain ind:SecurityDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositType rdf:type rdf:Property ;
    rdfs:label 'Deposit Type' ;
    rdfs:comment 'Classification of the security deposit instrument. Determines the mechanism by which the landlord can draw on the deposit in the event of tenant default or lease-end obligations.' ;
    rdfs:domain ind:SecurityDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heldAmount rdf:type rdf:Property ;
    rdfs:label 'Held Amount' ;
    rdfs:comment 'The actual amount of security deposit currently held by the landlord. May differ from the required amount due to partial receipt, reduction schedules, or applied deductions.' ;
    rdfs:domain ind:SecurityDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestBearing rdf:type rdf:Property ;
    rdfs:label 'Interest Bearing' ;
    rdfs:comment 'Indicates whether the security deposit is required by law or contract to accrue interest for the benefit of the tenant. Jurisdictional requirements vary; some states mandate interest-bearing accounts for residential deposits.' ;
    rdfs:domain ind:SecurityDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locAmount rdf:type rdf:Property ;
    rdfs:label 'Loc Amount' ;
    rdfs:comment 'The face value of the letter of credit as issued by the bank. May differ from the required deposit amount if partial draws have been made. Applicable when deposit_type is \'letter_of_credit\'.' ;
    rdfs:domain ind:SecurityDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locAutoRenew rdf:type rdf:Property ;
    rdfs:label 'Loc Auto Renew' ;
    rdfs:comment 'Indicates whether the letter of credit contains an evergreen/automatic renewal clause. If True, the LOC renews automatically unless the issuing bank provides non-renewal notice. Critical for deposit continuity monitoring.' ;
    rdfs:domain ind:SecurityDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Loc Expiry Date' ;
    rdfs:comment 'The expiration date of the letter of credit. Landlord must monitor this date to ensure timely renewal or draw before expiry. A lapsed LOC creates unprotected credit exposure. Applicable when deposit_type is \'letter_of_credit\'.' ;
    rdfs:domain ind:SecurityDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locIssuerName rdf:type rdf:Property ;
    rdfs:label 'Loc Issuer Name' ;
    rdfs:comment 'Name of the financial institution (bank) that issued the letter of credit serving as the security deposit instrument. Applicable only when deposit_type is \'letter_of_credit\'.' ;
    rdfs:domain ind:SecurityDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locNumber rdf:type rdf:Property ;
    rdfs:label 'Loc Number' ;
    rdfs:comment 'The unique reference number assigned by the issuing bank to the letter of credit. Used for draw requests, renewals, and bank correspondence. Applicable when deposit_type is \'letter_of_credit\'.' ;
    rdfs:domain ind:SecurityDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReductionAmount rdf:type rdf:Property ;
    rdfs:label 'Next Reduction Amount' ;
    rdfs:comment 'The dollar amount by which the required security deposit will be reduced on the next scheduled reduction date. Used for cash flow planning and tenant notification.' ;
    rdfs:domain ind:SecurityDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextReductionDate rdf:type rdf:Property ;
    rdfs:label 'Next Reduction Date' ;
    rdfs:comment 'The next scheduled date on which the required security deposit amount is contractually reduced per the deposit reduction schedule. Triggers a review and potential partial return to the tenant.' ;
    rdfs:domain ind:SecurityDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reductionScheduleApplicable rdf:type rdf:Property ;
    rdfs:label 'Reduction Schedule Applicable' ;
    rdfs:comment 'Indicates whether the lease agreement includes a contractual schedule for reducing the required security deposit amount over time, typically tied to tenant performance milestones or lease anniversary dates.' ;
    rdfs:domain ind:SecurityDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredAmount rdf:type rdf:Property ;
    rdfs:label 'Required Amount' ;
    rdfs:comment 'The contractually stipulated security deposit amount as defined in the executed lease agreement. Represents the landlord\'s minimum required collateral from the tenant.' ;
    rdfs:domain ind:SecurityDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnAmount rdf:type rdf:Property ;
    rdfs:label 'Return Amount' ;
    rdfs:comment 'The net amount of the security deposit returned or scheduled to be returned to the tenant upon lease termination, after deducting any applied charges, damages, or outstanding balances.' ;
    rdfs:domain ind:SecurityDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Return Deadline Date' ;
    rdfs:comment 'The statutory or contractual deadline by which the landlord must return the security deposit or provide an itemized deduction statement to the tenant. Failure to meet this deadline may result in penalties.' ;
    rdfs:domain ind:SecurityDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnProcessed rdf:type rdf:Property ;
    rdfs:label 'Return Processed' ;
    rdfs:comment 'Indicates whether the security deposit return transaction has been fully processed in the financial system, including AP payment issuance or LOC release. Used for lease-end settlement tracking.' ;
    rdfs:domain ind:SecurityDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suretyBondExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Surety Bond Expiry Date' ;
    rdfs:comment 'The expiration date of the surety bond instrument. Landlord must track this date to ensure the bond remains valid throughout the lease term. Applicable when deposit_type is \'surety_bond\'.' ;
    rdfs:domain ind:SecurityDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suretyBondIssuer rdf:type rdf:Property ;
    rdfs:label 'Surety Bond Issuer' ;
    rdfs:comment 'Name of the surety company or insurance carrier that issued the surety bond serving as the security deposit. Applicable when deposit_type is \'surety_bond\'.' ;
    rdfs:domain ind:SecurityDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suretyBondNumber rdf:type rdf:Property ;
    rdfs:label 'Surety Bond Number' ;
    rdfs:comment 'Reference number of the surety bond instrument used as the security deposit. Applicable when deposit_type is \'surety_bond\'. Used for claims processing and bond renewal tracking.' ;
    rdfs:domain ind:SecurityDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yardiDepositCode rdf:type rdf:Property ;
    rdfs:label 'Yardi Deposit Code' ;
    rdfs:comment 'The internal deposit charge code assigned in Yardi Voyager for this security deposit record. Used for system reconciliation, AR posting, and cross-referencing with source system transactions.' ;
    rdfs:domain ind:SecurityDeposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableBreakpointAmount rdf:type rdf:Property ;
    rdfs:label 'Applicable Breakpoint Amount' ;
    rdfs:comment 'The effective breakpoint amount used for this reporting period\'s percentage rent calculation — either the natural or artificial breakpoint as determined by breakpoint_type. This is the operative threshold against which reported gross sales are compared.' ;
    rdfs:domain ind:PercentageRent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arInvoiceRef rdf:type rdf:Property ;
    rdfs:label 'Ar Invoice Ref' ;
    rdfs:comment 'Reference to the Accounts Receivable invoice number generated in Yardi Voyager for the billed percentage rent amount. Links the percentage rent record to the AR billing and collection workflow.' ;
    rdfs:domain ind:PercentageRent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:artificialBreakpointAmount rdf:type rdf:Property ;
    rdfs:label 'Artificial Breakpoint Amount' ;
    rdfs:comment 'Fixed gross sales threshold negotiated in the lease above which percentage rent becomes payable. Applicable when breakpoint_type is \'artificial\'. May differ from the natural breakpoint to incentivize or protect the tenant.' ;
    rdfs:domain ind:PercentageRent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Audit Completion Date' ;
    rdfs:comment 'Date on which the landlord\'s audit of the tenant\'s gross sales records was completed and findings were finalized. Populated only when audit_right_exercised is True.' ;
    rdfs:domain ind:PercentageRent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Audit Variance Amount' ;
    rdfs:comment 'Dollar difference between audited_gross_sales and reported_gross_sales discovered during a landlord audit. Positive value indicates tenant under-reported sales; negative indicates over-reporting. Drives additional billing or credit adjustments.' ;
    rdfs:domain ind:PercentageRent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditedGrossSales rdf:type rdf:Property ;
    rdfs:label 'Audited Gross Sales' ;
    rdfs:comment 'Gross sales amount as verified or adjusted following a landlord-initiated audit of the tenant\'s sales records. Populated only when an audit has been completed. May differ from reported_gross_sales if discrepancies are found.' ;
    rdfs:domain ind:PercentageRent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breakpointType rdf:type rdf:Property ;
    rdfs:label 'Breakpoint Type' ;
    rdfs:comment 'Indicates whether the sales breakpoint is a natural breakpoint (derived as base rent divided by the percentage rate) or an artificial breakpoint (a fixed dollar amount negotiated in the lease regardless of base rent).' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseYearNumber rdf:type rdf:Property ;
    rdfs:label 'Lease Year Number' ;
    rdfs:comment 'Sequential lease year (1, 2, 3, …) within the lease term to which this reporting period belongs. Used for annual breakpoint resets and lease-year-based reconciliation cycles.' ;
    rdfs:domain ind:PercentageRent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:naturalBreakpointAmount rdf:type rdf:Property ;
    rdfs:label 'Natural Breakpoint Amount' ;
    rdfs:comment 'Calculated sales threshold equal to annual base rent divided by the percentage rent rate. Gross sales above this level trigger percentage rent obligations. Applicable when breakpoint_type is \'natural\'.' ;
    rdfs:domain ind:PercentageRent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netSalesForCalculation rdf:type rdf:Property ;
    rdfs:label 'Net Sales For Calculation' ;
    rdfs:comment 'Gross sales net of contractual exclusions used as the operative sales figure for percentage rent calculation. Equals reported_gross_sales (or audited_gross_sales if audited) minus sales_exclusions_amount.' ;
    rdfs:domain ind:PercentageRent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pctRentBilled rdf:type rdf:Property ;
    rdfs:label 'Pct Rent Billed' ;
    rdfs:comment 'Actual percentage rent amount invoiced to the tenant for the reporting period. May differ from pct_rent_calculated due to interim billing adjustments, credits applied, or reconciliation true-ups.' ;
    rdfs:domain ind:PercentageRent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pctRentCalculated rdf:type rdf:Property ;
    rdfs:label 'Pct Rent Calculated' ;
    rdfs:comment 'Calculated overage rent amount due for the reporting period, derived as sales_over_breakpoint multiplied by the applicable percentage_rate (or tiered rates). This is the system-computed obligation before any adjustments or credits.' ;
    rdfs:domain ind:PercentageRent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pctRentCollected rdf:type rdf:Property ;
    rdfs:label 'Pct Rent Collected' ;
    rdfs:comment 'Total percentage rent cash received from the tenant for this reporting period. Used to track collection status and outstanding balances against billed amounts.' ;
    rdfs:domain ind:PercentageRent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentageRate rdf:type rdf:Property ;
    rdfs:label 'Percentage Rate' ;
    rdfs:comment 'The contractual percentage rate (expressed as a decimal, e.g., 0.0600 for 6%) applied to gross sales in excess of the applicable breakpoint to calculate overage rent due. Sourced directly from the lease agreement.' ;
    rdfs:domain ind:PercentageRent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'Date on which the percentage rent reconciliation for this reporting period was finalized and agreed between landlord and tenant. Marks the transition to \'reconciled\' status.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportedGrossSales rdf:type rdf:Property ;
    rdfs:label 'Reported Gross Sales' ;
    rdfs:comment 'Total gross sales amount reported by the tenant for the reporting period as submitted in the tenant\'s sales report. This is the tenant-declared figure prior to landlord audit or verification. Classified confidential as it contains commercially sensitive tenant revenue data.' ;
    rdfs:domain ind:PercentageRent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End Date' ;
    rdfs:comment 'Last day of the sales reporting period for which the tenant is required to report gross sales and calculate percentage rent due.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start Date' ;
    rdfs:comment 'First day of the sales reporting period (monthly, quarterly, or annual) for which the tenant is required to report gross sales and calculate percentage rent due.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodType rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Type' ;
    rdfs:comment 'Frequency classification of the sales reporting period as defined in the lease agreement. Determines how often the tenant must submit gross sales reports and how often percentage rent is calculated.' ;
    rdfs:domain ind:PercentageRent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesExclusionsAmount rdf:type rdf:Property ;
    rdfs:label 'Sales Exclusions Amount' ;
    rdfs:comment 'Dollar value of gross sales items contractually excluded from the percentage rent calculation per the lease (e.g., sales tax collected, returns and allowances, employee discounts, internet sales if excluded). Reduces the gross sales base for breakpoint comparison.' ;
    rdfs:domain ind:PercentageRent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesOverBreakpoint rdf:type rdf:Property ;
    rdfs:label 'Sales Over Breakpoint' ;
    rdfs:comment 'The amount by which net_sales_for_calculation exceeds the applicable_breakpoint_amount. This is the overage base to which the percentage_rate is applied. Zero if net sales do not exceed the breakpoint.' ;
    rdfs:domain ind:PercentageRent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Sales Report Due Date' ;
    rdfs:comment 'Contractual deadline by which the tenant must submit their gross sales report for the reporting period as specified in the lease agreement. Used for compliance tracking and late notice generation.' ;
    rdfs:domain ind:PercentageRent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesReportLate rdf:type rdf:Property ;
    rdfs:label 'Sales Report Late' ;
    rdfs:comment 'Indicates whether the tenant\'s gross sales report was received after the contractual due date. True when sales_report_received_date exceeds sales_report_due_date or when the report has not been received by the due date.' ;
    rdfs:domain ind:PercentageRent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesReportReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Sales Report Received Date' ;
    rdfs:comment 'Actual date on which the tenant\'s gross sales report was received by the landlord or property manager. Compared against sales_report_due_date to identify late submissions.' ;
    rdfs:domain ind:PercentageRent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tieredRateApplicable rdf:type rdf:Property ;
    rdfs:label 'Tiered Rate Applicable' ;
    rdfs:comment 'Indicates whether the lease specifies multiple tiered percentage rates applied to different bands of gross sales above the breakpoint (e.g., 5% on first $500K over breakpoint, 6% on next $500K). When True, rate tiers are managed in a related reference structure.' ;
    rdfs:domain ind:PercentageRent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:yardiPctRentRef rdf:type rdf:Property ;
    rdfs:label 'Yardi Pct Rent Ref' ;
    rdfs:comment 'Source system reference code from Yardi Voyager percentage rent module uniquely identifying this record in the operational system of record. Used for reconciliation and audit trail.' ;
    rdfs:domain ind:PercentageRent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountingEntryId rdf:type rdf:Property ;
    rdfs:label 'Accounting Entry Id' ;
    rdfs:comment 'Primary key for accounting_entry' ;
    rdfs:domain ind:AccountingEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountingPeriodDate rdf:type rdf:Property ;
    rdfs:label 'Accounting Period Date' ;
    rdfs:comment 'The first day of the accounting period (month-end or quarter-end) to which this lease accounting entry relates, used for period-end close and disclosure aggregation.' ;
    rdfs:domain ind:AccountingEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entryReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Entry Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned by Yardi Voyager or SAP S/4HANA to uniquely identify this lease accounting entry for cross-system reconciliation and audit trail.' ;
    rdfs:domain ind:AccountingEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryStatus rdf:type rdf:Property ;
    rdfs:label 'Entry Status' ;
    rdfs:comment 'Current workflow state of the lease accounting entry. \'draft\' = pending review; \'posted\' = recorded in GL; \'reversed\' = correcting entry applied; \'adjusted\' = amended after initial posting; \'under_review\' = flagged for auditor review.' ;
    rdfs:domain ind:AccountingEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryType rdf:type rdf:Property ;
    rdfs:label 'Entry Type' ;
    rdfs:comment 'Discriminator for the nature of the accounting entry: \'initial_recognition\' = commencement date measurement; \'subsequent_measurement\' = periodic amortisation/interest; \'remeasurement\' = triggered by lease modification or reassessment; \'termination\' = derecognition; \'modification\' = lease term or payment change; \'disclosure_summary\' = aggregated period-end disclosure record.' ;
    rdfs:domain ind:AccountingEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'The fiscal quarter (1–4) within the fiscal year to which this entry belongs, supporting quarterly 10-Q disclosure requirements for publicly traded REITs.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interestExpense rdf:type rdf:Property ;
    rdfs:label 'Interest Expense' ;
    rdfs:comment 'Interest accrued on the lease liability during the period using the effective interest method at the incremental borrowing rate or implicit rate. Recognised in the income statement for finance leases; included in operating lease cost for operating leases under ASC 842.' ;
    rdfs:domain ind:AccountingEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseIncentiveReceived rdf:type rdf:Property ;
    rdfs:label 'Lease Incentive Received' ;
    rdfs:comment 'Cash or non-cash lease incentives received from the lessor (e.g., Tenant Improvement allowances, free rent periods) that reduce the initial measurement of the ROU asset under ASC 842 / IFRS 16.' ;
    rdfs:domain ind:AccountingEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseLiabilityClosingBalance rdf:type rdf:Property ;
    rdfs:label 'Lease Liability Closing Balance' ;
    rdfs:comment 'Present value of remaining lease payments at the end of the accounting period, as reported on the balance sheet. Equals opening balance plus interest accrual minus principal repayment plus/minus remeasurement.' ;
    rdfs:domain ind:AccountingEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseLiabilityOpeningBalance rdf:type rdf:Property ;
    rdfs:label 'Lease Liability Opening Balance' ;
    rdfs:comment 'Present value of remaining lease payments at the beginning of the accounting period, before current-period interest accrual and principal repayment.' ;
    rdfs:domain ind:AccountingEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseLiabilityRemeasurement rdf:type rdf:Property ;
    rdfs:label 'Lease Liability Remeasurement' ;
    rdfs:comment 'Adjustment to the lease liability resulting from a lease modification, change in lease term, change in variable payments indexed to a rate, or reassessment of a purchase/extension option. Positive = increase; negative = decrease.' ;
    rdfs:domain ind:AccountingEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maturityAfterYear5Payments rdf:type rdf:Property ;
    rdfs:label 'Maturity After Year5 Payments' ;
    rdfs:comment 'Undiscounted future lease payments due more than 5 years from the balance sheet date, completing the maturity analysis disclosure schedule under ASC 842-20-50-6 and IFRS 16 paragraph 58.' ;
    rdfs:domain ind:AccountingEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maturityYear1Payments rdf:type rdf:Property ;
    rdfs:label 'Maturity Year1 Payments' ;
    rdfs:comment 'Undiscounted future lease payments due within 12 months of the balance sheet date, as required for the lease liability maturity analysis disclosure under ASC 842-20-50-6 and IFRS 16 paragraph 58.' ;
    rdfs:domain ind:AccountingEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maturityYear2To5Payments rdf:type rdf:Property ;
    rdfs:label 'Maturity Year2 To5 Payments' ;
    rdfs:comment 'Undiscounted future lease payments due between 1 and 5 years from the balance sheet date, forming part of the maturity analysis disclosure schedule under ASC 842-20-50-6 and IFRS 16 paragraph 58.' ;
    rdfs:domain ind:AccountingEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Date' ;
    rdfs:comment 'The specific date on which the ROU asset and lease liability were measured or remeasured, which may differ from the accounting period date in the case of mid-period modifications or reassessments.' ;
    rdfs:domain ind:AccountingEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modificationFlag rdf:type rdf:Property ;
    rdfs:label 'Modification Flag' ;
    rdfs:comment 'Indicates whether this accounting entry was triggered by a lease modification event (e.g., extension, scope change, rent renegotiation) requiring remeasurement of the ROU asset and lease liability.' ;
    rdfs:domain ind:AccountingEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posted Timestamp' ;
    rdfs:comment 'The date and time when this accounting entry was posted to the General Ledger, representing the principal business event timestamp for the transaction lifecycle.' ;
    rdfs:domain ind:AccountingEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:practicalExpedientApplied rdf:type rdf:Property ;
    rdfs:label 'Practical Expedient Applied' ;
    rdfs:comment 'Indicates which ASC 842 / IFRS 16 practical expedient, if any, has been elected for this lease: \'short_term\' = ≤12-month exemption; \'low_value\' = IFRS 16 low-value asset exemption; \'portfolio\' = portfolio-level application; \'hindsight\' = hindsight expedient on transition; \'none\' = no expedient applied.' ;
    rdfs:domain ind:AccountingEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:principalRepayment rdf:type rdf:Property ;
    rdfs:label 'Principal Repayment' ;
    rdfs:comment 'Cash payment applied to reduce the lease liability principal during the period, representing the financing portion of the lease payment.' ;
    rdfs:domain ind:AccountingEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rouAssetAdditions rdf:type rdf:Property ;
    rdfs:label 'Rou Asset Additions' ;
    rdfs:comment 'Increases to the ROU asset during the period from new lease commencements, lease modifications that increase scope, or remeasurements that increase the lease liability.' ;
    rdfs:domain ind:AccountingEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rouAssetAmortisation rdf:type rdf:Property ;
    rdfs:label 'Rou Asset Amortisation' ;
    rdfs:comment 'Current-period amortisation charge applied to the ROU asset. For finance leases, amortised on a straight-line basis over the shorter of the lease term or useful life; for operating leases, the plug to achieve straight-line rent expense.' ;
    rdfs:domain ind:AccountingEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rouAssetClosingBalance rdf:type rdf:Property ;
    rdfs:label 'Rou Asset Closing Balance' ;
    rdfs:comment 'Net carrying value of the ROU asset at the end of the accounting period after amortisation and any impairment, as reported on the balance sheet.' ;
    rdfs:domain ind:AccountingEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rouAssetImpairment rdf:type rdf:Property ;
    rdfs:label 'Rou Asset Impairment' ;
    rdfs:comment 'Impairment loss recognised against the ROU asset during the period under ASC 360 / IAS 36, reducing the carrying value below the amortised cost.' ;
    rdfs:domain ind:AccountingEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rouAssetOpeningBalance rdf:type rdf:Property ;
    rdfs:label 'Rou Asset Opening Balance' ;
    rdfs:comment 'Carrying value of the Right-of-Use (ROU) asset at the beginning of the accounting period before current-period amortisation, as required for ASC 842 / IFRS 16 roll-forward disclosure.' ;
    rdfs:domain ind:AccountingEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shortTermLeaseCost rdf:type rdf:Property ;
    rdfs:label 'Short Term Lease Cost' ;
    rdfs:comment 'Lease expense recognised for leases with a term of 12 months or less where the short-term practical expedient has been elected, excluded from ROU asset and lease liability recognition. Required disclosure under ASC 842-20-50-4.' ;
    rdfs:domain ind:AccountingEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:straightLineRentExpense rdf:type rdf:Property ;
    rdfs:label 'Straight Line Rent Expense' ;
    rdfs:comment 'Total operating lease cost recognised on a straight-line basis over the lease term for operating leases under ASC 842, combining the amortisation of the ROU asset and the unwinding of the lease liability discount.' ;
    rdfs:domain ind:AccountingEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subleaseIncome rdf:type rdf:Property ;
    rdfs:label 'Sublease Income' ;
    rdfs:comment 'Income received or receivable from subleasing the right-of-use asset to a third party during the period. Required as a separate disclosure line under ASC 842-20-50-4 and IFRS 16 paragraph 53(b).' ;
    rdfs:domain ind:AccountingEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variableLeaseCost rdf:type rdf:Property ;
    rdfs:label 'Variable Lease Cost' ;
    rdfs:comment 'Lease payments not included in the lease liability measurement that vary based on an index, rate, or usage (e.g., CPI-linked rent escalations above the initial index, percentage rent, CAM true-ups). Required disclosure under ASC 842-20-50 and IFRS 16 paragraph 53.' ;
    rdfs:domain ind:AccountingEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightedAvgDiscountRate rdf:type rdf:Property ;
    rdfs:label 'Weighted Avg Discount Rate' ;
    rdfs:comment 'Weighted average incremental borrowing rate or implicit rate applied across the lease portfolio as of period-end, required for ASC 842-20-50-6 and IFRS 16 paragraph 58 disclosure. Stored as a decimal (e.g., 0.048500 = 4.85%).' ;
    rdfs:domain ind:AccountingEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightedAvgRemainingTermYears rdf:type rdf:Property ;
    rdfs:label 'Weighted Avg Remaining Term Years' ;
    rdfs:comment 'Weighted Average Lease Term (WALT) remaining as of the period-end date, expressed in years. Populated on disclosure_summary entry types for aggregated portfolio-level ASC 842 / IFRS 16 footnote disclosure.' ;
    rdfs:domain ind:AccountingEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primarySubleaseTenantId rdf:type rdf:Property ;
    rdfs:label 'Primary Sublease Tenant Id' ;
    rdfs:comment 'Reference to the primary tenant acting as sublessor — the party who holds the head lease and is subletting all or part of their demised premises to a subtenant.' ;
    rdfs:domain ind:Sublease ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tenant .

ind:subleaseSubtenantProfileTenantId rdf:type rdf:Property ;
    rdfs:label 'Sublease Subtenant Profile Tenant Id' ;
    rdfs:comment 'Reference to the subtenant entity occupying the subleased premises. The subtenant has a direct contractual relationship with the sublessor, not the landlord.' ;
    rdfs:domain ind:Sublease ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tenant .

ind:subleaseTenantId rdf:type rdf:Property ;
    rdfs:label 'Sublease Tenant Id' ;
    rdfs:comment 'FK to tenant.tenant' ;
    rdfs:domain ind:Sublease ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tenant .

ind:asc842SubleaseClassification rdf:type rdf:Property ;
    rdfs:label 'Asc842 Sublease Classification' ;
    rdfs:comment 'Classification of the sublease under FASB ASC 842 from the sublessor\'s perspective as an intermediate lessor. \'operating\' means the sublessor recognizes lease income on a straight-line basis; \'finance\' means the sublessor derecognizes the underlying asset and recognizes a net investment in the sublease.' ;
    rdfs:domain ind:Sublease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:camAmountAnnual rdf:type rdf:Property ;
    rdfs:label 'Cam Amount Annual' ;
    rdfs:comment 'Estimated annual Common Area Maintenance (CAM) charges payable by the subtenant. Relevant for NNN and modified gross sublease structures. Used for total occupancy cost analysis.' ;
    rdfs:domain ind:Sublease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountRatePercent rdf:type rdf:Property ;
    rdfs:label 'Discount Rate Percent' ;
    rdfs:comment 'The interest rate used to discount future sublease payments for ASC 842 / IFRS 16 net investment measurement. Typically the rate implicit in the sublease or the sublessor\'s incremental borrowing rate.' ;
    rdfs:domain ind:Sublease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earlyTerminationOption rdf:type rdf:Property ;
    rdfs:label 'Early Termination Option' ;
    rdfs:comment 'Indicates whether the sublease contains an early termination clause allowing either party to terminate the sublease before the scheduled expiration date. Affects ASC 842 lease term determination and WALE calculations.' ;
    rdfs:domain ind:Sublease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governingLawState rdf:type rdf:Property ;
    rdfs:label 'Governing Law State' ;
    rdfs:comment 'Two-letter US state code (or equivalent jurisdiction) whose laws govern the sublease agreement. Relevant for dispute resolution, regulatory compliance, and legal enforceability analysis.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headLeaseRentPsf rdf:type rdf:Property ;
    rdfs:label 'Head Lease Rent Psf' ;
    rdfs:comment 'The sublessor\'s rent obligation under the head lease expressed on a PSF basis for the subleased area. Used to calculate profit or loss on sublease relative to the head lease rent obligation.' ;
    rdfs:domain ind:Sublease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ifrs16SubleaseClassification rdf:type rdf:Property ;
    rdfs:label 'Ifrs16 Sublease Classification' ;
    rdfs:comment 'Classification of the sublease under IFRS 16 from the intermediate lessor\'s perspective. Classification is based on the right-of-use (ROU) asset arising from the head lease, not the underlying asset. \'finance\' requires recognition of a net investment in the sublease.' ;
    rdfs:domain ind:Sublease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landlordConsentDate rdf:type rdf:Property ;
    rdfs:label 'Landlord Consent Date' ;
    rdfs:comment 'The date on which the landlord formally granted written consent to the sublease arrangement. Required for sublease validity where landlord consent is mandated by the head lease.' ;
    rdfs:domain ind:Sublease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:landlordConsentRequired rdf:type rdf:Property ;
    rdfs:label 'Landlord Consent Required' ;
    rdfs:comment 'Indicates whether the head lease requires the landlord\'s written consent before the sublease can be executed. Derived from the head lease assignment and subletting clause.' ;
    rdfs:domain ind:Sublease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:landlordConsentStatus rdf:type rdf:Property ;
    rdfs:label 'Landlord Consent Status' ;
    rdfs:comment 'Current status of the landlord\'s consent process for the sublease. \'not_required\' indicates the head lease permits subletting without consent; \'conditional\' indicates consent granted subject to specific conditions.' ;
    rdfs:domain ind:Sublease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netInvestmentInSublease rdf:type rdf:Property ;
    rdfs:label 'Net Investment In Sublease' ;
    rdfs:comment 'Present value of future sublease payments plus any unguaranteed residual value, recognized on the balance sheet for finance subleases under ASC 842 / IFRS 16. Applicable only when asc842_sublease_classification or ifrs16_sublease_classification is \'finance\'.' ;
    rdfs:domain ind:Sublease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profitLossOnSublease rdf:type rdf:Property ;
    rdfs:label 'Profit Loss On Sublease' ;
    rdfs:comment 'Net financial position of the sublease relative to the head lease rent obligation for the subleased area. Positive value indicates sublease rent exceeds head lease cost (profit); negative value indicates a loss position. Calculated as sublease rent minus allocated head lease rent for the sublet area.' ;
    rdfs:domain ind:Sublease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalOptionAvailable rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Available' ;
    rdfs:comment 'Indicates whether the sublease includes a renewal option allowing the subtenant to extend the sublease term. Relevant for WALT/WALE calculations and ASC 842 lease term reassessment.' ;
    rdfs:domain ind:Sublease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rentAnnual rdf:type rdf:Property ;
    rdfs:label 'Rent Annual' ;
    rdfs:comment 'Total annual base rent payable by the subtenant to the sublessor under the sublease agreement. Used for NOI analysis, profit/loss on sublease calculations, and ASC 842 lessor income recognition.' ;
    rdfs:domain ind:Sublease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rentMonthly rdf:type rdf:Property ;
    rdfs:label 'Rent Monthly' ;
    rdfs:comment 'Monthly base rent payable by the subtenant. Derived from the annual rent schedule but stored explicitly for billing and cash flow forecasting in Yardi Voyager AR.' ;
    rdfs:domain ind:Sublease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rouAssetAllocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Rou Asset Allocated Amount' ;
    rdfs:comment 'Portion of the head lease Right-of-Use (ROU) asset allocated to the subleased area for ASC 842 / IFRS 16 intermediate lessor accounting. Used to determine the carrying amount of the net investment in a finance sublease or the ROU asset derecognition amount.' ;
    rdfs:domain ind:Sublease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subleaseStatus rdf:type rdf:Property ;
    rdfs:label 'Sublease Status' ;
    rdfs:comment 'Current lifecycle state of the sublease agreement. \'draft\' indicates the sublease is being negotiated; \'pending_consent\' indicates awaiting landlord approval; \'active\' indicates the sublease is in force; \'expired\' indicates the term has ended; \'terminated\' indicates early termination; \'holdover\' indicates the subtenant remains in possession beyond the sublease expiry.' ;
    rdfs:domain ind:Sublease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subleaseType rdf:type rdf:Property ;
    rdfs:label 'Sublease Type' ;
    rdfs:comment 'Classification of the sublease arrangement. \'full_assignment\' transfers all rights and obligations of the head lease; \'partial_sublease\' sublets only a portion of the demised premises; \'master_sublease\' covers an entire building or multi-unit portfolio; \'short_term_sublease\' is a temporary arrangement typically under 12 months.' ;
    rdfs:domain ind:Sublease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subletAreaSqft rdf:type rdf:Property ;
    rdfs:label 'Sublet Area Sqft' ;
    rdfs:comment 'The net leasable area (NLA) in square feet being subleased to the subtenant. May be less than the total demised premises area under the head lease for partial subleases. Used for PSF rent calculations and GLA reporting.' ;
    rdfs:domain ind:Sublease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:termMonths rdf:type rdf:Property ;
    rdfs:label 'Term Months' ;
    rdfs:comment 'Total duration of the sublease in months, calculated from commencement to expiration. Used for WALT/WALE analysis and ASC 842 lease term determination.' ;
    rdfs:domain ind:Sublease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yardiSubleaseRef rdf:type rdf:Property ;
    rdfs:label 'Yardi Sublease Ref' ;
    rdfs:comment 'Internal reference code assigned to the sublease record in Yardi Voyager Lease Administration. Used for cross-system reconciliation between the Silver Layer lakehouse and the operational system of record.' ;
    rdfs:domain ind:Sublease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressId rdf:type rdf:Property ;
    rdfs:label 'Address Id' ;
    rdfs:comment 'Foreign key linking to property.address. Business justification: Asset currently embeds address fields (street_address, city, state_code, postal_code, country_code) directly. The address product is the single source of truth for standardized addresses with USPS val' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:apn rdf:type rdf:Property ;
    rdfs:label 'Apn' ;
    rdfs:comment 'Assessor Parcel Number assigned by the county assessor\'s office. Uniquely identifies the land parcel for property tax assessment, title search, and GIS integration.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetCode rdf:type rdf:Property ;
    rdfs:label 'Asset Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the asset as assigned in the property management system (e.g., Yardi property code). Used for cross-system reconciliation and reporting.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetName rdf:type rdf:Property ;
    rdfs:label 'Asset Name' ;
    rdfs:comment 'The canonical marketing or operational name of the property (e.g., \'One Embarcadero Center\', \'Riverside Apartments\'). Used as the primary human-readable identifier across all systems.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bimModelReference rdf:type rdf:Property ;
    rdfs:label 'Bim Model Reference' ;
    rdfs:comment 'Reference identifier or URL to the BIM model file for this asset stored in the document management system (e.g., Procore). Enables digital twin integration, construction oversight, and facility management.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breeamRating rdf:type rdf:Property ;
    rdfs:label 'Breeam Rating' ;
    rdfs:comment 'BREEAM sustainability rating for the building, primarily applicable to UK and European assets. Supports ESG reporting and international investor sustainability requirements.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cooDate rdf:type rdf:Property ;
    rdfs:label 'Coo Date' ;
    rdfs:comment 'Date on which the Certificate of Occupancy was issued by the local building authority. Used for lease commencement eligibility and regulatory compliance tracking.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cooStatus rdf:type rdf:Property ;
    rdfs:label 'Coo Status' ;
    rdfs:comment 'Current status of the Certificate of Occupancy issued by the local building authority. Required for legal occupancy, lease commencement, and regulatory compliance.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costarPropertyNumber rdf:type rdf:Property ;
    rdfs:label 'Costar Property Number' ;
    rdfs:comment 'CoStar Suite\'s proprietary property identifier for this asset. Enables direct linkage to CoStar market data, comparable transactions, and analytics feeds.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energyStarScore rdf:type rdf:Property ;
    rdfs:label 'Energy Star Score' ;
    rdfs:comment 'EPA ENERGY STAR score (1–100) measuring the asset\'s energy efficiency relative to similar buildings. Used for ESG benchmarking, utility cost management, and green certification eligibility.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:far rdf:type rdf:Property ;
    rdfs:label 'Far' ;
    rdfs:comment 'Floor Area Ratio — the ratio of total building floor area to the area of the land parcel. Determines maximum allowable development density under zoning regulations. Key input for development feasibility and entitlement analysis.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fipsCode rdf:type rdf:Property ;
    rdfs:label 'Fips Code' ;
    rdfs:comment 'Five-digit FIPS county code identifying the county in which the asset is located. Used for geographic aggregation, regulatory reporting, and HUD compliance.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEncumbered rdf:type rdf:Property ;
    rdfs:label 'Is Encumbered' ;
    rdfs:comment 'Indicates whether the asset is subject to a mortgage, lien, deed of trust, or other encumbrance. Flags assets with debt obligations for LTV monitoring and disposition clearance requirements.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'WGS-84 decimal degree latitude coordinate of the asset\'s primary location. Enables GIS mapping, spatial analytics, and proximity-based market analysis.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leedCertification rdf:type rdf:Property ;
    rdfs:label 'Leed Certification' ;
    rdfs:comment 'LEED certification level awarded by the U.S. Green Building Council. Drives ESG reporting, green lease premiums, and investor sustainability disclosures.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalDescription rdf:type rdf:Property ;
    rdfs:label 'Legal Description' ;
    rdfs:comment 'Full legal description of the property as recorded in the deed and title documents (metes and bounds, lot/block, or subdivision description). Required for ALTA title insurance and conveyancing.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'WGS-84 decimal degree longitude coordinate of the asset\'s primary location. Enables GIS mapping, spatial analytics, and proximity-based market analysis.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFloors rdf:type rdf:Property ;
    rdfs:label 'Total Floors' ;
    rdfs:comment 'Total number of above-grade floors in the building. Used for building specification reporting, fire safety compliance, and elevator/HVAC system planning.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalUnits rdf:type rdf:Property ;
    rdfs:label 'Total Units' ;
    rdfs:comment 'Total number of leasable units within the asset (applicable to multifamily, self-storage, and hospitality assets). Used for occupancy rate calculations and per-unit financial benchmarking.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yearRenovated rdf:type rdf:Property ;
    rdfs:label 'Year Renovated' ;
    rdfs:comment 'The calendar year of the most recent major renovation or capital improvement. Used for effective age adjustments in appraisals and CAPEX planning cycles.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:buildingCode rdf:type rdf:Property ;
    rdfs:label 'Building Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the building across operational systems (Yardi Voyager, MRI Software, Building Engines). Used as the cross-system business key for integration and reporting.' ;
    rdfs:domain ind:Building ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingName rdf:type rdf:Property ;
    rdfs:label 'Building Name' ;
    rdfs:comment 'Official marketing or operational name of the building (e.g., \'One Market Plaza\', \'Tower A\'). Used in tenant communications, leasing materials, and portfolio reporting.' ;
    rdfs:domain ind:Building ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingStatus rdf:type rdf:Property ;
    rdfs:label 'Building Status' ;
    rdfs:comment 'Current lifecycle status of the building. Drives leasing eligibility, maintenance scheduling, and portfolio reporting. [ENUM-REF-CANDIDATE: operational|under_construction|under_renovation|demolished|held_for_sale|mothballed — promote to reference product]' ;
    rdfs:domain ind:Building ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elevatorCount rdf:type rdf:Property ;
    rdfs:label 'Elevator Count' ;
    rdfs:comment 'Total number of passenger and service elevators in the building. Used in building operations planning, tenant service level assessments, and ADA compliance verification.' ;
    rdfs:domain ind:Building ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fireSuppressionType rdf:type rdf:Property ;
    rdfs:label 'Fire Suppression Type' ;
    rdfs:comment 'Type of fire suppression system installed in the building. Required for insurance underwriting, OSHA compliance reporting, and tenant safety disclosures.' ;
    rdfs:domain ind:Building ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorsAboveGrade rdf:type rdf:Property ;
    rdfs:label 'Floors Above Grade' ;
    rdfs:comment 'Total number of occupied or leasable floors above ground level. Used in floor plan management, elevator capacity planning, and fire safety compliance.' ;
    rdfs:domain ind:Building ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:floorsBelowGrade rdf:type rdf:Property ;
    rdfs:label 'Floors Below Grade' ;
    rdfs:comment 'Total number of floors below ground level (basement, sub-basement, parking levels). Used in parking stall counts, mechanical space planning, and flood risk assessments.' ;
    rdfs:domain ind:Building ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hvacSystemType rdf:type rdf:Property ;
    rdfs:label 'Hvac System Type' ;
    rdfs:comment 'Description of the primary Heating, Ventilation, and Air Conditioning (HVAC) system type installed in the building (e.g., \'VAV\', \'chilled beam\', \'VRF\', \'central plant\'). Used in maintenance scheduling, energy benchmarking, and ESG reporting.' ;
    rdfs:domain ind:Building ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAdaCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Ada Compliant' ;
    rdfs:comment 'Indicates whether the building meets Americans with Disabilities Act (ADA) accessibility requirements. Required for lease disclosures, regulatory compliance, and tenant accommodation obligations.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEsgReported rdf:type rdf:Property ;
    rdfs:label 'Is Esg Reported' ;
    rdfs:comment 'Indicates whether this building is included in the enterprise\'s Environmental, Social, and Governance (ESG) reporting scope. Drives inclusion in GRESB, SEC sustainability disclosures, and REIT ESG benchmarks.' ;
    rdfs:domain ind:Building ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nlaSqm rdf:type rdf:Property ;
    rdfs:label 'Nla Sqm' ;
    rdfs:comment 'Net Leasable Area (NLA) of the building in square meters (SQM). Used for international lease abstractions, IFRS 16 right-of-use asset calculations, and ESG intensity metrics (e.g., energy per SQM).' ;
    rdfs:domain ind:Building ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parkingStallsTotal rdf:type rdf:Property ;
    rdfs:label 'Parking Stalls Total' ;
    rdfs:comment 'Total number of parking stalls associated with the building, including surface, structured, and underground parking. Used in lease negotiations, parking revenue management, and zoning compliance.' ;
    rdfs:domain ind:Building ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:structuralSystem rdf:type rdf:Property ;
    rdfs:label 'Structural System' ;
    rdfs:comment 'Description of the primary structural system (e.g., \'moment frame\', \'shear wall\', \'flat plate\', \'post-tensioned slab\'). Required for engineering assessments, seismic compliance, and BIM documentation.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalRentableSqft rdf:type rdf:Property ;
    rdfs:label 'Total Rentable Sqft' ;
    rdfs:comment 'Total rentable area per BOMA measurement standards, including tenant usable area plus the tenant\'s pro-rata share of Common Area Maintenance (CAM) spaces. Basis for rent billing and CAM reconciliation.' ;
    rdfs:domain ind:Building ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessedLandValue rdf:type rdf:Property ;
    rdfs:label 'Assessed Land Value' ;
    rdfs:comment 'County assessor\'s assessed value of the land (excluding improvements) in USD. Used for property tax calculation, Argus Enterprise valuation modeling, and NAV/GAV reporting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessedValueYear rdf:type rdf:Property ;
    rdfs:label 'Assessed Value Year' ;
    rdfs:comment 'Tax year for which the assessed_land_value was determined by the county assessor. Ensures temporal accuracy of valuation data for tax and financial reporting.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:centroidLatitude rdf:type rdf:Property ;
    rdfs:label 'Centroid Latitude' ;
    rdfs:comment 'Decimal latitude coordinate of the parcel centroid in WGS84 datum. Used for mapping, proximity analysis, and GIS-based portfolio reporting.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:centroidLongitude rdf:type rdf:Property ;
    rdfs:label 'Centroid Longitude' ;
    rdfs:comment 'Decimal longitude coordinate of the parcel centroid in WGS84 datum. Used for mapping, proximity analysis, and GIS-based portfolio reporting.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deedBookPage rdf:type rdf:Property ;
    rdfs:label 'Deed Book Page' ;
    rdfs:comment 'County recorder deed book and page number reference (e.g., \'Book 1234, Page 567\') identifying the recorded deed instrument for this parcel. Used for title chain verification and ALTA surveys.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:easementDescription rdf:type rdf:Property ;
    rdfs:label 'Easement Description' ;
    rdfs:comment 'Description of any recorded easements, rights-of-way, or encumbrances affecting the parcel (e.g., utility easement, access easement, drainage easement). Material to title review and development planning.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalDesignation rdf:type rdf:Property ;
    rdfs:label 'Environmental Designation' ;
    rdfs:comment 'Environmental status designation of the parcel indicating known contamination or regulatory classification. \'brownfield\' indicates previously developed land with potential contamination; \'superfund\' indicates EPA National Priorities List site; \'wetland\' indicates protected wetland area; \'contaminated\' indicates confirmed contamination; \'under_review\' indicates active Phase I/II ESA in progress.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:farAllowed rdf:type rdf:Property ;
    rdfs:label 'Far Allowed' ;
    rdfs:comment 'Maximum Floor Area Ratio (FAR) permitted under current zoning regulations. FAR is the ratio of total building floor area to the parcel land area. Critical input for development feasibility and Argus Enterprise cash flow modeling.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:femaMapPanelNumber rdf:type rdf:Property ;
    rdfs:label 'Fema Map Panel Number' ;
    rdfs:comment 'FEMA Flood Insurance Rate Map (FIRM) panel number identifying the specific flood map panel on which this parcel appears. Required for flood insurance underwriting and lender compliance.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floodZoneDesignation rdf:type rdf:Property ;
    rdfs:label 'Flood Zone Designation' ;
    rdfs:comment 'Federal Emergency Management Agency (FEMA) flood zone designation for the parcel (e.g., Zone A, Zone AE, Zone X, Zone VE). Determines flood insurance requirements, lender mandates, and development risk. Sourced from FEMA Flood Insurance Rate Maps (FIRM). [ENUM-REF-CANDIDATE: Zone A|Zone AE|Zone AH|Zone AO|Zone AR|Zone A99|Zone V|Zone VE|Zone X|Zone D — promote to reference product]' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frontSetbackFt rdf:type rdf:Property ;
    rdfs:label 'Front Setback Ft' ;
    rdfs:comment 'Minimum required front setback distance in feet from the street right-of-way to the building face, as mandated by local zoning regulations. Impacts buildable area calculations.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gisBoundaryWkt rdf:type rdf:Property ;
    rdfs:label 'Gis Boundary Wkt' ;
    rdfs:comment 'GIS polygon boundary of the parcel expressed in Well-Known Text (WKT) format (e.g., POLYGON((lon1 lat1, lon2 lat2, ...))). Enables spatial analysis, mapping, and integration with GIS platforms. Conforms to OGC Simple Features standard.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastSaleDate rdf:type rdf:Property ;
    rdfs:label 'Last Sale Date' ;
    rdfs:comment 'Date of the most recent arm\'s-length sale transaction recorded for this parcel. Used for Comparative Market Analysis (CMA), Broker Price Opinion (BPO), and CoStar comparable sales analysis.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastSalePrice rdf:type rdf:Property ;
    rdfs:label 'Last Sale Price' ;
    rdfs:comment 'Recorded sale price in USD from the most recent arm\'s-length transaction for this parcel. Used for CMA, BPO, CAP rate analysis, and Argus Enterprise valuation benchmarking.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotSizeAcres rdf:type rdf:Property ;
    rdfs:label 'Lot Size Acres' ;
    rdfs:comment 'Total land area of the parcel expressed in acres as recorded by the county assessor. Used for valuation, FAR calculations, and development feasibility analysis.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotSizeSqf rdf:type rdf:Property ;
    rdfs:label 'Lot Size Sqf' ;
    rdfs:comment 'Total land area of the parcel expressed in square feet (SQF). Primary unit for commercial real estate analysis, PSF calculations, and CoStar/MLS data alignment.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotSizeSqm rdf:type rdf:Property ;
    rdfs:label 'Lot Size Sqm' ;
    rdfs:comment 'Total land area of the parcel expressed in square meters (SQM). Required for international portfolio reporting, IFRS 16 compliance, and cross-border investment analysis.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxBuildingHeightFt rdf:type rdf:Property ;
    rdfs:label 'Max Building Height Ft' ;
    rdfs:comment 'Maximum allowable building height in feet as specified by local zoning ordinance. Constrains development potential and is used in Procore construction project planning and Argus Enterprise valuation models.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parcelName rdf:type rdf:Property ;
    rdfs:label 'Parcel Name' ;
    rdfs:comment 'Human-readable business name or label assigned to the parcel for internal identification and reporting purposes (e.g., \'Westside Industrial Lot 4\'). Distinct from the legal description.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parcelStatus rdf:type rdf:Property ;
    rdfs:label 'Parcel Status' ;
    rdfs:comment 'Current lifecycle status of the parcel record. \'active\' indicates the parcel is a valid, undivided legal unit; \'subdivided\' indicates it has been split into child parcels; \'merged\' indicates it has been combined with adjacent parcels; \'inactive\' indicates retired or decommissioned; \'pending\' indicates awaiting county confirmation.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parcelType rdf:type rdf:Property ;
    rdfs:label 'Parcel Type' ;
    rdfs:comment 'Classification of the parcel by its legal and physical nature. \'land\' denotes unimproved vacant land; \'improved\' denotes land with structures; \'condominium\' denotes a condo parcel; \'timeshare\' denotes a fractional ownership parcel; \'right_of_way\' denotes easement or access parcels.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentApn rdf:type rdf:Property ;
    rdfs:label 'Parent Apn' ;
    rdfs:comment 'APN of the parent parcel from which this parcel was subdivided. Populated when status is \'subdivided\' to maintain the parcel lineage and ownership hierarchy. Null for original parcels.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseIEsaCompleted rdf:type rdf:Property ;
    rdfs:label 'Phase I Esa Completed' ;
    rdfs:comment 'Indicates whether a Phase I Environmental Site Assessment (ESA) has been completed for this parcel. Required by lenders and investors prior to acquisition per ASTM E1527 standard.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phaseIEsaDate rdf:type rdf:Property ;
    rdfs:label 'Phase I Esa Date' ;
    rdfs:comment 'Date on which the most recent Phase I Environmental Site Assessment (ESA) was completed. Used to determine if the assessment is current (typically valid for 180 days per ASTM E1527).' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:platMapReference rdf:type rdf:Property ;
    rdfs:label 'Plat Map Reference' ;
    rdfs:comment 'Reference to the recorded subdivision plat map (e.g., plat book and page, or plat file number) from which the parcel\'s lot and block description is derived. Required for title and survey work.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rearSetbackFt rdf:type rdf:Property ;
    rdfs:label 'Rear Setback Ft' ;
    rdfs:comment 'Minimum required rear setback distance in feet from the rear property line to the building, as mandated by local zoning regulations.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sideSetbackFt rdf:type rdf:Property ;
    rdfs:label 'Side Setback Ft' ;
    rdfs:comment 'Minimum required side setback distance in feet from the side property line to the building, as mandated by local zoning regulations.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soilClassification rdf:type rdf:Property ;
    rdfs:label 'Soil Classification' ;
    rdfs:comment 'Soil type classification for the parcel as determined by geotechnical survey or USDA Natural Resources Conservation Service (NRCS) soil survey data (e.g., Class I, Class II, expansive clay, sandy loam). Relevant for construction feasibility, agricultural use, and environmental assessment.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subdivisionName rdf:type rdf:Property ;
    rdfs:label 'Subdivision Name' ;
    rdfs:comment 'Name of the recorded subdivision or plat in which the parcel is located (e.g., \'Oakwood Business Park Phase II\'). Used for lot-and-block legal descriptions and development project tracking in Procore.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:titleReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Title Reference Number' ;
    rdfs:comment 'Title or deed reference number as recorded with the county recorder or land registry. Links the parcel to its chain of title and is required for ALTA title insurance and ownership verification.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:askingRentPsf rdf:type rdf:Property ;
    rdfs:label 'Asking Rent Psf' ;
    rdfs:comment 'Current listed asking rent for the unit expressed as an annual rate per square foot (PSF). Used in leasing negotiations, broker marketing, and MLS/CoStar syndication.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableDate rdf:type rdf:Property ;
    rdfs:label 'Available Date' ;
    rdfs:comment 'The date on which the unit is or will be available for leasing or sale. Drives vacancy reporting, leasing pipeline prioritization, and revenue forecasting in Argus Enterprise.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bathroomCount rdf:type rdf:Property ;
    rdfs:label 'Bathroom Count' ;
    rdfs:comment 'Number of bathrooms in the unit, expressed as a decimal to accommodate half-baths (e.g., 1.5, 2.0). Standard residential listing attribute per RESO Data Dictionary.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bedroomCount rdf:type rdf:Property ;
    rdfs:label 'Bedroom Count' ;
    rdfs:comment 'Number of bedrooms in the unit. Applicable to residential units (apartments, condominiums). Used for MLS listing, rent benchmarking, and residential portfolio segmentation.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bimReference rdf:type rdf:Property ;
    rdfs:label 'Bim Reference' ;
    rdfs:comment 'Reference identifier linking this unit to its corresponding object in the Building Information Modeling (BIM) system (e.g., Procore or Revit model GUID). Enables digital twin integration and construction-to-operations handover.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:camEligible rdf:type rdf:Property ;
    rdfs:label 'Cam Eligible' ;
    rdfs:comment 'Indicates whether the unit is subject to Common Area Maintenance (CAM) charge recovery. Drives operating expense billing setup in Yardi Voyager and MRI Software.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:configuration rdf:type rdf:Property ;
    rdfs:label 'Configuration' ;
    rdfs:comment 'Physical layout configuration of the unit interior. Relevant for office and commercial leasing where tenant fit-out requirements vary by configuration type.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructionYear rdf:type rdf:Property ;
    rdfs:label 'Construction Year' ;
    rdfs:comment 'The year in which the unit was originally constructed. Used for depreciation calculations, building age analysis, and capital planning under FASB ASC 840/842.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cooIssueDate rdf:type rdf:Property ;
    rdfs:label 'Coo Issue Date' ;
    rdfs:comment 'The date on which the Certificate of Occupancy (COO) was issued for this unit by the relevant municipal authority. Required for compliance documentation and leasing eligibility verification.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:efficiencyRatio rdf:type rdf:Property ;
    rdfs:label 'Efficiency Ratio' ;
    rdfs:comment 'Ratio of usable area to rentable area (usable_area_sqf / rentable_area_sqf). Indicates how much of the rented space is directly usable by the tenant. A key metric in office leasing and space planning.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyRating rdf:type rdf:Property ;
    rdfs:label 'Energy Rating' ;
    rdfs:comment 'Energy Performance Certificate (EPC) rating for the unit, ranging from A (most efficient) to G (least efficient). Required for regulatory compliance in many jurisdictions and ESG portfolio reporting.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasBalcony rdf:type rdf:Property ;
    rdfs:label 'Has Balcony' ;
    rdfs:comment 'Indicates whether the unit includes a private balcony or patio. Used in residential marketing, rent premium analysis, and amenity-based comparables.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hvacZone rdf:type rdf:Property ;
    rdfs:label 'Hvac Zone' ;
    rdfs:comment 'The HVAC zone designation for this unit within the building\'s mechanical system. Used for facility operations, energy management, and service request routing in Building Engines.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internetConnectivity rdf:type rdf:Property ;
    rdfs:label 'Internet Connectivity' ;
    rdfs:comment 'Type of internet connectivity infrastructure available in the unit. Increasingly a key leasing criterion for commercial and residential tenants; tracked for marketing and tenant amenity reporting.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFurnished rdf:type rdf:Property ;
    rdfs:label 'Is Furnished' ;
    rdfs:comment 'Indicates whether the unit is offered with furniture included. Relevant for short-term residential leasing, corporate housing, and serviced apartment inventory.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRenovatedDate rdf:type rdf:Property ;
    rdfs:label 'Last Renovated Date' ;
    rdfs:comment 'The date on which the unit was most recently renovated or refurbished. Used for capital expenditure (CAPEX) planning, asset condition assessment, and maintenance scheduling.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseTypeEligibility rdf:type rdf:Property ;
    rdfs:label 'Lease Type Eligibility' ;
    rdfs:comment 'The lease structure(s) for which this unit is eligible, such as Gross, Triple Net (NNN), Modified Gross, or Full Service Gross (FSG). Drives lease template selection and operating expense recovery modeling. [ENUM-REF-CANDIDATE: gross|NNN|modified_gross|FSG|double_net|ground_lease — promote to reference product]' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketRentPsf rdf:type rdf:Property ;
    rdfs:label 'Market Rent Psf' ;
    rdfs:comment 'Estimated market rent for the unit per square foot (PSF) based on comparable market analysis (CMA) and CoStar benchmarking. Used for Argus Enterprise DCF modeling, NAV calculations, and asset management reporting.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxOccupancy rdf:type rdf:Property ;
    rdfs:label 'Max Occupancy' ;
    rdfs:comment 'Maximum number of occupants permitted in the unit as specified by the Certificate of Occupancy (COO) or local building code. Used for compliance monitoring and lease clause enforcement.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:meteringType rdf:type rdf:Property ;
    rdfs:label 'Metering Type' ;
    rdfs:comment 'Indicates how utilities (electricity, gas, water) are metered for this unit. Drives utility billing setup, CAM reconciliation, and ESG energy consumption reporting.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mriUnitCode rdf:type rdf:Property ;
    rdfs:label 'Mri Unit Code' ;
    rdfs:comment 'The unit\'s native identifier in MRI Software, used for residential management and investment accounting. Supports cross-system reconciliation for mixed-use portfolios.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parkingSpaces rdf:type rdf:Property ;
    rdfs:label 'Parking Spaces' ;
    rdfs:comment 'Number of dedicated parking spaces allocated to this unit. Used in lease administration, tenant onboarding, and parking revenue management.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rentableAreaSqf rdf:type rdf:Property ;
    rdfs:label 'Rentable Area Sqf' ;
    rdfs:comment 'Total rentable area of the unit measured in square feet (SQF) per BOMA/RESO standards. Used as the basis for rent calculation (PSF), CAM charge proration, and GLA/NLA portfolio reporting.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rentableAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Rentable Area Sqm' ;
    rdfs:comment 'Total rentable area of the unit measured in square meters (SQM). Required for international portfolio reporting, IFRS 16 compliance, and cross-border investment analysis.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitNumber rdf:type rdf:Property ;
    rdfs:label 'Unit Number' ;
    rdfs:comment 'Human-readable alphanumeric identifier for the unit as displayed on signage, lease documents, and tenant correspondence (e.g., \'101\', \'Suite 2A\', \'Bay 5\'). Sourced from Yardi Voyager unit master.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitStatus rdf:type rdf:Property ;
    rdfs:label 'Unit Status' ;
    rdfs:comment 'Current operational lifecycle state of the unit. Drives vacancy reporting, leasing pipeline management, and NOI forecasting. \'offline\' indicates the unit is temporarily removed from leasable inventory.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitType rdf:type rdf:Property ;
    rdfs:label 'Unit Type' ;
    rdfs:comment 'Classification of the unit by its intended use and configuration. Drives lease template selection, rent benchmarking, and portfolio segmentation. [ENUM-REF-CANDIDATE: studio|1BR|2BR|3BR|penthouse|office_suite|retail_bay|industrial_bay|storage|mixed_use|other — promote to reference product]' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewType rdf:type rdf:Property ;
    rdfs:label 'View Type' ;
    rdfs:comment 'Classification of the primary view from the unit. Influences premium pricing, marketing positioning, and tenant preference scoring in CRM systems.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yardiUnitCode rdf:type rdf:Property ;
    rdfs:label 'Yardi Unit Code' ;
    rdfs:comment 'The unit\'s native identifier in Yardi Voyager, the system of record for property management and lease administration. Used for data lineage, system reconciliation, and integration with AR/AP workflows.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spaceId rdf:type rdf:Property ;
    rdfs:label 'Space Id' ;
    rdfs:comment 'Primary key for space' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Space .

ind:spaceSuiteUnitId rdf:type rdf:Property ;
    rdfs:label 'Space Suite Unit Id' ;
    rdfs:comment 'Reference to the suite or demised premises to which this space belongs. Enables grouping of individual spaces into a leasable suite for lease administration in Yardi Voyager.' ;
    rdfs:domain ind:Space ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:spaceUnitId rdf:type rdf:Property ;
    rdfs:label 'Space Unit Id' ;
    rdfs:comment 'Foreign key linking to property.unit. Business justification: Space is described as a sub-unit space within a building, supporting multi-tenant floor configurations and co-working arrangements. A space can be a subdivision of a leasable unit (e.g., a suite subdi' ;
    rdfs:domain ind:Space ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:accessibilityCompliant rdf:type rdf:Property ;
    rdfs:label 'Accessibility Compliant' ;
    rdfs:comment 'Indicates whether the space meets Americans with Disabilities Act (ADA) or equivalent accessibility standards. Required for regulatory compliance reporting, COO issuance, and HUD-related affordable housing programs.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bimElementCode rdf:type rdf:Property ;
    rdfs:label 'Bim Element Code' ;
    rdfs:comment 'Unique element identifier from the Building Information Modeling (BIM) model corresponding to this space. Enables integration between the data lakehouse and BIM authoring tools (e.g., Revit) via Procore for construction and facility management workflows.' ;
    rdfs:domain ind:Space ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingEnginesSpaceCode rdf:type rdf:Property ;
    rdfs:label 'Building Engines Space Code' ;
    rdfs:comment 'Space identifier as recorded in Building Engines facility operations platform. Used to link work orders, tenant service requests, and preventive maintenance schedules to the correct physical space.' ;
    rdfs:domain ind:Space ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:camAreaSqf rdf:type rdf:Property ;
    rdfs:label 'Cam Area Sqf' ;
    rdfs:comment 'Square footage of this space that is allocated to the CAM pool. May differ from total rentable area when only a portion of the space is CAM-eligible (e.g., a partially shared corridor). Used in CAM charge calculations and annual CAM reconciliation.' ;
    rdfs:domain ind:Space ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ceilingHeightFt rdf:type rdf:Property ;
    rdfs:label 'Ceiling Height Ft' ;
    rdfs:comment 'Clear ceiling height of the space measured in feet from finished floor to finished ceiling. A key physical specification influencing tenant suitability (e.g., data centers require raised floors and high ceilings), TI design, and HVAC system sizing.' ;
    rdfs:domain ind:Space ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:condition rdf:type rdf:Property ;
    rdfs:label 'Condition' ;
    rdfs:comment 'Physical condition and fit-out state of the space at the time of listing or inspection. \'Shell\' = bare concrete/structure only; \'Warm Shell\' = HVAC and electrical roughed in; \'Plug and Play\' = fully furnished and wired; \'Full Fit Out\' = custom tenant improvements complete; \'As Is\' = existing condition without landlord work.' ;
    rdfs:domain ind:Space ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveRentPsf rdf:type rdf:Property ;
    rdfs:label 'Effective Rent Psf' ;
    rdfs:comment 'Net effective rent per square foot after accounting for free rent periods, TI allowances, and other concessions. Used in Argus Enterprise cash flow modeling and investment analysis to reflect true economic rent versus face rent.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:electricalCapacityAmps rdf:type rdf:Property ;
    rdfs:label 'Electrical Capacity Amps' ;
    rdfs:comment 'Dedicated electrical capacity allocated to this space in amperes. Critical for tenant fit-out planning, data center and lab space leasing, and building infrastructure load management.' ;
    rdfs:domain ind:Space ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyStarEligible rdf:type rdf:Property ;
    rdfs:label 'Energy Star Eligible' ;
    rdfs:comment 'Indicates whether this space qualifies for ENERGY STAR certification based on energy performance benchmarks. Supports ESG reporting, green lease provisions, and EPA ENERGY STAR portfolio benchmarking.' ;
    rdfs:domain ind:Space ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:floorPlanReference rdf:type rdf:Property ;
    rdfs:label 'Floor Plan Reference' ;
    rdfs:comment 'Document reference or URL pointing to the architectural floor plan drawing for this space, typically stored in Procore or a document management system. Supports TI space planning, BIM coordination, and tenant improvement design reviews.' ;
    rdfs:domain ind:Space ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isContiguous rdf:type rdf:Property ;
    rdfs:label 'Is Contiguous' ;
    rdfs:comment 'Indicates whether this space is physically contiguous with adjacent spaces, enabling combination into a larger demised unit for a single tenant. Critical for large-block leasing strategies and tenant expansion rights.' ;
    rdfs:domain ind:Space ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSubdivisible rdf:type rdf:Property ;
    rdfs:label 'Is Subdivisible' ;
    rdfs:comment 'Indicates whether this space can be physically subdivided into smaller demised units to accommodate multiple tenants or co-working configurations. Supports leasing flexibility analysis and TI space planning.' ;
    rdfs:domain ind:Space ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastOccupiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Occupied Date' ;
    rdfs:comment 'Date on which the most recent tenant vacated or the space was last in active occupancy. Used to calculate vacancy duration, assess market re-leasing timelines, and trigger preventive maintenance inspections in Building Engines.' ;
    rdfs:domain ind:Space ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leedCertificationLevel rdf:type rdf:Property ;
    rdfs:label 'Leed Certification Level' ;
    rdfs:comment 'LEED certification level applicable to this space or the building section it occupies, as awarded by the U.S. Green Building Council (USGBC). Drives ESG reporting, green premium rent analysis, and sustainability compliance disclosures for publicly traded REITs.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occupancyClass rdf:type rdf:Property ;
    rdfs:label 'Occupancy Class' ;
    rdfs:comment 'Building quality classification of the space (Class A, B, or C) per BOMA/CoStar standards. Influences asking rent benchmarks, tenant profile targeting, and portfolio reporting in CoStar Suite and Argus Enterprise.' ;
    rdfs:domain ind:Space ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spaceName rdf:type rdf:Property ;
    rdfs:label 'Space Name' ;
    rdfs:comment 'Descriptive human-readable name for the space (e.g., \'Executive Conference Room\', \'North Lobby\', \'Parking Bay 12\'). Used in tenant communications, floor plan references, and facility operations.' ;
    rdfs:domain ind:Space ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spaceNumber rdf:type rdf:Property ;
    rdfs:label 'Space Number' ;
    rdfs:comment 'Alphanumeric identifier assigned to the space within the building, as recorded in Yardi Voyager and Building Engines (e.g., \'101A\', \'B-204\', \'LOBBY-1\'). Used for physical wayfinding, work order routing, and tenant service requests.' ;
    rdfs:domain ind:Space ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spaceType rdf:type rdf:Property ;
    rdfs:label 'Space Type' ;
    rdfs:comment 'Categorical classification of the space\'s functional use within the building. Drives CAM eligibility, GLA/NLA inclusion rules, and TI planning. [ENUM-REF-CANDIDATE: private_office|conference_room|common_corridor|lobby|mechanical_room|parking_bay|storage|retail_unit|coworking_bay|restroom — promote to reference product]' ;
    rdfs:domain ind:Space ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usableAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Usable Area Sqm' ;
    rdfs:comment 'Usable area of the space in square meters. Used for international lease administration, IFRS 16 right-of-use asset calculations, and cross-border portfolio benchmarking.' ;
    rdfs:domain ind:Space ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yardiSpaceCode rdf:type rdf:Property ;
    rdfs:label 'Yardi Space Code' ;
    rdfs:comment 'Native space identifier as assigned in Yardi Voyager Property Management system. Used for system-of-record reconciliation, data lineage tracking, and integration with Yardi AR/AP and lease administration modules.' ;
    rdfs:domain ind:Space ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressSource rdf:type rdf:Property ;
    rdfs:label 'Address Source' ;
    rdfs:comment 'Operational system of record from which this address record was originally sourced or last updated. Supports data lineage tracking, conflict resolution during ETL, and audit trail requirements. Values correspond to enterprise operational systems. [ENUM-REF-CANDIDATE: yardi|mri|costar|manual|usps|gis|procore — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressType rdf:type rdf:Property ;
    rdfs:label 'Address Type' ;
    rdfs:comment 'Classification of the address purpose within the enterprise. Primary indicates the main physical address; mailing is the postal delivery address; legal is the address of record for title and regulatory filings; billing is used for invoicing; secondary captures additional frontages for corner properties.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierRoute rdf:type rdf:Property ;
    rdfs:label 'Carrier Route' ;
    rdfs:comment 'USPS carrier route code identifying the specific mail carrier delivery route for the address. Used for bulk mail processing, address quality validation, and USPS CASS (Coding Accuracy Support System) certification.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:censusTract rdf:type rdf:Property ;
    rdfs:label 'Census Tract' ;
    rdfs:comment 'U.S. Census Bureau census tract code for the address location. Used for HUD regulatory reporting, Community Reinvestment Act (CRA) compliance, demographic analysis, and opportunity zone identification for tax-advantaged investment reporting.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:congressionalDistrict rdf:type rdf:Property ;
    rdfs:label 'Congressional District' ;
    rdfs:comment 'U.S. Congressional district designation for the address location. Used for government affairs tracking, lobbying activity reporting, and compliance with federal housing and development programs administered at the district level.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:county rdf:type rdf:Property ;
    rdfs:label 'County' ;
    rdfs:comment 'County or parish name in which the property is located. Required for property tax assessment, title searches, and regulatory compliance reporting to HUD and local jurisdictions.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPointBarcode rdf:type rdf:Property ;
    rdfs:label 'Delivery Point Barcode' ;
    rdfs:comment 'USPS-assigned Delivery Point Barcode (DPBC) for the address, consisting of the ZIP+4 code plus a two-digit delivery point code. Confirms mail deliverability and is used for bulk mail operations and address quality scoring.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floodZoneCode rdf:type rdf:Property ;
    rdfs:label 'Flood Zone Code' ;
    rdfs:comment 'FEMA National Flood Insurance Program (NFIP) flood zone designation for the address (e.g., AE, X, VE). Required for property insurance underwriting, lender due diligence, environmental compliance reporting, and disclosure obligations under HUD and EPA regulations.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geocodeAccuracy rdf:type rdf:Property ;
    rdfs:label 'Geocode Accuracy' ;
    rdfs:comment 'Precision level of the geocoded latitude/longitude coordinates. Rooftop indicates exact building-level precision; parcel_centroid is parcel-level; street_interpolated is estimated from street range; zip_centroid and city_centroid are approximate. Critical for GIS analysis quality assessment.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geocodeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Geocode Timestamp' ;
    rdfs:comment 'Date and time when the latitude and longitude coordinates were last geocoded or re-geocoded for this address. Supports GIS data freshness monitoring and triggers re-geocoding workflows when coordinates are stale relative to address changes.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:line1 rdf:type rdf:Property ;
    rdfs:label 'Line 1' ;
    rdfs:comment 'Primary street address line including house/building number and street name. Represents the first line of the standardized postal address as defined by USPS or local postal authority. Sourced from Yardi Voyager property address fields.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line2 rdf:type rdf:Property ;
    rdfs:label 'Line 2' ;
    rdfs:comment 'Secondary address line capturing suite, floor, unit, building name, or additional directional information not captured in address line 1. Common for multi-tenant commercial buildings with multiple street frontages or suite designations.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msaCode rdf:type rdf:Property ;
    rdfs:label 'Msa Code' ;
    rdfs:comment 'U.S. Office of Management and Budget (OMB) five-digit code identifying the Metropolitan Statistical Area (MSA) in which the property is located. Used for market-level performance benchmarking, CoStar market analytics, and investment portfolio geographic classification.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:neighborhoodName rdf:type rdf:Property ;
    rdfs:label 'Neighborhood Name' ;
    rdfs:comment 'Recognized neighborhood or district name within the city or submarket (e.g., SoHo, Buckhead, River North). Supports hyper-local market analysis, tenant demand mapping, and broker price opinion (BPO) comparables selection.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityZoneFlag rdf:type rdf:Property ;
    rdfs:label 'Opportunity Zone Flag' ;
    rdfs:comment 'Indicates whether the address falls within a federally designated Qualified Opportunity Zone (QOZ) as defined under the Tax Cuts and Jobs Act of 2017. True enables investment advisory teams to identify tax-advantaged investment opportunities and report to investors on QOZ portfolio exposure.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plus4Code rdf:type rdf:Property ;
    rdfs:label 'Plus4 Code' ;
    rdfs:comment 'Four-digit USPS ZIP+4 extension code that narrows the delivery area to a specific block face, building, or floor. Enhances address precision for mail delivery and is required for USPS bulk mailing discounts and DPV validation.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxParcelNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Parcel Number' ;
    rdfs:comment 'Assessor\'s Parcel Number (APN) or tax parcel identification number assigned by the county assessor\'s office. Links the address to property tax records, title searches, and ALTA surveys. Used in Yardi Voyager fixed asset and property tax modules.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitScore rdf:type rdf:Property ;
    rdfs:label 'Transit Score' ;
    rdfs:comment 'Transit Score rating (0–100) for the address location measuring access to public transportation. Used in tenant demand analysis, property valuation inputs, and ESG reporting on sustainable location attributes for LEED and BREEAM certifications.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uspsStandardized rdf:type rdf:Property ;
    rdfs:label 'Usps Standardized' ;
    rdfs:comment 'Indicates whether the address has been standardized according to USPS Publication 28 postal addressing standards. True means the address conforms to USPS format and has passed DPV validation. Used for mail deliverability and regulatory reporting quality assurance.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Current USPS or third-party address standardization and validation status. Validated indicates the address has been confirmed against the USPS Delivery Point Validation (DPV) database. Failed indicates the address could not be matched. Corrected indicates the address was auto-corrected during standardization.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validation Timestamp' ;
    rdfs:comment 'Date and time when this address was last validated or re-validated against USPS DPV or a third-party address verification service. Used to assess address data freshness and trigger re-validation workflows when the timestamp exceeds a defined staleness threshold.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:walkScore rdf:type rdf:Property ;
    rdfs:label 'Walk Score' ;
    rdfs:comment 'Walk Score rating (0–100) for the address location measuring pedestrian accessibility to amenities. Used in tenant demand analysis, property marketing, and investment advisory scoring for commercial and residential assets. Sourced from Walk Score API or CoStar.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:zoningJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Zoning Jurisdiction' ;
    rdfs:comment 'Name of the local government authority (municipality, county, or special district) with zoning jurisdiction over the address. Critical for development feasibility, permitting, and regulatory compliance tracking in Procore and SAP S/4HANA project systems.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocatedDebtAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Debt Amount' ;
    rdfs:comment 'The portion of property-level debt (mortgage, CMBS, or other financing) allocated to this ownership interest based on the ownership percentage. Used for Loan-to-Value (LTV) ratio calculations and Debt Service Coverage Ratio (DSCR) reporting in Argus Enterprise.' ;
    rdfs:domain ind:PropertyOwnershipInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deedReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Deed Reference Number' ;
    rdfs:comment 'The recorded deed book and page number or instrument number from the county recorder\'s office that evidences this ownership interest. Critical for title chain of custody and legal due diligence.' ;
    rdfs:domain ind:PropertyOwnershipInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionPriority rdf:type rdf:Property ;
    rdfs:label 'Distribution Priority' ;
    rdfs:comment 'The numeric priority rank of this ownership interest in the waterfall distribution structure (1 = highest priority). Determines the order in which distributions are made among multiple interest holders in joint ventures and fund structures.' ;
    rdfs:domain ind:PropertyOwnershipInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:encumbranceDescription rdf:type rdf:Property ;
    rdfs:label 'Encumbrance Description' ;
    rdfs:comment 'Narrative description of any liens, mortgages, easements, covenants, or other encumbrances affecting this ownership interest. Sourced from ALTA title search results and legal due diligence documentation.' ;
    rdfs:domain ind:PropertyOwnershipInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equityContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Equity Contribution Amount' ;
    rdfs:comment 'The total equity capital contributed by the owner entity for this ownership interest, net of debt financing. Used for Return on Investment (ROI), Internal Rate of Return (IRR), and Net Asset Value (NAV) calculations in Argus Enterprise and MRI Software.' ;
    rdfs:domain ind:PropertyOwnershipInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isControllingInterest rdf:type rdf:Property ;
    rdfs:label 'Is Controlling Interest' ;
    rdfs:comment 'Indicates whether this ownership interest constitutes a controlling interest in the property or owning entity, triggering consolidation requirements under FASB ASC 810. True if controlling; False if non-controlling (minority interest).' ;
    rdfs:domain ind:PropertyOwnershipInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isManagingMember rdf:type rdf:Property ;
    rdfs:label 'Is Managing Member' ;
    rdfs:comment 'Indicates whether the owner entity holding this interest serves as the managing member or general partner of the ownership structure, with authority over day-to-day property management decisions.' ;
    rdfs:domain ind:PropertyOwnershipInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownershipNotes rdf:type rdf:Property ;
    rdfs:label 'Ownership Notes' ;
    rdfs:comment 'Free-text field for additional context, legal annotations, or special conditions associated with this ownership interest record, such as pending litigation, regulatory restrictions, or investor-specific terms not captured in structured fields.' ;
    rdfs:domain ind:PropertyOwnershipInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipStatus rdf:type rdf:Property ;
    rdfs:label 'Ownership Status' ;
    rdfs:comment 'Current lifecycle status of the ownership interest record. Active indicates the interest is currently held; transferred indicates the interest has been conveyed to another party; dissolved indicates the owning entity has been wound down; pending indicates a transaction in progress; encumbered indicates the interest is subject to a lien or restriction.' ;
    rdfs:domain ind:PropertyOwnershipInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipStructure rdf:type rdf:Property ;
    rdfs:label 'Ownership Structure' ;
    rdfs:comment 'The legal and organizational structure under which the ownership interest is held. Supports complex arrangements including joint ventures (JV), tenancy-in-common (TIC), Real Estate Investment Trust (REIT) structures, and fund ownership. [ENUM-REF-CANDIDATE: sole_ownership|joint_venture|tic|reit|fund|partnership|trust — promote to reference product]' ;
    rdfs:domain ind:PropertyOwnershipInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordingJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Recording Jurisdiction' ;
    rdfs:comment 'The county, parish, or municipality where the deed or title instrument for this ownership interest is recorded. Determines applicable property law, transfer taxes, and regulatory reporting requirements.' ;
    rdfs:domain ind:PropertyOwnershipInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sndaStatus rdf:type rdf:Property ;
    rdfs:label 'Snda Status' ;
    rdfs:comment 'The execution status of the Subordination Non-Disturbance and Attornment Agreement (SNDA) associated with this ownership interest, which governs the relationship between the lender, owner, and tenants in the event of foreclosure.' ;
    rdfs:domain ind:PropertyOwnershipInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:titleCompanyName rdf:type rdf:Property ;
    rdfs:label 'Title Company Name' ;
    rdfs:comment 'The name of the title insurance company that issued the title policy for this ownership interest. Used for title claim escalation and due diligence tracking.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:titlePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Title Policy Number' ;
    rdfs:comment 'The policy number of the title insurance policy issued by the title company at the time of acquisition, as referenced in ALTA title commitments. Used for title claim management and due diligence.' ;
    rdfs:domain ind:PropertyOwnershipInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:titleVestingLanguage rdf:type rdf:Property ;
    rdfs:label 'Title Vesting Language' ;
    rdfs:comment 'The exact legal language used in the deed or title instrument to describe how title is vested in the owner entity (e.g., \'as joint tenants with right of survivorship\', \'as tenants in common\'). Sourced from ALTA title commitments and closing documents managed in DocuSign CLM.' ;
    rdfs:domain ind:PropertyOwnershipInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Transfer Restriction Flag' ;
    rdfs:comment 'Indicates whether this ownership interest is subject to transfer restrictions, right of first refusal (ROFR), or lock-up provisions that limit the owner\'s ability to sell or assign the interest. True if restricted; False if freely transferable.' ;
    rdfs:domain ind:PropertyOwnershipInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:votingRightsPercentage rdf:type rdf:Property ;
    rdfs:label 'Voting Rights Percentage' ;
    rdfs:comment 'The percentage of voting rights held by this ownership interest, which may differ from the economic ownership percentage in certain joint venture or preferred equity structures. Used for consolidation analysis under FASB ASC 810.' ;
    rdfs:domain ind:PropertyOwnershipInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chainOfTitleNotes rdf:type rdf:Property ;
    rdfs:label 'Chain Of Title Notes' ;
    rdfs:comment 'Free-text narrative summarizing the historical sequence of ownership transfers and any notable gaps, breaks, or anomalies identified in the chain of title examination. Critical for transaction due diligence.' ;
    rdfs:domain ind:TitleRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deedBook rdf:type rdf:Property ;
    rdfs:label 'Deed Book' ;
    rdfs:comment 'Official deed book number or volume identifier as recorded in the county recorder\'s office. Used in conjunction with deed_page to locate the physical or digital deed instrument in public records.' ;
    rdfs:domain ind:TitleRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deedPage rdf:type rdf:Property ;
    rdfs:label 'Deed Page' ;
    rdfs:comment 'Official deed page number within the deed book as recorded in the county recorder\'s office. Combined with deed_book provides the precise public record locator for the deed instrument.' ;
    rdfs:domain ind:TitleRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encumbranceGrantee rdf:type rdf:Property ;
    rdfs:label 'Encumbrance Grantee' ;
    rdfs:comment 'Legal name of the party receiving the benefit of the encumbrance (e.g., lender receiving a mortgage lien, utility company receiving an easement). Used for lien holder identification and release coordination.' ;
    rdfs:domain ind:TitleRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encumbranceGrantor rdf:type rdf:Property ;
    rdfs:label 'Encumbrance Grantor' ;
    rdfs:comment 'Legal name of the party granting the encumbrance (e.g., property owner granting an easement, borrower granting a mortgage lien). Used for due diligence and lien release tracking.' ;
    rdfs:domain ind:TitleRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encumbranceMaturityDate rdf:type rdf:Property ;
    rdfs:label 'Encumbrance Maturity Date' ;
    rdfs:comment 'Date on which the encumbrance is scheduled to mature or expire by its own terms (e.g., loan maturity date for a mortgage lien, expiration date for a temporary easement). Null for perpetual encumbrances.' ;
    rdfs:domain ind:TitleRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:encumbranceRecordingDate rdf:type rdf:Property ;
    rdfs:label 'Encumbrance Recording Date' ;
    rdfs:comment 'Date on which the encumbrance instrument was officially recorded with the county recorder. Establishes the legal priority position of the encumbrance relative to other recorded interests.' ;
    rdfs:domain ind:TitleRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:encumbranceRecordingNumber rdf:type rdf:Property ;
    rdfs:label 'Encumbrance Recording Number' ;
    rdfs:comment 'Official instrument number assigned by the county recorder when the encumbrance instrument (lien, easement, restriction) was recorded. Used to locate the encumbrance in public records.' ;
    rdfs:domain ind:TitleRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encumbranceReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Encumbrance Release Date' ;
    rdfs:comment 'Date on which the encumbrance was formally released, discharged, or satisfied and the release instrument was recorded. Null if the encumbrance remains active. Used to confirm clear title status.' ;
    rdfs:domain ind:TitleRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:encumbranceStatus rdf:type rdf:Property ;
    rdfs:label 'Encumbrance Status' ;
    rdfs:comment 'Current status of the encumbrance recorded against the property title. Active indicates the encumbrance is in force; released indicates it has been formally discharged; expired indicates it lapsed by its own terms; disputed indicates it is subject to legal challenge.' ;
    rdfs:domain ind:TitleRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalLienFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Lien Flag' ;
    rdfs:comment 'Indicates whether an environmental lien or notice of environmental action has been recorded against the property by the EPA or a state environmental agency. Critical for acquisition due diligence and ESG compliance.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grantorName rdf:type rdf:Property ;
    rdfs:label 'Grantor Name' ;
    rdfs:comment 'Legal name of the party conveying title (seller or transferor) as recorded on the deed instrument. Critical for chain of title verification and due diligence.' ;
    rdfs:domain ind:TitleRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lisPendensFlag rdf:type rdf:Property ;
    rdfs:label 'Lis Pendens Flag' ;
    rdfs:comment 'Indicates whether a lis pendens (notice of pending litigation) has been recorded against the property. A lis pendens clouds title and must be resolved prior to any sale or refinancing.' ;
    rdfs:domain ind:TitleRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policyAmount rdf:type rdf:Property ;
    rdfs:label 'Policy Amount' ;
    rdfs:comment 'Dollar amount of coverage provided under the title insurance policy, typically equal to the purchase price (owner\'s policy) or loan amount (lender\'s policy). Expressed in USD.' ;
    rdfs:domain ind:TitleRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:policyEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Policy Effective Date' ;
    rdfs:comment 'Date on which the title insurance policy became effective, typically the date of closing or recording. Establishes the coverage commencement date for claims purposes.' ;
    rdfs:domain ind:TitleRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:policyExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Policy Expiry Date' ;
    rdfs:comment 'Date on which the title insurance policy expires or is no longer in force. Null for perpetual owner\'s policies. Populated for lender policies tied to loan maturity.' ;
    rdfs:domain ind:TitleRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:policyNumber rdf:type rdf:Property ;
    rdfs:label 'Policy Number' ;
    rdfs:comment 'Unique policy number assigned by the title insurance company for the title insurance policy covering this property. Used for claims filing, policy retrieval, and underwriting reference.' ;
    rdfs:domain ind:TitleRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyType rdf:type rdf:Property ;
    rdfs:label 'Policy Type' ;
    rdfs:comment 'Classification of the title insurance policy per American Land Title Association (ALTA) standards. Distinguishes between owner\'s policies protecting the buyer and lender\'s policies protecting the mortgagee.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityPosition rdf:type rdf:Property ;
    rdfs:label 'Priority Position' ;
    rdfs:comment 'Numeric lien priority position of the encumbrance relative to other recorded interests on the property (e.g., 1 = first lien, 2 = second lien). Determines payment order in foreclosure or disposition proceedings.' ;
    rdfs:domain ind:TitleRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recordingNumber rdf:type rdf:Property ;
    rdfs:label 'Recording Number' ;
    rdfs:comment 'Official instrument or document number assigned by the county recorder at the time of deed recordation. Unique identifier within the recorder\'s jurisdiction for this recorded instrument.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sndaOnFile rdf:type rdf:Property ;
    rdfs:label 'Snda On File' ;
    rdfs:comment 'Indicates whether a Subordination Non-Disturbance and Attornment Agreement (SNDA) has been executed and is on file for this property. Critical for lender underwriting and tenant protection in leveraged assets.' ;
    rdfs:domain ind:TitleRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surveyDate rdf:type rdf:Property ;
    rdfs:label 'Survey Date' ;
    rdfs:comment 'Date of the most recent ALTA/NSPS land title survey conducted for the property. Used to assess the currency of boundary and encumbrance information relative to current conditions.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surveyOnFile rdf:type rdf:Property ;
    rdfs:label 'Survey On File' ;
    rdfs:comment 'Indicates whether a current ALTA/NSPS land title survey is on file for this property. Surveys are required for commercial transactions and lender underwriting to identify boundary issues, encroachments, and easement locations.' ;
    rdfs:domain ind:TitleRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:titleCompany rdf:type rdf:Property ;
    rdfs:label 'Title Company' ;
    rdfs:comment 'Name of the title insurance company that issued the title insurance policy for this property. Used for claims management, underwriting reference, and vendor relationship tracking.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:titleExaminationDate rdf:type rdf:Property ;
    rdfs:label 'Title Examination Date' ;
    rdfs:comment 'Date on which the most recent title examination or title search was completed by the title company or attorney. Indicates the currency of the title status and chain of title review.' ;
    rdfs:domain ind:TitleRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:titleExaminer rdf:type rdf:Property ;
    rdfs:label 'Title Examiner' ;
    rdfs:comment 'Name of the attorney, title officer, or title company representative who conducted the most recent title examination. Used for accountability and follow-up on title defects.' ;
    rdfs:domain ind:TitleRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:titleNumber rdf:type rdf:Property ;
    rdfs:label 'Title Number' ;
    rdfs:comment 'Externally assigned title or certificate number issued by the county recorder or land registry authority. Serves as the official public record identifier for this title.' ;
    rdfs:domain ind:TitleRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:titleOpinionOnFile rdf:type rdf:Property ;
    rdfs:label 'Title Opinion On File' ;
    rdfs:comment 'Indicates whether a formal attorney\'s title opinion letter is on file for this property. Title opinions are required by certain lenders and in states where attorney title opinions substitute for title insurance.' ;
    rdfs:domain ind:TitleRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:titleStatus rdf:type rdf:Property ;
    rdfs:label 'Title Status' ;
    rdfs:comment 'Current status of the title indicating whether ownership is unencumbered and marketable. Values: clear (no outstanding encumbrances), encumbered (active liens or restrictions), in_dispute (ownership contested), pending_release (encumbrance release in process), under_review (title examination ongoing).' ;
    rdfs:domain ind:TitleRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionId rdf:type rdf:Property ;
    rdfs:label 'Inspection Id' ;
    rdfs:comment 'Primary key for inspection' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessRestrictions rdf:type rdf:Property ;
    rdfs:label 'Access Restrictions' ;
    rdfs:comment 'Free-text description of any areas, systems, or components that were inaccessible during the inspection and therefore excluded from the assessment. Required per ASTM E2018 to document inspection limitations and scope exclusions.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDueDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Due Date' ;
    rdfs:comment 'Deadline by which the inspection must be completed or deficiencies remediated to maintain regulatory compliance. Distinct from scheduled_date — this is the hard regulatory deadline, not the planned inspection date.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:endTime rdf:type rdf:Property ;
    rdfs:label 'End Time' ;
    rdfs:comment 'Precise date and time when the physical inspection was concluded on-site. Used together with inspection_start_time to compute inspection duration for billing and performance analytics.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:environmentalPhase rdf:type rdf:Property ;
    rdfs:label 'Environmental Phase' ;
    rdfs:comment 'For environmental inspections, identifies the ASTM Phase I, II, or III Environmental Site Assessment (ESA) stage. Phase I is a records review, Phase II involves physical sampling, Phase III is remediation. Not applicable for non-environmental inspection types.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasCriticalDeficiency rdf:type rdf:Property ;
    rdfs:label 'Has Critical Deficiency' ;
    rdfs:comment 'Boolean flag indicating whether the inspection identified at least one critical deficiency requiring immediate attention. True when critical_deficiency_count > 0. Used as a quick filter for escalation dashboards and executive reporting.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:immediateRepairCost rdf:type rdf:Property ;
    rdfs:label 'Immediate Repair Cost' ;
    rdfs:comment 'Estimated cost in USD for repairs that must be completed within 90 days to address critical deficiencies and safety hazards. Subset of estimated_remediation_cost. Used for short-term CAPEX planning and acquisition price negotiation.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectorCompany rdf:type rdf:Property ;
    rdfs:label 'Inspector Company' ;
    rdfs:comment 'Name of the third-party firm or organization that employs the inspector and is contracted to perform the inspection. Used for vendor management, insurance certificate tracking, and report attribution.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorNotes rdf:type rdf:Property ;
    rdfs:label 'Inspector Notes' ;
    rdfs:comment 'Free-text field for the inspector\'s on-site observations, qualitative findings, and contextual commentary not captured in structured fields. Supplements the formal report with real-time field observations.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalReviewer rdf:type rdf:Property ;
    rdfs:label 'Internal Reviewer' ;
    rdfs:comment 'Name of the internal Asset Manager (AM) or Property Manager (PM) responsible for reviewing the inspection report, validating findings, and approving remediation plans. Establishes internal accountability for follow-up actions.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRegulatoryRequired rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Required' ;
    rdfs:comment 'Indicates whether this inspection is mandated by a government regulation, code, or regulatory authority. True for fire safety, elevator, and environmental inspections required by law. False for voluntary or insurance-driven inspections.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leedRelevant rdf:type rdf:Property ;
    rdfs:label 'Leed Relevant' ;
    rdfs:comment 'Indicates whether the findings of this inspection are relevant to the property\'s LEED or BREEAM green building certification status. True for energy audits, HVAC inspections, and environmental assessments that may affect certification scores.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:longTermRepairCost rdf:type rdf:Property ;
    rdfs:label 'Long Term Repair Cost' ;
    rdfs:comment 'Estimated cost in USD for capital replacements and major repairs projected over a 3-to-10-year horizon. Used for long-range CAPEX planning, reserve studies, and asset lifecycle management.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Date' ;
    rdfs:comment 'Date on which the next recurring or follow-up inspection is due for this property and inspection type. Drives automated scheduling reminders and regulatory compliance calendar management.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:passFailResult rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Result' ;
    rdfs:comment 'Binary or conditional outcome of the inspection as determined by the inspector or regulatory authority. A fail result triggers mandatory remediation and re-inspection workflows. Conditional pass indicates compliance with conditions attached.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinspectionDate rdf:type rdf:Property ;
    rdfs:label 'Reinspection Date' ;
    rdfs:comment 'Planned date for the follow-up re-inspection to verify that deficiencies identified in this inspection have been remediated. Populated when reinspection_required is True.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reinspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Reinspection Required' ;
    rdfs:comment 'Indicates whether a follow-up re-inspection is required after remediation of identified deficiencies. Typically set to True when pass_fail_result is fail or conditional_pass. Drives re-inspection scheduling workflow.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Report Document Ref' ;
    rdfs:comment 'File path, URL, or document management system reference (e.g., DocuSign CLM, SharePoint, Procore) pointing to the formal inspection report document. Enables direct access to the full inspection report from the data record.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Report Issued Date' ;
    rdfs:comment 'Date on which the formal inspection report was issued or delivered by the inspector or inspection firm. Used for SLA tracking, due diligence timeline management, and regulatory submission deadlines.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportVersion rdf:type rdf:Property ;
    rdfs:label 'Report Version' ;
    rdfs:comment 'Version identifier of the inspection report document (e.g., v1.0, v2.1). Tracks report revisions issued after initial delivery, such as updates following inspector corrections or additional findings.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Review Completed Date' ;
    rdfs:comment 'Date on which the internal reviewer completed their review of the inspection report and approved or escalated findings. Used for SLA tracking between report receipt and internal action initiation.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shortTermRepairCost rdf:type rdf:Property ;
    rdfs:label 'Short Term Repair Cost' ;
    rdfs:comment 'Estimated cost in USD for repairs required within 1 to 2 years beyond the immediate repair window. Used for annual CAPEX budgeting and reserve fund planning in property management.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:startTime rdf:type rdf:Property ;
    rdfs:label 'Start Time' ;
    rdfs:comment 'Precise date and time when the physical inspection commenced on-site. Used for duration calculation, inspector billing, and audit trail purposes.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:trigger rdf:type rdf:Property ;
    rdfs:label 'Trigger' ;
    rdfs:comment 'Business reason or event that initiated this inspection. Distinguishes routine scheduled inspections from event-driven ones (e.g., acquisition due diligence, insurance renewal, tenant complaint, post-incident assessment). [ENUM-REF-CANDIDATE: scheduled|due_diligence|insurance_requirement|regulatory_mandate|tenant_request|incident_response|post_construction — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderTriggered rdf:type rdf:Property ;
    rdfs:label 'Work Order Triggered' ;
    rdfs:comment 'Indicates whether this inspection has resulted in the creation of one or more maintenance work orders to address identified deficiencies. True when remediation work orders have been raised in Building Engines or Yardi.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:occupancyRecordId rdf:type rdf:Property ;
    rdfs:label 'Occupancy Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each occupancy snapshot record in the silver layer. Serves as the primary key for this point-in-time or period occupancy record.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OccupancyRecord .

ind:assetPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Asset Performance Id' ;
    rdfs:comment 'Foreign key linking to investment.asset_performance. Business justification: Asset performance calculations (NOI, cap rate, EGI) are derived from occupancy snapshots. Linking the source occupancy record to the asset performance period supports audit trail, data lineage reconci' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetPerformance .

ind:areaUnderNoticeSqf rdf:type rdf:Property ;
    rdfs:label 'Area Under Notice Sqf' ;
    rdfs:comment 'Total square footage of GLA where tenants have issued a notice to vacate but leases have not yet expired. Used alongside units_under_notice_count for forward vacancy exposure analysis and Argus cash flow modeling.' ;
    rdfs:domain ind:OccupancyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageInPlaceRentPsf rdf:type rdf:Property ;
    rdfs:label 'Average In Place Rent Psf' ;
    rdfs:comment 'Weighted average contractual base rent per square foot (PSF) across all occupied leases as of the snapshot date. Core metric for rent roll analysis, mark-to-market rent spread calculations, and NOI benchmarking against CoStar market comparables.' ;
    rdfs:domain ind:OccupancyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditLossAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Loss Amount' ;
    rdfs:comment 'Dollar value of rental income lost due to tenant delinquency, bad debt, or credit concessions during the reporting period. Distinct from vacancy loss; reflects economic occupancy shortfall versus physical occupancy. Used in EGI and NOI calculations.' ;
    rdfs:domain ind:OccupancyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Flag' ;
    rdfs:comment 'Quality status of this occupancy record as assessed during silver layer ingestion. Clean records are validated against source system; estimated records use interpolated values; reconciling records have discrepancies under investigation; error records failed validation rules.' ;
    rdfs:domain ind:OccupancyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:economicOccupancyRate rdf:type rdf:Property ;
    rdfs:label 'Economic Occupancy Rate' ;
    rdfs:comment 'Ratio of actual rent collected (or contractually due) to potential gross income (PGI) at 100% occupancy, expressed as a decimal. Accounts for rent concessions, free rent periods, and delinquencies. Critical for NOI calculations, DSCR covenant compliance, and investor reporting.' ;
    rdfs:domain ind:OccupancyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveGrossIncome rdf:type rdf:Property ;
    rdfs:label 'Effective Gross Income' ;
    rdfs:comment 'Actual rental income after deducting vacancy loss and credit loss from PGI for the reporting period. EGI is the revenue basis for NOI calculations, DSCR covenant testing, and REIT FFO/AFFO reporting.' ;
    rdfs:domain ind:OccupancyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossAbsorptionSqf rdf:type rdf:Property ;
    rdfs:label 'Gross Absorption Sqf' ;
    rdfs:comment 'Total square footage of new leases commenced during the reporting period, without netting out space vacated. Measures leasing velocity and demand activity independent of move-outs. Used in CoStar market analytics and portfolio leasing reports.' ;
    rdfs:domain ind:OccupancyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isSameStore rdf:type rdf:Property ;
    rdfs:label 'Is Same Store' ;
    rdfs:comment 'Flag indicating whether this property qualifies for same-store NOI comparison in the current reporting period (i.e., owned and stabilized for at least 12 consecutive months). Required for REIT same-store NOI reporting per NAREIT guidelines.' ;
    rdfs:domain ind:OccupancyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStabilized rdf:type rdf:Property ;
    rdfs:label 'Is Stabilized' ;
    rdfs:comment 'Flag indicating whether the property has reached stabilized occupancy (typically 90%+ physical occupancy for 90+ days). Stabilized assets are included in core portfolio NOI reporting; non-stabilized assets are tracked separately during lease-up.' ;
    rdfs:domain ind:OccupancyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaseExpirationsSqf rdf:type rdf:Property ;
    rdfs:label 'Lease Expirations Sqf' ;
    rdfs:comment 'Total square footage of leases scheduled to expire within the reporting period. Used for lease expiry schedule reporting, WALE/WALT calculations, and rollover risk assessment in Argus Enterprise cash flow models.' ;
    rdfs:domain ind:OccupancyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseUpStartDate rdf:type rdf:Property ;
    rdfs:label 'Lease Up Start Date' ;
    rdfs:comment 'Date on which the property entered the active lease-up phase following construction completion or major repositioning. Null for stabilized assets. Used to track lease-up velocity and project stabilization timelines in Argus Enterprise.' ;
    rdfs:domain ind:OccupancyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementLevel rdf:type rdf:Property ;
    rdfs:label 'Measurement Level' ;
    rdfs:comment 'Granularity at which this occupancy record is measured — building-level for asset management dashboards, unit-level for rent roll reconciliation, portfolio-level for REIT investor reporting.' ;
    rdfs:domain ind:OccupancyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netAbsorptionSqf rdf:type rdf:Property ;
    rdfs:label 'Net Absorption Sqf' ;
    rdfs:comment 'Change in occupied area square footage between the current and prior reporting period (current occupied SQF minus prior occupied SQF). Positive values indicate demand exceeding supply; negative values indicate space being returned to market. Key CoStar market benchmarking metric.' ;
    rdfs:domain ind:OccupancyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newLeasesSqf rdf:type rdf:Property ;
    rdfs:label 'New Leases Sqf' ;
    rdfs:comment 'Square footage of brand-new lease agreements (not renewals or expansions) that commenced during the reporting period. Distinguishes new demand from renewal activity for leasing performance attribution.' ;
    rdfs:domain ind:OccupancyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:occupiedUnitCount rdf:type rdf:Property ;
    rdfs:label 'Occupied Unit Count' ;
    rdfs:comment 'Number of units currently under an active lease or occupancy agreement as of the snapshot date. Used for unit-based occupancy rate reporting in multifamily portfolios and MRI residential management.' ;
    rdfs:domain ind:OccupancyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:physicalOccupancyRate rdf:type rdf:Property ;
    rdfs:label 'Physical Occupancy Rate' ;
    rdfs:comment 'Ratio of physically occupied area to total GLA, expressed as a decimal (e.g., 0.9250 = 92.50%). Measures actual space utilization regardless of rent collection status. Key metric for asset management dashboards and REIT same-store comparisons.' ;
    rdfs:domain ind:OccupancyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:potentialGrossIncome rdf:type rdf:Property ;
    rdfs:label 'Potential Gross Income' ;
    rdfs:comment 'Total rental income the property would generate if 100% occupied at market rent for the full reporting period. PGI is the starting point for NOI calculations and EGI derivation in Argus Enterprise cash flow models.' ;
    rdfs:domain ind:OccupancyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'Lifecycle status of this occupancy record within the data pipeline. Draft records are pending validation; published records are approved for investor reporting; superseded records have been replaced by a revised snapshot for the same period.' ;
    rdfs:domain ind:OccupancyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalLeasesSqf rdf:type rdf:Property ;
    rdfs:label 'Renewal Leases Sqf' ;
    rdfs:comment 'Square footage of lease renewals executed during the reporting period. Supports tenant retention rate analysis, WALE/WALT calculations, and same-store NOI stability assessment.' ;
    rdfs:domain ind:OccupancyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:snapshotDate rdf:type rdf:Property ;
    rdfs:label 'Snapshot Date' ;
    rdfs:comment 'The specific calendar date on which the occupancy measurement was captured or as-of date for point-in-time snapshots. Enables historical trend analysis and WALE/WALT calculations.' ;
    rdfs:domain ind:OccupancyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stabilizationDate rdf:type rdf:Property ;
    rdfs:label 'Stabilization Date' ;
    rdfs:comment 'Date on which the property first achieved stabilized occupancy status. Marks the transition from lease-up to core portfolio reporting. Used for same-store inclusion eligibility and investment performance benchmarking.' ;
    rdfs:domain ind:OccupancyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalGlaSqf rdf:type rdf:Property ;
    rdfs:label 'Total Gla Sqf' ;
    rdfs:comment 'Total Gross Leasable Area (GLA) of the property or unit in square feet as of the snapshot date. GLA is the standard denominator for occupancy rate calculations, NOI per square foot (PSF) analysis, and CAP rate benchmarking.' ;
    rdfs:domain ind:OccupancyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNlaSqf rdf:type rdf:Property ;
    rdfs:label 'Total Nla Sqf' ;
    rdfs:comment 'Total Net Leasable Area (NLA) of the property or unit in square feet, excluding common areas and building core. NLA is used for NNN lease calculations, CAM reconciliation, and tenant PSF rent comparisons.' ;
    rdfs:domain ind:OccupancyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalUnitCount rdf:type rdf:Property ;
    rdfs:label 'Total Unit Count' ;
    rdfs:comment 'Total number of leasable units within the property or building as of the snapshot date. Used as the denominator for unit-based occupancy rate calculations in multifamily and mixed-use assets tracked in MRI Software.' ;
    rdfs:domain ind:OccupancyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitsUnderNoticeCount rdf:type rdf:Property ;
    rdfs:label 'Units Under Notice Count' ;
    rdfs:comment 'Number of units where the tenant has issued a notice to vacate but the lease has not yet expired. Critical for forward-looking vacancy forecasting, WALE/WALT calculations, and leasing team pipeline management.' ;
    rdfs:domain ind:OccupancyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vacancyLossAmount rdf:type rdf:Property ;
    rdfs:label 'Vacancy Loss Amount' ;
    rdfs:comment 'Dollar value of rental income lost due to vacant space during the reporting period (PGI minus income from occupied space). Used in NOI statements, EGI calculations, and investor reporting for portfolio performance monitoring.' ;
    rdfs:domain ind:OccupancyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vacantAreaSqf rdf:type rdf:Property ;
    rdfs:label 'Vacant Area Sqf' ;
    rdfs:comment 'Total square footage of GLA not under any active lease or occupancy agreement as of the snapshot date. Equals total GLA minus occupied area. Used for vacancy loss calculations in NOI statements and EGI modeling.' ;
    rdfs:domain ind:OccupancyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vacantUnitCount rdf:type rdf:Property ;
    rdfs:label 'Vacant Unit Count' ;
    rdfs:comment 'Number of units not under any active lease or occupancy agreement as of the snapshot date. Equals total unit count minus occupied unit count. Supports vacancy trend analysis and leasing pipeline prioritization.' ;
    rdfs:domain ind:OccupancyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waleYears rdf:type rdf:Property ;
    rdfs:label 'Wale Years' ;
    rdfs:comment 'Weighted Average Lease Expiry (WALE) in years as of the snapshot date, weighted by GLA. Measures the average time until leases expire across the occupied portfolio. Core metric for REIT investor reporting, debt covenant compliance, and asset management risk assessment.' ;
    rdfs:domain ind:OccupancyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waltYears rdf:type rdf:Property ;
    rdfs:label 'Walt Years' ;
    rdfs:comment 'Weighted Average Lease Term (WALT) in years as of the snapshot date, weighted by GLA. Measures the average remaining lease term across the occupied portfolio. Distinct from WALE in that it reflects the full contracted term rather than expiry proximity. Used in Argus Enterprise DCF modeling.' ;
    rdfs:domain ind:OccupancyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentPropertyTypeId rdf:type rdf:Property ;
    rdfs:label 'Parent Property Type Id' ;
    rdfs:comment 'Self-referencing foreign key to the parent node in the property classification hierarchy. NULL for Level 1 (asset class) root nodes. Enables traversal of the multi-level taxonomy (L1 asset class → L2 sub-category → L3 quality tier → L4 space use → L5 construction method → L6 amenity classification).' ;
    rdfs:domain ind:PropertyType ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PropertyType .

ind:amenityClassification rdf:type rdf:Property ;
    rdfs:label 'Amenity Classification' ;
    rdfs:comment 'Level 6 amenity classification indicating whether amenities associated with this property type are provided at the building level (lobbies, fitness centers, conference rooms), unit level (in-unit washer/dryer, private terrace), or community level (shared outdoor spaces, pools, clubhouses). Used in property marketing, tenant scoring, and lease negotiation.' ;
    rdfs:domain ind:PropertyType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bimApplicable rdf:type rdf:Property ;
    rdfs:label 'Bim Applicable' ;
    rdfs:comment 'Indicates whether BIM (Building Information Modeling) digital asset documentation is applicable and required for development and construction projects of this property type. True for complex commercial, mixed-use, and large-scale residential development types managed in Procore. Drives BIM data collection and document control workflows.' ;
    rdfs:domain ind:PropertyType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:camInclusionRule rdf:type rdf:Property ;
    rdfs:label 'Cam Inclusion Rule' ;
    rdfs:comment 'Standard CAM (Common Area Maintenance) expense inclusion rule applicable to this property type, defining which operating expenses are passed through to tenants. NNN (Triple Net) passes taxes, insurance, and maintenance; NN (Double Net) passes taxes and insurance; Full-Service Gross includes all expenses in base rent. Drives lease structuring defaults in Yardi Voyager and MRI Software. [ENUM-REF-CANDIDATE: Full-Service Gross|Modified Gross|NNN|NN|N|Absolute Net|N/A — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capRateBenchmarkPct rdf:type rdf:Property ;
    rdfs:label 'Cap Rate Benchmark Pct' ;
    rdfs:comment 'Market benchmark CAP Rate (Capitalization Rate) percentage for this property type, representing the expected ratio of Net Operating Income (NOI) to property value. Used as a default underwriting assumption in Argus Enterprise DCF (Discounted Cash Flow) models and investment advisory valuations. Expressed as a percentage (e.g., 5.50 = 5.50%).' ;
    rdfs:domain ind:PropertyType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costarPropertyTypeCode rdf:type rdf:Property ;
    rdfs:label 'Costar Property Type Code' ;
    rdfs:comment 'CoStar Suite\'s standardized property type code for this classification node. Enables direct mapping and data reconciliation between the enterprise taxonomy and CoStar market research data, comparable sales, and lease analytics. Critical for market benchmarking and CMA (Comparative Market Analysis) workflows.' ;
    rdfs:domain ind:PropertyType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:farApplicable rdf:type rdf:Property ;
    rdfs:label 'Far Applicable' ;
    rdfs:comment 'Indicates whether Floor Area Ratio (FAR) regulations are applicable to development projects of this property type. True for commercial and mixed-use development types subject to FAR zoning restrictions. Used in development feasibility analysis and Procore project planning.' ;
    rdfs:domain ind:PropertyType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hoaApplicable rdf:type rdf:Property ;
    rdfs:label 'Hoa Applicable' ;
    rdfs:comment 'Indicates whether properties of this type are subject to HOA (Homeowners Association) governance, fees, and covenants. Applicable to condominium, single-family community, and certain mixed-use residential property types. Drives HOA fee tracking in property management and tenant disclosure requirements.' ;
    rdfs:domain ind:PropertyType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ibcFireResistanceType rdf:type rdf:Property ;
    rdfs:label 'Ibc Fire Resistance Type' ;
    rdfs:comment 'International Building Code (IBC) construction type classification indicating the fire resistance rating of the structural system. Types I and II are non-combustible; Types III, IV, and V include combustible elements. Drives insurance underwriting, OSHA compliance, and maintenance safety protocols. Aligned with IBC Chapter 6 construction type definitions. [ENUM-REF-CANDIDATE: Type I-A|Type I-B|Type II-A|Type II-B|Type III-A|Type III-B|Type IV|Type V-A|Type V-B|N/A — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PropertyType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCamApplicable rdf:type rdf:Property ;
    rdfs:label 'Is Cam Applicable' ;
    rdfs:comment 'Indicates whether Common Area Maintenance (CAM) charges are applicable to leases for properties of this type. True for commercial property types (office, retail, industrial) where CAM reconciliation is standard. False for residential or gross lease property types where operating expenses are not passed through to tenants.' ;
    rdfs:domain ind:PropertyType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCommercial rdf:type rdf:Property ;
    rdfs:label 'Is Commercial' ;
    rdfs:comment 'Indicates whether this property type is classified as CRE (Commercial Real Estate) for regulatory, tax, and accounting purposes. Drives applicability of CMBS (Commercial Mortgage-Backed Securities) financing, DSCR (Debt Service Coverage Ratio) underwriting, and commercial lease accounting under FASB ASC 842.' ;
    rdfs:domain ind:PropertyType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEsgRelevant rdf:type rdf:Property ;
    rdfs:label 'Is Esg Relevant' ;
    rdfs:comment 'Indicates whether ESG (Environmental, Social, and Governance) reporting metrics and sustainability certifications are applicable and tracked for properties of this type. True for property types subject to LEED, BREEAM, or ENERGY STAR certification programs. Drives ESG data collection requirements and SEC sustainability disclosure obligations for publicly traded REITs.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGlaApplicable rdf:type rdf:Property ;
    rdfs:label 'Is Gla Applicable' ;
    rdfs:comment 'Indicates whether Gross Leasable Area (GLA) measurement methodology is applicable to properties of this type. True for retail and commercial property types where GLA is the standard measurement basis per BOMA and ICSC standards. False for property types measured by other methodologies (e.g., residential measured by GFA or NLA).' ;
    rdfs:domain ind:PropertyType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInvestmentGrade rdf:type rdf:Property ;
    rdfs:label 'Is Investment Grade' ;
    rdfs:comment 'Indicates whether properties of this type qualify as institutional investment-grade assets suitable for REIT (Real Estate Investment Trust) portfolios, pension fund investment, and institutional capital allocation. Drives portfolio screening in Argus Enterprise and investment advisory workflows. Typically True for Class A and Trophy commercial assets.' ;
    rdfs:domain ind:PropertyType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLeafNode rdf:type rdf:Property ;
    rdfs:label 'Is Leaf Node' ;
    rdfs:comment 'Indicates whether this taxonomy node is a terminal leaf node (True) with no child nodes, or an intermediate branch node (False). Leaf nodes represent the most granular assignable property type classifications. Used to enforce that only leaf-level types are assigned to individual properties and leases.' ;
    rdfs:domain ind:PropertyType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReitEligible rdf:type rdf:Property ;
    rdfs:label 'Is Reit Eligible' ;
    rdfs:comment 'Indicates whether properties of this type qualify as REIT-eligible assets under IRS REIT qualification rules (IRC Section 856). Drives asset classification in financial consolidation (SAP S/4HANA) and SEC regulatory reporting for publicly traded REITs. Distinct from investment_grade as it reflects specific tax and regulatory eligibility.' ;
    rdfs:domain ind:PropertyType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isResidential rdf:type rdf:Property ;
    rdfs:label 'Is Residential' ;
    rdfs:comment 'Indicates whether this property type is classified as residential for regulatory, tax, and accounting purposes. Drives applicability of HUD regulations, residential mortgage underwriting standards (PMI, ARM, FRM, DTI), and RMBS (Residential Mortgage-Backed Securities) eligibility. Distinct from asset_class for use in compliance filtering.' ;
    rdfs:domain ind:PropertyType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leedCertificationApplicable rdf:type rdf:Property ;
    rdfs:label 'Leed Certification Applicable' ;
    rdfs:comment 'Indicates whether LEED (Leadership in Energy and Environmental Design) certification is applicable and pursued for properties of this type. Drives green building data collection, energy benchmarking, and ESG reporting workflows. Relevant for institutional-grade commercial and multifamily property types.' ;
    rdfs:domain ind:PropertyType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementMethodology rdf:type rdf:Property ;
    rdfs:label 'Measurement Methodology' ;
    rdfs:comment 'Standard area measurement methodology applicable to this property type. GLA (Gross Leasable Area) for retail; NLA (Net Leasable Area) for commercial office; GFA (Gross Floor Area) for development and planning; IPMS (International Property Measurement Standards) for cross-border portfolios. Drives how PSF (Per Square Foot) rent and valuation metrics are calculated.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:naiopTypeCode rdf:type rdf:Property ;
    rdfs:label 'Naiop Type Code' ;
    rdfs:comment 'NAIOP (National Association for Industrial and Office Properties) standardized property type code for commercial real estate classification. Used for industry benchmarking, market research alignment, and CRE (Commercial Real Estate) portfolio reporting.' ;
    rdfs:domain ind:PropertyType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertyTypeStatus rdf:type rdf:Property ;
    rdfs:label 'Property Type Status' ;
    rdfs:comment 'Current lifecycle status of this property type taxonomy node. \'active\' nodes are available for assignment to properties, leases, and valuations. \'deprecated\' nodes are retained for historical data integrity but no longer assignable. \'draft\' nodes are under review prior to enterprise publication.' ;
    rdfs:domain ind:PropertyType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resoPropertyTypeCode rdf:type rdf:Property ;
    rdfs:label 'Reso Property Type Code' ;
    rdfs:comment 'RESO (Real Estate Standards Organization) standardized property type code for MLS (Multiple Listing Service) data exchange and industry interoperability. Enables syndication of property listings via MLS platforms and ensures compliance with RESO Data Dictionary standards.' ;
    rdfs:domain ind:PropertyType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortOrder rdf:type rdf:Property ;
    rdfs:label 'Sort Order' ;
    rdfs:comment 'Integer defining the preferred display sequence of this property type node within its sibling group at the same hierarchy level. Used to control the ordering of property type options in dropdown menus, reports, and dashboards across Yardi Voyager, MRI Software, and Salesforce CRM integrations.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subCategory rdf:type rdf:Property ;
    rdfs:label 'Sub Category' ;
    rdfs:comment 'Level 2 sub-category classification denormalized from the taxonomy hierarchy for analytical convenience. Examples: Office, Retail, Industrial, Hospitality, Single-Family, Multifamily, Condo, Mixed-Use Retail/Office. [ENUM-REF-CANDIDATE: Office|Retail|Industrial|Hospitality|Single-Family|Multifamily|Condo|Mixed-Use|Self-Storage|Data Center|Life Science|Senior Housing — promote to reference product]' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tiAllowanceBenchmarkPsf rdf:type rdf:Property ;
    rdfs:label 'Ti Allowance Benchmark Psf' ;
    rdfs:comment 'Market benchmark for Tenant Improvement (TI) allowance expressed in dollars Per Square Foot (PSF) for this property type. Used as a default starting point in lease negotiations and deal underwriting. Sourced from CoStar market data and internal brokerage transaction history. Supports deal pipeline analysis in Salesforce CRM.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typeCode rdf:type rdf:Property ;
    rdfs:label 'Type Code' ;
    rdfs:comment 'Standardized alphanumeric code uniquely identifying this property type node within the enterprise taxonomy. Used as the stable business key for cross-system integration with Yardi Voyager, MRI Software, CoStar, and Argus Enterprise. Examples: COMM_OFF_A, RES_MF_LUX, IND_WRHSE.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeDescription rdf:type rdf:Property ;
    rdfs:label 'Type Description' ;
    rdfs:comment 'Detailed narrative description of the property classification node, including defining characteristics, typical use cases, and distinguishing criteria from adjacent nodes. Supports business user understanding and onboarding.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeName rdf:type rdf:Property ;
    rdfs:label 'Type Name' ;
    rdfs:comment 'Human-readable display name for this property classification node as used in reports, dashboards, and user interfaces across all operational systems. Examples: \'Class A Office\', \'Luxury Multifamily\', \'Triple Net Retail\'.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalLeaseTermMonths rdf:type rdf:Property ;
    rdfs:label 'Typical Lease Term Months' ;
    rdfs:comment 'Market-standard typical lease term in months for this property type. Used as a default assumption in lease underwriting, WALT (Weighted Average Lease Term) calculations, and cash flow modeling in Argus Enterprise. Examples: 12 months for residential, 60-120 months for commercial office, 36-60 months for retail.' ;
    rdfs:domain ind:PropertyType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:zoningCompatibilityCodes rdf:type rdf:Property ;
    rdfs:label 'Zoning Compatibility Codes' ;
    rdfs:comment 'Pipe-delimited list of standard zoning designation codes compatible with this property type (e.g., \'C-1|C-2|M-1\' for light commercial/industrial). Supports regulatory compliance checks, development feasibility analysis, and GIS (Geographic Information System) integration. Aligned with local municipal zoning ordinances and FAR (Floor Area Ratio) regulations.' ;
    rdfs:domain ind:PropertyType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseTypeId rdf:type rdf:Property ;
    rdfs:label 'Lease Type Id' ;
    rdfs:comment 'Primary key for lease_type' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LeaseType .

ind:abbreviation rdf:type rdf:Property ;
    rdfs:label 'Abbreviation' ;
    rdfs:comment 'Industry-standard abbreviation for the lease type used in market communications, CoStar listings, and brokerage reports (e.g., NNN, MG, FS, PCT, GL). Aligns with CoStar Suite and MLS syndication field conventions.' ;
    rdfs:domain ind:LeaseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:argusLeaseTypeCode rdf:type rdf:Property ;
    rdfs:label 'Argus Lease Type Code' ;
    rdfs:comment 'The corresponding lease type identifier as used in Argus Enterprise cash flow and valuation models. Enables mapping between this reference record and Argus Enterprise lease structure assumptions for DCF modeling, CAP rate analysis, and portfolio reporting.' ;
    rdfs:domain ind:LeaseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:camReconciliationRequired rdf:type rdf:Property ;
    rdfs:label 'Cam Reconciliation Required' ;
    rdfs:comment 'Indicates whether annual CAM reconciliation is required for this lease type (True). CAM reconciliation compares estimated CAM charges billed to tenants against actual CAM expenses incurred. Required for NNN and modified gross leases; not applicable for full gross leases. Activates CAM reconciliation workflows in Yardi Voyager.' ;
    rdfs:domain ind:LeaseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:camResponsibility rdf:type rdf:Property ;
    rdfs:label 'Cam Responsibility' ;
    rdfs:comment 'Indicates which party bears responsibility for Common Area Maintenance (CAM) charges under this lease type. \'landlord\' means the landlord absorbs all CAM costs; \'tenant\' means the tenant pays CAM directly (as in NNN); \'shared\' means costs are pro-rated; \'not_applicable\' for lease types where CAM is not a relevant concept (e.g., ground lease). Governs CAM reconciliation workflows in Yardi Voyager.' ;
    rdfs:domain ind:LeaseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationMethod rdf:type rdf:Property ;
    rdfs:label 'Escalation Method' ;
    rdfs:comment 'Indicates the standard rent escalation methodology associated with this lease type: fixed_step (predetermined dollar or percentage increases), cpi_indexed (Consumer Price Index-linked adjustments), market_reset (rent reset to prevailing market rate at intervals), none (flat rent for term), or hybrid (combination of methods). Governs rent schedule escalation logic in Yardi Voyager and Argus Enterprise DCF models.' ;
    rdfs:domain ind:LeaseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgReportingApplicable rdf:type rdf:Property ;
    rdfs:label 'Esg Reporting Applicable' ;
    rdfs:comment 'Indicates whether ESG (Environmental, Social, and Governance) reporting obligations — such as green lease clauses, LEED/BREEAM compliance requirements, or energy consumption data sharing — are applicable to this lease type (True). Relevant for institutional and REIT portfolios subject to SEC ESG disclosure requirements and USGBC LEED certification programs.' ;
    rdfs:domain ind:LeaseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'Industry-standard or regulatory body reference code for this lease type, such as RESO standard codes, NCREIF property type codes, or CoStar lease type identifiers. Enables cross-system interoperability and alignment with industry data exchange standards.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrs16LeaseClassification rdf:type rdf:Property ;
    rdfs:label 'Ifrs16 Lease Classification' ;
    rdfs:comment 'Specifies the default lease classification under IASB IFRS 16 for this lease type: \'single_model\' (all leases recognized on balance sheet as right-of-use asset and lease liability), \'short_term_exemption\' (leases ≤12 months), \'low_value_exemption\' (underlying asset of low value), or \'not_applicable\'. Supports international financial reporting in SAP S/4HANA for entities reporting under IFRS.' ;
    rdfs:domain ind:LeaseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceResponsibility rdf:type rdf:Property ;
    rdfs:label 'Insurance Responsibility' ;
    rdfs:comment 'Defines which party is responsible for property insurance premiums under this lease type. Relevant for NNN and modified gross lease structures where insurance cost allocation varies. Used in lease administration billing and CAM reconciliation processes.' ;
    rdfs:domain ind:LeaseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGroundLease rdf:type rdf:Property ;
    rdfs:label 'Is Ground Lease' ;
    rdfs:comment 'Indicates whether this lease type is a ground lease (True), where the tenant leases land only and typically constructs improvements. Ground leases have distinct legal, accounting, and investment characteristics including long terms (50–99 years), land-only rent, and reversion of improvements to the landlord. Relevant for REIT portfolio classification and Argus Enterprise valuation modeling.' ;
    rdfs:domain ind:LeaseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isShortTerm rdf:type rdf:Property ;
    rdfs:label 'Is Short Term' ;
    rdfs:comment 'Indicates whether this lease type is classified as short-term (True), typically defined as a lease term of 12 months or less at commencement. Short-term leases qualify for the practical expedient exemption from balance sheet recognition under both FASB ASC 842 and IASB IFRS 16. Drives accounting treatment selection in SAP S/4HANA and Yardi Voyager.' ;
    rdfs:domain ind:LeaseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaseCategory rdf:type rdf:Property ;
    rdfs:label 'Lease Category' ;
    rdfs:comment 'Broad property-use category to which this lease type applies — commercial, residential, industrial, mixed_use, or land. Determines which operational workflows in Yardi Voyager and MRI Software are applicable and which regulatory frameworks (ASC 842, IFRS 16) govern accounting treatment.' ;
    rdfs:domain ind:LeaseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseTypeCode rdf:type rdf:Property ;
    rdfs:label 'Lease Type Code' ;
    rdfs:comment 'Short, system-facing alphanumeric code uniquely identifying the lease type (e.g., NNN, GROSS, MOD_GROSS, PCT, GROUND, SUBLEASE, MTM). Used as the canonical lookup key in Yardi Voyager, MRI Software, and downstream analytical systems to join lease records to their classification.' ;
    rdfs:domain ind:LeaseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Lease Type Description' ;
    rdfs:comment 'Detailed narrative description of the lease type, including its defining characteristics, typical use cases, cost responsibility allocation, and distinguishing features from similar lease structures. Used in training materials, lease administration documentation, and business glossary entries.' ;
    rdfs:domain ind:LeaseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseTypeName rdf:type rdf:Property ;
    rdfs:label 'Lease Type Name' ;
    rdfs:comment 'Full human-readable name of the lease structure classification (e.g., \'Triple Net Lease\', \'Gross Lease\', \'Modified Gross Lease\', \'Percentage Lease\', \'Ground Lease\', \'Sublease\', \'Month-to-Month\'). Displayed in reporting, lease administration screens, and tenant-facing documents.' ;
    rdfs:domain ind:LeaseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseTypeStatus rdf:type rdf:Property ;
    rdfs:label 'Lease Type Status' ;
    rdfs:comment 'Current lifecycle status of this lease type reference record: \'active\' (available for use in new lease agreements), \'inactive\' (temporarily disabled but retained for historical reference), or \'deprecated\' (superseded by a newer classification; retained for legacy lease records only). Controls availability in Yardi Voyager and MRI Software lease type selection lists.' ;
    rdfs:domain ind:LeaseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loiRequired rdf:type rdf:Property ;
    rdfs:label 'Loi Required' ;
    rdfs:comment 'Indicates whether a Letter of Intent (LOI) is a standard prerequisite in the deal process for this lease type (True). LOIs are standard for commercial leases but typically not required for residential or month-to-month arrangements. Governs deal pipeline workflow in Salesforce CRM and DocuSign CLM.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mriLeaseTypeCode rdf:type rdf:Property ;
    rdfs:label 'Mri Lease Type Code' ;
    rdfs:comment 'The corresponding lease type code as configured in MRI Software Lease Management module. Enables direct mapping between this enterprise reference record and the MRI source system code for data integration and reconciliation, particularly for residential and investment management portfolios.' ;
    rdfs:domain ind:LeaseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noiImpactClassification rdf:type rdf:Property ;
    rdfs:label 'Noi Impact Classification' ;
    rdfs:comment 'Classifies how this lease type impacts Net Operating Income (NOI) calculation: \'gross_revenue\' (all income flows through gross revenue line before expense deductions), \'net_revenue\' (tenant pays expenses directly, reducing gross revenue line), or \'not_applicable\'. Used in Argus Enterprise NOI modeling and MRI Software investment reporting.' ;
    rdfs:domain ind:LeaseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opexResponsibility rdf:type rdf:Property ;
    rdfs:label 'Opex Responsibility' ;
    rdfs:comment 'Defines which party is responsible for property operating expenditures (OpEx) beyond CAM — including insurance, management fees, and administrative costs — under this lease type. Critical for NOI calculation accuracy in Argus Enterprise and financial reporting under FASB ASC 842.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:percentageRentApplicable rdf:type rdf:Property ;
    rdfs:label 'Percentage Rent Applicable' ;
    rdfs:comment 'Indicates whether percentage rent (a portion of tenant gross sales revenue above a breakpoint) is a feature of this lease type (True). Applicable primarily to retail percentage leases. Activates percentage rent calculation and reporting workflows in Yardi Voyager and MRI Software.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalOptionApplicable rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Applicable' ;
    rdfs:comment 'Indicates whether renewal options are a standard feature of this lease type (True) or not applicable (False). For example, ground leases and long-term commercial leases typically include renewal options, while month-to-month leases do not. Informs lease renewal option tracking in Yardi Voyager and WALT/WALE calculations in Argus Enterprise.' ;
    rdfs:domain ind:LeaseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rentBasis rdf:type rdf:Property ;
    rdfs:label 'Rent Basis' ;
    rdfs:comment 'Defines the standard unit of measure for rent quotation under this lease type: PSF (Per Square Foot) annual, PSF monthly, flat monthly amount, flat annual amount, or percentage of sales. Aligns with industry PSF/SQF conventions and drives rent schedule generation in Yardi Voyager and Argus Enterprise underwriting models.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rentStructure rdf:type rdf:Property ;
    rdfs:label 'Rent Structure' ;
    rdfs:comment 'Defines the fundamental rent calculation methodology for this lease type: fixed (flat base rent), variable (indexed or market-reset), percentage (percentage of tenant sales revenue), hybrid (base + percentage), or ground_rent (land-only lease payment). Drives rent schedule generation logic in Yardi Voyager and Argus Enterprise cash flow models.' ;
    rdfs:domain ind:LeaseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityDepositRequired rdf:type rdf:Property ;
    rdfs:label 'Security Deposit Required' ;
    rdfs:comment 'Indicates whether a security deposit is a standard requirement for this lease type (True). Security deposits are common in residential and commercial leases but may not apply to ground leases or certain institutional arrangements. Drives security deposit tracking and accounting in Yardi Voyager AR and MRI Software.' ;
    rdfs:domain ind:LeaseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subleasePermitted rdf:type rdf:Property ;
    rdfs:label 'Sublease Permitted' ;
    rdfs:comment 'Indicates whether subleasing is a standard permitted feature under this lease type (True). Relevant for distinguishing primary lease structures from sublease structures and for compliance with FASB ASC 842 sublease accounting requirements.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxResponsibility rdf:type rdf:Property ;
    rdfs:label 'Tax Responsibility' ;
    rdfs:comment 'Specifies which party is responsible for real estate property taxes under this lease type. In a Triple Net (NNN) lease, the tenant bears tax responsibility; in a gross lease, the landlord absorbs taxes. Drives tax pass-through billing logic in Yardi Voyager and MRI Software.' ;
    rdfs:domain ind:LeaseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tiAllowanceApplicable rdf:type rdf:Property ;
    rdfs:label 'Ti Allowance Applicable' ;
    rdfs:comment 'Indicates whether Tenant Improvement (TI) allowances are a standard feature of this lease type (True). TI allowances are common in commercial gross and modified gross leases but less common in NNN or ground leases. Drives TI allowance tracking and amortization in Yardi Voyager Fixed Assets and FASB ASC 842 right-of-use asset calculations.' ;
    rdfs:domain ind:LeaseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:typicalTermMaxMonths rdf:type rdf:Property ;
    rdfs:label 'Typical Term Max Months' ;
    rdfs:comment 'The typical maximum lease duration in months associated with this lease type (e.g., 12 months for short-term, 120 months for standard commercial, 1200 months for ground leases). Used in Argus Enterprise for WALT/WALE modeling, portfolio duration analytics, and investment underwriting.' ;
    rdfs:domain ind:LeaseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:typicalTermMinMonths rdf:type rdf:Property ;
    rdfs:label 'Typical Term Min Months' ;
    rdfs:comment 'The typical minimum lease duration in months associated with this lease type (e.g., 1 month for month-to-month, 12 months for short-term, 60 months for standard commercial NNN). Used in Argus Enterprise for WALT/WALE modeling and portfolio duration analytics.' ;
    rdfs:domain ind:LeaseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:utilityResponsibility rdf:type rdf:Property ;
    rdfs:label 'Utility Responsibility' ;
    rdfs:comment 'Specifies which party is responsible for utility costs (electricity, water, gas, HVAC) under this lease type. Gross leases typically assign utilities to the landlord; NNN leases assign them to the tenant. Drives utility billing configuration in Building Engines and Yardi Voyager.' ;
    rdfs:domain ind:LeaseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yardiLeaseTypeCode rdf:type rdf:Property ;
    rdfs:label 'Yardi Lease Type Code' ;
    rdfs:comment 'The corresponding lease type code as configured in Yardi Voyager Lease Administration module. Enables direct mapping between this enterprise reference record and the source system code for data integration, reconciliation, and ETL processes from Yardi Voyager.' ;
    rdfs:domain ind:LeaseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appraisalRequired rdf:type rdf:Property ;
    rdfs:label 'Appraisal Required' ;
    rdfs:comment 'Indicates whether a formal property appraisal or valuation is required for transactions of this type. Triggers valuation workflow initiation in Argus Enterprise and appraisal order management processes.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assetClassApplicability rdf:type rdf:Property ;
    rdfs:label 'Asset Class Applicability' ;
    rdfs:comment 'Comma-delimited list of real estate asset classes to which this transaction type applies (e.g., \'office,retail,industrial,multifamily,land,hotel,mixed-use\'). Governs which asset classes can be tagged with this transaction type in Yardi Voyager and MRI Software.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerCommissionApplicable rdf:type rdf:Property ;
    rdfs:label 'Broker Commission Applicable' ;
    rdfs:comment 'Indicates whether brokerage commissions are applicable to transactions of this type. Drives commission calculation and split workflows in Salesforce CRM and the brokerage domain commission products.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capexOrOpex rdf:type rdf:Property ;
    rdfs:label 'Capex Or Opex' ;
    rdfs:comment 'Indicates whether transactions of this type are classified as Capital Expenditure (CAPEX), Operating Expenditure (OPEX), both, or neither for financial reporting and budgeting purposes. Drives budget line categorization in Yardi Voyager and SAP S/4HANA.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDiligencePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Due Diligence Period Days' ;
    rdfs:comment 'Standard number of calendar days allocated for due diligence for transactions of this type, as defined by industry convention or internal policy. Used as a default in deal timeline planning within Salesforce CRM and Argus Enterprise.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:environmentalReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Environmental Review Required' ;
    rdfs:comment 'Flags whether an environmental site assessment (Phase I/II ESA) is required for transactions of this type. Drives due diligence checklist items in Procore and compliance tracking in SAP S/4HANA.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:glTransactionClass rdf:type rdf:Property ;
    rdfs:label 'Gl Transaction Class' ;
    rdfs:comment 'General Ledger (GL) transaction class code used to map this transaction type to the appropriate accounting treatment in Yardi Voyager and SAP S/4HANA (e.g., capital event, operating event, financing event). Ensures consistent financial statement classification.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:is1031Eligible rdf:type rdf:Property ;
    rdfs:label 'Is 1031 Eligible' ;
    rdfs:comment 'Flags whether this transaction type is eligible for a like-kind exchange under IRS Section 1031, allowing deferral of capital gains taxes. Critical for investment advisory and portfolio management workflows in Argus Enterprise and MRI Software.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDistressedAsset rdf:type rdf:Property ;
    rdfs:label 'Is Distressed Asset' ;
    rdfs:comment 'Indicates whether this transaction type involves a distressed asset scenario (e.g., foreclosure, REO sale, short sale, deed-in-lieu). Drives specialized due diligence checklists and risk flags in Salesforce CRM and Argus Enterprise.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFasbAsc842Applicable rdf:type rdf:Property ;
    rdfs:label 'Is Fasb Asc842 Applicable' ;
    rdfs:comment 'Flags whether this transaction type triggers lease accounting recognition requirements under FASB ASC 842 (e.g., ground lease assignments, sale-leaseback transactions). Used by the finance domain for lease liability and right-of-use asset recognition in Yardi Voyager and SAP S/4HANA.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHudReportable rdf:type rdf:Property ;
    rdfs:label 'Is Hud Reportable' ;
    rdfs:comment 'Indicates whether transactions of this type require reporting to HUD (e.g., residential foreclosures, REO sales, FHA-related transactions). Drives compliance workflow routing in DocuSign CLM and SAP S/4HANA.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isIfrs16Applicable rdf:type rdf:Property ;
    rdfs:label 'Is Ifrs16 Applicable' ;
    rdfs:comment 'Flags whether this transaction type triggers lease accounting recognition requirements under IFRS 16 for entities reporting under international accounting standards. Supports multi-standard financial reporting in SAP S/4HANA.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isJointVenture rdf:type rdf:Property ;
    rdfs:label 'Is Joint Venture' ;
    rdfs:comment 'Indicates whether this transaction type involves the formation or dissolution of a joint venture (JV) entity. Triggers JV-specific legal entity setup workflows in SAP S/4HANA and investment structuring processes in MRI Software.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPortfolioTrade rdf:type rdf:Property ;
    rdfs:label 'Is Portfolio Trade' ;
    rdfs:comment 'Flags whether this transaction type represents a bulk portfolio trade involving multiple properties transacted as a single deal. Enables portfolio-level aggregation and reporting in Argus Enterprise and MRI Software investment management modules.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSecReportable rdf:type rdf:Property ;
    rdfs:label 'Is Sec Reportable' ;
    rdfs:comment 'Indicates whether transactions of this type must be reported to the SEC under applicable regulations (e.g., material acquisitions or dispositions by publicly traded REITs under Form 8-K or 10-K). Drives automated regulatory reporting flags in SAP S/4HANA.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTaxableEvent rdf:type rdf:Property ;
    rdfs:label 'Is Taxable Event' ;
    rdfs:comment 'Indicates whether this transaction type constitutes a taxable event under applicable U.S. federal tax law (e.g., a standard acquisition/disposition is taxable; a 1031 exchange defers capital gains tax). Used by the finance domain for tax provision calculations in SAP S/4HANA.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mlsReportable rdf:type rdf:Property ;
    rdfs:label 'Mls Reportable' ;
    rdfs:comment 'Flags whether transactions of this type are required or eligible to be reported to the Multiple Listing Service (MLS) and syndicated via CoStar Suite. Drives MLS syndication workflow in the brokerage domain.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mriTransactionCode rdf:type rdf:Property ;
    rdfs:label 'Mri Transaction Code' ;
    rdfs:comment 'Corresponding transaction type code as defined in MRI Software, used for system integration and data lineage tracing between the enterprise data lakehouse and the MRI source system.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertySector rdf:type rdf:Property ;
    rdfs:label 'Property Sector' ;
    rdfs:comment 'Indicates whether this transaction type applies to Commercial Real Estate (CRE), residential properties, both sectors, or is sector-agnostic. Drives sector-specific workflow routing in Salesforce CRM and Yardi Voyager.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reitQualifyingIncome rdf:type rdf:Property ;
    rdfs:label 'Reit Qualifying Income' ;
    rdfs:comment 'Flags whether income or proceeds from transactions of this type qualify as REIT qualifying income under IRS Section 856. Critical for REIT compliance monitoring and FFO/AFFO calculations in MRI Software and Argus Enterprise.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredDocChecklist rdf:type rdf:Property ;
    rdfs:label 'Required Doc Checklist' ;
    rdfs:comment 'Structured list or reference identifier for the documentation checklist required for transactions of this type (e.g., purchase agreement, title commitment, survey, environmental report, estoppel certificates, SNDA, LOI). Drives document management workflows in DocuSign CLM.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:titleInsuranceRequired rdf:type rdf:Property ;
    rdfs:label 'Title Insurance Required' ;
    rdfs:comment 'Flags whether title insurance (ALTA policy) is required for transactions of this type. Drives documentation checklist requirements in DocuSign CLM and closing process workflows.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionTypeCategory rdf:type rdf:Property ;
    rdfs:label 'Transaction Type Category' ;
    rdfs:comment 'High-level grouping of the transaction type into a major business category. Supports portfolio-level reporting and analytics segmentation across the transaction and brokerage domains. [ENUM-REF-CANDIDATE: acquisition|disposition|financing|leasing|development|investment|distressed|exchange — promote to reference product]' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTypeStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Type Status' ;
    rdfs:comment 'Lifecycle status of the transaction type record within the controlled vocabulary. \'active\' records are available for use across all domains; \'deprecated\' records are retained for historical data integrity but no longer selectable for new transactions.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferTaxApplicable rdf:type rdf:Property ;
    rdfs:label 'Transfer Tax Applicable' ;
    rdfs:comment 'Indicates whether real estate transfer taxes (deed taxes, documentary stamp taxes) are applicable to transactions of this type. Used by the finance domain to trigger transfer tax calculations and GL entries in Yardi Voyager and SAP S/4HANA.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:typicalClosingDays rdf:type rdf:Property ;
    rdfs:label 'Typical Closing Days' ;
    rdfs:comment 'Standard number of calendar days from executed purchase and sale agreement to closing for transactions of this type. Used for deal timeline forecasting and pipeline velocity reporting in Salesforce CRM and Argus Enterprise.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yardiTransactionCode rdf:type rdf:Property ;
    rdfs:label 'Yardi Transaction Code' ;
    rdfs:comment 'Corresponding transaction type code as defined in Yardi Voyager, used for system integration and data lineage tracing between the enterprise data lakehouse and the Yardi source system.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentNodeGeographicHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Parent Node Geographic Hierarchy Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediate parent node in the geographic hierarchy (e.g., a submarket node\'s parent is its MSA node). Enables recursive hierarchy traversal for portfolio roll-up and drill-down analytics.' ;
    rdfs:domain ind:GeographicHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeographicHierarchy .

ind:areaSqm rdf:type rdf:Property ;
    rdfs:label 'Area Sqm' ;
    rdfs:comment 'Total land area of this geographic node measured in square meters (SQM). Used for density analysis, FAR calculations, and market size benchmarking in portfolio analytics.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cityName rdf:type rdf:Property ;
    rdfs:label 'City Name' ;
    rdfs:comment 'Name of the city or municipality for this geographic node. Used in property address standardization, lease administration in Yardi Voyager, and MLS syndication via Salesforce CRM.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costarSubmarketCode rdf:type rdf:Property ;
    rdfs:label 'Costar Submarket Code' ;
    rdfs:comment 'CoStar-assigned submarket identifier code used for market research, comparable lease and sales data alignment, and submarket-level vacancy and absorption analytics. Primary integration key with CoStar Suite.' ;
    rdfs:domain ind:GeographicHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costarSubmarketName rdf:type rdf:Property ;
    rdfs:label 'Costar Submarket Name' ;
    rdfs:comment 'CoStar-defined submarket name (e.g., \'Midtown Manhattan\', \'Beverly Hills/West Hollywood\'). Used for market benchmarking, CMA preparation, and BPO analysis aligned with CoStar Suite data.' ;
    rdfs:domain ind:GeographicHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enterpriseZoneFlag rdf:type rdf:Property ;
    rdfs:label 'Enterprise Zone Flag' ;
    rdfs:comment 'Indicates whether this geographic node is designated as a state or local enterprise zone, qualifying properties for tax incentives, development grants, or expedited permitting. Used in development feasibility analysis and CAPEX planning.' ;
    rdfs:domain ind:GeographicHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:esgClimateRiskZone rdf:type rdf:Property ;
    rdfs:label 'Esg Climate Risk Zone' ;
    rdfs:comment 'ESG climate risk classification for this geographic node based on exposure to physical climate risks (flood, wildfire, hurricane, sea-level rise). Used for ESG portfolio reporting, LEED/BREEAM site selection, and insurance underwriting support.' ;
    rdfs:domain ind:GeographicHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyDepth rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Depth' ;
    rdfs:comment 'Integer depth level of this node within the hierarchy tree, where 1 = country (root). Used to optimize hierarchy traversal queries and enforce level-specific business rules in portfolio analytics.' ;
    rdfs:domain ind:GeographicHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hudAreaCode rdf:type rdf:Property ;
    rdfs:label 'Hud Area Code' ;
    rdfs:comment 'U.S. Department of Housing and Urban Development (HUD) area code designating this geographic node for federal housing program eligibility, fair market rent (FMR) determination, and affordable housing compliance reporting.' ;
    rdfs:domain ind:GeographicHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketTier rdf:type rdf:Property ;
    rdfs:label 'Market Tier' ;
    rdfs:comment 'Classification of the market\'s investment grade and liquidity profile: primary (top-tier gateway markets, e.g., NYC, LA, Chicago), secondary (mid-size markets with strong fundamentals), or tertiary (smaller markets with higher risk/return profiles). Drives investment strategy, CAP rate benchmarking, and portfolio allocation decisions in Argus Enterprise.' ;
    rdfs:domain ind:GeographicHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medianHouseholdIncome rdf:type rdf:Property ;
    rdfs:label 'Median Household Income' ;
    rdfs:comment 'Median annual household income for this geographic node in the node\'s applicable currency. Used for residential affordability analysis, HUD area median income (AMI) benchmarking, and tenant demand modeling.' ;
    rdfs:domain ind:GeographicHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:msaName rdf:type rdf:Property ;
    rdfs:label 'Msa Name' ;
    rdfs:comment 'Official OMB name of the Metropolitan Statistical Area (e.g., \'New York-Newark-Jersey City, NY-NJ-PA MSA\'). Used in Argus Enterprise cash flow models, investment advisory reports, and portfolio benchmarking.' ;
    rdfs:domain ind:GeographicHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeCode rdf:type rdf:Property ;
    rdfs:label 'Node Code' ;
    rdfs:comment 'Externally-known, human-readable unique code identifying this geographic node (e.g., \'MSA-NYC\', \'STATE-CA\', \'ZIP-90210\', \'SUBMARKET-MIDTOWN\'). Used as the business key for cross-system integration with CoStar, Yardi, and MRI. Aligns with CoStar submarket codes and HUD geographic designations.' ;
    rdfs:domain ind:GeographicHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeName rdf:type rdf:Property ;
    rdfs:label 'Node Name' ;
    rdfs:comment 'Full human-readable name of the geographic node (e.g., \'New York-Newark-Jersey City MSA\', \'California\', \'Midtown Manhattan Submarket\'). Used in portfolio reports, dashboards, and regulatory filings.' ;
    rdfs:domain ind:GeographicHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeShortName rdf:type rdf:Property ;
    rdfs:label 'Node Short Name' ;
    rdfs:comment 'Abbreviated or commonly used short name for the geographic node (e.g., \'NYC MSA\', \'CA\', \'Midtown\'). Used in space-constrained UI labels, map overlays, and condensed reporting.' ;
    rdfs:domain ind:GeographicHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeStatus rdf:type rdf:Property ;
    rdfs:label 'Node Status' ;
    rdfs:comment 'Current lifecycle status of this geographic hierarchy node. Active nodes are used in portfolio assignments and reporting. Deprecated nodes are retained for historical data integrity. Pending review nodes are under validation before activation.' ;
    rdfs:domain ind:GeographicHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:population rdf:type rdf:Property ;
    rdfs:label 'Population' ;
    rdfs:comment 'Most recent census or estimated population count for this geographic node. Used as a demand driver in residential market analysis, HUD program sizing, and investment advisory demographic modeling.' ;
    rdfs:domain ind:GeographicHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:populationYear rdf:type rdf:Property ;
    rdfs:label 'Population Year' ;
    rdfs:comment 'The reference year for the population count recorded in this node (e.g., 2020 for the decennial census). Ensures temporal accuracy in demographic-driven investment analysis.' ;
    rdfs:domain ind:GeographicHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction Code' ;
    rdfs:comment 'Code identifying the primary regulatory jurisdiction governing real estate activities in this geographic node (e.g., state real estate commission code, municipal zoning authority code). Used for license compliance tracking, NAR/state board reporting, and OSHA/EPA regulatory mapping.' ;
    rdfs:domain ind:GeographicHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvinceCode rdf:type rdf:Property ;
    rdfs:label 'State Province Code' ;
    rdfs:comment 'ISO 3166-2 subdivision code for the state or province (e.g., \'CA\', \'NY\', \'TX\'). Used for state-level regulatory compliance, tax jurisdiction mapping, and HUD reporting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvinceName rdf:type rdf:Property ;
    rdfs:label 'State Province Name' ;
    rdfs:comment 'Full name of the state or province (e.g., \'California\', \'New York\'). Used in lease administration, regulatory filings, and portfolio reporting within Yardi Voyager and MRI Software.' ;
    rdfs:domain ind:GeographicHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Code identifying the tax jurisdiction applicable to properties in this geographic node. Used for property tax assessment, transfer tax calculation, and SAP S/4HANA tax configuration for financial consolidation.' ;
    rdfs:domain ind:GeographicHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unemploymentRate rdf:type rdf:Property ;
    rdfs:label 'Unemployment Rate' ;
    rdfs:comment 'Most recent unemployment rate (as a percentage) for this geographic node. Used as a macroeconomic indicator in CRE investment analysis, NOI forecasting, and portfolio risk assessment in Argus Enterprise.' ;
    rdfs:domain ind:GeographicHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zipPostalCode rdf:type rdf:Property ;
    rdfs:label 'Zip Postal Code' ;
    rdfs:comment 'ZIP code (USA) or postal code (international) for this geographic node. Used for property address validation, HUD program area mapping, tax jurisdiction assignment, and GIS-based portfolio analysis.' ;
    rdfs:domain ind:GeographicHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSteward rdf:type rdf:Property ;
    rdfs:label 'Data Steward' ;
    rdfs:comment 'Name or identifier of the business data steward responsible for maintaining the accuracy and completeness of this market segment record. Supports data governance accountability and reference data change management processes.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developmentAllowed rdf:type rdf:Property ;
    rdfs:label 'Development Allowed' ;
    rdfs:comment 'Indicates whether ground-up development or major redevelopment projects are permitted within this market segment\'s investment mandate (True = allowed, False = not allowed). Opportunistic segments typically allow development; core segments do not.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distressedAssetEligible rdf:type rdf:Property ;
    rdfs:label 'Distressed Asset Eligible' ;
    rdfs:comment 'Indicates whether distressed, REO (Real Estate Owned), or impaired assets are eligible for acquisition under this market segment (True = eligible). Used in deal sourcing filters and investment committee approval workflows.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equityMultipleMax rdf:type rdf:Property ;
    rdfs:label 'Equity Multiple Max' ;
    rdfs:comment 'Maximum target equity multiple for investments in this market segment (e.g., 2.50x for opportunistic). Defines the upper bound of expected return multiples used in fund performance benchmarking and investor reporting.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equityMultipleMin rdf:type rdf:Property ;
    rdfs:label 'Equity Multiple Min' ;
    rdfs:comment 'Minimum target equity multiple (total distributions / total equity invested) for investments in this market segment (e.g., 1.50x for core-plus). Used alongside IRR in investor return reporting and deal underwriting benchmarks.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exitStrategy rdf:type rdf:Property ;
    rdfs:label 'Exit Strategy' ;
    rdfs:comment 'Primary exit strategy indicator for investments in this market segment. Defines the expected disposition mechanism: outright sale, recapitalization, refinance and hold, IPO/REIT listing, long-term hold, or portfolio/bulk sale. Used in investment advisory, asset management planning, and investor reporting.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalBenchmarkName rdf:type rdf:Property ;
    rdfs:label 'External Benchmark Name' ;
    rdfs:comment 'Name of the primary external performance benchmark associated with this market segment for investor reporting (e.g., \'NCREIF Property Index\', \'NCREIF ODCE\', \'MSCI Real Estate\', \'INREV All Vehicles Index\'). Used in Argus Enterprise portfolio reporting and investor presentations.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicFocus rdf:type rdf:Property ;
    rdfs:label 'Geographic Focus' ;
    rdfs:comment 'Describes the geographic investment focus associated with this market segment (e.g., \'Gateway markets only\', \'Secondary and tertiary markets\', \'National diversified\', \'Sun Belt metros\'). Used in deal sourcing strategy, CoStar market research filters, and portfolio geographic allocation reporting.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdPeriodMaxYears rdf:type rdf:Property ;
    rdfs:label 'Hold Period Max Years' ;
    rdfs:comment 'Maximum typical investment hold period in years for assets classified under this market segment (e.g., 10.0 years for core). Used in fund lifecycle planning, Discounted Cash Flow (DCF) horizon setting, and exit strategy modeling in Argus Enterprise.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdPeriodMinYears rdf:type rdf:Property ;
    rdfs:label 'Hold Period Min Years' ;
    rdfs:comment 'Minimum typical investment hold period in years for assets classified under this market segment (e.g., 3.0 years for value-add). Used in Argus Enterprise DCF modeling, Weighted Average Lease Term (WALT) analysis, and investor fund lifecycle planning.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incomeReturnFocus rdf:type rdf:Property ;
    rdfs:label 'Income Return Focus' ;
    rdfs:comment 'Indicates whether this market segment is primarily income-return focused (True) versus capital appreciation focused (False). Core and core-plus segments are typically income-focused; opportunistic and value-add are appreciation-focused. Used in portfolio allocation and investor mandate classification.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inrevStrategyCode rdf:type rdf:Property ;
    rdfs:label 'Inrev Strategy Code' ;
    rdfs:comment 'INREV (European Association for Investors in Non-Listed Real Estate Vehicles) strategy classification code for cross-border fund reporting alignment. Used for European investor mandates and INREV benchmark submissions.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentStrategyType rdf:type rdf:Property ;
    rdfs:label 'Investment Strategy Type' ;
    rdfs:comment 'Classification of the investment strategy associated with this market segment per industry-standard NCREIF/INREV taxonomy. Core = stabilized, low-risk; Core-Plus = modest value creation; Value-Add = significant repositioning; Opportunistic = high-risk/high-return development or turnaround; Distressed = below-market acquisition of impaired assets. Null for residential segments where strategy type is not applicable.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investorTypeTarget rdf:type rdf:Property ;
    rdfs:label 'Investor Type Target' ;
    rdfs:comment 'Describes the target investor profile for this market segment (e.g., \'Institutional pension funds\', \'High-net-worth individuals\', \'Family offices\', \'Sovereign wealth funds\'). Used in investor relations, fund marketing, and Salesforce CRM deal pipeline classification.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'Date on which this market segment definition was last reviewed and validated by the data steward or investment committee. Supports reference data governance, periodic review cycles, and audit trail requirements.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leverageStrategy rdf:type rdf:Property ;
    rdfs:label 'Leverage Strategy' ;
    rdfs:comment 'Qualitative leverage strategy descriptor for the market segment. Unlevered = all-equity; Low = LTV < 40%; Moderate = LTV 40–60%; High = LTV > 60%. Complements the target_ltv_max_pct field for narrative reporting and investor mandate screening.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncreifBenchmarkCode rdf:type rdf:Property ;
    rdfs:label 'Ncreif Benchmark Code' ;
    rdfs:comment 'NCREIF Property Index benchmark code associated with this market segment for performance comparison (e.g., NPI, ODCE). Used in portfolio performance reporting, investor presentations, and Argus Enterprise benchmark analysis.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occupancyThresholdMinPct rdf:type rdf:Property ;
    rdfs:label 'Occupancy Threshold Min Pct' ;
    rdfs:comment 'Minimum acceptable physical occupancy percentage for assets classified under this market segment at acquisition or during the hold period (e.g., 85.00 for 85%). Used in deal screening, underwriting assumptions, and Yardi Voyager lease administration reporting.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:propertyTypeFocus rdf:type rdf:Property ;
    rdfs:label 'Property Type Focus' ;
    rdfs:comment 'Describes the primary property type(s) targeted by this market segment (e.g., \'Office, Retail, Industrial\', \'Multifamily\', \'Mixed-Use\'). Used in deal sourcing filters, CoStar comparable analysis, and portfolio sector allocation reporting. Free-text to accommodate multi-type segments.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Notes' ;
    rdfs:comment 'Free-text field capturing specific regulatory or compliance considerations applicable to this market segment (e.g., HUD affordability restrictions for affordable housing, REIT distribution requirements, SEC reporting obligations for publicly traded vehicles, LIHTC compliance for tax credit properties).' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residentialTier rdf:type rdf:Property ;
    rdfs:label 'Residential Tier' ;
    rdfs:comment 'Residential market tier classification for residential segments. Affordable = income-restricted housing (HUD AMI thresholds); Workforce = moderate-income households; Market-Rate = unsubsidized standard rental/for-sale; Luxury = premium amenity-rich product. Null for commercial segments.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskProfile rdf:type rdf:Property ;
    rdfs:label 'Risk Profile' ;
    rdfs:comment 'Qualitative risk descriptor for the market segment, reflecting expected volatility, leverage sensitivity, and execution complexity. Used in investor mandate screening, portfolio risk reporting, and deal approval workflows. Aligns with INREV risk classification framework.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCategory rdf:type rdf:Property ;
    rdfs:label 'Segment Category' ;
    rdfs:comment 'Broad asset class category to which this market segment belongs. Distinguishes commercial investment strategies (core, core-plus, value-add, opportunistic, distressed) from residential strategies (affordable, workforce, market-rate, luxury) and other asset classes. Drives portfolio allocation reporting and investor mandate compliance.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Detailed narrative description of the market segment, including its investment thesis, risk characteristics, typical asset profile, and use cases. Used in investor reporting, investment committee materials, and data governance documentation.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Full human-readable name of the market segment (e.g., \'Core\', \'Core-Plus\', \'Value-Add\', \'Opportunistic\', \'Distressed\', \'Affordable Housing\', \'Workforce Housing\', \'Market-Rate\', \'Luxury\'). Displayed in investor reports, portfolio dashboards, and deal classification screens.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCapRateMaxPct rdf:type rdf:Property ;
    rdfs:label 'Target Cap Rate Max Pct' ;
    rdfs:comment 'Maximum target Capitalization Rate (CAP Rate) percentage for acquisitions in this market segment, expressed as a percentage (e.g., 7.00 for 7%). Defines the upper bound of the CAP rate range used in deal screening and portfolio benchmarking.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetCapRateMinPct rdf:type rdf:Property ;
    rdfs:label 'Target Cap Rate Min Pct' ;
    rdfs:comment 'Minimum target Capitalization Rate (CAP Rate) percentage for acquisitions in this market segment, expressed as a percentage (e.g., 4.50 for 4.5%). CAP Rate = Net Operating Income (NOI) / Property Value. Used in Argus Enterprise underwriting models and CoStar comparable analysis.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetDscrMin rdf:type rdf:Property ;
    rdfs:label 'Target Dscr Min' ;
    rdfs:comment 'Minimum acceptable Debt Service Coverage Ratio (DSCR) for assets in this market segment (e.g., 1.25). DSCR = Net Operating Income (NOI) / Total Debt Service. Used in lender covenant compliance, debt instrument structuring, and portfolio risk monitoring.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetIrrMaxPct rdf:type rdf:Property ;
    rdfs:label 'Target Irr Max Pct' ;
    rdfs:comment 'Maximum target Internal Rate of Return (IRR) percentage for investments classified under this market segment, expressed as a percentage (e.g., 15.00 for 15%). Defines the upper bound of the IRR range used in deal underwriting and investor mandate compliance checks.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetIrrMinPct rdf:type rdf:Property ;
    rdfs:label 'Target Irr Min Pct' ;
    rdfs:comment 'Minimum target unlevered or levered Internal Rate of Return (IRR) percentage for investments classified under this market segment, expressed as a percentage (e.g., 8.00 for 8%). Defines the lower bound of the IRR range used in deal underwriting, Argus Enterprise cash flow models, and investor reporting against NCREIF benchmarks.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetLtvMaxPct rdf:type rdf:Property ;
    rdfs:label 'Target Ltv Max Pct' ;
    rdfs:comment 'Maximum target Loan-to-Value (LTV) ratio percentage for debt financing on assets in this market segment, expressed as a percentage (e.g., 65.00 for 65%). Defines the leverage ceiling used in debt structuring, CMBS underwriting, and DSCR compliance monitoring.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalAssetSizeMaxUsd rdf:type rdf:Property ;
    rdfs:label 'Typical Asset Size Max Usd' ;
    rdfs:comment 'Maximum typical asset value in USD for investments classified under this market segment (e.g., 500,000,000 for $500M). Defines the upper bound of deal size for mandate compliance and portfolio concentration limits.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalAssetSizeMinUsd rdf:type rdf:Property ;
    rdfs:label 'Typical Asset Size Min Usd' ;
    rdfs:comment 'Minimum typical asset value in USD for investments classified under this market segment (e.g., 10,000,000 for $10M). Used in deal sourcing filters, portfolio allocation guidelines, and investment mandate compliance in MRI Software and Argus Enterprise.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valueCreationApproach rdf:type rdf:Property ;
    rdfs:label 'Value Creation Approach' ;
    rdfs:comment 'Narrative description of the primary value creation approach for this market segment (e.g., \'Stabilized income with minimal capital expenditure\', \'Lease-up of vacant space with light renovation\', \'Major repositioning, redevelopment, or change of use\'). Used in investment committee presentations and investor reporting.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affordableHousingRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Affordable Housing Requirement Flag' ;
    rdfs:comment 'Indicates whether this zoning designation includes an inclusionary zoning requirement mandating a percentage of residential units be designated as affordable housing. True = affordable housing set-aside required; False = no such requirement. Relevant for HUD compliance and residential development planning.' ;
    rdfs:domain ind:ZoningCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conditionalUses rdf:type rdf:Property ;
    rdfs:label 'Conditional Uses' ;
    rdfs:comment 'Narrative description of land uses that may be permitted under this zoning designation subject to approval of a Conditional Use Permit (CUP) by the governing authority. Relevant for development feasibility and entitlement risk assessment.' ;
    rdfs:domain ind:ZoningCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:densityClass rdf:type rdf:Property ;
    rdfs:label 'Density Class' ;
    rdfs:comment 'Density classification associated with the zoning designation, indicating the intensity of permitted land use. Used in development feasibility analysis and portfolio density reporting.' ;
    rdfs:domain ind:ZoningCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalOverlayFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Overlay Flag' ;
    rdfs:comment 'Indicates whether this zoning designation includes or is subject to an environmental overlay or restriction (e.g., flood zone, wetlands buffer, brownfield remediation zone, EPA-designated area). True = environmental overlay applies; False = no environmental overlay.' ;
    rdfs:domain ind:ZoningCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:esgDesignation rdf:type rdf:Property ;
    rdfs:label 'Esg Designation' ;
    rdfs:comment 'ESG-related zoning designation or incentive associated with this zoning code, indicating whether the jurisdiction mandates or incentivizes green building standards such as LEED or BREEAM for developments under this designation. Supports ESG portfolio reporting.' ;
    rdfs:domain ind:ZoningCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:farMax rdf:type rdf:Property ;
    rdfs:label 'Far Max' ;
    rdfs:comment 'Maximum Floor Area Ratio (FAR) permitted under this zoning designation, expressed as the ratio of total building floor area to the area of the parcel. A FAR of 2.0 means total floor area may be up to twice the lot area. Critical input for development feasibility analysis in Argus Enterprise and CoStar.' ;
    rdfs:domain ind:ZoningCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:farMin rdf:type rdf:Property ;
    rdfs:label 'Far Min' ;
    rdfs:comment 'Minimum Floor Area Ratio (FAR) required under this zoning designation, where applicable. Some jurisdictions mandate minimum development intensity to prevent underutilization of zoned land.' ;
    rdfs:domain ind:ZoningCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gisLayerReference rdf:type rdf:Property ;
    rdfs:label 'Gis Layer Reference' ;
    rdfs:comment 'Reference identifier or URL for the municipal Geographic Information System (GIS) layer or dataset from which this zoning designation is sourced. Enables spatial data integration with CoStar Suite and enterprise GIS platforms.' ;
    rdfs:domain ind:ZoningCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heightLimitFt rdf:type rdf:Property ;
    rdfs:label 'Height Limit Ft' ;
    rdfs:comment 'Maximum permitted building height in feet as specified by the zoning designation. Used in development feasibility analysis, BIM planning, and construction oversight in Procore.' ;
    rdfs:domain ind:ZoningCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:heightLimitStories rdf:type rdf:Property ;
    rdfs:label 'Height Limit Stories' ;
    rdfs:comment 'Maximum permitted number of building stories as specified by the zoning designation, where the jurisdiction expresses height restrictions in stories rather than feet.' ;
    rdfs:domain ind:ZoningCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:jurisdictionName rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Name' ;
    rdfs:comment 'Name of the municipal or county authority that issued and administers this zoning designation (e.g., \'City of Los Angeles\', \'Cook County\', \'City of New York\'). Enables multi-jurisdiction portfolio management.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionType rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Type' ;
    rdfs:comment 'Type of governing authority that administers this zoning code, distinguishing between city, county, township, or special district jurisdictions.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotCoveragePct rdf:type rdf:Property ;
    rdfs:label 'Lot Coverage Pct' ;
    rdfs:comment 'Maximum percentage of the lot area that may be covered by buildings and impervious structures under this zoning designation. Expressed as a percentage (e.g., 60.00 = 60%). Used in site planning and development feasibility.' ;
    rdfs:domain ind:ZoningCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minLotSizeSqf rdf:type rdf:Property ;
    rdfs:label 'Min Lot Size Sqf' ;
    rdfs:comment 'Minimum parcel area in square feet (SQF) required for a lot to be developed under this zoning designation. Critical for subdivision analysis and land acquisition due diligence.' ;
    rdfs:domain ind:ZoningCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minLotWidthFt rdf:type rdf:Property ;
    rdfs:label 'Min Lot Width Ft' ;
    rdfs:comment 'Minimum required lot frontage width in feet as specified by the zoning designation. Affects parcel subdivision feasibility and site design.' ;
    rdfs:domain ind:ZoningCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ordinanceReference rdf:type rdf:Property ;
    rdfs:label 'Ordinance Reference' ;
    rdfs:comment 'Official ordinance number, resolution number, or legislative reference that established or most recently amended this zoning designation (e.g., \'Ordinance No. 2023-045\'). Supports regulatory compliance documentation and audit trails.' ;
    rdfs:domain ind:ZoningCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overlayDistrictFlag rdf:type rdf:Property ;
    rdfs:label 'Overlay District Flag' ;
    rdfs:comment 'Indicates whether this zoning code represents a special overlay district that applies supplemental regulations on top of a base zoning designation (e.g., historic preservation overlay, flood plain overlay, transit corridor overlay). True = overlay district; False = base zoning designation.' ;
    rdfs:domain ind:ZoningCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parkingRatioMin rdf:type rdf:Property ;
    rdfs:label 'Parking Ratio Min' ;
    rdfs:comment 'Minimum required off-street parking spaces per unit of use (e.g., spaces per 1,000 SQF of GLA, or spaces per residential unit) as mandated by this zoning designation. Used in development feasibility and site planning.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parkingRatioUnit rdf:type rdf:Property ;
    rdfs:label 'Parking Ratio Unit' ;
    rdfs:comment 'Unit of measure denominator for the minimum parking ratio (e.g., \'per_1000_sqf\' for commercial uses, \'per_unit\' for residential uses). Provides context for interpreting the parking_ratio_min value.' ;
    rdfs:domain ind:ZoningCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permittedUses rdf:type rdf:Property ;
    rdfs:label 'Permitted Uses' ;
    rdfs:comment 'Narrative or semi-structured description of land uses permitted by right under this zoning designation without requiring a conditional use permit or variance (e.g., \'Single-family detached dwellings, accessory structures, home occupations\'). Sourced from municipal zoning ordinance text.' ;
    rdfs:domain ind:ZoningCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prohibitedUses rdf:type rdf:Property ;
    rdfs:label 'Prohibited Uses' ;
    rdfs:comment 'Narrative description of land uses explicitly prohibited under this zoning designation. Critical for acquisition due diligence and regulatory compliance screening.' ;
    rdfs:domain ind:ZoningCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rezoningPendingFlag rdf:type rdf:Property ;
    rdfs:label 'Rezoning Pending Flag' ;
    rdfs:comment 'Indicates whether a formal rezoning application or amendment is currently pending with the governing jurisdiction for this zoning designation. True = active rezoning proceeding; False = no pending rezoning. Relevant for portfolio risk monitoring.' ;
    rdfs:domain ind:ZoningCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateCode rdf:type rdf:Property ;
    rdfs:label 'State Code' ;
    rdfs:comment 'Two-letter U.S. state abbreviation (ISO 3166-2:US) or equivalent provincial/regional code for the jurisdiction in which this zoning designation applies. Supports geographic filtering and regulatory compliance reporting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'Secondary classification providing finer granularity within the primary category (e.g., \'Single-Family Low Density\', \'Neighborhood Commercial\', \'Heavy Industrial\', \'Transit-Oriented Mixed-Use\'). [ENUM-REF-CANDIDATE: single_family_low_density|single_family_medium_density|multifamily|neighborhood_commercial|general_commercial|regional_commercial|light_industrial|heavy_industrial|mixed_use_residential|mixed_use_commercial|transit_oriented|agricultural_general|agricultural_conservation — promote to reference product]' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Variance Allowed Flag' ;
    rdfs:comment 'Indicates whether the governing jurisdiction permits applications for variances from the standard development regulations associated with this zoning designation. True = variances may be applied for; False = no variance process available.' ;
    rdfs:domain ind:ZoningCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:varianceHistoryNotes rdf:type rdf:Property ;
    rdfs:label 'Variance History Notes' ;
    rdfs:comment 'Free-text notes summarizing the history of variances granted or denied for properties under this zoning designation. Supports development feasibility analysis and entitlement risk assessment.' ;
    rdfs:domain ind:ZoningCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoningCodeCategory rdf:type rdf:Property ;
    rdfs:label 'Zoning Code Category' ;
    rdfs:comment 'High-level classification grouping the zoning code into a primary land-use category. Drives portfolio segmentation, development feasibility screening, and regulatory compliance reporting. [ENUM-REF-CANDIDATE: residential|commercial|industrial|mixed_use|agricultural|special_overlay|planned_development|open_space — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ZoningCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoningCodeCode rdf:type rdf:Property ;
    rdfs:label 'Zoning Code Code' ;
    rdfs:comment 'Official alphanumeric zoning designation assigned by the governing municipality or county (e.g., R1, C2, I1, MU, A, PD). This is the externally-recognized code used in regulatory filings, title reports, and GIS databases.' ;
    rdfs:domain ind:ZoningCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoningCodeDescription rdf:type rdf:Property ;
    rdfs:label 'Zoning Code Description' ;
    rdfs:comment 'Extended narrative description of the zoning designation, including its planning intent, applicable land use policies, and any special conditions or notes sourced from the municipal zoning ordinance. Provides context for business users and analysts.' ;
    rdfs:domain ind:ZoningCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoningCodeName rdf:type rdf:Property ;
    rdfs:label 'Zoning Code Name' ;
    rdfs:comment 'Full descriptive name of the zoning designation as defined by the issuing jurisdiction (e.g., \'Single-Family Residential\', \'General Commercial\', \'Light Industrial\', \'Mixed-Use Corridor\').' ;
    rdfs:domain ind:ZoningCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoningCodeStatus rdf:type rdf:Property ;
    rdfs:label 'Zoning Code Status' ;
    rdfs:comment 'Current lifecycle status of the zoning code record within the enterprise reference registry. \'active\' indicates the code is currently in force; \'superseded\' indicates it has been replaced by a newer designation; \'pending_amendment\' indicates a formal rezoning or amendment is in progress.' ;
    rdfs:domain ind:ZoningCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionFactor rdf:type rdf:Property ;
    rdfs:label 'Conversion Factor' ;
    rdfs:comment 'Fixed conversion factor applied when this currency was replaced by a successor currency (e.g., 1 EUR = 1.95583 DEM). Applicable only to discontinued currencies with a defined successor. Used for historical financial restatement and legacy portfolio valuation in Argus Enterprise and SAP S/4HANA.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currencyCodeCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code Code' ;
    rdfs:comment 'Three-letter alphabetic currency code as defined by ISO 4217 (e.g., USD, EUR, GBP, CAD, AUD, JPY). Used as the business-facing identifier across all financial systems including Yardi Voyager AP/AR, SAP S/4HANA GL, MRI Software, and Argus Enterprise for multi-currency portfolio operations.' ;
    rdfs:domain ind:CurrencyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyCodeName rdf:type rdf:Property ;
    rdfs:label 'Currency Code Name' ;
    rdfs:comment 'Full official name of the currency as defined by ISO 4217 (e.g., United States Dollar, Euro, British Pound Sterling). Displayed in financial reports, Argus Enterprise valuation models, and investor-facing portfolio reporting for clarity.' ;
    rdfs:domain ind:CurrencyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyType rdf:type rdf:Property ;
    rdfs:label 'Currency Type' ;
    rdfs:comment 'Classification of the currency by its underlying nature. Fiat currencies are government-issued legal tender (the vast majority of ISO 4217 codes). SDR (Special Drawing Rights) is the IMF composite currency. Precious metal codes (XAU for gold, XAG for silver) and crypto codes may appear in investment portfolios or alternative asset valuations.' ;
    rdfs:domain ind:CurrencyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decimalSeparator rdf:type rdf:Property ;
    rdfs:label 'Decimal Separator' ;
    rdfs:comment 'Character used as the decimal point separator when displaying monetary amounts in this currency (e.g., period for USD/GBP, comma for EUR in many European countries). Critical for correct parsing and display of financial figures in multi-locale real estate reporting environments.' ;
    rdfs:domain ind:CurrencyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'Date on which this currency code was officially discontinued or superseded per ISO 4217 (e.g., legacy national currencies replaced by EUR). Null for currently active currencies. Retained for historical lease and transaction records in Yardi Voyager and MRI Software that reference the discontinued currency.' ;
    rdfs:domain ind:CurrencyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:displayFormat rdf:type rdf:Property ;
    rdfs:label 'Display Format' ;
    rdfs:comment 'Locale-specific display format pattern for rendering monetary amounts in this currency (e.g., #,##0.00 for USD, #.##0,00 for EUR in European locales). Controls how currency values are presented in investor reports, NOI statements, and Argus Enterprise output for international portfolio stakeholders.' ;
    rdfs:domain ind:CurrencyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRateSource rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Source' ;
    rdfs:comment 'Name or identifier of the authoritative external source used to obtain exchange rates for this currency (e.g., European Central Bank, Federal Reserve, Bloomberg, Reuters/Refinitiv, ICE). Governs which rate feed is consumed by SAP S/4HANA and Yardi Voyager for currency translation in AP/AR and GL consolidation.' ;
    rdfs:domain ind:CurrencyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRateType rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Type' ;
    rdfs:comment 'Type of exchange rate applied when translating this currency for financial reporting purposes. Spot rate is used for transaction-date translation; average rate for income statement items; closing rate for balance sheet items per FASB ASC 830 and IAS 21. Budget rate is used for planning in Argus Enterprise DCF models.' ;
    rdfs:domain ind:CurrencyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFreelyConvertible rdf:type rdf:Property ;
    rdfs:label 'Is Freely Convertible' ;
    rdfs:comment 'Indicates whether this currency can be freely exchanged for other currencies without government restrictions or capital controls. Non-convertible or restricted currencies require special handling in cross-border real estate investment structures, repatriation planning, and REIT distribution calculations.' ;
    rdfs:domain ind:CurrencyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFunctionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Is Functional Currency' ;
    rdfs:comment 'Indicates whether this currency is designated as the functional currency for the enterprise or a specific legal entity under FASB ASC 830 (Foreign Currency Matters) or IASB IAS 21. The functional currency is the primary currency of the economic environment in which the REIT or fund entity operates, used as the base for financial consolidation in SAP S/4HANA.' ;
    rdfs:domain ind:CurrencyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHardCurrency rdf:type rdf:Property ;
    rdfs:label 'Is Hard Currency' ;
    rdfs:comment 'Indicates whether this currency is classified as a hard currency — a globally accepted, stable reserve currency (e.g., USD, EUR, GBP, JPY, CHF). Hard currency designation influences lease denomination decisions in international commercial real estate, particularly for NNN leases in emerging markets where rents may be quoted in USD or EUR.' ;
    rdfs:domain ind:CurrencyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReportingCurrency rdf:type rdf:Property ;
    rdfs:label 'Is Reporting Currency' ;
    rdfs:comment 'Indicates whether this currency is designated as the reporting currency for consolidated financial statements and SEC/regulatory filings. Distinct from functional currency — a REIT may operate in multiple functional currencies but report in a single reporting currency (typically USD) for investor and regulatory purposes.' ;
    rdfs:domain ind:CurrencyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso4217Status rdf:type rdf:Property ;
    rdfs:label 'Iso 4217 Status' ;
    rdfs:comment 'Official status of the currency code within the ISO 4217 standard. Active codes are currently in circulation; historic codes have been withdrawn or superseded; fund codes represent monetary funds (e.g., XDR for SDR). Drives eligibility rules for new transaction entry across Yardi Voyager, MRI Software, and SAP S/4HANA.' ;
    rdfs:domain ind:CurrencyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minorUnitDecimalPlaces rdf:type rdf:Property ;
    rdfs:label 'Minor Unit Decimal Places' ;
    rdfs:comment 'Number of decimal places used for the minor unit of the currency as specified by ISO 4217 (e.g., 2 for USD/EUR/GBP representing cents, 0 for JPY/KWD which has no minor unit, 3 for KWD). Critical for correct rounding in AP/AR processing in Yardi Voyager, rent schedule calculations, and FASB/IASB-compliant financial reporting.' ;
    rdfs:domain ind:CurrencyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numericCode rdf:type rdf:Property ;
    rdfs:label 'Numeric Code' ;
    rdfs:comment 'Three-digit numeric code assigned to the currency under ISO 4217 (e.g., 840 for USD, 978 for EUR). Used in electronic data interchange, CMBS/RMBS reporting, and SAP S/4HANA financial consolidation where numeric codes are required for system interoperability.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Broad geographic region associated with the currency (e.g., North America, Europe, Asia Pacific, Middle East, Latin America). Used for regional portfolio aggregation, cross-border investment analysis, and AUM reporting in Argus Enterprise and MRI Software.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roundingRule rdf:type rdf:Property ;
    rdfs:label 'Rounding Rule' ;
    rdfs:comment 'Rounding convention applied to monetary amounts in this currency during financial calculations, AP/AR processing, and rent schedule generation. Half-even (banker\'s rounding) is standard for FASB/IASB-compliant financial reporting. Governs rounding behavior in Yardi Voyager rent calculations, CAM reconciliations, and SAP S/4HANA GL postings.' ;
    rdfs:domain ind:CurrencyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCurrencyKey rdf:type rdf:Property ;
    rdfs:label 'Source System Currency Key' ;
    rdfs:comment 'Native key or identifier used to represent this currency in the originating source system (e.g., SAP currency key \'USD\', Yardi currency code field value). Enables cross-system reconciliation and ETL mapping between the enterprise reference registry and operational systems.' ;
    rdfs:domain ind:CurrencyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subunitName rdf:type rdf:Property ;
    rdfs:label 'Subunit Name' ;
    rdfs:comment 'Name of the minor unit or subunit of the currency (e.g., Cent for USD/EUR, Penny for GBP, Sen for JPY). Used in detailed financial disclosures, lease rent schedules expressed in subunit precision, and CAM reconciliation statements in Yardi Voyager.' ;
    rdfs:domain ind:CurrencyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successorCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Successor Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter code of the currency that replaced this currency upon discontinuation (e.g., EUR as successor to DEM, FRF, ITL). Used to support currency migration mapping for historical portfolio restatement and financial consolidation in SAP S/4HANA.' ;
    rdfs:domain ind:CurrencyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:symbol rdf:type rdf:Property ;
    rdfs:label 'Symbol' ;
    rdfs:comment 'Commonly used typographic symbol representing the currency (e.g., $ for USD, € for EUR, £ for GBP, ¥ for JPY). Used in UI displays, lease rent schedules, NOI statements, and investor reporting dashboards for human-readable financial presentation.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:symbolPosition rdf:type rdf:Property ;
    rdfs:label 'Symbol Position' ;
    rdfs:comment 'Indicates whether the currency symbol is displayed before (prefix) or after (suffix) the numeric amount per locale convention (e.g., prefix for USD: $1,000; suffix for SEK: 1 000 kr). Used in report rendering engines for investor communications and tenant-facing financial statements.' ;
    rdfs:domain ind:CurrencyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thousandsSeparator rdf:type rdf:Property ;
    rdfs:label 'Thousands Separator' ;
    rdfs:comment 'Character used as the thousands grouping separator when displaying monetary amounts in this currency (e.g., comma for USD/GBP, period for EUR in many European countries, space for CHF). Ensures correct formatting in investor-facing financial reports and lease abstracts.' ;
    rdfs:domain ind:CurrencyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volatilityClassification rdf:type rdf:Property ;
    rdfs:label 'Volatility Classification' ;
    rdfs:comment 'Classification of the currency\'s exchange rate volatility relative to major reserve currencies. Hyperinflationary designation triggers special accounting treatment under FASB ASC 830-10-45 and IAS 29 for real estate entities operating in those economies. Informs FX risk management and hedging strategy for international portfolio investments.' ;
    rdfs:domain ind:CurrencyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uomId rdf:type rdf:Property ;
    rdfs:label 'Uom Id' ;
    rdfs:comment 'Unique surrogate identifier for each unit-of-measure record in the enterprise UOM registry. Primary key. [REFERENCE_LOOKUP role — canonical_skip_reason: This entity is a controlled vocabulary / code-list table; per-role minimum categories do not apply.]' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Uom .

ind:applicablePropertyTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Property Types' ;
    rdfs:comment 'Comma-separated list of property type codes for which this UOM is valid (e.g., \'office,retail,industrial\' for SQF; \'land\' for acres; \'parking\' for stalls). Restricts UOM selection in Yardi Voyager lease setup and MRI Software property configuration to contextually appropriate measures.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaStandard rdf:type rdf:Property ;
    rdfs:label 'Area Standard' ;
    rdfs:comment 'For area-dimension UOMs, the industry measurement standard that defines how the area is calculated (e.g., BOMA for US office, IPMS for international, GLA for retail, NLA for net leasable area, GFA for gross floor area). Null for non-area UOMs. Critical for appraisal compliance and cross-border portfolio comparability. [ENUM-REF-CANDIDATE: BOMA|IPMS|GLA|NLA|GFA|RICS|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionFormula rdf:type rdf:Property ;
    rdfs:label 'Conversion Formula' ;
    rdfs:comment 'Optional algebraic formula string for non-linear conversions where a simple multiplicative factor is insufficient (e.g., temperature scales). For most real estate UOMs this is null; populated only when the conversion requires an offset or compound expression.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultRegionCode rdf:type rdf:Property ;
    rdfs:label 'Default Region Code' ;
    rdfs:comment 'ISO 3166-1 alpha-2 or alpha-3 country/region code for which this UOM is the default standard (e.g., US for SQF, DE/GB/AU for SQM). Drives automatic UOM defaulting in Yardi Voyager and MRI Software when creating properties in a given jurisdiction.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionType rdf:type rdf:Property ;
    rdfs:label 'Dimension Type' ;
    rdfs:comment 'Physical or financial dimension category the UOM belongs to: area (SQF, SQM, GLA, NLA, GFA), linear (LF, LM), volume (CF, CM), weight (LB, KG), rate (PSF/year, PSM/month), count (units, floors), currency (USD, EUR), or other. Drives validation rules in rent calculations and valuation models. [ENUM-REF-CANDIDATE: area|linear|volume|weight|rate|count|currency|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayOrder rdf:type rdf:Property ;
    rdfs:label 'Display Order' ;
    rdfs:comment 'Integer sort order controlling the sequence in which UOMs appear in dropdown lists and selection menus across Yardi Voyager, MRI Software, and Argus Enterprise. Lower values appear first; commonly used UOMs (SQF, SQM) are assigned low values.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isBaseUnit rdf:type rdf:Property ;
    rdfs:label 'Is Base Unit' ;
    rdfs:comment 'Indicates whether this UOM is the designated base unit for its dimension type and measurement system (True = base unit; False = derived unit). Base units have a conversion_factor of exactly 1.0.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRateBased rdf:type rdf:Property ;
    rdfs:label 'Is Rate Based' ;
    rdfs:comment 'Indicates whether this UOM is a rate measure combining a quantity dimension with a time period (e.g., PSF/year, PSM/month, $/SQF/year). Rate-based UOMs require both a numerator UOM and a denominator time period for correct rent and NOI calculations.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryDisclosureRequired rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Disclosure Required' ;
    rdfs:comment 'Indicates whether values expressed in this UOM must be disclosed in regulatory filings (True = required). For example, GLA in SQF/SQM is required in SEC REIT filings, HUD disclosures, and LEED/BREEAM certification submissions.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRentableAreaMeasure rdf:type rdf:Property ;
    rdfs:label 'Is Rentable Area Measure' ;
    rdfs:comment 'Indicates whether this UOM is used to express rentable area for lease billing purposes (True = rentable area measure such as SQF or SQM under BOMA/IPMS). Drives rent calculation logic in Yardi Voyager lease administration and FASB ASC 842 / IFRS 16 right-of-use asset computations.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isoUomCode rdf:type rdf:Property ;
    rdfs:label 'Iso Uom Code' ;
    rdfs:comment 'Corresponding ISO 80000 or UN/CEFACT Recommendation 20 unit code for interoperability with SAP S/4HANA procurement, ERP integrations, and international regulatory submissions (e.g., MTK for square meters, FTK for square feet, KGM for kilograms).' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementSystem rdf:type rdf:Property ;
    rdfs:label 'Measurement System' ;
    rdfs:comment 'Indicates whether the UOM belongs to the imperial, metric (SI), US customary, or other measurement system. Critical for cross-border portfolio reporting and regulatory area disclosures where jurisdictions mandate specific systems (e.g., metric in EU, imperial in US).' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precisionDecimalPlaces rdf:type rdf:Property ;
    rdfs:label 'Precision Decimal Places' ;
    rdfs:comment 'Number of decimal places to which values expressed in this UOM should be rounded for display and storage (e.g., 2 for SQF area, 4 for conversion factors, 0 for whole-unit counts). Ensures consistent rounding in lease abstracts, valuation reports, and regulatory area disclosures.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateDenominatorUomCode rdf:type rdf:Property ;
    rdfs:label 'Rate Denominator Uom Code' ;
    rdfs:comment 'For rate-based UOMs (is_rate_based = True), the UOM code of the denominator area or volume measure (e.g., for PSF/year the denominator is SQF). Null for non-rate UOMs.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateNumeratorUomCode rdf:type rdf:Property ;
    rdfs:label 'Rate Numerator Uom Code' ;
    rdfs:comment 'For rate-based UOMs (is_rate_based = True), the UOM code of the numerator quantity (e.g., for PSF/year the numerator is USD). Null for non-rate UOMs. Enables decomposition of rent rates into currency and area components for PSF/PSM analytics.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateTimePeriod rdf:type rdf:Property ;
    rdfs:label 'Rate Time Period' ;
    rdfs:comment 'For rate-based UOMs, the time period denominator of the rate (e.g., annual for PSF/year, monthly for PSM/month). Drives annualization logic in NOI statements, rent schedules, and Argus Enterprise cash flow models. [ENUM-REF-CANDIDATE: annual|monthly|weekly|daily|per_sqf|per_sqm|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resoUomCode rdf:type rdf:Property ;
    rdfs:label 'Reso Uom Code' ;
    rdfs:comment 'RESO Data Dictionary standardized UOM code for MLS and real estate data exchange interoperability (e.g., SquareFeet, SquareMeters, Acres). Enables consistent data syndication via CoStar Suite and MLS platforms.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemUomCode rdf:type rdf:Property ;
    rdfs:label 'Source System Uom Code' ;
    rdfs:comment 'The native identifier or code assigned to this UOM in the originating source system (e.g., Yardi Voyager internal UOM key, SAP S/4HANA unit code). Enables bidirectional reconciliation and cross-system mapping during data integration.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uomCategory rdf:type rdf:Property ;
    rdfs:label 'Uom Category' ;
    rdfs:comment 'Business-facing grouping of the UOM within real estate operations (e.g., \'Leasable Area\', \'Gross Area\', \'Rent Rate\', \'Construction Measure\', \'Valuation Metric\', \'Utility Consumption\'). Supports filtering in Argus Enterprise and MRI Software reporting. [ENUM-REF-CANDIDATE: leasable_area|gross_area|rent_rate|construction_measure|valuation_metric|utility_consumption|land_area|parking — promote to reference product]' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uomCode rdf:type rdf:Property ;
    rdfs:label 'Uom Code' ;
    rdfs:comment 'Short, system-facing alphanumeric code uniquely identifying the unit of measure (e.g., SQF, SQM, PSF, LF, CF, LB, KG). Used as the canonical lookup key across Yardi Voyager, MRI Software, Argus Enterprise, and SAP S/4HANA integrations.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uomDescription rdf:type rdf:Property ;
    rdfs:label 'Uom Description' ;
    rdfs:comment 'Detailed narrative description of the UOM, including its definition, applicable measurement context, and any industry-specific nuances (e.g., distinction between GLA and NLA, BOMA vs IPMS methodology differences). Used in data governance documentation and business glossary.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uomName rdf:type rdf:Property ;
    rdfs:label 'Uom Name' ;
    rdfs:comment 'Full human-readable name of the unit of measure (e.g., \'Square Feet\', \'Square Meters\', \'Linear Feet\', \'Pounds per Square Foot per Year\'). Displayed in reports, lease abstracts, and valuation outputs.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uomStatus rdf:type rdf:Property ;
    rdfs:label 'Uom Status' ;
    rdfs:comment 'Lifecycle status of the UOM record: active (in current use), inactive (no longer used for new records), deprecated (superseded by another UOM, retained for historical data), pending_review (under governance review). Controls availability in Yardi Voyager and MRI Software UOM selection lists.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationSystem rdf:type rdf:Property ;
    rdfs:label 'Classification System' ;
    rdfs:comment 'The industry classification standard or system to which this code belongs. Supported systems include NAICS (North American Industry Classification System), SIC (Standard Industrial Classification), GICS (Global Industry Classification Standard), NACE (European industry classification), ANZSIC (Australian/New Zealand), and ISIC (International Standard Industrial Classification). Determines how the code is interpreted and which authority governs it.' ;
    rdfs:domain ind:IndustryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeVersion rdf:type rdf:Property ;
    rdfs:label 'Code Version' ;
    rdfs:comment 'The version or revision year of the classification system under which this code is defined (e.g., \'NAICS 2022\', \'NAICS 2017\', \'SIC 1987\'). Classification systems are periodically revised; version tracking ensures codes are interpreted against the correct edition for historical comparability and regulatory compliance.' ;
    rdfs:domain ind:IndustryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costarCategory rdf:type rdf:Property ;
    rdfs:label 'Costar Category' ;
    rdfs:comment 'The corresponding tenant industry category as defined in CoStar Suite\'s market analytics taxonomy. CoStar uses its own proprietary tenant categorization that maps to but does not always align 1:1 with NAICS/SIC codes. Populated to enable direct integration with CoStar comparable lease data, market research reports, and tenant mix benchmarking against market peers.' ;
    rdfs:domain ind:IndustryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditRiskTier rdf:type rdf:Property ;
    rdfs:label 'Credit Risk Tier' ;
    rdfs:comment 'General credit risk tier associated with tenants in this industry classification, based on historical default rates and sector credit quality benchmarks. Used in lease underwriting, DSCR analysis, and portfolio risk concentration reporting. Supports Argus Enterprise cash flow modeling assumptions and MRI Investment Management risk-adjusted return calculations.' ;
    rdfs:domain ind:IndustryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgRiskCategory rdf:type rdf:Property ;
    rdfs:label 'Esg Risk Category' ;
    rdfs:comment 'The ESG risk category associated with tenants or occupiers in this industry classification, reflecting environmental impact, social responsibility, and governance risk exposure. Used in ESG portfolio reporting, LEED/BREEAM tenant engagement programs, and green lease structuring. Supports SEC ESG disclosure requirements for publicly traded REITs and institutional investor reporting.' ;
    rdfs:domain ind:IndustryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gicsEquivalentCode rdf:type rdf:Property ;
    rdfs:label 'Gics Equivalent Code' ;
    rdfs:comment 'The corresponding GICS 8-digit sub-industry code for records originating from NAICS or SIC systems. Used for investment portfolio analysis in Argus Enterprise and MRI Investment Management, where institutional investors and REITs classify tenant and occupier exposure using GICS for equity market benchmarking and ESG reporting. Null when classification_system is already GICS.' ;
    rdfs:domain ind:IndustryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Risk Flag' ;
    rdfs:comment 'Indicates whether tenants in this industry classification typically handle, store, or generate hazardous materials, requiring environmental due diligence, Phase I/II environmental site assessments, and specialized lease provisions. Relevant for industrial and laboratory occupiers. Supports EPA environmental compliance, OSHA building safety requirements, and property acquisition due diligence.' ;
    rdfs:domain ind:IndustryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:industryClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Industry Classification Code' ;
    rdfs:comment 'The official alphanumeric code assigned by the governing classification authority (e.g., NAICS code \'531120\' for Lessors of Nonresidential Buildings, SIC code \'6512\', or GICS code \'60101010\' for Diversified REITs). This is the externally recognized business identifier used in regulatory filings, lease underwriting, and portfolio reporting.' ;
    rdfs:domain ind:IndustryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryClassificationDescription rdf:type rdf:Property ;
    rdfs:label 'Industry Classification Description' ;
    rdfs:comment 'Full narrative description of the industry classification code as defined by the governing authority. Explains the scope of economic activities covered, typical establishments included, and any cross-references or exclusions. Supports lease underwriting decisions and tenant mix analysis by providing context beyond the short title.' ;
    rdfs:domain ind:IndustryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryClassificationStatus rdf:type rdf:Property ;
    rdfs:label 'Industry Classification Status' ;
    rdfs:comment 'Current lifecycle status of this industry classification code record. \'Active\' codes are available for assignment to tenants and occupiers. \'Deprecated\' codes have been retired by the governing authority but retained for historical record integrity. \'Superseded\' codes have been replaced by a new code in a revised edition of the classification system.' ;
    rdfs:domain ind:IndustryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAnchorEligible rdf:type rdf:Property ;
    rdfs:label 'Is Anchor Eligible' ;
    rdfs:comment 'Indicates whether tenants in this industry classification are typically eligible to serve as anchor tenants in retail or mixed-use properties. Anchor tenants drive foot traffic and influence co-tenancy clauses in lease agreements. Used in retail leasing strategy, tenant mix planning, and co-tenancy clause risk assessment in Salesforce CRM deal pipeline management.' ;
    rdfs:domain ind:IndustryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEssentialBusiness rdf:type rdf:Property ;
    rdfs:label 'Is Essential Business' ;
    rdfs:comment 'Indicates whether tenants in this industry classification are typically designated as essential businesses under applicable government emergency orders (e.g., grocery, pharmacy, healthcare, utilities). Relevant for lease force majeure clause analysis, rent abatement risk assessment during declared emergencies, and regulatory compliance reporting to HUD and SEC for publicly traded REITs.' ;
    rdfs:domain ind:IndustryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRealEstateSpecific rdf:type rdf:Property ;
    rdfs:label 'Is Real Estate Specific' ;
    rdfs:comment 'Indicates whether this industry classification code is specifically relevant to real estate operations, investment, or property-related activities (e.g., NAICS 531 Real Estate, GICS sector 60 Real Estate). Used to filter the classification code list for real estate portfolio analytics, REIT regulatory reporting, and property management system integrations.' ;
    rdfs:domain ind:IndustryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mriIndustryCode rdf:type rdf:Property ;
    rdfs:label 'Mri Industry Code' ;
    rdfs:comment 'The corresponding industry code as configured in MRI Software\'s lease management and residential management modules. MRI Software uses its own tenant industry classification codes for lease underwriting and portfolio reporting. Enables synchronization between the enterprise reference repository and MRI Software tenant and lease records.' ;
    rdfs:domain ind:IndustryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:naicsEquivalentCode rdf:type rdf:Property ;
    rdfs:label 'Naics Equivalent Code' ;
    rdfs:comment 'The corresponding NAICS 6-digit code for records originating from SIC or GICS systems, enabling cross-system concordance. Populated when classification_system is SIC or GICS to allow unified NAICS-based reporting as required by U.S. federal regulatory filings and CoStar market analytics. Null when classification_system is already NAICS.' ;
    rdfs:domain ind:IndustryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:realEstateUseCategory rdf:type rdf:Property ;
    rdfs:label 'Real Estate Use Category' ;
    rdfs:comment 'The primary real estate property use category most commonly associated with tenants or occupiers in this industry classification. Drives retail tenant mix analysis (anchor vs. inline), office sector concentration tracking, and industrial occupier type classification. Used in Yardi Voyager and MRI lease management for automated tenant categorization and CoStar market analytics segmentation. [ENUM-REF-CANDIDATE: retail|office|industrial|multifamily|hospitality|mixed_use|specialty|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IndustryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Code' ;
    rdfs:comment 'The specific code or identifier used when reporting tenant industry classification to regulatory bodies (e.g., SEC REIT tenant concentration disclosures, HUD reporting, CMBS loan-level data reporting). May differ from the standard NAICS/SIC/GICS code when regulators require a mapped or aggregated code. Supports SOX financial controls compliance for publicly traded REITs.' ;
    rdfs:domain ind:IndustryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailTenantType rdf:type rdf:Property ;
    rdfs:label 'Retail Tenant Type' ;
    rdfs:comment 'For retail-use classifications, designates the tenant positioning category within a retail center (e.g., anchor, major, inline, kiosk, pad/outparcel, food and beverage, entertainment, service). Critical for retail tenant mix analysis, GLA allocation planning, and CAM cost recovery structuring. Null or \'not_applicable\' for non-retail classifications. [ENUM-REF-CANDIDATE: anchor|major|inline|kiosk|pad|outparcel|food_and_beverage|entertainment|service|not_applicable — promote to reference product]' ;
    rdfs:domain ind:IndustryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectorCode rdf:type rdf:Property ;
    rdfs:label 'Sector Code' ;
    rdfs:comment 'The top-level sector code within the classification system (e.g., NAICS sector \'53\', SIC division \'H\', GICS sector code \'60\'). Provides a concise key for sector-level grouping in portfolio analytics, lease underwriting scorecards, and regulatory concentration reporting.' ;
    rdfs:domain ind:IndustryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectorName rdf:type rdf:Property ;
    rdfs:label 'Sector Name' ;
    rdfs:comment 'The top-level sector name under which this classification code falls (e.g., \'Real Estate and Rental and Leasing\' for NAICS sector 53, \'Finance, Insurance, and Real Estate\' for SIC division H, \'Real Estate\' for GICS sector 60). Used for high-level portfolio diversification analysis and tenant sector concentration reporting in CRE portfolios.' ;
    rdfs:domain ind:IndustryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sicEquivalentCode rdf:type rdf:Property ;
    rdfs:label 'Sic Equivalent Code' ;
    rdfs:comment 'The corresponding SIC 4-digit code for records originating from NAICS or GICS systems. Maintained for backward compatibility with legacy Yardi Voyager tenant records, MRI Software lease management configurations, and older regulatory filings that reference SIC codes. Null when classification_system is already SIC.' ;
    rdfs:domain ind:IndustryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByCode rdf:type rdf:Property ;
    rdfs:label 'Superseded By Code' ;
    rdfs:comment 'When status is \'superseded\', the code that replaces this classification code in the current or subsequent version of the classification system. Enables automated migration of tenant classifications during NAICS revision cycles and maintains audit trail for historical lease records in Yardi Voyager and MRI Software.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalLeaseType rdf:type rdf:Property ;
    rdfs:label 'Typical Lease Type' ;
    rdfs:comment 'The lease structure most commonly associated with tenants in this industry classification (e.g., NNN for retail/industrial, gross for office, percentage rent for food and beverage). Informs lease underwriting assumptions in Argus Enterprise, CAM recovery modeling, and NOI forecasting. NNN = Triple Net Lease. [ENUM-REF-CANDIDATE: NNN|gross|modified_gross|percentage|ground|net|double_net — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IndustryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalSpaceSizeMaxSqf rdf:type rdf:Property ;
    rdfs:label 'Typical Space Size Max Sqf' ;
    rdfs:comment 'The maximum typical occupied space size in square feet (SQF) for tenants in this industry classification. Used alongside the minimum to define the expected space demand range for lease underwriting, tenant mix planning, and market absorption analysis. SQF = Square Feet.' ;
    rdfs:domain ind:IndustryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:typicalSpaceSizeMinSqf rdf:type rdf:Property ;
    rdfs:label 'Typical Space Size Min Sqf' ;
    rdfs:comment 'The minimum typical occupied space size in square feet (SQF) for tenants in this industry classification. Used as a benchmark in lease underwriting, space planning, and GLA allocation analysis. Supports PSF rent benchmarking and NLA/GLA ratio analysis in Argus Enterprise cash flow models. SQF = Square Feet.' ;
    rdfs:domain ind:IndustryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yardiIndustryCode rdf:type rdf:Property ;
    rdfs:label 'Yardi Industry Code' ;
    rdfs:comment 'The corresponding industry code as configured in Yardi Voyager\'s tenant profile module. Yardi Voyager maintains its own internal industry code list for tenant categorization in lease administration and accounts receivable. This field enables bidirectional synchronization between the enterprise reference repository and Yardi Voyager tenant records.' ;
    rdfs:domain ind:IndustryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalSizeUomId rdf:type rdf:Property ;
    rdfs:label 'Typical Size Uom Id' ;
    rdfs:comment 'Foreign key linking to reference.uom. Business justification: Amenity types have a typical physical size measured in a specific unit of measure (e.g., square feet for a fitness center, number of spaces for a parking garage). Linking to the enterprise UOM registr' ;
    rdfs:domain ind:AmenityType ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Uom .

ind:amenityCategory rdf:type rdf:Property ;
    rdfs:label 'Amenity Category' ;
    rdfs:comment 'Functional category grouping amenities by their primary purpose for analytics and comparable analysis (e.g., \'Wellness & Fitness\', \'Parking & Transportation\', \'Technology & Smart Building\', \'Food & Beverage\', \'Conference & Collaboration\', \'Green Space & Recreation\', \'Concierge & Services\', \'Security & Access\'). [ENUM-REF-CANDIDATE: Wellness & Fitness|Parking & Transportation|Technology & Smart Building|Food & Beverage|Conference & Collaboration|Green Space & Recreation|Concierge & Services|Security & Access — promote to reference product]' ;
    rdfs:domain ind:AmenityType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amenityClass rdf:type rdf:Property ;
    rdfs:label 'Amenity Class' ;
    rdfs:comment 'High-level classification grouping amenities by their physical scope and applicability: \'building\' (shared building-wide features such as lobbies and fitness centers), \'unit\' (in-unit features such as in-unit laundry or private terrace), \'community\' (campus or complex-wide features such as shared green spaces), \'outdoor\' (exterior amenities such as parking structures or dog parks).' ;
    rdfs:domain ind:AmenityType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amenityCode rdf:type rdf:Property ;
    rdfs:label 'Amenity Code' ;
    rdfs:comment 'Short, system-readable alphanumeric code uniquely identifying the amenity type across all operational systems (e.g., FIT_CTR, ROOFTOP_TER, EV_CHRG, CONF_FAC). Used as the stable integration key between Yardi Voyager, CoStar Suite, MRI Software, and the data lakehouse.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amenityName rdf:type rdf:Property ;
    rdfs:label 'Amenity Name' ;
    rdfs:comment 'Human-readable display name for the amenity type as it appears in property listings, marketing materials, tenant portals, and brokerage reports (e.g., \'Fitness Center\', \'Rooftop Terrace\', \'EV Charging Station\', \'Conference Facility\').' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amenityTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Amenity Type Description' ;
    rdfs:comment 'Full narrative description of the amenity type, including its physical characteristics, typical configuration, and business purpose. Used in property marketing copy, tenant attraction materials, and brokerage listing enrichment within Salesforce CRM and CoStar Suite.' ;
    rdfs:domain ind:AmenityType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amenityTypeStatus rdf:type rdf:Property ;
    rdfs:label 'Amenity Type Status' ;
    rdfs:comment 'Lifecycle status of the amenity type record within the controlled vocabulary. \'active\' — currently in use across operational systems; \'inactive\' — no longer assigned to new properties but retained for historical records; \'deprecated\' — superseded by a replacement code; \'pending_review\' — submitted for governance approval but not yet ratified.' ;
    rdfs:domain ind:AmenityType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costarAmenityCode rdf:type rdf:Property ;
    rdfs:label 'Costar Amenity Code' ;
    rdfs:comment 'The amenity identifier code as used in CoStar Suite for property analytics, comparable sales and lease data, and market research. Enables direct mapping between the enterprise reference vocabulary and CoStar data feeds for comparable analysis (CMA) and Broker Price Opinion (BPO) workflows.' ;
    rdfs:domain ind:AmenityType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displaySortOrder rdf:type rdf:Property ;
    rdfs:label 'Display Sort Order' ;
    rdfs:comment 'Integer value controlling the display sequence of amenity types in property listing portals, tenant-facing marketing materials, and brokerage platforms. Lower values appear first. Managed by the reference data governance team.' ;
    rdfs:domain ind:AmenityType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iconIdentifier rdf:type rdf:Property ;
    rdfs:label 'Icon Identifier' ;
    rdfs:comment 'Reference key or filename for the standardized icon representing this amenity type in tenant portals, property marketing websites, and mobile applications. Enables consistent visual branding across Salesforce CRM tenant portals and Building Engines service request interfaces.' ;
    rdfs:domain ind:AmenityType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indoorOutdoorIndicator rdf:type rdf:Property ;
    rdfs:label 'Indoor Outdoor Indicator' ;
    rdfs:comment 'Specifies whether this amenity type is physically located indoors, outdoors, or spans both environments. Used in property marketing, facility operations planning in Building Engines, and LEED site assessment scoring.' ;
    rdfs:domain ind:AmenityType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBillable rdf:type rdf:Property ;
    rdfs:label 'Is Billable' ;
    rdfs:comment 'Indicates whether this amenity type is typically subject to a separate charge to tenants (e.g., reserved parking, private storage units, premium concierge services) as opposed to being included in base rent. Drives billing configuration in Yardi Voyager AR and lease charge setup in MRI Software.' ;
    rdfs:domain ind:AmenityType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBreeamQualifying rdf:type rdf:Property ;
    rdfs:label 'Is Breeam Qualifying' ;
    rdfs:comment 'Indicates whether the presence of this amenity type can contribute credits toward a BREEAM (Building Research Establishment Environmental Assessment Method) certification assessment. Relevant for international portfolio assets and cross-border investment reporting.' ;
    rdfs:domain ind:AmenityType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLeedQualifying rdf:type rdf:Property ;
    rdfs:label 'Is Leed Qualifying' ;
    rdfs:comment 'Indicates whether the presence of this amenity type can contribute points toward a LEED (Leadership in Energy and Environmental Design) certification score. Used in development project planning within Procore and asset valuation models in Argus Enterprise.' ;
    rdfs:domain ind:AmenityType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceIntensity rdf:type rdf:Property ;
    rdfs:label 'Maintenance Intensity' ;
    rdfs:comment 'Categorical indicator of the relative operational and maintenance burden associated with this amenity type: \'low\' (e.g., bike racks, signage), \'medium\' (e.g., fitness equipment, conference rooms), \'high\' (e.g., pools, rooftop terraces, EV charging infrastructure). Used in OPEX budgeting, preventive maintenance scheduling in Building Engines, and CAPEX planning.' ;
    rdfs:domain ind:AmenityType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketSegmentApplicability rdf:type rdf:Property ;
    rdfs:label 'Market Segment Applicability' ;
    rdfs:comment 'Comma-delimited list of market segments for which this amenity type is commonly relevant (e.g., \'CLASS_A,CLASS_B\', \'LUXURY_RESIDENTIAL\', \'INDUSTRIAL\'). Supports comparable market analysis (CMA) filtering in CoStar Suite and brokerage listing enrichment in Salesforce CRM. [ENUM-REF-CANDIDATE: CLASS_A|CLASS_B|CLASS_C|LUXURY_RESIDENTIAL|AFFORDABLE_HOUSING|INDUSTRIAL|MIXED_USE — promote to reference product]' ;
    rdfs:domain ind:AmenityType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mriAmenityCode rdf:type rdf:Property ;
    rdfs:label 'Mri Amenity Code' ;
    rdfs:comment 'The amenity identifier as configured in MRI Software residential and commercial property management modules. Supports data lineage and reconciliation between MRI Software and the enterprise reference data layer.' ;
    rdfs:domain ind:AmenityType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notes' ;
    rdfs:comment 'Free-text field capturing relevant regulatory, zoning, or compliance considerations associated with this amenity type (e.g., ADA accessibility requirements, EPA environmental standards for EV charging, OSHA safety requirements for fitness equipment). Supports compliance reporting and development due diligence.' ;
    rdfs:domain ind:AmenityType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresPermit rdf:type rdf:Property ;
    rdfs:label 'Requires Permit' ;
    rdfs:comment 'Indicates whether installation or operation of this amenity type typically requires a municipal building permit, zoning variance, or regulatory approval (e.g., rooftop structures, pools, EV charging infrastructure, food service facilities). Used in development project planning in Procore and regulatory compliance tracking.' ;
    rdfs:domain ind:AmenityType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resoAmenityCode rdf:type rdf:Property ;
    rdfs:label 'Reso Amenity Code' ;
    rdfs:comment 'The standardized amenity code as defined by the Real Estate Standards Organization (RESO) Data Dictionary, used for MLS syndication and cross-platform data exchange. Enables interoperability with MLS systems and CoStar Suite data feeds.' ;
    rdfs:domain ind:AmenityType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smartBuildingFeature rdf:type rdf:Property ;
    rdfs:label 'Smart Building Feature' ;
    rdfs:comment 'Indicates whether this amenity type is classified as a smart building or PropTech-enabled feature (e.g., automated access control, IoT-connected HVAC, smart parking systems, digital concierge kiosks). Relevant for Building Information Modeling (BIM) integration and ESG technology reporting.' ;
    rdfs:domain ind:AmenityType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tenantAttractionScore rdf:type rdf:Property ;
    rdfs:label 'Tenant Attraction Score' ;
    rdfs:comment 'Standardized integer score (1–10) representing the relative importance of this amenity type in attracting and retaining tenants, based on market research benchmarks from CoStar Suite and ULI tenant surveys. Used in brokerage deal pipeline analysis in Salesforce CRM and lease renewal probability modeling.' ;
    rdfs:domain ind:AmenityType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:typicalCapexTier rdf:type rdf:Property ;
    rdfs:label 'Typical Capex Tier' ;
    rdfs:comment 'Indicative tier representing the typical capital expenditure (CAPEX) required to install or construct this amenity type: \'low\' (under $50K), \'medium\' ($50K–$500K), \'high\' ($500K–$2M), \'very_high\' (over $2M). Used in development feasibility analysis in Procore and investment underwriting in Argus Enterprise.' ;
    rdfs:domain ind:AmenityType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Valuation Impact Flag' ;
    rdfs:comment 'Indicates the general directional impact this amenity type has on property valuation and CAP rate analysis: \'positive\' — typically increases asset value and NOI; \'neutral\' — no material valuation impact; \'negative\' — may reduce value (e.g., high-maintenance amenities with low tenant uptake); \'variable\' — impact depends on market segment. Used in Argus Enterprise DCF models and Appraisal Institute valuation reports.' ;
    rdfs:domain ind:AmenityType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yardiAmenityCode rdf:type rdf:Property ;
    rdfs:label 'Yardi Amenity Code' ;
    rdfs:comment 'The amenity code as configured in Yardi Voyager property management and lease administration modules. Used for system-of-record alignment when synchronizing amenity data between the lakehouse silver layer and Yardi Voyager operational data.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amenityRequirementLevel rdf:type rdf:Property ;
    rdfs:label 'Amenity Requirement Level' ;
    rdfs:comment 'Minimum level of building amenities required for this class designation. Full-service includes concierge, fitness center, conference facilities, and food service; minimal reflects basic building services only. Supports property management benchmarking in Building Engines and Yardi Voyager.' ;
    rdfs:domain ind:BuildingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetSegment rdf:type rdf:Property ;
    rdfs:label 'Asset Segment' ;
    rdfs:comment 'Broad real estate asset segment to which this building class applies. Distinguishes commercial (office, retail), residential (multifamily, single-family), industrial (warehouse, flex), and mixed-use classifications, as building class criteria differ materially by segment.' ;
    rdfs:domain ind:BuildingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomaClassDesignation rdf:type rdf:Property ;
    rdfs:label 'Boma Class Designation' ;
    rdfs:comment 'Official Building Owners and Managers Association (BOMA) building class designation (A, B, C, or D) mapped to this enterprise class. Ensures alignment with the industry-standard BOMA classification framework used in lease administration, property management, and benchmarking.' ;
    rdfs:domain ind:BuildingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingClassStatus rdf:type rdf:Property ;
    rdfs:label 'Building Class Status' ;
    rdfs:comment 'Current lifecycle status of this building class record in the enterprise reference data repository. Active records are available for property classification; deprecated records are retained for historical reference only. Managed through the reference data governance process.' ;
    rdfs:domain ind:BuildingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classCode rdf:type rdf:Property ;
    rdfs:label 'Class Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the building class (e.g., A, B, C, TROPHY, LUX, MID, AFF, INST). Used as the externally-known business identifier across operational systems including Yardi Voyager, MRI Software, CoStar, and Argus Enterprise for property classification lookups.' ;
    rdfs:domain ind:BuildingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classDescription rdf:type rdf:Property ;
    rdfs:label 'Class Description' ;
    rdfs:comment 'Detailed narrative description of the building class, including qualitative criteria such as construction quality, finish standards, location requirements, amenity expectations, and typical tenant profile. Supports underwriting, valuation, and investment advisory workflows.' ;
    rdfs:domain ind:BuildingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:className rdf:type rdf:Property ;
    rdfs:label 'Class Name' ;
    rdfs:comment 'Full descriptive name of the building class (e.g., \'Class A\', \'Class B\', \'Class C\', \'Trophy\', \'Luxury\', \'Mid-Market\', \'Affordable\', \'Institutional Grade\'). Human-readable label used in reports, dashboards, and tenant-facing materials.' ;
    rdfs:domain ind:BuildingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationTier rdf:type rdf:Property ;
    rdfs:label 'Classification Tier' ;
    rdfs:comment 'Numeric ordinal rank of the building class within its asset segment hierarchy (e.g., 1 = highest/Trophy/Class A, 2 = Class B/Mid-Market, 3 = Class C/Affordable). Enables ranked sorting and comparative analytics across the classification spectrum in Argus Enterprise and portfolio reporting.' ;
    rdfs:domain ind:BuildingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:constructionQualityGrade rdf:type rdf:Property ;
    rdfs:label 'Construction Quality Grade' ;
    rdfs:comment 'Qualitative grade of construction quality required for this building class, reflecting structural integrity, materials specification, and build standards. Premium denotes trophy/Class A+ finishes; economy denotes Class C or below. Informs property valuation and appraisal workflows in Argus Enterprise.' ;
    rdfs:domain ind:BuildingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costarClassCode rdf:type rdf:Property ;
    rdfs:label 'Costar Class Code' ;
    rdfs:comment 'CoStar Suite building class code used for market research, comparable sales, and lease data alignment. Enables direct cross-referencing between the enterprise classification system and CoStar\'s industry-standard building quality ratings for benchmarking and market analytics.' ;
    rdfs:domain ind:BuildingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energyStarMinScore rdf:type rdf:Property ;
    rdfs:label 'Energy Star Min Score' ;
    rdfs:comment 'Minimum EPA ENERGY STAR score (1–100 scale) required for buildings to qualify for this class designation. A score of 75 or above qualifies for ENERGY STAR certification. Null if no ENERGY STAR threshold is mandated. Supports ESG and environmental compliance reporting.' ;
    rdfs:domain ind:BuildingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finishQualityGrade rdf:type rdf:Property ;
    rdfs:label 'Finish Quality Grade' ;
    rdfs:comment 'Grade of interior finish quality expected for buildings in this class, covering flooring, ceiling heights, lobby finishes, restroom quality, and common area standards. Directly influences Tenant Improvement (TI) allowance benchmarks and lease negotiation parameters.' ;
    rdfs:domain ind:BuildingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hvacSystemRequirement rdf:type rdf:Property ;
    rdfs:label 'Hvac System Requirement' ;
    rdfs:comment 'Minimum Heating, Ventilation, and Air Conditioning (HVAC) system type required for buildings in this class. Central VAV (Variable Air Volume) systems are typically required for Class A office; split systems may be acceptable for Class C. Informs property management and capital expenditure (CAPEX) planning.' ;
    rdfs:domain ind:BuildingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentGradeFlag rdf:type rdf:Property ;
    rdfs:label 'Investment Grade Flag' ;
    rdfs:comment 'Indicates whether properties in this building class are considered institutional or investment-grade assets suitable for REIT portfolios, pension fund investment, and institutional capital allocation. True for Trophy and Class A designations; typically False for Class C and below.' ;
    rdfs:domain ind:BuildingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationGrade rdf:type rdf:Property ;
    rdfs:label 'Location Grade' ;
    rdfs:comment 'Required location quality grade for buildings in this class, reflecting proximity to Central Business District (CBD), transportation infrastructure, and market desirability. Prime CBD locations are typically required for Trophy and Class A designations. Used in market segmentation and portfolio analytics.' ;
    rdfs:domain ind:BuildingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxBuildingAgeYears rdf:type rdf:Property ;
    rdfs:label 'Max Building Age Years' ;
    rdfs:comment 'Maximum age of a building in years (measured from year of construction or last major renovation) that qualifies for this class. Null indicates no upper age limit. Used alongside min_building_age_years to define the age band for classification eligibility.' ;
    rdfs:domain ind:BuildingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxCapRatePct rdf:type rdf:Property ;
    rdfs:label 'Max Cap Rate Pct' ;
    rdfs:comment 'Maximum typical Capitalization Rate (CAP Rate) expressed as a decimal percentage (e.g., 0.0800 = 8.00%) associated with properties in this building class. Used alongside min_cap_rate_pct to define the CAP rate band for investment analysis and portfolio benchmarking.' ;
    rdfs:domain ind:BuildingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minBuildingAgeYears rdf:type rdf:Property ;
    rdfs:label 'Min Building Age Years' ;
    rdfs:comment 'Minimum age of a building in years (measured from year of construction or last major renovation) that qualifies for this class. Used as a threshold criterion in automated property classification workflows within Yardi Voyager and MRI Software.' ;
    rdfs:domain ind:BuildingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minCapRatePct rdf:type rdf:Property ;
    rdfs:label 'Min Cap Rate Pct' ;
    rdfs:comment 'Minimum typical Capitalization Rate (CAP Rate) expressed as a decimal percentage (e.g., 0.0400 = 4.00%) associated with properties in this building class. Provides investment benchmarking guidance for asset managers and investment advisors using Argus Enterprise and MRI Software.' ;
    rdfs:domain ind:BuildingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minFloorCount rdf:type rdf:Property ;
    rdfs:label 'Min Floor Count' ;
    rdfs:comment 'Minimum number of above-grade floors a building must have to qualify for this class designation. Applicable primarily to office and mixed-use classifications where building height is a quality indicator (e.g., Trophy office typically requires high-rise status).' ;
    rdfs:domain ind:BuildingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minGlaSqf rdf:type rdf:Property ;
    rdfs:label 'Min Gla Sqf' ;
    rdfs:comment 'Minimum Gross Leasable Area (GLA) in Square Feet (SQF) required for a property to qualify for this building class. Null if no minimum size threshold applies. Used in automated property classification and portfolio segmentation analytics.' ;
    rdfs:domain ind:BuildingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:propertyTypeScope rdf:type rdf:Property ;
    rdfs:label 'Property Type Scope' ;
    rdfs:comment 'Specific property type(s) within the asset segment to which this class definition applies (e.g., Office, Retail, Multifamily, Industrial, Hotel, Self-Storage, Senior Housing). Aligns with CoStar and RESO property type taxonomies. [ENUM-REF-CANDIDATE: office|retail|multifamily|industrial|hotel|self_storage|senior_housing|mixed_use|land|other — promote to reference product]' ;
    rdfs:domain ind:BuildingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reitEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Reit Eligible Flag' ;
    rdfs:comment 'Indicates whether properties classified under this building class are typically eligible for inclusion in a Real Estate Investment Trust (REIT) portfolio based on quality, income-producing characteristics, and institutional standards. Supports investment advisory and portfolio management workflows.' ;
    rdfs:domain ind:BuildingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sustainabilityCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certification Required' ;
    rdfs:comment 'Indicates whether a recognized sustainability certification (e.g., LEED, BREEAM, ENERGY STAR) is required or expected for buildings to qualify for this class designation. Reflects ESG compliance requirements increasingly embedded in institutional-grade CRE classification.' ;
    rdfs:domain ind:BuildingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technologyInfrastructureGrade rdf:type rdf:Property ;
    rdfs:label 'Technology Infrastructure Grade' ;
    rdfs:comment 'Required level of technology infrastructure for buildings in this class, including fiber connectivity, building automation systems (BAS), smart building capabilities, and telecommunications readiness. Increasingly critical for Class A and Trophy designations in CRE markets.' ;
    rdfs:domain ind:BuildingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalLeaseStructure rdf:type rdf:Property ;
    rdfs:label 'Typical Lease Structure' ;
    rdfs:comment 'Typical lease structure associated with this building class (e.g., Full Service Gross, Modified Gross, NNN — Triple Net Lease). Provides context for lease administration in Yardi Voyager and MRI Software, and informs CAM (Common Area Maintenance) charge modeling.' ;
    rdfs:domain ind:BuildingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalPsfRentMax rdf:type rdf:Property ;
    rdfs:label 'Typical Psf Rent Max' ;
    rdfs:comment 'Maximum typical asking rent expressed in Per Square Foot (PSF) per annum for properties in this building class, in the base currency. Used alongside typical_psf_rent_min to define the rent band for this class in market analytics and investment underwriting.' ;
    rdfs:domain ind:BuildingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalPsfRentMin rdf:type rdf:Property ;
    rdfs:label 'Typical Psf Rent Min' ;
    rdfs:comment 'Minimum typical asking rent expressed in Per Square Foot (PSF) per annum for properties in this building class, in the base currency. Provides market benchmarking context for lease negotiations, rent schedule modeling, and comparative market analysis (CMA) in CoStar and Argus Enterprise.' ;
    rdfs:domain ind:BuildingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalTenantProfile rdf:type rdf:Property ;
    rdfs:label 'Typical Tenant Profile' ;
    rdfs:comment 'Narrative description of the typical tenant profile associated with this building class (e.g., \'Fortune 500 corporations, financial institutions, law firms\' for Class A; \'small-to-medium businesses, local retailers\' for Class B/C). Supports tenant relationship management and leasing strategy in Salesforce CRM.' ;
    rdfs:domain ind:BuildingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalVacancyRatePct rdf:type rdf:Property ;
    rdfs:label 'Typical Vacancy Rate Pct' ;
    rdfs:comment 'Typical market vacancy rate expressed as a decimal percentage (e.g., 0.0500 = 5.00%) for properties in this building class. Used as a benchmark input in Effective Gross Income (EGI) and Net Operating Income (NOI) modeling within Argus Enterprise cash flow projections.' ;
    rdfs:domain ind:BuildingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCurrencyCodeId rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code Id' ;
    rdfs:comment 'Foreign key linking to reference.currency_code. Business justification: construction_type tracks cost benchmarks (typical_cost_psf_low, typical_cost_psf_high, replacement_cost_multiplier) that are currency-denominated. Adding cost_currency_code_id → currency_code.currency' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CurrencyCode .

ind:costUomId rdf:type rdf:Property ;
    rdfs:label 'Cost Uom Id' ;
    rdfs:comment 'Foreign key linking to reference.uom. Business justification: construction_type tracks cost benchmarks per area unit (typical_cost_psf_low, typical_cost_psf_high DECIMAL — PSF = per square foot) and physical measurements (max_building_height_ft, typical_span_ft,' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Uom .

ind:acousticPerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Acoustic Performance Rating' ;
    rdfs:comment 'Qualitative acoustic performance rating (low, moderate, high, very_high) for this construction type based on typical sound transmission characteristics. Relevant for multifamily, hospitality, and office property types; informs tenant improvement specifications and lease negotiations.' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bimSupport rdf:type rdf:Property ;
    rdfs:label 'Bim Support' ;
    rdfs:comment 'Indicates whether this construction type is fully supported by BIM workflows in Procore and related development management systems (True = BIM-supported; False = not BIM-supported). Supports digital construction management and as-built documentation practices.' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breeamCompatibility rdf:type rdf:Property ;
    rdfs:label 'Breeam Compatibility' ;
    rdfs:comment 'Indicates whether this construction type is compatible with BREEAM certification pathways (not_applicable, compatible, preferred). Supports international ESG investment screening and sustainable development planning for cross-border real estate portfolios.' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructionCategory rdf:type rdf:Property ;
    rdfs:label 'Construction Category' ;
    rdfs:comment 'Broad grouping of construction types for portfolio-level analytics and reporting (light_frame, heavy_frame, concrete, masonry, modular, mixed, specialty). Used in CoStar Suite market segmentation, Argus Enterprise portfolio dashboards, and investment committee reporting. [ENUM-REF-CANDIDATE: light_frame|heavy_frame|concrete|masonry|modular|mixed|specialty — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructionMethod rdf:type rdf:Property ;
    rdfs:label 'Construction Method' ;
    rdfs:comment 'Method by which the building is assembled (site_built, prefabricated, modular, panelized, hybrid). Impacts construction schedule, CAPEX phasing, and Procore project management workflows for development projects.' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructionTypeCode rdf:type rdf:Property ;
    rdfs:label 'Construction Type Code' ;
    rdfs:comment 'Short, system-readable alphanumeric code uniquely identifying the construction type (e.g., WOOD_FRAME, STL_FRAME, CIP_CONC, PRECAST, TILT_UP, MASONRY, MODULAR, MIXED). Used as the stable business key for cross-system integration with Yardi Voyager, Procore, and CoStar Suite.' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructionTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Construction Type Description' ;
    rdfs:comment 'Detailed narrative describing the structural system, primary materials, assembly method, and distinguishing characteristics of this construction type. Used by appraisers, underwriters, and development teams for technical documentation and cost estimation.' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructionTypeName rdf:type rdf:Property ;
    rdfs:label 'Construction Type Name' ;
    rdfs:comment 'Full human-readable name of the construction type as used in property records, valuation reports, and development documentation (e.g., \'Wood Frame\', \'Structural Steel Frame\', \'Cast-In-Place Concrete\', \'Precast Concrete\', \'Tilt-Up Concrete\', \'Masonry\', \'Modular\', \'Mixed Construction\').' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructionTypeStatus rdf:type rdf:Property ;
    rdfs:label 'Construction Type Status' ;
    rdfs:comment 'Current lifecycle status of this construction type reference record (active = in use across enterprise systems; inactive = no longer assigned to new properties; deprecated = superseded by a newer classification). Controls availability in downstream system dropdowns and data entry forms.' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costBenchmarkYear rdf:type rdf:Property ;
    rdfs:label 'Cost Benchmark Year' ;
    rdfs:comment 'Calendar year for which the PSF cost benchmarks (typical_cost_psf_low and typical_cost_psf_high) are valid. Enables cost escalation adjustments in Argus Enterprise DCF models and development CAPEX forecasts.' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costarConstructionTypeCode rdf:type rdf:Property ;
    rdfs:label 'Costar Construction Type Code' ;
    rdfs:comment 'Construction type code as used in CoStar Suite property database. Enables market comparables analysis and benchmarking by construction type in CoStar Analytics and supports comparable sales/lease data integration.' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energyEfficiencyProfile rdf:type rdf:Property ;
    rdfs:label 'Energy Efficiency Profile' ;
    rdfs:comment 'Qualitative energy efficiency profile (low, moderate, high, very_high) for this construction type based on typical thermal performance, insulation characteristics, and building envelope properties. Supports ESG reporting, LEED/BREEAM certification tracking, and green building investment analysis.' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exteriorWallSystem rdf:type rdf:Property ;
    rdfs:label 'Exterior Wall System' ;
    rdfs:comment 'Description of the typical exterior wall assembly for this construction type (e.g., \'Curtain Wall\', \'Brick Veneer\', \'Tilt-Up Concrete Panel\', \'Metal Panel\', \'EIFS\'). Informs building condition assessments, maintenance cost benchmarking, and insurance replacement cost estimates.' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireResistanceRatingHours rdf:type rdf:Property ;
    rdfs:label 'Fire Resistance Rating Hours' ;
    rdfs:comment 'Minimum fire resistance rating in hours for the primary structural assembly as required by the IBC for this construction type (e.g., 0, 1.0, 2.0, 3.0). Used by insurance underwriters to determine property insurance premiums and by development teams for code compliance verification.' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:floorLoadCapacityPsf rdf:type rdf:Property ;
    rdfs:label 'Floor Load Capacity Psf' ;
    rdfs:comment 'Typical live load capacity of floor systems in pounds per square foot (PSF) for this construction type. Critical for industrial, warehouse, and data center property underwriting, tenant improvement design, and building condition assessments.' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:foundationType rdf:type rdf:Property ;
    rdfs:label 'Foundation Type' ;
    rdfs:comment 'Typical foundation system associated with this construction type (slab_on_grade, crawl_space, basement, pile, mat, caisson, other). Used in property condition assessments, maintenance planning in Building Engines, and environmental due diligence during acquisitions. [ENUM-REF-CANDIDATE: slab_on_grade|crawl_space|basement|pile|mat|caisson|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hvacCompatibility rdf:type rdf:Property ;
    rdfs:label 'Hvac Compatibility' ;
    rdfs:comment 'Typical HVAC system types compatible with this construction type. Informs tenant improvement (TI) planning, building operations management in Building Engines, and energy efficiency assessments for ESG reporting. [ENUM-REF-CANDIDATE: central_air|split_system|vrf|chilled_water|ptac|mixed|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ibcConstructionType rdf:type rdf:Property ;
    rdfs:label 'Ibc Construction Type' ;
    rdfs:comment 'Official IBC construction type designation (Type I-A through Type V-B) reflecting fire-resistance requirements for structural elements. Critical for building permit compliance, insurance underwriting, and occupancy classification. Aligns with Procore project documentation and CoStar property data. [ENUM-REF-CANDIDATE: Type_I-A|Type_I-B|Type_II-A|Type_II-B|Type_III-A|Type_III-B|Type_IV|Type_V-A|Type_V-B — promote to reference product]' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceClassCode rdf:type rdf:Property ;
    rdfs:label 'Insurance Class Code' ;
    rdfs:comment 'Insurer-assigned class code for this construction type used in property insurance policy underwriting and premium calculation. Aligns with ISO Commercial Lines Manual classifications and supports portfolio-level insurance cost benchmarking.' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCombustible rdf:type rdf:Property ;
    rdfs:label 'Is Combustible' ;
    rdfs:comment 'Indicates whether this construction type uses combustible materials in its primary structural assembly (True = combustible; False = non-combustible). Directly impacts property insurance classification, fire suppression system requirements, and building code compliance.' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isoConstructionClass rdf:type rdf:Property ;
    rdfs:label 'Iso Construction Class' ;
    rdfs:comment 'ISO construction class code (1–6) used by property insurance underwriters to classify buildings by construction material and fire resistance. Class 1 = Frame; Class 2 = Joisted Masonry; Class 3 = Non-Combustible; Class 4 = Masonry Non-Combustible; Class 5 = Modified Fire Resistive; Class 6 = Fire Resistive. Essential for insurance premium calculation and portfolio risk reporting.' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leedCompatibility rdf:type rdf:Property ;
    rdfs:label 'Leed Compatibility' ;
    rdfs:comment 'Indicates whether this construction type is compatible with LEED certification pathways (not_applicable, compatible, preferred). Preferred indicates the construction type is commonly used in LEED-certified projects. Supports ESG investment screening and green development planning.' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxStories rdf:type rdf:Property ;
    rdfs:label 'Max Stories' ;
    rdfs:comment 'Maximum number of above-grade stories permitted for this construction type under IBC regulations. Supports development feasibility studies, density analysis, and investment underwriting in Argus Enterprise.' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryMaterial rdf:type rdf:Property ;
    rdfs:label 'Primary Material' ;
    rdfs:comment 'Dominant structural material used in this construction type (e.g., wood, steel, concrete, masonry, composite). Drives insurance premium calculations, maintenance cost benchmarks, and CAPEX reserve estimates in Argus Enterprise and Yardi Voyager. [ENUM-REF-CANDIDATE: wood|steel|concrete|masonry|composite|aluminum|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procoreConstructionTypeCode rdf:type rdf:Property ;
    rdfs:label 'Procore Construction Type Code' ;
    rdfs:comment 'Construction type code as defined in Procore Construction Management system. Enables direct mapping between this enterprise reference record and Procore project specifications, RFIs, and submittal logs for development and renovation projects.' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementCostMultiplier rdf:type rdf:Property ;
    rdfs:label 'Replacement Cost Multiplier' ;
    rdfs:comment 'Relative cost multiplier applied to base construction cost benchmarks to estimate replacement cost for this construction type (e.g., 1.0000 = baseline; 1.2500 = 25% premium over baseline). Used in insurance replacement cost appraisals and Argus Enterprise valuation models.' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roofSystem rdf:type rdf:Property ;
    rdfs:label 'Roof System' ;
    rdfs:comment 'Typical roof structural system and covering type associated with this construction type (e.g., \'Built-Up Roofing on Steel Deck\', \'Asphalt Shingle on Wood Truss\', \'TPO Membrane on Concrete\'). Used in preventive maintenance scheduling in Building Engines and CAPEX reserve planning.' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seismicPerformanceCategory rdf:type rdf:Property ;
    rdfs:label 'Seismic Performance Category' ;
    rdfs:comment 'ASCE 7 seismic design category (A through F) typically associated with this construction type, indicating relative seismic performance and risk. Used in property risk assessment, insurance underwriting, and ESG reporting for portfolio management.' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thermalMassRating rdf:type rdf:Property ;
    rdfs:label 'Thermal Mass Rating' ;
    rdfs:comment 'Qualitative thermal mass rating (low, moderate, high) indicating the heat storage capacity of this construction type. Impacts energy consumption modeling, LEED/BREEAM certification scoring, and OPEX forecasting for building operations.' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalConstructionDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Typical Construction Duration Months' ;
    rdfs:comment 'Typical construction duration in months for a standard building of this construction type. Used in development project scheduling in Procore, investment return timing analysis in Argus Enterprise, and construction loan draw schedule planning.' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:typicalCostPsfHigh rdf:type rdf:Property ;
    rdfs:label 'Typical Cost Psf High' ;
    rdfs:comment 'Upper bound of the typical hard construction cost range in USD per square foot (PSF) for this construction type. Paired with typical_cost_psf_low to define the cost range bracket used in development pro forma modeling and insurance replacement cost estimation.' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalCostPsfLow rdf:type rdf:Property ;
    rdfs:label 'Typical Cost Psf Low' ;
    rdfs:comment 'Lower bound of the typical hard construction cost range in USD per square foot (PSF) for this construction type. Used in development feasibility analysis, CAPEX budgeting, and replacement cost valuation in Argus Enterprise and Yardi Voyager.' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalSpanFt rdf:type rdf:Property ;
    rdfs:label 'Typical Span Ft' ;
    rdfs:comment 'Typical clear span capability in feet for the structural system of this construction type. Informs GLA/NLA planning, column-free floor plate design, and tenant improvement (TI) feasibility assessments for commercial leasing.' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalUsefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Typical Useful Life Years' ;
    rdfs:comment 'Expected economic useful life in years for buildings of this construction type. Used for depreciation schedules under FASB ASC 360 and IFRS 16, fixed asset management in Yardi Voyager, and replacement reserve modeling in investment underwriting.' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:windResistanceRating rdf:type rdf:Property ;
    rdfs:label 'Wind Resistance Rating' ;
    rdfs:comment 'Qualitative wind resistance performance rating (basic, enhanced, superior) for this construction type based on IBC and ASCE 7 wind load provisions. Supports property insurance underwriting and catastrophe risk modeling for portfolio management.' ;
    rdfs:domain ind:ConstructionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tiAllowanceCurrencyCodeId rdf:type rdf:Property ;
    rdfs:label 'Ti Allowance Currency Code Id' ;
    rdfs:comment 'Foreign key linking to reference.currency_code. Business justification: Tenant improvement allowance benchmarks (ti_allowance_benchmark_psf) are denominated in a specific currency. Linking to the ISO 4217 currency registry ensures referential integrity for financial bench' ;
    rdfs:domain ind:SpaceUseType ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CurrencyCode .

ind:adaComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Ada Compliance Required' ;
    rdfs:comment 'Indicates whether Americans with Disabilities Act (ADA) accessibility compliance requirements are mandated for spaces of this use type. Drives compliance checklist generation in Building Engines and regulatory reporting for HUD and local authorities.' ;
    rdfs:domain ind:SpaceUseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableLeaseStructures rdf:type rdf:Property ;
    rdfs:label 'Applicable Lease Structures' ;
    rdfs:comment 'Pipe-delimited list of lease structures typically associated with this space use type (e.g., \'NNN|gross|modified_gross|percentage_rent|ground_lease\'). Guides lease structuring in Yardi Voyager and DocuSign CLM and informs brokerage deal configuration. [ENUM-REF-CANDIDATE: NNN|gross|modified_gross|percentage_rent|ground_lease|net|double_net — promote to reference product]' ;
    rdfs:domain ind:SpaceUseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseRentBenchmarkPsf rdf:type rdf:Property ;
    rdfs:label 'Base Rent Benchmark Psf' ;
    rdfs:comment 'Market benchmark base rent rate expressed in currency Per Square Foot (PSF) per annum for this space use type. Sourced from CoStar Suite comparable lease data and used in Argus Enterprise cash flow modeling and brokerage CMA preparation.' ;
    rdfs:domain ind:SpaceUseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:camRecoveryMethod rdf:type rdf:Property ;
    rdfs:label 'Cam Recovery Method' ;
    rdfs:comment 'Specifies the CAM expense recovery methodology applicable to this space use type — pro-rata share, fixed amount, capped recovery, base-year stop, or not applicable. Used in Yardi Voyager CAM estimate and reconciliation schedules.' ;
    rdfs:domain ind:SpaceUseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capexResponsibility rdf:type rdf:Property ;
    rdfs:label 'Capex Responsibility' ;
    rdfs:comment 'Defines the default Capital Expenditure (CAPEX) responsibility for structural improvements and major systems for this space use type — landlord, tenant, shared, or not applicable. Supports CAPEX planning in Procore and fixed asset management in Yardi Voyager.' ;
    rdfs:domain ind:SpaceUseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coTenancyApplicable rdf:type rdf:Property ;
    rdfs:label 'Co Tenancy Applicable' ;
    rdfs:comment 'Indicates whether co-tenancy clauses (allowing rent reduction or termination rights if anchor tenants vacate) are typically applicable for this space use type. Primarily relevant for retail and food-and-beverage use types in shopping center lease structures.' ;
    rdfs:domain ind:SpaceUseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusiveUseApplicable rdf:type rdf:Property ;
    rdfs:label 'Exclusive Use Applicable' ;
    rdfs:comment 'Indicates whether exclusive use clauses (restricting the landlord from leasing adjacent space to competing tenants) are typically applicable for this space use type. Relevant for retail, food-and-beverage, and medical use types in lease negotiation and Salesforce CRM deal pipeline management.' ;
    rdfs:domain ind:SpaceUseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalCodeCostar rdf:type rdf:Property ;
    rdfs:label 'External Code Costar' ;
    rdfs:comment 'Corresponding space use type code as used in CoStar Suite for comparable lease and property analytics. Enables direct mapping between enterprise reference data and CoStar market data for benchmarking and CMA preparation.' ;
    rdfs:domain ind:SpaceUseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCodeReso rdf:type rdf:Property ;
    rdfs:label 'External Code Reso' ;
    rdfs:comment 'Corresponding space use type code as defined by the Real Estate Standards Organization (RESO) data dictionary standard. Enables interoperability with MLS systems, CoStar Suite, and other RESO-compliant platforms for data exchange and market benchmarking.' ;
    rdfs:domain ind:SpaceUseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireEgressClass rdf:type rdf:Property ;
    rdfs:label 'Fire Egress Class' ;
    rdfs:comment 'International Building Code (IBC) occupancy classification for fire egress and life safety purposes associated with this space use type (e.g., assembly, business, mercantile, storage). Drives building compliance checks and preventive maintenance scheduling in Building Engines. [ENUM-REF-CANDIDATE: assembly|business|mercantile|industrial|storage|residential|hazardous|not_applicable — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SpaceUseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fitOutCategory rdf:type rdf:Property ;
    rdfs:label 'Fit Out Category' ;
    rdfs:comment 'Standard fit-out delivery condition associated with this space use type — warm shell, cold shell, turnkey, as-is, or not applicable. Informs TI allowance benchmarking, construction scope in Procore, and lease negotiation defaults in Salesforce CRM.' ;
    rdfs:domain ind:SpaceUseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodServicePermitted rdf:type rdf:Property ;
    rdfs:label 'Food Service Permitted' ;
    rdfs:comment 'Indicates whether food preparation and service activities are permitted for spaces of this use type. Relevant for distinguishing restaurant/F&B use from retail or office use types, and for triggering health department compliance requirements and grease trap infrastructure planning.' ;
    rdfs:domain ind:SpaceUseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hvacResponsibility rdf:type rdf:Property ;
    rdfs:label 'Hvac Responsibility' ;
    rdfs:comment 'Defines who bears responsibility for Heating, Ventilation, and Air Conditioning (HVAC) systems for this space use type — landlord, tenant, shared, or not applicable. Drives lease clause defaults in DocuSign CLM and work order assignment rules in Building Engines.' ;
    rdfs:domain ind:SpaceUseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leedRelevance rdf:type rdf:Property ;
    rdfs:label 'Leed Relevance' ;
    rdfs:comment 'Indicates the degree to which LEED certification criteria and ESG sustainability metrics are relevant to this space use type — high, medium, low, or not applicable. Supports ESG reporting, green building compliance, and LEED certification tracking per U.S. Green Building Council standards.' ;
    rdfs:domain ind:SpaceUseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadFactorTypical rdf:type rdf:Property ;
    rdfs:label 'Load Factor Typical' ;
    rdfs:comment 'Typical load factor (also known as loss factor or add-on factor) expressed as a decimal ratio for this space use type, representing the difference between rentable and usable area (e.g., 0.15 = 15%). Used in BOMA-compliant area calculations and rent roll reporting in Yardi Voyager.' ;
    rdfs:domain ind:SpaceUseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxContiguousArea rdf:type rdf:Property ;
    rdfs:label 'Max Contiguous Area' ;
    rdfs:comment 'Maximum contiguous leasable area (in the applicable unit of measure — SQF or SQM) typically available for this space use type within a single building. Used in CoStar Suite availability searches and brokerage space matching for large-block tenant requirements.' ;
    rdfs:domain ind:SpaceUseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementStandard rdf:type rdf:Property ;
    rdfs:label 'Measurement Standard' ;
    rdfs:comment 'Defines the area measurement methodology applicable to this space use type — Gross Leasable Area (GLA), Net Leasable Area (NLA), BOMA standard, IPMS standard, gross, or net. Governs how rentable square footage is calculated and reported for rent roll and lease administration purposes.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minDivisibleArea rdf:type rdf:Property ;
    rdfs:label 'Min Divisible Area' ;
    rdfs:comment 'Minimum leasable area (in the applicable unit of measure — SQF or SQM) to which a space of this use type can be subdivided. Governs space planning and demised space configuration in Yardi Voyager and MRI Software space inventory management.' ;
    rdfs:domain ind:SpaceUseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:occupancyDensityTypical rdf:type rdf:Property ;
    rdfs:label 'Occupancy Density Typical' ;
    rdfs:comment 'Typical occupancy density expressed as area per person (SQF or SQM per person) for this space use type. Used in building capacity planning, HVAC sizing, fire safety compliance, and ESG workplace analytics.' ;
    rdfs:domain ind:SpaceUseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outdoorAreaApplicable rdf:type rdf:Property ;
    rdfs:label 'Outdoor Area Applicable' ;
    rdfs:comment 'Indicates whether outdoor or exterior leasable area (e.g., patio, terrace, rooftop deck, signage fascia) is applicable and measurable for this space use type. Affects GLA/NLA calculation methodology and lease area definitions in Yardi Voyager.' ;
    rdfs:domain ind:SpaceUseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parkingRatioPer1000sqf rdf:type rdf:Property ;
    rdfs:label 'Parking Ratio Per 1000sqf' ;
    rdfs:comment 'Standard parking ratio (number of parking stalls per 1,000 square feet of leasable area) associated with this space use type. Used in property development feasibility, zoning compliance, and lease negotiation for office, retail, and medical use types.' ;
    rdfs:domain ind:SpaceUseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:propertyTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Property Type Applicability' ;
    rdfs:comment 'Pipe-delimited list of property types to which this space use type applies (e.g., \'office_building|mixed_use|retail_center|medical_office\'). Constrains valid space use assignments during lease and space inventory setup in Yardi Voyager and MRI Software. [ENUM-REF-CANDIDATE: office_building|retail_center|mixed_use|medical_office|industrial|multifamily|hospitality|specialty — promote to reference product]' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Method' ;
    rdfs:comment 'Accounting revenue recognition method applicable to lease income for this space use type — straight-line, cash basis, percentage of completion, or not applicable. Governs lease accounting entries in Yardi Voyager GL and SAP S/4HANA financial consolidation per FASB ASC 842 and IFRS 16.' ;
    rdfs:domain ind:SpaceUseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rouAssetApplicable rdf:type rdf:Property ;
    rdfs:label 'Rou Asset Applicable' ;
    rdfs:comment 'Indicates whether a Right-of-Use (ROU) asset must be recognized on the lessee\'s balance sheet for leases of this space use type under FASB ASC 842 or IFRS 16. Drives lease accounting classification logic in Yardi Voyager and MRI Software lease accounting modules.' ;
    rdfs:domain ind:SpaceUseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spaceUseTypeStatus rdf:type rdf:Property ;
    rdfs:label 'Space Use Type Status' ;
    rdfs:comment 'Current lifecycle status of the space use type record in the controlled vocabulary — active (in use), inactive (no longer applied to new leases), deprecated (replaced by another code), or pending_review (under governance review). Governs availability of the code in downstream lease and property systems.' ;
    rdfs:domain ind:SpaceUseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalLeaseTermMaxMonths rdf:type rdf:Property ;
    rdfs:label 'Typical Lease Term Max Months' ;
    rdfs:comment 'Maximum typical lease term in months for this space use type, reflecting market norms. Used alongside the minimum to define the expected lease term range for deal structuring, WALT analysis, and Argus Enterprise cash flow modeling.' ;
    rdfs:domain ind:SpaceUseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:typicalLeaseTermMinMonths rdf:type rdf:Property ;
    rdfs:label 'Typical Lease Term Min Months' ;
    rdfs:comment 'Minimum typical lease term in months for this space use type, reflecting market norms (e.g., 12 months for storage, 60 months for office, 120 months for anchor retail). Used in Weighted Average Lease Term (WALT) benchmarking and deal underwriting.' ;
    rdfs:domain ind:SpaceUseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:useCategory rdf:type rdf:Property ;
    rdfs:label 'Use Category' ;
    rdfs:comment 'Broad asset class category grouping the space use type (e.g., commercial, residential, mixed_use, industrial, hospitality, specialty). Aligns with CoStar Suite and Argus Enterprise asset class taxonomies for portfolio-level reporting and investment analysis.' ;
    rdfs:domain ind:SpaceUseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:useTypeCode rdf:type rdf:Property ;
    rdfs:label 'Use Type Code' ;
    rdfs:comment 'Short, system-recognized alphanumeric code uniquely identifying the space use type (e.g., OFF, RET, F&B, MED, FIT, STG, PRK, RTF, SGN, CAM). Used as the business key in Yardi Voyager, MRI Software, and CoStar Suite for space inventory classification and rent roll reporting.' ;
    rdfs:domain ind:SpaceUseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:useTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Use Type Description' ;
    rdfs:comment 'Detailed narrative description of the space use classification, including typical tenant profile, permitted activities, and distinguishing characteristics from adjacent use types. Supports training, onboarding, and data governance documentation.' ;
    rdfs:domain ind:SpaceUseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:useTypeName rdf:type rdf:Property ;
    rdfs:label 'Use Type Name' ;
    rdfs:comment 'Full human-readable name of the space use classification (e.g., \'Office\', \'Retail\', \'Restaurant / Food and Beverage\', \'Medical / Dental\', \'Fitness\', \'Storage\', \'Parking\', \'Rooftop\', \'Signage\', \'Common Area\'). Displayed in lease administration, rent roll, and brokerage reporting.' ;
    rdfs:domain ind:SpaceUseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoningUseClass rdf:type rdf:Property ;
    rdfs:label 'Zoning Use Class' ;
    rdfs:comment 'Standard zoning use classification code or category associated with this space use type (e.g., B1, A1, A3, D1 under UK Use Classes Order; or C-1, C-2, O-1 under US zoning codes). Supports regulatory compliance checks and development feasibility analysis. [ENUM-REF-CANDIDATE: promote to reference product if jurisdiction-specific zoning codes are required]' ;
    rdfs:domain ind:SpaceUseType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alpha2Code rdf:type rdf:Property ;
    rdfs:label 'Alpha2 Code' ;
    rdfs:comment 'Two-letter ISO 3166-1 country code (e.g., US, GB, DE). Used as the primary short-form identifier in lease agreements, tenant records, property addresses, and regulatory filings across Yardi Voyager and SAP S/4HANA.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alpha3Code rdf:type rdf:Property ;
    rdfs:label 'Alpha3 Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 country code (e.g., USA, GBR, DEU). Used in financial consolidation reporting in SAP S/4HANA, CMBS/RMBS documentation, and cross-border investment portfolio reporting in Argus Enterprise.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amlRiskRating rdf:type rdf:Property ;
    rdfs:label 'Aml Risk Rating' ;
    rdfs:comment 'FATF-aligned AML risk classification for the country. Used in KYC/AML due diligence for real estate transactions, tenant onboarding, and cross-border investment approvals. High-risk countries require enhanced due diligence per SOX and SEC compliance requirements.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaMeasurementBody rdf:type rdf:Property ;
    rdfs:label 'Area Measurement Body' ;
    rdfs:comment 'Name of the primary standards body governing property area measurement methodology in the country (e.g., BOMA, IPMS, RICS). Ensures consistent GLA/NLA calculations for PSF rent benchmarking and CAM reconciliation.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breeamRecognized rdf:type rdf:Property ;
    rdfs:label 'Breeam Recognized' ;
    rdfs:comment 'Indicates whether BREEAM certification is officially recognized or incentivized in the country. Relevant for ESG compliance, green building asset classification, and sustainability reporting for European and international portfolios.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capitalCity rdf:type rdf:Property ;
    rdfs:label 'Capital City' ;
    rdfs:comment 'Name of the country\'s capital city. Used as a geographic reference point for market research, CoStar comparable data alignment, and investment market classification.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalGainsTaxApplicable rdf:type rdf:Property ;
    rdfs:label 'Capital Gains Tax Applicable' ;
    rdfs:comment 'Indicates whether capital gains tax applies to real estate dispositions in the country. Affects IRR and NPV modeling in Argus Enterprise, investment advisory recommendations, and property acquisition/disposition strategy.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countryName rdf:type rdf:Property ;
    rdfs:label 'Country Name' ;
    rdfs:comment 'Official short-form country name in English as defined by ISO 3166-1 (e.g., United States, United Kingdom, Germany). Used as the display label in property records, lease agreements, tenant profiles, and portfolio reports.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryStatus rdf:type rdf:Property ;
    rdfs:label 'Country Status' ;
    rdfs:comment 'Operational status of the country record within the enterprise reference data registry. \'active\' indicates the country is in use across operational systems; \'inactive\' indicates no current portfolio exposure; \'deprecated\' indicates the country code has been superseded (e.g., post-dissolution or renaming per ISO 3166-1 updates).' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Default Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code representing the primary legal tender of the country (e.g., USD, GBP, EUR). Used as the default currency for property valuations, lease rent schedules, NOI calculations, and CAP rate analysis in Yardi Voyager, MRI Software, and Argus Enterprise.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dialingCode rdf:type rdf:Property ;
    rdfs:label 'Dialing Code' ;
    rdfs:comment 'International telephone dialing prefix for the country (e.g., +1 for USA, +44 for UK). Used for formatting tenant and owner contact phone numbers in Salesforce CRM and Yardi Voyager tenant records.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgReportingFramework rdf:type rdf:Property ;
    rdfs:label 'Esg Reporting Framework' ;
    rdfs:comment 'Primary ESG reporting framework mandated or commonly adopted for real estate assets in the country (e.g., GRI, TCFD, SFDR, local regulation). Drives sustainability data collection, LEED/BREEAM certification tracking, and ESG disclosure requirements for REITs and institutional investors.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatfMember rdf:type rdf:Property ;
    rdfs:label 'Fatf Member' ;
    rdfs:comment 'Indicates whether the country is a member of the Financial Action Task Force (FATF). Relevant for AML/KYC compliance in cross-border real estate investment transactions, REIT capital flows, and CMBS/RMBS structuring.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:foreignOwnershipAllowed rdf:type rdf:Property ;
    rdfs:label 'Foreign Ownership Allowed' ;
    rdfs:comment 'Indicates whether foreign nationals and entities are permitted to own real property in the country. Critical for investment advisory, portfolio acquisition strategy, and REIT eligibility assessments in Argus Enterprise and MRI Software.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:foreignOwnershipRestrictionNotes rdf:type rdf:Property ;
    rdfs:label 'Foreign Ownership Restriction Notes' ;
    rdfs:comment 'Narrative description of any restrictions, conditions, or limitations on foreign ownership of real property in the country (e.g., maximum ownership percentage, restricted zones, required local partner). Supports investment advisory and compliance review.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprApplicable rdf:type rdf:Property ;
    rdfs:label 'Gdpr Applicable' ;
    rdfs:comment 'Indicates whether the General Data Protection Regulation (GDPR) applies to real estate operations conducted in or with residents of this country. Drives data handling policies for tenant PII in Salesforce CRM, Yardi Voyager, and DocuSign CLM.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ifrsAdopted rdf:type rdf:Property ;
    rdfs:label 'Ifrs Adopted' ;
    rdfs:comment 'Indicates whether the country has adopted International Financial Reporting Standards (IFRS) for financial reporting. Determines applicable accounting treatment for investment property (IAS 40), lease liabilities (IFRS 16), and financial instrument disclosures in SAP S/4HANA.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:landRegistrationSystem rdf:type rdf:Property ;
    rdfs:label 'Land Registration System' ;
    rdfs:comment 'Type of land title registration system in use in the country. Affects title insurance requirements, ALTA policy applicability, due diligence procedures for property acquisition, and LTV calculations for debt instruments.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseAccountingStandard rdf:type rdf:Property ;
    rdfs:label 'Lease Accounting Standard' ;
    rdfs:comment 'The applicable lease accounting standard for real estate leases in the country. Drives right-of-use asset recognition, lease liability classification, and financial statement presentation in Yardi Voyager lease accounting and SAP S/4HANA financial consolidation.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leedRecognized rdf:type rdf:Property ;
    rdfs:label 'Leed Recognized' ;
    rdfs:comment 'Indicates whether LEED certification is officially recognized or incentivized by the country\'s regulatory or governmental bodies. Supports ESG reporting, green building compliance tracking, and sustainability-linked financing decisions.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:multipleTimeZones rdf:type rdf:Property ;
    rdfs:label 'Multiple Time Zones' ;
    rdfs:comment 'Indicates whether the country spans multiple time zones. Relevant for scheduling lease payment processing, maintenance dispatch, and financial period close operations across geographically dispersed property portfolios.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:officialName rdf:type rdf:Property ;
    rdfs:label 'Official Name' ;
    rdfs:comment 'Full official name of the country as recognized by the United Nations (e.g., United States of America, United Kingdom of Great Britain and Northern Ireland). Used in legal contracts, SNDA agreements, and regulatory filings requiring formal jurisdiction identification.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioExposure rdf:type rdf:Property ;
    rdfs:label 'Portfolio Exposure' ;
    rdfs:comment 'Indicates whether the enterprise currently holds active real estate assets, leases, or investments in this country. Used to filter active jurisdictions in portfolio reporting, AUM dashboards, and regulatory compliance monitoring.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryValuationStandard rdf:type rdf:Property ;
    rdfs:label 'Primary Valuation Standard' ;
    rdfs:comment 'The predominant property valuation standard applied in the country. Determines the methodology used for appraisals, CAP rate benchmarking, DCF modeling, and NAV/GAV calculations in Argus Enterprise and investment advisory services.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertyLawSystem rdf:type rdf:Property ;
    rdfs:label 'Property Law System' ;
    rdfs:comment 'Legal system governing property rights and real estate transactions in the country. Determines applicable title transfer procedures, SNDA enforceability, ground lease structures, and tenure type classifications used in lease administration and investment advisory.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reitFrameworkExists rdf:type rdf:Property ;
    rdfs:label 'Reit Framework Exists' ;
    rdfs:comment 'Indicates whether the country has an established legal and regulatory framework for Real Estate Investment Trusts (REITs) or equivalent listed property vehicles. Used in investment portfolio structuring and AUM classification in Argus Enterprise.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sanctionsStatus rdf:type rdf:Property ;
    rdfs:label 'Sanctions Status' ;
    rdfs:comment 'Current OFAC/UN sanctions status for the country. Determines whether real estate transactions, lease agreements, and investment activities are permissible. \'sanctioned\' or \'embargoed\' countries are blocked from all transaction processing in Yardi Voyager and SAP S/4HANA.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sovereigntyType rdf:type rdf:Property ;
    rdfs:label 'Sovereignty Type' ;
    rdfs:comment 'Classification of the country or territory\'s political sovereignty status. Determines applicable legal frameworks, title insurance requirements (ALTA), and regulatory reporting obligations for cross-border real estate transactions.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardVatRatePct rdf:type rdf:Property ;
    rdfs:label 'Standard Vat Rate Pct' ;
    rdfs:comment 'Standard VAT or GST rate applicable to real estate transactions in the country, expressed as a percentage (e.g., 20.00 for 20%). Used in lease rent schedule calculations, AP invoice processing, and tax provision modeling in SAP S/4HANA.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subRegion rdf:type rdf:Property ;
    rdfs:label 'Sub Region' ;
    rdfs:comment 'UN M.49 sub-regional grouping for the country (e.g., Northern Europe, South-Eastern Asia, Northern America). Supports granular portfolio analytics and cross-border investment reporting in Argus Enterprise.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxTreatyWithUs rdf:type rdf:Property ;
    rdfs:label 'Tax Treaty With Us' ;
    rdfs:comment 'Indicates whether the country has an active bilateral tax treaty with the United States. Affects withholding tax rates on rental income, capital gains treatment for cross-border property dispositions, and REIT distribution taxation for international investors.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeZonePrimary rdf:type rdf:Property ;
    rdfs:label 'Time Zone Primary' ;
    rdfs:comment 'IANA time zone identifier for the country\'s primary or capital time zone (e.g., America/New_York, Europe/London). Used for scheduling lease payment due dates, maintenance work orders in Building Engines, and financial period close timestamps in SAP S/4HANA.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatApplicable rdf:type rdf:Property ;
    rdfs:label 'Vat Applicable' ;
    rdfs:comment 'Indicates whether Value Added Tax (VAT) or equivalent goods and services tax applies to real estate transactions and rental income in the country. Affects lease rent invoicing, CAM charge calculations, and AP/AR processing in Yardi Voyager and SAP S/4HANA.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:withholdingTaxRatePct rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Rate Pct' ;
    rdfs:comment 'Standard withholding tax rate applied to rental income and property-related payments remitted to foreign investors in the country, expressed as a percentage. Used in cross-border investment advisory, REIT distribution modeling, and DSCR calculations.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:constructionLoanDebtInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Construction Loan Debt Instrument Id' ;
    rdfs:comment 'Foreign key linking to finance.debt_instrument. Business justification: Development projects are financed by construction loans. Linking the project to its debt instrument enables LTV/DSCR covenant monitoring, draw schedule management, and lender reporting — all standard ' ;
    rdfs:domain ind:DevProject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DebtInstrument .

ind:actualCostToDateUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Cost To Date Usd' ;
    rdfs:comment 'Cumulative actual project costs incurred to date in US dollars, including all approved invoices, contractor payments, and capitalized soft costs. Compared against total_budget_usd for budget variance analysis and CAPEX draw schedule reconciliation. Sourced from SAP S/4HANA AP and Yardi Voyager Fixed Assets.' ;
    rdfs:domain ind:DevProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:asBuiltDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'As Built Delivery Date' ;
    rdfs:comment 'Date on which the general contractor delivered final as-built drawings and documentation to the owner (yyyy-MM-dd). Required closeout deliverable confirming that construction records reflect actual field conditions. Prerequisite for final retainage release and O&M manual acceptance.' ;
    rdfs:domain ind:DevProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:buildingPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Building Permit Number' ;
    rdfs:comment 'Primary building permit number issued by the local jurisdiction authorizing construction. Tracked for regulatory compliance, inspection scheduling, and permit fee reconciliation. Stored in Procore document control.' ;
    rdfs:domain ind:DevProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeoutPackageComplete rdf:type rdf:Property ;
    rdfs:label 'Closeout Package Complete' ;
    rdfs:comment 'Indicates whether all project closeout deliverables have been received and accepted, including as-built drawings, O&M manuals, warranty registrations, lien waivers, COO, and final retainage release (True = complete, False = pending). Triggers formal handoff to asset management and property management teams.' ;
    rdfs:domain ind:DevProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contingencyBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Contingency Budget Usd' ;
    rdfs:comment 'Budget reserve allocated for unforeseen construction costs, scope changes, and risk mitigation. Typically expressed as a percentage of hard costs (e.g., 5-10%). Managed through Procore change order workflows and SAP S/4HANA project cost control.' ;
    rdfs:domain ind:DevProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cooNumber rdf:type rdf:Property ;
    rdfs:label 'Coo Number' ;
    rdfs:comment 'Official Certificate of Occupancy (COO) number issued by the local building authority upon successful final inspection. Required before tenants can legally occupy the building. Critical closeout milestone for lease commencement and asset handoff to property management.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentPhase rdf:type rdf:Property ;
    rdfs:label 'Current Phase' ;
    rdfs:comment 'Current phase within the project lifecycle following standard AIA/construction industry phase gates: entitlement, schematic design, design development, construction documents, bidding, construction, substantial completion, and closeout. More granular than project_status and used for milestone-level tracking and Procore phase management. [ENUM-REF-CANDIDATE: entitlement|schematic_design|design_development|construction_documents|bidding|construction|substantial_completion|closeout — promote to reference product]' ;
    rdfs:domain ind:DevProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgFlag rdf:type rdf:Property ;
    rdfs:label 'Esg Flag' ;
    rdfs:comment 'Indicates whether this development project has been formally designated as an ESG (Environmental, Social, and Governance) initiative for green bond financing, sustainability reporting, or REIT ESG disclosure purposes (True = ESG designated, False = standard project).' ;
    rdfs:domain ind:DevProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Completion Date' ;
    rdfs:comment 'Currently projected substantial completion date for the development project (yyyy-MM-dd). Updated through the project lifecycle as schedule changes occur. Used for lease commencement planning, Certificate of Occupancy (COO) target setting, and investment return modeling in Argus Enterprise.' ;
    rdfs:domain ind:DevProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedStartDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Start Date' ;
    rdfs:comment 'Originally planned or currently projected construction start date (yyyy-MM-dd). Used for contractor mobilization scheduling, financing draw schedule setup, and portfolio CAPEX forecasting. May differ from actual_start_date due to entitlement delays or permitting timelines.' ;
    rdfs:domain ind:DevProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:farProposed rdf:type rdf:Property ;
    rdfs:label 'Far Proposed' ;
    rdfs:comment 'Proposed Floor Area Ratio (FAR) for the development as submitted in entitlement and design documents. Compared against far_allowed to confirm zoning compliance. Tracked through design phase iterations.' ;
    rdfs:domain ind:DevProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalRetainageReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Final Retainage Release Date' ;
    rdfs:comment 'Date on which the final construction retainage amount was released to the general contractor (yyyy-MM-dd). Retainage is typically 5-10% of contract value withheld until project closeout conditions are met. Triggers final AP payment processing in Yardi Voyager and SAP S/4HANA.' ;
    rdfs:domain ind:DevProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hardCostBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Hard Cost Budget Usd' ;
    rdfs:comment 'Portion of the total project budget allocated to hard costs — direct construction costs including site work, structural, MEP (mechanical, electrical, plumbing), finishes, and contractor fees. Tracked separately from soft costs for CAPEX draw schedule management and contractor payment applications.' ;
    rdfs:domain ind:DevProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:omManualSubmitted rdf:type rdf:Property ;
    rdfs:label 'Om Manual Submitted' ;
    rdfs:comment 'Indicates whether the contractor has submitted the Operations and Maintenance (O&M) manual package to the owner as part of project closeout (True = submitted, False = pending). O&M manuals cover HVAC, electrical, plumbing, and building systems. Required for Building Engines facility operations onboarding.' ;
    rdfs:domain ind:DevProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:procoreProjectReference rdf:type rdf:Property ;
    rdfs:label 'Procore Project Reference' ;
    rdfs:comment 'Source-system project identifier from Procore (Construction and Development Project Management). Enables traceability and reconciliation between the lakehouse Silver Layer record and the operational system of record. Used for data lineage and cross-system joins during ETL.' ;
    rdfs:domain ind:Development ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:softCostBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Soft Cost Budget Usd' ;
    rdfs:comment 'Portion of the total project budget allocated to soft costs — indirect project costs including architecture and engineering fees, legal and entitlement costs, permitting fees, environmental studies, financing costs, and project management fees. Tracked separately for CAPEX classification and tax treatment.' ;
    rdfs:domain ind:DevProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetGlaSqft rdf:type rdf:Property ;
    rdfs:label 'Target Gla Sqft' ;
    rdfs:comment 'Target Gross Leasable Area (GLA) for the completed development, measured in square feet (SQF). Represents the total floor area designed for tenant occupancy and lease revenue generation. Used in investment underwriting, Argus Enterprise cash flow modeling, and portfolio reporting.' ;
    rdfs:domain ind:DevProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetNlaSqft rdf:type rdf:Property ;
    rdfs:label 'Target Nla Sqft' ;
    rdfs:comment 'Target Net Leasable Area (NLA) for the completed development, measured in square feet (SQF). Represents usable tenant space after deducting common areas, mechanical rooms, and circulation. Used for PSF (Per Square Foot) rent underwriting and lease absorption modeling.' ;
    rdfs:domain ind:DevProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Total Budget Usd' ;
    rdfs:comment 'Total approved project budget in US dollars (USD), encompassing all hard costs (construction), soft costs (design, legal, permitting), land costs, financing costs, and contingency reserves. The primary CAPEX (Capital Expenditure) authorization amount. Sourced from SAP S/4HANA Project Systems and Procore budget module.' ;
    rdfs:domain ind:DevProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStories rdf:type rdf:Property ;
    rdfs:label 'Total Stories' ;
    rdfs:comment 'Total number of above-grade floors in the planned development. Used for structural engineering classification, fire code compliance, elevator planning, and building permit applications.' ;
    rdfs:domain ind:DevProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyRegistrationDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Registration Date' ;
    rdfs:comment 'Date on which contractor and equipment warranties were formally registered with the owner (yyyy-MM-dd). Initiates warranty tracking periods for building systems, roofing, and major equipment. Supports maintenance planning in Building Engines and CAPEX reserve scheduling.' ;
    rdfs:domain ind:DevProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:zoningApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Zoning Approval Date' ;
    rdfs:comment 'Date on which final zoning approval or variance was granted by the local planning authority (yyyy-MM-dd). Marks completion of the entitlement phase and enables progression to design and permitting. Critical milestone for project schedule and investment commitment decisions.' ;
    rdfs:domain ind:DevProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affordableUnitCount rdf:type rdf:Property ;
    rdfs:label 'Affordable Unit Count' ;
    rdfs:comment 'Number of dwelling units designated as affordable housing within the proposed development. Often a condition of approval for bonus FAR or density bonuses under inclusionary zoning requirements.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appealDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Deadline Date' ;
    rdfs:comment 'Date by which an appeal of the entitlement decision must be filed with the appropriate appellate body. After this date, the entitlement decision becomes final and vested. Critical for project risk management.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealFiled rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed' ;
    rdfs:comment 'Indicates whether an appeal of the entitlement decision has been filed by a third party or the applicant. A value of True signals that the entitlement is subject to appellate review and the project timeline may be impacted.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicantContact rdf:type rdf:Property ;
    rdfs:label 'Applicant Contact' ;
    rdfs:comment 'Primary contact information for the entitlement applicant, including name, phone, or email of the responsible representative. Used for correspondence with the regulatory authority.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicantName rdf:type rdf:Property ;
    rdfs:label 'Applicant Name' ;
    rdfs:comment 'Name of the legal entity or individual who submitted the entitlement application to the governing jurisdiction. Typically the property owner, developer, or their authorized representative.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationDate rdf:type rdf:Property ;
    rdfs:label 'Application Date' ;
    rdfs:comment 'Date on which the entitlement application was formally submitted to the governing jurisdiction. Marks the start of the regulatory review clock and is used for tracking processing timelines.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:asBuiltFar rdf:type rdf:Property ;
    rdfs:label 'As Built Far' ;
    rdfs:comment 'The actual FAR of the completed development as measured upon construction completion. Compared against total allowable FAR to confirm final FAR compliance. Populated post-construction.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseFarAllowance rdf:type rdf:Property ;
    rdfs:label 'Base Far Allowance' ;
    rdfs:comment 'The baseline Floor Area Ratio (FAR) permitted by the zoning district without any bonus mechanisms. Represents the ratio of total building floor area to the gross site area as established by the applicable zoning ordinance.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusFar rdf:type rdf:Property ;
    rdfs:label 'Bonus Far' ;
    rdfs:comment 'Additional FAR allowance earned through bonus mechanisms such as affordable housing inclusion, open space dedication, transit proximity, or public amenity contributions. Added to the base FAR to derive total allowable FAR.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusFarMechanism rdf:type rdf:Property ;
    rdfs:label 'Bonus Far Mechanism' ;
    rdfs:comment 'The specific incentive mechanism through which bonus FAR was earned (e.g., affordable housing set-aside, open space dedication, transit proximity, public amenity). Determines the conditions and obligations attached to the bonus FAR grant.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionsOfApproval rdf:type rdf:Property ;
    rdfs:label 'Conditions Of Approval' ;
    rdfs:comment 'Narrative description of the conditions, mitigation measures, or obligations imposed by the regulatory authority as part of the entitlement approval. May include infrastructure dedications, design requirements, operational restrictions, or monitoring obligations.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counsel rdf:type rdf:Property ;
    rdfs:label 'Counsel' ;
    rdfs:comment 'Name of the law firm or attorney representing the applicant in the entitlement process. Entitlement counsel manages regulatory submissions, hearing appearances, and conditions negotiations.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denialDate rdf:type rdf:Property ;
    rdfs:label 'Denial Date' ;
    rdfs:comment 'Date on which the entitlement application was formally denied by the governing authority. Null if not denied. Used for tracking appeal windows and regulatory timelines.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entitlementName rdf:type rdf:Property ;
    rdfs:label 'Entitlement Name' ;
    rdfs:comment 'Human-readable descriptive name or title for the entitlement (e.g., \'Mixed-Use Conditional Use Permit — Block 42\', \'Height Variance — Tower A\'). Used for display and reporting purposes.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementNumber rdf:type rdf:Property ;
    rdfs:label 'Entitlement Number' ;
    rdfs:comment 'Externally-known reference number or case number assigned by the governing jurisdiction or planning authority for this entitlement application (e.g., CUP-2024-0042, VAR-2024-0017). Used for cross-referencing with municipal records.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementStatus rdf:type rdf:Property ;
    rdfs:label 'Entitlement Status' ;
    rdfs:comment 'Current lifecycle state of the entitlement application. Tracks progression from initial draft through submission, regulatory review, planning commission decision, and any appeal or withdrawal. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|denied|appealed|withdrawn — promote to reference product]' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementType rdf:type rdf:Property ;
    rdfs:label 'Entitlement Type' ;
    rdfs:comment 'Classification of the entitlement by its regulatory category. Identifies whether the entitlement is a zoning approval, variance, conditional use permit (CUP), environmental impact review, subdivision map, planned unit development (PUD), or design review. [ENUM-REF-CANDIDATE: zoning_approval|variance|conditional_use_permit|environmental_impact_review|subdivision_map|planned_unit_development|design_review — promote to reference product]' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Environmental Review Status' ;
    rdfs:comment 'Current status of the environmental impact review process associated with this entitlement. Tracks progression from initiation through certification, which is typically a prerequisite for entitlement approval.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalReviewType rdf:type rdf:Property ;
    rdfs:label 'Environmental Review Type' ;
    rdfs:comment 'Classification of the environmental review conducted for this entitlement under applicable environmental law (e.g., CEQA, NEPA). Determines the level of environmental analysis required and the associated public review process.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:farComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Far Compliance Status' ;
    rdfs:comment 'Indicates whether the proposed or as-built development is in compliance with the total allowable FAR. Drives regulatory sign-off and Certificate of Occupancy (COO) issuance eligibility.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hearingDate rdf:type rdf:Property ;
    rdfs:label 'Hearing Date' ;
    rdfs:comment 'Scheduled or actual date of the planning commission or board hearing at which this entitlement application is reviewed and decided. Critical for project scheduling and stakeholder notification.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxDensityUnits rdf:type rdf:Property ;
    rdfs:label 'Max Density Units' ;
    rdfs:comment 'Maximum number of residential dwelling units permitted on the subject parcel under the applicable zoning ordinance or as approved through the entitlement. Applicable to residential and mixed-use developments.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proposedBuildingHeightFt rdf:type rdf:Property ;
    rdfs:label 'Proposed Building Height Ft' ;
    rdfs:comment 'Proposed building height in feet as submitted in the entitlement application. Must not exceed the maximum permitted height unless a height variance has been approved.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedFar rdf:type rdf:Property ;
    rdfs:label 'Proposed Far' ;
    rdfs:comment 'The FAR proposed by the development project as submitted in the entitlement application. Calculated as proposed gross floor area divided by gross site area. Must not exceed total allowable FAR for compliance.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedGrossFloorAreaSqf rdf:type rdf:Property ;
    rdfs:label 'Proposed Gross Floor Area Sqf' ;
    rdfs:comment 'Total proposed gross floor area of the development in square feet (SQF) as submitted in the entitlement application. Used to calculate proposed FAR and assess compliance with density limits.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedUnits rdf:type rdf:Property ;
    rdfs:label 'Proposed Units' ;
    rdfs:comment 'Number of residential dwelling units proposed in the development application. Compared against maximum density units to assess density compliance.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority' ;
    rdfs:comment 'Specific regulatory body or planning commission responsible for adjudicating this entitlement (e.g., \'City Planning Commission\', \'Board of Zoning Appeals\', \'Environmental Review Board\'). May differ from the broader jurisdiction.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteAreaSqf rdf:type rdf:Property ;
    rdfs:label 'Site Area Sqf' ;
    rdfs:comment 'Gross area of the subject development parcel in square feet (SQF). Used as the denominator in FAR calculations and for density limit assessments.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAllowableFar rdf:type rdf:Property ;
    rdfs:label 'Total Allowable Far' ;
    rdfs:comment 'The maximum permitted FAR for the subject parcel, calculated as the sum of base FAR allowance and any approved bonus FAR. Represents the regulatory ceiling for building density on the site.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryConstructionCompliancePermitId rdf:type rdf:Property ;
    rdfs:label 'Primary Construction Compliance Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: Construction permits tracked in the development domain must be reconciled with compliance.permit records for regulatory reporting and audit. This cross-system link enables compliance teams to verify p' ;
    rdfs:domain ind:ConstructionPermit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:approvedFloorAreaSqft rdf:type rdf:Property ;
    rdfs:label 'Approved Floor Area Sqft' ;
    rdfs:comment 'Total floor area in square feet (SQF) authorized under this permit. Used to verify Floor Area Ratio (FAR) compliance and track the scope of permitted construction against the approved development program.' ;
    rdfs:domain ind:ConstructionPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:architectOfRecord rdf:type rdf:Property ;
    rdfs:label 'Architect Of Record' ;
    rdfs:comment 'Name of the licensed architect or engineering firm designated as the architect of record for the permitted construction. Responsible for stamped drawings submitted with the permit application.' ;
    rdfs:domain ind:ConstructionPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondAmount rdf:type rdf:Property ;
    rdfs:label 'Bond Amount' ;
    rdfs:comment 'Dollar value of the performance bond or surety bond required by the issuing authority as a condition of permit issuance. Null if no bond is required. Tracked as a contingent liability in project financials.' ;
    rdfs:domain ind:ConstructionPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bondRequired rdf:type rdf:Property ;
    rdfs:label 'Bond Required' ;
    rdfs:comment 'Indicates whether the issuing authority requires a performance bond or surety bond as a condition of permit issuance. Relevant for large-scale grading, demolition, or infrastructure permits.' ;
    rdfs:domain ind:ConstructionPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractorLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Contractor License Number' ;
    rdfs:comment 'State or jurisdiction-issued contractor license number for the contractor named on the permit. Validates contractor eligibility to perform the permitted work and is required for regulatory compliance.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractorName rdf:type rdf:Property ;
    rdfs:label 'Contractor Name' ;
    rdfs:comment 'Legal name of the licensed general contractor or specialty subcontractor named on the permit as the responsible party for the permitted work. Required by most jurisdictions for permit issuance.' ;
    rdfs:domain ind:ConstructionPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cooIssuanceDate rdf:type rdf:Property ;
    rdfs:label 'Coo Issuance Date' ;
    rdfs:comment 'Date on which the Certificate of Occupancy (COO) was formally issued by the authority. Null until COO is granted. Critical milestone for lease commencement, asset capitalization, and regulatory compliance.' ;
    rdfs:domain ind:ConstructionPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cooIssued rdf:type rdf:Property ;
    rdfs:label 'Coo Issued' ;
    rdfs:comment 'Indicates whether a Certificate of Occupancy (COO) has been issued in connection with this permit. True when the COO has been granted by the authority, enabling legal occupancy of the structure.' ;
    rdfs:domain ind:ConstructionPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:farComplianceConfirmed rdf:type rdf:Property ;
    rdfs:label 'Far Compliance Confirmed' ;
    rdfs:comment 'Indicates whether the permitted construction has been confirmed to comply with the applicable Floor Area Ratio (FAR) limits for the zoning district. FAR compliance is a prerequisite for permit issuance in most jurisdictions.' ;
    rdfs:domain ind:ConstructionPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feePaymentDate rdf:type rdf:Property ;
    rdfs:label 'Fee Payment Date' ;
    rdfs:comment 'Date on which the permit fee was paid to the issuing authority. Null if fee has not yet been paid. Used for CAPEX draw schedule reconciliation and development cost tracking.' ;
    rdfs:domain ind:ConstructionPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Final Inspection Date' ;
    rdfs:comment 'Date on which the final inspection by the issuing authority was completed. Null if final inspection has not yet occurred. Prerequisite for Certificate of Occupancy (COO) issuance.' ;
    rdfs:domain ind:ConstructionPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionResultNotes rdf:type rdf:Property ;
    rdfs:label 'Inspection Result Notes' ;
    rdfs:comment 'Free-text notes recorded by the inspector or project manager documenting findings, deficiencies, or conditions identified during the permit inspection. Supports re-inspection planning and compliance remediation.' ;
    rdfs:domain ind:ConstructionPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuanceDate rdf:type rdf:Property ;
    rdfs:label 'Issuance Date' ;
    rdfs:comment 'Date on which the permit was officially issued by the authority. Marks the start of the authorized construction window and triggers the permit validity period.' ;
    rdfs:domain ind:ConstructionPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permitConditions rdf:type rdf:Property ;
    rdfs:label 'Permit Conditions' ;
    rdfs:comment 'Free-text description of any special conditions, restrictions, or requirements imposed by the issuing authority as part of permit approval. May include noise ordinances, work hour restrictions, environmental mitigation measures, or neighbor notification requirements.' ;
    rdfs:domain ind:ConstructionPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitDescription rdf:type rdf:Property ;
    rdfs:label 'Permit Description' ;
    rdfs:comment 'Narrative description of the scope of work authorized under this permit as stated by the issuing authority. Captures the specific construction activities, systems, or structures covered.' ;
    rdfs:domain ind:ConstructionPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Permit Fee Amount' ;
    rdfs:comment 'Total fee amount charged by the issuing authority for the permit application and issuance. Denominated in the local currency (USD). Included in project Capital Expenditure (CAPEX) tracking and development cost budgets.' ;
    rdfs:domain ind:ConstructionPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permitFeePaid rdf:type rdf:Property ;
    rdfs:label 'Permit Fee Paid' ;
    rdfs:comment 'Indicates whether the permit fee has been fully paid to the issuing authority. Unpaid fees may result in permit suspension or revocation. Supports accounts payable reconciliation for development CAPEX.' ;
    rdfs:domain ind:ConstructionPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permitNumber rdf:type rdf:Property ;
    rdfs:label 'Permit Number' ;
    rdfs:comment 'Externally assigned permit number issued by the governing municipality or jurisdiction authority. This is the official public-facing identifier used in all regulatory correspondence and inspection scheduling.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitPhase rdf:type rdf:Property ;
    rdfs:label 'Permit Phase' ;
    rdfs:comment 'Development phase during which this permit is applicable. Aligns the permit to the project lifecycle from entitlement through post-occupancy. Supports milestone-based CAPEX draw scheduling and project reporting.' ;
    rdfs:domain ind:ConstructionPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitStatus rdf:type rdf:Property ;
    rdfs:label 'Permit Status' ;
    rdfs:comment 'Current lifecycle state of the construction permit. Drives compliance tracking, inspection scheduling, and COO issuance eligibility. Valid values: applied, issued, active, expired, revoked, closed.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitType rdf:type rdf:Property ;
    rdfs:label 'Permit Type' ;
    rdfs:comment 'Classification of the construction permit by trade or phase of work. Drives inspection sequencing and COO issuance workflow. [ENUM-REF-CANDIDATE: grading|foundation|structural|mechanical|electrical|plumbing|fire_suppression|demolition|occupancy|site_work — promote to reference product]' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Sequential revision number indicating how many times this permit has been amended or revised since original issuance. A value of 0 indicates the original permit. Supports permit version control and change order tracking.' ;
    rdfs:domain ind:Development ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Work Completion Date' ;
    rdfs:comment 'Date by which all permitted construction work must be completed per the permit conditions. Used to track construction schedule compliance and trigger final inspection requests.' ;
    rdfs:domain ind:ConstructionPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workStartDate rdf:type rdf:Property ;
    rdfs:label 'Work Start Date' ;
    rdfs:comment 'Earliest date on which permitted construction work may legally commence per the permit conditions. May differ from the issuance date if the authority imposes a delayed start condition.' ;
    rdfs:domain ind:ConstructionPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractingLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Contracting Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to finance.legal_entity. Business justification: Construction contracts are executed by a specific legal entity (the owner/developer SPE). Multi-entity real estate portfolios require entity-level contract tracking for financial reporting, tax liabil' ;
    rdfs:domain ind:ConstructionContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:actualSubstantialCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Substantial Completion Date' ;
    rdfs:comment 'Actual date on which substantial completion was achieved and certified. Compared against the contractual substantial_completion_date to measure schedule variance and assess liquidated damages eligibility.' ;
    rdfs:domain ind:ConstructionContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingCycle rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle' ;
    rdfs:comment 'Frequency at which the contractor submits applications for payment (pay apps) under this contract. Typically monthly for GC agreements. Drives AP invoice scheduling and CAPEX draw management.' ;
    rdfs:domain ind:ConstructionContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondingRequired rdf:type rdf:Property ;
    rdfs:label 'Bonding Required' ;
    rdfs:comment 'Indicates whether the contractor is required to provide a performance bond and/or payment bond under this contract. True if bonding is contractually mandated. Critical for risk management on large CAPEX projects.' ;
    rdfs:domain ind:ConstructionContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeOrderAllowance rdf:type rdf:Property ;
    rdfs:label 'Change Order Allowance' ;
    rdfs:comment 'Contingency amount included in the contract or project budget specifically reserved to cover anticipated change orders. Expressed in contract currency. Helps manage CAPEX (Capital Expenditure) budget risk.' ;
    rdfs:domain ind:ConstructionContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractCategory rdf:type rdf:Property ;
    rdfs:label 'Contract Category' ;
    rdfs:comment 'Categorizes the contract by the role of the contracting party: general contractor (GC) agreement, subcontractor contract, owner-architect agreement, design-build contract, or construction manager at-risk. Used for procurement hierarchy and reporting.' ;
    rdfs:domain ind:ConstructionContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:docusignEnvelopeReference rdf:type rdf:Property ;
    rdfs:label 'Docusign Envelope Reference' ;
    rdfs:comment 'Unique envelope identifier assigned by DocuSign CLM when the contract was routed for electronic signature. Enables direct retrieval of the executed contract document from the CLM system for audit and compliance purposes.' ;
    rdfs:domain ind:ConstructionContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgRequirements rdf:type rdf:Property ;
    rdfs:label 'Esg Requirements' ;
    rdfs:comment 'Specifies any ESG (Environmental, Social, and Governance) or green building certification requirements embedded in the contract, such as LEED or BREEAM compliance obligations for the contractor. Supports sustainability reporting and USGBC compliance.' ;
    rdfs:domain ind:ConstructionContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executedDate rdf:type rdf:Property ;
    rdfs:label 'Executed Date' ;
    rdfs:comment 'Date on which the construction contract was fully executed (signed by all parties) via DocuSign CLM or physical signature. Establishes the binding effective date of the agreement and triggers mobilization timelines.' ;
    rdfs:domain ind:ConstructionContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Final Completion Date' ;
    rdfs:comment 'Target date by which all punch list items must be resolved and the contractor must achieve final completion, enabling release of final retainage and contract closeout.' ;
    rdfs:domain ind:ConstructionContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:generalLiabilityLimit rdf:type rdf:Property ;
    rdfs:label 'General Liability Limit' ;
    rdfs:comment 'Required minimum general liability insurance coverage limit per occurrence as specified in the contract. Ensures the contractor carries adequate coverage to protect the owner from third-party claims.' ;
    rdfs:domain ind:ConstructionContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Number' ;
    rdfs:comment 'Reference number of the ACORD certificate of insurance (COI) provided by the contractor evidencing required coverage (general liability, workers compensation, builders risk). Tracked for compliance and risk management.' ;
    rdfs:domain ind:ConstructionContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Expiry Date' ;
    rdfs:comment 'Expiration date of the contractor\'s insurance certificate. Used to trigger renewal reminders and ensure continuous coverage throughout the construction period. Compliance-critical for risk management.' ;
    rdfs:domain ind:ConstructionContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:liquidatedDamagesPerDay rdf:type rdf:Property ;
    rdfs:label 'Liquidated Damages Per Day' ;
    rdfs:comment 'Pre-agreed daily monetary penalty assessed against the contractor for each calendar day of delay beyond the substantial completion date. Expressed in contract currency. Used for schedule enforcement and delay claim calculations.' ;
    rdfs:domain ind:ConstructionContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minorityBusinessRequired rdf:type rdf:Property ;
    rdfs:label 'Minority Business Required' ;
    rdfs:comment 'Indicates whether the contract includes Minority Business Enterprise (MBE), Women Business Enterprise (WBE), or Disadvantaged Business Enterprise (DBE) participation requirements. True if diversity subcontracting goals are contractually mandated.' ;
    rdfs:domain ind:ConstructionContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noticeToProceedDate rdf:type rdf:Property ;
    rdfs:label 'Notice To Proceed Date' ;
    rdfs:comment 'Date on which the owner issued the Notice to Proceed (NTP) to the contractor, authorizing commencement of construction work. Triggers the contract schedule and liquidated damages clock.' ;
    rdfs:domain ind:ConstructionContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalContractValue rdf:type rdf:Property ;
    rdfs:label 'Original Contract Value' ;
    rdfs:comment 'The original agreed contract sum at execution, expressed in the contract currency. For GMP contracts, this is the guaranteed maximum price. For lump sum, the fixed price. Baseline for CAPEX budget tracking and change order variance analysis.' ;
    rdfs:domain ind:ConstructionContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBondAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Bond Amount' ;
    rdfs:comment 'Dollar value of the payment bond required from the contractor, protecting subcontractors and suppliers from non-payment. Typically equal to 100% of the contract value. Null if bonding_required is False.' ;
    rdfs:domain ind:ConstructionContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceBondAmount rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Amount' ;
    rdfs:comment 'Dollar value of the performance bond required from the contractor, typically equal to 100% of the contract value. Protects the owner against contractor default. Null if bonding_required is False.' ;
    rdfs:domain ind:ConstructionContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prevailingWageRequired rdf:type rdf:Property ;
    rdfs:label 'Prevailing Wage Required' ;
    rdfs:comment 'Indicates whether the contract requires payment of prevailing wages under the Davis-Bacon Act or applicable state prevailing wage laws. Relevant for publicly funded or government-assisted development projects.' ;
    rdfs:domain ind:ConstructionContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:procoreContractReference rdf:type rdf:Property ;
    rdfs:label 'Procore Contract Reference' ;
    rdfs:comment 'Native contract identifier from Procore construction management platform. Used for cross-system reconciliation between the lakehouse silver layer and Procore source system for RFIs, submittals, and change order management.' ;
    rdfs:domain ind:ConstructionContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retainagePercentage rdf:type rdf:Property ;
    rdfs:label 'Retainage Percentage' ;
    rdfs:comment 'Percentage of each progress payment withheld by the owner as retainage (holdback) until substantial or final completion. Typically 5–10%. Governs accounts payable (AP) withholding calculations and contractor cash flow.' ;
    rdfs:domain ind:ConstructionContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retainageReleaseThreshold rdf:type rdf:Property ;
    rdfs:label 'Retainage Release Threshold' ;
    rdfs:comment 'Percentage of contract completion at which retainage may be reduced or released (e.g., 50% completion triggers reduction from 10% to 5%). Contractual milestone that affects CAPEX draw schedules.' ;
    rdfs:domain ind:ConstructionContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisedContractValue rdf:type rdf:Property ;
    rdfs:label 'Revised Contract Value' ;
    rdfs:comment 'Current contract value inclusive of all approved change orders. Reflects the most up-to-date authorized contract sum. Used for CAPEX draw schedule management and budget-to-actual reporting.' ;
    rdfs:domain ind:ConstructionContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scopeOfWork rdf:type rdf:Property ;
    rdfs:label 'Scope Of Work' ;
    rdfs:comment 'Narrative description of the construction work covered by this contract, including trade scope, deliverables, and exclusions. Sourced from Procore contract documents and DocuSign CLM executed exhibits.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substantialCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Substantial Completion Date' ;
    rdfs:comment 'Contractually agreed target date by which the contractor must achieve substantial completion, meaning the work is sufficiently complete for the owner to occupy or use the facility for its intended purpose. Key milestone for Certificate of Occupancy (COO) pursuit.' ;
    rdfs:domain ind:ConstructionContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tradeDivision rdf:type rdf:Property ;
    rdfs:label 'Trade Division' ;
    rdfs:comment 'Construction Specifications Institute (CSI) MasterFormat division code or trade category describing the primary work scope (e.g., Division 03 Concrete, Division 15 Mechanical, Division 16 Electrical). Enables cost segregation and trade-level reporting. [ENUM-REF-CANDIDATE: promote to reference product for full CSI MasterFormat division list]' ;
    rdfs:domain ind:ConstructionContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Warranty Period Months' ;
    rdfs:comment 'Duration in months of the contractor\'s warranty obligation following substantial completion. Typically 12 months for general construction. Drives post-completion defect tracking and O&M (Operations and Maintenance) handover planning.' ;
    rdfs:domain ind:ConstructionContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bimCapable rdf:type rdf:Property ;
    rdfs:label 'Bim Capable' ;
    rdfs:comment 'Indicates whether the contractor has the software, hardware, and trained personnel to participate in BIM-coordinated project delivery. Required for projects mandating BIM model contributions and clash detection workflows.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bondExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Bond Expiration Date' ;
    rdfs:comment 'Expiration date of the contractor\'s surety bond. Contractors must maintain valid bonding throughout the project engagement period. Triggers renewal alerts.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bondingCapacity rdf:type rdf:Property ;
    rdfs:label 'Bonding Capacity' ;
    rdfs:comment 'Maximum aggregate bonding capacity (in USD) the contractor\'s surety has approved. Determines the maximum contract value the contractor can be awarded. Critical for CAPEX project risk management and bid qualification.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:companyName rdf:type rdf:Property ;
    rdfs:label 'Company Name' ;
    rdfs:comment 'Legal registered business name of the contractor, subcontractor, or design professional entity as it appears on licensing and bonding documents.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractorType rdf:type rdf:Property ;
    rdfs:label 'Contractor Type' ;
    rdfs:comment 'Classification of the contractor\'s role in the development project hierarchy. Distinguishes general contractors (GC), specialty subcontractors, licensed design professionals (architects, engineers), and advisory consultants or owner representatives.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dbeCertified rdf:type rdf:Property ;
    rdfs:label 'Dbe Certified' ;
    rdfs:comment 'Indicates whether the contractor holds a valid Disadvantaged Business Enterprise (DBE) certification as defined by the U.S. Department of Transportation. Required for federally funded projects and diversity compliance reporting.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:diversityCertExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Diversity Cert Expiration Date' ;
    rdfs:comment 'Expiration date of the contractor\'s active diversity certification (MBE, WBE, or DBE). Certifications must be renewed periodically; expired certifications cannot be counted toward diversity spend goals.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:federalTaxNumber rdf:type rdf:Property ;
    rdfs:label 'Federal Tax Number' ;
    rdfs:comment 'Employer Identification Number (EIN) or Federal Tax ID assigned by the IRS to the contractor entity. Required for 1099 reporting, contract execution, and AP payment processing in Yardi Voyager and SAP S/4HANA.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Gl Coverage Amount' ;
    rdfs:comment 'Maximum coverage limit of the contractor\'s commercial general liability insurance policy, expressed in USD. Used to verify adequacy against project risk thresholds during prequalification.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceGlExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Gl Expiration Date' ;
    rdfs:comment 'Expiration date of the contractor\'s commercial general liability (GL) insurance policy. Must remain current for the contractor to be active on any project. Triggers compliance alerts 30–60 days prior to expiry.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceProfessionalExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Professional Expiration Date' ;
    rdfs:comment 'Expiration date of the contractor\'s professional liability (errors and omissions) insurance policy. Required for architects, engineers, and design consultants engaged on development projects.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceWcExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Wc Expiration Date' ;
    rdfs:comment 'Expiration date of the contractor\'s workers\' compensation insurance policy. Mandatory for all contractors with employees working on project sites. Verified during prequalification and monitored continuously.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leedCapable rdf:type rdf:Property ;
    rdfs:label 'Leed Capable' ;
    rdfs:comment 'Indicates whether the contractor has demonstrated capability and experience executing LEED-certified construction projects. Used to filter eligible contractors for ESG-aligned development projects.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'License Expiration Date' ;
    rdfs:comment 'Date on which the contractor\'s primary license expires. Triggers compliance alerts for renewal tracking. Contractors with expired licenses must not be issued new contracts.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseState rdf:type rdf:Property ;
    rdfs:label 'License State' ;
    rdfs:comment 'Two-letter US state code of the jurisdiction that issued the contractor\'s primary license. Used to verify geographic eligibility for project work.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mbeCertified rdf:type rdf:Property ;
    rdfs:label 'Mbe Certified' ;
    rdfs:comment 'Indicates whether the contractor holds a valid Minority Business Enterprise (MBE) certification. Supports diversity spend tracking, regulatory reporting, and compliance with HUD and local government diversity requirements.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:officeAddress rdf:type rdf:Property ;
    rdfs:label 'Office Address' ;
    rdfs:comment 'Primary business office street address of the contractor. Used for contract execution, lien notices, certified mail, and vendor master records in SAP S/4HANA and Yardi Voyager.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaRecordableRate rdf:type rdf:Property ;
    rdfs:label 'Osha Recordable Rate' ;
    rdfs:comment 'OSHA Total Recordable Incident Rate (TRIR) for the contractor, calculated per 200,000 work hours. Used to assess site safety performance during prequalification. Lower values indicate better safety records.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceRating rdf:type rdf:Property ;
    rdfs:label 'Performance Rating' ;
    rdfs:comment 'Composite historical performance rating for the contractor on a 0.00–5.00 scale, aggregated from project closeout evaluations across all completed engagements. Inputs include schedule adherence, quality, safety record, and responsiveness. Used for bid shortlisting and prequalification renewal.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredVendor rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor' ;
    rdfs:comment 'Indicates whether the contractor has been designated as a preferred vendor based on demonstrated performance, pricing competitiveness, and strategic relationship. Preferred vendors receive priority bid invitations.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prequalificationExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Prequalification Expiration Date' ;
    rdfs:comment 'Date on which the contractor\'s current prequalification approval expires. Contractors must resubmit prequalification packages before this date to remain eligible for new bid invitations.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prequalificationStatus rdf:type rdf:Property ;
    rdfs:label 'Prequalification Status' ;
    rdfs:comment 'Current prequalification standing of the contractor for engagement on development projects. Approved contractors are eligible for bid invitations; conditional status may require additional documentation; disqualified contractors are barred from new engagements.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyEmodRate rdf:type rdf:Property ;
    rdfs:label 'Safety Emod Rate' ;
    rdfs:comment 'OSHA Experience Modification Rate (EMod or EMR) reflecting the contractor\'s workers\' compensation claims history relative to industry average. A rate above 1.0 indicates above-average claims; many projects require EMod ≤ 1.0 for bid eligibility.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:suretyCompanyName rdf:type rdf:Property ;
    rdfs:label 'Surety Company Name' ;
    rdfs:comment 'Name of the surety company that issued the contractor\'s performance and payment bonds. Used for bond verification and claims processing.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbeCertified rdf:type rdf:Property ;
    rdfs:label 'Wbe Certified' ;
    rdfs:comment 'Indicates whether the contractor holds a valid Women-Owned Business Enterprise (WBE) certification. Supports diversity spend tracking and compliance with project-level diversity inclusion goals.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:yearsInBusiness rdf:type rdf:Property ;
    rdfs:label 'Years In Business' ;
    rdfs:comment 'Number of years the contractor has been in continuous operation. Used as a financial stability and experience indicator during prequalification scoring.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualCostToDate rdf:type rdf:Property ;
    rdfs:label 'Actual Cost To Date' ;
    rdfs:comment 'Total construction costs actually incurred and recorded (invoiced and paid) as of the reporting date. Used for CAPEX draw schedule reconciliation and cost-to-complete analysis. Denominated in currency_code.' ;
    rdfs:domain ind:ConstructionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedChangeOrderAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Change Order Amount' ;
    rdfs:comment 'Cumulative dollar value of all formally approved change orders (COs) that have been incorporated into the current budget. Tracks scope creep and budget evolution. Denominated in currency_code.' ;
    rdfs:domain ind:Development ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetEndDate rdf:type rdf:Property ;
    rdfs:label 'Budget End Date' ;
    rdfs:comment 'The projected or actual date on which the construction budget period ends, typically aligned with the Certificate of Occupancy (COO) issuance or project substantial completion date.' ;
    rdfs:domain ind:ConstructionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetStartDate rdf:type rdf:Property ;
    rdfs:label 'Budget Start Date' ;
    rdfs:comment 'The date on which the construction budget period commences, typically aligned with the project groundbreaking or Notice to Proceed (NTP) date. Used for CAPEX draw schedule management.' ;
    rdfs:domain ind:ConstructionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Status' ;
    rdfs:comment 'Current lifecycle status of the construction budget. Drives workflow approvals, CAPEX draw eligibility, and reporting inclusion. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|on_hold|closed|cancelled — promote to reference product]' ;
    rdfs:domain ind:ConstructionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingencyBudget rdf:type rdf:Property ;
    rdfs:label 'Contingency Budget' ;
    rdfs:comment 'Budget reserve allocated for unforeseen construction costs and risk mitigation. Typically expressed as a percentage of hard costs. Drawdown of contingency requires formal approval. Denominated in currency_code.' ;
    rdfs:domain ind:ConstructionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contingencyRemaining rdf:type rdf:Property ;
    rdfs:label 'Contingency Remaining' ;
    rdfs:comment 'Unused contingency budget remaining after approved contingency draws. Monitors risk buffer availability throughout the construction lifecycle. Denominated in currency_code.' ;
    rdfs:domain ind:ConstructionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Category' ;
    rdfs:comment 'High-level cost category classification for this budget line, aligning with standard real estate development cost reporting categories. Enables roll-up reporting by category across projects.' ;
    rdfs:domain ind:ConstructionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCode rdf:type rdf:Property ;
    rdfs:label 'Cost Code' ;
    rdfs:comment 'The CSI MasterFormat division code or custom Work Breakdown Structure (WBS) element code identifying the specific cost category for line-item budget records (e.g., \'03-0000\' for Concrete, \'05-0000\' for Metals). Null for summary-level records.' ;
    rdfs:domain ind:Development ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCodeDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Code Description' ;
    rdfs:comment 'Human-readable description of the cost code or WBS element (e.g., \'Concrete Work\', \'Structural Steel\', \'Mechanical Systems\'). Used in budget reports and investor packages.' ;
    rdfs:domain ind:ConstructionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCodeLevel rdf:type rdf:Property ;
    rdfs:label 'Cost Code Level' ;
    rdfs:comment 'Indicates whether this budget record represents a summary-level budget (rolled-up by category) or a line-item-level budget (individual CSI division or WBS element). Drives reporting granularity and drill-down capability.' ;
    rdfs:domain ind:ConstructionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Variance Amount' ;
    rdfs:comment 'Difference between the current approved budget and the forecast at completion (current_budget_amount minus forecast_at_completion). Positive value indicates under-budget; negative indicates over-budget. Denominated in currency_code.' ;
    rdfs:domain ind:ConstructionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Current Budget Amount' ;
    rdfs:comment 'The current total budget amount inclusive of all approved change orders (COs). Represents the most up-to-date authorized spend ceiling for the project. Denominated in currency_code.' ;
    rdfs:domain ind:ConstructionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financingCostBudget rdf:type rdf:Property ;
    rdfs:label 'Financing Cost Budget' ;
    rdfs:comment 'Portion of the budget allocated to construction financing costs including loan origination fees, interest carry, and lender-required reserves. Relevant for DSCR and LTV monitoring. Denominated in currency_code.' ;
    rdfs:domain ind:ConstructionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastAtCompletion rdf:type rdf:Property ;
    rdfs:label 'Forecast At Completion' ;
    rdfs:comment 'Projected total cost at project completion based on actual costs to date plus estimated cost to complete. Key metric for investor reporting, lender draw management, and budget variance analysis. Denominated in currency_code.' ;
    rdfs:domain ind:ConstructionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hardCostBudget rdf:type rdf:Property ;
    rdfs:label 'Hard Cost Budget' ;
    rdfs:comment 'Portion of the current budget allocated to hard costs — direct construction costs including site work, structural, MEP, finishes, and contractor fees. Key category for cost control and draw schedule management. Denominated in currency_code.' ;
    rdfs:domain ind:ConstructionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isContingencyDrawn rdf:type rdf:Property ;
    rdfs:label 'Is Contingency Drawn' ;
    rdfs:comment 'Flag indicating whether any contingency budget has been formally drawn down on this project budget. Triggers enhanced monitoring and lender notification requirements when True.' ;
    rdfs:domain ind:ConstructionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:landCostBudget rdf:type rdf:Property ;
    rdfs:label 'Land Cost Budget' ;
    rdfs:comment 'Portion of the total development budget allocated to land acquisition costs, including purchase price, closing costs, and entitlement-related land carrying costs. Denominated in currency_code.' ;
    rdfs:domain ind:ConstructionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineActualCost rdf:type rdf:Property ;
    rdfs:label 'Line Actual Cost' ;
    rdfs:comment 'Actual costs incurred and recorded for this specific cost code line as of the reporting date. Enables granular cost tracking at the CSI division or WBS element level. Denominated in currency_code.' ;
    rdfs:domain ind:ConstructionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineCommittedCost rdf:type rdf:Property ;
    rdfs:label 'Line Committed Cost' ;
    rdfs:comment 'Committed costs for this specific cost code line through executed contracts and purchase orders. Used for line-level cost control and remaining budget calculation. Denominated in currency_code.' ;
    rdfs:domain ind:ConstructionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineOriginalBudget rdf:type rdf:Property ;
    rdfs:label 'Line Original Budget' ;
    rdfs:comment 'Original budget amount for this specific cost code or WBS line item at project inception. Baseline for line-level variance analysis. Applicable only for line-item-level records. Denominated in currency_code.' ;
    rdfs:domain ind:ConstructionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineRemainingBudget rdf:type rdf:Property ;
    rdfs:label 'Line Remaining Budget' ;
    rdfs:comment 'Remaining authorized budget for this cost code line (line_revised_budget minus line_actual_cost). Indicates available spend capacity at the line level for cost control purposes. Denominated in currency_code.' ;
    rdfs:domain ind:ConstructionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineRevisedBudget rdf:type rdf:Property ;
    rdfs:label 'Line Revised Budget' ;
    rdfs:comment 'Revised budget amount for this cost code or WBS line item after approved change orders. Reflects the current authorized spend for this line. Denominated in currency_code.' ;
    rdfs:domain ind:ConstructionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Original Budget Amount' ;
    rdfs:comment 'The initial total CAPEX budget amount as approved at project inception, before any change orders or revisions. Serves as the baseline for variance analysis and investor reporting. Denominated in currency_code.' ;
    rdfs:domain ind:ConstructionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pendingChangeOrderAmount rdf:type rdf:Property ;
    rdfs:label 'Pending Change Order Amount' ;
    rdfs:comment 'Cumulative dollar value of change orders submitted but not yet formally approved. Represents potential budget exposure for risk management and lender notification purposes. Denominated in currency_code.' ;
    rdfs:domain ind:ConstructionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingPeriodDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Date' ;
    rdfs:comment 'The as-of date for which this budget snapshot is valid. Enables point-in-time budget reporting, period-over-period variance analysis, and investor reporting aligned to financial close periods.' ;
    rdfs:domain ind:ConstructionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapWbsElement rdf:type rdf:Property ;
    rdfs:label 'Sap Wbs Element' ;
    rdfs:comment 'SAP S/4HANA Project Systems Work Breakdown Structure element code corresponding to this budget record. Enables financial consolidation, GL posting, and CAPEX capitalization tracking in SAP.' ;
    rdfs:domain ind:ConstructionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:softCostBudget rdf:type rdf:Property ;
    rdfs:label 'Soft Cost Budget' ;
    rdfs:comment 'Portion of the current budget allocated to soft costs — indirect costs including architecture, engineering, legal, permitting, financing fees, and project management. Denominated in currency_code.' ;
    rdfs:domain ind:ConstructionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeOrderId rdf:type rdf:Property ;
    rdfs:label 'Change Order Id' ;
    rdfs:comment 'Unique system-generated identifier for the change order record. Primary key for the development.change_order data product.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:potentialChangeOrderId rdf:type rdf:Property ;
    rdfs:label 'Potential Change Order Id' ;
    rdfs:comment 'Reference to the Potential Change Order (PCO) or Owner Change Order Request (OCOR) in Procore from which this formal change order was generated. Maintains the full change management audit trail from identification through execution.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChangeOrder .

ind:approvingAuthority rdf:type rdf:Property ;
    rdfs:label 'Approving Authority' ;
    rdfs:comment 'Name or role designation of the individual or body that granted final approval for the change order (e.g., Owner Representative, Project Director, Investment Committee). Required for audit trail and delegation-of-authority compliance.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeType rdf:type rdf:Property ;
    rdfs:label 'Change Type' ;
    rdfs:comment 'Classification of the originating cause of the change order. Distinguishes owner-directed changes, contractor-initiated scope modifications, unforeseen site conditions, design revisions, regulatory-driven changes, and value engineering. [ENUM-REF-CANDIDATE: owner_initiated|contractor_initiated|unforeseen_conditions|design_revision|regulatory_requirement|value_engineering — promote to reference product]' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Amount' ;
    rdfs:comment 'Net monetary cost impact of the change order on the contract value, expressed in the contract currency. Positive values indicate additions to contract value; negative values indicate deductions (credits). Core field for CAPEX budget variance analysis.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeCoAmount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Co Amount' ;
    rdfs:comment 'Running total of all approved change order cost impacts against the originating contract as of this change order\'s approval, inclusive of the current change order. Represents the total contract value adjustment from original contract sum. Used for contract value management and budget variance reporting.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeDescription rdf:type rdf:Property ;
    rdfs:label 'Dispute Description' ;
    rdfs:comment 'Narrative description of the nature of the dispute if the change order is contested, including the basis of disagreement on scope, cost, or schedule impact. Populated only when is_disputed is True.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDisputed rdf:type rdf:Property ;
    rdfs:label 'Is Disputed' ;
    rdfs:comment 'Indicates whether the change order is currently subject to a formal dispute between the owner and contractor. Disputed change orders require separate tracking for legal and claims management purposes.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTimeAndMaterial rdf:type rdf:Property ;
    rdfs:label 'Is Time And Material' ;
    rdfs:comment 'Indicates whether the change order is priced on a time-and-material basis rather than a lump sum or unit price. T&M change orders require field verification of labor hours and material quantities before final cost settlement.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:justification rdf:type rdf:Property ;
    rdfs:label 'Justification' ;
    rdfs:comment 'Business or technical justification for the change order, including root cause analysis, reference to RFIs, design bulletins, or site conditions that necessitated the change. Supports dispute resolution and owner approval.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lumpSumAmount rdf:type rdf:Property ;
    rdfs:label 'Lump Sum Amount' ;
    rdfs:comment 'Fixed lump sum price agreed for the change order scope when priced on a lump sum basis. Null when the change order is priced on a time-and-material or unit price basis.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markupPercentage rdf:type rdf:Property ;
    rdfs:label 'Markup Percentage' ;
    rdfs:comment 'Overhead and profit markup percentage applied by the contractor to direct costs on this change order, as negotiated per the contract terms. Expressed as a percentage (e.g., 15.00 for 15%). Used for cost reasonableness review.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:number rdf:type rdf:Property ;
    rdfs:label 'Number' ;
    rdfs:comment 'Externally-known, human-readable identifier for the change order as assigned in Procore or the contract administration system. Used in correspondence, RFIs, and dispute documentation. Format: CO-{ProjectCode}-{Sequence}.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalContractAmount rdf:type rdf:Property ;
    rdfs:label 'Original Contract Amount' ;
    rdfs:comment 'The original executed contract sum prior to any change orders, captured at the time of this change order for reference and variance calculation. Supports contract value management and budget baseline reporting.' ;
    rdfs:domain ind:Development ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primeContractCoNumber rdf:type rdf:Property ;
    rdfs:label 'Prime Contract Co Number' ;
    rdfs:comment 'Change order number as recorded on the prime (owner-contractor) contract, which may differ from the internal Procore sequence number. Used for cross-referencing with owner records and AIA G701 documentation.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procoreCoReference rdf:type rdf:Property ;
    rdfs:label 'Procore Co Reference' ;
    rdfs:comment 'Native change order identifier from the Procore Construction Management system, used for cross-system reconciliation and data lineage tracing between the lakehouse silver layer and the operational source system.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPercentage rdf:type rdf:Property ;
    rdfs:label 'Retention Percentage' ;
    rdfs:comment 'Retainage percentage withheld from progress payments on this change order, as specified in the contract. Expressed as a percentage (e.g., 10.00 for 10%). Governs cash flow and payment application processing.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisedContractAmount rdf:type rdf:Property ;
    rdfs:label 'Revised Contract Amount' ;
    rdfs:comment 'Updated total contract value after incorporating this change order, equal to the original contract amount plus cumulative change order amounts. Represents the current contract sum for payment application and budget tracking purposes.' ;
    rdfs:domain ind:Development ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleImpactDays rdf:type rdf:Property ;
    rdfs:label 'Schedule Impact Days' ;
    rdfs:comment 'Number of calendar days by which the change order extends or compresses the contract completion date. Positive values indicate schedule extensions; negative values indicate accelerations. Critical for milestone tracking and liquidated damages assessment.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Work Completed Date' ;
    rdfs:comment 'Date on which the physical work associated with the change order was substantially completed in the field. Used for payment application timing and project milestone tracking.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:constructionLoanFinancingId rdf:type rdf:Property ;
    rdfs:label 'Construction Loan Financing Id' ;
    rdfs:comment 'Foreign key linking to transaction.financing. Business justification: Construction loan draw process: each draw_request is submitted against a specific construction loan (transaction.financing). Lenders approve draws against the loan commitment. Role-prefixed \'construct' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Financing .

ind:architectCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Architect Certification Date' ;
    rdfs:comment 'Date on which the project architect certified the draw request as accurately representing work completed per AIA G702. Architect certification is a prerequisite for owner approval and lender disbursement.' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:architectCertifiedAmount rdf:type rdf:Property ;
    rdfs:label 'Architect Certified Amount' ;
    rdfs:comment 'Amount certified by the architect for payment, which may differ from the contractor\'s requested amount if the architect adjusts the certified value based on site observation. Corresponds to \'Amount Certified\' on AIA G702.' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balanceToFinish rdf:type rdf:Property ;
    rdfs:label 'Balance To Finish' ;
    rdfs:comment 'Remaining contract value yet to be earned, including retainage (revised_contract_amount minus total_earned_less_retainage). Corresponds to \'Balance to Finish, Including Retainage\' on AIA G702. Key metric for construction loan budget monitoring.' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disbursementDate rdf:type rdf:Property ;
    rdfs:label 'Disbursement Date' ;
    rdfs:comment 'Actual date on which funds were disbursed from the construction loan or owner\'s equity account to the contractor for this draw. Null until disbursement occurs. Critical for CAPEX cash flow management and loan draw tracking.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drawNumber rdf:type rdf:Property ;
    rdfs:label 'Draw Number' ;
    rdfs:comment 'Sequential number identifying this draw request within the construction contract. Corresponds to the Application Number on AIA G702. Used to track draw sequence and ensure no gaps in the payment application series.' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drawPackageDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Draw Package Document Reference' ;
    rdfs:comment 'Document storage reference for the complete draw package submitted to the lender, including the AIA G702/G703 forms, supporting invoices, stored materials documentation, and lien waivers.' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drawStatus rdf:type rdf:Property ;
    rdfs:label 'Draw Status' ;
    rdfs:comment 'Current lifecycle status of the draw request through the approval and disbursement workflow. Tracks progression from contractor submission through lender approval to actual disbursement. [ENUM-REF-CANDIDATE: draft|submitted|under_review|conditionally_approved|approved|rejected|disbursed|voided — promote to reference product]' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorReportReference rdf:type rdf:Property ;
    rdfs:label 'Inspector Report Reference' ;
    rdfs:comment 'Document reference for the third-party construction inspector\'s report commissioned by the lender to verify work-in-place prior to approving this draw. Lender inspections are standard practice in construction loan administration.' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isNotarized rdf:type rdf:Property ;
    rdfs:label 'Is Notarized' ;
    rdfs:comment 'Indicates whether the lien waiver for this draw has been notarized. Some states and lenders require notarized lien waivers as a condition of disbursement.' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lenderApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Lender Approval Date' ;
    rdfs:comment 'Date on which the construction lender formally approved this draw request for disbursement from the construction loan facility.' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lenderApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Lender Approval Status' ;
    rdfs:comment 'Status of the construction lender\'s review and approval of this draw request. Lender approval is required before funds are disbursed from the construction loan facility. Critical for construction loan administration.' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lienWaiverStatus rdf:type rdf:Property ;
    rdfs:label 'Lien Waiver Status' ;
    rdfs:comment 'Aggregate status of lien waiver collection for this draw request across all contractors and subcontractors. Indicates whether all required conditional and/or unconditional lien waivers have been received and validated.' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialsStored rdf:type rdf:Property ;
    rdfs:label 'Materials Stored' ;
    rdfs:comment 'Dollar value of materials and equipment presently stored on-site or in bonded storage but not yet incorporated into the work (Column F on AIA G703). Subject to lender approval and may require stored materials agreement.' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPaymentDue rdf:type rdf:Property ;
    rdfs:label 'Net Payment Due' ;
    rdfs:comment 'Net amount due to the contractor for this draw request (total_earned_less_retainage minus previous_payments). Corresponds to \'Current Payment Due\' on AIA G702. This is the amount requested for disbursement.' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownerApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Owner Approval Date' ;
    rdfs:comment 'Date on which the property owner or owner\'s representative formally approved this draw request for submission to the construction lender.' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownerApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Owner Approval Status' ;
    rdfs:comment 'Status of the owner\'s review and approval of this draw request. Owner approval is required before lender disbursement can be initiated.' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:percentComplete rdf:type rdf:Property ;
    rdfs:label 'Percent Complete' ;
    rdfs:comment 'Overall percentage of the contract work completed to date, calculated as total_earned_to_date divided by revised_contract_amount. Corresponds to Column H on AIA G703. Critical metric for lender draw approval and construction loan monitoring.' ;
    rdfs:domain ind:Development ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousPayments rdf:type rdf:Property ;
    rdfs:label 'Previous Payments' ;
    rdfs:comment 'Total amount of all prior certified payments made to the contractor under this contract. Corresponds to \'Less Previous Certificates for Payment\' on AIA G702. Used to calculate the current net payment due.' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procoreDrawReference rdf:type rdf:Property ;
    rdfs:label 'Procore Draw Reference' ;
    rdfs:comment 'Native identifier for this draw request record within Procore Construction Management system. Used for system-of-record traceability and data lineage from the source operational system.' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retainageRate rdf:type rdf:Property ;
    rdfs:label 'Retainage Rate' ;
    rdfs:comment 'Contractual retainage percentage applied to earned value for this draw (e.g., 0.1000 = 10%). May be reduced at substantial completion milestones per contract terms. Stored as a decimal fraction.' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retainageWithheldCurrent rdf:type rdf:Property ;
    rdfs:label 'Retainage Withheld Current' ;
    rdfs:comment 'Retainage amount withheld from the current period\'s earned value. Corresponds to Column J on AIA G703. Calculated as the applicable retainage percentage applied to current period work completed.' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retainageWithheldPrevious rdf:type rdf:Property ;
    rdfs:label 'Retainage Withheld Previous' ;
    rdfs:comment 'Cumulative retainage withheld from all prior draw requests. Corresponds to Column I on AIA G703. Retainage is a percentage of earned value held back by the owner as security for contract completion.' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledValue rdf:type rdf:Property ;
    rdfs:label 'Scheduled Value' ;
    rdfs:comment 'Total scheduled value of all work items in the Schedule of Values (AIA G703) for this contract as of this draw. Represents the total value of work to be performed under the contract.' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:titleReviewDate rdf:type rdf:Property ;
    rdfs:label 'Title Review Date' ;
    rdfs:comment 'Date on which the title company completed its review and issued clearance (or noted exceptions) for this draw request.' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:titleReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Title Review Status' ;
    rdfs:comment 'Status of the title company\'s review of lien waivers and title endorsement for this draw. Title company clearance confirms no mechanic\'s liens have been filed and is typically required by the lender before disbursement.' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalEarnedLessRetainage rdf:type rdf:Property ;
    rdfs:label 'Total Earned Less Retainage' ;
    rdfs:comment 'Net amount earned to date after deducting total retainage withheld (total_earned_to_date minus total_retainage_withheld). Corresponds to Column L on AIA G703. Represents the contractor\'s net certified entitlement.' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalEarnedToDate rdf:type rdf:Property ;
    rdfs:label 'Total Earned To Date' ;
    rdfs:comment 'Cumulative total amount earned to date including work completed in all prior periods, work completed in the current period, and materials presently stored (work_completed_previous + work_completed_current + materials_stored). Corresponds to Column G on AIA G703.' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRetainageWithheld rdf:type rdf:Property ;
    rdfs:label 'Total Retainage Withheld' ;
    rdfs:comment 'Total cumulative retainage withheld to date across all draw requests including current period (retainage_withheld_previous + retainage_withheld_current). Corresponds to Column K on AIA G703.' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverAmount rdf:type rdf:Property ;
    rdfs:label 'Waiver Amount' ;
    rdfs:comment 'Dollar amount covered by the lien waiver, representing the value of work and materials for which lien rights are being released. Should correspond to the net payment due or disbursed amount.' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Waiver Document Reference' ;
    rdfs:comment 'Document storage reference (URL, document management system path, or DocuSign envelope ID) for the executed lien waiver document associated with this draw. Enables retrieval for lender and title company review.' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Execution Date' ;
    rdfs:comment 'Date on which the lien waiver was signed and executed by the contractor or subcontractor. Required for lien waiver validity and title company review.' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverThroughDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Through Date' ;
    rdfs:comment 'The date through which the lien waiver releases lien rights. Typically corresponds to the billing period end date. Ensures lien rights are waived for all work included in this draw.' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverType rdf:type rdf:Property ;
    rdfs:label 'Waiver Type' ;
    rdfs:comment 'Type of lien waiver associated with this draw request per California Civil Code §8132-8138 or equivalent state standards. Conditional waivers are effective upon receipt of payment; unconditional waivers are effective immediately. Progress waivers cover partial work; final waivers cover all work through contract completion.' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCompletedCurrent rdf:type rdf:Property ;
    rdfs:label 'Work Completed Current' ;
    rdfs:comment 'Dollar value of work completed during the current billing period only (Column E on AIA G703). Represents the incremental progress achieved in this draw cycle.' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workCompletedPrevious rdf:type rdf:Property ;
    rdfs:label 'Work Completed Previous' ;
    rdfs:comment 'Cumulative dollar value of work completed and certified in all prior draw requests (Column D on AIA G703). Used to calculate incremental work completed in the current billing period.' ;
    rdfs:domain ind:DrawRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionEventId rdf:type rdf:Property ;
    rdfs:label 'Inspection Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each construction inspection event record in the development domain.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionEvent .

ind:correctiveWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Corrective Work Order Id' ;
    rdfs:comment 'Foreign key linking to maintenance.work_order. Business justification: Construction inspection deficiencies trigger maintenance work orders for remediation tracking. Real estate operations teams create work orders directly from failed construction inspections to manage p' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:reinspectionEventId rdf:type rdf:Property ;
    rdfs:label 'Reinspection Event Id' ;
    rdfs:comment 'Self-referencing identifier linking this failed or partial-pass inspection to its subsequent re-inspection event record. Enables inspection chain traceability for COO documentation.' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionEvent .

ind:remediationCapexProjectId rdf:type rdf:Property ;
    rdfs:label 'Remediation Capex Project Id' ;
    rdfs:comment 'Foreign key linking to maintenance.capex_project. Business justification: Major construction inspection failures (structural, fire-life-safety) trigger capital remediation projects tracked in the maintenance capex domain. Real estate asset managers link inspection findings ' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapexProject .

ind:areasInspected rdf:type rdf:Property ;
    rdfs:label 'Areas Inspected' ;
    rdfs:comment 'Free-text description of the specific building areas, floors, zones, or grid locations covered during this inspection event (e.g., \'Level 3 east wing structural framing, columns C4 through C8\').' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingLevel rdf:type rdf:Property ;
    rdfs:label 'Building Level' ;
    rdfs:comment 'Specific floor or level of the building structure where the inspection was conducted (e.g., \'B1\', \'L1\', \'Roof\'). Supports spatial tracking of inspection coverage across the development.' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cooRelated rdf:type rdf:Property ;
    rdfs:label 'Coo Related' ;
    rdfs:comment 'Indicates whether this inspection event is on the critical path for Certificate of Occupancy (COO) issuance. True for all mandatory municipal inspections required before occupancy is permitted.' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cooSignOffDate rdf:type rdf:Property ;
    rdfs:label 'Coo Sign Off Date' ;
    rdfs:comment 'Date on which the inspector or authority having jurisdiction (AHJ) provided final sign-off on this inspection, confirming it satisfies COO requirements. Null until formal sign-off is granted.' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Detailed description of the corrective actions required to remediate deficiencies identified during this inspection. Drives contractor work orders and re-inspection scheduling.' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required' ;
    rdfs:comment 'Indicates whether corrective action must be completed before the next inspection or before work may proceed. True when inspection_result is fail or partial_pass.' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deficiencyDescription rdf:type rdf:Property ;
    rdfs:label 'Deficiency Description' ;
    rdfs:comment 'Detailed narrative of all deficiencies, non-conformances, or code violations identified during the inspection. Serves as the official record for corrective action planning and regulatory documentation.' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deficiencySeverity rdf:type rdf:Property ;
    rdfs:label 'Deficiency Severity' ;
    rdfs:comment 'Risk classification of the most severe deficiency identified during this inspection. Critical deficiencies may trigger stop-work orders. Supports prioritization of corrective action and OSHA compliance reporting.' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCategory rdf:type rdf:Property ;
    rdfs:label 'Inspection Category' ;
    rdfs:comment 'Specific trade or discipline category being inspected (e.g., foundation, framing, electrical rough-in, plumbing rough-in, mechanical/HVAC, fire suppression, roofing, concrete, soils, waterproofing, final). [ENUM-REF-CANDIDATE: foundation|framing|electrical|plumbing|mechanical_hvac|fire_suppression|roofing|concrete|soils|waterproofing|insulation|final — promote to reference product]' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionReportNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Report Number' ;
    rdfs:comment 'Official report number assigned to the inspection report document generated from this event. Used for document control and cross-referencing with Procore document management.' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorAffiliation rdf:type rdf:Property ;
    rdfs:label 'Inspector Affiliation' ;
    rdfs:comment 'Name of the organization or agency the inspector represents (e.g., municipal building department, third-party inspection firm, lender, owner). Distinguishes authority of inspection for COO and compliance purposes.' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lenderDrawRelated rdf:type rdf:Property ;
    rdfs:label 'Lender Draw Related' ;
    rdfs:comment 'Indicates whether this inspection event is associated with a Capital Expenditure (CAPEX) draw schedule request. Lender inspections must pass before draw funds are released.' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oshaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Osha Compliance Flag' ;
    rdfs:comment 'Indicates whether this inspection event includes OSHA safety compliance verification. Required for all inspections conducted on active construction sites under OSHA 29 CFR 1926 standards.' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oshaViolationNoted rdf:type rdf:Property ;
    rdfs:label 'Osha Violation Noted' ;
    rdfs:comment 'Indicates whether any OSHA safety violations were identified during this inspection event. True triggers mandatory OSHA compliance reporting and corrective action documentation.' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:photoDocumentationUrl rdf:type rdf:Property ;
    rdfs:label 'Photo Documentation Url' ;
    rdfs:comment 'URL or file path reference to photographic evidence captured during the inspection. Photos document both compliant work and deficiencies for legal and regulatory purposes.' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Report Document Url' ;
    rdfs:comment 'URL or file path reference to the official inspection report document stored in the document management system (Procore or DocuSign CLM). Supports audit trail and regulatory compliance documentation.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weatherConditions rdf:type rdf:Property ;
    rdfs:label 'Weather Conditions' ;
    rdfs:comment 'Prevailing weather conditions at the time of the inspection. Relevant for outdoor inspections where weather may affect work quality assessment or inspector access. [ENUM-REF-CANDIDATE: clear|cloudy|rain|snow|high_wind|extreme_heat|fog — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectScheduleId rdf:type rdf:Property ;
    rdfs:label 'Project Schedule Id' ;
    rdfs:comment 'Unique surrogate identifier for the project schedule record in the development domain. Primary key for the master schedule of a real estate development project.' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselineFinishDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Finish Date' ;
    rdfs:comment 'The originally approved project completion date from the baseline schedule. Serves as the contractual reference for substantial completion and COO issuance milestones.' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselineStartDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Start Date' ;
    rdfs:comment 'The originally approved project start date from the baseline schedule. Used as the reference point for schedule variance analysis and SPI calculation throughout the project lifecycle.' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capexDrawScheduleRef rdf:type rdf:Property ;
    rdfs:label 'Capex Draw Schedule Ref' ;
    rdfs:comment 'Reference identifier linking this project schedule to the associated CAPEX draw schedule in the finance system (Yardi or SAP S/4HANA). Enables alignment of construction milestone completion with capital draw requests to lenders.' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalPathActivityCount rdf:type rdf:Property ;
    rdfs:label 'Critical Path Activity Count' ;
    rdfs:comment 'Number of activities on the critical path (total float = 0 or negative) in the current schedule. Used to assess schedule complexity and focus project management attention on critical activities.' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentFinishDate rdf:type rdf:Property ;
    rdfs:label 'Current Finish Date' ;
    rdfs:comment 'The current forecast or actual project completion date from the latest schedule update. Used for investor milestone reporting and CAPEX draw schedule alignment.' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentStartDate rdf:type rdf:Property ;
    rdfs:label 'Current Start Date' ;
    rdfs:comment 'The current forecast or actual project start date reflecting the latest approved schedule update. May differ from baseline_start_date due to approved schedule changes.' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataDate rdf:type rdf:Property ;
    rdfs:label 'Data Date' ;
    rdfs:comment 'The as-of date through which actual progress has been recorded in this schedule update (also called the status date or time-now date in CPM scheduling). All forecast dates are projected forward from this date.' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalScheduleFileRef rdf:type rdf:Property ;
    rdfs:label 'External Schedule File Ref' ;
    rdfs:comment 'Path or URI to the native scheduling software file (e.g., Primavera P6 .xer or MS Project .mpp) stored in the document management system or cloud storage. Enables drill-back to the source schedule file.' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:farApproved rdf:type rdf:Property ;
    rdfs:label 'Far Approved' ;
    rdfs:comment 'The approved Floor Area Ratio for the development project as granted by the zoning authority. Used to verify that the construction schedule aligns with the approved development envelope and FAR compliance requirements.' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Last Updated Date' ;
    rdfs:comment 'Date on which the schedule was last updated with progress data or revised logic. Indicates the currency of the schedule information for reporting and audit purposes.' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:milestoneActualDate rdf:type rdf:Property ;
    rdfs:label 'Milestone Actual Date' ;
    rdfs:comment 'The date on which the milestone was actually achieved. Null if the milestone has not yet been completed. Populated upon milestone completion and used for as-built schedule records and regulatory filings.' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:milestoneForecastDate rdf:type rdf:Property ;
    rdfs:label 'Milestone Forecast Date' ;
    rdfs:comment 'Current forecast date for milestone achievement based on the latest schedule update. Reflects schedule changes, delays, or acceleration. Used for investor milestone updates and CAPEX draw schedule alignment.' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:milestoneName rdf:type rdf:Property ;
    rdfs:label 'Milestone Name' ;
    rdfs:comment 'Name of the key project milestone tracked in this schedule record (e.g., \'Entitlement Approval\', \'Groundbreaking\', \'Foundation Pour\', \'Topping Out\', \'Substantial Completion\', \'COO Issuance\'). Supports milestone-level reporting to investors and lenders.' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestonePlannedDate rdf:type rdf:Property ;
    rdfs:label 'Milestone Planned Date' ;
    rdfs:comment 'The baseline-approved planned date for this milestone as established in the original project schedule. Used as the reference for milestone variance calculation and investor commitment tracking.' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:milestonePredecessorIds rdf:type rdf:Property ;
    rdfs:label 'Milestone Predecessor Ids' ;
    rdfs:comment 'Comma-separated list of schedule activity or milestone IDs that must be completed before this milestone can begin, representing predecessor relationships in the CPM network. Supports critical path analysis and dependency visualization.' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneResponsibleParty rdf:type rdf:Property ;
    rdfs:label 'Milestone Responsible Party' ;
    rdfs:comment 'Name or role of the party accountable for achieving this milestone (e.g., General Contractor, Owner\'s Representative, Architect, Civil Engineer, Municipality). Used for accountability tracking and escalation management.' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Milestone Status' ;
    rdfs:comment 'Current completion status of the milestone: not_started, in_progress, completed, delayed (past forecast date without completion), or at_risk (forecast date within risk threshold). Drives milestone dashboard RAG status reporting.' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneType rdf:type rdf:Property ;
    rdfs:label 'Milestone Type' ;
    rdfs:comment 'Standardized classification of the milestone per real estate development lifecycle: entitlement_approval, groundbreaking, foundation_pour, topping_out, substantial_completion, or coo_issuance (Certificate of Occupancy). Enables cross-project milestone benchmarking.' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneVarianceDays rdf:type rdf:Property ;
    rdfs:label 'Milestone Variance Days' ;
    rdfs:comment 'Variance in calendar days between the milestone forecast (or actual) date and the milestone planned date. Positive value indicates delay; negative indicates early completion. Reported to investors and lenders as a key development performance indicator.' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduleApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Schedule Approved Date' ;
    rdfs:comment 'Date on which this schedule version was formally approved by the authorized party. Establishes the effective date of the baseline or revised schedule for contractual and reporting purposes.' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleNarrative rdf:type rdf:Property ;
    rdfs:label 'Schedule Narrative' ;
    rdfs:comment 'Free-text narrative accompanying the schedule update, describing key changes, delays, recovery actions, and risk items. Submitted with each schedule update to the owner and lender as part of the monthly construction report.' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleType rdf:type rdf:Property ;
    rdfs:label 'Schedule Type' ;
    rdfs:comment 'Classification of the schedule version: baseline (original approved plan), current (live working schedule), recovery (corrective re-plan), what_if (scenario analysis), or as_built (post-completion record). Drives which schedule is used for SPI and variance reporting.' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleVarianceDays rdf:type rdf:Property ;
    rdfs:label 'Schedule Variance Days' ;
    rdfs:comment 'Difference in calendar days between the current finish date and the baseline finish date (current_finish_date minus baseline_finish_date). Positive value indicates delay; negative indicates ahead of schedule. Key metric for construction oversight reporting.' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduleVersion rdf:type rdf:Property ;
    rdfs:label 'Schedule Version' ;
    rdfs:comment 'Version identifier of the schedule (e.g., \'B0\' for baseline, \'R1\', \'R2\' for revisions). Tracks schedule evolution through the project lifecycle per CPM scheduling best practices.' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schedulingSoftware rdf:type rdf:Property ;
    rdfs:label 'Scheduling Software' ;
    rdfs:comment 'CPM scheduling application used to produce this schedule (e.g., Primavera P6, MS Project). Required for interoperability and file format management when importing schedule data into Procore or the lakehouse.' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spi rdf:type rdf:Property ;
    rdfs:label 'Spi' ;
    rdfs:comment 'Schedule Performance Index from Earned Value Management: ratio of earned value to planned value (EV/PV). SPI < 1.0 indicates the project is behind schedule; SPI > 1.0 indicates ahead of schedule. Key metric for lender and investor reporting.' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalActivityCount rdf:type rdf:Property ;
    rdfs:label 'Total Activity Count' ;
    rdfs:comment 'Total number of schedule activities (tasks) in this schedule version. Used to assess schedule density and compliance with owner-required schedule specifications.' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalFloatDays rdf:type rdf:Property ;
    rdfs:label 'Total Float Days' ;
    rdfs:comment 'Total float (slack) of the project\'s critical path in calendar days as of the data date. Negative total float indicates the project is behind the contractual completion date. Critical for schedule risk assessment.' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:updateFrequency rdf:type rdf:Property ;
    rdfs:label 'Update Frequency' ;
    rdfs:comment 'Contractually required or agreed frequency at which the schedule is updated with progress data: weekly, bi_weekly, monthly, or milestone_driven. Governs the cadence of schedule submissions to the owner and lender.' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableAssetClass rdf:type rdf:Property ;
    rdfs:label 'Applicable Asset Class' ;
    rdfs:comment 'Specific real estate asset class to which this obligation applies (e.g., \'Office\', \'Retail\', \'Multifamily\', \'Industrial\', \'Hotel\', \'Data Center\'). Narrows applicability scope beyond property type. [ENUM-REF-CANDIDATE: office|retail|multifamily|industrial|hotel|data_center|healthcare|self_storage|all — promote to reference product]' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationRequired rdf:type rdf:Property ;
    rdfs:label 'Documentation Required' ;
    rdfs:comment 'Description of the specific documentation, reports, or filings required to demonstrate compliance with this obligation (e.g., \'Phase I ESA Report\', \'Annual 10-K Filing\', \'LEED Scorecard\', \'GDPR Data Processing Agreement\').' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalPortalUrl rdf:type rdf:Property ;
    rdfs:label 'External Portal Url' ;
    rdfs:comment 'URL of the official regulatory body\'s online portal or filing system where compliance submissions for this obligation are made (e.g., EPA\'s CDX portal, SEC EDGAR, HUD IDIS).' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDeadlineDays rdf:type rdf:Property ;
    rdfs:label 'Filing Deadline Days' ;
    rdfs:comment 'Number of calendar days before the renewal date by which the compliance filing or documentation must be submitted to the governing body. Used to calculate advance preparation timelines.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gdprDataCategory rdf:type rdf:Property ;
    rdfs:label 'Gdpr Data Category' ;
    rdfs:comment 'Classification of personal data category under GDPR for privacy-related obligations. \'special_category\' refers to sensitive data per GDPR Article 9 (e.g., health, biometric). \'not_applicable\' for non-GDPR obligations.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingBody rdf:type rdf:Property ;
    rdfs:label 'Governing Body' ;
    rdfs:comment 'Name of the regulatory authority or standards body that issued and enforces this obligation (e.g., \'Environmental Protection Agency (EPA)\', \'Occupational Safety and Health Administration (OSHA)\', \'U.S. Securities and Exchange Commission (SEC)\').' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMandatory rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory' ;
    rdfs:comment 'Indicates whether this obligation is legally mandatory (True) or voluntary/best-practice (False). Mandatory obligations carry legal enforcement risk; voluntary ones (e.g., LEED certification) are pursued for strategic or ESG reasons.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leedBreeamLevel rdf:type rdf:Property ;
    rdfs:label 'Leed Breeam Level' ;
    rdfs:comment 'Target or required certification level for LEED or BREEAM obligations. Applicable only when compliance_framework is \'LEED\' or \'BREEAM\'. \'not_applicable\' for non-certification obligations. [ENUM-REF-CANDIDATE: certified|silver|gold|platinum|pass|good|very_good|excellent|outstanding|not_applicable — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Max Penalty Amount' ;
    rdfs:comment 'Maximum monetary penalty or fine that can be imposed for non-compliance with this obligation, expressed in the obligation currency. Supports risk quantification and materiality assessment.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Next Renewal Date' ;
    rdfs:comment 'Date by which the compliance filing, certification, or permit renewal must be completed for this obligation. Drives compliance calendar and deadline management.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:obligationCategory rdf:type rdf:Property ;
    rdfs:label 'Obligation Category' ;
    rdfs:comment 'Jurisdictional tier of the regulatory obligation, indicating whether it originates from a federal, state, local, or international governing body.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationCode rdf:type rdf:Property ;
    rdfs:label 'Obligation Code' ;
    rdfs:comment 'Externally-known, human-readable unique code assigned to this regulatory obligation (e.g., EPA-PHASE1-001, OSHA-1910-001). Used as the business identifier across systems and filings.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationDescription rdf:type rdf:Property ;
    rdfs:label 'Obligation Description' ;
    rdfs:comment 'Full narrative description of the regulatory obligation, including its purpose, scope, and key compliance requirements as defined by the governing body.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationName rdf:type rdf:Property ;
    rdfs:label 'Obligation Name' ;
    rdfs:comment 'Short, descriptive name of the regulatory obligation (e.g., \'Phase I Environmental Site Assessment\', \'OSHA Hazard Communication Standard\'). Used as the primary identity label in reports and dashboards.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationType rdf:type rdf:Property ;
    rdfs:label 'Obligation Type' ;
    rdfs:comment 'High-level classification of the regulatory obligation by subject matter domain. [ENUM-REF-CANDIDATE: environmental|safety|fair_housing|privacy|financial_reporting|zoning|building_code|esg|certification|other — promote to reference product]' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyDescription rdf:type rdf:Property ;
    rdfs:label 'Penalty Description' ;
    rdfs:comment 'Narrative description of the penalties, fines, or sanctions that may be imposed for non-compliance with this obligation (e.g., \'Civil penalty up to $25,000 per day per violation under 40 CFR Part 312\').' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationReference rdf:type rdf:Property ;
    rdfs:label 'Regulation Reference' ;
    rdfs:comment 'Official citation or reference number for the regulation, statute, or standard (e.g., \'40 CFR Part 312\', \'OSHA 29 CFR 1910.1200\', \'ASC 842\', \'IFRS 16\', \'GDPR Article 5\'). Enables direct traceability to the source regulatory text.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationVersion rdf:type rdf:Property ;
    rdfs:label 'Regulation Version' ;
    rdfs:comment 'Version or amendment number of the regulation or standard to which this obligation corresponds. Tracks regulatory changes over time (e.g., \'2023 Amendment\', \'Rev. 4\', \'LEED v4.1\').' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryObligationStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Obligation Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory obligation in the master registry. \'Active\' means currently enforceable; \'superseded\' means replaced by a newer regulation; \'under_review\' means applicability is being assessed.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalFrequency rdf:type rdf:Property ;
    rdfs:label 'Renewal Frequency' ;
    rdfs:comment 'Cadence at which this regulatory obligation must be renewed, re-filed, or re-certified (e.g., \'annual\' for SEC REIT filings, \'triennial\' for LEED recertification, \'one_time\' for Phase I ESA). [ENUM-REF-CANDIDATE: annual|biennial|triennial|quarterly|monthly|one_time|as_needed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresThirdPartyAudit rdf:type rdf:Property ;
    rdfs:label 'Requires Third Party Audit' ;
    rdfs:comment 'Indicates whether compliance with this obligation must be verified by an independent third-party auditor or certifying body (e.g., LEED certification requires USGBC-approved verifier, Phase I ESA requires licensed environmental professional).' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleDepartment rdf:type rdf:Property ;
    rdfs:label 'Responsible Department' ;
    rdfs:comment 'Internal business department or team accountable for managing and fulfilling this regulatory obligation (e.g., \'Legal & Compliance\', \'Asset Management\', \'Property Management\', \'Finance\', \'ESG & Sustainability\').' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleRole rdf:type rdf:Property ;
    rdfs:label 'Responsible Role' ;
    rdfs:comment 'Job title or role designation of the individual accountable for this obligation (e.g., \'Chief Compliance Officer\', \'Asset Manager (AM)\', \'Property Manager (PM)\', \'Environmental Health & Safety Manager\').' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Assessed risk level of non-compliance with this obligation, reflecting the severity of potential penalties, reputational impact, and likelihood of regulatory scrutiny. Used to prioritize compliance activities.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secFormType rdf:type rdf:Property ;
    rdfs:label 'Sec Form Type' ;
    rdfs:comment 'SEC filing form type associated with this obligation for publicly traded REITs (e.g., \'10-K\', \'10-Q\', \'8-K\', \'S-11\', \'DEF 14A\'). Null for non-SEC obligations.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordRef rdf:type rdf:Property ;
    rdfs:label 'Source Record Ref' ;
    rdfs:comment 'Identifier of the corresponding record in the originating source system (e.g., Yardi Voyager compliance module record ID, SAP compliance item number). Enables traceability back to the system of record.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementId rdf:type rdf:Property ;
    rdfs:label 'Requirement Id' ;
    rdfs:comment 'Primary key for requirement' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Requirement .

ind:appliesToPortfolio rdf:type rdf:Property ;
    rdfs:label 'Applies To Portfolio' ;
    rdfs:comment 'Indicates whether this compliance requirement applies across the entire portfolio rather than to a specific property. True for entity-level requirements such as SEC 10-K REIT disclosures, SOX financial controls, and GDPR privacy program certifications.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approverRole rdf:type rdf:Property ;
    rdfs:label 'Approver Role' ;
    rdfs:comment 'The organizational role required to formally approve or sign off on the completion of this compliance requirement (e.g., VP Compliance, CFO for SEC filings, General Counsel for GDPR certifications). Supports segregation of duties and SOX controls.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceRequired rdf:type rdf:Property ;
    rdfs:label 'Evidence Required' ;
    rdfs:comment 'Indicates whether documentary evidence (inspection reports, certificates, signed forms, audit logs) must be collected and retained to demonstrate fulfillment of this requirement. Drives document management workflows in DocuSign CLM and Building Engines.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evidenceRetentionYears rdf:type rdf:Property ;
    rdfs:label 'Evidence Retention Years' ;
    rdfs:comment 'Number of years that evidence and documentation for this compliance requirement must be retained per regulatory mandate (e.g., OSHA records 5 years, GDPR processing records 3 years, SEC filings 7 years, SOX records 7 years).' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:filingAgency rdf:type rdf:Property ;
    rdfs:label 'Filing Agency' ;
    rdfs:comment 'Name of the regulatory agency or authority to which the formal filing or submission must be made (e.g., \'SEC\', \'HUD\', \'EPA Region 5\', \'OSHA Area Office\', \'State Fire Marshal\'). Null if no external filing is required.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingRequired rdf:type rdf:Property ;
    rdfs:label 'Filing Required' ;
    rdfs:comment 'Indicates whether this requirement involves a formal submission or filing to a regulatory authority (e.g., SEC 10-K, HUD fair housing certification, EPA environmental report, OSHA 300A summary posting). Drives filing calendar management.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:frequencyUnit rdf:type rdf:Property ;
    rdfs:label 'Frequency Unit' ;
    rdfs:comment 'Unit of time for the frequency_interval field (e.g., \'year\' with interval 2 = every 2 years). Together with frequency_interval, enables precise custom recurrence scheduling beyond standard frequency buckets.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'Number of calendar days before the due date that preparation or initiation of this requirement must begin. Used to trigger advance notifications and task assignments to responsible parties (e.g., 30-day lead time for annual fire inspection scheduling).' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leedCreditCategory rdf:type rdf:Property ;
    rdfs:label 'Leed Credit Category' ;
    rdfs:comment 'LEED credit category associated with this requirement when applicable (e.g., \'Energy & Atmosphere\', \'Water Efficiency\', \'Indoor Environmental Quality\', \'Sustainable Sites\'). Null for non-LEED requirements. Supports LEED certification tracking.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Penalty Risk Level' ;
    rdfs:comment 'Assessed risk level of non-compliance with this requirement, reflecting the severity of potential regulatory penalties, fines, or sanctions. Critical = license revocation or criminal liability; High = significant fines (e.g., GDPR up to 4% global revenue); Medium = moderate fines; Low = administrative notices.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationCitation rdf:type rdf:Property ;
    rdfs:label 'Regulation Citation' ;
    rdfs:comment 'Specific regulatory citation, code section, or standard reference that mandates this requirement (e.g., \'OSHA 29 CFR 1910.157\', \'GDPR Article 15\', \'ASC 842-20-50\', \'SEC Rule 10-K Item 2\', \'HUD 24 CFR Part 100\'). Enables precise legal traceability.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDomain rdf:type rdf:Property ;
    rdfs:label 'Regulatory Domain' ;
    rdfs:comment 'The primary regulatory domain governing this requirement. Drives routing to the appropriate compliance team and applicable regulatory body. [ENUM-REF-CANDIDATE: environmental|safety|fair_housing|privacy|financial|esg|building_code|tax|employment|zoning|accessibility — promote to reference product]' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementCode rdf:type rdf:Property ;
    rdfs:label 'Requirement Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this compliance requirement within the compliance management system (e.g., ENV-EPA-001, OSHA-FIRE-Q1, HUD-FH-ANN). Used for cross-system referencing and regulatory filing tracking.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementDescription rdf:type rdf:Property ;
    rdfs:label 'Requirement Description' ;
    rdfs:comment 'Detailed narrative description of the compliance requirement, including the specific action, control, or submission that must be completed, the regulatory basis, and any relevant procedural notes.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementName rdf:type rdf:Property ;
    rdfs:label 'Requirement Name' ;
    rdfs:comment 'Human-readable short name of the compliance requirement (e.g., \'Annual Fire Inspection\', \'Quarterly OSHA Safety Audit\', \'GDPR Data Subject Access Request Process\', \'SEC 10-K REIT Disclosure\'). Used in dashboards, reports, and task assignments.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementStatus rdf:type rdf:Property ;
    rdfs:label 'Requirement Status' ;
    rdfs:comment 'Current lifecycle status of the compliance requirement. \'Active\' means currently enforceable; \'Inactive\' means no longer applicable; \'Pending\' means awaiting activation; \'Waived\' means formally exempted; \'Superseded\' means replaced by a newer requirement.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementType rdf:type rdf:Property ;
    rdfs:label 'Requirement Type' ;
    rdfs:comment 'Categorical classification of the compliance requirement by the nature of the action required. [ENUM-REF-CANDIDATE: inspection|audit|filing|certification|disclosure|training|assessment|remediation|permit|notification|testing|monitoring — promote to reference product]' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyVerification rdf:type rdf:Property ;
    rdfs:label 'Third Party Verification' ;
    rdfs:comment 'Indicates whether this compliance requirement must be verified or certified by an independent third party (e.g., licensed inspector, certified appraiser, external auditor, LEED commissioning agent). Drives vendor engagement and scheduling.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amendedFilingRegulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Amended Filing Regulatory Filing Id' ;
    rdfs:comment 'Reference to the original regulatory_filing_id that this record amends or supersedes. Null if is_amendment is False. Enables amendment chain tracking for audit purposes.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFiling .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'Date on which the governing body formally accepted or acknowledged the filing as complete and compliant. Distinct from filing_date (submission date). Null if not yet accepted.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationLevel rdf:type rdf:Property ;
    rdfs:label 'Certification Level' ;
    rdfs:comment 'Achievement level attained or applied for under the certification program (e.g., LEED Certified/Silver/Gold/Platinum, BREEAM Pass/Good/Very Good/Excellent/Outstanding). Null for non-certification filings. [ENUM-REF-CANDIDATE: certified|silver|gold|platinum|pass|good|very_good|excellent|outstanding — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'For certification-related filings, specifies the certification standard being applied for or renewed (e.g., LEED, BREEAM, ENERGY STAR, ISO 55000, Certificate of Occupancy). Null for non-certification filings.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCategory rdf:type rdf:Property ;
    rdfs:label 'Compliance Category' ;
    rdfs:comment 'High-level compliance domain category for the filing, enabling portfolio-wide compliance reporting by category (e.g., environmental for EPA filings, safety for OSHA, financial for SEC/SOX, fair_housing for HUD, privacy for GDPR, esg for ESG disclosures, certification for LEED/BREEAM). [ENUM-REF-CANDIDATE: environmental|safety|financial|fair_housing|privacy|zoning|esg|certification — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDescription rdf:type rdf:Property ;
    rdfs:label 'Filing Description' ;
    rdfs:comment 'Narrative description of the regulatory filing\'s purpose, scope, and key disclosures. Provides context for compliance officers and auditors reviewing the filing record.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Filing Reference Number' ;
    rdfs:comment 'Externally-known filing number or submission identifier assigned by the business or the regulator at the time of submission (e.g., SEC accession number, HUD case number, EPA facility ID submission reference). Serves as the primary business identifier for tracking the filing across systems.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingTitle rdf:type rdf:Property ;
    rdfs:label 'Filing Title' ;
    rdfs:comment 'Descriptive title or name of the regulatory filing as it appears on the submission document (e.g., \'Annual Report on Form 10-K for Fiscal Year 2024\', \'OSHA 300 Log of Work-Related Injuries and Illnesses\').' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingType rdf:type rdf:Property ;
    rdfs:label 'Filing Type' ;
    rdfs:comment 'Classification of the regulatory filing by form or report type (e.g., 10-K Annual Report, 10-Q Quarterly Report, 8-K Current Report, HUD Fair Housing Report, EPA Environmental Disclosure, OSHA Incident Report, State Permit Application, Municipal Zoning Filing, LEED Certification Submission, ESG Disclosure). [ENUM-REF-CANDIDATE: 10-K|10-Q|8-K|HUD_fair_housing|EPA_environmental|OSHA_incident|state_permit|zoning_filing|LEED_submission|ESG_disclosure|BREEAM_submission|other — promote to reference product]' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAmendment rdf:type rdf:Property ;
    rdfs:label 'Is Amendment' ;
    rdfs:comment 'Indicates whether this filing is an amendment or correction to a previously submitted filing (e.g., SEC 10-K/A, 10-Q/A). True if amendment; False if original submission.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMaterial rdf:type rdf:Property ;
    rdfs:label 'Is Material' ;
    rdfs:comment 'Indicates whether the filing is deemed material under applicable securities or regulatory law (e.g., SEC 8-K material event, material environmental violation). True if material; False otherwise. Drives escalation and investor notification workflows.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyExposureAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Exposure Amount' ;
    rdfs:comment 'Estimated monetary penalty or fine exposure (in base currency) associated with late, rejected, or non-compliant filing. Used for risk quantification and legal reserve provisioning.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatorConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Regulator Confirmation Number' ;
    rdfs:comment 'Unique reference number or accession number assigned by the governing body upon receipt or acceptance of the filing (e.g., SEC EDGAR accession number, EPA confirmation ID, HUD case number). Distinct from the internal filing_reference_number.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Narrative explanation provided by the governing body for rejecting or returning the filing. Populated only when filing_status is \'rejected\'. Used to drive remediation workflows.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionDueDate rdf:type rdf:Property ;
    rdfs:label 'Resubmission Due Date' ;
    rdfs:comment 'Deadline by which a rejected or deficient filing must be corrected and resubmitted to the governing body. Populated when filing_status is \'rejected\' or \'under_review\'.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewedBy rdf:type rdf:Property ;
    rdfs:label 'Reviewed By' ;
    rdfs:comment 'Name or identifier of the compliance officer, legal counsel, or senior executive who reviewed and approved the filing prior to submission. Required for SOX certifications and SEC filings.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'Channel or mechanism used to submit the filing to the governing body (e.g., electronic via SEC EDGAR, online portal, paper mail, courier, in-person delivery). Supports audit trail and submission verification.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentId rdf:type rdf:Property ;
    rdfs:label 'Assessment Id' ;
    rdfs:comment 'Primary key for assessment' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Assessment .

ind:assessmentType rdf:type rdf:Property ;
    rdfs:label 'Assessment Type' ;
    rdfs:comment 'Classification of the assessment or audit engagement. Covers the full range of formal compliance evaluation activities conducted across the portfolio. [ENUM-REF-CANDIDATE: OSHA_safety_inspection|EPA_phase_I_esa|EPA_phase_II_esa|HUD_fair_housing_audit|fire_marshal_inspection|building_code_review|internal_compliance_audit|external_financial_audit|SOX_audit|SEC_regulatory_examination|LEED_certification_review|BREEAM_assessment|ESG_audit|third_party_compliance_audit — promote to reference product]' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorFirmName rdf:type rdf:Property ;
    rdfs:label 'Assessor Firm Name' ;
    rdfs:comment 'Name of the external auditing firm, regulatory agency, or third-party inspection organization conducting the assessment (e.g., Deloitte, EPA Region 5, Bureau Veritas). Null for internal assessments.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorType rdf:type rdf:Property ;
    rdfs:label 'Assessor Type' ;
    rdfs:comment 'Indicates whether the assessment was conducted by an internal compliance team, an external auditing firm, a regulatory body, or an independent third-party inspector.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditOpinion rdf:type rdf:Property ;
    rdfs:label 'Audit Opinion' ;
    rdfs:comment 'Formal audit opinion issued by the external auditor for financial or SOX audits (unqualified/clean, qualified, adverse, or disclaimer of opinion). Null or not_applicable for non-financial inspections.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current overall compliance status of the assessed property or business unit as determined by this assessment. Drives remediation workflows and regulatory reporting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Findings Count' ;
    rdfs:comment 'Number of findings classified as critical severity — those requiring immediate corrective action due to imminent risk to health, safety, legal standing, or financial reporting integrity.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:environmentalConditionIdentified rdf:type rdf:Property ;
    rdfs:label 'Environmental Condition Identified' ;
    rdfs:comment 'Indicates whether a Recognized Environmental Condition (REC) was identified during an EPA Phase I or Phase II Environmental Site Assessment (ESA). A REC triggers further investigation and potential remediation obligations under CERCLA.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:esgScore rdf:type rdf:Property ;
    rdfs:label 'Esg Score' ;
    rdfs:comment 'Composite ESG score assigned to the property or portfolio as an outcome of an ESG assessment or audit. Expressed as a numeric score on the assessor\'s defined scale. Supports ESG reporting and investor disclosure requirements.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fieldworkEndDate rdf:type rdf:Property ;
    rdfs:label 'Fieldwork End Date' ;
    rdfs:comment 'Date on which fieldwork activities were completed. Used to track assessment duration and SLA compliance with regulatory or contractual deadlines.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fieldworkStartDate rdf:type rdf:Property ;
    rdfs:label 'Fieldwork Start Date' ;
    rdfs:comment 'Date on which on-site or remote fieldwork activities commenced (site visits, document reviews, interviews, sampling). Distinct from the assessment period under review.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:findingsSummary rdf:type rdf:Property ;
    rdfs:label 'Findings Summary' ;
    rdfs:comment 'Executive narrative summary of the key findings identified during the assessment, including material deficiencies, violations, observations, and areas of concern. Sourced from the formal assessment report.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Assessment Date' ;
    rdfs:comment 'Scheduled date for the follow-up or re-inspection assessment. Supports compliance calendar management and ensures timely closure of open findings.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpAssessmentRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Assessment Required' ;
    rdfs:comment 'Indicates whether a follow-up or re-inspection assessment is required to verify remediation completion or to conduct Phase II investigation following a Phase I ESA finding.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:highFindingsCount rdf:type rdf:Property ;
    rdfs:label 'High Findings Count' ;
    rdfs:comment 'Number of findings classified as high severity, requiring prompt corrective action within a defined short-term remediation window.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadAssessorCredential rdf:type rdf:Property ;
    rdfs:label 'Lead Assessor Credential' ;
    rdfs:comment 'Professional credential or license held by the lead assessor (e.g., CPA, MAI, PE, CISA, LEED AP, Certified Industrial Hygienist). Validates assessor qualification for the specific assessment type.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadAssessorName rdf:type rdf:Property ;
    rdfs:label 'Lead Assessor Name' ;
    rdfs:comment 'Full name of the lead auditor, inspector, or assessor responsible for conducting and signing off on this assessment. Used for accountability and follow-up communications.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialWeaknessIdentified rdf:type rdf:Property ;
    rdfs:label 'Material Weakness Identified' ;
    rdfs:comment 'Indicates whether a material weakness in internal controls over financial reporting was identified during this assessment. Directly relevant to SOX Section 404 disclosures and SEC filings for publicly traded REITs.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overallRiskRating rdf:type rdf:Property ;
    rdfs:label 'Overall Risk Rating' ;
    rdfs:comment 'Aggregate risk rating assigned to the assessed entity based on the totality of findings. Used to prioritize remediation resources and escalation to senior management.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFilingDeadline rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Deadline' ;
    rdfs:comment 'Mandatory deadline by which the assessment results or remediation response must be filed with the relevant regulatory authority. Critical for avoiding penalties and enforcement actions.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationDueDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Due Date' ;
    rdfs:comment 'Target date by which all required corrective actions must be completed and verified. Set by the assessor, regulator, or internal compliance team based on finding severity.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationRequired rdf:type rdf:Property ;
    rdfs:label 'Remediation Required' ;
    rdfs:comment 'Indicates whether corrective action or remediation is required as a result of this assessment. Triggers the creation of remediation plan records and tracks outstanding compliance obligations.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationStatus rdf:type rdf:Property ;
    rdfs:label 'Remediation Status' ;
    rdfs:comment 'Current status of the remediation or corrective action plan associated with this assessment. Tracks progress from identification of findings through to verified closure.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Report Document Reference' ;
    rdfs:comment 'Document management system reference, DocuSign CLM contract ID, or file path to the formal assessment or audit report. Enables direct retrieval of source documentation for regulatory review or litigation support.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:significantDeficiencyIdentified rdf:type rdf:Property ;
    rdfs:label 'Significant Deficiency Identified' ;
    rdfs:comment 'Indicates whether a significant deficiency in internal controls was identified. Less severe than a material weakness but still requires communication to the audit committee under SOX and PCAOB standards.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subtype rdf:type rdf:Property ;
    rdfs:label 'Subtype' ;
    rdfs:comment 'Further classification within the assessment type (e.g., Phase I vs Phase II for EPA ESA, initial vs surveillance for LEED, interim vs annual for SOX). Provides granularity for reporting and scheduling.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Total Findings Count' ;
    rdfs:comment 'Total number of individual findings, violations, or observations identified during this assessment. Provides a quantitative measure of assessment severity for portfolio-level analytics.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remediationActionId rdf:type rdf:Property ;
    rdfs:label 'Remediation Action Id' ;
    rdfs:comment 'Unique system-generated identifier for each corrective and preventive action (CAPA) record within the compliance remediation tracking system.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RemediationAction .

ind:actionDescription rdf:type rdf:Property ;
    rdfs:label 'Action Description' ;
    rdfs:comment 'Detailed narrative describing the specific corrective or preventive steps required to resolve the compliance finding or regulatory violation. Supports OSHA corrective action plans, EPA remediation programs, and internal audit follow-up workflows.' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionNumber rdf:type rdf:Property ;
    rdfs:label 'Action Number' ;
    rdfs:comment 'Externally-visible, human-readable reference number assigned to the remediation action (e.g., REM-2024-000123). Used in regulatory correspondence, audit trails, and enforcement agency communications.' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionStatus rdf:type rdf:Property ;
    rdfs:label 'Action Status' ;
    rdfs:comment 'Current lifecycle state of the remediation action: open (assigned but not started), in_progress (work underway), completed (work finished, pending verification), verified (independently confirmed complete), or cancelled (action voided with documented justification).' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionTitle rdf:type rdf:Property ;
    rdfs:label 'Action Title' ;
    rdfs:comment 'Short, descriptive title summarizing the corrective or preventive action required (e.g., \'Install secondary containment for HVAC refrigerant storage\'). Used in dashboards and regulatory filings.' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionType rdf:type rdf:Property ;
    rdfs:label 'Action Type' ;
    rdfs:comment 'Classification of the action as corrective (addressing an existing violation), preventive (avoiding future recurrence), interim (temporary measure pending permanent fix), permanent (long-term resolution), or monitoring (ongoing observation). Aligns with CAPA methodology.' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingEnginesWoRef rdf:type rdf:Property ;
    rdfs:label 'Building Engines Wo Ref' ;
    rdfs:comment 'External reference identifier for the corresponding work order in Building Engines (Facility Operations and Work Order Management system) when the remediation action requires physical facility work or preventive maintenance.' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDateExtensionDate rdf:type rdf:Property ;
    rdfs:label 'Due Date Extension Date' ;
    rdfs:comment 'Revised target completion date when a formal extension has been granted by the regulatory authority or approved internally. Tracks deadline modifications for audit trail purposes.' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enforcementActionReference rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Reference' ;
    rdfs:comment 'External reference number assigned by the regulatory authority for the enforcement action, citation, consent decree, or SEC comment letter that mandated this remediation action. Used for regulatory correspondence tracking.' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'The date on which this remediation action was formally escalated to senior management or regulatory authorities due to non-compliance with the target completion date or increased risk.' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicates whether this remediation action has been escalated due to missed deadlines, increased risk severity, or regulatory enforcement pressure. Triggers management notification and priority review workflows.' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:findingCategory rdf:type rdf:Property ;
    rdfs:label 'Finding Category' ;
    rdfs:comment 'High-level category of the compliance finding that triggered this action. Supports cross-domain compliance analytics and regulatory reporting segmentation. [ENUM-REF-CANDIDATE: environmental|safety|fair_housing|data_privacy|financial_reporting|building_code|esg|certification — promote to reference product]' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprDataSubjectImpact rdf:type rdf:Property ;
    rdfs:label 'Gdpr Data Subject Impact' ;
    rdfs:comment 'Indicates whether this remediation action involves tenant personal data and has implications for GDPR data subject rights (e.g., right to erasure, data breach remediation, consent management). Triggers GDPR-specific workflow and DPO notification.' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Risk-based priority level assigned to the remediation action, reflecting the severity of the underlying finding and potential regulatory or safety consequences. Critical items require immediate action; low items are scheduled improvements.' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procoreTaskRef rdf:type rdf:Property ;
    rdfs:label 'Procore Task Ref' ;
    rdfs:comment 'External reference identifier for the corresponding task or punch list item in Procore (Construction and Development Project Management system) when the remediation action involves construction or physical building work.' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Deadline Date' ;
    rdfs:comment 'The externally mandated deadline imposed by the regulatory authority (OSHA, EPA, HUD, SEC) for completion of this remediation action. May differ from the internal target_completion_date if the organization sets an earlier internal deadline.' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'Standardized category of the root cause to enable trend analysis across the portfolio. [ENUM-REF-CANDIDATE: process_failure|equipment_failure|human_error|policy_gap|training_deficiency|third_party|regulatory_change — promote to reference product]' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Ref' ;
    rdfs:comment 'Reference identifier or URL to supporting documentation stored in the document management system (e.g., DocuSign CLM, Procore) including corrective action plans, inspection reports, contractor agreements, and regulatory correspondence.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'The planned or regulatory-mandated date by which the remediation action must be completed. Used for deadline tracking, regulatory filing compliance, and escalation workflows.' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:triggeredBy rdf:type rdf:Property ;
    rdfs:label 'Triggered By' ;
    rdfs:comment 'Identifies the originating event that triggered this remediation action: an internal assessment finding, a formal regulatory violation notice, an enforcement action, an internal audit, a consent decree obligation, or an SEC comment letter response.' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'The method used to independently verify that the remediation action has been completed satisfactorily. Options include physical site inspection, document review, third-party audit, regulatory sign-off, photographic evidence, or laboratory/test results.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifierName rdf:type rdf:Property ;
    rdfs:label 'Verifier Name' ;
    rdfs:comment 'Name of the individual, organization, or regulatory body that performed the verification of the completed remediation action (e.g., OSHA compliance officer, EPA inspector, internal audit manager, third-party assessor).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fairHousingRecordId rdf:type rdf:Property ;
    rdfs:label 'Fair Housing Record Id' ;
    rdfs:comment 'Unique system-generated identifier for each fair housing compliance record. Primary key for this entity.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FairHousingRecord .

ind:adCreativeId rdf:type rdf:Property ;
    rdfs:label 'Ad Creative Id' ;
    rdfs:comment 'Foreign key linking to marketing.ad_creative. Business justification: Fair housing complaints are often triggered by specific ad creatives containing discriminatory imagery or copy. HUD investigations require identifying the exact creative. Compliance teams routinely li' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdCreative .

ind:listingSyndicationId rdf:type rdf:Property ;
    rdfs:label 'Listing Syndication Id' ;
    rdfs:comment 'Foreign key linking to marketing.listing_syndication. Business justification: Fair housing complaints are frequently triggered by specific syndicated listings containing discriminatory language or imagery on platforms like Zillow or Realtor.com. Investigators need to identify t' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ListingSyndication .

ind:accommodationApproved rdf:type rdf:Property ;
    rdfs:label 'Accommodation Approved' ;
    rdfs:comment 'Indicates whether the reasonable accommodation or modification request was approved (True) or denied (False). Null if the request is still pending review.' ;
    rdfs:domain ind:FairHousingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accommodationDenialReason rdf:type rdf:Property ;
    rdfs:label 'Accommodation Denial Reason' ;
    rdfs:comment 'Documented reason for denying a reasonable accommodation or modification request, required for ADA/FHA compliance documentation. Populated only when accommodation_approved is False.' ;
    rdfs:domain ind:FairHousingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accommodationType rdf:type rdf:Property ;
    rdfs:label 'Accommodation Type' ;
    rdfs:comment 'Specifies the type of reasonable accommodation or modification requested under the Americans with Disabilities Act (ADA) or Fair Housing Act (FHA). Applicable when record_type is \'accommodation_request\'. [ENUM-REF-CANDIDATE: physical_modification|policy_exception|service_animal|accessible_unit|parking|communication_aid|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FairHousingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adaApplicable rdf:type rdf:Property ;
    rdfs:label 'Ada Applicable' ;
    rdfs:comment 'Indicates whether the Americans with Disabilities Act (ADA) is the primary governing statute for this fair housing record (True), particularly for accommodation requests and accessibility compliance.' ;
    rdfs:domain ind:FairHousingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assignedInvestigator rdf:type rdf:Property ;
    rdfs:label 'Assigned Investigator' ;
    rdfs:comment 'Name or identifier of the internal compliance officer or external investigator assigned to handle the fair housing complaint or investigation.' ;
    rdfs:domain ind:FairHousingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintType rdf:type rdf:Property ;
    rdfs:label 'Complaint Type' ;
    rdfs:comment 'Classifies the specific nature of a discrimination complaint received. Applicable when record_type is \'complaint\'. [ENUM-REF-CANDIDATE: discrimination|harassment|retaliation|failure_to_accommodate|steering|redlining|other — promote to reference product]' ;
    rdfs:domain ind:FairHousingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecoaApplicable rdf:type rdf:Property ;
    rdfs:label 'Ecoa Applicable' ;
    rdfs:comment 'Indicates whether the Equal Credit Opportunity Act (ECOA) applies to this fair housing record (True), such as cases involving credit decisions in real estate transactions.' ;
    rdfs:domain ind:FairHousingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hudCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Hud Case Number' ;
    rdfs:comment 'Official case reference number assigned by the U.S. Department of Housing and Urban Development (HUD) for a formal complaint, audit, or investigation. Used to cross-reference HUD records and track regulatory correspondence.' ;
    rdfs:domain ind:FairHousingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hudFilingDate rdf:type rdf:Property ;
    rdfs:label 'Hud Filing Date' ;
    rdfs:comment 'Date on which the complaint or response was formally filed with HUD. Used to track regulatory submission deadlines and audit timelines.' ;
    rdfs:domain ind:FairHousingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hudResponseDueDate rdf:type rdf:Property ;
    rdfs:label 'Hud Response Due Date' ;
    rdfs:comment 'Deadline by which the organization must submit a formal response to HUD in connection with an audit, complaint, or investigation. Supports regulatory deadline tracking.' ;
    rdfs:domain ind:FairHousingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hudResponseSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Hud Response Submitted Date' ;
    rdfs:comment 'Actual date on which the organization submitted its formal response to HUD. Used to verify timely compliance with regulatory deadlines.' ;
    rdfs:domain ind:FairHousingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incidentDate rdf:type rdf:Property ;
    rdfs:label 'Incident Date' ;
    rdfs:comment 'Date on which the alleged fair housing violation, accommodation request, or compliance event occurred. Represents the real-world event date, distinct from the record filing date.' ;
    rdfs:domain ind:FairHousingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:internalCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Case Number' ;
    rdfs:comment 'Organization\'s internal reference number assigned to this fair housing compliance matter, used for internal tracking, audit trails, and cross-referencing with legal and compliance management systems.' ;
    rdfs:domain ind:FairHousingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationStartDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Start Date' ;
    rdfs:comment 'Date on which the internal or external investigation into the fair housing matter was formally initiated.' ;
    rdfs:domain ind:FairHousingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalCounselAssigned rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Assigned' ;
    rdfs:comment 'Indicates whether legal counsel has been engaged to represent the organization in connection with this fair housing matter (True) or not (False).' ;
    rdfs:domain ind:FairHousingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:protectedClassCategories rdf:type rdf:Property ;
    rdfs:label 'Protected Class Categories' ;
    rdfs:comment 'Comma-separated list of protected class categories involved in this fair housing record (e.g., race, color, national_origin, religion, sex, familial_status, disability, source_of_income). Captures all applicable protected classes per the Fair Housing Act and applicable state/local laws.' ;
    rdfs:domain ind:FairHousingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordType rdf:type rdf:Property ;
    rdfs:label 'Record Type' ;
    rdfs:comment 'Categorizes the nature of this fair housing compliance record. Values include: complaint (discrimination allegation received), accommodation_request (ADA/FHA reasonable accommodation), training_completion (staff fair housing training), hud_audit_response (response to HUD audit), investigation (internal or external investigation), self_audit (proactive internal compliance review).' ;
    rdfs:domain ind:FairHousingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionOutcome rdf:type rdf:Property ;
    rdfs:label 'Resolution Outcome' ;
    rdfs:comment 'Final determination or outcome of the fair housing investigation or complaint. Captures the substantive result upon closure. [ENUM-REF-CANDIDATE: no_cause_found|cause_found|conciliation_agreement|settlement|administrative_closure|referred_to_doj|other — promote to reference product]' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Current lifecycle status of the fair housing record. Tracks the workflow state from initial receipt through final disposition. [ENUM-REF-CANDIDATE: open|under_investigation|resolved|dismissed|settled|withdrawn|referred_to_hud — promote to reference product]' ;
    rdfs:domain ind:FairHousingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Amount' ;
    rdfs:comment 'Monetary value of any financial settlement reached in connection with a fair housing complaint or investigation. Expressed in USD. Classified as confidential business-sensitive data.' ;
    rdfs:domain ind:FairHousingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementCurrency rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the settlement amount (e.g., USD, CAD, EUR). Supports multi-jurisdictional portfolio operations.' ;
    rdfs:domain ind:FairHousingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementTerms rdf:type rdf:Property ;
    rdfs:label 'Settlement Terms' ;
    rdfs:comment 'Narrative description of the terms agreed upon in a conciliation agreement or settlement, including any non-monetary remedies, policy changes, or training requirements imposed. Classified as confidential.' ;
    rdfs:domain ind:FairHousingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgMetricId rdf:type rdf:Property ;
    rdfs:label 'Esg Metric Id' ;
    rdfs:comment 'Unique surrogate identifier for each ESG metric record in the lakehouse silver layer.' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fundPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Fund Performance Id' ;
    rdfs:comment 'Foreign key linking to investment.fund_performance. Business justification: ESG metrics feed into fund performance reporting (GRESB scores, ESG-adjusted returns, sustainability KPIs). Linking ESG metrics to fund performance periods supports integrated ESG and financial report' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundPerformance .

ind:affordableHousingUnits rdf:type rdf:Property ;
    rdfs:label 'Affordable Housing Units' ;
    rdfs:comment 'Number of residential units designated as affordable housing within the property or portfolio for the reporting period. Applicable for Social pillar metrics; null for non-residential or non-applicable metrics. Supports HUD fair housing compliance reporting.' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:antiCorruptionTrainingPct rdf:type rdf:Property ;
    rdfs:label 'Anti Corruption Training Pct' ;
    rdfs:comment 'Percentage of employees who completed mandatory anti-corruption and ethics training during the reporting period. Applicable for Governance pillar anti-corruption metrics; null otherwise.' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineValue rdf:type rdf:Property ;
    rdfs:label 'Baseline Value' ;
    rdfs:comment 'Reference baseline value against which performance targets and progress are measured (e.g., 2019 energy consumption baseline for net-zero pathway). Null when no formal baseline has been established.' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineYear rdf:type rdf:Property ;
    rdfs:label 'Baseline Year' ;
    rdfs:comment 'Calendar year of the baseline measurement used for target-setting and progress tracking (e.g., 2019). Null when no formal baseline year has been established.' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:boardDiversityPct rdf:type rdf:Property ;
    rdfs:label 'Board Diversity Pct' ;
    rdfs:comment 'Percentage of board members from underrepresented groups (gender, ethnicity, or combined diversity metric as defined by the organization\'s governance policy) for the reporting period. Applicable for Governance pillar board diversity metrics; null otherwise.' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:communityInvestmentUsd rdf:type rdf:Property ;
    rdfs:label 'Community Investment Usd' ;
    rdfs:comment 'Total monetary value of community investment, charitable contributions, and social programs funded by the organization for the reporting period. Applicable for Social pillar community investment metrics; null otherwise.' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coveragePct rdf:type rdf:Property ;
    rdfs:label 'Coverage Pct' ;
    rdfs:comment 'Percentage of the total portfolio floor area or units for which actual measured data (as opposed to estimates) is available for this metric in the reporting period. A coverage of 100% indicates fully metered data; lower values indicate partial coverage with estimation applied to gaps.' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'Operational system or external source from which the metric data was obtained (e.g., \'Yardi Voyager Utility Tracking\', \'Building Engines Work Order System\', \'Utility Provider Invoice\', \'ENERGY STAR Portfolio Manager\', \'Manual Survey\'). Supports data lineage and audit trail requirements.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgPillar rdf:type rdf:Property ;
    rdfs:label 'Esg Pillar' ;
    rdfs:comment 'High-level ESG pillar classification: Environmental, Social, or Governance. Drives framework mapping and investor disclosure categorization.' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimationMethod rdf:type rdf:Property ;
    rdfs:label 'Estimation Method' ;
    rdfs:comment 'Method used to fill data gaps where actual measured data is unavailable: Actual (fully metered), Extrapolation, Interpolation, Engineering Estimate, or Proxy. Supports GRESB data quality scoring and third-party assurance.' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethicsViolationsCount rdf:type rdf:Property ;
    rdfs:label 'Ethics Violations Count' ;
    rdfs:comment 'Number of confirmed ethics policy violations or code-of-conduct breaches recorded during the reporting period. Applicable for Governance pillar ethics metrics. Classified confidential due to sensitive governance nature.' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frameworkIndicatorCode rdf:type rdf:Property ;
    rdfs:label 'Framework Indicator Code' ;
    rdfs:comment 'Specific indicator or disclosure code within the reporting framework (e.g., \'GRI 302-1\', \'SASB IF-RE-130a.1\', \'GRESB EC1\', \'TCFD Metrics and Targets\'). Enables precise framework alignment mapping for regulatory and investor filings.' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghgScope rdf:type rdf:Property ;
    rdfs:label 'Ghg Scope' ;
    rdfs:comment 'GHG Protocol emission scope classification applicable when the metric category is GHG Emissions: Scope 1 (direct emissions), Scope 2 (purchased energy indirect), Scope 3 (value chain indirect). Set to N/A for non-emissions metrics.' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intensityDenominator rdf:type rdf:Property ;
    rdfs:label 'Intensity Denominator' ;
    rdfs:comment 'The normalization basis used to compute the intensity value: SQM (square meters), SQF (square feet), GLA (Gross Leasable Area), NLA (Net Leasable Area), or revenue_usd. Null or N/A when intensity is not reported.' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intensityValue rdf:type rdf:Property ;
    rdfs:label 'Intensity Value' ;
    rdfs:comment 'Normalized intensity metric expressing the ESG value per unit of floor area or revenue (e.g., kWh per SQM, CO2e per SQF, m3 per SQM). Enables like-for-like benchmarking across properties of different sizes. Null when intensity normalization is not applicable.' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isLandlordControlled rdf:type rdf:Property ;
    rdfs:label 'Is Landlord Controlled' ;
    rdfs:comment 'Indicates whether the energy, water, or utility consumption represented by this metric is under landlord operational control (True) or tenant-controlled (False). Critical for determining boundary of operational control under GHG Protocol and GRESB data collection scope.' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLikeForLike rdf:type rdf:Property ;
    rdfs:label 'Is Like For Like' ;
    rdfs:comment 'Indicates whether this metric record qualifies for like-for-like (LfL) comparison with the prior period — i.e., the property was owned and operational for the full duration of both the current and prior reporting periods with no significant structural changes. Required for GRESB like-for-like performance scoring.' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:metricCategory rdf:type rdf:Property ;
    rdfs:label 'Metric Category' ;
    rdfs:comment 'Sub-category within the ESG pillar (e.g., Energy, Water, GHG Emissions, Waste, Biodiversity, Affordable Housing, Community Investment, Tenant Satisfaction, Board Diversity, Ethics, Anti-Corruption). [ENUM-REF-CANDIDATE: Energy|Water|GHG Emissions|Waste|Biodiversity|Affordable Housing|Community Investment|Tenant Satisfaction|Board Diversity|Ethics|Anti-Corruption|Renewable Energy|Indoor Air Quality — promote to reference product]' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricCode rdf:type rdf:Property ;
    rdfs:label 'Metric Code' ;
    rdfs:comment 'Standardized alphanumeric code uniquely identifying the ESG metric type within the enterprise taxonomy (e.g., ENV-ENERGY-KWH, SOC-AFFORD-UNITS, GOV-BOARD-DIV). Aligns with GRESB indicator codes and internal ESG data dictionary.' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricName rdf:type rdf:Property ;
    rdfs:label 'Metric Name' ;
    rdfs:comment 'Human-readable name of the ESG metric (e.g., \'Total Energy Consumption\', \'GHG Emissions Scope 1\', \'Affordable Housing Units\', \'Board Gender Diversity Ratio\'). Used in investor reports and regulatory filings.' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricStatus rdf:type rdf:Property ;
    rdfs:label 'Metric Status' ;
    rdfs:comment 'Lifecycle status of this ESG metric record: Draft (data entry in progress), Submitted (submitted for review), Under Review (being reviewed by ESG team or auditor), Approved (finalized and approved for disclosure), Restated (previously published value corrected), Withdrawn (removed from disclosure).' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricValue rdf:type rdf:Property ;
    rdfs:label 'Metric Value' ;
    rdfs:comment 'Quantitative measured or reported value for the ESG metric for the specified reporting period (e.g., 1,250,000 kWh of energy consumed, 45.2 tonnes CO2e of GHG emissions, 120 affordable housing units). Precision supports both large energy figures and small fractional rates.' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorPeriodValue rdf:type rdf:Property ;
    rdfs:label 'Prior Period Value' ;
    rdfs:comment 'Metric value for the immediately preceding comparable reporting period. Stored to support year-over-year variance analysis and trend reporting in investor ESG disclosures without requiring a self-join.' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewableEnergyPct rdf:type rdf:Property ;
    rdfs:label 'Renewable Energy Pct' ;
    rdfs:comment 'Percentage of total energy consumption sourced from renewable energy (solar, wind, geothermal, etc.) for the reporting period. Applicable when metric_category is Energy or Renewable Energy; null otherwise. Expressed as a percentage (0–100).' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingFramework rdf:type rdf:Property ;
    rdfs:label 'Reporting Framework' ;
    rdfs:comment 'Primary ESG reporting framework under which this metric is disclosed: GRI (Global Reporting Initiative), SASB (Sustainability Accounting Standards Board), TCFD (Task Force on Climate-related Financial Disclosures), GRESB (Global Real Estate Sustainability Benchmark), CDP, UNPRI, SFDR, Multiple, or Other. [ENUM-REF-CANDIDATE: GRI|SASB|TCFD|GRESB|CDP|UNPRI|SFDR|Multiple|Other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'Approved internal or externally committed target value for this metric for the reporting period (e.g., a 10% reduction in energy consumption vs. baseline). Supports performance-against-target reporting for ESG scorecards.' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Current verification or assurance status of the ESG metric data: Unverified (raw), Internal Review (reviewed by internal ESG team), Third-Party Assured (externally assured), Limited Assurance, or Reasonable Assurance. Drives investor confidence and regulatory disclosure quality.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteDiversionRate rdf:type rdf:Property ;
    rdfs:label 'Waste Diversion Rate' ;
    rdfs:comment 'Percentage of total waste diverted from landfill through recycling, composting, or reuse for the reporting period. Applicable when metric_category is Waste; null otherwise. Expressed as a percentage (0–100).' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:greenCertificationId rdf:type rdf:Property ;
    rdfs:label 'Green Certification Id' ;
    rdfs:comment 'Primary key for green_certification' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GreenCertification .

ind:previousCertificationGreenCertificationId rdf:type rdf:Property ;
    rdfs:label 'Previous Certification Green Certification Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the prior certification record for the same property and certification type, enabling certification history chain tracking and renewal lineage. Null for the initial certification.' ;
    rdfs:domain ind:GreenCertification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GreenCertification .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'The date on which the formal on-site or documentary assessment was conducted by the certifying body or licensed assessor. Distinct from the application date and the certification award date.' ;
    rdfs:domain ind:GreenCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessorAccreditation rdf:type rdf:Property ;
    rdfs:label 'Assessor Accreditation' ;
    rdfs:comment 'The professional accreditation or credential held by the assessor (e.g., LEED AP BD+C, LEED AP O+M, BREEAM Assessor, WELL AP). Validates the assessor\'s authority to conduct the certification assessment.' ;
    rdfs:domain ind:GreenCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorName rdf:type rdf:Property ;
    rdfs:label 'Assessor Name' ;
    rdfs:comment 'The name of the licensed or accredited assessor, consultant, or LEED Accredited Professional (LEED AP) who conducted the certification assessment or managed the certification submission on behalf of the property.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailRequired rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Required' ;
    rdfs:comment 'Indicates whether this certification record requires a formal audit trail of supporting documentation for regulatory or certifying body verification purposes. True for certifications subject to third-party verification audits (e.g., ENERGY STAR verification, LEED documentation review).' ;
    rdfs:domain ind:GreenCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breeamCategoryBreakdown rdf:type rdf:Property ;
    rdfs:label 'Breeam Category Breakdown' ;
    rdfs:comment 'Structured summary of scores across BREEAM assessment categories (e.g., Energy, Water, Materials, Waste, Land Use & Ecology, Pollution, Transport, Health & Wellbeing, Management). Stored as a delimited string for BREEAM-type certifications; null for non-BREEAM certifications.' ;
    rdfs:domain ind:GreenCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Date' ;
    rdfs:comment 'The date on which the certifying body officially awarded the certification to the property. Represents the commencement of the certified period. Used for ESG reporting timelines and green lease compliance.' ;
    rdfs:domain ind:GreenCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'Externally-issued unique identifier assigned by the certifying body (e.g., USGBC LEED project ID, ENERGY STAR certification number, BRE BREEAM certificate reference). Used for cross-referencing with the certifying body\'s registry.' ;
    rdfs:domain ind:GreenCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Current lifecycle state of the certification record. \'Pursuing\' indicates the property is in the application or assessment process; \'Certified\' indicates active certification; \'Expired\' indicates the certification period has lapsed; \'Withdrawn\' indicates the application was voluntarily withdrawn; \'Suspended\' indicates certification has been placed on hold by the certifying body.' ;
    rdfs:domain ind:GreenCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationVersion rdf:type rdf:Property ;
    rdfs:label 'Certification Version' ;
    rdfs:comment 'The specific version or edition of the certification standard under which the property was assessed (e.g., LEED v4.1, LEED v4, LEED 2009, BREEAM 2018, BREEAM In-Use v6). Critical for interpreting scoring criteria and prerequisites.' ;
    rdfs:domain ind:GreenCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedAreaSqft rdf:type rdf:Property ;
    rdfs:label 'Certified Area Sqft' ;
    rdfs:comment 'The gross floor area (GFA) in square feet (SQF) covered by this certification. Used for ESG intensity metrics (e.g., energy use per SQF), green lease obligations, and portfolio-level certified area reporting.' ;
    rdfs:domain ind:GreenCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certifyingBody rdf:type rdf:Property ;
    rdfs:label 'Certifying Body' ;
    rdfs:comment 'The organization responsible for issuing and administering the certification (e.g., USGBC for LEED, BRE for BREEAM, EPA for ENERGY STAR, IWBI for WELL Building Standard, Fitwel for Fitwel). Used for ESG reporting and audit trail purposes.' ;
    rdfs:domain ind:GreenCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingBodyProjectRef rdf:type rdf:Property ;
    rdfs:label 'Certifying Body Project Ref' ;
    rdfs:comment 'The project registration or tracking identifier assigned by the certifying body\'s online platform (e.g., USGBC LEED Online project ID, BREEAM Projects portal reference). Used for direct cross-referencing with the certifying body\'s registry and audit purposes.' ;
    rdfs:domain ind:GreenCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:greenLeaseLinked rdf:type rdf:Property ;
    rdfs:label 'Green Lease Linked' ;
    rdfs:comment 'Indicates whether this certification is referenced in or required by one or more green lease agreements for the property. True if the certification underpins green lease obligations (e.g., tenant energy reporting, sustainability covenants); False otherwise.' ;
    rdfs:domain ind:GreenCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gresbSubmissionYear rdf:type rdf:Property ;
    rdfs:label 'Gresb Submission Year' ;
    rdfs:comment 'The calendar year in which this certification data was included in the organization\'s GRESB (Global Real Estate Sustainability Benchmark) submission. Used to track ESG reporting cycles and benchmark performance year-over-year.' ;
    rdfs:domain ind:GreenCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incentiveDescription rdf:type rdf:Property ;
    rdfs:label 'Incentive Description' ;
    rdfs:comment 'Narrative description of the specific financial incentives, tax credits, or grants for which the property is eligible as a result of this certification (e.g., IRS Section 179D deduction, state property tax abatement, utility rebate program). Populated when incentive_eligible is True.' ;
    rdfs:domain ind:GreenCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveEligible rdf:type rdf:Property ;
    rdfs:label 'Incentive Eligible' ;
    rdfs:comment 'Indicates whether the property qualifies for financial incentives (tax credits, grants, reduced permit fees, expedited permitting) as a result of achieving this green certification. Supports CAPEX planning and investment advisory analysis.' ;
    rdfs:domain ind:GreenCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leedCategoryBreakdown rdf:type rdf:Property ;
    rdfs:label 'Leed Category Breakdown' ;
    rdfs:comment 'Structured summary of points earned across LEED credit categories (e.g., Sustainable Sites, Water Efficiency, Energy & Atmosphere, Materials & Resources, Indoor Environmental Quality, Innovation). Stored as a delimited string for LEED-type certifications; null for non-LEED certifications.' ;
    rdfs:domain ind:GreenCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsAvailable rdf:type rdf:Property ;
    rdfs:label 'Points Available' ;
    rdfs:comment 'The maximum number of credits or points available under the applicable certification version and building type. Used to calculate the percentage score and determine the achievable certification level.' ;
    rdfs:domain ind:GreenCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsScored rdf:type rdf:Property ;
    rdfs:label 'Points Scored' ;
    rdfs:comment 'The total number of credits or points awarded to the property under the certification framework\'s scoring system (e.g., LEED points out of 110, BREEAM percentage score). Represents the principal quantitative outcome of the certification assessment.' ;
    rdfs:domain ind:GreenCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prerequisitesMet rdf:type rdf:Property ;
    rdfs:label 'Prerequisites Met' ;
    rdfs:comment 'Indicates whether all mandatory prerequisites required by the certification framework have been satisfied. A value of True confirms all prerequisites are fulfilled; False indicates outstanding prerequisites that must be resolved before certification can be awarded.' ;
    rdfs:domain ind:GreenCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Due Date' ;
    rdfs:comment 'The deadline by which the renewal application must be submitted to the certifying body to avoid lapse of certification. May differ from expiry_date if the certifying body requires advance submission. Supports compliance calendar and deadline management.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalInProgress rdf:type rdf:Property ;
    rdfs:label 'Renewal In Progress' ;
    rdfs:comment 'Indicates whether a renewal application for this certification is currently in progress with the certifying body. True if the renewal process has been initiated but not yet completed; False otherwise. Supports compliance monitoring and workflow management.' ;
    rdfs:domain ind:GreenCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scorePercentage rdf:type rdf:Property ;
    rdfs:label 'Score Percentage' ;
    rdfs:comment 'The certification score expressed as a percentage of total available points (points_scored / points_available × 100). Used for cross-framework ESG benchmarking and portfolio-level green performance reporting.' ;
    rdfs:domain ind:GreenCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permitId rdf:type rdf:Property ;
    rdfs:label 'Permit Id' ;
    rdfs:comment 'Primary key for permit' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:conditions rdf:type rdf:Property ;
    rdfs:label 'Conditions' ;
    rdfs:comment 'Free-text description of any special conditions, restrictions, or obligations attached to the permit by the issuing authority (e.g., noise restrictions, construction hours, environmental mitigation requirements). Sourced from DocuSign CLM or Procore document records.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgRelevant rdf:type rdf:Property ;
    rdfs:label 'Esg Relevant' ;
    rdfs:comment 'Indicates whether this permit is relevant to ESG reporting obligations (e.g., environmental permits, LEED/BREEAM certifications, energy efficiency permits). Drives ESG data aggregation for SEC and investor reporting.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Fee Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the permit fee amount (e.g., \'USD\', \'GBP\', \'EUR\'). Supports multi-currency portfolio accounting.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorAreaSqft rdf:type rdf:Property ;
    rdfs:label 'Floor Area Sqft' ;
    rdfs:comment 'The gross floor area in square feet (SQF) covered by the scope of this permit. Relevant for building permits, COO, and zoning variance permits. Supports FAR (Floor Area Ratio) compliance calculations.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'The date of the most recent inspection conducted in connection with this permit. Used to assess inspection currency and schedule next required inspection.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastInspectionResult rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Result' ;
    rdfs:comment 'Outcome of the most recent inspection associated with this permit. \'conditional_pass\' indicates approval subject to remediation of minor deficiencies within a specified timeframe.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitName rdf:type rdf:Property ;
    rdfs:label 'Permit Name' ;
    rdfs:comment 'Descriptive name or title of the permit as assigned by the issuing authority or internally for operational reference (e.g., \'Annual Elevator Operating Permit — Tower A\', \'LEED Construction Waste Management Permit\').' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Frequency Months' ;
    rdfs:comment 'The number of months between required permit renewals. Null if renewal_required is False. Used to auto-calculate future renewal_due_date values and schedule compliance calendar events.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalRequired rdf:type rdf:Property ;
    rdfs:label 'Renewal Required' ;
    rdfs:comment 'Indicates whether this permit requires periodic renewal. True for time-limited permits (e.g., annual elevator permits, fire safety certificates); False for one-time permits (e.g., demolition permits).' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revocationDate rdf:type rdf:Property ;
    rdfs:label 'Revocation Date' ;
    rdfs:comment 'The date on which the permit was revoked by the issuing authority, if applicable. Null for permits that have not been revoked. Critical for disposition compliance and regulatory audit trails.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemPermitRef rdf:type rdf:Property ;
    rdfs:label 'Source System Permit Ref' ;
    rdfs:comment 'The native permit record identifier from the originating operational system (e.g., Procore permit ID, Yardi Voyager compliance record ID). Enables traceability and reconciliation between the lakehouse Silver Layer and source systems.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationAmount rdf:type rdf:Property ;
    rdfs:label 'Valuation Amount' ;
    rdfs:comment 'The declared construction or project valuation amount submitted with the permit application, as required by many jurisdictions to calculate permit fees and assess project scale. Expressed in the local currency.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:abatementCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Abatement Completed Date' ;
    rdfs:comment 'Actual date on which the corrective action or abatement of the cited condition was completed and verified. Used to calculate abatement lead time and confirm regulatory closure.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:abatementDueDate rdf:type rdf:Property ;
    rdfs:label 'Abatement Due Date' ;
    rdfs:comment 'Regulatory deadline by which the cited hazard or non-compliance condition must be corrected and abated. Failure to meet this date may result in additional penalties or willful reclassification.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignedTo rdf:type rdf:Property ;
    rdfs:label 'Assigned To' ;
    rdfs:comment 'Name or employee identifier of the compliance officer, property manager, or responsible party assigned to manage the remediation and regulatory response for this violation.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:citationIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Citation Issued Date' ;
    rdfs:comment 'Date on which the regulatory body formally issued the citation, notice of violation, or enforcement action. Triggers the statutory response and contest windows.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contestDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Contest Deadline Date' ;
    rdfs:comment 'Statutory deadline by which the cited party must file a notice of contest to challenge the citation before the relevant review commission (e.g., OSHRC for OSHA citations). Typically 15 working days from receipt of citation.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionPlan rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan' ;
    rdfs:comment 'Description of the formal corrective action plan (CAP) developed to remediate the cited condition and prevent recurrence. Summarizes the remediation steps, responsible parties, and milestones.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isContested rdf:type rdf:Property ;
    rdfs:label 'Is Contested' ;
    rdfs:comment 'Indicates whether the cited party has formally filed a notice of contest challenging the violation citation. When true, the matter is referred to the applicable review commission or administrative tribunal.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMandatoryReport rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory Report' ;
    rdfs:comment 'Indicates whether this violation or incident triggers a mandatory regulatory reporting obligation (e.g., OSHA 8-hour fatality report, OSHA 24-hour hospitalization report, SEC material event disclosure, GDPR 72-hour breach notification). When true, drives the mandatory reporting workflow.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRepeatViolation rdf:type rdf:Property ;
    rdfs:label 'Is Repeat Violation' ;
    rdfs:comment 'Indicates whether this violation is a repeat of a substantially similar violation cited at the same establishment within the past five years. Repeat violations carry significantly higher OSHA penalties (up to 10x the base penalty).' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leedBreeamImpact rdf:type rdf:Property ;
    rdfs:label 'Leed Breeam Impact' ;
    rdfs:comment 'Indicates whether the violation has a material impact on the property\'s LEED or BREEAM certification status. When true, triggers a review of the certification standing with the U.S. Green Building Council or BRE.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mandatoryReportDeadline rdf:type rdf:Property ;
    rdfs:label 'Mandatory Report Deadline' ;
    rdfs:comment 'Timestamp by which the mandatory regulatory report must be submitted to the governing body. Calculated from the violation or incident date based on the applicable regulatory timeline (e.g., 8 hours for OSHA fatality, 72 hours for GDPR breach).' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:oshaLogClassification rdf:type rdf:Property ;
    rdfs:label 'Osha Log Classification' ;
    rdfs:comment 'OSHA 300 Log column classification for recordable workplace incidents. Categorizes the nature of the work-related injury or illness per OSHA 29 CFR 1904 recordkeeping requirements. Applicable only when osha_recordable is true.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaRecordable rdf:type rdf:Property ;
    rdfs:label 'Osha Recordable' ;
    rdfs:comment 'Indicates whether the safety incident meets OSHA recordability criteria under 29 CFR 1904 and must be entered on the OSHA 300 Log. Applies to work-related injuries and illnesses meeting the recording threshold.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyAmountAssessed rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount Assessed' ;
    rdfs:comment 'Gross monetary penalty amount formally assessed by the regulatory body at the time of citation issuance, in the currency specified by penalty_currency_code. Represents the initial proposed penalty before any informal settlement or reduction.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyAmountSettled rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount Settled' ;
    rdfs:comment 'Final negotiated or settled penalty amount after informal conference, contest resolution, or administrative settlement. May differ from the assessed amount due to reductions for good faith, size, or history.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed narrative description of the root cause findings from the formal root cause analysis (RCA) investigation. Captures the specific conditions, actions, or systemic failures that led to the violation.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'OSHA-aligned severity classification of the violation indicating the degree of hazard or non-compliance. Willful and serious violations carry higher penalties and mandatory abatement timelines. Also applied to non-OSHA violations by analogy.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationDate rdf:type rdf:Property ;
    rdfs:label 'Violation Date' ;
    rdfs:comment 'The date on which the violation, non-compliance event, or workplace safety incident occurred. This is the principal real-world event date, distinct from the citation issuance date or record creation date.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:violationDescription rdf:type rdf:Property ;
    rdfs:label 'Violation Description' ;
    rdfs:comment 'Detailed narrative description of the violation or non-compliance event as documented in the citation or inspection report. Captures the specific condition, act, or omission that constitutes the violation.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationStatus rdf:type rdf:Property ;
    rdfs:label 'Violation Status' ;
    rdfs:comment 'Current lifecycle state of the violation record. Drives remediation workflow, regulatory response management, and compliance dashboard reporting.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationType rdf:type rdf:Property ;
    rdfs:label 'Violation Type' ;
    rdfs:comment 'High-level classification of the violation category. Drives routing to the appropriate compliance program and remediation workflow. [ENUM-REF-CANDIDATE: environmental|safety|building_code|zoning|fair_housing|financial_reporting|data_privacy|fire_code|accessibility|labor — promote to reference product]' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptedSubmissionMethods rdf:type rdf:Property ;
    rdfs:label 'Accepted Submission Methods' ;
    rdfs:comment 'Comma-separated list of accepted filing submission methods for this jurisdiction (e.g., \'online_portal,mail,email,in_person\'). Informs compliance teams of valid channels for regulatory submissions.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countyName rdf:type rdf:Property ;
    rdfs:label 'County Name' ;
    rdfs:comment 'Name of the county or parish within which this jurisdiction operates. Applicable for county-level and municipal jurisdictions. Used for property-level compliance mapping where county authorities govern zoning, permitting, and environmental assessments.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Esg Reporting Required' ;
    rdfs:comment 'Indicates whether this jurisdiction mandates Environmental, Social, and Governance (ESG) reporting for real estate entities operating within its boundaries. Drives ESG compliance program activation for properties in this jurisdiction.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:filingPortalName rdf:type rdf:Property ;
    rdfs:label 'Filing Portal Name' ;
    rdfs:comment 'Official name of the electronic filing portal or system used to submit compliance filings to this jurisdiction (e.g., \'EPA Central Data Exchange (CDX)\', \'SEC EDGAR\', \'HUD Integrated Disbursement and Information System (IDIS)\').' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingPortalUrl rdf:type rdf:Property ;
    rdfs:label 'Filing Portal Url' ;
    rdfs:comment 'URL of the official online filing portal for this jurisdiction (e.g., EPA\'s CDX portal, SEC EDGAR, HUD IDIS). Used by compliance teams to submit regulatory filings, permits, and disclosures electronically.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicBoundaryDescription rdf:type rdf:Property ;
    rdfs:label 'Geographic Boundary Description' ;
    rdfs:comment 'Textual description of the geographic boundaries or territorial scope of this jurisdiction (e.g., \'All properties within the five boroughs of New York City\', \'Coastal zone within 1,000 feet of mean high tide\'). Supports GIS-based compliance mapping for portfolio properties.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Code' ;
    rdfs:comment 'Unique, externally-recognizable alphanumeric code identifying the jurisdiction (e.g., US-EPA, US-CA-DRE, US-NYC-DOB). Used as the business key for cross-system lookups and compliance mapping across Yardi Voyager, MRI Software, and SAP S/4HANA.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionLevel rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Level' ;
    rdfs:comment 'Hierarchical level of the regulatory jurisdiction within the governmental structure. Drives multi-jurisdictional compliance mapping logic — federal obligations cascade to state and local levels. Values: federal, state, county, city, special_district.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionStatus rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Status' ;
    rdfs:comment 'Current lifecycle status of the jurisdiction record. \'active\' indicates the jurisdiction is currently enforcing regulations applicable to the portfolio. \'superseded\' indicates the jurisdiction has been replaced by another record. Used to filter valid jurisdictions for compliance obligation assignment.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leedBreeamApplicable rdf:type rdf:Property ;
    rdfs:label 'Leed Breeam Applicable' ;
    rdfs:comment 'Indicates whether LEED (Leadership in Energy and Environmental Design) or BREEAM (Building Research Establishment Environmental Assessment Method) certification requirements or incentives apply within this jurisdiction. Supports green building compliance tracking.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mailingAddress rdf:type rdf:Property ;
    rdfs:label 'Mailing Address' ;
    rdfs:comment 'Official mailing address of the regulatory jurisdiction\'s governing body office. Used for physical filing submissions, certified mail correspondence, and formal regulatory notices.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyAuthority rdf:type rdf:Property ;
    rdfs:label 'Penalty Authority' ;
    rdfs:comment 'Indicates whether this jurisdiction has statutory authority to impose financial penalties or enforcement actions for non-compliance. True = jurisdiction can levy fines, issue cease-and-desist orders, or pursue legal action. Drives risk prioritization in compliance programs.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresLocalRegistration rdf:type rdf:Property ;
    rdfs:label 'Requires Local Registration' ;
    rdfs:comment 'Indicates whether entities operating within this jurisdiction must register with the governing body before conducting real estate activities (e.g., broker licensing with state DRE, REIT registration with SEC, contractor licensing with local authority). Drives onboarding compliance workflows.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:secReportingApplicable rdf:type rdf:Property ;
    rdfs:label 'Sec Reporting Applicable' ;
    rdfs:comment 'Indicates whether Securities and Exchange Commission (SEC) reporting obligations apply to real estate investment entities operating within this jurisdiction (e.g., publicly traded REITs). Activates SEC filing workflows including 10-K, 10-Q, and 8-K submissions.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardFilingDeadlineDays rdf:type rdf:Property ;
    rdfs:label 'Standard Filing Deadline Days' ;
    rdfs:comment 'Default number of calendar days from the end of the reporting period within which filings must be submitted to this jurisdiction. Used to auto-calculate filing due dates for compliance obligations assigned to this jurisdiction.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baseCurrencyCurrencyCodeId rdf:type rdf:Property ;
    rdfs:label 'Base Currency Currency Code Id' ;
    rdfs:comment 'Foreign key linking to reference.currency_code. Business justification: Fund base currency drives NAV calculation, investor capital account statements, and multi-currency consolidation reporting. Role-prefixed to distinguish from other potential currency FKs on fund; norm' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CurrencyCode .

ind:parentFundId rdf:type rdf:Property ;
    rdfs:label 'Parent Fund Id' ;
    rdfs:comment 'Self-referencing FK on fund (parent_fund_id)' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fund .

ind:actualAum rdf:type rdf:Property ;
    rdfs:label 'Actual Aum' ;
    rdfs:comment 'Current total Assets Under Management (AUM) representing the fair market value of all assets held by the fund, expressed in the fund\'s base currency. Sourced from MRI Software and Argus Enterprise valuations. Updated at each reporting period.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calledCapital rdf:type rdf:Property ;
    rdfs:label 'Called Capital' ;
    rdfs:comment 'Cumulative capital drawn down from LP commitments to fund investments, fees, and expenses, expressed in the fund\'s base currency. Used in DPI (Distributions to Paid-In) and TVPI (Total Value to Paid-In) multiple calculations.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carriedInterestRate rdf:type rdf:Property ;
    rdfs:label 'Carried Interest Rate' ;
    rdfs:comment 'GP\'s share of profits above the preferred return hurdle, expressed as a decimal (e.g., 0.2000 = 20%). Represents the performance-based compensation to the General Partner. Sourced from LPA terms in DocuSign CLM.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrationLimit rdf:type rdf:Property ;
    rdfs:label 'Concentration Limit' ;
    rdfs:comment 'Maximum percentage of total fund GAV that may be invested in any single asset or property, expressed as a decimal (e.g., 0.20 = 20%). Enforces diversification requirements per the LPA investment mandate.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributedCapital rdf:type rdf:Property ;
    rdfs:label 'Distributed Capital' ;
    rdfs:comment 'Cumulative capital returned to Limited Partners (LPs) through asset dispositions, refinancing proceeds, and income distributions, expressed in the fund\'s base currency. Key input for DPI multiple and IRR calculations.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:esgFramework rdf:type rdf:Property ;
    rdfs:label 'Esg Framework' ;
    rdfs:comment 'Primary ESG reporting framework adopted by the fund (e.g., GRESB for real estate, UN PRI, TCFD). Null if esg_mandate is false. Drives sustainability data collection and disclosure requirements.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgMandate rdf:type rdf:Property ;
    rdfs:label 'Esg Mandate' ;
    rdfs:comment 'Indicates whether the fund operates under a formal Environmental, Social, and Governance (ESG) investment mandate requiring ESG screening, LEED/BREEAM certification targets, or sustainability reporting obligations.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extensionOptions rdf:type rdf:Property ;
    rdfs:label 'Extension Options' ;
    rdfs:comment 'Number of permissible one-year extension options available to the General Partner (GP) beyond the base fund term, as specified in the LPA. Supports fund lifecycle planning and investor communication.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feeBasis rdf:type rdf:Property ;
    rdfs:label 'Fee Basis' ;
    rdfs:comment 'The capital base upon which the annual management fee rate is applied. Committed capital is common during the investment period; invested capital or NAV is common during the harvest period.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeCap rdf:type rdf:Property ;
    rdfs:label 'Fee Cap' ;
    rdfs:comment 'Maximum absolute dollar amount of management fees that may be charged to the fund in any given year, expressed in the fund\'s base currency. Null if no cap is specified in the LPA.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeWaiverConditions rdf:type rdf:Property ;
    rdfs:label 'Fee Waiver Conditions' ;
    rdfs:comment 'Narrative description of conditions under which management fees may be waived or reduced (e.g., GP co-investment, fund underperformance, LP negotiated side letter terms). Sourced from LPA and side letter agreements in DocuSign CLM.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalCloseDate rdf:type rdf:Property ;
    rdfs:label 'Final Close Date' ;
    rdfs:comment 'Date on which the fund completed its capital raising period and accepted its last investor commitment. Marks the end of the fundraising phase and the start of the investment period. Null for open-end funds.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fundCode rdf:type rdf:Property ;
    rdfs:label 'Fund Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the fund across systems (e.g., MRI Software, Argus Enterprise, SAP S/4HANA). Used as the business key in cross-system reconciliation and regulatory filings.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundName rdf:type rdf:Property ;
    rdfs:label 'Fund Name' ;
    rdfs:comment 'Full legal name of the investment fund or vehicle as registered with the relevant regulatory authority (e.g., SEC, FINRA). Used in investor communications, regulatory filings, and reporting.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundStatus rdf:type rdf:Property ;
    rdfs:label 'Fund Status' ;
    rdfs:comment 'Current lifecycle state of the fund. Drives operational workflows, investor reporting obligations, and capital call eligibility. Fundraising indicates the fund is accepting commitments; fully_invested indicates deployment is complete; harvesting indicates asset disposition phase.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundType rdf:type rdf:Property ;
    rdfs:label 'Fund Type' ;
    rdfs:comment 'Classification of the investment vehicle structure. Determines regulatory treatment, investor redemption rights, and accounting framework. [ENUM-REF-CANDIDATE: open_end|closed_end|reit|partnership|cmbs_trust|rmbs_trust|separate_account|co_investment — promote to reference product]' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gav rdf:type rdf:Property ;
    rdfs:label 'Gav' ;
    rdfs:comment 'Gross Asset Value (GAV) of the fund representing the total fair market value of all real estate assets before deducting fund-level debt and liabilities, expressed in the fund\'s base currency. Used in leverage ratio and LTV calculations.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpEntityName rdf:type rdf:Property ;
    rdfs:label 'Gp Entity Name' ;
    rdfs:comment 'Legal name of the General Partner entity responsible for managing the fund, making investment decisions, and fulfilling fiduciary obligations to Limited Partners (LPs). Sourced from MRI Software Investment Management module.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inceptionDate rdf:type rdf:Property ;
    rdfs:label 'Inception Date' ;
    rdfs:comment 'Date on which the fund was legally formed and commenced operations. Used as the start date for IRR, equity multiple, and since-inception performance calculations in Argus Enterprise.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investmentPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Investment Period End Date' ;
    rdfs:comment 'Date on which the fund\'s investment period expires and the GP is no longer permitted to make new investments or call capital for new acquisitions. After this date, capital calls are limited to follow-on investments and fund expenses.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxDealSize rdf:type rdf:Property ;
    rdfs:label 'Max Deal Size' ;
    rdfs:comment 'Maximum individual asset or transaction size (in base currency) that the fund is mandated to consider for investment. Prevents over-concentration in a single asset and ensures portfolio diversification per LPA guidelines.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minDealSize rdf:type rdf:Property ;
    rdfs:label 'Min Deal Size' ;
    rdfs:comment 'Minimum individual asset or transaction size (in base currency) that the fund is mandated to consider for investment. Ensures portfolio concentration and operational efficiency thresholds are maintained.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nav rdf:type rdf:Property ;
    rdfs:label 'Nav' ;
    rdfs:comment 'Net Asset Value (NAV) of the fund as of the most recent valuation date, calculated as total assets minus total liabilities, expressed in the fund\'s base currency. Primary metric for open-end fund unit pricing and investor redemption calculations.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredReturnHurdle rdf:type rdf:Property ;
    rdfs:label 'Preferred Return Hurdle' ;
    rdfs:comment 'Minimum annualized return rate (expressed as a decimal, e.g., 0.0800 = 8.00%) that must be distributed to Limited Partners (LPs) before the General Partner (GP) is entitled to receive carried interest. Also known as the hurdle rate or preferred return.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetAum rdf:type rdf:Property ;
    rdfs:label 'Target Aum' ;
    rdfs:comment 'Target total Assets Under Management (AUM) the fund intends to reach at full deployment, expressed in the fund\'s base currency. Used in fundraising materials, investor presentations, and portfolio planning in Argus Enterprise.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetLeverageMax rdf:type rdf:Property ;
    rdfs:label 'Target Leverage Max' ;
    rdfs:comment 'Maximum Loan-to-Value (LTV) ratio permitted under the fund\'s investment mandate, expressed as a decimal (e.g., 0.65 = 65%). Defines the upper bound of the fund\'s leverage range. Exceeding this threshold may trigger LP notification requirements.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetLeverageMin rdf:type rdf:Property ;
    rdfs:label 'Target Leverage Min' ;
    rdfs:comment 'Minimum Loan-to-Value (LTV) ratio permitted under the fund\'s investment mandate, expressed as a decimal (e.g., 0.40 = 40%). Defines the lower bound of the fund\'s leverage range for portfolio construction and risk management.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:termYears rdf:type rdf:Property ;
    rdfs:label 'Term Years' ;
    rdfs:comment 'Contractual life of the fund in years from inception to scheduled termination, as defined in the Limited Partnership Agreement (LPA) or fund prospectus. Null for open-end funds with no fixed term.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalCommitments rdf:type rdf:Property ;
    rdfs:label 'Total Commitments' ;
    rdfs:comment 'Aggregate capital committed by all Limited Partners (LPs) to the fund as of the final close, expressed in the fund\'s base currency. Represents the maximum capital available for investment and fee calculation basis.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationDate rdf:type rdf:Property ;
    rdfs:label 'Valuation Date' ;
    rdfs:comment 'Date of the most recent formal appraisal or valuation of the fund\'s portfolio used to calculate NAV and GAV. Typically quarterly for institutional funds. Sourced from Argus Enterprise valuation models.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parentPortfolioId rdf:type rdf:Property ;
    rdfs:label 'Parent Portfolio Id' ;
    rdfs:comment 'Self-referencing FK on portfolio (parent_portfolio_id)' ;
    rdfs:domain ind:Portfolio ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Portfolio .

ind:reportingCurrencyCodeId rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Code Id' ;
    rdfs:comment 'Foreign key linking to reference.currency_code. Business justification: Portfolio reporting currency drives financial consolidation, investor capital account statements, and multi-currency NAV reporting. Role-prefixed to clarify reporting context; normalizes the denormali' ;
    rdfs:domain ind:Portfolio ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CurrencyCode .

ind:targetLeaseTypeId rdf:type rdf:Property ;
    rdfs:label 'Target Lease Type Id' ;
    rdfs:comment 'Foreign key linking to reference.lease_type. Business justification: Portfolio strategy documents specify target lease structure (NNN, gross, modified gross) which drives NOI modeling, CAM recovery projections, and benchmark comparisons. Role-prefixed \'target_\' as port' ;
    rdfs:domain ind:Portfolio ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LeaseType .

ind:benchmarkIndex rdf:type rdf:Property ;
    rdfs:label 'Benchmark Index' ;
    rdfs:comment 'The market index or peer benchmark against which portfolio performance (IRR, TWR, total return) is measured (e.g., NCREIF NPI, MSCI Real Estate Index, FTSE NAREIT All Equity REITs Index).' ;
    rdfs:domain ind:Portfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedCapital rdf:type rdf:Property ;
    rdfs:label 'Committed Capital' ;
    rdfs:comment 'Total equity capital formally committed by investors to the portfolio as of the most recent reporting date. Distinct from called/deployed capital. Tracks fundraising progress against target fund size.' ;
    rdfs:domain ind:Portfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ffoReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Ffo Reporting Flag' ;
    rdfs:comment 'Indicates whether this portfolio reports Funds From Operations (FFO) and Adjusted Funds From Operations (AFFO) per NAREIT standards. Applicable primarily to REIT-structured portfolios for SEC and investor reporting.' ;
    rdfs:domain ind:Portfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leveragePolicy rdf:type rdf:Property ;
    rdfs:label 'Leverage Policy' ;
    rdfs:comment 'Portfolio-level leverage policy classification governing the use of debt financing. Unleveraged = no debt; Low = LTV <30%; Moderate = LTV 30-60%; High = LTV >60%. Aligns with investment strategy and risk mandate.' ;
    rdfs:domain ind:Portfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openEndFlag rdf:type rdf:Property ;
    rdfs:label 'Open End Flag' ;
    rdfs:comment 'Indicates whether the portfolio is structured as an open-end fund allowing ongoing investor subscriptions and redemptions (True) versus a closed-end fund with a fixed capital raise and defined term (False).' ;
    rdfs:domain ind:Portfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portfolioCode rdf:type rdf:Property ;
    rdfs:label 'Portfolio Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the portfolio used in investor reporting, Argus Enterprise, MRI Software, and regulatory filings. Unique across all portfolios.' ;
    rdfs:domain ind:Portfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioName rdf:type rdf:Property ;
    rdfs:label 'Portfolio Name' ;
    rdfs:comment 'Full human-readable name of the investment portfolio as used in investor communications, fund documents, and management reporting (e.g., \'Core Office Fund III\', \'Diversified Income REIT Portfolio\').' ;
    rdfs:domain ind:Portfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioStatus rdf:type rdf:Property ;
    rdfs:label 'Portfolio Status' ;
    rdfs:comment 'Current lifecycle state of the portfolio. Active = fully operational; Inactive = temporarily not deploying capital; Winding Down = in liquidation/disposition phase; Closed = fully liquidated; Pending Launch = pre-inception setup; Suspended = operations halted pending review.' ;
    rdfs:domain ind:Portfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Compliance Flag' ;
    rdfs:comment 'Indicates whether this portfolio is subject to Sarbanes-Oxley Act (SOX) internal control requirements, applicable to publicly traded REITs and entities with SEC reporting obligations.' ;
    rdfs:domain ind:Portfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetCapRate rdf:type rdf:Property ;
    rdfs:label 'Target Cap Rate' ;
    rdfs:comment 'Target portfolio-level Capitalization Rate (CAP Rate) expressed as a decimal (e.g., 0.0550 = 5.50%) representing the expected NOI yield on asset value. Used for acquisition underwriting and portfolio valuation benchmarking.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetFundSize rdf:type rdf:Property ;
    rdfs:label 'Target Fund Size' ;
    rdfs:comment 'Total target equity capital raise for the portfolio/fund expressed in the reporting currency. Represents the maximum committed capital the fund intends to raise from investors. Used for capital deployment planning.' ;
    rdfs:domain ind:Portfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetGav rdf:type rdf:Property ;
    rdfs:label 'Target Gav' ;
    rdfs:comment 'Target Gross Asset Value (GAV) representing the total undiscounted market value of all assets in the portfolio at full deployment, before deducting liabilities. Used for capital raising targets and AUM reporting.' ;
    rdfs:domain ind:Portfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetLtv rdf:type rdf:Property ;
    rdfs:label 'Target Ltv' ;
    rdfs:comment 'Target portfolio-level Loan-to-Value Ratio (LTV) expressed as a decimal (e.g., 0.60 = 60%) representing the maximum leverage policy for the portfolio. Governs debt capacity and risk management guidelines.' ;
    rdfs:domain ind:Portfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetNav rdf:type rdf:Property ;
    rdfs:label 'Target Nav' ;
    rdfs:comment 'Target Net Asset Value (NAV) representing the portfolio\'s equity value after deducting all liabilities from GAV. Key metric for open-end fund unit pricing, investor redemptions, and performance reporting.' ;
    rdfs:domain ind:Portfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetNoi rdf:type rdf:Property ;
    rdfs:label 'Target Noi' ;
    rdfs:comment 'Target annual Net Operating Income (NOI) for the portfolio representing total revenue less operating expenses before debt service and capital expenditures. Core income metric for CAP rate valuation and DSCR analysis.' ;
    rdfs:domain ind:Portfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetOccupancyRate rdf:type rdf:Property ;
    rdfs:label 'Target Occupancy Rate' ;
    rdfs:comment 'Target portfolio-level physical occupancy rate expressed as a decimal (e.g., 0.95 = 95%) representing the proportion of Net Leasable Area (NLA) that is leased and occupied. Core operational KPI for income forecasting.' ;
    rdfs:domain ind:Portfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetWale rdf:type rdf:Property ;
    rdfs:label 'Target Wale' ;
    rdfs:comment 'Target Weighted Average Lease Expiry (WALE) in years representing the income-weighted average time until lease expiry across all portfolio assets. Distinct from WALT as it measures time to expiry rather than total term.' ;
    rdfs:domain ind:Portfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetWalt rdf:type rdf:Property ;
    rdfs:label 'Target Walt' ;
    rdfs:comment 'Target Weighted Average Lease Term (WALT) in years representing the income-weighted average remaining lease duration across all portfolio assets. Key metric for income stability and refinancing risk assessment.' ;
    rdfs:domain ind:Portfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationFrequency rdf:type rdf:Property ;
    rdfs:label 'Valuation Frequency' ;
    rdfs:comment 'Frequency at which independent or internal valuations are conducted for portfolio assets to update NAV and GAV. Quarterly is standard for institutional funds; monthly for open-end funds with frequent redemptions.' ;
    rdfs:domain ind:Portfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationMethod rdf:type rdf:Property ;
    rdfs:label 'Valuation Method' ;
    rdfs:comment 'Primary valuation methodology applied to assets within this portfolio for NAV and GAV calculations. DCF = Discounted Cash Flow; Direct Capitalization = NOI/CAP Rate; Sales Comparison = comparable transactions; Cost Approach = replacement cost; NAV Based = for fund-of-funds.' ;
    rdfs:domain ind:Portfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleType rdf:type rdf:Property ;
    rdfs:label 'Vehicle Type' ;
    rdfs:comment 'Legal and structural form of the investment vehicle housing this portfolio. Determines regulatory reporting obligations (SEC for REITs), tax treatment, and investor eligibility. [ENUM-REF-CANDIDATE: reit|open_end_fund|closed_end_fund|separate_account|partnership|joint_venture|cmbs|rmbs — promote to reference product]' ;
    rdfs:domain ind:Portfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investorId rdf:type rdf:Property ;
    rdfs:label 'Investor Id' ;
    rdfs:comment 'Unique surrogate identifier for the investor record in the real estate investment platform. Primary key for the investor entity.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Investor .

ind:preferredCurrencyCodeId rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency Code Id' ;
    rdfs:comment 'Foreign key linking to reference.currency_code. Business justification: Investor preferred currency drives distribution payment processing, capital account statement generation, and FX conversion for multi-currency fund distributions. Role-prefixed to distinguish from oth' ;
    rdfs:domain ind:Investor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CurrencyCode .

ind:targetPropertyTypeId rdf:type rdf:Property ;
    rdfs:label 'Target Property Type Id' ;
    rdfs:comment 'Foreign key linking to reference.property_type. Business justification: Investor mandate specifies target property type for deal matching, co-investment eligibility screening, and fund-investor mandate alignment reporting used in investor relations and capital raising.' ;
    rdfs:domain ind:Investor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PropertyType .

ind:accreditationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Accreditation Expiry Date' ;
    rdfs:comment 'Date on which the investor\'s accreditation verification expires. Accreditation must be re-verified periodically to maintain eligibility for private placement investments under SEC Regulation D. Drives compliance monitoring and investor eligibility gating.' ;
    rdfs:domain ind:Investor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accreditationStatus rdf:type rdf:Property ;
    rdfs:label 'Accreditation Status' ;
    rdfs:comment 'Regulatory accreditation classification of the investor under SEC Regulation D. Accredited investors meet income or net worth thresholds permitting participation in private placements. Qualified purchaser status permits investment in 3(c)(7) funds. Critical for fund eligibility gating and regulatory compliance.' ;
    rdfs:domain ind:Investor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amlStatus rdf:type rdf:Property ;
    rdfs:label 'Aml Status' ;
    rdfs:comment 'Current Anti-Money Laundering (AML) screening status for the investor. Cleared indicates the investor has passed sanctions screening and adverse media checks. Flagged indicates a potential match requiring enhanced due diligence. Mandatory for regulatory compliance under FinCEN and FATF guidelines.' ;
    rdfs:domain ind:Investor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coInvestmentEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Co Investment Eligible Flag' ;
    rdfs:comment 'Indicates whether the investor is eligible to participate in co-investment opportunities alongside the fund. Co-investment rights are typically granted to anchor investors and platinum-tier relationships. True enables the investor to receive co-investment deal flow notifications and participate in direct deal allocations.' ;
    rdfs:domain ind:Investor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:committedCapitalAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Capital Amount' ;
    rdfs:comment 'Total capital amount formally committed by the investor to real estate funds or investment vehicles, expressed in the investor\'s preferred currency. Represents the contractual obligation to fund capital calls up to this amount. Core metric for AUM (Assets Under Management) calculation and fund capacity management in MRI Software and Argus Enterprise.' ;
    rdfs:domain ind:Investor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crsClassification rdf:type rdf:Property ;
    rdfs:label 'Crs Classification' ;
    rdfs:comment 'OECD Common Reporting Standard (CRS) entity classification for automatic exchange of financial account information between tax authorities. Reportable Person indicates the investor\'s account information must be reported to their country of tax residency. Drives annual CRS reporting obligations.' ;
    rdfs:domain ind:Investor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionBankAccountRef rdf:type rdf:Property ;
    rdfs:label 'Distribution Bank Account Ref' ;
    rdfs:comment 'Masked or tokenized reference to the investor\'s designated bank account for distribution wire transfers and capital return payments. Full account details are stored in the secure payment vault; this field holds only the reference token. Used by Yardi Voyager AP module for distribution processing.' ;
    rdfs:domain ind:Investor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionPreference rdf:type rdf:Property ;
    rdfs:label 'Distribution Preference' ;
    rdfs:comment 'Investor\'s preferred frequency and method for receiving investment distributions (income and return of capital). Quarterly is most common for real estate funds. Reinvest indicates the investor elects to reinvest distributions into additional fund units. Drives distribution waterfall processing in MRI Software and Yardi Voyager.' ;
    rdfs:domain ind:Investor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatcaClassification rdf:type rdf:Property ;
    rdfs:label 'Fatca Classification' ;
    rdfs:comment 'FATCA (Foreign Account Tax Compliance Act) entity classification for the investor. Determines US withholding tax obligations and IRS reporting requirements. US Person classification triggers Form W-9 requirements. Foreign Financial Institution (FFI) classification requires GIIN registration. NFFE (Non-Financial Foreign Entity) requires beneficial ownership disclosure.' ;
    rdfs:domain ind:Investor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentHorizonYears rdf:type rdf:Property ;
    rdfs:label 'Investment Horizon Years' ;
    rdfs:comment 'Investor\'s preferred investment hold period expressed in years. Drives fund structure matching (open-end vs. closed-end funds), asset disposition timing, and WALT (Weighted Average Lease Term) alignment in portfolio construction. Typical real estate investment horizons range from 3 to 10+ years.' ;
    rdfs:domain ind:Investor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:investorCode rdf:type rdf:Property ;
    rdfs:label 'Investor Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier assigned to the investor upon onboarding. Used across MRI Software, Yardi Voyager, and Argus Enterprise to reference the investor in capital accounts, distribution statements, and fund reporting.' ;
    rdfs:domain ind:Investor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investorStatus rdf:type rdf:Property ;
    rdfs:label 'Investor Status' ;
    rdfs:comment 'Current lifecycle status of the investor record. Active indicates the investor is in good standing with capital deployed. Pending indicates onboarding in progress. Suspended indicates a hold due to KYC/AML review. Redeemed indicates full capital withdrawal. Closed indicates the investor relationship has been formally terminated.' ;
    rdfs:domain ind:Investor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investorTier rdf:type rdf:Property ;
    rdfs:label 'Investor Tier' ;
    rdfs:comment 'Relationship tier classification assigned to the investor based on committed capital, strategic importance, and relationship depth. Drives fee schedule application, co-investment priority access, reporting frequency, and relationship manager assignment. Platinum typically denotes anchor investors with largest AUM commitments.' ;
    rdfs:domain ind:Investor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investorType rdf:type rdf:Property ;
    rdfs:label 'Investor Type' ;
    rdfs:comment 'Classification of the investor by entity category. Drives regulatory treatment, reporting obligations, and fee structures. Institutional includes insurance companies, banks, and asset managers. HNWI (High Net Worth Individual) denotes qualifying individuals. [ENUM-REF-CANDIDATE: institutional|hnwi|family_office|pension_fund|sovereign_wealth_fund|endowment|retail|reit|fund_of_funds — promote to reference product]' ;
    rdfs:domain ind:Investor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumInvestmentAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Investment Amount' ;
    rdfs:comment 'Minimum capital amount the investor is willing to deploy per investment vehicle or fund subscription. Used during fund structuring and deal allocation to ensure investment sizing meets investor thresholds. Expressed in the investor\'s preferred currency.' ;
    rdfs:domain ind:Investor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pepFlag rdf:type rdf:Property ;
    rdfs:label 'Pep Flag' ;
    rdfs:comment 'Indicates whether the investor or any beneficial owner is classified as a Politically Exposed Person (PEP) under AML regulations. PEP status requires enhanced due diligence (EDD) and senior management approval for onboarding. True indicates PEP status confirmed; False indicates no PEP association identified.' ;
    rdfs:domain ind:Investor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sideLetterFlag rdf:type rdf:Property ;
    rdfs:label 'Side Letter Flag' ;
    rdfs:comment 'Indicates whether the investor has a side letter agreement with the fund manager granting special terms, rights, or concessions beyond the standard limited partnership agreement (LPA). Side letters may include MFN (Most Favored Nation) clauses, reduced management fees, enhanced reporting rights, or co-investment priority. True triggers side letter terms application in fee and distribution calculations.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceOfFunds rdf:type rdf:Property ;
    rdfs:label 'Source Of Funds' ;
    rdfs:comment 'Declared source of the investor\'s capital being deployed into real estate investments. Required for AML compliance to verify the legitimacy of invested capital. [ENUM-REF-CANDIDATE: operating_income|asset_sale|inheritance|pension_fund|endowment_corpus|debt_financing|equity_raise|insurance_reserves|sovereign_allocation — promote to reference product]' ;
    rdfs:domain ind:Investor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetIrrMax rdf:type rdf:Property ;
    rdfs:label 'Target Irr Max' ;
    rdfs:comment 'Maximum acceptable Internal Rate of Return (IRR) threshold expressed as a decimal percentage. Defines the upper bound of the investor\'s risk-return appetite. Investors with low IRR maximums typically prefer core or core-plus strategies. Used alongside target_irr_min to define the investor\'s return corridor in Argus Enterprise.' ;
    rdfs:domain ind:Investor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetIrrMin rdf:type rdf:Property ;
    rdfs:label 'Target Irr Min' ;
    rdfs:comment 'Minimum acceptable Internal Rate of Return (IRR) threshold expressed as a decimal percentage (e.g., 0.0800 = 8.00%). Represents the investor\'s stated return hurdle below which investment opportunities are not considered. Used in Argus Enterprise for deal screening and portfolio matching against investor mandates.' ;
    rdfs:domain ind:Investor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxResidencyCountry rdf:type rdf:Property ;
    rdfs:label 'Tax Residency Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the investor\'s country of tax residency, which may differ from domicile country. Used for CRS (Common Reporting Standard) automatic exchange of information and applicable withholding tax treaty determination.' ;
    rdfs:domain ind:Investor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentInvestorId rdf:type rdf:Property ;
    rdfs:label 'Commitment Investor Id' ;
    rdfs:comment 'Reference to the investor (institutional or individual) making this capital commitment. Serves as the PARTY_REFERENCE for this transaction.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Investor .

ind:commitmentTransfereeInvestorId rdf:type rdf:Property ;
    rdfs:label 'Commitment Transferee Investor Id' ;
    rdfs:comment 'Reference to the investor who received this commitment via secondary transfer. Populated only when commitment_status is \'transferred\'. Enables tracking of secondary market activity.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Investor .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'The gross total capital amount the investor has committed to the fund or investment vehicle, expressed in the commitment currency. Represents the investor\'s maximum obligation under the subscription agreement. Part of the MONETARY_TRIPLET.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aumContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Aum Contribution Amount' ;
    rdfs:comment 'The portion of this commitment that contributes to the fund\'s reported Assets Under Management (AUM) figure, which may differ from the total commitment amount based on fund accounting policies and deployment stage.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calledCapitalAmount rdf:type rdf:Property ;
    rdfs:label 'Called Capital Amount' ;
    rdfs:comment 'Total capital that has been called (drawn down) from the investor to date across all capital calls against this commitment. Represents cumulative funded capital. Part of the MONETARY_TRIPLET.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalCallScheduleType rdf:type rdf:Property ;
    rdfs:label 'Capital Call Schedule Type' ;
    rdfs:comment 'The methodology governing how and when capital calls are issued against this commitment. Determines cash flow planning for both the fund manager and the investor.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coInvestmentFlag rdf:type rdf:Property ;
    rdfs:label 'Co Investment Flag' ;
    rdfs:comment 'Indicates whether this commitment is a co-investment alongside the main fund vehicle (True) or a standard fund commitment (False). Co-investments typically carry different fee structures and governance rights.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commitmentDate rdf:type rdf:Property ;
    rdfs:label 'Commitment Date' ;
    rdfs:comment 'The date on which the investor formally committed capital to the fund, typically the date the subscription agreement or LOI was executed. Serves as the principal business event date (BUSINESS_EVENT_TIMESTAMP category).' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commitmentNumber rdf:type rdf:Property ;
    rdfs:label 'Commitment Number' ;
    rdfs:comment 'Externally-known business identifier for the commitment, used in investor correspondence, subscription documents, and capital call notices. Sourced from MRI Software Investment Management.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentStatus rdf:type rdf:Property ;
    rdfs:label 'Commitment Status' ;
    rdfs:comment 'Current lifecycle state of the capital commitment from LOI through full deployment. Tracks progression: pending (LOI received), executed (subscription agreement signed), funded (capital fully called and received), defaulted (investor failed to meet capital call), cancelled (commitment withdrawn), transferred (commitment assigned to another investor). [ENUM-REF-CANDIDATE: pending|executed|funded|defaulted|cancelled|transferred — promote to reference product]' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultDate rdf:type rdf:Property ;
    rdfs:label 'Default Date' ;
    rdfs:comment 'The date on which the investor defaulted on a capital call obligation. Populated only when commitment_status is \'defaulted\'. Triggers default remedies per the limited partnership agreement.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distributedCapitalAmount rdf:type rdf:Property ;
    rdfs:label 'Distributed Capital Amount' ;
    rdfs:comment 'Total capital returned to the investor through distributions (return of capital, realized gains, income distributions) against this commitment to date. Used in DPI (Distributions to Paid-In) calculations.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:erisaFlag rdf:type rdf:Property ;
    rdfs:label 'Erisa Flag' ;
    rdfs:comment 'Indicates whether the investor\'s assets are subject to ERISA (Employee Retirement Income Security Act) regulations. ERISA investors trigger plan asset rules and fiduciary obligations for the fund manager.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstCallDate rdf:type rdf:Property ;
    rdfs:label 'First Call Date' ;
    rdfs:comment 'The date of the first capital call issued against this commitment. Marks the beginning of the capital deployment phase and triggers the investment period clock.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fundTermEndDate rdf:type rdf:Property ;
    rdfs:label 'Fund Term End Date' ;
    rdfs:comment 'The scheduled termination date of the fund, representing the EFFECTIVE_UNTIL for the commitment\'s binding period. After this date, the fund is expected to be wound down and all capital returned.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loiReference rdf:type rdf:Property ;
    rdfs:label 'Loi Reference' ;
    rdfs:comment 'Reference identifier for the Letter of Intent (LOI) that preceded the formal subscription agreement. Tracks the initial non-binding expression of interest in the commitment lifecycle.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallableDistributionsAmount rdf:type rdf:Property ;
    rdfs:label 'Recallable Distributions Amount' ;
    rdfs:comment 'The cumulative amount of distributions made to the investor that are subject to recall (clawback) for future capital calls, per the fund\'s limited partnership agreement. Affects the effective uncalled capital balance.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sideLetterReference rdf:type rdf:Property ;
    rdfs:label 'Side Letter Reference' ;
    rdfs:comment 'Document reference identifier for the executed side letter associated with this commitment. Populated only when side_letter_flag is True. Links to DocuSign CLM for document retrieval.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionAgreementRef rdf:type rdf:Property ;
    rdfs:label 'Subscription Agreement Ref' ;
    rdfs:comment 'Reference number or document identifier for the executed subscription agreement that formalizes the investor\'s capital commitment. Links to the DocuSign CLM contract lifecycle management system.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCapitalCallsCount rdf:type rdf:Property ;
    rdfs:label 'Total Capital Calls Count' ;
    rdfs:comment 'The total number of capital calls that have been issued against this commitment to date. Used for tracking deployment pace and investor notification history.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uncalledCapitalAmount rdf:type rdf:Property ;
    rdfs:label 'Uncalled Capital Amount' ;
    rdfs:comment 'Remaining capital not yet called from the investor, calculated as commitment_amount minus called_capital_amount. Represents the investor\'s dry powder — capital committed but not yet deployed. Critical for fund liquidity and deployment planning.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:callAmount rdf:type rdf:Property ;
    rdfs:label 'Call Amount' ;
    rdfs:comment 'Gross dollar amount of capital being called from the investor in this notice. Represents the base monetary demand before any adjustments. Denominated in the fund\'s base currency.' ;
    rdfs:domain ind:CapitalCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:callDate rdf:type rdf:Property ;
    rdfs:label 'Call Date' ;
    rdfs:comment 'The date on which the capital call notice was formally issued to the investor. Represents the principal business event date for the call. Used for LP capital account reconciliation and fund cash flow scheduling.' ;
    rdfs:domain ind:CapitalCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:callNumber rdf:type rdf:Property ;
    rdfs:label 'Call Number' ;
    rdfs:comment 'Externally-known sequential identifier for the capital call notice, typically formatted as CC-YYYY-NNNN. Used in investor communications, wire transfer instructions, and LP capital account statements.' ;
    rdfs:domain ind:CapitalCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callPercentage rdf:type rdf:Property ;
    rdfs:label 'Call Percentage' ;
    rdfs:comment 'The capital call amount expressed as a percentage of the investor\'s total committed capital. Enables proportional analysis across LPs with different commitment sizes. Calculated as call_amount / total_commitment * 100.' ;
    rdfs:domain ind:CapitalCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:callPurpose rdf:type rdf:Property ;
    rdfs:label 'Call Purpose' ;
    rdfs:comment 'Business purpose for which the called capital will be deployed. Drives fund accounting allocation and investor reporting. [ENUM-REF-CANDIDATE: acquisition|capex|fees|reserves|debt_repayment|operating_expenses|recapitalization|distribution_recallable — promote to reference product if additional values required]' ;
    rdfs:domain ind:CapitalCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callSequence rdf:type rdf:Property ;
    rdfs:label 'Call Sequence' ;
    rdfs:comment 'Sequential ordinal number of this capital call within the fund\'s overall capital call program (e.g., 1st call, 2nd call). Supports WALT/WALE-style weighted average analysis and fund deployment tracking.' ;
    rdfs:domain ind:CapitalCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:callStatus rdf:type rdf:Property ;
    rdfs:label 'Call Status' ;
    rdfs:comment 'Current lifecycle state of the capital call notice. Tracks progression from issuance through funding or default. Supports fund cash management and LP default monitoring.' ;
    rdfs:domain ind:CapitalCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callType rdf:type rdf:Property ;
    rdfs:label 'Call Type' ;
    rdfs:comment 'Classification of the capital call by its structural nature. Distinguishes initial drawdowns from follow-on calls, recallable distributions, bridge financing calls, and supplemental calls. Supports fund accounting and investor reporting.' ;
    rdfs:domain ind:CapitalCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeCalledAmount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Called Amount' ;
    rdfs:comment 'Total capital called from this investor across all capital calls to date including this call. Supports LP capital account balance tracking and uncalled capital calculation. Denominated in currency_code.' ;
    rdfs:domain ind:CapitalCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundedAmount rdf:type rdf:Property ;
    rdfs:label 'Funded Amount' ;
    rdfs:comment 'Actual dollar amount received from the investor in response to this capital call. May be less than call_amount in partial funding scenarios. Used for LP capital account reconciliation and shortfall calculation.' ;
    rdfs:domain ind:CapitalCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundedDate rdf:type rdf:Property ;
    rdfs:label 'Funded Date' ;
    rdfs:comment 'The date on which the investor\'s wire transfer or funding was received and confirmed. Null if not yet funded. Used for cash management reconciliation and default determination.' ;
    rdfs:domain ind:CapitalCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interestOnLatePayment rdf:type rdf:Property ;
    rdfs:label 'Interest On Late Payment' ;
    rdfs:comment 'Annual interest rate (as a percentage) charged on unfunded capital call amounts past the due date, per the fund\'s LPA default provisions. Used to calculate default penalty amounts for LP capital account adjustments.' ;
    rdfs:domain ind:CapitalCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:investmentPurposeDescription rdf:type rdf:Property ;
    rdfs:label 'Investment Purpose Description' ;
    rdfs:comment 'Narrative description of the specific investment or expenditure for which the called capital will be used (e.g., acquisition of 123 Main St, CAPEX for HVAC replacement). Included in investor notice for transparency.' ;
    rdfs:domain ind:CapitalCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefault rdf:type rdf:Property ;
    rdfs:label 'Is Default' ;
    rdfs:comment 'Indicates whether the investor has defaulted on this capital call by failing to fund by the due date. True triggers default penalty provisions per the fund\'s Limited Partnership Agreement (LPA).' ;
    rdfs:domain ind:CapitalCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRecallable rdf:type rdf:Property ;
    rdfs:label 'Is Recallable' ;
    rdfs:comment 'Indicates whether the capital called in this notice is recallable (i.e., previously distributed capital being recalled for reinvestment per LPA terms). Affects LP capital account treatment and AFFO/FFO reporting.' ;
    rdfs:domain ind:CapitalCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noticeDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Notice Delivery Method' ;
    rdfs:comment 'Channel through which the capital call notice was delivered to the investor. Supports investor communication compliance and audit trail per fund LPA requirements.' ;
    rdfs:domain ind:CapitalCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeSentDate rdf:type rdf:Property ;
    rdfs:label 'Notice Sent Date' ;
    rdfs:comment 'The date on which the capital call notice was formally dispatched to the investor via the designated communication channel (email, DocuSign CLM, investor portal). Supports investor communication audit trail.' ;
    rdfs:domain ind:CapitalCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shortfallAmount rdf:type rdf:Property ;
    rdfs:label 'Shortfall Amount' ;
    rdfs:comment 'Dollar amount by which the investor\'s funded amount falls short of the called amount (call_amount minus funded_amount). Zero if fully funded. Drives default flag and remediation workflows.' ;
    rdfs:domain ind:CapitalCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCommitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Total Commitment Amount' ;
    rdfs:comment 'The investor\'s total committed capital to the fund at the time of this capital call. Provides context for call_percentage calculation and LP capital account reconciliation. Denominated in currency_code.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uncalledCommitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Uncalled Commitment Amount' ;
    rdfs:comment 'Remaining committed but uncalled capital available from this investor after this call (total_commitment_amount minus cumulative_called_amount). Key metric for fund deployment planning and AUM reporting.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wireReference rdf:type rdf:Property ;
    rdfs:label 'Wire Reference' ;
    rdfs:comment 'Bank wire transfer reference number or confirmation code associated with the investor\'s funding of this capital call. Used for treasury reconciliation and audit trail. Sourced from MRI Software or bank confirmation.' ;
    rdfs:domain ind:CapitalCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affoComponentAmount rdf:type rdf:Property ;
    rdfs:label 'Affo Component Amount' ;
    rdfs:comment 'The portion of the gross distribution attributable to Adjusted Funds From Operations (AFFO), which further adjusts FFO for recurring capital expenditures (CAPEX), straight-line rent adjustments, and tenant improvement (TI) amortization. Supports AFFO payout ratio analysis.' ;
    rdfs:domain ind:InvestmentDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountPerUnit rdf:type rdf:Property ;
    rdfs:label 'Amount Per Unit' ;
    rdfs:comment 'The distribution amount expressed on a per-unit or per-share basis (gross distribution divided by total units/shares outstanding). Key metric for investor comparison, NAV calculations, and REIT dividend-per-share reporting.' ;
    rdfs:domain ind:InvestmentDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalGainAmount rdf:type rdf:Property ;
    rdfs:label 'Capital Gain Amount' ;
    rdfs:comment 'The portion of the gross distribution classified as long-term or short-term capital gain, arising from property dispositions or asset sales within the fund. Reported on IRS Form 1099-DIV Box 2a for investor tax purposes.' ;
    rdfs:domain ind:InvestmentDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carriedInterestAmount rdf:type rdf:Property ;
    rdfs:label 'Carried Interest Amount' ;
    rdfs:comment 'The portion of the distribution representing carried interest (promote) paid to the general partner or fund manager after the preferred return hurdle has been met. Subject to IRC Section 1061 three-year holding period rules.' ;
    rdfs:domain ind:InvestmentDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:declarationDate rdf:type rdf:Property ;
    rdfs:label 'Declaration Date' ;
    rdfs:comment 'The date on which the fund manager or board formally declared this distribution. Required for REIT compliance reporting and investor disclosure under SEC regulations.' ;
    rdfs:domain ind:InvestmentDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exDistributionDate rdf:type rdf:Property ;
    rdfs:label 'Ex Distribution Date' ;
    rdfs:comment 'The date on or after which a new investor purchasing units/shares is no longer entitled to receive the declared distribution. Used in secondary market trading and investor entitlement calculations.' ;
    rdfs:domain ind:InvestmentDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ffoComponentAmount rdf:type rdf:Property ;
    rdfs:label 'Ffo Component Amount' ;
    rdfs:comment 'The portion of the gross distribution attributable to Funds From Operations (FFO) as defined by NAREIT. Supports FFO-based investor reporting and REIT performance benchmarking. FFO excludes depreciation and gains/losses on property sales.' ;
    rdfs:domain ind:InvestmentDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:k1Issued rdf:type rdf:Property ;
    rdfs:label 'K1 Issued' ;
    rdfs:comment 'Indicates whether an IRS Schedule K-1 (Partner\'s Share of Income, Deductions, Credits) has been issued to the investor for this distribution period. Applicable to partnership and LLC fund structures. Supports tax compliance tracking.' ;
    rdfs:domain ind:InvestmentDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredReturnAmount rdf:type rdf:Property ;
    rdfs:label 'Preferred Return Amount' ;
    rdfs:comment 'The portion of the distribution representing the preferred return (hurdle rate) paid to limited partners or preferred equity investors before carried interest or promote is allocated to the general partner. Core component of waterfall calculations.' ;
    rdfs:domain ind:InvestmentDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordDate rdf:type rdf:Property ;
    rdfs:label 'Record Date' ;
    rdfs:comment 'The date on which an investor must be on record as a unit/shareholder to be eligible to receive this distribution. Critical for REIT dividend eligibility and investor entitlement calculations.' ;
    rdfs:domain ind:InvestmentDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reinvestmentElected rdf:type rdf:Property ;
    rdfs:label 'Reinvestment Elected' ;
    rdfs:comment 'Indicates whether the investor has elected to reinvest this distribution through a Dividend Reinvestment Plan (DRIP) rather than receive cash. When True, the net distribution amount is used to purchase additional units/shares at the current NAV.' ;
    rdfs:domain ind:InvestmentDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reinvestmentPricePerUnit rdf:type rdf:Property ;
    rdfs:label 'Reinvestment Price Per Unit' ;
    rdfs:comment 'The NAV or price per unit at which the reinvested distribution was used to purchase additional units under the DRIP. Establishes the cost basis for the newly acquired units for tax purposes.' ;
    rdfs:domain ind:InvestmentDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reinvestmentUnits rdf:type rdf:Property ;
    rdfs:label 'Reinvestment Units' ;
    rdfs:comment 'The number of additional fund units or shares purchased through the DRIP reinvestment of this distribution. Populated only when reinvestment_elected is True. Used to update the investor\'s unit holding balance.' ;
    rdfs:domain ind:InvestmentDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnOfCapitalAmount rdf:type rdf:Property ;
    rdfs:label 'Return Of Capital Amount' ;
    rdfs:comment 'The portion of the gross distribution classified as return of capital (ROC), which is non-taxable but reduces the investor\'s cost basis in the investment. Critical for investor tax reporting via IRS Form 1099-DIV Box 3.' ;
    rdfs:domain ind:InvestmentDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitsHeld rdf:type rdf:Property ;
    rdfs:label 'Units Held' ;
    rdfs:comment 'The number of fund units, shares, or partnership interest units held by the investor as of the record date, used to calculate the investor\'s pro-rata share of the total distribution.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionTransactionTypeId rdf:type rdf:Property ;
    rdfs:label 'Acquisition Transaction Type Id' ;
    rdfs:comment 'Foreign key linking to reference.transaction_type. Business justification: Portfolio assets are acquired via specific transaction types (direct purchase, 1031 exchange, joint venture, portfolio trade) that determine tax treatment, due diligence requirements, and title insura' ;
    rdfs:domain ind:PortfolioAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransactionType .

ind:primaryLeaseTypeId rdf:type rdf:Property ;
    rdfs:label 'Primary Lease Type Id' ;
    rdfs:comment 'Foreign key linking to reference.lease_type. Business justification: Portfolio assets have a primary lease structure (NNN, gross, modified gross) that drives NOI modeling, CAM recovery calculations, and asset valuation. Used in underwriting, appraisal, and investor rep' ;
    rdfs:domain ind:PortfolioAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LeaseType .

ind:acquisitionNotes rdf:type rdf:Property ;
    rdfs:label 'Acquisition Notes' ;
    rdfs:comment 'Free-text notes capturing key details about the acquisition rationale, deal structure, special conditions, or investment thesis for this asset. Used by asset managers and investment committees for context and historical reference.' ;
    rdfs:domain ind:PortfolioAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualExitDate rdf:type rdf:Property ;
    rdfs:label 'Actual Exit Date' ;
    rdfs:comment 'Actual date on which the asset was disposed of or transferred out of the portfolio. Populated upon disposition completion. Used for realized IRR calculations, hold period reporting, and fund performance attribution.' ;
    rdfs:domain ind:PortfolioAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocatedDebt rdf:type rdf:Property ;
    rdfs:label 'Allocated Debt' ;
    rdfs:comment 'Total debt financing allocated to this asset holding, including mortgage debt, mezzanine financing, and any other encumbrances. Used for LTV ratio monitoring, DSCR calculations, and portfolio leverage reporting.' ;
    rdfs:domain ind:PortfolioAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capexBudget rdf:type rdf:Property ;
    rdfs:label 'Capex Budget' ;
    rdfs:comment 'Total approved Capital Expenditure (CAPEX) budget allocated to this asset for the current hold period, including planned improvements, repositioning costs, and major capital repairs. Used for value-add strategy tracking and return-on-investment analysis.' ;
    rdfs:domain ind:PortfolioAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capexSpentToDate rdf:type rdf:Property ;
    rdfs:label 'Capex Spent To Date' ;
    rdfs:comment 'Cumulative Capital Expenditure (CAPEX) actually spent on this asset from acquisition date through the most recent reporting period. Compared against capex_budget to monitor capital deployment progress and cost control.' ;
    rdfs:domain ind:PortfolioAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentBookValue rdf:type rdf:Property ;
    rdfs:label 'Current Book Value' ;
    rdfs:comment 'Current carrying value of the asset on the portfolio\'s books after accumulated depreciation and any impairment charges. Used for balance sheet reporting, NAV calculations, and GAAP/IFRS financial statements.' ;
    rdfs:domain ind:PortfolioAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dispositionPrice rdf:type rdf:Property ;
    rdfs:label 'Disposition Price' ;
    rdfs:comment 'Gross sale price received upon disposition of the asset from the portfolio. Populated when asset_status = \'disposed\'. Used for realized gain/loss calculation, IRR computation, and fund performance reporting.' ;
    rdfs:domain ind:PortfolioAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equityInvested rdf:type rdf:Property ;
    rdfs:label 'Equity Invested' ;
    rdfs:comment 'Total equity capital deployed into this asset by the portfolio, net of debt financing. Used as the denominator in equity multiple and ROI calculations, and for tracking capital deployment against fund commitments.' ;
    rdfs:domain ind:PortfolioAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdStrategy rdf:type rdf:Property ;
    rdfs:label 'Hold Strategy' ;
    rdfs:comment 'Investment hold strategy assigned to this asset within the portfolio. Determines capital allocation priorities, return expectations, and exit planning. \'core_hold\' = long-term stabilized income; \'value_add\' = active repositioning for value creation; \'opportunistic\' = higher-risk/return transformation; \'disposition_target\' = approved for near-term sale; \'development\' = ground-up or major redevelopment.' ;
    rdfs:domain ind:PortfolioAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inPlaceNoi rdf:type rdf:Property ;
    rdfs:label 'In Place Noi' ;
    rdfs:comment 'Current annualized Net Operating Income (NOI) generated by the asset based on in-place leases and operating expenses. Used for CAP rate derivation, DSCR monitoring, and portfolio income reporting. Sourced from Yardi Voyager NOI statements.' ;
    rdfs:domain ind:PortfolioAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:investmentRiskProfile rdf:type rdf:Property ;
    rdfs:label 'Investment Risk Profile' ;
    rdfs:comment 'Risk-return classification of this asset holding per institutional investment framework. Distinct from hold_strategy — this reflects the underwriting risk tier used for investor disclosure, fund mandate compliance, and performance benchmarking.' ;
    rdfs:domain ind:PortfolioAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stabilizedNoi rdf:type rdf:Property ;
    rdfs:label 'Stabilized Noi' ;
    rdfs:comment 'Projected stabilized Net Operating Income (NOI) upon completion of the asset\'s business plan (lease-up, repositioning, or value-add program). Used in exit valuation modeling, IRR projections, and investment committee reporting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetExitDate rdf:type rdf:Property ;
    rdfs:label 'Target Exit Date' ;
    rdfs:comment 'Planned or target date for disposition or exit of this asset from the portfolio. Used in hold period analysis, IRR projections, fund lifecycle planning, and WALT/WALE reporting. Nullable for open-ended core holds.' ;
    rdfs:domain ind:PortfolioAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unrealizedGainLoss rdf:type rdf:Property ;
    rdfs:label 'Unrealized Gain Loss' ;
    rdfs:comment 'Difference between the current appraised value (adjusted for ownership percentage) and the current book value, representing the mark-to-market unrealized gain or loss on this holding. Positive = unrealized gain; negative = unrealized loss. Key input for NAV reporting and investor performance statements.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capRateBenchmarkId rdf:type rdf:Property ;
    rdfs:label 'Cap Rate Benchmark Id' ;
    rdfs:comment 'Foreign key linking to valuation.cap_rate_benchmark. Business justification: Fund performance reporting benchmarks the portfolio weighted-average cap rate against market surveys for LP reporting and INREV/NCREIF compliance. This is a standard fund-level performance attribution' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapRateBenchmark .

ind:affo rdf:type rdf:Property ;
    rdfs:label 'Affo' ;
    rdfs:comment 'Adjusted Funds From Operations (AFFO) for the measurement period — FFO adjusted for recurring capital expenditures (CAPEX), straight-line rent adjustments, and other non-cash items. Considered a more accurate proxy for distributable cash flow than FFO.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alpha rdf:type rdf:Property ;
    rdfs:label 'Alpha' ;
    rdfs:comment 'The fund\'s excess return over the benchmark return for the measurement period (TWR minus benchmark_return). Positive alpha indicates outperformance; negative alpha indicates underperformance relative to the benchmark.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditorSignoffStatus rdf:type rdf:Property ;
    rdfs:label 'Auditor Signoff Status' ;
    rdfs:comment 'The external auditor\'s sign-off status for this performance period. \'not_required\' for interim periods; \'pending\' for annual periods awaiting audit; \'signed_off\' for unqualified audit opinion; \'qualified\' or \'adverse\' for modified opinions. Required for SOX and SEC compliance.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkName rdf:type rdf:Property ;
    rdfs:label 'Benchmark Name' ;
    rdfs:comment 'The name of the benchmark index used for performance comparison (e.g., \'NCREIF ODCE\', \'MSCI US REIT Index\', \'FTSE NAREIT All Equity REITs\'). Provides context for interpreting benchmark_return and alpha.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkReturn rdf:type rdf:Property ;
    rdfs:label 'Benchmark Return' ;
    rdfs:comment 'The return of the designated benchmark index (e.g., NCREIF ODCE, MSCI Real Estate, S&P 500) for the same measurement period. Used to compute alpha and assess relative fund performance.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capRate rdf:type rdf:Property ;
    rdfs:label 'Cap Rate' ;
    rdfs:comment 'The weighted average Capitalization Rate (CAP Rate) applied across the fund\'s portfolio for the period — NOI divided by GAV. A key real estate valuation metric used in Argus Enterprise models and investor reporting.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capex rdf:type rdf:Property ;
    rdfs:label 'Capex' ;
    rdfs:comment 'Total Capital Expenditure (CAPEX) incurred by the fund\'s portfolio during the measurement period, including Tenant Improvement (TI) allowances, building improvements, and major repairs that extend asset life.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionPerUnit rdf:type rdf:Property ;
    rdfs:label 'Distribution Per Unit' ;
    rdfs:comment 'Cash distribution declared or paid per fund unit or share during the measurement period. Used for investor yield calculations, REIT dividend reporting, and AFFO payout ratio analysis.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dpi rdf:type rdf:Property ;
    rdfs:label 'Dpi' ;
    rdfs:comment 'Distributions to Paid-In Capital (DPI) ratio — total cumulative distributions paid to investors divided by total paid-in capital. Measures the realized return component. A DPI of 1.0 means investors have received back their full invested capital in cash.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equityMultiple rdf:type rdf:Property ;
    rdfs:label 'Equity Multiple' ;
    rdfs:comment 'The ratio of total value (realized distributions plus unrealized NAV) to total invested capital, also known as Multiple on Invested Capital (MOIC). A value of 1.75 means investors have received or hold 1.75x their invested capital.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ffo rdf:type rdf:Property ;
    rdfs:label 'Ffo' ;
    rdfs:comment 'Funds From Operations (FFO) for the measurement period — net income plus real estate depreciation and amortization, adjusted for gains/losses on property sales. The NAREIT-defined primary earnings metric for REITs, used in lieu of GAAP net income.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossIrr rdf:type rdf:Property ;
    rdfs:label 'Gross Irr' ;
    rdfs:comment 'The annualized gross Internal Rate of Return (IRR) for the fund over the measurement period, before management fees and carried interest. Expressed as a decimal (e.g., 0.1250 = 12.50%). Core metric for ILPA and SEC reporting.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leverageRatio rdf:type rdf:Property ;
    rdfs:label 'Leverage Ratio' ;
    rdfs:comment 'The fund\'s leverage ratio as of the period end date, typically expressed as total debt divided by GAV (Loan-to-Value / LTV). Monitors compliance with fund-level debt covenants and risk parameters.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mwr rdf:type rdf:Property ;
    rdfs:label 'Mwr' ;
    rdfs:comment 'Money-Weighted Return (MWR) for the measurement period, reflecting the actual investor experience including the timing and magnitude of capital calls and distributions. Equivalent to the period IRR from the investor\'s perspective.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:navMethodology rdf:type rdf:Property ;
    rdfs:label 'Nav Methodology' ;
    rdfs:comment 'The methodology used to determine the NAV for this period. \'independent_appraisal\' uses third-party Appraisal Institute-certified appraisers; \'internal_valuation\' uses Argus Enterprise DCF models; \'broker_opinion\' uses Broker Price Opinion (BPO); \'automated_valuation\' uses AVM models; \'hybrid\' combines methods.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:navPerUnit rdf:type rdf:Property ;
    rdfs:label 'Nav Per Unit' ;
    rdfs:comment 'NAV divided by total units or shares outstanding as of the period end date. The per-unit pricing basis for investor subscriptions, redemptions, and REIT share pricing.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netIrr rdf:type rdf:Property ;
    rdfs:label 'Net Irr' ;
    rdfs:comment 'The annualized net Internal Rate of Return (IRR) for the fund over the measurement period, after deducting management fees, carried interest, and fund expenses. Primary investor-facing performance metric.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:npv rdf:type rdf:Property ;
    rdfs:label 'Npv' ;
    rdfs:comment 'Net Present Value (NPV) of the fund\'s projected cash flows discounted at the fund\'s hurdle rate or discount rate as of the period end date. Sourced from Argus Enterprise DCF models.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:opex rdf:type rdf:Property ;
    rdfs:label 'Opex' ;
    rdfs:comment 'Total Operating Expenditure (OPEX) of the fund\'s underlying portfolio for the measurement period, including property management fees, insurance, utilities, repairs, and Common Area Maintenance (CAM) costs.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodStatus rdf:type rdf:Property ;
    rdfs:label 'Period Status' ;
    rdfs:comment 'Lifecycle state of the performance record. \'open\' indicates the period is still accumulating data; \'closed\' indicates the period is finalized; \'audited\' indicates external auditor sign-off has been received; \'restated\' indicates a prior-period correction has been applied.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumDiscountToNav rdf:type rdf:Property ;
    rdfs:label 'Premium Discount To Nav' ;
    rdfs:comment 'The percentage premium or discount at which the fund\'s market price or transaction price trades relative to its NAV per unit. Positive values indicate a premium; negative values indicate a discount. Critical for publicly traded REITs and closed-end funds.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rvpi rdf:type rdf:Property ;
    rdfs:label 'Rvpi' ;
    rdfs:comment 'Residual Value to Paid-In Capital (RVPI) ratio — the current NAV of unrealized investments divided by total paid-in capital. Measures the unrealized return component. RVPI + DPI = TVPI.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDistributions rdf:type rdf:Property ;
    rdfs:label 'Total Distributions' ;
    rdfs:comment 'Total cash distributions paid to all fund investors during the measurement period. Feeds into DPI calculation and is a key component of ILPA cash flow reporting.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLiabilities rdf:type rdf:Property ;
    rdfs:label 'Total Liabilities' ;
    rdfs:comment 'Total outstanding liabilities of the fund as of the period end date, including mortgage debt, credit facilities, accrued fees, and other obligations. NAV = GAV minus total_liabilities.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRevenue rdf:type rdf:Property ;
    rdfs:label 'Total Revenue' ;
    rdfs:comment 'Total revenue generated by the fund\'s underlying properties and investments during the measurement period, including Gross Rental Income (GRI), interest income, and other operating income. Sourced from MRI Software property accounting.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tvpi rdf:type rdf:Property ;
    rdfs:label 'Tvpi' ;
    rdfs:comment 'Total Value to Paid-In Capital (TVPI) ratio — the sum of DPI and RVPI. Represents the total value created per dollar of invested capital, combining both realized and unrealized returns.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:twr rdf:type rdf:Property ;
    rdfs:label 'Twr' ;
    rdfs:comment 'Time-Weighted Return (TWR) for the measurement period, eliminating the distorting effects of external cash flows (capital calls and distributions). The GIPS-compliant return metric for comparing fund manager performance against benchmarks.' ;
    rdfs:domain ind:FundPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitsOutstanding rdf:type rdf:Property ;
    rdfs:label 'Units Outstanding' ;
    rdfs:comment 'Total number of fund units or shares outstanding as of the period end date. Used to compute NAV per unit and to track dilution from new subscriptions or reduction from redemptions.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appraisedValue rdf:type rdf:Property ;
    rdfs:label 'Appraised Value' ;
    rdfs:comment 'Most recent third-party or internal appraised market value of the asset as of the performance period. Used for CAP rate calculation, LTV computation, and NAV/GAV reporting.' ;
    rdfs:domain ind:AssetPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashOnCashReturn rdf:type rdf:Property ;
    rdfs:label 'Cash On Cash Return' ;
    rdfs:comment 'Annual pre-tax cash flow divided by total equity invested in the asset. Expressed as a decimal. Measures the actual cash income earned on the equity invested, before considering appreciation or leverage effects.' ;
    rdfs:domain ind:AssetPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Operational system of record from which this performance record was sourced. Supports data lineage, reconciliation, and audit trail requirements. Primary sources are Argus Enterprise and Yardi Voyager.' ;
    rdfs:domain ind:AssetPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitCapRate rdf:type rdf:Property ;
    rdfs:label 'Exit Cap Rate' ;
    rdfs:comment 'Projected CAP rate applied to the terminal year NOI to calculate the asset\'s residual/terminal value at the end of the hold period. Expressed as a decimal. Key assumption in DCF terminal value calculation.' ;
    rdfs:domain ind:AssetPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Hold Period Years' ;
    rdfs:comment 'Projected investment hold period in years as modeled in the DCF analysis. Determines the time horizon over which cash flows are projected and the terminal value is calculated.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leveredIrr rdf:type rdf:Property ;
    rdfs:label 'Levered Irr' ;
    rdfs:comment 'Internal Rate of Return calculated on the asset\'s equity cash flows after accounting for debt financing. Expressed as a decimal. Reflects the return to equity investors after leverage effects.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingExpenses rdf:type rdf:Property ;
    rdfs:label 'Operating Expenses' ;
    rdfs:comment 'Total property-level operating expenditures for the period including property management fees, insurance, taxes, utilities, repairs, and CAM costs. Excludes debt service and capital expenditures.' ;
    rdfs:domain ind:AssetPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:opexPsf rdf:type rdf:Property ;
    rdfs:label 'Opex Psf' ;
    rdfs:comment 'Total operating expenses divided by the property\'s net leasable area in square feet. Expressed as currency per square foot (PSF). Enables cross-property benchmarking of operating efficiency.' ;
    rdfs:domain ind:AssetPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performancePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Performance Period End Date' ;
    rdfs:comment 'Last day of the reporting period for which this asset performance record is calculated. Together with performance_period_start_date defines the measurement window.' ;
    rdfs:domain ind:AssetPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performancePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Performance Period Start Date' ;
    rdfs:comment 'First day of the reporting period for which this asset performance record is calculated. Used to define the measurement window for NOI, EGI, occupancy, and other period-level metrics.' ;
    rdfs:domain ind:AssetPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceStatus rdf:type rdf:Property ;
    rdfs:label 'Performance Status' ;
    rdfs:comment 'Current lifecycle state of this asset performance record. Draft indicates in-progress calculation; preliminary is unaudited; final is approved; restated reflects post-close corrections; archived is superseded.' ;
    rdfs:domain ind:AssetPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectedNoiGrowthRate rdf:type rdf:Property ;
    rdfs:label 'Projected Noi Growth Rate' ;
    rdfs:comment 'Annual NOI growth rate assumption applied in the DCF model for projecting future cash flows. Expressed as a decimal (e.g., 0.0300 = 3.00%). Reflects rent escalation, occupancy improvement, and expense management assumptions.' ;
    rdfs:domain ind:AssetPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenuePsf rdf:type rdf:Property ;
    rdfs:label 'Revenue Psf' ;
    rdfs:comment 'Effective gross income divided by the property\'s net leasable area in square feet. Expressed as currency per square foot (PSF). Benchmarks revenue productivity across the portfolio.' ;
    rdfs:domain ind:AssetPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sensitivityScenario rdf:type rdf:Property ;
    rdfs:label 'Sensitivity Scenario' ;
    rdfs:comment 'DCF sensitivity scenario label for this performance record. Base is the primary underwriting case; upside reflects optimistic assumptions; downside reflects conservative assumptions; stress reflects severe adverse conditions.' ;
    rdfs:domain ind:AssetPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalValue rdf:type rdf:Property ;
    rdfs:label 'Terminal Value' ;
    rdfs:comment 'Projected residual value of the asset at the end of the DCF hold period, calculated as terminal year NOI divided by exit CAP rate. Represents the expected sale proceeds at disposition.' ;
    rdfs:domain ind:AssetPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalReturn rdf:type rdf:Property ;
    rdfs:label 'Total Return' ;
    rdfs:comment 'Total investment return for the period combining income return (NOI yield) and capital appreciation return. Expressed as a decimal. NCREIF-standard metric for benchmarking against property indices.' ;
    rdfs:domain ind:AssetPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unleveredIrr rdf:type rdf:Property ;
    rdfs:label 'Unlevered Irr' ;
    rdfs:comment 'Internal Rate of Return calculated on the asset\'s cash flows before debt financing (unlevered/all-equity basis). Expressed as a decimal. Measures the intrinsic return of the asset independent of capital structure.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vacancyCreditLoss rdf:type rdf:Property ;
    rdfs:label 'Vacancy Credit Loss' ;
    rdfs:comment 'Deduction from PGI representing income lost due to vacant units and uncollectable rents during the period. Used to derive EGI from PGI.' ;
    rdfs:domain ind:AssetPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wale rdf:type rdf:Property ;
    rdfs:label 'Wale' ;
    rdfs:comment 'Weighted average date on which leases across the asset expire, weighted by rental income or NLA. Expressed as a date. Indicates the point in time when the portfolio faces significant re-leasing risk.' ;
    rdfs:domain ind:AssetPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:walt rdf:type rdf:Property ;
    rdfs:label 'Walt' ;
    rdfs:comment 'Weighted average remaining lease term across all occupied tenants, weighted by rental income or NLA. Expressed in years. Measures lease duration risk and income security of the asset.' ;
    rdfs:domain ind:AssetPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Commitment Amount' ;
    rdfs:comment 'Maximum principal amount committed by the lender under this facility. For revolving or construction facilities, this is the total available commitment, not the drawn balance.' ;
    rdfs:domain ind:DebtFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:covenantComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Covenant Compliance Status' ;
    rdfs:comment 'Current compliance status of all financial covenants on this facility. Drives lender notification workflows, waiver requests, and regulatory disclosures.' ;
    rdfs:domain ind:DebtFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:covenantDscrThreshold rdf:type rdf:Property ;
    rdfs:label 'Covenant Dscr Threshold' ;
    rdfs:comment 'Minimum DSCR required under the loan covenant, expressed as a decimal (e.g., 1.20). Breach triggers lender notification, cash trap, or default provisions.' ;
    rdfs:domain ind:DebtFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:covenantLtvThreshold rdf:type rdf:Property ;
    rdfs:label 'Covenant Ltv Threshold' ;
    rdfs:comment 'Maximum LTV ratio permitted under the loan covenant, expressed as a decimal (e.g., 0.75 for 75%). Breach triggers lender notification and potential cure obligations.' ;
    rdfs:domain ind:DebtFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:covenantMeasurementFrequency rdf:type rdf:Property ;
    rdfs:label 'Covenant Measurement Frequency' ;
    rdfs:comment 'Frequency at which financial covenants (LTV, DSCR, occupancy) are tested and reported to the lender.' ;
    rdfs:domain ind:DebtFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:covenantOccupancyThreshold rdf:type rdf:Property ;
    rdfs:label 'Covenant Occupancy Threshold' ;
    rdfs:comment 'Minimum physical occupancy rate required under the loan covenant, expressed as a decimal (e.g., 0.85 for 85%). Measured against GLA or NLA depending on loan agreement.' ;
    rdfs:domain ind:DebtFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extensionOptionsCount rdf:type rdf:Property ;
    rdfs:label 'Extension Options Count' ;
    rdfs:comment 'Number of extension options available to the borrower to extend the maturity date, subject to conditions (e.g., no event of default, minimum DSCR). Common in bridge and construction loans.' ;
    rdfs:domain ind:DebtFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:extensionPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Extension Period Months' ;
    rdfs:comment 'Duration in months of each extension option. Multiplied by extension_options_count to determine maximum extended term.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilityName rdf:type rdf:Property ;
    rdfs:label 'Facility Name' ;
    rdfs:comment 'Descriptive business name for the debt facility (e.g., \'One Market Plaza Senior Mortgage\', \'Portfolio Bridge Facility 2024\'). Used for identification in reporting and dashboards.' ;
    rdfs:domain ind:DebtFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityNumber rdf:type rdf:Property ;
    rdfs:label 'Facility Number' ;
    rdfs:comment 'Externally-known loan or facility reference number assigned by the lender or originating system. Used for lender correspondence, CMBS reporting, and covenant tracking.' ;
    rdfs:domain ind:DebtFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityStatus rdf:type rdf:Property ;
    rdfs:label 'Facility Status' ;
    rdfs:comment 'Current lifecycle status of the debt facility. Drives covenant monitoring workflows, reporting inclusion, and asset management alerts.' ;
    rdfs:domain ind:DebtFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Classification of the debt instrument by structure and purpose. [ENUM-REF-CANDIDATE: mortgage_loan|construction_loan|bridge_loan|mezzanine_debt|credit_facility|cmbs|rmbs — promote to reference product]' ;
    rdfs:domain ind:DebtFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestRateType rdf:type rdf:Property ;
    rdfs:label 'Interest Rate Type' ;
    rdfs:comment 'Indicates whether the interest rate is fixed for the loan term, floating (variable based on a benchmark index), or hybrid (fixed converting to floating or vice versa).' ;
    rdfs:domain ind:DebtFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ioPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Io Period Months' ;
    rdfs:comment 'Number of months from origination during which only interest payments are required, with no principal amortization. Common in bridge loans and construction facilities.' ;
    rdfs:domain ind:DebtFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isCrossCollateralized rdf:type rdf:Property ;
    rdfs:label 'Is Cross Collateralized' ;
    rdfs:comment 'Indicates whether this facility is secured by multiple properties under a cross-collateralization agreement. True for portfolio loans; False for single-asset facilities.' ;
    rdfs:domain ind:DebtFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCrossDefaulted rdf:type rdf:Property ;
    rdfs:label 'Is Cross Defaulted' ;
    rdfs:comment 'Indicates whether a default on this facility triggers a default on other debt facilities under a cross-default provision. Critical for portfolio risk management.' ;
    rdfs:domain ind:DebtFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCovenantTestDate rdf:type rdf:Property ;
    rdfs:label 'Last Covenant Test Date' ;
    rdfs:comment 'Date on which the most recent covenant compliance measurement was performed. Used to determine when the next test is due.' ;
    rdfs:domain ind:DebtFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lenderNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Lender Notification Required' ;
    rdfs:comment 'Indicates whether the current covenant compliance status requires formal written notification to the lender per the loan agreement terms.' ;
    rdfs:domain ind:Investment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prepaymentType rdf:type rdf:Property ;
    rdfs:label 'Prepayment Type' ;
    rdfs:comment 'Type of prepayment restriction or penalty applicable to this facility: lockout (no prepayment allowed), yield maintenance, defeasance, step-down penalty, or none.' ;
    rdfs:domain ind:DebtFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seniorityTier rdf:type rdf:Property ;
    rdfs:label 'Seniority Tier' ;
    rdfs:comment 'Capital stack position of this debt facility relative to other obligations on the same collateral. Determines priority of repayment in liquidation or refinancing scenarios.' ;
    rdfs:domain ind:DebtFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unfundedCommitment rdf:type rdf:Property ;
    rdfs:label 'Unfunded Commitment' ;
    rdfs:comment 'Portion of the total commitment not yet drawn by the borrower. Relevant for construction loans, credit facilities, and revolving debt structures.' ;
    rdfs:domain ind:DebtFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debtCovenantId rdf:type rdf:Property ;
    rdfs:label 'Debt Covenant Id' ;
    rdfs:comment 'Unique system-generated identifier for each debt covenant record tracked across the real estate debt portfolio.' ;
    rdfs:domain ind:DebtCovenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breachDate rdf:type rdf:Property ;
    rdfs:label 'Breach Date' ;
    rdfs:comment 'The date on which a covenant breach was first identified. Populated when compliance_status transitions to \'breach\'. Used to calculate cure deadlines and trigger lender notification workflows.' ;
    rdfs:domain ind:DebtCovenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calculationMethodology rdf:type rdf:Property ;
    rdfs:label 'Calculation Methodology' ;
    rdfs:comment 'Narrative description of the specific calculation methodology for the covenant metric as defined in the loan agreement, including any agreed adjustments, exclusions, or definitions (e.g., how NOI is defined for DSCR purposes, whether straight-line rent is included).' ;
    rdfs:domain ind:DebtCovenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:covenantDescription rdf:type rdf:Property ;
    rdfs:label 'Covenant Description' ;
    rdfs:comment 'Full narrative description of the covenant terms and conditions as extracted from the loan agreement, including any qualifications, exclusions, or special calculation methodologies.' ;
    rdfs:domain ind:DebtCovenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:covenantMetric rdf:type rdf:Property ;
    rdfs:label 'Covenant Metric' ;
    rdfs:comment 'The specific financial or operational metric being tested by this covenant, such as Loan-to-Value Ratio (LTV), Debt Service Coverage Ratio (DSCR), occupancy rate, Net Operating Income (NOI), debt yield, Interest Coverage Ratio (ICR), Funds From Operations (FFO), Adjusted Funds From Operations (AFFO), or Net Asset Value (NAV). [ENUM-REF-CANDIDATE: LTV|DSCR|occupancy_rate|NOI|debt_yield|ICR|FFO|AFFO|NAV|other — promote to reference product]' ;
    rdfs:domain ind:DebtCovenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:covenantName rdf:type rdf:Property ;
    rdfs:label 'Covenant Name' ;
    rdfs:comment 'Human-readable name or short description of the covenant as defined in the loan agreement (e.g., \'Minimum DSCR Test\', \'Maximum LTV Covenant\', \'Minimum Occupancy Requirement\').' ;
    rdfs:domain ind:DebtCovenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:covenantReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Covenant Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for this covenant as referenced in the loan agreement or credit facility documentation. Used for lender correspondence and audit trail.' ;
    rdfs:domain ind:DebtCovenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:covenantScope rdf:type rdf:Property ;
    rdfs:label 'Covenant Scope' ;
    rdfs:comment 'Defines the level at which the covenant is tested: asset_level (single property), portfolio_level (pool of properties), entity_level (borrowing SPV or LLC), or fund_level (entire investment fund or REIT).' ;
    rdfs:domain ind:DebtCovenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:covenantType rdf:type rdf:Property ;
    rdfs:label 'Covenant Type' ;
    rdfs:comment 'High-level classification of the covenant: financial (ratio-based tests), operational (occupancy, NOI), reporting (information delivery obligations), maintenance (ongoing compliance tests), or incurrence (triggered by specific actions). [ENUM-REF-CANDIDATE: financial|operational|reporting|maintenance|incurrence — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:DebtCovenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCrossDefault rdf:type rdf:Property ;
    rdfs:label 'Is Cross Default' ;
    rdfs:comment 'Indicates whether a breach of this covenant triggers a cross-default event under other debt facilities of the same borrower or related entities. Critical for portfolio-level risk management.' ;
    rdfs:domain ind:DebtCovenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFinancialCovenant rdf:type rdf:Property ;
    rdfs:label 'Is Financial Covenant' ;
    rdfs:comment 'Indicates whether this covenant is classified as a financial covenant under FASB ASC 470 or IFRS 9, which may require reclassification of the associated debt from long-term to current liabilities upon breach.' ;
    rdfs:domain ind:DebtCovenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMeasuredValue rdf:type rdf:Property ;
    rdfs:label 'Last Measured Value' ;
    rdfs:comment 'The most recently calculated or reported value of the covenant metric as of the last measurement date. Compared against threshold_value to determine compliance_status.' ;
    rdfs:domain ind:DebtCovenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastMeasurementDate rdf:type rdf:Property ;
    rdfs:label 'Last Measurement Date' ;
    rdfs:comment 'The date on which the covenant metric was most recently calculated and tested against the threshold. Used to determine when the next measurement is due.' ;
    rdfs:domain ind:DebtCovenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lenderNotificationDays rdf:type rdf:Property ;
    rdfs:label 'Lender Notification Days' ;
    rdfs:comment 'Number of calendar days within which the borrower must notify the lender following a covenant breach, as specified in the loan agreement. Applicable only when lender_notification_required is True.' ;
    rdfs:domain ind:DebtCovenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementFrequency rdf:type rdf:Property ;
    rdfs:label 'Measurement Frequency' ;
    rdfs:comment 'How often the covenant metric must be calculated and reported to the lender: monthly, quarterly, semi-annual, annual, or on-demand (triggered by specific events such as a new acquisition or disposition).' ;
    rdfs:domain ind:DebtCovenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriodType rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Type' ;
    rdfs:comment 'The look-back or calculation period used when computing the covenant metric: trailing 12 months (T12), trailing 3 months annualized, point-in-time (balance sheet date), or annualized from a shorter period.' ;
    rdfs:domain ind:DebtCovenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMeasurementDate rdf:type rdf:Property ;
    rdfs:label 'Next Measurement Date' ;
    rdfs:comment 'The scheduled date for the next covenant measurement and compliance test. Derived from last_measurement_date and measurement_frequency but stored explicitly to support proactive monitoring workflows.' ;
    rdfs:domain ind:DebtCovenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationSentDate rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Date' ;
    rdfs:comment 'The date on which the formal breach notification was dispatched to the lender. Used to evidence compliance with contractual notification obligations and support audit requirements.' ;
    rdfs:domain ind:DebtCovenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingDueDays rdf:type rdf:Property ;
    rdfs:label 'Reporting Due Days' ;
    rdfs:comment 'Number of days after the measurement period end date by which the compliance certificate or reporting package must be delivered to the lender. Applicable when reporting_package_required is True.' ;
    rdfs:domain ind:DebtCovenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingPackageRequired rdf:type rdf:Property ;
    rdfs:label 'Reporting Package Required' ;
    rdfs:comment 'Indicates whether the lender requires a formal compliance certificate or reporting package (e.g., rent roll, financial statements, occupancy report) to be submitted alongside each covenant measurement.' ;
    rdfs:domain ind:DebtCovenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thresholdDirection rdf:type rdf:Property ;
    rdfs:label 'Threshold Direction' ;
    rdfs:comment 'Indicates whether the covenant requires the metric to be at or above a minimum (e.g., minimum DSCR of 1.25x) or at or below a maximum (e.g., maximum LTV of 75%). Determines the breach logic for compliance monitoring.' ;
    rdfs:domain ind:DebtCovenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Threshold Unit' ;
    rdfs:comment 'Unit of measure for the threshold value: ratio (e.g., LTV expressed as 0.75), percentage (e.g., occupancy rate as 85%), currency (e.g., minimum NOI in USD), or times (e.g., DSCR expressed as 1.25x).' ;
    rdfs:domain ind:DebtCovenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdValue rdf:type rdf:Property ;
    rdfs:label 'Threshold Value' ;
    rdfs:comment 'The contractually defined threshold or limit for the covenant metric. For ratio-based covenants (LTV, DSCR), this is expressed as a decimal (e.g., 0.75 for 75% LTV). For monetary covenants (minimum NOI), this is expressed in the applicable currency.' ;
    rdfs:domain ind:DebtCovenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Date' ;
    rdfs:comment 'The date on which the lender formally granted a waiver for a covenant breach. Populated only when compliance_status is \'waiver\'.' ;
    rdfs:domain ind:DebtCovenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Expiry Date' ;
    rdfs:comment 'The date on which a lender-granted waiver expires. After this date, the covenant reverts to its standard compliance testing regime. Null if the waiver is permanent.' ;
    rdfs:domain ind:DebtCovenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:watchListThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Watch List Threshold Value' ;
    rdfs:comment 'An internal early-warning threshold set by the asset management team, typically more conservative than the contractual threshold_value. When last_measured_value approaches this level, the covenant is flagged as \'watch_list\' to trigger proactive remediation.' ;
    rdfs:domain ind:DebtCovenant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:askingPrice rdf:type rdf:Property ;
    rdfs:label 'Asking Price' ;
    rdfs:comment 'Seller\'s listed or quoted price for the asset in the deal currency. Represents the gross consideration requested before negotiation. Used as the baseline for underwriting and bid strategy.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractDate rdf:type rdf:Property ;
    rdfs:label 'Contract Date' ;
    rdfs:comment 'Date the Purchase and Sale Agreement (PSA) or equivalent binding contract was fully executed. Marks the transition to \'under_contract\' stage. Triggers due diligence period and deposit obligations.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractedPrice rdf:type rdf:Property ;
    rdfs:label 'Contracted Price' ;
    rdfs:comment 'Agreed purchase/sale price as executed in the Purchase and Sale Agreement (PSA) or equivalent binding contract. Populated once the deal reaches \'under_contract\' stage. May differ from asking price and underwritten value.' ;
    rdfs:domain ind:InvestmentDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealCode rdf:type rdf:Property ;
    rdfs:label 'Deal Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the deal across systems (e.g., Salesforce CRM, Argus Enterprise, MRI Software). Follows the format FUND-YEAR-SEQ (e.g., \'REIT-2024-0042\').' ;
    rdfs:domain ind:InvestmentDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealStatus rdf:type rdf:Property ;
    rdfs:label 'Deal Status' ;
    rdfs:comment 'Operational status of the deal record, distinct from deal_stage. Indicates whether the deal is actively being pursued (active), paused (on_hold), IC-approved (approved), IC-rejected (rejected), withdrawn by counterparty (withdrawn), or fully closed (closed).' ;
    rdfs:domain ind:InvestmentDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icApprovingMembers rdf:type rdf:Property ;
    rdfs:label 'Ic Approving Members' ;
    rdfs:comment 'Comma-separated list of IC member names or IDs who voted to approve the deal. Captured for governance audit trail and SOX compliance. Stored as a structured string; full member details reside in the workforce domain.' ;
    rdfs:domain ind:InvestmentDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icConditionsOfApproval rdf:type rdf:Property ;
    rdfs:label 'Ic Conditions Of Approval' ;
    rdfs:comment 'Free-text description of any conditions, covenants, or requirements attached to the IC\'s conditional approval (e.g., \'Subject to satisfactory Phase I ESG environmental review\', \'Requires lender commitment letter at ≤65% LTV\'). Null if unconditional approval or not yet decided.' ;
    rdfs:domain ind:InvestmentDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icDecision rdf:type rdf:Property ;
    rdfs:label 'Ic Decision' ;
    rdfs:comment 'Formal decision rendered by the Investment Committee (IC): approved (unconditional go-ahead), rejected (deal declined), conditional_approval (approved subject to conditions), deferred (decision postponed pending additional information), withdrawn (deal pulled before IC vote).' ;
    rdfs:domain ind:InvestmentDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Ic Decision Date' ;
    rdfs:comment 'Date the Investment Committee (IC) rendered its formal decision (approve, reject, or conditional approval) on the deal. Essential for IC governance audit trail and regulatory compliance.' ;
    rdfs:domain ind:InvestmentDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:icKeyRisks rdf:type rdf:Property ;
    rdfs:label 'Ic Key Risks' ;
    rdfs:comment 'Free-text summary of key investment risks identified in the IC memo (e.g., lease rollover risk, market vacancy trends, environmental exposure, construction cost overruns). Supports IC governance documentation and post-investment risk monitoring.' ;
    rdfs:domain ind:InvestmentDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icRecommendation rdf:type rdf:Property ;
    rdfs:label 'Ic Recommendation' ;
    rdfs:comment 'AM team\'s formal recommendation to the IC as stated in the IC memo: recommend (team supports proceeding), do_not_recommend (team advises against), conditional_recommend (team supports subject to conditions). Distinct from the IC\'s actual decision.' ;
    rdfs:domain ind:InvestmentDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Ic Submission Date' ;
    rdfs:comment 'Date the IC memo was formally submitted to the Investment Committee (IC) for review. Marks the start of the IC governance process. Critical for IC audit trail and governance compliance.' ;
    rdfs:domain ind:InvestmentDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isOffMarket rdf:type rdf:Property ;
    rdfs:label 'Is Off Market' ;
    rdfs:comment 'Indicates whether the deal was sourced through proprietary off-market channels (True) rather than publicly marketed processes such as MLS, broker campaigns, or auctions (False). Key metric for sourcing strategy and competitive advantage analytics.' ;
    rdfs:domain ind:InvestmentDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourcedDate rdf:type rdf:Property ;
    rdfs:label 'Sourced Date' ;
    rdfs:comment 'Date the investment opportunity was first identified and entered into the deal pipeline. Represents the business event timestamp for deal origination. Used to measure pipeline velocity and sourcing lead times.' ;
    rdfs:domain ind:InvestmentDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:underwrittenDebtAmount rdf:type rdf:Property ;
    rdfs:label 'Underwritten Debt Amount' ;
    rdfs:comment 'Total debt financing assumed in the underwriting model for this deal. Represents the debt portion of the capital stack. Used to calculate Loan-to-Value Ratio (LTV) and Debt Service Coverage Ratio (DSCR) in IC analysis.' ;
    rdfs:domain ind:InvestmentDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:underwrittenEquityAmount rdf:type rdf:Property ;
    rdfs:label 'Underwritten Equity Amount' ;
    rdfs:comment 'Total equity capital required for the deal as underwritten in the IC memo. Represents the equity portion of the capital stack (total deal cost minus debt). Drives capital call planning and fund commitment tracking.' ;
    rdfs:domain ind:InvestmentDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:underwrittenLtv rdf:type rdf:Property ;
    rdfs:label 'Underwritten Ltv' ;
    rdfs:comment 'Underwritten Loan-to-Value Ratio (LTV) expressed as a decimal (e.g., 0.6500 = 65%). Calculated as underwritten debt divided by underwritten value. Key leverage metric reviewed by the IC and lenders.' ;
    rdfs:domain ind:InvestmentDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:underwrittenNoi rdf:type rdf:Property ;
    rdfs:label 'Underwritten Noi' ;
    rdfs:comment 'Stabilized Net Operating Income (NOI) as projected in the underwriting model. Represents effective gross income minus operating expenses, excluding debt service and capital expenditures. Foundation of CAP rate and DCF valuation.' ;
    rdfs:domain ind:InvestmentDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:underwrittenValue rdf:type rdf:Property ;
    rdfs:label 'Underwritten Value' ;
    rdfs:comment 'Internal valuation of the asset as determined by the Asset Manager\'s (AM) underwriting model (typically a Discounted Cash Flow (DCF) or direct capitalization approach in Argus Enterprise). Represents the AM\'s view of intrinsic value, distinct from asking price.' ;
    rdfs:domain ind:InvestmentDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocatedIncomeLoss rdf:type rdf:Property ;
    rdfs:label 'Allocated Income Loss' ;
    rdfs:comment 'Net income or loss allocated to this investor\'s capital account during the period per the fund\'s partnership agreement waterfall and allocation methodology. Positive values represent income allocation; negative values represent loss allocation.' ;
    rdfs:domain ind:CapitalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beginningCapitalBalance rdf:type rdf:Property ;
    rdfs:label 'Beginning Capital Balance' ;
    rdfs:comment 'Investor\'s capital account balance at the start of the statement period, equal to the ending balance of the immediately preceding period. Serves as the opening balance for the period\'s capital account roll-forward reconciliation.' ;
    rdfs:domain ind:CapitalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalContributions rdf:type rdf:Property ;
    rdfs:label 'Capital Contributions' ;
    rdfs:comment 'Total capital contributed by the investor during the statement period in response to capital calls. Includes funded amounts from all capital calls settled within the period. Increases the capital account balance.' ;
    rdfs:domain ind:CapitalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalDistributions rdf:type rdf:Property ;
    rdfs:label 'Capital Distributions' ;
    rdfs:comment 'Total distributions returned to the investor during the statement period, including return of capital, realized gains, and income distributions. Decreases the capital account balance. Reported as a positive number representing cash out to the investor.' ;
    rdfs:domain ind:CapitalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carriedInterestAllocated rdf:type rdf:Property ;
    rdfs:label 'Carried Interest Allocated' ;
    rdfs:comment 'Performance-based carried interest (carry) allocated to the general partner and charged against this investor\'s capital account during the period, per the fund\'s waterfall provisions. Typically triggered after the preferred return hurdle is met.' ;
    rdfs:domain ind:CapitalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeContributions rdf:type rdf:Property ;
    rdfs:label 'Cumulative Contributions' ;
    rdfs:comment 'Total capital contributed by the investor from fund inception through the end of the statement period. Used for IRR calculation, return-of-capital tracking, and ILPA transparency reporting.' ;
    rdfs:domain ind:CapitalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeDistributions rdf:type rdf:Property ;
    rdfs:label 'Cumulative Distributions' ;
    rdfs:comment 'Total distributions returned to the investor from fund inception through the end of the statement period. Used for DPI (Distributions to Paid-In) multiple calculation and ILPA transparency reporting.' ;
    rdfs:domain ind:CapitalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endingCapitalBalance rdf:type rdf:Property ;
    rdfs:label 'Ending Capital Balance' ;
    rdfs:comment 'Investor\'s capital account balance at the close of the statement period. Calculated as: beginning_capital_balance + capital_contributions - capital_distributions + allocated_income_loss - management_fees_charged - carried_interest_allocated - other_fees_charged. This is the SSOT for the investor\'s fund position at period end.' ;
    rdfs:domain ind:CapitalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inceptionToDateIrr rdf:type rdf:Property ;
    rdfs:label 'Inception To Date Irr' ;
    rdfs:comment 'Cumulative Internal Rate of Return (IRR) for this investor\'s capital account from fund inception through the statement period end date, expressed as a decimal (e.g., 0.142500 = 14.25%). Calculated using the XIRR methodology on all cash flows. Primary performance metric for LP reporting.' ;
    rdfs:domain ind:CapitalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isTaxExemptInvestor rdf:type rdf:Property ;
    rdfs:label 'Is Tax Exempt Investor' ;
    rdfs:comment 'Indicates whether the investor is a tax-exempt entity (e.g., pension fund, endowment, foundation, ERISA plan) for purposes of UBTI (Unrelated Business Taxable Income) tracking and tax reporting. True = tax-exempt; False = taxable investor.' ;
    rdfs:domain ind:CapitalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:managementFeesCharged rdf:type rdf:Property ;
    rdfs:label 'Management Fees Charged' ;
    rdfs:comment 'Asset management fees charged to this investor\'s capital account during the period, calculated per the fund\'s management fee schedule (typically expressed as a percentage of committed or invested capital). Reduces the capital account balance.' ;
    rdfs:domain ind:CapitalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moic rdf:type rdf:Property ;
    rdfs:label 'Moic' ;
    rdfs:comment 'Multiple on Invested Capital (MOIC) for this investor from inception through the statement period end date. Calculated as (ending_capital_balance + cumulative_distributions) / cumulative_contributions. Measures total value creation relative to invested capital.' ;
    rdfs:domain ind:CapitalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredReturnAccrued rdf:type rdf:Property ;
    rdfs:label 'Preferred Return Accrued' ;
    rdfs:comment 'Cumulative preferred return accrued but not yet distributed to the investor from fund inception through the statement period end date. Represents the outstanding preferred return obligation owed to the LP before carried interest can be earned.' ;
    rdfs:domain ind:CapitalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:realizedGainLoss rdf:type rdf:Property ;
    rdfs:label 'Realized Gain Loss' ;
    rdfs:comment 'Investor\'s pro-rata share of realized gains or losses from asset dispositions completed during the statement period. Represents the difference between net sale proceeds and cost basis allocated to this investor.' ;
    rdfs:domain ind:CapitalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statementIssueDate rdf:type rdf:Property ;
    rdfs:label 'Statement Issue Date' ;
    rdfs:comment 'Calendar date on which this capital account statement was formally issued and made available to the investor. Used for ILPA compliance tracking and investor communication audit trails.' ;
    rdfs:domain ind:CapitalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Statement Period End Date' ;
    rdfs:comment 'Last calendar date of the reporting period covered by this capital account statement (e.g., 2024-03-31 for Q1 2024). Defines the end of the measurement window and the valuation date for ending balance calculations.' ;
    rdfs:domain ind:CapitalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Statement Period Start Date' ;
    rdfs:comment 'First calendar date of the reporting period covered by this capital account statement (e.g., 2024-01-01 for Q1 2024). Defines the beginning of the measurement window for all period activity fields.' ;
    rdfs:domain ind:CapitalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxBasisAdjustment rdf:type rdf:Property ;
    rdfs:label 'Tax Basis Adjustment' ;
    rdfs:comment 'Cumulative tax basis adjustment to the investor\'s capital account from inception through the statement period end date, reflecting differences between GAAP book basis and tax basis (e.g., depreciation timing differences, Section 754 elections). Supports K-1 preparation.' ;
    rdfs:domain ind:CapitalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorAppraisalId rdf:type rdf:Property ;
    rdfs:label 'Prior Appraisal Id' ;
    rdfs:comment 'Self-referencing identifier linking this appraisal to the most recent prior appraisal for the same property. Enables appraisal history tracking, value trend analysis, and year-over-year valuation movement reporting.' ;
    rdfs:domain ind:Appraisal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Appraisal .

ind:appraisalStatus rdf:type rdf:Property ;
    rdfs:label 'Appraisal Status' ;
    rdfs:comment 'Current lifecycle state of the appraisal engagement. Tracks progression from initial order through field work, internal review, and final delivery or rejection. Supports SLA monitoring and workflow management in Yardi Voyager and Argus Enterprise.' ;
    rdfs:domain ind:Appraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appraisalType rdf:type rdf:Property ;
    rdfs:label 'Appraisal Type' ;
    rdfs:comment 'Classification of the appraisal scope and inspection methodology. Full appraisals involve complete interior/exterior inspection; limited, desktop, and drive-by involve reduced scope. Retrospective appraisals value a property as of a historical date. [ENUM-REF-CANDIDATE: full|limited|desktop|drive-by|retrospective|automated — promote to reference product]' ;
    rdfs:domain ind:Appraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appraiserCredential rdf:type rdf:Property ;
    rdfs:label 'Appraiser Credential' ;
    rdfs:comment 'Professional designation held by the assigned appraiser at the time of the engagement. MAI and SRA are Appraisal Institute designations for commercial and residential specialists respectively. AI-GRS and AI-RRS are review designations. MRICS is the Royal Institution of Chartered Surveyors designation. Required for USPAP and IVSC compliance.' ;
    rdfs:domain ind:Appraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appraiserLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Appraiser License Number' ;
    rdfs:comment 'State-issued appraiser license or certification number for the assigned appraiser. Required for regulatory compliance and lender review. Confidential business record used to verify appraiser eligibility on each engagement.' ;
    rdfs:domain ind:Appraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:argusModelReference rdf:type rdf:Property ;
    rdfs:label 'Argus Model Reference' ;
    rdfs:comment 'The unique identifier of the Argus Enterprise cash flow model associated with this appraisal engagement. Enables direct traceability between the appraisal record and the underlying DCF model file for audit and replication purposes.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientReference rdf:type rdf:Property ;
    rdfs:label 'Client Reference' ;
    rdfs:comment 'The client\'s internal reference number or loan number associated with this appraisal order. Used by lenders, investment managers, or asset managers to cross-reference the appraisal with their own systems (e.g., MRI Software investment records).' ;
    rdfs:domain ind:Appraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concludedMarketValue rdf:type rdf:Property ;
    rdfs:label 'Concluded Market Value' ;
    rdfs:comment 'The appraiser\'s final concluded value opinion for the subject property as of the effective value date, expressed in the engagement currency. This is the primary output of the appraisal engagement and feeds NAV/GAV calculations, LTV ratios, and DSCR analysis.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engagementDate rdf:type rdf:Property ;
    rdfs:label 'Engagement Date' ;
    rdfs:comment 'The date the appraisal was formally ordered and the engagement letter was executed. Marks the start of the appraisal lifecycle and the SLA turnaround clock.' ;
    rdfs:domain ind:Appraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engagementFee rdf:type rdf:Property ;
    rdfs:label 'Engagement Fee' ;
    rdfs:comment 'The agreed fee payable to the appraisal firm for the engagement, in the engagement currency. Recorded for accounts payable processing in Yardi Voyager and budget tracking against the valuation OPEX budget.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engagementLetterRef rdf:type rdf:Property ;
    rdfs:label 'Engagement Letter Ref' ;
    rdfs:comment 'Document reference number or DocuSign CLM contract ID for the executed engagement letter between the client and the appraisal firm. Provides legal traceability and supports contract lifecycle management.' ;
    rdfs:domain ind:Appraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementNumber rdf:type rdf:Property ;
    rdfs:label 'Engagement Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned to the appraisal engagement at the time of ordering. Used for cross-referencing with the engagement letter, Argus Enterprise, and Yardi Voyager fixed asset records.' ;
    rdfs:domain ind:Appraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firmName rdf:type rdf:Property ;
    rdfs:label 'Firm Name' ;
    rdfs:comment 'The name of the external appraisal firm engaged to perform the appraisal. Supports vendor management, conflict-of-interest tracking, and appraiser rotation policies required by lenders and regulators.' ;
    rdfs:domain ind:Appraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdingPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Holding Period Years' ;
    rdfs:comment 'The number of years in the Discounted Cash Flow (DCF) analysis projection period. Typically 10 years for commercial real estate. Defines the time horizon over which cash flows are modeled in Argus Enterprise.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:intendedUser rdf:type rdf:Property ;
    rdfs:label 'Intended User' ;
    rdfs:comment 'The party or parties identified in the engagement letter as the intended user(s) of the appraisal report (e.g., lender name, investment committee, asset manager). USPAP requires explicit identification of intended users to define the scope of work.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irr rdf:type rdf:Property ;
    rdfs:label 'Irr' ;
    rdfs:comment 'The discount rate at which the net present value of projected cash flows equals zero, as concluded in the DCF analysis. Expressed as a decimal (e.g., 0.0850 for 8.50%). Key output metric for investment decision-making and portfolio performance benchmarking.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ivscCompliant rdf:type rdf:Property ;
    rdfs:label 'Ivsc Compliant' ;
    rdfs:comment 'Indicates whether the appraisal methodology and report comply with International Valuation Standards (IVS) as published by the IVSC. Required for cross-border investment reporting and IFRS-based financial statements.' ;
    rdfs:domain ind:Appraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:methodology rdf:type rdf:Property ;
    rdfs:label 'Methodology' ;
    rdfs:comment 'The primary valuation methodology applied in the appraisal. Sales Comparison, Income Capitalization (direct CAP rate), Cost Approach, Discounted Cash Flow (DCF), Broker Price Opinion (BPO), or Comparative Market Analysis (CMA). USPAP and IVSC require disclosure of methodology in the report.' ;
    rdfs:domain ind:Appraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purpose rdf:type rdf:Property ;
    rdfs:label 'Purpose' ;
    rdfs:comment 'The intended use of the appraisal report as stated in the engagement letter. Drives the applicable standard of value and methodology selection. Common purposes include financing (LTV/DSCR support), disposition, insurance replacement cost, tax appeal, portfolio review (NAV/GAV), and litigation support.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Report Delivery Date' ;
    rdfs:comment 'The date the completed appraisal report was delivered to the client or intended user. Used to measure SLA turnaround compliance from engagement date to delivery.' ;
    rdfs:domain ind:Appraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportType rdf:type rdf:Property ;
    rdfs:label 'Report Type' ;
    rdfs:comment 'The format of the appraisal report deliverable. URAR (Uniform Residential Appraisal Report) is the standard Fannie Mae/Freddie Mac form for residential properties. Narrative reports provide full written analysis. Restricted and Summary reports are abbreviated formats per USPAP.' ;
    rdfs:domain ind:Appraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Review Outcome' ;
    rdfs:comment 'The outcome of the internal or external appraisal review. Approved reports proceed to final use; rejected or revision-required reports are returned to the appraiser. Drives the status lifecycle transition.' ;
    rdfs:domain ind:Appraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTurnaroundDays rdf:type rdf:Property ;
    rdfs:label 'Sla Turnaround Days' ;
    rdfs:comment 'The contractually agreed maximum number of calendar days from engagement date to report delivery. Used to monitor appraiser performance and manage investment decision timelines.' ;
    rdfs:domain ind:Appraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:terminalCapRate rdf:type rdf:Property ;
    rdfs:label 'Terminal Cap Rate' ;
    rdfs:comment 'The reversion or terminal capitalization rate applied to the projected NOI at the end of the DCF holding period to estimate the residual/reversion value. Expressed as a decimal. Standard Argus Enterprise DCF model parameter.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uspapCompliant rdf:type rdf:Property ;
    rdfs:label 'Uspap Compliant' ;
    rdfs:comment 'Indicates whether the appraisal was performed in compliance with the Uniform Standards of Professional Appraisal Practice (USPAP) as promulgated by The Appraisal Foundation. Required for federally related transactions under FIRREA.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:valueRangeHigh rdf:type rdf:Property ;
    rdfs:label 'Value Range High' ;
    rdfs:comment 'The upper bound of the appraiser\'s value range opinion when a range rather than a point estimate is concluded. Used alongside value_range_low for sensitivity analysis and investment committee reporting.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valueRangeLow rdf:type rdf:Property ;
    rdfs:label 'Value Range Low' ;
    rdfs:comment 'The lower bound of the appraiser\'s value range opinion when a range rather than a point estimate is concluded. Used in portfolio stress testing and sensitivity analysis in Argus Enterprise.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valueType rdf:type rdf:Property ;
    rdfs:label 'Value Type' ;
    rdfs:comment 'The standard of value concluded in the appraisal report. Market Value is the most common; Investment Value reflects a specific investor\'s criteria; Liquidation Value assumes a forced sale; Insurable Value is used for insurance replacement cost; Assessed Value is used for property tax purposes.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appraisalReportId rdf:type rdf:Property ;
    rdfs:label 'Appraisal Report Id' ;
    rdfs:comment 'Unique surrogate identifier for the appraisal report record in the Silver Layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:AppraisalReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approachId rdf:type rdf:Property ;
    rdfs:label 'Approach Id' ;
    rdfs:comment 'Foreign key linking to valuation.approach. Business justification: An appraisal report is the formal deliverable that summarizes the valuation approaches applied. Linking appraisal_report.approach_id to approach.approach_id allows the report to reference the specific' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Approach .

ind:dcfModelId rdf:type rdf:Property ;
    rdfs:label 'Dcf Model Id' ;
    rdfs:comment 'Foreign key linking to valuation.dcf_model. Business justification: An appraisal report may be supported by a specific DCF model (Argus Enterprise model). Linking appraisal_report.dcf_model_id to dcf_model.dcf_model_id enables direct traceability from the formal repor' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DcfModel .

ind:asIsValue rdf:type rdf:Property ;
    rdfs:label 'As Is Value' ;
    rdfs:comment 'The appraised value of the property in its current physical and economic condition as of the effective date, without consideration of any proposed improvements or stabilization. Commonly used alongside as-stabilized value for development and repositioning assets.' ;
    rdfs:domain ind:AppraisalReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:asStabilizedValue rdf:type rdf:Property ;
    rdfs:label 'As Stabilized Value' ;
    rdfs:comment 'The prospective appraised value of the property upon reaching stabilized occupancy and income levels, assuming completion of any proposed improvements. Used in development financing and investment underwriting.' ;
    rdfs:domain ind:AppraisalReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extraordinaryAssumptions rdf:type rdf:Property ;
    rdfs:label 'Extraordinary Assumptions' ;
    rdfs:comment 'Narrative description of any extraordinary assumptions made in the appraisal that, if found to be false, could alter the appraiser\'s opinions or conclusions. Required USPAP disclosure. Examples include assumed lease-up timelines or assumed environmental clearance.' ;
    rdfs:domain ind:AppraisalReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossBuildingAreaSqf rdf:type rdf:Property ;
    rdfs:label 'Gross Building Area Sqf' ;
    rdfs:comment 'The total gross building area of the subject property in square feet (SQF) as measured or verified by the appraiser. Used to calculate per-square-foot (PSF) value indicators and compare to market comparables.' ;
    rdfs:domain ind:AppraisalReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hypotheticalConditions rdf:type rdf:Property ;
    rdfs:label 'Hypothetical Conditions' ;
    rdfs:comment 'Narrative description of any hypothetical conditions applied in the appraisal that are contrary to known facts but assumed for the purpose of analysis (e.g., assuming a proposed building is complete as of the effective date). Required USPAP disclosure.' ;
    rdfs:domain ind:AppraisalReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intendedUse rdf:type rdf:Property ;
    rdfs:label 'Intended Use' ;
    rdfs:comment 'The stated purpose for which the appraisal report is intended to be used, as required by USPAP (e.g., mortgage financing, financial reporting, portfolio valuation, acquisition due diligence, estate planning, litigation support). Determines the scope of work and applicable standards.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitingConditions rdf:type rdf:Property ;
    rdfs:label 'Limiting Conditions' ;
    rdfs:comment 'Summary of the general and specific limiting conditions that govern the scope and reliance of the appraisal report. Standard USPAP certification element included in all appraisal reports.' ;
    rdfs:domain ind:AppraisalReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfComparables rdf:type rdf:Property ;
    rdfs:label 'Number Of Comparables' ;
    rdfs:comment 'The count of comparable sales transactions analyzed and used in the sales comparison approach. Provides a quality indicator for the depth of market evidence supporting the concluded value.' ;
    rdfs:domain ind:AppraisalReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportDate rdf:type rdf:Property ;
    rdfs:label 'Report Date' ;
    rdfs:comment 'The date on which the appraisal report was signed and issued by the appraiser. May differ from the effective date of value, particularly for retrospective or prospective appraisals.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportFormat rdf:type rdf:Property ;
    rdfs:label 'Report Format' ;
    rdfs:comment 'The format type of the appraisal report as defined by USPAP and Fannie Mae guidelines. URAR (Uniform Residential Appraisal Report) is standard for residential; narrative and summary formats are common for commercial CRE engagements.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportNumber rdf:type rdf:Property ;
    rdfs:label 'Report Number' ;
    rdfs:comment 'Externally-known unique alphanumeric identifier assigned to the report by the appraisal firm or internal valuation team. Used for cross-referencing with Argus Enterprise and client deliverables.' ;
    rdfs:domain ind:AppraisalReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportScenario rdf:type rdf:Property ;
    rdfs:label 'Report Scenario' ;
    rdfs:comment 'The valuation scenario represented by this report. As-Is reflects current condition; As-Stabilized assumes full occupancy; As-Complete assumes construction completion; As-Dark assumes vacant/non-operating; Prospective reflects a future date. One engagement may produce multiple scenario reports.' ;
    rdfs:domain ind:AppraisalReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportStatus rdf:type rdf:Property ;
    rdfs:label 'Report Status' ;
    rdfs:comment 'Current lifecycle state of the appraisal report workflow. Tracks progression from initial draft through internal review, approval, client issuance, and potential supersession or withdrawal.' ;
    rdfs:domain ind:AppraisalReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'The current status of the internal or external review process for this appraisal report. Tracks whether a supervisory or desk review has been initiated, completed, approved, or rejected per Appraisal Institute and USPAP Standards Rule 3.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerSignOffDate rdf:type rdf:Property ;
    rdfs:label 'Reviewer Sign Off Date' ;
    rdfs:comment 'The date on which the designated reviewer completed and approved the review of this appraisal report. Null if review is not yet completed or not required.' ;
    rdfs:domain ind:AppraisalReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:valuationApproach rdf:type rdf:Property ;
    rdfs:label 'Valuation Approach' ;
    rdfs:comment 'Primary valuation methodology applied in the report. Sales Comparison uses comparable transactions; Income Capitalization applies CAP rate to NOI; Cost approach estimates replacement cost less depreciation; DCF (Discounted Cash Flow) models future cash flows; Hybrid combines multiple approaches.' ;
    rdfs:domain ind:AppraisalReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuePsf rdf:type rdf:Property ;
    rdfs:label 'Value Psf' ;
    rdfs:comment 'The concluded market value expressed on a per-square-foot (PSF) basis, calculated as concluded market value divided by gross building area. Key benchmarking metric for CRE investment analysis and market comparison.' ;
    rdfs:domain ind:AppraisalReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:asRepairedValue rdf:type rdf:Property ;
    rdfs:label 'As Repaired Value' ;
    rdfs:comment 'The broker\'s estimated market value of the subject property assuming all identified repairs and deferred maintenance items have been completed. Used to assess post-rehabilitation value for REO and distressed asset management.' ;
    rdfs:domain ind:Bpo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:basisForOpinion rdf:type rdf:Property ;
    rdfs:label 'Basis For Opinion' ;
    rdfs:comment 'A narrative description of the primary methodological basis and evidence used by the broker to arrive at the opinion of value, including comparable sales, active listings, and market data sources.' ;
    rdfs:domain ind:Bpo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bpoNumber rdf:type rdf:Property ;
    rdfs:label 'Bpo Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned to the BPO engagement, used for tracking and communication with requesting parties and lenders.' ;
    rdfs:domain ind:Bpo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bpoStatus rdf:type rdf:Property ;
    rdfs:label 'Bpo Status' ;
    rdfs:comment 'Current workflow state of the BPO engagement lifecycle, from initial order through completion, review, and potential expiry or cancellation.' ;
    rdfs:domain ind:Bpo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bpoType rdf:type rdf:Property ;
    rdfs:label 'Bpo Type' ;
    rdfs:comment 'Classification of the BPO inspection methodology: drive-by (exterior-only observation), interior (full interior and exterior inspection), or desktop (no physical inspection; relies on MLS and public data).' ;
    rdfs:domain ind:Bpo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerCompanyName rdf:type rdf:Property ;
    rdfs:label 'Broker Company Name' ;
    rdfs:comment 'The name of the brokerage firm or company under which the preparing broker operates, as it appears on the BPO report.' ;
    rdfs:domain ind:Bpo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completedDate rdf:type rdf:Property ;
    rdfs:label 'Completed Date' ;
    rdfs:comment 'The date on which the broker submitted the completed BPO report to the requesting party.' ;
    rdfs:domain ind:Bpo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costarPropertyReference rdf:type rdf:Property ;
    rdfs:label 'Costar Property Reference' ;
    rdfs:comment 'The CoStar Suite property identifier for the subject property, enabling cross-reference to CoStar market research, comparable sales, and property analytics data.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDom rdf:type rdf:Property ;
    rdfs:label 'Estimated Dom' ;
    rdfs:comment 'The broker\'s estimate of the number of days the subject property would remain on the market before a sale at the recommended list price under current market conditions.' ;
    rdfs:domain ind:Bpo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isRushOrder rdf:type rdf:Property ;
    rdfs:label 'Is Rush Order' ;
    rdfs:comment 'Indicates whether the BPO was ordered on an expedited or rush basis, typically associated with a higher engagement fee and shorter turnaround SLA.' ;
    rdfs:domain ind:Bpo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketConditionsNarrative rdf:type rdf:Property ;
    rdfs:label 'Market Conditions Narrative' ;
    rdfs:comment 'The broker\'s qualitative description of current local market conditions, including supply/demand dynamics, absorption rates, price trends, and competitive environment influencing the subject property\'s value.' ;
    rdfs:domain ind:Bpo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketTrend rdf:type rdf:Property ;
    rdfs:label 'Market Trend' ;
    rdfs:comment 'The broker\'s assessment of the directional trend in property values in the subject market area at the time of the BPO effective date.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numComparableListings rdf:type rdf:Property ;
    rdfs:label 'Num Comparable Listings' ;
    rdfs:comment 'The count of active or pending comparable listings used as competitive market evidence in the BPO.' ;
    rdfs:domain ind:Bpo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numComparableSales rdf:type rdf:Property ;
    rdfs:label 'Num Comparable Sales' ;
    rdfs:comment 'The count of closed comparable sales transactions used as evidence in the BPO\'s sales comparison approach.' ;
    rdfs:domain ind:Bpo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:opinionValue rdf:type rdf:Property ;
    rdfs:label 'Opinion Value' ;
    rdfs:comment 'The broker\'s point-estimate opinion of the subject property\'s market value as of the effective date, expressed in the local currency (USD). This is the primary valuation output of the BPO.' ;
    rdfs:domain ind:Bpo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderedDate rdf:type rdf:Property ;
    rdfs:label 'Ordered Date' ;
    rdfs:comment 'The date on which the BPO was formally ordered or requested by the requesting party.' ;
    rdfs:domain ind:Bpo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:propertyCondition rdf:type rdf:Property ;
    rdfs:label 'Property Condition' ;
    rdfs:comment 'The broker\'s assessment of the overall physical condition of the subject property at the time of inspection, used as a key input to value adjustments.' ;
    rdfs:domain ind:Bpo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quickSaleValue rdf:type rdf:Property ;
    rdfs:label 'Quick Sale Value' ;
    rdfs:comment 'The estimated value achievable in an accelerated or distressed sale scenario (e.g., REO liquidation), typically below the as-is market value. Used by lenders for loss mitigation analysis.' ;
    rdfs:domain ind:Bpo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedListPrice rdf:type rdf:Property ;
    rdfs:label 'Recommended List Price' ;
    rdfs:comment 'The broker\'s recommended listing price for the subject property if placed on the open market, which may differ from the opinion of value based on current market absorption and competitive positioning.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repairCostEstimate rdf:type rdf:Property ;
    rdfs:label 'Repair Cost Estimate' ;
    rdfs:comment 'The broker\'s estimate of the total cost of repairs and deferred maintenance items identified during the inspection, used to bridge the as-is value to the as-repaired value.' ;
    rdfs:domain ind:Bpo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requesterReference rdf:type rdf:Property ;
    rdfs:label 'Requester Reference' ;
    rdfs:comment 'The requesting party\'s own internal reference or order number for this BPO engagement, used for cross-referencing and reconciliation with the client\'s systems.' ;
    rdfs:domain ind:Bpo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerNotes rdf:type rdf:Property ;
    rdfs:label 'Reviewer Notes' ;
    rdfs:comment 'Qualitative notes or feedback provided by the reviewing party upon quality review of the BPO, including reasons for rejection or required revisions.' ;
    rdfs:domain ind:Bpo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turnaroundSlaHours rdf:type rdf:Property ;
    rdfs:label 'Turnaround Sla Hours' ;
    rdfs:comment 'The contractually agreed turnaround time in hours from order placement to BPO delivery, as specified in the engagement agreement with the requesting party.' ;
    rdfs:domain ind:Bpo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:absorptionRate rdf:type rdf:Property ;
    rdfs:label 'Absorption Rate' ;
    rdfs:comment 'The rate at which available properties in the subject market are sold over a given period, expressed as a percentage or number of homes sold per month. A key indicator of market velocity and pricing power.' ;
    rdfs:domain ind:Cma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:activeComparableCount rdf:type rdf:Property ;
    rdfs:label 'Active Comparable Count' ;
    rdfs:comment 'Number of currently active listing comparables included in the analysis. Active listings represent current competition and establish the upper bound of buyer expectations.' ;
    rdfs:domain ind:Cma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:analysisDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Date' ;
    rdfs:comment 'The date on which the Comparative Market Analysis was conducted and the market data was assembled. This is the effective date of the analysis, not the delivery date.' ;
    rdfs:domain ind:Cma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:analystNotes rdf:type rdf:Property ;
    rdfs:label 'Analyst Notes' ;
    rdfs:comment 'Free-text narrative commentary from the broker or agent explaining the comparable selection rationale, market observations, adjustments made, and any qualifications on the concluded value range.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avgComparablePsf rdf:type rdf:Property ;
    rdfs:label 'Avg Comparable Psf' ;
    rdfs:comment 'The average sale price per square foot (PSF) across all comparable sales used in the analysis. Key metric for value benchmarking and pricing strategy validation.' ;
    rdfs:domain ind:Cma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgDaysOnMarket rdf:type rdf:Property ;
    rdfs:label 'Avg Days On Market' ;
    rdfs:comment 'Average number of days comparable sold properties were listed on the market before going under contract. Informs realistic time-to-sale expectations for the seller.' ;
    rdfs:domain ind:Cma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cmaNumber rdf:type rdf:Property ;
    rdfs:label 'Cma Number' ;
    rdfs:comment 'Externally-visible business identifier for the CMA engagement, used in client-facing reports and broker correspondence. Format: CMA-{YYYY}-{NNNNNN}.' ;
    rdfs:domain ind:Cma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmaStatus rdf:type rdf:Property ;
    rdfs:label 'Cma Status' ;
    rdfs:comment 'Current lifecycle state of the CMA record. Draft indicates work-in-progress; delivered indicates client receipt; superseded indicates a newer CMA has replaced this one for the same property.' ;
    rdfs:domain ind:Cma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comparableCount rdf:type rdf:Property ;
    rdfs:label 'Comparable Count' ;
    rdfs:comment 'Total number of comparable properties (sold, active, and pending listings) used in the analysis. A higher count generally increases the reliability of the concluded value range.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:comparableLookbackMonths rdf:type rdf:Property ;
    rdfs:label 'Comparable Lookback Months' ;
    rdfs:comment 'The number of months of historical sales data reviewed when selecting comparable sold properties. Typically 3–12 months depending on market activity and data availability.' ;
    rdfs:domain ind:Cma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:comparableSearchRadiusMiles rdf:type rdf:Property ;
    rdfs:label 'Comparable Search Radius Miles' ;
    rdfs:comment 'The geographic radius in miles used to define the comparable property search area around the subject property. Smaller radii indicate tighter, more homogeneous market areas.' ;
    rdfs:domain ind:Cma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concludedValueHigh rdf:type rdf:Property ;
    rdfs:label 'Concluded Value High' ;
    rdfs:comment 'The upper bound of the analyst\'s concluded market value range for the subject property, expressed in USD. Together with concluded_value_low, defines the recommended pricing corridor.' ;
    rdfs:domain ind:Cma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concludedValueLow rdf:type rdf:Property ;
    rdfs:label 'Concluded Value Low' ;
    rdfs:comment 'The lower bound of the analyst\'s concluded market value range for the subject property, expressed in USD. Together with concluded_value_high, defines the recommended pricing corridor for seller consultations.' ;
    rdfs:domain ind:Cma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costarReportReference rdf:type rdf:Property ;
    rdfs:label 'Costar Report Reference' ;
    rdfs:comment 'Reference identifier for the CoStar Suite market report or comparable data export used as a data source for this CMA. Supports data lineage and source traceability.' ;
    rdfs:domain ind:Cma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'The date the completed CMA report was delivered to the client or seller. May differ from analysis_date if preparation spans multiple days.' ;
    rdfs:domain ind:Cma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engagementType rdf:type rdf:Property ;
    rdfs:label 'Engagement Type' ;
    rdfs:comment 'The business purpose or context for which this CMA was prepared. Drives the analytical focus and recommended pricing strategy. [ENUM-REF-CANDIDATE: listing_price_recommendation|seller_consultation|buyer_advisory|refinance_support|estate_settlement|other — promote to reference product]' ;
    rdfs:domain ind:Cma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isUspapCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Uspap Compliant' ;
    rdfs:comment 'Indicates whether this CMA was prepared in accordance with USPAP standards. CMAs are typically NOT USPAP-compliant (False) as they are broker-prepared market analyses, not certified appraisals. This flag distinguishes CMAs from formal appraisals for regulatory and disclosure purposes.' ;
    rdfs:domain ind:Cma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:listToSaleRatio rdf:type rdf:Property ;
    rdfs:label 'List To Sale Ratio' ;
    rdfs:comment 'The average ratio of final sale price to original list price across comparable sold properties, expressed as a decimal (e.g., 0.97 = 97%). Indicates negotiation dynamics and pricing accuracy in the local market.' ;
    rdfs:domain ind:Cma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketCondition rdf:type rdf:Property ;
    rdfs:label 'Market Condition' ;
    rdfs:comment 'Classification of the current supply-demand balance in the subject property\'s local market. Sellers markets have low inventory and high demand; buyers markets have high inventory and low demand.' ;
    rdfs:domain ind:Cma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlsAreaCode rdf:type rdf:Property ;
    rdfs:label 'Mls Area Code' ;
    rdfs:comment 'The MLS-defined geographic area or submarket code within which the subject property and comparables are located. Ensures comparables are drawn from the same MLS market area.' ;
    rdfs:domain ind:Cma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthsOfSupply rdf:type rdf:Property ;
    rdfs:label 'Months Of Supply' ;
    rdfs:comment 'Estimated number of months it would take to sell all current active listings at the current absorption rate. Less than 3 months indicates a sellers market; more than 6 months indicates a buyers market.' ;
    rdfs:domain ind:Cma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pendingComparableCount rdf:type rdf:Property ;
    rdfs:label 'Pending Comparable Count' ;
    rdfs:comment 'Number of pending (under contract) comparable listings included in the analysis. Pending comparables indicate near-term market clearing prices.' ;
    rdfs:domain ind:Cma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pricingStrategy rdf:type rdf:Property ;
    rdfs:label 'Pricing Strategy' ;
    rdfs:comment 'The analyst\'s recommended pricing approach for the listing based on market conditions, seller objectives, and CMA findings. Aggressive pricing targets above-market value; below-market pricing aims for rapid sale.' ;
    rdfs:domain ind:Cma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soldComparableCount rdf:type rdf:Property ;
    rdfs:label 'Sold Comparable Count' ;
    rdfs:comment 'Number of recently sold comparable properties included in the analysis. Sold comparables are the primary evidence of market value in a CMA.' ;
    rdfs:domain ind:Cma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:comparableSaleId rdf:type rdf:Property ;
    rdfs:label 'Comparable Sale Id' ;
    rdfs:comment 'Primary key for comparable_sale' ;
    rdfs:domain ind:ComparableSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incomeApproachId rdf:type rdf:Property ;
    rdfs:label 'Income Approach Id' ;
    rdfs:comment 'Foreign key linking to valuation.valuation_approach. Business justification: The sales comparison approach (valuation_approach with approach_type = \'SALES_COMPARISON\') relies on comparable sales as primary evidence. Adding income_approach_id (nullable, using the PK of valuatio' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Approach .

ind:adjustedPricePsf rdf:type rdf:Property ;
    rdfs:label 'Adjusted Price Psf' ;
    rdfs:comment 'The adjusted sale price divided by the gross leasable area, expressed as adjusted price per square foot (PSF). The primary reconciled unit-of-comparison metric used to bracket and support the subject property\'s value conclusion.' ;
    rdfs:domain ind:ComparableSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustedSalePrice rdf:type rdf:Property ;
    rdfs:label 'Adjusted Sale Price' ;
    rdfs:comment 'The comparable sale price after application of all adjustments (location, physical, time, and other). This is the final adjusted value indicator used in the reconciliation of the sales comparison approach to derive the subject property\'s market value opinion.' ;
    rdfs:domain ind:ComparableSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appraiserNotes rdf:type rdf:Property ;
    rdfs:label 'Appraiser Notes' ;
    rdfs:comment 'Free-text narrative notes entered by the appraiser describing the rationale for selecting this comparable, the basis for adjustments applied, and any special circumstances affecting the sale. Required for USPAP Standard 1 documentation of the sales comparison approach.' ;
    rdfs:domain ind:ComparableSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:armsLengthFlag rdf:type rdf:Property ;
    rdfs:label 'Arms Length Flag' ;
    rdfs:comment 'Indicates whether the comparable sale was an arm\'s length transaction between unrelated parties with no undue influence (True) or a non-arm\'s length transaction (False) such as a foreclosure, related-party sale, or distressed sale. Non-arm\'s length transactions require additional adjustment or exclusion per USPAP.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capRateAtSale rdf:type rdf:Property ;
    rdfs:label 'Cap Rate At Sale' ;
    rdfs:comment 'The implied capitalization rate (CAP rate) at the time of the comparable sale, calculated as the net operating income (NOI) divided by the sale price. A key market indicator used in income approach cross-checks and investment analysis.' ;
    rdfs:domain ind:ComparableSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Comp Reference Number' ;
    rdfs:comment 'Externally-known identifier for this comparable sale record, typically sourced from CoStar Suite, MLS, or public record systems (e.g., CoStar property ID, MLS listing number, or county assessor parcel number).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Data Source Record Reference' ;
    rdfs:comment 'The unique identifier of this comparable sale record within the originating source system (e.g., CoStar property ID, MLS listing number, county assessor parcel number). Enables traceability back to the source system for verification.' ;
    rdfs:domain ind:ComparableSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distressedSaleFlag rdf:type rdf:Property ;
    rdfs:label 'Distressed Sale Flag' ;
    rdfs:comment 'Indicates whether the comparable sale was a distressed transaction (True), such as a foreclosure, Real Estate Owned (REO) sale, short sale, or bankruptcy sale. Distressed sales may require exclusion or significant adjustment in USPAP-compliant appraisals.' ;
    rdfs:domain ind:ComparableSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financingType rdf:type rdf:Property ;
    rdfs:label 'Financing Type' ;
    rdfs:comment 'Type of financing used in the comparable sale transaction (e.g., conventional mortgage, cash, seller financing, assumed mortgage, CMBS). Atypical financing may require a cash equivalency adjustment per USPAP.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationAdjustmentPct rdf:type rdf:Property ;
    rdfs:label 'Location Adjustment Pct' ;
    rdfs:comment 'Percentage adjustment applied to the comparable sale price to account for locational differences between the comparable property and the subject property (e.g., submarket quality, access, visibility, corner location). Positive values indicate the subject is superior; negative values indicate the comparable is superior.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotSizeSqft rdf:type rdf:Property ;
    rdfs:label 'Lot Size Sqft' ;
    rdfs:comment 'Total land area of the comparable sale property parcel measured in square feet. Critical for land valuation, FAR analysis, and comparability assessment for properties where land value is a significant component.' ;
    rdfs:domain ind:ComparableSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:noiAtSale rdf:type rdf:Property ;
    rdfs:label 'Noi At Sale' ;
    rdfs:comment 'The net operating income (NOI) of the comparable property at the time of sale, used to calculate the implied CAP rate and to support income approach cross-validation in the appraisal.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfStories rdf:type rdf:Property ;
    rdfs:label 'Number Of Stories' ;
    rdfs:comment 'Total number of above-grade floors or stories in the comparable sale property. Used as a physical characteristic for comparability assessment and adjustment.' ;
    rdfs:domain ind:ComparableSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:occupancyRatePct rdf:type rdf:Property ;
    rdfs:label 'Occupancy Rate Pct' ;
    rdfs:comment 'Percentage of the comparable property that was occupied at the time of sale. Used to assess income-producing capacity and to determine whether occupancy-related adjustments are required.' ;
    rdfs:domain ind:ComparableSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:physicalAdjustmentPct rdf:type rdf:Property ;
    rdfs:label 'Physical Adjustment Pct' ;
    rdfs:comment 'Percentage adjustment applied to the comparable sale price to account for physical differences between the comparable and subject property (e.g., size, age, condition, quality, amenities). Positive values indicate the subject is superior.' ;
    rdfs:domain ind:ComparableSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricePsf rdf:type rdf:Property ;
    rdfs:label 'Price Psf' ;
    rdfs:comment 'Sale price divided by the gross leasable area or building area, expressed as price per square foot (PSF). A primary unit-of-comparison metric used in the sales comparison approach for commercial and residential appraisals.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricePsm rdf:type rdf:Property ;
    rdfs:label 'Price Psm' ;
    rdfs:comment 'Sale price divided by the building area expressed in square meters (SQM). Used for international valuations and IVSC-compliant reporting where metric units are required.' ;
    rdfs:domain ind:ComparableSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:propertySubtype rdf:type rdf:Property ;
    rdfs:label 'Property Subtype' ;
    rdfs:comment 'More granular classification of the comparable property within its property type (e.g., Class A Office, Strip Center, Bulk Warehouse, Garden Apartment). Supports refined comparability analysis.' ;
    rdfs:domain ind:ComparableSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityRating rdf:type rdf:Property ;
    rdfs:label 'Quality Rating' ;
    rdfs:comment 'Rating of the construction quality and finish level of the comparable sale property. Used to assess quality-based adjustments in the sales comparison approach.' ;
    rdfs:domain ind:ComparableSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saleDate rdf:type rdf:Property ;
    rdfs:label 'Sale Date' ;
    rdfs:comment 'The date on which the comparable property sale was recorded or closed, used as the principal business event date for time adjustment calculations in the sales comparison approach.' ;
    rdfs:domain ind:ComparableSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:timeAdjustmentPct rdf:type rdf:Property ;
    rdfs:label 'Time Adjustment Pct' ;
    rdfs:comment 'Percentage adjustment applied to the comparable sale price to account for market conditions changes between the comparable sale date and the effective appraisal date. Reflects market appreciation or depreciation over the intervening period.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'The date on which the comparable sale data was verified against the primary source. Supports USPAP compliance documentation and audit trail requirements.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:comparableLeaseId rdf:type rdf:Property ;
    rdfs:label 'Comparable Lease Id' ;
    rdfs:comment 'Unique system-generated identifier for the comparable lease transaction record used as market evidence in valuation analysis.' ;
    rdfs:domain ind:ComparableLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustedRentPsf rdf:type rdf:Property ;
    rdfs:label 'Adjusted Rent Psf' ;
    rdfs:comment 'Base rent per square foot after applying all grid adjustments (time, location, condition, size, etc.) to normalize the comparable lease to the subject property characteristics. The final adjusted rent used in market rent conclusions.' ;
    rdfs:domain ind:ComparableLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:camChargesPsf rdf:type rdf:Property ;
    rdfs:label 'Cam Charges Psf' ;
    rdfs:comment 'Common Area Maintenance (CAM) charges expressed on a per-square-foot annual basis for the comparable lease. Used to gross up NNN rents to a gross equivalent for cross-lease comparisons.' ;
    rdfs:domain ind:ComparableLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compPropertyAddress rdf:type rdf:Property ;
    rdfs:label 'Comp Property Address' ;
    rdfs:comment 'Full street address of the comparable property including street number, street name, suite or floor where applicable. Used for geographic proximity analysis in market rent conclusions.' ;
    rdfs:domain ind:ComparableLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compPropertyName rdf:type rdf:Property ;
    rdfs:label 'Comp Property Name' ;
    rdfs:comment 'Common or marketing name of the comparable property (e.g., \'One Embarcadero Center\', \'Westfield Mall\'). Used for identification and reporting in valuation narratives.' ;
    rdfs:domain ind:ComparableLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionAdjustmentPct rdf:type rdf:Property ;
    rdfs:label 'Condition Adjustment Pct' ;
    rdfs:comment 'Percentage adjustment applied to the comparable lease rent to account for differences in building condition, quality, or finish level between the comparable and subject properties.' ;
    rdfs:domain ind:ComparableLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expansionOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Expansion Option Flag' ;
    rdfs:comment 'Indicates whether the comparable lease includes a tenant expansion option for additional space. Relevant for assessing tenant demand and flexibility provisions in market analysis.' ;
    rdfs:domain ind:ComparableLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaseExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Lease Execution Date' ;
    rdfs:comment 'Date on which the comparable lease agreement was fully executed (signed) by both landlord and tenant. Establishes the market date for the transaction, critical for time-adjustment analysis in income approach valuations.' ;
    rdfs:domain ind:ComparableLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiration Date' ;
    rdfs:comment 'Scheduled expiration date of the comparable lease term. Used in conjunction with commencement date to validate the stated lease term in months.' ;
    rdfs:domain ind:ComparableLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseSizeSqf rdf:type rdf:Property ;
    rdfs:label 'Lease Size Sqf' ;
    rdfs:comment 'Total leased area of the comparable lease expressed in square feet (SQF). Used to assess scale comparability with the subject property and to weight rent conclusions in market analysis.' ;
    rdfs:domain ind:ComparableLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseSizeSqm rdf:type rdf:Property ;
    rdfs:label 'Lease Size Sqm' ;
    rdfs:comment 'Total leased area of the comparable lease expressed in square meters (SQM). Used for international market comparisons and IVSC-compliant valuation reports.' ;
    rdfs:domain ind:ComparableLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingExpenseStopPsf rdf:type rdf:Property ;
    rdfs:label 'Operating Expense Stop Psf' ;
    rdfs:comment 'Base year operating expense stop per square foot above which the tenant is responsible for expense increases. Common in modified gross leases; used to normalize rent comparisons across different expense structures.' ;
    rdfs:domain ind:ComparableLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approachDate rdf:type rdf:Property ;
    rdfs:label 'Approach Date' ;
    rdfs:comment 'Effective date as of which the valuation approach analysis is performed. Represents the appraisal effective date for this specific methodology, which may differ from the report date.' ;
    rdfs:domain ind:Approach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approachStatus rdf:type rdf:Property ;
    rdfs:label 'Approach Status' ;
    rdfs:comment 'Current lifecycle state of this valuation approach record within the appraisal workflow. Tracks progression from initial draft through peer review, approval, and potential supersession by a revised approach.' ;
    rdfs:domain ind:Approach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approachType rdf:type rdf:Property ;
    rdfs:label 'Approach Type' ;
    rdfs:comment 'Discriminator identifying the valuation methodology applied in this record. Supported types: direct_cap (Direct Capitalization), DCF (Discounted Cash Flow), cost (Cost Approach), sales_comparison (Sales Comparison Approach), GRM (Gross Rent Multiplier). Drives which set of methodology-specific fields are populated.' ;
    rdfs:domain ind:Approach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concludedMarketRentPsf rdf:type rdf:Property ;
    rdfs:label 'Concluded Market Rent Psf' ;
    rdfs:comment 'Appraiser\'s concluded market rent per square foot (PSF) used as the basis for PGI estimation in income capitalization approaches. Derived from comparable lease analysis and market surveys. Expressed in the reporting currency per square foot per year.' ;
    rdfs:domain ind:Approach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concludedValue rdf:type rdf:Property ;
    rdfs:label 'Concluded Value' ;
    rdfs:comment 'The indicated market value produced by this specific valuation approach before reconciliation weighting. Represents the raw output of the methodology (e.g., direct capitalization value, DCF NPV, depreciated cost, or sales comparison adjusted value) in the reporting currency.' ;
    rdfs:domain ind:Approach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costIndexSource rdf:type rdf:Property ;
    rdfs:label 'Cost Index Source' ;
    rdfs:comment 'Source of the construction cost index or cost manual used to estimate RCN in the cost approach. Common sources include Marshall & Swift Valuation Service and RSMeans Cost Data. Supports methodology transparency and IVSC IVS 105 compliance documentation.' ;
    rdfs:domain ind:Approach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciatedCostOfImprovements rdf:type rdf:Property ;
    rdfs:label 'Depreciated Cost Of Improvements' ;
    rdfs:comment 'Net value of the improvements after deducting total accrued depreciation (physical, functional, and external obsolescence) from RCN. Added to land value to derive the cost approach indicated value. Populated for cost approach type.' ;
    rdfs:domain ind:Approach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:directCapValue rdf:type rdf:Property ;
    rdfs:label 'Direct Cap Value' ;
    rdfs:comment 'Indicated value derived by dividing stabilized NOI by the overall CAP rate (NOI / CAP Rate). Represents the concluded value under the direct capitalization method. Populated only when approach_type = direct_cap.' ;
    rdfs:domain ind:Approach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:economicLifeYears rdf:type rdf:Property ;
    rdfs:label 'Economic Life Years' ;
    rdfs:comment 'Total estimated economic life of the improvements in years — the period over which the building is expected to contribute positively to property value. Used with effective age to calculate the age-life depreciation ratio in the cost approach.' ;
    rdfs:domain ind:Approach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveAgeYears rdf:type rdf:Property ;
    rdfs:label 'Effective Age Years' ;
    rdfs:comment 'Appraiser\'s estimate of the effective age of the improvements in years, reflecting the actual condition and utility of the building relative to a new structure of similar type. May differ from chronological age due to renovations or deferred maintenance. Used in cost approach depreciation calculations.' ;
    rdfs:domain ind:Approach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalObsolescence rdf:type rdf:Property ;
    rdfs:label 'External Obsolescence' ;
    rdfs:comment 'Loss in value caused by factors external to the property, such as adverse market conditions, neighborhood decline, or proximity to negative influences. Also known as economic obsolescence. Deducted from RCN in the cost approach.' ;
    rdfs:domain ind:Approach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalObsolescence rdf:type rdf:Property ;
    rdfs:label 'Functional Obsolescence' ;
    rdfs:comment 'Loss in value resulting from deficiencies or superadequacies in the design, layout, or functionality of the improvements relative to current market standards (e.g., outdated floor plans, inadequate HVAC systems). Deducted from RCN in the cost approach.' ;
    rdfs:domain ind:Approach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grm rdf:type rdf:Property ;
    rdfs:label 'Grm' ;
    rdfs:comment 'Gross Rent Multiplier — the ratio of property value to gross annual (or monthly) rental income, derived from comparable sales. Applied to the subject property\'s gross rent to estimate value under the GRM approach. Populated when approach_type = GRM.' ;
    rdfs:domain ind:Approach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ivscMethodologyCode rdf:type rdf:Property ;
    rdfs:label 'Ivsc Methodology Code' ;
    rdfs:comment 'IVSC IVS 105 methodology classification code identifying the specific valuation technique applied (e.g., IVS105-IC for Income Capitalization, IVS105-CA for Cost Approach, IVS105-SC for Sales Comparison). Supports regulatory compliance documentation and cross-border reporting.' ;
    rdfs:domain ind:Approach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landValue rdf:type rdf:Property ;
    rdfs:label 'Land Value' ;
    rdfs:comment 'Estimated market value of the land component as if vacant and available for its highest and best use. Used in the cost approach as the foundation to which depreciated cost of improvements is added. Populated for cost approach type.' ;
    rdfs:domain ind:Approach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:methodologyNotes rdf:type rdf:Property ;
    rdfs:label 'Methodology Notes' ;
    rdfs:comment 'Free-text field capturing appraiser commentary on the rationale, assumptions, limitations, and adjustments specific to this valuation approach. Supports IVSC IVS 105 compliance, USPAP disclosure requirements, and peer review documentation.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalDepreciation rdf:type rdf:Property ;
    rdfs:label 'Physical Depreciation' ;
    rdfs:comment 'Loss in value attributable to physical deterioration of the improvements, including curable deferred maintenance and incurable structural wear. Deducted from RCN in the cost approach. Populated for cost approach type.' ;
    rdfs:domain ind:Approach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replacementCostNew rdf:type rdf:Property ;
    rdfs:label 'Replacement Cost New' ;
    rdfs:comment 'Replacement Cost New (RCN) — the estimated cost to construct a building of equivalent utility using current materials, standards, and design at current prices. Starting point for the cost approach before depreciation deductions. Populated for cost approach type.' ;
    rdfs:domain ind:Approach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sensitivityNotes rdf:type rdf:Property ;
    rdfs:label 'Sensitivity Notes' ;
    rdfs:comment 'Narrative description of key sensitivity scenarios tested for this approach, such as the impact of a 25 bps change in CAP rate or discount rate on concluded value. Supports investment decision-making and risk disclosure in appraisal reports.' ;
    rdfs:domain ind:Approach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalOpex rdf:type rdf:Property ;
    rdfs:label 'Total Opex' ;
    rdfs:comment 'Total annual operating expenses (OPEX) for the subject property, including property taxes, insurance, management fees, maintenance, utilities, and reserves for replacement. Deducted from EGI to derive NOI. Populated for income capitalization approaches.' ;
    rdfs:domain ind:Approach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vacancyCreditLossRate rdf:type rdf:Property ;
    rdfs:label 'Vacancy Credit Loss Rate' ;
    rdfs:comment 'Estimated rate (decimal fraction) applied to PGI to account for expected vacancy and uncollectible rent. For example, 0.05 represents a 5% vacancy and credit loss allowance. Used in income capitalization to derive EGI from PGI.' ;
    rdfs:domain ind:Approach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightPct rdf:type rdf:Property ;
    rdfs:label 'Weight Pct' ;
    rdfs:comment 'Weighting factor (expressed as a decimal between 0 and 1) assigned to this approach in the final value reconciliation. For example, 0.60 indicates this approach contributes 60% to the concluded value. All approach weights for a given valuation should sum to 1.0.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionPrice rdf:type rdf:Property ;
    rdfs:label 'Acquisition Price' ;
    rdfs:comment 'Total assumed purchase price of the property at the start of the hold period, used as the basis for LTV, equity multiple, and IRR calculations.' ;
    rdfs:domain ind:DcfModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:argusModelVersion rdf:type rdf:Property ;
    rdfs:label 'Argus Model Version' ;
    rdfs:comment 'Version label of the Argus Enterprise model file (e.g., v1.0, v2.3-final) to distinguish iterative revisions of the same model.' ;
    rdfs:domain ind:DcfModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avgDscr rdf:type rdf:Property ;
    rdfs:label 'Avg Dscr' ;
    rdfs:comment 'Average annual Debt Service Coverage Ratio across the hold period, calculated as NOI divided by annual debt service. Lenders typically require a minimum DSCR of 1.20x–1.25x.' ;
    rdfs:domain ind:DcfModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capexReservePsf rdf:type rdf:Property ;
    rdfs:label 'Capex Reserve Psf' ;
    rdfs:comment 'Annual capital expenditure reserve amount per square foot budgeted for building improvements, tenant improvements (TI), and leasing commissions over the hold period.' ;
    rdfs:domain ind:DcfModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debtAmount rdf:type rdf:Property ;
    rdfs:label 'Debt Amount' ;
    rdfs:comment 'Total debt (mortgage or loan) assumed at acquisition used to finance the property purchase. Drives LTV and DSCR calculations within the model.' ;
    rdfs:domain ind:DcfModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equityInvestment rdf:type rdf:Property ;
    rdfs:label 'Equity Investment' ;
    rdfs:comment 'Total equity capital contributed at acquisition, representing the difference between acquisition price and debt financing. Used to compute levered IRR and equity multiple.' ;
    rdfs:domain ind:DcfModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expenseGrowthRate rdf:type rdf:Property ;
    rdfs:label 'Expense Growth Rate' ;
    rdfs:comment 'Assumed annual percentage increase in operating expenses (OPEX) applied across the projection period. Typically benchmarked to CPI or market inflation indices.' ;
    rdfs:domain ind:DcfModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goingInCapRate rdf:type rdf:Property ;
    rdfs:label 'Going In Cap Rate' ;
    rdfs:comment 'The capitalization rate implied by the acquisition price and Year 1 NOI. Used to benchmark the entry pricing against market comparables and assess acquisition risk.' ;
    rdfs:domain ind:DcfModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Hold Period End Date' ;
    rdfs:comment 'The date on which the modeled investment hold period ends, representing the assumed disposition or reversion date.' ;
    rdfs:domain ind:DcfModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Hold Period Start Date' ;
    rdfs:comment 'The date on which the modeled investment hold period commences, typically the assumed acquisition or ownership transfer date.' ;
    rdfs:domain ind:DcfModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isLevered rdf:type rdf:Property ;
    rdfs:label 'Is Levered' ;
    rdfs:comment 'Indicates whether this DCF model incorporates debt financing (levered analysis). True = levered model with debt service; False = unlevered all-equity model.' ;
    rdfs:domain ind:DcfModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:methodologyStandard rdf:type rdf:Property ;
    rdfs:label 'Methodology Standard' ;
    rdfs:comment 'The governing valuation methodology standard applied in constructing this DCF model. Ensures compliance with applicable appraisal and financial reporting frameworks.' ;
    rdfs:domain ind:DcfModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minDscr rdf:type rdf:Property ;
    rdfs:label 'Min Dscr' ;
    rdfs:comment 'The lowest annual DSCR observed across all projection periods in the hold period. Identifies the most stressed year for debt coverage, critical for lender covenant compliance.' ;
    rdfs:domain ind:DcfModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelAssumptionsNarrative rdf:type rdf:Property ;
    rdfs:label 'Model Assumptions Narrative' ;
    rdfs:comment 'Free-text narrative documenting the key assumptions, market conditions, data sources, and qualifications underlying this DCF model. Required for IVSC-compliant methodology disclosure and investment committee review.' ;
    rdfs:domain ind:DcfModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelPurpose rdf:type rdf:Property ;
    rdfs:label 'Model Purpose' ;
    rdfs:comment 'Business purpose for which this DCF model was constructed. Determines the applicable methodology standards and reporting requirements. [ENUM-REF-CANDIDATE: acquisition_underwriting|disposition_analysis|refinancing|annual_valuation|portfolio_reporting|impairment_testing|loan_origination — promote to reference product]' ;
    rdfs:domain ind:DcfModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelStatus rdf:type rdf:Property ;
    rdfs:label 'Model Status' ;
    rdfs:comment 'Current lifecycle state of the DCF model record. Controls which version is authoritative for investment decisions and financial reporting.' ;
    rdfs:domain ind:DcfModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netReversionProceeds rdf:type rdf:Property ;
    rdfs:label 'Net Reversion Proceeds' ;
    rdfs:comment 'Gross reversion value less estimated selling costs, representing the net cash inflow to the investor upon disposition at the end of the hold period.' ;
    rdfs:domain ind:DcfModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:npvAtDiscountRate rdf:type rdf:Property ;
    rdfs:label 'Npv At Discount Rate' ;
    rdfs:comment 'Net Present Value of all projected cash flows (including reversion) discounted at the model\'s target discount rate. Positive NPV indicates value creation above the required return threshold.' ;
    rdfs:domain ind:DcfModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rentGrowthRate rdf:type rdf:Property ;
    rdfs:label 'Rent Growth Rate' ;
    rdfs:comment 'Assumed annual percentage increase in market rents applied across the projection period. Drives revenue escalation in the DCF cash flow schedule.' ;
    rdfs:domain ind:DcfModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversionValue rdf:type rdf:Property ;
    rdfs:label 'Reversion Value' ;
    rdfs:comment 'Estimated gross sale proceeds at the end of the hold period, calculated by applying the terminal cap rate to the projected NOI in the reversion year. Represents the largest single cash inflow in the DCF model.' ;
    rdfs:domain ind:DcfModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sellingCostsRate rdf:type rdf:Property ;
    rdfs:label 'Selling Costs Rate' ;
    rdfs:comment 'Percentage of reversion value deducted for estimated disposition costs (brokerage commissions, transfer taxes, legal fees) to arrive at net reversion proceeds.' ;
    rdfs:domain ind:DcfModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sensitivityIrrHigh rdf:type rdf:Property ;
    rdfs:label 'Sensitivity Irr High' ;
    rdfs:comment 'Levered IRR under the upside/bull case sensitivity scenario, reflecting optimistic assumptions (lower vacancy, higher rent growth, lower cap rate). Bounds the investment return range.' ;
    rdfs:domain ind:DcfModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sensitivityIrrLow rdf:type rdf:Property ;
    rdfs:label 'Sensitivity Irr Low' ;
    rdfs:comment 'Levered IRR under the downside/bear case sensitivity scenario, reflecting stressed assumptions (higher vacancy, lower rent growth, higher cap rate). Used in investment committee risk analysis.' ;
    rdfs:domain ind:DcfModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vacancyRateAssumption rdf:type rdf:Property ;
    rdfs:label 'Vacancy Rate Assumption' ;
    rdfs:comment 'Blended vacancy and credit loss rate applied to Potential Gross Income (PGI) to derive Effective Gross Income (EGI) in the model. Expressed as a decimal (e.g., 0.05 for 5%).' ;
    rdfs:domain ind:DcfModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:year1Noi rdf:type rdf:Property ;
    rdfs:label 'Year1 Noi' ;
    rdfs:comment 'Projected Net Operating Income for the first year of the hold period, representing Effective Gross Income (EGI) less operating expenses. Foundational input for going-in cap rate and debt sizing.' ;
    rdfs:domain ind:DcfModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchmarkCode rdf:type rdf:Property ;
    rdfs:label 'Benchmark Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this benchmark record, used for cross-system referencing and CoStar/Argus Enterprise integration (e.g., CRB-2024Q3-OFF-CLA-NYC). Serves as the business identifier for this benchmark.' ;
    rdfs:domain ind:CapRateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkStatus rdf:type rdf:Property ;
    rdfs:label 'Benchmark Status' ;
    rdfs:comment 'Lifecycle status of this benchmark record indicating whether it is currently active for use in valuations, has been superseded by a newer survey, is in draft pending publication, archived for historical reference, or under review for accuracy.' ;
    rdfs:domain ind:CapRateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capRateHigh rdf:type rdf:Property ;
    rdfs:label 'Cap Rate High' ;
    rdfs:comment 'The upper bound of the surveyed CAP rate range for this property type, asset class, and submarket combination, expressed as a decimal (e.g., 0.0650 = 6.50%). Represents the most conservative (highest) CAP rate observed, typically associated with lower-quality assets or less competitive submarkets.' ;
    rdfs:domain ind:CapRateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capRateLow rdf:type rdf:Property ;
    rdfs:label 'Cap Rate Low' ;
    rdfs:comment 'The lower bound of the surveyed CAP rate range for this property type, asset class, and submarket combination, expressed as a decimal (e.g., 0.0450 = 4.50%). Represents the most aggressive (lowest) CAP rate observed in the market, typically associated with the highest-quality assets or most competitive submarkets.' ;
    rdfs:domain ind:CapRateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capRateMid rdf:type rdf:Property ;
    rdfs:label 'Cap Rate Mid' ;
    rdfs:comment 'The midpoint or median of the surveyed CAP rate range, expressed as a decimal (e.g., 0.0550 = 5.50%). This is the primary benchmark value used by appraisers for CAP rate selection validation and by asset managers for NAV/GAV calculations in Argus Enterprise models.' ;
    rdfs:domain ind:CapRateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capRatePriorMid rdf:type rdf:Property ;
    rdfs:label 'Cap Rate Prior Mid' ;
    rdfs:comment 'The midpoint CAP rate from the immediately preceding survey period for the same property type, asset class, and submarket. Used to calculate period-over-period movement and validate the trend_direction field. Supports time-series analysis in investment committee presentations.' ;
    rdfs:domain ind:CapRateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costarMarketReference rdf:type rdf:Property ;
    rdfs:label 'Costar Market Reference' ;
    rdfs:comment 'The CoStar Suite internal market identifier for the submarket or market area covered by this benchmark. Enables direct linkage to CoStar market analytics, comparable transaction data, and property analytics for benchmark validation and enrichment.' ;
    rdfs:domain ind:CapRateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'A numeric score (0.00–100.00) representing the assessed quality and reliability of this benchmark record based on sample size, source credibility, methodology transparency, and recency. Used by the data governance team to flag low-confidence benchmarks and by appraisers to weight multiple sources.' ;
    rdfs:domain ind:CapRateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impliedValuePsfHigh rdf:type rdf:Property ;
    rdfs:label 'Implied Value Psf High' ;
    rdfs:comment 'The upper bound of the implied market value per square foot derived from the CAP rate range and prevailing NOI levels for this segment. Used in conjunction with implied_value_psf_low to establish a market value range for portfolio-level reporting.' ;
    rdfs:domain ind:CapRateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impliedValuePsfLow rdf:type rdf:Property ;
    rdfs:label 'Implied Value Psf Low' ;
    rdfs:comment 'The lower bound of the implied market value per square foot derived from the CAP rate range and prevailing NOI levels for this segment. Provides a sanity-check metric for appraiser CAP rate selections and supports portfolio-level GAV/NAV estimation.' ;
    rdfs:domain ind:CapRateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:investorSentiment rdf:type rdf:Property ;
    rdfs:label 'Investor Sentiment' ;
    rdfs:comment 'The prevailing investor sentiment toward this property type and market segment as reported in the source survey (bullish, neutral, bearish). Provides qualitative market context for investment committee presentations and portfolio strategy discussions.' ;
    rdfs:domain ind:CapRateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isInstitutionalGrade rdf:type rdf:Property ;
    rdfs:label 'Is Institutional Grade' ;
    rdfs:comment 'Indicates whether this benchmark applies specifically to institutional-grade investment properties meeting NCREIF/REIT portfolio standards (True) or to the broader market including non-institutional assets (False). Relevant for REIT portfolio NAV/GAV calculations and SEC reporting.' ;
    rdfs:domain ind:CapRateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryBenchmark rdf:type rdf:Property ;
    rdfs:label 'Is Primary Benchmark' ;
    rdfs:comment 'Indicates whether this record is designated as the primary (preferred) benchmark for the given property type, asset class, and submarket combination when multiple sources exist for the same period. True = primary benchmark to be used in appraisal validation; False = secondary/supplemental benchmark.' ;
    rdfs:domain ind:CapRateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketLiquidityRating rdf:type rdf:Property ;
    rdfs:label 'Market Liquidity Rating' ;
    rdfs:comment 'Qualitative assessment of the transaction liquidity in this market segment at the time of the survey (high, moderate, low, illiquid). Informs the reliability weighting of the benchmark and the appropriate discount for illiquidity in investment advisory and REIT portfolio reporting.' ;
    rdfs:domain ind:CapRateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncreifPropertyIndexCode rdf:type rdf:Property ;
    rdfs:label 'Ncreif Property Index Code' ;
    rdfs:comment 'The NCREIF (National Council of Real Estate Investment Fiduciaries) Property Index segment code corresponding to this benchmark\'s property type and geographic classification. Enables alignment with NCREIF NPI return benchmarks for institutional investment performance reporting.' ;
    rdfs:domain ind:CapRateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noiPsfHigh rdf:type rdf:Property ;
    rdfs:label 'Noi Psf High' ;
    rdfs:comment 'The upper bound of the surveyed Net Operating Income (NOI) per square foot (PSF) range for this market segment. Used alongside noi_psf_low to bracket NOI assumptions in Argus Enterprise DCF models and appraisal income approach analyses.' ;
    rdfs:domain ind:CapRateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:noiPsfLow rdf:type rdf:Property ;
    rdfs:label 'Noi Psf Low' ;
    rdfs:comment 'The lower bound of the surveyed Net Operating Income (NOI) per square foot (PSF) range for this market segment, expressed in the currency per square foot. Used as an input cross-check for DCF models in Argus Enterprise and for validating NOI assumptions in appraisal reports.' ;
    rdfs:domain ind:CapRateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'The number of transactions, properties, or investor respondents included in the source survey for this specific property type, asset class, and submarket segment. A key indicator of statistical reliability; smaller samples warrant greater caution in appraisal application.' ;
    rdfs:domain ind:CapRateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceOrganization rdf:type rdf:Property ;
    rdfs:label 'Source Organization' ;
    rdfs:comment 'The name of the industry research organization or brokerage firm that published the survey from which this benchmark data was sourced (e.g., CoStar, CBRE, JLL, Cushman & Wakefield, NCREIF, PwC/Korpacz). Governs the credibility weighting applied during appraiser CAP rate selection validation. [ENUM-REF-CANDIDATE: CoStar|CBRE|JLL|Cushman & Wakefield|NCREIF|PwC/Korpacz|Marcus & Millichap|Colliers|Avison Young|Green Street — promote to reference product]' ;
    rdfs:domain ind:CapRateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceReportName rdf:type rdf:Property ;
    rdfs:label 'Source Report Name' ;
    rdfs:comment 'The formal name of the survey report or publication from which this benchmark data was extracted (e.g., \'CBRE Cap Rate Survey H1 2024\', \'PwC Real Estate Investor Survey Q3 2024\', \'NCREIF Property Index Q2 2024\'). Enables traceability back to the original source document for audit and IVSC compliance.' ;
    rdfs:domain ind:CapRateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceReportUrl rdf:type rdf:Property ;
    rdfs:label 'Source Report Url' ;
    rdfs:comment 'The URL or digital reference link to the original published survey report. Supports audit trail requirements and allows appraisers to access the primary source document when validating CAP rate selections.' ;
    rdfs:domain ind:CapRateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyFrequency rdf:type rdf:Property ;
    rdfs:label 'Survey Frequency' ;
    rdfs:comment 'The publication cadence of the source survey (quarterly, semi-annual, annual, monthly). Used to determine the expected expiry_date of each benchmark record and to schedule automated refresh workflows in the data pipeline.' ;
    rdfs:domain ind:CapRateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyMethodology rdf:type rdf:Property ;
    rdfs:label 'Survey Methodology' ;
    rdfs:comment 'Narrative description of the data collection and analysis methodology used by the source organization to derive the CAP rate benchmarks (e.g., transaction-based, investor survey, broker opinion, hedonic regression). Required for IVSC-compliant methodology metadata and appraiser disclosure in appraisal reports.' ;
    rdfs:domain ind:CapRateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalTransactionVolume rdf:type rdf:Property ;
    rdfs:label 'Total Transaction Volume' ;
    rdfs:comment 'The aggregate dollar value of all transactions included in the benchmark dataset for this segment and period, expressed in the currency indicated by currency_code. Provides context for the depth and liquidity of the market segment being benchmarked.' ;
    rdfs:domain ind:CapRateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCount rdf:type rdf:Property ;
    rdfs:label 'Transaction Count' ;
    rdfs:comment 'The number of actual closed sale transactions underlying the CAP rate benchmark data for this segment and period, where the source provides transaction-based data. Distinct from sample_size which may include survey respondents. Supports statistical confidence assessment.' ;
    rdfs:domain ind:CapRateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trendBasisPoints rdf:type rdf:Property ;
    rdfs:label 'Trend Basis Points' ;
    rdfs:comment 'The period-over-period change in the midpoint CAP rate expressed in basis points (bps), where 1 bps = 0.01%. Negative values indicate compression; positive values indicate expansion. Provides a precise quantitative measure of market movement to complement the qualitative trend_direction field.' ;
    rdfs:domain ind:CapRateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trendDirection rdf:type rdf:Property ;
    rdfs:label 'Trend Direction' ;
    rdfs:comment 'Directional trend of CAP rates in this market segment relative to the prior survey period. Compressing indicates CAP rates are decreasing (values rising); stable indicates no material change; expanding indicates CAP rates are increasing (values falling). Critical context for investment committee presentations and portfolio NAV/GAV assessments.' ;
    rdfs:domain ind:CapRateBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorCalculationNavCalculationId rdf:type rdf:Property ;
    rdfs:label 'Prior Calculation Nav Calculation Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediately preceding NAV calculation record for this portfolio/fund. Enables calculation chain traceability and period-over-period reconciliation.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NavCalculation .

ind:calculationDate rdf:type rdf:Property ;
    rdfs:label 'Calculation Date' ;
    rdfs:comment 'The as-of date for which the NAV and GAV are calculated. This is the principal business event date — the valuation reference point used in investor reports, REIT filings, and ASC 820 fair value disclosures.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calculationNumber rdf:type rdf:Property ;
    rdfs:label 'Calculation Number' ;
    rdfs:comment 'Human-readable, externally referenceable business identifier for this NAV/GAV calculation run (e.g., NAV-2024-000123). Used in investor reports, SEC filings, and audit trails to uniquely reference a specific calculation event.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationStatus rdf:type rdf:Property ;
    rdfs:label 'Calculation Status' ;
    rdfs:comment 'Current lifecycle state of the NAV/GAV calculation record. Controls workflow from initial preparation through review, approval, and publication to investors or regulators. \'Superseded\' indicates a revised calculation replaced this one.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashAndEquivalents rdf:type rdf:Property ;
    rdfs:label 'Cash And Equivalents' ;
    rdfs:comment 'Total cash and cash equivalent balances held at the portfolio or fund level as of the calculation date. Included in the NAV bridge as a non-real-estate asset component.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fairValueHierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Fair Value Hierarchy Level' ;
    rdfs:comment 'ASC 820 / IFRS 13 fair value hierarchy classification for the inputs used in this NAV calculation. Level 1 = quoted market prices; Level 2 = observable inputs; Level 3 = unobservable inputs (most common for real estate). Required for SEC and financial statement disclosures.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossAssetValue rdf:type rdf:Property ;
    rdfs:label 'Gross Asset Value' ;
    rdfs:comment 'Total Gross Asset Value (GAV) of the portfolio as of the calculation date, representing the sum of all property market values before deducting debt and liabilities. Core output of the NAV model used in REIT reporting, investor communications, and ASC 820 fair value disclosures.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAudited rdf:type rdf:Property ;
    rdfs:label 'Is Audited' ;
    rdfs:comment 'Indicates whether this NAV/GAV calculation has been subject to external audit review (True) or is an unaudited management estimate (False). Relevant for annual REIT financial statement audits and SEC filings.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPublished rdf:type rdf:Property ;
    rdfs:label 'Is Published' ;
    rdfs:comment 'Indicates whether this NAV calculation has been formally published and communicated to investors or regulators (True) or remains an internal working estimate (False). Controls investor disclosure workflow.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:navChange rdf:type rdf:Property ;
    rdfs:label 'Nav Change' ;
    rdfs:comment 'Absolute change in NAV from the prior period to the current calculation date (current NAV minus prior NAV). Supports period-over-period performance reporting to investors and the board.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netAssetValue rdf:type rdf:Property ;
    rdfs:label 'Net Asset Value' ;
    rdfs:comment 'Net Asset Value (NAV) of the portfolio or fund, calculated as GAV minus total debt outstanding minus other liabilities. The primary output metric used in REIT investor reporting, unit pricing, and SEC fair value disclosures.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:noiTotal rdf:type rdf:Property ;
    rdfs:label 'Noi Total' ;
    rdfs:comment 'Aggregate Net Operating Income (NOI) across all properties included in this NAV calculation, representing total effective gross income minus operating expenses before debt service. Primary input to direct capitalization and DCF valuation methodologies.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorNav rdf:type rdf:Property ;
    rdfs:label 'Prior Nav' ;
    rdfs:comment 'NAV from the immediately preceding calculation period, used to compute period-over-period NAV change and growth rate for investor reporting and performance attribution.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:propertyCount rdf:type rdf:Property ;
    rdfs:label 'Property Count' ;
    rdfs:comment 'Total count of properties included in this NAV/GAV calculation. Provides a completeness check and supports reconciliation against the portfolio property register in Argus Enterprise or MRI Software.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'The date on which this NAV calculation was formally published and made available to investors or filed with regulators. Null if not yet published.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Reporting Period' ;
    rdfs:comment 'The financial reporting period this NAV calculation corresponds to (e.g., Q1, Q2, Q3, Q4, Annual, Monthly). Aligns the calculation with the fund\'s financial reporting calendar for investor and SEC reporting.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingYear rdf:type rdf:Property ;
    rdfs:label 'Reporting Year' ;
    rdfs:comment 'The fiscal or calendar year associated with this NAV calculation (e.g., 2024). Used in conjunction with reporting_period to uniquely identify the reporting cycle.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thirdPartyAppraiser rdf:type rdf:Property ;
    rdfs:label 'Third Party Appraiser' ;
    rdfs:comment 'Name of the external appraisal firm or certified appraiser (MAI designation, Appraisal Institute member) engaged to provide independent property valuations used in this NAV calculation. Required when valuation_methodology includes third-party appraisal.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDebtOutstanding rdf:type rdf:Property ;
    rdfs:label 'Total Debt Outstanding' ;
    rdfs:comment 'Aggregate outstanding debt balance (mortgages, credit facilities, CMBS, and other borrowings) secured against or attributable to the portfolio as of the calculation date. Deducted from GAV to arrive at NAV.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationMethodology rdf:type rdf:Property ;
    rdfs:label 'Valuation Methodology' ;
    rdfs:comment 'The primary methodology used to determine property market values feeding into the GAV calculation. Options include direct capitalization (applying a CAP rate to NOI), Discounted Cash Flow (DCF), third-party appraisal, a blended approach, or a proprietary NAV model. Aligns with IVSC and FASB ASC 820 fair value hierarchy.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightedAvgCapRate rdf:type rdf:Property ;
    rdfs:label 'Weighted Avg Cap Rate' ;
    rdfs:comment 'Portfolio-level weighted average CAP rate (Capitalization Rate) applied across all properties in the NAV calculation, weighted by property value. Used to validate the implied GAV against market benchmarks and support investor reporting.' ;
    rdfs:domain ind:NavCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:abatementAmount rdf:type rdf:Property ;
    rdfs:label 'Abatement Amount' ;
    rdfs:comment 'Dollar value of any tax abatement granted by the taxing authority (e.g., development incentive abatement, payment-in-lieu-of-taxes (PILOT) arrangement). Distinct from exemptions; abatements are typically time-limited incentives tied to development agreements.' ;
    rdfs:domain ind:TaxAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:abatementExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Abatement Expiry Date' ;
    rdfs:comment 'Date on which any tax abatement arrangement expires, after which the full tax liability applies. Critical for long-term cash flow modeling in Argus Enterprise and investment underwriting — abatement burn-off materially impacts NOI (Net Operating Income) projections.' ;
    rdfs:domain ind:TaxAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealDeadline rdf:type rdf:Property ;
    rdfs:label 'Appeal Deadline' ;
    rdfs:comment 'Statutory deadline by which a formal appeal of the assessed value must be filed with the taxing authority. Critical compliance date tracked in Yardi Voyager and DocuSign CLM for deadline management.' ;
    rdfs:domain ind:TaxAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Resolution Date' ;
    rdfs:comment 'Date on which the taxing authority or appeals board issued a final decision on the appeal. Null if appeal is still pending. Triggers revised tax liability calculations.' ;
    rdfs:domain ind:TaxAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealSettledValue rdf:type rdf:Property ;
    rdfs:label 'Appeal Settled Value' ;
    rdfs:comment 'Final assessed value agreed upon or ordered as a result of the appeal process. Null if appeal is pending or not filed. Replaces the original assessed value for tax liability calculation upon resolution.' ;
    rdfs:domain ind:TaxAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appealTargetValue rdf:type rdf:Property ;
    rdfs:label 'Appeal Target Value' ;
    rdfs:comment 'The assessed value the property owner is seeking through the appeal process. Represents the owner\'s position on fair assessed value, typically supported by an independent appraisal or BPO (Broker Price Opinion). Used to quantify potential tax savings from a successful appeal.' ;
    rdfs:domain ind:TaxAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessedImprovementValue rdf:type rdf:Property ;
    rdfs:label 'Assessed Improvement Value' ;
    rdfs:comment 'Dollar value assigned by the taxing authority to the building and structural improvements on the property, exclusive of land. Drives depreciation analysis and CAPEX (Capital Expenditure) planning in Argus Enterprise models.' ;
    rdfs:domain ind:TaxAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessmentRatio rdf:type rdf:Property ;
    rdfs:label 'Assessment Ratio' ;
    rdfs:comment 'The ratio of assessed value to estimated market value as applied by the taxing jurisdiction (e.g., 0.80 = 80% of market value). Varies by jurisdiction and property class. Used to back-calculate implied market value from assessed value for investment analysis.' ;
    rdfs:domain ind:TaxAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assessment Status' ;
    rdfs:comment 'Current lifecycle state of the tax assessment record. Tracks progression from preliminary notice through certification, appeal, and final determination. Drives workflow in Yardi Voyager property accounting.' ;
    rdfs:domain ind:TaxAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentYear rdf:type rdf:Property ;
    rdfs:label 'Assessment Year' ;
    rdfs:comment 'The tax year (calendar year) for which this assessment applies. Drives annual property tax expense calculations and year-over-year valuation trend analysis. Critical for NOI (Net Operating Income) OPEX reporting.' ;
    rdfs:domain ind:TaxAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessorContact rdf:type rdf:Property ;
    rdfs:label 'Assessor Contact' ;
    rdfs:comment 'Phone number or contact detail for the assessor\'s office. Used for inquiry and appeal coordination. Classified as confidential organizational contact data.' ;
    rdfs:domain ind:TaxAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveTaxRate rdf:type rdf:Property ;
    rdfs:label 'Effective Tax Rate' ;
    rdfs:comment 'The effective property tax rate expressed as a decimal percentage of the total assessed value (e.g., 0.0125 = 1.25%). Accounts for all applicable levies across overlapping jurisdictions. Used in NOI (Net Operating Income) modeling and CAP Rate (Capitalization Rate) analysis in Argus Enterprise.' ;
    rdfs:domain ind:TaxAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exemptionAmount rdf:type rdf:Property ;
    rdfs:label 'Exemption Amount' ;
    rdfs:comment 'Total dollar value of tax exemptions applied to this assessment (e.g., homestead exemption, REIT (Real Estate Investment Trust) exemption, historic preservation, enterprise zone). Reduces the taxable assessed value or gross tax liability.' ;
    rdfs:domain ind:TaxAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exemptionType rdf:type rdf:Property ;
    rdfs:label 'Exemption Type' ;
    rdfs:comment 'Classification of the primary tax exemption applied to this assessment. Determines eligibility criteria and renewal requirements. [ENUM-REF-CANDIDATE: homestead|senior|veteran|nonprofit|historic|enterprise_zone|reit — promote to reference product]' ;
    rdfs:domain ind:TaxAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossAnnualTax rdf:type rdf:Property ;
    rdfs:label 'Gross Annual Tax' ;
    rdfs:comment 'Gross annual property tax liability before application of any exemptions, abatements, or credits. Computed from assessed value and millage rate. Key OPEX (Operating Expenditure) component in NOI (Net Operating Income) calculations and Argus Enterprise cash flow models.' ;
    rdfs:domain ind:TaxAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impliedMarketValue rdf:type rdf:Property ;
    rdfs:label 'Implied Market Value' ;
    rdfs:comment 'Estimated market value implied by the taxing authority\'s assessment, calculated as total assessed value divided by the assessment ratio. Provides a reference point for comparing assessed value against independent appraisals and Argus Enterprise DCF (Discounted Cash Flow) valuations.' ;
    rdfs:domain ind:TaxAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isNnnTenantRecoverable rdf:type rdf:Property ;
    rdfs:label 'Is Nnn Tenant Recoverable' ;
    rdfs:comment 'Indicates whether the property tax expense is recoverable from tenants under NNN (Triple Net Lease) or modified gross lease structures. True = tax is passed through to tenants as a CAM (Common Area Maintenance) or operating expense recovery; False = landlord bears the tax expense. Critical for EGI (Effective Gross Income) and NOI (Net Operating Income) modeling.' ;
    rdfs:domain ind:TaxAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:millageRate rdf:type rdf:Property ;
    rdfs:label 'Millage Rate' ;
    rdfs:comment 'The tax rate expressed in mills (dollars of tax per $1,000 of assessed value) levied by the taxing jurisdiction. Multiplied by the assessed value to compute the gross annual tax liability before exemptions.' ;
    rdfs:domain ind:TaxAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netAnnualTax rdf:type rdf:Property ;
    rdfs:label 'Net Annual Tax' ;
    rdfs:comment 'Net annual property tax liability after deducting all exemptions, abatements, and credits from the gross tax. This is the actual cash tax expense recorded in Yardi Voyager GL (General Ledger) and reported as a property OPEX (Operating Expenditure) line item in NOI (Net Operating Income) statements.' ;
    rdfs:domain ind:TaxAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorYearAssessedValue rdf:type rdf:Property ;
    rdfs:label 'Prior Year Assessed Value' ;
    rdfs:comment 'Total assessed value from the immediately preceding tax year. Enables year-over-year change analysis and supports appeal arguments based on disproportionate value increases. Used in Argus Enterprise cash flow modeling.' ;
    rdfs:domain ind:TaxAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:propertyClassCode rdf:type rdf:Property ;
    rdfs:label 'Property Class Code' ;
    rdfs:comment 'Assessor\'s classification code for the property type (e.g., residential, commercial, industrial, agricultural). Determines applicable assessment methodology, exemption eligibility, and tax rate schedule.' ;
    rdfs:domain ind:TaxAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewNotes rdf:type rdf:Property ;
    rdfs:label 'Review Notes' ;
    rdfs:comment 'Free-text notes entered by the internal reviewer documenting assessment analysis, appeal rationale, comparable evidence, or instructions for the AP (Accounts Payable) team. Supports audit trail requirements under SOX (Sarbanes-Oxley Act).' ;
    rdfs:domain ind:TaxAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxBillNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Bill Number' ;
    rdfs:comment 'Official tax bill number issued by the taxing authority for the annual tax payment. Used for AP (Accounts Payable) invoice matching in Yardi Voyager and SAP S/4HANA to ensure accurate tax remittance.' ;
    rdfs:domain ind:TaxAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxPsf rdf:type rdf:Property ;
    rdfs:label 'Tax Psf' ;
    rdfs:comment 'Annual net property tax liability expressed on a per-square-foot (PSF) basis. Enables benchmarking across properties of different sizes and is a standard metric in NNN (Triple Net Lease) lease analysis and CAM (Common Area Maintenance) reconciliations.' ;
    rdfs:domain ind:TaxAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAssessedValue rdf:type rdf:Property ;
    rdfs:label 'Total Assessed Value' ;
    rdfs:comment 'Total assessed value of the property as determined by the taxing authority, representing the sum of assessed land value and assessed improvement value. This is the ad valorem tax base and is typically distinct from market value. Key input to NOI (Net Operating Income) OPEX calculations.' ;
    rdfs:domain ind:TaxAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yardiPropertyCode rdf:type rdf:Property ;
    rdfs:label 'Yardi Property Code' ;
    rdfs:comment 'Property code as assigned in Yardi Voyager, the system of record for property accounting and tax expense tracking. Enables direct reconciliation between this Silver Layer record and the source system\'s tax ledger entries.' ;
    rdfs:domain ind:TaxAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Seller Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to finance.legal_entity. Business justification: Property sales are executed by legal entities (SPEs, REITs, LLCs). The selling entity determines consolidation treatment, gain/loss recognition, and REIT distribution requirements. Role-prefixed \'sell' ;
    rdfs:domain ind:PropertySale ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:sellerOwnerId rdf:type rdf:Property ;
    rdfs:label 'Seller Owner Id' ;
    rdfs:comment 'Foreign key linking to owner.owner. Business justification: Owner disposition reporting, capital gains analysis, and 1031 exchange eligibility checks require linking a property sale directly to the selling owner entity. Portfolio-level sale history and owner t' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Owner .

ind:buyerName rdf:type rdf:Property ;
    rdfs:label 'Buyer Name' ;
    rdfs:comment 'Legal name of the purchasing party (individual, entity, or trust) as recorded on the executed purchase and sale agreement and ALTA closing statement.' ;
    rdfs:domain ind:PropertySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closingDate rdf:type rdf:Property ;
    rdfs:label 'Closing Date' ;
    rdfs:comment 'Date on which the property sale transaction was legally closed, title transferred, and funds settled. Critical for revenue recognition under FASB ASC 606 and IFRS 15.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contingencyRemoved rdf:type rdf:Property ;
    rdfs:label 'Contingency Removed' ;
    rdfs:comment 'Indicates whether all contractual contingencies have been formally waived or satisfied, making the transaction firm and non-refundable. True = all contingencies removed; False = contingencies still active.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contingencyType rdf:type rdf:Property ;
    rdfs:label 'Contingency Type' ;
    rdfs:comment 'Primary contingency type governing the buyer\'s right to terminate the purchase agreement without penalty. Common types include financing, inspection, appraisal, title, and environmental contingencies.' ;
    rdfs:domain ind:PropertySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costarCompCode rdf:type rdf:Property ;
    rdfs:label 'Costar Comp Code' ;
    rdfs:comment 'CoStar Suite comparable sale identifier linking this transaction to the CoStar market database for benchmarking, comparable sales analysis, and market research.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deedRecordedDate rdf:type rdf:Property ;
    rdfs:label 'Deed Recorded Date' ;
    rdfs:comment 'Date on which the deed was officially recorded with the county recorder or registrar of deeds, establishing the public record of title transfer.' ;
    rdfs:domain ind:PropertySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deedType rdf:type rdf:Property ;
    rdfs:label 'Deed Type' ;
    rdfs:comment 'Type of deed instrument used to convey title from seller to buyer. Determines the scope of title warranties provided. Common types include warranty, special warranty, quitclaim, grant, and bargain and sale deeds.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earnestMoneyAmount rdf:type rdf:Property ;
    rdfs:label 'Earnest Money Amount' ;
    rdfs:comment 'Dollar amount of earnest money deposit submitted by the buyer upon execution of the purchase and sale agreement (PSA), held in escrow pending closing.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earnestMoneyDueDate rdf:type rdf:Property ;
    rdfs:label 'Earnest Money Due Date' ;
    rdfs:comment 'Date by which the earnest money deposit must be received and confirmed in escrow per the terms of the purchase and sale agreement.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:earnestMoneyReceived rdf:type rdf:Property ;
    rdfs:label 'Earnest Money Received' ;
    rdfs:comment 'Indicates whether the earnest money deposit has been received and confirmed in escrow. True = received; False = not yet received.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escrowCompany rdf:type rdf:Property ;
    rdfs:label 'Escrow Company' ;
    rdfs:comment 'Name of the escrow company or closing agent holding funds and documents in trust during the transaction period between contract execution and closing.' ;
    rdfs:domain ind:PropertySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Exchange Deadline Date' ;
    rdfs:comment 'Statutory deadline by which the replacement property must be identified and acquired to qualify for 1031 like-kind exchange tax deferral treatment. Applicable only when is_1031_exchange is True.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedClosingDate rdf:type rdf:Property ;
    rdfs:label 'Expected Closing Date' ;
    rdfs:comment 'Projected date on which the transaction is anticipated to close, as tracked in the deal pipeline. Used for cash flow forecasting and portfolio planning in Argus Enterprise.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:is1031Exchange rdf:type rdf:Property ;
    rdfs:label 'Is 1031 Exchange' ;
    rdfs:comment 'Indicates whether this transaction is structured as a 1031 like-kind exchange under IRS Section 1031, deferring capital gains tax recognition. True = 1031 exchange; False = standard sale.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netSalePrice rdf:type rdf:Property ;
    rdfs:label 'Net Sale Price' ;
    rdfs:comment 'Net proceeds from the property sale after deducting seller concessions, credits, prorations, and closing cost adjustments from the gross purchase price.' ;
    rdfs:domain ind:PropertySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchasePrice rdf:type rdf:Property ;
    rdfs:label 'Purchase Price' ;
    rdfs:comment 'Gross executed purchase price of the property as agreed in the purchase and sale agreement (PSA). Represents the total consideration paid before adjustments, credits, or prorations.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sellerConcessionsAmount rdf:type rdf:Property ;
    rdfs:label 'Seller Concessions Amount' ;
    rdfs:comment 'Total dollar value of concessions granted by the seller to the buyer, including closing cost credits, repair allowances, and price reductions negotiated post-inspection.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionNotes rdf:type rdf:Property ;
    rdfs:label 'Transaction Notes' ;
    rdfs:comment 'Free-text field for capturing material deal notes, special conditions, negotiation context, or other qualitative information relevant to the property sale transaction.' ;
    rdfs:domain ind:PropertySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the property sale transaction, used across Yardi Voyager, CoStar, and MLS systems for cross-referencing and audit trail purposes.' ;
    rdfs:domain ind:PropertySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current lifecycle state of the property sale transaction. Drives workflow routing in Yardi Voyager and Salesforce CRM deal pipeline. [ENUM-REF-CANDIDATE: pending|under_contract|closed|cancelled|on_hold|terminated — promote to reference product]' ;
    rdfs:domain ind:PropertySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yardiTransactionRef rdf:type rdf:Property ;
    rdfs:label 'Yardi Transaction Ref' ;
    rdfs:comment 'Source system transaction reference identifier from Yardi Voyager, used for data lineage, reconciliation, and audit trail back to the system of record.' ;
    rdfs:domain ind:PropertySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Buyer Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to finance.legal_entity. Business justification: The buying legal entity on a purchase agreement is required for FIRPTA withholding determination, contract execution authority, and entity-level acquisition reporting. purchase_agreement has buyer_own' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:buyerOwnerId rdf:type rdf:Property ;
    rdfs:label 'Buyer Owner Id' ;
    rdfs:comment 'Foreign key linking to owner.owner. Business justification: Owner acquisition pipeline reporting, KYC pre-closing verification, and accredited investor confirmation for PSA execution require linking the purchase agreement buyer to a tracked owner entity. Inves' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Owner .

ind:transactionOfferId rdf:type rdf:Property ;
    rdfs:label 'Transaction Offer Id' ;
    rdfs:comment 'Foreign key linking to transaction.offer. Business justification: A purchase agreement (PSA) is the formal contractual document that formalizes an accepted offer. The PSA is directly derived from the accepted offer terms. Adding transaction_offer_id to purchase_agre' ;
    rdfs:domain ind:PurchaseAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offer .

ind:actualClosingDate rdf:type rdf:Property ;
    rdfs:label 'Actual Closing Date' ;
    rdfs:comment 'The actual date on which the property transaction closed and title was transferred. Populated upon successful closing; null if not yet closed.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appraisalContingencyDate rdf:type rdf:Property ;
    rdfs:label 'Appraisal Contingency Date' ;
    rdfs:comment 'The deadline by which a formal property appraisal must be completed and the appraisal contingency resolved. Protects the buyer if the appraised value is below the contract price.' ;
    rdfs:domain ind:PurchaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appraisalContingencyFlag rdf:type rdf:Property ;
    rdfs:label 'Appraisal Contingency Flag' ;
    rdfs:comment 'Indicates whether the purchase agreement includes an appraisal contingency (True = appraisal contingency is present and active).' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contingencyStatus rdf:type rdf:Property ;
    rdfs:label 'Contingency Status' ;
    rdfs:comment 'Overall status of all contingencies in the purchase agreement. Tracks whether contingencies are pending resolution, have been waived by the buyer, satisfied, exercised to terminate, or have expired.' ;
    rdfs:domain ind:PurchaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractPrice rdf:type rdf:Property ;
    rdfs:label 'Contract Price' ;
    rdfs:comment 'The final negotiated and agreed purchase price as recorded in the executed PSA, which may differ from the initial offer price following negotiations.' ;
    rdfs:domain ind:PurchaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Down Payment Amount' ;
    rdfs:comment 'The equity portion of the purchase price to be paid by the buyer at closing, calculated as contract price minus loan amount.' ;
    rdfs:domain ind:PurchaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dueDiligenceStartDate rdf:type rdf:Property ;
    rdfs:label 'Due Diligence Start Date' ;
    rdfs:comment 'The start date of the contractual due diligence period during which the buyer may conduct inspections, environmental reviews, title searches, and financial analysis.' ;
    rdfs:domain ind:PurchaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:environmentalContingencyDate rdf:type rdf:Property ;
    rdfs:label 'Environmental Contingency Date' ;
    rdfs:comment 'The deadline by which environmental due diligence (Phase I/II ESA) must be completed and the environmental contingency resolved.' ;
    rdfs:domain ind:PurchaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financingContingencyDate rdf:type rdf:Property ;
    rdfs:label 'Financing Contingency Date' ;
    rdfs:comment 'The deadline by which the buyer must secure mortgage or financing commitment. If financing is not secured by this date, the buyer may terminate the agreement per contingency terms.' ;
    rdfs:domain ind:PurchaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financingContingencyFlag rdf:type rdf:Property ;
    rdfs:label 'Financing Contingency Flag' ;
    rdfs:comment 'Indicates whether the purchase agreement includes a financing contingency (True = financing contingency is present and active).' ;
    rdfs:domain ind:PurchaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionContingencyDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Contingency Date' ;
    rdfs:comment 'The deadline by which the buyer must complete physical property inspections and either waive or exercise the inspection contingency.' ;
    rdfs:domain ind:PurchaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionContingencyFlag rdf:type rdf:Property ;
    rdfs:label 'Inspection Contingency Flag' ;
    rdfs:comment 'Indicates whether the purchase agreement includes a physical inspection contingency (True = inspection contingency is present and active).' ;
    rdfs:domain ind:PurchaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latestAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Latest Amendment Date' ;
    rdfs:comment 'The date of the most recent amendment or addendum executed against this purchase agreement.' ;
    rdfs:domain ind:PurchaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerPrice rdf:type rdf:Property ;
    rdfs:label 'Offer Price' ;
    rdfs:comment 'The initial purchase price offered by the buyer as stated in the purchase agreement or Letter of Intent (LOI), in the transaction currency.' ;
    rdfs:domain ind:PurchaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:psaNumber rdf:type rdf:Property ;
    rdfs:label 'Psa Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned to the executed Purchase and Sale Agreement (PSA), used for cross-system identification and legal reference.' ;
    rdfs:domain ind:PurchaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saleOfHomeContingency rdf:type rdf:Property ;
    rdfs:label 'Sale Of Home Contingency' ;
    rdfs:comment 'Indicates whether the purchase agreement includes a contingency requiring the buyer to sell their existing property before this transaction can close (True = contingency present).' ;
    rdfs:domain ind:PurchaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetClosingDate rdf:type rdf:Property ;
    rdfs:label 'Target Closing Date' ;
    rdfs:comment 'The contractually agreed target date for closing the property transaction and transferring title, as specified in the PSA.' ;
    rdfs:domain ind:PurchaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:zoningContingencyFlag rdf:type rdf:Property ;
    rdfs:label 'Zoning Contingency Flag' ;
    rdfs:comment 'Indicates whether the purchase agreement includes a zoning or entitlement contingency, allowing the buyer to terminate if required zoning approvals are not obtained.' ;
    rdfs:domain ind:PurchaseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:buyerBrokerCommission rdf:type rdf:Property ;
    rdfs:label 'Buyer Broker Commission' ;
    rdfs:comment 'Portion of the total brokerage commission allocated to the buyer\'s broker (cooperating broker) at closing.' ;
    rdfs:domain ind:ClosingStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buyerCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Buyer Credit Amount' ;
    rdfs:comment 'Total monetary credits applied in favor of the buyer at closing, including lender credits, prorated rents, and security deposit transfers from seller to buyer.' ;
    rdfs:domain ind:ClosingStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capRateAtClosing rdf:type rdf:Property ;
    rdfs:label 'Cap Rate At Closing' ;
    rdfs:comment 'Implied capitalization rate at the time of closing, calculated as the property\'s net operating income (NOI) divided by the gross sale price. Core investment performance metric for CRE transactions.' ;
    rdfs:domain ind:ClosingStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashToClose rdf:type rdf:Property ;
    rdfs:label 'Cash To Close' ;
    rdfs:comment 'Total cash amount the buyer must bring to closing, calculated as the gross sale price less the new loan amount, earnest money deposit, and buyer credits, plus buyer-side closing costs and prorations.' ;
    rdfs:domain ind:ClosingStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closingStatus rdf:type rdf:Property ;
    rdfs:label 'Closing Status' ;
    rdfs:comment 'Current lifecycle state of the closing statement. DRAFT indicates preparation; PENDING indicates awaiting execution; EXECUTED indicates signed by all parties; FUNDED indicates funds disbursed; RECORDED indicates deed recorded with county; VOIDED indicates cancelled.' ;
    rdfs:domain ind:ClosingStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costarPropertyCode rdf:type rdf:Property ;
    rdfs:label 'Costar Property Code' ;
    rdfs:comment 'CoStar Suite unique property identifier enabling integration with CoStar comparable sales and market analytics data for benchmarking this transaction against market comps.' ;
    rdfs:domain ind:ClosingStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earnestMoneyDeposit rdf:type rdf:Property ;
    rdfs:label 'Earnest Money Deposit' ;
    rdfs:comment 'Good-faith deposit paid by the buyer at contract execution, credited against the purchase price at closing. Held in escrow until closing or contract termination.' ;
    rdfs:domain ind:ClosingStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escrowNumber rdf:type rdf:Property ;
    rdfs:label 'Escrow Number' ;
    rdfs:comment 'Unique escrow file number assigned by the title company or escrow agent to track this closing transaction through the settlement process.' ;
    rdfs:domain ind:ClosingStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossSalePrice rdf:type rdf:Property ;
    rdfs:label 'Gross Sale Price' ;
    rdfs:comment 'The total contracted purchase price for the property as agreed between buyer and seller before any adjustments, prorations, or credits. The top-line transaction value on the closing statement.' ;
    rdfs:domain ind:ClosingStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isReoTransaction rdf:type rdf:Property ;
    rdfs:label 'Is Reo Transaction' ;
    rdfs:comment 'Indicates whether this closing involves a Real Estate Owned (REO) property — a property acquired by a lender through foreclosure. REO transactions have distinct pricing, disclosure, and title requirements.' ;
    rdfs:domain ind:ClosingStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:listingBrokerCommission rdf:type rdf:Property ;
    rdfs:label 'Listing Broker Commission' ;
    rdfs:comment 'Portion of the total brokerage commission allocated to the listing (seller\'s) broker at closing.' ;
    rdfs:domain ind:ClosingStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loanPayoffAmount rdf:type rdf:Property ;
    rdfs:label 'Loan Payoff Amount' ;
    rdfs:comment 'Total amount required to fully satisfy and discharge the seller\'s existing mortgage(s) or deed(s) of trust at closing, including outstanding principal, accrued interest, and prepayment penalties.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netProceedsToSeller rdf:type rdf:Property ;
    rdfs:label 'Net Proceeds To Seller' ;
    rdfs:comment 'Final net amount disbursed to the seller at closing after deducting loan payoffs, commissions, transfer taxes, title fees, prorations, and all other seller-side charges from the gross sale price. The authoritative seller disbursement figure.' ;
    rdfs:domain ind:ClosingStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newLoanAmount rdf:type rdf:Property ;
    rdfs:label 'New Loan Amount' ;
    rdfs:comment 'Principal amount of the new mortgage or financing obtained by the buyer to fund the acquisition, as reflected on the closing statement. Used to compute Loan-to-Value (LTV) ratio.' ;
    rdfs:domain ind:ClosingStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prorationAmount rdf:type rdf:Property ;
    rdfs:label 'Proration Amount' ;
    rdfs:comment 'Net proration adjustment on the closing statement covering property taxes, HOA dues, prepaid rents, and utility charges apportioned between buyer and seller based on the closing date. Positive value indicates net credit to buyer; negative indicates net debit.' ;
    rdfs:domain ind:ClosingStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Recording Fee Amount' ;
    rdfs:comment 'Fees paid to the county recorder or register of deeds for recording the deed, mortgage, and other closing instruments in the public record.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salePricePsf rdf:type rdf:Property ;
    rdfs:label 'Sale Price Psf' ;
    rdfs:comment 'Gross sale price divided by the property\'s net leasable area (NLA) or gross leasable area (GLA), expressed in price per square foot (PSF). Key comparable sales metric used in CoStar and appraisal analysis.' ;
    rdfs:domain ind:ClosingStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sellerCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Seller Credit Amount' ;
    rdfs:comment 'Total monetary credits granted by the seller to the buyer at closing, including repair credits, closing cost concessions, and tenant improvement (TI) allowances negotiated in the purchase agreement.' ;
    rdfs:domain ind:ClosingStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Fee Amount' ;
    rdfs:comment 'Fee charged by the title company or escrow agent for conducting the closing and settlement services, separate from title insurance premiums.' ;
    rdfs:domain ind:ClosingStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:titleInsurancePremium rdf:type rdf:Property ;
    rdfs:label 'Title Insurance Premium' ;
    rdfs:comment 'Total premium paid for owner\'s and/or lender\'s title insurance policies at closing, protecting against title defects, liens, and encumbrances. Governed by ALTA standards.' ;
    rdfs:domain ind:ClosingStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCommissionAmount rdf:type rdf:Property ;
    rdfs:label 'Total Commission Amount' ;
    rdfs:comment 'Total brokerage commission paid at closing, typically expressed as a percentage of the gross sale price and split between listing and buyer\'s brokers. Charged to the seller on the closing statement.' ;
    rdfs:domain ind:ClosingStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:titleSearchId rdf:type rdf:Property ;
    rdfs:label 'Title Search Id' ;
    rdfs:comment 'Unique system-generated identifier for the title search record. Primary key for the title_search data product within the transaction domain.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TitleSearch .

ind:chainOfTitleYears rdf:type rdf:Property ;
    rdfs:label 'Chain Of Title Years' ;
    rdfs:comment 'Number of years of ownership history examined in the title search, representing the depth of the chain-of-title review (e.g., 40 years, 60 years).' ;
    rdfs:domain ind:TitleSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commitmentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Commitment Expiry Date' ;
    rdfs:comment 'Date on which the title commitment expires if closing has not occurred, after which a new or updated commitment must be issued.' ;
    rdfs:domain ind:TitleSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageAmount rdf:type rdf:Property ;
    rdfs:label 'Coverage Amount' ;
    rdfs:comment 'Total dollar amount of coverage provided under the title insurance policy, typically equal to the purchase price for an owner\'s policy or the loan amount for a loan policy.' ;
    rdfs:domain ind:TitleSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageCurrency rdf:type rdf:Property ;
    rdfs:label 'Coverage Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the title insurance coverage amount (e.g., USD).' ;
    rdfs:domain ind:TitleSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deedBookReference rdf:type rdf:Property ;
    rdfs:label 'Deed Book Reference' ;
    rdfs:comment 'Public records reference for the most recent deed in the chain of title, including deed book/volume number and page number as recorded in the county recorder\'s office.' ;
    rdfs:domain ind:TitleSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:easementCount rdf:type rdf:Property ;
    rdfs:label 'Easement Count' ;
    rdfs:comment 'Number of easements identified on the property, including utility easements, access easements, drainage easements, and conservation easements that affect use or marketability of title.' ;
    rdfs:domain ind:TitleSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:encumbranceCount rdf:type rdf:Property ;
    rdfs:label 'Encumbrance Count' ;
    rdfs:comment 'Total number of encumbrances identified on the property title, including mortgages, deeds of trust, easements, covenants, conditions, and restrictions (CC&Rs).' ;
    rdfs:domain ind:TitleSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endorsements rdf:type rdf:Property ;
    rdfs:label 'Endorsements' ;
    rdfs:comment 'List of ALTA endorsements attached to the title insurance policy that expand or modify standard coverage (e.g., ALTA 3.1 Zoning, ALTA 9 Restrictions/Encroachments/Minerals, ALTA 22 Location). Stored as a comma-separated list of endorsement codes.' ;
    rdfs:domain ind:TitleSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionCount rdf:type rdf:Property ;
    rdfs:label 'Exception Count' ;
    rdfs:comment 'Number of standard and special exceptions listed in Schedule B of the title commitment or policy, representing matters excluded from title insurance coverage.' ;
    rdfs:domain ind:TitleSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exceptionNotes rdf:type rdf:Property ;
    rdfs:label 'Exception Notes' ;
    rdfs:comment 'Narrative description of material title exceptions and exclusions listed in Schedule B of the title commitment or policy, including specific encumbrances, easements, restrictions, and other matters not covered by the policy.' ;
    rdfs:domain ind:TitleSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:existingMortgageAmount rdf:type rdf:Property ;
    rdfs:label 'Existing Mortgage Amount' ;
    rdfs:comment 'Outstanding principal balance of existing mortgage(s) or deed(s) of trust encumbering the property as identified in the title search, which must be satisfied or assumed at closing.' ;
    rdfs:domain ind:TitleSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hoaLienFlag rdf:type rdf:Property ;
    rdfs:label 'Hoa Lien Flag' ;
    rdfs:comment 'Indicates whether any Homeowners Association (HOA) or condominium association liens for unpaid assessments were identified against the property during the title search.' ;
    rdfs:domain ind:TitleSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:judgmentLienAmount rdf:type rdf:Property ;
    rdfs:label 'Judgment Lien Amount' ;
    rdfs:comment 'Total dollar amount of judgment liens recorded against the property or current owner, identified during the title search and requiring resolution prior to clear title transfer.' ;
    rdfs:domain ind:TitleSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lienCount rdf:type rdf:Property ;
    rdfs:label 'Lien Count' ;
    rdfs:comment 'Total number of outstanding liens identified against the property during the title search, including tax liens, mechanic\'s liens, judgment liens, and HOA liens.' ;
    rdfs:domain ind:TitleSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lienSearchResult rdf:type rdf:Property ;
    rdfs:label 'Lien Search Result' ;
    rdfs:comment 'Summary result of the lien search conducted as part of the title examination, indicating whether any outstanding liens (tax liens, mechanic\'s liens, judgment liens, HOA liens) were discovered against the property.' ;
    rdfs:domain ind:TitleSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mechanicsLienAmount rdf:type rdf:Property ;
    rdfs:label 'Mechanics Lien Amount' ;
    rdfs:comment 'Total dollar amount of mechanic\'s liens or materialman\'s liens filed against the property by contractors or suppliers for unpaid construction or improvement work.' ;
    rdfs:domain ind:TitleSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ordered Timestamp' ;
    rdfs:comment 'Date and time when the title search was formally ordered from the title company or abstracting firm, marking the initiation of the title examination process.' ;
    rdfs:domain ind:TitleSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:premiumAmount rdf:type rdf:Property ;
    rdfs:label 'Premium Amount' ;
    rdfs:comment 'One-time premium paid for the title insurance policy, typically a function of the coverage amount and state-filed rate schedules.' ;
    rdfs:domain ind:TitleSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requirementsNotes rdf:type rdf:Property ;
    rdfs:label 'Requirements Notes' ;
    rdfs:comment 'Narrative description of Schedule B-I requirements that must be satisfied prior to closing for the title company to issue the final title insurance policy (e.g., payoff of existing mortgages, release of liens, execution of documents).' ;
    rdfs:domain ind:TitleSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchFromDate rdf:type rdf:Property ;
    rdfs:label 'Search From Date' ;
    rdfs:comment 'Start date of the chain-of-title period examined in the title search, establishing the historical depth of the title examination.' ;
    rdfs:domain ind:TitleSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:searchOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Search Order Number' ;
    rdfs:comment 'Externally-known order number assigned by the title company or abstracting firm when the title search was commissioned. Used for cross-referencing with the title company\'s records.' ;
    rdfs:domain ind:TitleSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchStatus rdf:type rdf:Property ;
    rdfs:label 'Search Status' ;
    rdfs:comment 'Current lifecycle status of the title search process, from initial order through commitment issuance and final policy delivery.' ;
    rdfs:domain ind:TitleSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchThroughDate rdf:type rdf:Property ;
    rdfs:label 'Search Through Date' ;
    rdfs:comment 'End date (effective date) of the title search examination period, representing the most recent date through which public records were reviewed.' ;
    rdfs:domain ind:TitleSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:searchType rdf:type rdf:Property ;
    rdfs:label 'Search Type' ;
    rdfs:comment 'Classification of the title search scope: full chain-of-title search, update/bring-down search for a prior search, or targeted lien or judgment search.' ;
    rdfs:domain ind:TitleSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyRequired rdf:type rdf:Property ;
    rdfs:label 'Survey Required' ;
    rdfs:comment 'Indicates whether an ALTA/NSPS land title survey is required as a condition of the title commitment or as a lender requirement prior to policy issuance.' ;
    rdfs:domain ind:TitleSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxLienAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Lien Amount' ;
    rdfs:comment 'Total dollar amount of outstanding property tax liens identified during the title search, representing delinquent taxes that must be resolved prior to or at closing.' ;
    rdfs:domain ind:TitleSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:titleAgentName rdf:type rdf:Property ;
    rdfs:label 'Title Agent Name' ;
    rdfs:comment 'Name of the title agent or title company acting as the issuing agent for the title insurance policy on behalf of the underwriter.' ;
    rdfs:domain ind:TitleSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:titleExaminerName rdf:type rdf:Property ;
    rdfs:label 'Title Examiner Name' ;
    rdfs:comment 'Name of the attorney or title examiner who conducted the title examination and certified the chain of title.' ;
    rdfs:domain ind:TitleSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deedTransferId rdf:type rdf:Property ;
    rdfs:label 'Deed Transfer Id' ;
    rdfs:comment 'Unique surrogate identifier for the deed transfer record in the lakehouse Silver layer. Primary key for this entity.' ;
    rdfs:domain ind:DeedTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exchange1031Id rdf:type rdf:Property ;
    rdfs:label 'Exchange 1031 Id' ;
    rdfs:comment 'Foreign key linking to transaction.exchange_1031. Business justification: deed_transfer has exchange_1031_flag (BOOLEAN) indicating the deed is part of a 1031 exchange. Normalizing this into a proper FK to exchange_1031 allows retrieval of full exchange details (QI name, de' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Exchange1031 .

ind:financingId rdf:type rdf:Property ;
    rdfs:label 'Financing Id' ;
    rdfs:comment 'Foreign key linking to transaction.financing. Business justification: deed_transfer records mortgage_amount as a denormalized field. Linking to the financing record normalizes the mortgage reference and allows retrieval of full loan terms (loan_type, lender, LTV, rate) ' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Financing .

ind:granteeLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Grantee Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to finance.legal_entity. Business justification: The grantee on a deed transfer is a legal entity required for deed recording, title vesting, FIRPTA withholding, and entity-level ownership tracking. grantee_name and grantee_entity_type are plain-tex' ;
    rdfs:domain ind:DeedTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:grantorOwnerId rdf:type rdf:Property ;
    rdfs:label 'Grantor Owner Id' ;
    rdfs:comment 'Foreign key linking to owner.owner. Business justification: Chain-of-title reporting, transfer tax compliance, and owner disposition history require linking the deed grantor to a tracked owner entity. Title examiners and compliance officers use this to verify ' ;
    rdfs:domain ind:DeedTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Owner .

ind:bookNumber rdf:type rdf:Property ;
    rdfs:label 'Book Number' ;
    rdfs:comment 'Official deed book or liber number assigned by the county recorder where the deed instrument is physically or digitally filed. Used in conjunction with page number for precise title search reference.' ;
    rdfs:domain ind:DeedTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchange1031Flag rdf:type rdf:Property ;
    rdfs:label 'Exchange 1031 Flag' ;
    rdfs:comment 'Indicates whether this deed transfer is part of a tax-deferred like-kind exchange under IRC Section 1031. When true, the transaction is subject to strict identification and exchange period deadlines and requires qualified intermediary documentation.' ;
    rdfs:domain ind:DeedTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:foreclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Foreclosure Flag' ;
    rdfs:comment 'Indicates whether this deed transfer resulted from a foreclosure proceeding (e.g., sheriff\'s deed, trustee\'s deed upon sale). Distinct from REO flag — foreclosure flag marks the transfer event itself, while REO flag marks lender-owned status.' ;
    rdfs:domain ind:DeedTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grantorEntityType rdf:type rdf:Property ;
    rdfs:label 'Grantor Entity Type' ;
    rdfs:comment 'Legal entity classification of the grantor. Determines applicable transfer tax exemptions, 1031 exchange eligibility, and FIRPTA withholding requirements for foreign sellers. [ENUM-REF-CANDIDATE: individual|corporation|llc|trust|partnership|government|reit|estate|other — promote to reference product]' ;
    rdfs:domain ind:DeedTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentNumber rdf:type rdf:Property ;
    rdfs:label 'Instrument Number' ;
    rdfs:comment 'Sequential instrument or reception number assigned by the recorder\'s office at the time of recording, distinct from the document number in jurisdictions that use both. Provides an alternative lookup key for title searches.' ;
    rdfs:domain ind:DeedTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlsTransactionCode rdf:type rdf:Property ;
    rdfs:label 'Mls Transaction Code' ;
    rdfs:comment 'Transaction identifier from the Multiple Listing Service (MLS) system associated with this deed transfer. Enables cross-referencing with MLS comparable sales data and CoStar Suite for market analytics and CMA reporting.' ;
    rdfs:domain ind:DeedTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mortgageAmount rdf:type rdf:Property ;
    rdfs:label 'Mortgage Amount' ;
    rdfs:comment 'Principal amount of the mortgage or deed of trust loan recorded concurrently with the deed transfer. Used for LTV calculation, DSCR analysis, and CMBS/RMBS portfolio reporting.' ;
    rdfs:domain ind:DeedTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notaryCommissionExpiry rdf:type rdf:Property ;
    rdfs:label 'Notary Commission Expiry' ;
    rdfs:comment 'Expiration date of the notary public\'s commission at the time of deed execution. Validates that the notarization was performed by a duly commissioned notary, which is required for deed recordability.' ;
    rdfs:domain ind:DeedTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notaryName rdf:type rdf:Property ;
    rdfs:label 'Notary Name' ;
    rdfs:comment 'Name of the notary public who acknowledged the grantor\'s signature on the deed instrument. Required for deed validity in most US jurisdictions and referenced in ALTA title review.' ;
    rdfs:domain ind:DeedTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pageNumber rdf:type rdf:Property ;
    rdfs:label 'Page Number' ;
    rdfs:comment 'Page number within the deed book where the recorded deed instrument begins. Together with book number, provides the complete recorder\'s reference citation for chain-of-title research.' ;
    rdfs:domain ind:DeedTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricePerSqf rdf:type rdf:Property ;
    rdfs:label 'Price Per Sqf' ;
    rdfs:comment 'Sale price expressed on a per-square-foot (PSF) basis, calculated as consideration amount divided by the property\'s gross leasable area (GLA) or building area. Key metric for comparable sales analysis (CMA), CoStar benchmarking, and investment underwriting.' ;
    rdfs:domain ind:DeedTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reoFlag rdf:type rdf:Property ;
    rdfs:label 'Reo Flag' ;
    rdfs:comment 'Indicates whether this deed transfer involves a Real Estate Owned (REO) property — real property acquired by a lender through foreclosure. REO transactions require special handling for CMBS reporting and distressed asset analytics.' ;
    rdfs:domain ind:DeedTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transferType rdf:type rdf:Property ;
    rdfs:label 'Transfer Type' ;
    rdfs:comment 'Classification of the nature of the ownership transfer. Sale indicates a market-rate conveyance; Gift and Inheritance indicate non-monetary transfers; Exchange covers 1031 like-kind exchanges; Intra-entity covers transfers between related legal entities; Court Order covers judicial transfers. [ENUM-REF-CANDIDATE: sale|gift|inheritance|foreclosure|exchange|intra_entity|court_order|partition — promote to reference product]' ;
    rdfs:domain ind:DeedTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:borrowerLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Borrower Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to finance.legal_entity. Business justification: The borrowing legal entity on a loan is required for lender underwriting, DSCR covenant compliance, and entity-level debt reporting. financing has borrower_owner_id (owner domain) but the legal entity' ;
    rdfs:domain ind:Financing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:borrowerOwnerId rdf:type rdf:Property ;
    rdfs:label 'Borrower Owner Id' ;
    rdfs:comment 'Foreign key linking to owner.owner. Business justification: Portfolio-level debt exposure analysis, LTV monitoring across an owner\'s holdings, and lender covenant compliance reporting require linking each financing record to the borrowing owner entity. Investm' ;
    rdfs:domain ind:Financing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Owner .

ind:borrowingOwnershipStructureId rdf:type rdf:Property ;
    rdfs:label 'Borrowing Ownership Structure Id' ;
    rdfs:comment 'Foreign key linking to owner.ownership_structure. Business justification: Commercial real estate loans are typically made to an ownership structure (LLC, LP, DST) rather than an individual. borrowing_ownership_structure_id supports loan covenant compliance, entity-level deb' ;
    rdfs:domain ind:Financing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OwnershipStructure .

ind:maintenanceCapexProjectId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Capex Project Id' ;
    rdfs:comment 'Foreign key linking to maintenance.capex_project. Business justification: Construction loans, renovation financing, and bridge loans are directly tied to specific CAPEX projects. Lenders and borrowers track loan draws against CAPEX project milestones. This link enables cons' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapexProject .

ind:annualDebtService rdf:type rdf:Property ;
    rdfs:label 'Annual Debt Service' ;
    rdfs:comment 'Total annual principal and interest payment obligation under the loan. Used as the denominator in DSCR calculations and for NOI/cash flow analysis in Argus Enterprise.' ;
    rdfs:domain ind:Financing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collateralDescription rdf:type rdf:Property ;
    rdfs:label 'Collateral Description' ;
    rdfs:comment 'Narrative description of the collateral pledged to secure the loan, including property address, legal description, or portfolio of properties for cross-collateralized loans.' ;
    rdfs:domain ind:Financing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escrowReserveAmount rdf:type rdf:Property ;
    rdfs:label 'Escrow Reserve Amount' ;
    rdfs:comment 'Total amount held in escrow reserve accounts (taxes, insurance, capital reserves) as required by the lender at the time of reporting.' ;
    rdfs:domain ind:Financing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extensionOptionCount rdf:type rdf:Property ;
    rdfs:label 'Extension Option Count' ;
    rdfs:comment 'Number of extension options available to the borrower to extend the loan maturity beyond the initial term, subject to conditions. Common in bridge and construction loans.' ;
    rdfs:domain ind:Financing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:financingStatus rdf:type rdf:Property ;
    rdfs:label 'Financing Status' ;
    rdfs:comment 'Current lifecycle state of the financing arrangement. Tracks progression from initial commitment through funding, assumption of existing debt, full payoff, or cancellation.' ;
    rdfs:domain ind:Financing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstPaymentDate rdf:type rdf:Property ;
    rdfs:label 'First Payment Date' ;
    rdfs:comment 'Date on which the first scheduled debt service payment (principal and/or interest) is due under the loan agreement.' ;
    rdfs:domain ind:Financing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fundingDate rdf:type rdf:Property ;
    rdfs:label 'Funding Date' ;
    rdfs:comment 'Date on which loan proceeds were disbursed to the borrower or escrow at closing. May differ from origination date for construction loans with draw schedules.' ;
    rdfs:domain ind:Financing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:indexRateType rdf:type rdf:Property ;
    rdfs:label 'Index Rate Type' ;
    rdfs:comment 'Benchmark interest rate index to which the floating rate is pegged for ARM or floating-rate loans (e.g., SOFR, Prime, Treasury). Null for fixed-rate instruments.' ;
    rdfs:domain ind:Financing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestOnlyPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Interest Only Period Months' ;
    rdfs:comment 'Number of months at the start of the loan term during which only interest payments are required, with no principal amortization. Applicable to IO and partial-IO loan structures.' ;
    rdfs:domain ind:Financing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isAssumption rdf:type rdf:Property ;
    rdfs:label 'Is Assumption' ;
    rdfs:comment 'Indicates whether this financing record represents the assumption of existing seller debt rather than new origination. True when the buyer assumes the seller\'s existing loan at closing.' ;
    rdfs:domain ind:Financing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lienPosition rdf:type rdf:Property ;
    rdfs:label 'Lien Position' ;
    rdfs:comment 'Priority position of the lender\'s lien on the collateral property. First lien has senior claim; mezzanine and subordinate positions carry higher risk and typically higher rates.' ;
    rdfs:domain ind:Financing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loanToCostRatio rdf:type rdf:Property ;
    rdfs:label 'Loan To Cost Ratio' ;
    rdfs:comment 'Ratio of the loan amount to the total project cost, used primarily for construction and development financing to assess lender exposure relative to total development spend.' ;
    rdfs:domain ind:Financing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loanType rdf:type rdf:Property ;
    rdfs:label 'Loan Type' ;
    rdfs:comment 'Classification of the financing instrument by structure and purpose (e.g., ARM, FRM, CMBS, bridge, construction, mezzanine, CMBS, RMBS, HUD, SBA 504). [ENUM-REF-CANDIDATE: ARM|FRM|CMBS|RMBS|bridge|construction|mezzanine|HUD|SBA_504|hard_money — promote to reference product]' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originationFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Origination Fee Amount' ;
    rdfs:comment 'Upfront fee charged by the lender at loan origination, expressed as a dollar amount. Included in closing cost analysis and CAPEX tracking.' ;
    rdfs:domain ind:Financing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originationFeePct rdf:type rdf:Property ;
    rdfs:label 'Origination Fee Pct' ;
    rdfs:comment 'Origination fee expressed as a percentage of the loan amount (e.g., 0.01 = 1 point). Used alongside the dollar amount for benchmarking and deal economics analysis.' ;
    rdfs:domain ind:Financing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pmiMonthlyAmount rdf:type rdf:Property ;
    rdfs:label 'Pmi Monthly Amount' ;
    rdfs:comment 'Monthly PMI premium amount payable when PMI is required. Null when pmi_required is False.' ;
    rdfs:domain ind:Financing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pmiRequired rdf:type rdf:Property ;
    rdfs:label 'Pmi Required' ;
    rdfs:comment 'Indicates whether Private Mortgage Insurance (PMI) is required for this loan, typically triggered when LTV exceeds 80% on residential transactions.' ;
    rdfs:domain ind:Financing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escrowAccountId rdf:type rdf:Property ;
    rdfs:label 'Escrow Account Id' ;
    rdfs:comment 'Foreign key linking to transaction.escrow_account. Business justification: exchange_1031 has qi_account_number (STRING) referencing the qualified intermediary account. The QI holds exchange proceeds in an escrow account. Linking exchange_1031 to escrow_account normalizes the' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EscrowAccount .

ind:primaryExchangeAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Exchange Asset Id' ;
    rdfs:comment 'Reference to the property being sold/transferred as part of the 1031 exchange (the \'relinquished\' or \'down-leg\' property). Links to the property master record for asset details, address, and valuation history.' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:relinquishedAppraisalId rdf:type rdf:Property ;
    rdfs:label 'Relinquished Appraisal Id' ;
    rdfs:comment 'Foreign key linking to valuation.appraisal. Business justification: IRS Form 8824 and 1031 exchange compliance require documented fair market value of the relinquished property. The appraisal establishes FMV for deferred gain and basis calculations. Role-prefix \'relin' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Appraisal .

ind:replacementCompliancePermitId rdf:type rdf:Property ;
    rdfs:label 'Replacement Compliance Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: 1031 exchange replacement properties must have valid certificates of occupancy and permits. Role-prefixed \'replacement_\' distinguishes this from the relinquished property permit. Linking exchange_1031' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:replacementDevProjectId rdf:type rdf:Property ;
    rdfs:label 'Replacement Dev Project Id' ;
    rdfs:comment 'Foreign key linking to development.dev_project. Business justification: 1031 exchange compliance: replacement property is often a development project. Exchange timeline (45-day ID, 180-day close) must be tracked against dev_project completion schedule. Role-prefixed \'repl' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DevProject .

ind:replacementFinancingId rdf:type rdf:Property ;
    rdfs:label 'Replacement Financing Id' ;
    rdfs:comment 'Foreign key linking to transaction.financing. Business justification: exchange_1031 tracks replacement_mortgage_balance as a denormalized field. Linking to the financing record for the replacement property loan normalizes this reference and provides access to full loan ' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Financing .

ind:replacementPurchaseAgreementId rdf:type rdf:Property ;
    rdfs:label 'Replacement Purchase Agreement Id' ;
    rdfs:comment 'Foreign key linking to transaction.purchase_agreement. Business justification: A 1031 exchange involves both a relinquished property sale and a replacement property acquisition. The replacement property purchase is governed by a purchase_agreement. Adding replacement_purchase_ag' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseAgreement .

ind:taxpayerLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Taxpayer Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to finance.legal_entity. Business justification: IRS Form 8824 filing for a 1031 exchange requires identification of the taxpayer as a legal entity for deferred gain calculation and entity-level tax reporting. exchange_1031 has taxpayer_ein as a pla' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:bootAmount rdf:type rdf:Property ;
    rdfs:label 'Boot Amount' ;
    rdfs:comment 'Total boot received in the exchange — any non-like-kind property or cash received that does not qualify for tax deferral. Includes cash boot (net cash received) and mortgage boot (net debt relief). Boot triggers immediate taxable gain recognition.' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bootType rdf:type rdf:Property ;
    rdfs:label 'Boot Type' ;
    rdfs:comment 'Classification of boot received in the exchange: none (fully deferred), cash (net cash received), mortgage_relief (net debt reduction), or mixed (combination of cash and mortgage relief). Determines the nature of taxable gain recognition.' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferredGain rdf:type rdf:Property ;
    rdfs:label 'Deferred Gain' ;
    rdfs:comment 'The portion of realized gain deferred for tax purposes under IRS Section 1031 — calculated as realized gain minus recognized gain. This deferred gain reduces the tax basis of the replacement property and is recognized upon future disposition.' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeAgreementDate rdf:type rdf:Property ;
    rdfs:label 'Exchange Agreement Date' ;
    rdfs:comment 'The date on which the formal exchange agreement was executed between the taxpayer and the Qualified Intermediary (QI). Must be entered into before the taxpayer transfers the relinquished property to qualify as a valid delayed exchange.' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exchangeClosingDeadline rdf:type rdf:Property ;
    rdfs:label 'Exchange Closing Deadline' ;
    rdfs:comment 'The IRS-mandated deadline by which the taxpayer must close on the replacement property — exactly 180 calendar days from the relinquished property closing date (or the due date of the tax return, whichever is earlier). Failure disqualifies the exchange.' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exchangeNumber rdf:type rdf:Property ;
    rdfs:label 'Exchange Number' ;
    rdfs:comment 'Externally-known business identifier for the 1031 exchange transaction, typically assigned by the Qualified Intermediary (QI) or internal deal tracking system. Used for cross-referencing with QI documentation and IRS Form 8824 filings.' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeStatus rdf:type rdf:Property ;
    rdfs:label 'Exchange Status' ;
    rdfs:comment 'Current lifecycle status of the 1031 exchange transaction. Tracks progression from initiation through identification period, replacement property acquisition, and final IRS compliance determination. [ENUM-REF-CANDIDATE: initiated|identification_period|replacement_pending|completed|failed|cancelled — promote to reference product if additional statuses are needed]' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeType rdf:type rdf:Property ;
    rdfs:label 'Exchange Type' ;
    rdfs:comment 'Classification of the 1031 exchange structure: simultaneous (same-day swap), delayed (Starker exchange with QI), reverse (replacement acquired before relinquishment), or improvement/construction (build-to-suit exchange). Determines applicable IRS deadlines and QI escrow requirements.' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:form8824Filed rdf:type rdf:Property ;
    rdfs:label 'Form 8824 Filed' ;
    rdfs:comment 'Indicates whether IRS Form 8824 (Like-Kind Exchanges) has been filed with the IRS for this exchange transaction. Required for all 1031 exchanges in the tax year of the relinquished property transfer.' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:form8824FiledDate rdf:type rdf:Property ;
    rdfs:label 'Form 8824 Filed Date' ;
    rdfs:comment 'The date on which IRS Form 8824 was filed with the IRS for this exchange. Used for compliance tracking and audit trail purposes.' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:identificationDeadline rdf:type rdf:Property ;
    rdfs:label 'Identification Deadline' ;
    rdfs:comment 'The IRS-mandated deadline by which the taxpayer must identify potential replacement properties — exactly 45 calendar days from the relinquished property closing date. Failure to meet this deadline disqualifies the exchange.' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:identificationRule rdf:type rdf:Property ;
    rdfs:label 'Identification Rule' ;
    rdfs:comment 'The IRS identification rule elected by the taxpayer for designating replacement properties: three_property (up to 3 properties regardless of value), two_hundred_percent (any number of properties with combined FMV ≤ 200% of relinquished FMV), or ninety_five_percent (any number if 95% of total FMV is actually acquired).' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedDate rdf:type rdf:Property ;
    rdfs:label 'Initiated Date' ;
    rdfs:comment 'The date on which the 1031 exchange was formally initiated, typically the closing date of the relinquished property sale. This date anchors the 45-day identification deadline and 180-day closing deadline under IRS rules.' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:irsComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Irs Compliance Status' ;
    rdfs:comment 'Current IRS compliance determination for the 1031 exchange: pending (exchange in progress), compliant (all IRS requirements met), non_compliant (deadline missed or disqualifying event), or under_review (IRS audit or inquiry in progress).' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:likeKindConfirmed rdf:type rdf:Property ;
    rdfs:label 'Like Kind Confirmed' ;
    rdfs:comment 'Indicates whether both the relinquished and replacement properties have been confirmed as qualifying like-kind real property under IRS Section 1031. Must be True for the exchange to qualify for tax deferral.' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qiAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Qi Account Number' ;
    rdfs:comment 'Bank account or escrow account number held by the Qualified Intermediary (QI) where exchange proceeds from the relinquished property sale are deposited and held pending acquisition of the replacement property.' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qiFundBalance rdf:type rdf:Property ;
    rdfs:label 'Qi Fund Balance' ;
    rdfs:comment 'Current balance of exchange proceeds held by the Qualified Intermediary (QI) in escrow. Tracks available funds for replacement property acquisition. Decreases as replacement property closings occur.' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qiName rdf:type rdf:Property ;
    rdfs:label 'Qi Name' ;
    rdfs:comment 'Legal name of the Qualified Intermediary (QI) — the independent third party that holds exchange proceeds and facilitates the transfer to prevent constructive receipt by the taxpayer. Required for delayed, reverse, and improvement exchanges.' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:realizedGain rdf:type rdf:Property ;
    rdfs:label 'Realized Gain' ;
    rdfs:comment 'Total economic gain realized on the relinquished property sale, calculated as the amount realized (sale price minus selling expenses) less the adjusted tax basis. Represents the total gain before deferral. Reported on IRS Form 8824 Part III.' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recognizedGain rdf:type rdf:Property ;
    rdfs:label 'Recognized Gain' ;
    rdfs:comment 'Portion of the realized gain that is taxable in the current tax year — equal to the lesser of the realized gain or the boot received. If no boot is received, recognized gain is zero. Reported on IRS Form 8824 Part III.' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relinquishedAdjustedBasis rdf:type rdf:Property ;
    rdfs:label 'Relinquished Adjusted Basis' ;
    rdfs:comment 'The taxpayer\'s adjusted cost basis in the relinquished property at the time of exchange, accounting for original acquisition cost, capital improvements, and accumulated depreciation. Critical input for deferred gain calculation on IRS Form 8824.' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relinquishedClosingDate rdf:type rdf:Property ;
    rdfs:label 'Relinquished Closing Date' ;
    rdfs:comment 'The actual closing/settlement date on which the relinquished property was transferred to the buyer. This is the trigger date for the 45-day and 180-day IRS exchange deadlines.' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relinquishedMortgageBalance rdf:type rdf:Property ;
    rdfs:label 'Relinquished Mortgage Balance' ;
    rdfs:comment 'Outstanding mortgage or debt balance on the relinquished property at the time of closing. Mortgage relief received by the taxpayer is treated as boot received and may trigger taxable gain recognition.' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relinquishedPropertyAddress rdf:type rdf:Property ;
    rdfs:label 'Relinquished Property Address' ;
    rdfs:comment 'Full street address of the relinquished (down-leg) property being exchanged. Captured directly on the exchange record for IRS Form 8824 reporting and audit trail purposes, independent of the property master record.' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relinquishedSalePrice rdf:type rdf:Property ;
    rdfs:label 'Relinquished Sale Price' ;
    rdfs:comment 'Gross sale price received for the relinquished property at closing, as reported on the settlement statement. Used as the basis for deferred gain calculation and boot determination on IRS Form 8824.' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replacementBasis rdf:type rdf:Property ;
    rdfs:label 'Replacement Basis' ;
    rdfs:comment 'The carryover tax basis assigned to the replacement property after the exchange, calculated as the replacement property\'s cost minus the deferred gain. This basis is used for future depreciation calculations and gain recognition upon eventual sale.' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replacementClosingDate rdf:type rdf:Property ;
    rdfs:label 'Replacement Closing Date' ;
    rdfs:comment 'The actual closing/settlement date on which the replacement property was acquired. Must occur on or before the 180-day exchange closing deadline to qualify for tax deferral.' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:replacementMortgageBalance rdf:type rdf:Property ;
    rdfs:label 'Replacement Mortgage Balance' ;
    rdfs:comment 'New mortgage or debt assumed on the replacement property at acquisition. Mortgage assumed by the taxpayer offsets boot received from mortgage relief on the relinquished property in the net boot calculation.' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replacementPropertyAddress rdf:type rdf:Property ;
    rdfs:label 'Replacement Property Address' ;
    rdfs:comment 'Full street address of the primary replacement (up-leg) property acquired in the exchange. Captured directly on the exchange record for IRS Form 8824 reporting and audit trail purposes.' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementPropertyCount rdf:type rdf:Property ;
    rdfs:label 'Replacement Property Count' ;
    rdfs:comment 'Number of replacement properties formally identified within the 45-day identification period. Must comply with the elected identification rule (e.g., maximum 3 under the three-property rule). Used for IRS compliance validation.' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replacementPurchasePrice rdf:type rdf:Property ;
    rdfs:label 'Replacement Purchase Price' ;
    rdfs:comment 'Gross purchase price paid for the replacement property at closing. Must equal or exceed the relinquished property sale price for full gain deferral. Used in boot calculation and IRS Form 8824 Part III reporting.' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sellingExpenses rdf:type rdf:Property ;
    rdfs:label 'Selling Expenses' ;
    rdfs:comment 'Total transaction costs incurred in selling the relinquished property, including brokerage commissions, title fees, legal fees, and transfer taxes. Reduces the amount realized for gain calculation purposes on IRS Form 8824.' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxpayerEin rdf:type rdf:Property ;
    rdfs:label 'Taxpayer Ein' ;
    rdfs:comment 'Federal Employer Identification Number (EIN) or Tax Identification Number (TIN) of the entity executing the exchange. Required for IRS Form 8824 filing and tax compliance reporting.' ;
    rdfs:domain ind:Exchange1031 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDiligenceItemId rdf:type rdf:Property ;
    rdfs:label 'Due Diligence Item Id' ;
    rdfs:comment 'Unique system-generated identifier for each due diligence task or finding record associated with a property transaction.' ;
    rdfs:domain ind:DueDiligenceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leaseClauseId rdf:type rdf:Property ;
    rdfs:label 'Lease Clause Id' ;
    rdfs:comment 'Foreign key linking to lease.clause. Business justification: Specific lease clauses (co-tenancy, exclusivity, termination options, ROFO/ROFR) are individually flagged as due diligence items with distinct risk ratings and price adjustment recommendations. Linkin' ;
    rdfs:domain ind:DueDiligenceItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Clause .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'Actual date on which the due diligence task was completed and findings were documented. Null if the item has not yet been completed.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contingencyRemovalDate rdf:type rdf:Property ;
    rdfs:label 'Contingency Removal Date' ;
    rdfs:comment 'Date on which the PSA contingency tied to this due diligence item was formally removed or waived by the buyer.' ;
    rdfs:domain ind:DueDiligenceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:findingSummary rdf:type rdf:Property ;
    rdfs:label 'Finding Summary' ;
    rdfs:comment 'Concise narrative summary of the key findings, observations, or conclusions from the due diligence task. Used in investment committee reports and PSA contingency resolution documentation.' ;
    rdfs:domain ind:DueDiligenceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goNoGoRecommendation rdf:type rdf:Property ;
    rdfs:label 'Go No Go Recommendation' ;
    rdfs:comment 'Investment committee recommendation derived from this due diligence item: go (proceed to closing), no-go (abort transaction), conditional go (proceed subject to remediation or price adjustment), or pending (awaiting further findings).' ;
    rdfs:domain ind:DueDiligenceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentCommitteeFlag rdf:type rdf:Property ;
    rdfs:label 'Investment Committee Flag' ;
    rdfs:comment 'Indicates whether this due diligence item has been escalated to the investment committee for review and decision, typically triggered by a red risk rating or a no-go or conditional-go recommendation.' ;
    rdfs:domain ind:DueDiligenceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemCategory rdf:type rdf:Property ;
    rdfs:label 'Item Category' ;
    rdfs:comment 'High-level classification of the due diligence workstream. Covers environmental (Phase I/II), structural/MEP inspection, zoning and entitlement review, ALTA survey, title search, financial audit, rent roll verification, estoppel review, tenant interview, legal/regulatory, and insurance. [ENUM-REF-CANDIDATE: environmental|structural_mep|zoning_entitlement|title_survey|financial_audit|rent_roll|estoppel|tenant_interview|legal_regulatory|insurance — promote to reference product]' ;
    rdfs:domain ind:DueDiligenceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemDescription rdf:type rdf:Property ;
    rdfs:label 'Item Description' ;
    rdfs:comment 'Detailed narrative describing the scope, objective, and methodology of the due diligence task, including any specific areas of focus or contractual requirements from the Purchase and Sale Agreement (PSA).' ;
    rdfs:domain ind:DueDiligenceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemName rdf:type rdf:Property ;
    rdfs:label 'Item Name' ;
    rdfs:comment 'Short descriptive title of the due diligence task (e.g., \'Phase I Environmental Site Assessment\', \'ALTA Survey\', \'Rent Roll Verification\', \'Structural and MEP Inspection\').' ;
    rdfs:domain ind:DueDiligenceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemNumber rdf:type rdf:Property ;
    rdfs:label 'Item Number' ;
    rdfs:comment 'Externally-visible alphanumeric identifier for the due diligence item, used in investment committee reports, PSA contingency schedules, and vendor communications (e.g., DD-2024-00123).' ;
    rdfs:domain ind:DueDiligenceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemStatus rdf:type rdf:Property ;
    rdfs:label 'Item Status' ;
    rdfs:comment 'Current workflow state of the due diligence task within the pre-closing process. Drives investment committee reporting and PSA contingency tracking.' ;
    rdfs:domain ind:DueDiligenceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemType rdf:type rdf:Property ;
    rdfs:label 'Item Type' ;
    rdfs:comment 'Operational type of the due diligence task — whether it is a physical inspection, document review, financial audit, land survey, stakeholder interview, title/lien search, or risk assessment. [ENUM-REF-CANDIDATE: inspection|review|audit|survey|interview|search|assessment — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DueDiligenceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leedBreeamStatus rdf:type rdf:Property ;
    rdfs:label 'Leed Breeam Status' ;
    rdfs:comment 'Current green building certification status relevant to the due diligence review, including LEED and BREEAM ratings. Supports ESG compliance reporting and investment committee assessment. [ENUM-REF-CANDIDATE: not_applicable|pending|certified|silver|gold|platinum|breeam_pass|breeam_good|breeam_very_good — promote to reference product]' ;
    rdfs:domain ind:DueDiligenceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseIiRequired rdf:type rdf:Property ;
    rdfs:label 'Phase Ii Required' ;
    rdfs:comment 'Indicates whether a Phase II Environmental Site Assessment is required based on findings from the Phase I ESA. Applicable only to environmental due diligence items.' ;
    rdfs:domain ind:DueDiligenceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceAdjustmentRecommended rdf:type rdf:Property ;
    rdfs:label 'Price Adjustment Recommended' ;
    rdfs:comment 'Indicates whether the findings from this due diligence item support a recommendation to renegotiate the purchase price (e.g., due to environmental remediation costs, deferred maintenance, or title defects).' ;
    rdfs:domain ind:DueDiligenceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:psaContingencyType rdf:type rdf:Property ;
    rdfs:label 'Psa Contingency Type' ;
    rdfs:comment 'Type of PSA contingency that this due diligence item is associated with. Tracks which contractual contingencies must be resolved or waived prior to closing. [ENUM-REF-CANDIDATE: financing|inspection|environmental|title|zoning|appraisal|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DueDiligenceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognizedEnvironmentalCondition rdf:type rdf:Property ;
    rdfs:label 'Recognized Environmental Condition' ;
    rdfs:comment 'ASTM-standard classification of environmental conditions identified during Phase I ESA: none (no REC), REC (Recognized Environmental Condition), CREC (Controlled REC), or HREC (Historical REC). Drives Phase II ESA decision.' ;
    rdfs:domain ind:DueDiligenceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedPriceAdjustment rdf:type rdf:Property ;
    rdfs:label 'Recommended Price Adjustment' ;
    rdfs:comment 'Dollar amount of the recommended purchase price reduction or credit based on findings from this due diligence item. Used in deal economics renegotiation and investment committee reporting.' ;
    rdfs:domain ind:DueDiligenceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remediationDescription rdf:type rdf:Property ;
    rdfs:label 'Remediation Description' ;
    rdfs:comment 'Detailed description of the required remediation actions, including scope of work, responsible party, and any regulatory requirements (e.g., EPA cleanup plan, structural repair specification, title defect cure).' ;
    rdfs:domain ind:DueDiligenceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyName rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Name' ;
    rdfs:comment 'Name of the individual, firm, or vendor responsible for completing this due diligence task (e.g., environmental consultant, structural engineer, title company, legal counsel, internal asset manager).' ;
    rdfs:domain ind:DueDiligenceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyType rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Type' ;
    rdfs:comment 'Classification of the party responsible for the due diligence task — internal team member, external third-party vendor, legal counsel, title company, lender representative, or broker.' ;
    rdfs:domain ind:DueDiligenceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:titleExceptionCount rdf:type rdf:Property ;
    rdfs:label 'Title Exception Count' ;
    rdfs:comment 'Number of title exceptions, encumbrances, or defects identified during the title search or ALTA survey. A non-zero count triggers further legal review and potential price adjustment.' ;
    rdfs:domain ind:DueDiligenceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorReportReference rdf:type rdf:Property ;
    rdfs:label 'Vendor Report Reference' ;
    rdfs:comment 'External report or document reference number assigned by the vendor (e.g., Phase I ESA report number, ALTA survey job number, structural inspection report ID). Enables cross-referencing with vendor deliverables.' ;
    rdfs:domain ind:DueDiligenceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoningComplianceConfirmed rdf:type rdf:Property ;
    rdfs:label 'Zoning Compliance Confirmed' ;
    rdfs:comment 'Indicates whether the property\'s current use and intended use have been confirmed as compliant with applicable zoning regulations and entitlement approvals.' ;
    rdfs:domain ind:DueDiligenceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dealPartyId rdf:type rdf:Property ;
    rdfs:label 'Deal Party Id' ;
    rdfs:comment 'Primary key for deal_party' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DealParty .

ind:eventRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Event Registration Id' ;
    rdfs:comment 'Foreign key linking to marketing.event_registration. Business justification: Event-to-transaction attribution: real estate investor days and open houses generate deal parties. Linking deal_party to event_registration enables tracking which events produced transacting buyers/in' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EventRegistration .

ind:offerId rdf:type rdf:Property ;
    rdfs:label 'Offer Id' ;
    rdfs:comment 'Foreign key linking to transaction.offer. Business justification: Offers are submitted by parties (buyer, buyer agent) and received by parties (seller, listing agent). While deal_party links to property_sale, adding offer_id provides direct linkage to the specific o' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offer .

ind:commissionSplitPct rdf:type rdf:Property ;
    rdfs:label 'Commission Split Pct' ;
    rdfs:comment 'The percentage of the total transaction commission allocated to this party, expressed as a decimal (e.g., 0.0250 = 2.50%). Applicable for broker and agent roles. Drives commission disbursement and 1099-MISC reporting.' ;
    rdfs:domain ind:DealParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firptaWithholdingAmount rdf:type rdf:Property ;
    rdfs:label 'Firpta Withholding Amount' ;
    rdfs:comment 'Dollar amount withheld from disposition proceeds under FIRPTA for foreign sellers. Applicable only when is_foreign_person is true. Reported on IRS Form 8288.' ;
    rdfs:domain ind:DealParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:is1099sReportable rdf:type rdf:Property ;
    rdfs:label 'Is 1099s Reportable' ;
    rdfs:comment 'Indicates whether this party\'s proceeds from the real estate transaction must be reported to the IRS on Form 1099-S. Typically true for sellers receiving proceeds above the IRS threshold.' ;
    rdfs:domain ind:DealParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isForeignPerson rdf:type rdf:Property ;
    rdfs:label 'Is Foreign Person' ;
    rdfs:comment 'Indicates whether the party is a foreign person or entity subject to FIRPTA (Foreign Investment in Real Property Tax Act) withholding requirements. When true, triggers mandatory IRS withholding on disposition proceeds.' ;
    rdfs:domain ind:DealParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryParty rdf:type rdf:Property ;
    rdfs:label 'Is Primary Party' ;
    rdfs:comment 'Indicates whether this party is the primary representative for their role in the transaction (e.g., lead buyer among multiple buyers, primary lender). Used to resolve reporting and notification routing when multiple parties share the same role.' ;
    rdfs:domain ind:DealParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lenderLoanNumber rdf:type rdf:Property ;
    rdfs:label 'Lender Loan Number' ;
    rdfs:comment 'Loan reference number assigned by the lender party for the financing associated with this transaction. Applicable when party_role is \'lender\'. Used for CMBS/RMBS tracking and debt instrument reconciliation.' ;
    rdfs:domain ind:DealParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participationStatus rdf:type rdf:Property ;
    rdfs:label 'Participation Status' ;
    rdfs:comment 'Current lifecycle status of this party\'s involvement in the transaction. Tracks whether the party is actively engaged, has withdrawn, is pending confirmation, has confirmed participation, or has declined.' ;
    rdfs:domain ind:DealParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyEmail rdf:type rdf:Property ;
    rdfs:label 'Party Email' ;
    rdfs:comment 'Primary email address for the party used for transaction correspondence, DocuSign CLM execution, and closing coordination.' ;
    rdfs:domain ind:DealParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyName rdf:type rdf:Property ;
    rdfs:label 'Party Name' ;
    rdfs:comment 'Full legal name of the party as it appears on the purchase agreement, closing statement, or title instrument. Used for 1099-S reporting, ALTA title commitments, and deed preparation.' ;
    rdfs:domain ind:DealParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyPhone rdf:type rdf:Property ;
    rdfs:label 'Party Phone' ;
    rdfs:comment 'Primary contact phone number for the party for transaction coordination and closing communications.' ;
    rdfs:domain ind:DealParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyRole rdf:type rdf:Property ;
    rdfs:label 'Party Role' ;
    rdfs:comment 'The functional role this party plays in the transaction. Drives commission allocation, 1099-S reporting obligations, and deal workflow routing. [ENUM-REF-CANDIDATE: buyer|seller|buyers_broker|sellers_broker|lender|title_company|escrow_agent|qualified_intermediary|attorney|appraiser|guarantor — promote to reference product]' ;
    rdfs:domain ind:DealParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proceedsAmount rdf:type rdf:Property ;
    rdfs:label 'Proceeds Amount' ;
    rdfs:comment 'Gross proceeds allocated to this party from the transaction closing, as reported on IRS Form 1099-S. Applicable to seller parties. Used for tax reporting and settlement reconciliation.' ;
    rdfs:domain ind:DealParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qiExchangeRef rdf:type rdf:Property ;
    rdfs:label 'Qi Exchange Ref' ;
    rdfs:comment 'Reference number assigned by the Qualified Intermediary (QI) for a 1031 like-kind exchange transaction. Applicable when party_role is \'qualified_intermediary\'. Required for IRS Section 1031 compliance tracking and exchange deadline monitoring.' ;
    rdfs:domain ind:DealParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureDate rdf:type rdf:Property ;
    rdfs:label 'Signature Date' ;
    rdfs:comment 'Date on which this party executed (signed) the primary transaction document (purchase agreement, closing statement, or deed). Used for contract formation analysis and closing timeline tracking.' ;
    rdfs:domain ind:DealParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signingAuthority rdf:type rdf:Property ;
    rdfs:label 'Signing Authority' ;
    rdfs:comment 'The capacity in which the party is authorized to execute transaction documents. Determines document execution requirements and legal validity of signatures on purchase agreements, deeds, and closing statements.' ;
    rdfs:domain ind:DealParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Date' ;
    rdfs:comment 'Date on which this party formally withdrew from or was removed from the transaction. Populated when participation_status is \'withdrawn\' or \'declined\'. Used for deal timeline and contingency analysis.' ;
    rdfs:domain ind:DealParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parentOfferId rdf:type rdf:Property ;
    rdfs:label 'Parent Offer Id' ;
    rdfs:comment 'Self-referencing identifier linking a counter-offer or revised offer back to the original offer record. Enables reconstruction of the full negotiation chain for a given property transaction.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offer .

ind:buyerAgentLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Buyer Agent License Number' ;
    rdfs:comment 'The state-issued real estate license number of the buyer\'s agent. Required for regulatory compliance and commission disbursement verification.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerAgentName rdf:type rdf:Property ;
    rdfs:label 'Buyer Agent Name' ;
    rdfs:comment 'The name of the licensed real estate agent or broker representing the buyer in this transaction. Used for commission split calculations and co-broker agreement tracking.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competingOfferCount rdf:type rdf:Property ;
    rdfs:label 'Competing Offer Count' ;
    rdfs:comment 'The number of competing offers disclosed by the seller or known to the listing agent at the time this offer was submitted. Used in multi-offer analytics and negotiation strategy reporting.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competingOfferFlag rdf:type rdf:Property ;
    rdfs:label 'Competing Offer Flag' ;
    rdfs:comment 'Indicates whether the seller has disclosed the existence of one or more competing offers on the same property at the time this offer was submitted. Supports multi-offer scenario management and deal pipeline analytics.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:counterOfferNumber rdf:type rdf:Property ;
    rdfs:label 'Counter Offer Number' ;
    rdfs:comment 'Sequential counter indicating which round of negotiation this offer record represents (1 = original offer, 2 = first counter, 3 = second counter, etc.). Supports negotiation history tracking.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationCeilingPrice rdf:type rdf:Property ;
    rdfs:label 'Escalation Ceiling Price' ;
    rdfs:comment 'The maximum purchase price the buyer is willing to pay under the escalation clause. The offer will not escalate beyond this ceiling regardless of competing offers.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Clause Flag' ;
    rdfs:comment 'Indicates whether the offer contains an escalation clause that automatically increases the offer price above competing offers up to a defined ceiling. Critical for multi-offer scenario management.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationIncrementAmount rdf:type rdf:Property ;
    rdfs:label 'Escalation Increment Amount' ;
    rdfs:comment 'The dollar amount by which the offer price will automatically escalate above a competing offer when an escalation clause is active. Null when escalation_clause_flag is false.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financingContingencyAmount rdf:type rdf:Property ;
    rdfs:label 'Financing Contingency Amount' ;
    rdfs:comment 'The maximum loan amount the buyer is seeking to finance. If the buyer cannot secure financing up to this amount, the contingency allows withdrawal without forfeiting earnest money. Supports LTV (Loan-to-Value) ratio analysis.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionContingencyDays rdf:type rdf:Property ;
    rdfs:label 'Inspection Contingency Days' ;
    rdfs:comment 'The number of calendar days from offer acceptance during which the buyer has the right to conduct property inspections and withdraw without penalty if findings are unsatisfactory.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionContingencyEndDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Contingency End Date' ;
    rdfs:comment 'The absolute calendar date on which the inspection contingency period expires. Derived from offer acceptance date plus inspection_contingency_days; stored explicitly for operational tracking.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerDate rdf:type rdf:Property ;
    rdfs:label 'Offer Date' ;
    rdfs:comment 'The calendar date on which the buyer formally submitted the purchase offer. Principal business event date for the offer lifecycle.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerNumber rdf:type rdf:Property ;
    rdfs:label 'Offer Number' ;
    rdfs:comment 'Externally-visible business identifier for the offer, used in correspondence, Salesforce CRM deal tracking, and closing documentation. Format: OFF-YYYYMMDD-NNNN.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerStatus rdf:type rdf:Property ;
    rdfs:label 'Offer Status' ;
    rdfs:comment 'Current lifecycle state of the purchase offer. Tracks progression from initial submission through counter, acceptance, rejection, or buyer withdrawal. Drives deal pipeline reporting in Salesforce CRM.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preApprovalAmount rdf:type rdf:Property ;
    rdfs:label 'Pre Approval Amount' ;
    rdfs:comment 'The maximum loan amount for which the buyer has received a lender pre-approval letter. Validates the buyer\'s financial capacity relative to the offer price.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proofOfFundsVerified rdf:type rdf:Property ;
    rdfs:label 'Proof Of Funds Verified' ;
    rdfs:comment 'Indicates whether the buyer has provided and the listing agent has verified proof of funds or mortgage pre-approval sufficient to support the offer price. Critical qualifier for offer strength assessment.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proposedClosingDate rdf:type rdf:Property ;
    rdfs:label 'Proposed Closing Date' ;
    rdfs:comment 'The target closing date proposed by the buyer in the offer. Used for deal timeline planning and pipeline forecasting in Salesforce CRM.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:saleContingencyFlag rdf:type rdf:Property ;
    rdfs:label 'Sale Contingency Flag' ;
    rdfs:comment 'Indicates whether the offer is contingent on the buyer successfully selling their existing property before closing. A key risk factor in multi-offer scenario evaluation.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'The externally-known escrow account number assigned by the escrow holder or title company (e.g., Yardi Voyager trust account reference). Used for reconciliation with AP/AR trust accounts.' ;
    rdfs:domain ind:EscrowAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earnestMoneyReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Earnest Money Received Date' ;
    rdfs:comment 'The date on which the earnest money deposit was received and confirmed in the escrow account.' ;
    rdfs:domain ind:EscrowAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:earnestMoneyStatus rdf:type rdf:Property ;
    rdfs:label 'Earnest Money Status' ;
    rdfs:comment 'Current disposition status of the earnest money deposit: pending (not yet received), received (in escrow), applied (credited toward purchase price at closing), refunded (returned to buyer), or forfeited (retained by seller upon buyer default).' ;
    rdfs:domain ind:EscrowAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escrowHolderName rdf:type rdf:Property ;
    rdfs:label 'Escrow Holder Name' ;
    rdfs:comment 'Legal name of the escrow holder entity (title company, escrow company, or attorney) responsible for managing and disbursing funds. Corresponds to the escrow_company field in property_sale.' ;
    rdfs:domain ind:EscrowAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escrowOfficerEmail rdf:type rdf:Property ;
    rdfs:label 'Escrow Officer Email' ;
    rdfs:comment 'Email address of the escrow officer for communication and document delivery purposes.' ;
    rdfs:domain ind:EscrowAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escrowOfficerName rdf:type rdf:Property ;
    rdfs:label 'Escrow Officer Name' ;
    rdfs:comment 'Full name of the individual escrow officer or closing agent at the escrow holder entity who is responsible for managing this account.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escrowOfficerPhone rdf:type rdf:Property ;
    rdfs:label 'Escrow Officer Phone' ;
    rdfs:comment 'Direct phone number of the escrow officer for transaction coordination.' ;
    rdfs:domain ind:EscrowAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impoundInsuranceAmount rdf:type rdf:Property ;
    rdfs:label 'Impound Insurance Amount' ;
    rdfs:comment 'Amount held in impound/reserve within the escrow account for property insurance premium obligations. Applicable for impound-type escrow accounts.' ;
    rdfs:domain ind:EscrowAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impoundTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Impound Tax Amount' ;
    rdfs:comment 'Amount held in impound/reserve within the escrow account for property tax obligations. Applicable for impound-type escrow accounts associated with mortgage servicing.' ;
    rdfs:domain ind:EscrowAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Last Reconciliation Date' ;
    rdfs:comment 'The most recent date on which the escrow account balance was reconciled against the Yardi Voyager trust account ledger and bank statement. Critical for SOX compliance and audit trail.' ;
    rdfs:domain ind:EscrowAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netProceedsAmount rdf:type rdf:Property ;
    rdfs:label 'Net Proceeds Amount' ;
    rdfs:comment 'The net amount to be disbursed to the seller after deducting loan payoffs, commissions, title fees, transfer taxes, and other closing costs from the purchase price.' ;
    rdfs:domain ind:EscrowAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingBalance rdf:type rdf:Property ;
    rdfs:label 'Opening Balance' ;
    rdfs:comment 'The initial fund balance at the time the escrow account was opened, typically representing the earnest money deposit or initial impound amount.' ;
    rdfs:domain ind:EscrowAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingDate rdf:type rdf:Property ;
    rdfs:label 'Opening Date' ;
    rdfs:comment 'The date on which the escrow account was formally opened and became active for receiving funds. Marks the start of the escrow lifecycle.' ;
    rdfs:domain ind:EscrowAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualifiedIntermediaryName rdf:type rdf:Property ;
    rdfs:label 'Qualified Intermediary Name' ;
    rdfs:comment 'Legal name of the qualified intermediary holding exchange proceeds for a 1031 exchange escrow. Required by IRS regulations to maintain tax-deferred status.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseAuthorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Release Authorization Status' ;
    rdfs:comment 'Current authorization status for fund release from escrow: pending (awaiting authorization), authorized (all parties have approved disbursement), partially_authorized (some disbursements approved), or rejected (authorization denied).' ;
    rdfs:domain ind:EscrowAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseConditions rdf:type rdf:Property ;
    rdfs:label 'Release Conditions' ;
    rdfs:comment 'Narrative description of the conditions that must be satisfied before escrow funds can be released or disbursed (e.g., clear title, financing approval, inspection sign-off, COO issuance). Sourced from DocuSign CLM escrow instructions.' ;
    rdfs:domain ind:EscrowAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:titleFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Title Fee Amount' ;
    rdfs:comment 'Total title insurance premium and title-related fees (search, examination, endorsements) to be disbursed from escrow at closing per the ALTA settlement statement.' ;
    rdfs:domain ind:EscrowAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDeposits rdf:type rdf:Property ;
    rdfs:label 'Total Deposits' ;
    rdfs:comment 'Cumulative sum of all funds deposited into the escrow account since opening, including earnest money, loan proceeds, and buyer closing funds.' ;
    rdfs:domain ind:EscrowAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDisbursements rdf:type rdf:Property ;
    rdfs:label 'Total Disbursements' ;
    rdfs:comment 'Cumulative sum of all funds disbursed from the escrow account since opening, including commissions, title fees, transfer taxes, loan payoffs, and net proceeds to seller.' ;
    rdfs:domain ind:EscrowAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yardiTrustAccountRef rdf:type rdf:Property ;
    rdfs:label 'Yardi Trust Account Ref' ;
    rdfs:comment 'The trust account reference number in Yardi Voyager AP/AR module used for reconciliation of escrow fund movements against the general ledger trust account.' ;
    rdfs:domain ind:EscrowAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escrowDisbursementId rdf:type rdf:Property ;
    rdfs:label 'Escrow Disbursement Id' ;
    rdfs:comment 'Unique system-generated identifier for each escrow disbursement record. Primary key for the escrow_disbursement data product within the transaction domain.' ;
    rdfs:domain ind:EscrowDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payoffLenderId rdf:type rdf:Property ;
    rdfs:label 'Payoff Lender Id' ;
    rdfs:comment 'Foreign key linking to finance.lender. Business justification: Loan payoff disbursements from escrow must identify the receiving lender for wire instructions, payoff confirmation, and lien release tracking. loan_payoff_lender_name is a plain-text denormalization ' ;
    rdfs:domain ind:EscrowDisbursement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lender .

ind:authorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Authorization Status' ;
    rdfs:comment 'Approval workflow status indicating whether the disbursement has been authorized by the required approving parties (e.g., escrow officer, title company, lender). Supports dual-control authorization requirements and SOX financial controls.' ;
    rdfs:domain ind:EscrowDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Authorization Timestamp' ;
    rdfs:comment 'Date and time when the disbursement was formally authorized by the approving party. Provides a precise audit trail event for SOX compliance and escrow reconciliation.' ;
    rdfs:domain ind:EscrowDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bankAccountNumberMasked rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number Masked' ;
    rdfs:comment 'Masked bank account number of the payee\'s receiving account, showing only the last four digits (e.g., ****1234). Stored for reconciliation and audit purposes without exposing full PCI-sensitive account data.' ;
    rdfs:domain ind:EscrowDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionBasisAmount rdf:type rdf:Property ;
    rdfs:label 'Commission Basis Amount' ;
    rdfs:comment 'The gross sale price or transaction value upon which the commission rate is applied to calculate the commission disbursement amount. Applicable when disbursement_type is \'commission\'. Supports commission audit and RESPA Section 8 compliance.' ;
    rdfs:domain ind:EscrowDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disbursementAmount rdf:type rdf:Property ;
    rdfs:label 'Disbursement Amount' ;
    rdfs:comment 'Gross monetary amount released from escrow to the payee in this disbursement event. Represents the base amount before any withholding or adjustments. Expressed in the transaction currency.' ;
    rdfs:domain ind:EscrowDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disbursementNotes rdf:type rdf:Property ;
    rdfs:label 'Disbursement Notes' ;
    rdfs:comment 'Free-text field for escrow officer or closing agent notes regarding special circumstances, conditions, or instructions associated with this disbursement. May include holdback conditions, lender instructions, or dispute notations.' ;
    rdfs:domain ind:EscrowDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementNumber rdf:type rdf:Property ;
    rdfs:label 'Disbursement Number' ;
    rdfs:comment 'Externally-visible alphanumeric reference number assigned to this disbursement by the escrow company or title company. Used for reconciliation with closing statements and Yardi Voyager AR/AP records.' ;
    rdfs:domain ind:EscrowDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementType rdf:type rdf:Property ;
    rdfs:label 'Disbursement Type' ;
    rdfs:comment 'Categorical classification of the nature of the disbursement. Identifies whether funds represent a brokerage commission, title/settlement fee, transfer tax, mortgage loan payoff, net sale proceeds to seller, recording fee, prorated property taxes, Tenant Improvement (TI) allowance, or other closing cost. [ENUM-REF-CANDIDATE: commission|title_fee|transfer_tax|loan_payoff|net_proceeds|recording_fee|prorated_taxes|tenant_improvement|other — promote to reference product]' ;
    rdfs:domain ind:EscrowDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdbackReleaseFlag rdf:type rdf:Property ;
    rdfs:label 'Holdback Release Flag' ;
    rdfs:comment 'Indicates whether this disbursement represents the release of a previously held-back escrow amount (True). Holdbacks are common in commercial transactions for repair escrows, environmental remediation reserves, or tenant improvement allowances.' ;
    rdfs:domain ind:EscrowDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:is1031ExchangeProceeds rdf:type rdf:Property ;
    rdfs:label 'Is 1031 Exchange Proceeds' ;
    rdfs:comment 'Indicates whether this disbursement represents proceeds being directed to a Qualified Intermediary (QI) as part of an IRS Section 1031 like-kind exchange. When True, funds must be held by the QI and not constructively received by the seller.' ;
    rdfs:domain ind:EscrowDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPostClosing rdf:type rdf:Property ;
    rdfs:label 'Is Post Closing' ;
    rdfs:comment 'Indicates whether this disbursement was made after the official closing date (True) or at closing (False). Post-closing disbursements may include holdback releases, prorated adjustments, or deferred commission payments.' ;
    rdfs:domain ind:EscrowDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loanPayoffReference rdf:type rdf:Property ;
    rdfs:label 'Loan Payoff Reference' ;
    rdfs:comment 'Lender-assigned loan number or payoff statement reference for the mortgage being satisfied by this disbursement. Used to confirm lien release and coordinate with title company for deed recording.' ;
    rdfs:domain ind:EscrowDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payeeName rdf:type rdf:Property ;
    rdfs:label 'Payee Name' ;
    rdfs:comment 'Full legal name of the individual, company, or institution receiving the disbursed funds. May be a broker, title company, lender, seller, buyer, government entity, or service provider. Required for closing statement reconciliation and 1099 reporting.' ;
    rdfs:domain ind:EscrowDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payeeTaxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Payee Tax Identification Number' ;
    rdfs:comment 'Federal Tax Identification Number (TIN), Employer Identification Number (EIN), or Social Security Number (SSN) of the payee. Required for IRS 1099-S real estate proceeds reporting and backup withholding compliance.' ;
    rdfs:domain ind:EscrowDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payeeType rdf:type rdf:Property ;
    rdfs:label 'Payee Type' ;
    rdfs:comment 'Classification of the payee entity receiving the disbursement. Distinguishes between brokers (commission recipients), lenders (loan payoff), sellers (net proceeds), buyers (refunds), title companies, government agencies (transfer tax), and other service providers. [ENUM-REF-CANDIDATE: broker|lender|seller|buyer|title_company|government|service_provider|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EscrowDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnDate rdf:type rdf:Property ;
    rdfs:label 'Return Date' ;
    rdfs:comment 'Date on which a disbursed amount was returned to the escrow account due to a failed payment, rejected wire, or stale check. Populated only when disbursement_status is \'returned\'. Triggers re-disbursement workflow.' ;
    rdfs:domain ind:EscrowDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transferTaxJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Transfer Tax Jurisdiction' ;
    rdfs:comment 'Name of the governmental jurisdiction (state, county, or municipality) to which transfer tax disbursements are remitted. Applicable when disbursement_type is \'transfer_tax\'. Required for tax compliance and regulatory reporting.' ;
    rdfs:domain ind:EscrowDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yardiDisbursementRef rdf:type rdf:Property ;
    rdfs:label 'Yardi Disbursement Ref' ;
    rdfs:comment 'Source system reference identifier from Yardi Voyager Accounts Payable or Accounts Receivable module corresponding to this disbursement record. Enables bi-directional traceability between the lakehouse silver layer and the operational system of record.' ;
    rdfs:domain ind:EscrowDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacedGuarantyId rdf:type rdf:Property ;
    rdfs:label 'Replaced Guaranty Id' ;
    rdfs:comment 'Self-referencing FK on guaranty (replaced_guaranty_id)' ;
    rdfs:domain ind:Guaranty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Guaranty .

ind:amountRecovered rdf:type rdf:Property ;
    rdfs:label 'Amount Recovered' ;
    rdfs:comment 'Total monetary amount actually recovered from the guarantor through enforcement, settlement, or voluntary payment. Used to calculate net credit loss on the lease.' ;
    rdfs:domain ind:Guaranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:burnDownApplicable rdf:type rdf:Property ;
    rdfs:label 'Burn Down Applicable' ;
    rdfs:comment 'Indicates whether the guaranty includes a contractual burn-down schedule under which the guaranteed amount reduces over time as the tenant demonstrates satisfactory lease performance.' ;
    rdfs:domain ind:Guaranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:burnDownIntervalMonths rdf:type rdf:Property ;
    rdfs:label 'Burn Down Interval Months' ;
    rdfs:comment 'Frequency in months at which the guaranteed amount is reduced per the burn-down schedule (e.g., 12 for annual reductions). Null if burn-down is not applicable.' ;
    rdfs:domain ind:Guaranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:burnDownReductionAmount rdf:type rdf:Property ;
    rdfs:label 'Burn Down Reduction Amount' ;
    rdfs:comment 'Fixed dollar amount by which the guaranteed exposure is reduced at each burn-down interval. Used when the burn-down is amount-based rather than percentage-based.' ;
    rdfs:domain ind:Guaranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:burnDownReductionPct rdf:type rdf:Property ;
    rdfs:label 'Burn Down Reduction Pct' ;
    rdfs:comment 'Percentage of the original guaranteed amount by which exposure is reduced at each burn-down interval. Used when the burn-down is percentage-based rather than fixed-amount-based. Stored as a decimal (e.g., 0.25 = 25%).' ;
    rdfs:domain ind:Guaranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:burnDownStartDate rdf:type rdf:Property ;
    rdfs:label 'Burn Down Start Date' ;
    rdfs:comment 'Date on which the guaranty burn-down schedule commences. Typically tied to a lease anniversary or a performance milestone such as rent payment history.' ;
    rdfs:domain ind:Guaranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentGuaranteedAmount rdf:type rdf:Property ;
    rdfs:label 'Current Guaranteed Amount' ;
    rdfs:comment 'Present outstanding guaranteed amount after applying any burn-down reductions, partial releases, or enforcement recoveries. Reflects the landlord\'s current credit risk exposure under this guaranty.' ;
    rdfs:domain ind:Guaranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enforcementDate rdf:type rdf:Property ;
    rdfs:label 'Enforcement Date' ;
    rdfs:comment 'Date on which the landlord formally initiated enforcement action against the guarantor (e.g., date of demand letter or filing of legal claim).' ;
    rdfs:domain ind:Guaranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enforcementStatus rdf:type rdf:Property ;
    rdfs:label 'Enforcement Status' ;
    rdfs:comment 'Current status of any enforcement action taken against the guarantor. \'demand_issued\' indicates a formal demand letter has been sent; \'litigation\' indicates legal proceedings are active; \'recovered\' indicates full or partial recovery has been achieved.' ;
    rdfs:domain ind:Guaranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialCovenantRequired rdf:type rdf:Property ;
    rdfs:label 'Financial Covenant Required' ;
    rdfs:comment 'Indicates whether the guaranty requires the guarantor to maintain specified financial covenants (e.g., minimum net worth, minimum liquidity ratio, maximum leverage). Critical for ongoing credit risk monitoring.' ;
    rdfs:domain ind:Guaranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialStatementFrequency rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Frequency' ;
    rdfs:comment 'Required frequency at which the guarantor must deliver financial statements to the landlord for covenant compliance monitoring.' ;
    rdfs:domain ind:Guaranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodGuyNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Good Guy Notice Period Days' ;
    rdfs:comment 'Number of days of advance written notice the tenant must provide to the landlord to trigger the good-guy guaranty release clause. Applicable only when guaranty_type is \'good_guy\'.' ;
    rdfs:domain ind:Guaranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:goodGuyVacateDate rdf:type rdf:Property ;
    rdfs:label 'Good Guy Vacate Date' ;
    rdfs:comment 'Actual date on which the tenant vacated the premises and surrendered possession, triggering the good-guy guaranty release. Populated upon confirmed surrender.' ;
    rdfs:domain ind:Guaranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guaranteedMonths rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Months' ;
    rdfs:comment 'Number of months of lease obligations covered by the guaranty. Used for limited and rolling guaranty types where exposure is defined by a time window rather than a fixed dollar amount.' ;
    rdfs:domain ind:Guaranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:guarantorLegalName rdf:type rdf:Property ;
    rdfs:label 'Guarantor Legal Name' ;
    rdfs:comment 'Full legal name of the guarantor as stated in the executed guaranty instrument. For corporate guarantors, this is the registered entity name; for individuals, the full legal name as on government-issued ID.' ;
    rdfs:domain ind:Guaranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guarantyStatus rdf:type rdf:Property ;
    rdfs:label 'Guaranty Status' ;
    rdfs:comment 'Current lifecycle status of the guaranty obligation. \'active\' indicates the guaranty is in force; \'burned_down\' indicates the guaranteed amount has been reduced per schedule; \'enforced\' indicates a claim has been made against the guarantor; \'released\' indicates the landlord has formally discharged the guarantor.' ;
    rdfs:domain ind:Guaranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guarantyType rdf:type rdf:Property ;
    rdfs:label 'Guaranty Type' ;
    rdfs:comment 'Classification of the guaranty structure. \'full\' covers all lease obligations for the full term; \'limited\' caps exposure by amount or period; \'good_guy\' releases guarantor upon tenant vacating and providing notice; \'rolling\' covers a fixed rolling window of rent; \'springing\' activates only upon a defined trigger event. [ENUM-REF-CANDIDATE: full|limited|good_guy|rolling|springing|burn_down|completion — promote to reference product]' ;
    rdfs:domain ind:Guaranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastFinancialStatementDate rdf:type rdf:Property ;
    rdfs:label 'Last Financial Statement Date' ;
    rdfs:comment 'Date of the most recently received guarantor financial statement. Used to track compliance with financial reporting covenants and assess current creditworthiness.' ;
    rdfs:domain ind:Guaranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minNetWorthCovenant rdf:type rdf:Property ;
    rdfs:label 'Min Net Worth Covenant' ;
    rdfs:comment 'Minimum net worth the guarantor must maintain throughout the guaranty term as a financial covenant condition. Breach of this threshold may constitute a guaranty default or trigger a springing guaranty.' ;
    rdfs:domain ind:Guaranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:personalGuaranteeFlag rdf:type rdf:Property ;
    rdfs:label 'Personal Guarantee Flag' ;
    rdfs:comment 'Indicates whether this guaranty is a personal guarantee provided by an individual (principal, officer, or owner of the tenant entity) as opposed to a corporate or entity guarantee. Drives different enforcement and credit risk treatment.' ;
    rdfs:domain ind:Guaranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releaseReason rdf:type rdf:Property ;
    rdfs:label 'Release Reason' ;
    rdfs:comment 'Business reason for the formal release of the guarantor. Tracks whether release was triggered by lease expiry, early termination, good-guy clause activation, full burn-down, landlord waiver, or lease assignment to a creditworthy assignee.' ;
    rdfs:domain ind:Guaranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:springingTriggerDescription rdf:type rdf:Property ;
    rdfs:label 'Springing Trigger Description' ;
    rdfs:comment 'Narrative description of the condition(s) that activate a springing guaranty (e.g., tenant credit rating downgrade below investment grade, tenant default on another obligation, change of control). Applicable only when guaranty_type is \'springing\'.' ;
    rdfs:domain ind:Guaranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yardiGuarantyRef rdf:type rdf:Property ;
    rdfs:label 'Yardi Guaranty Ref' ;
    rdfs:comment 'Source system reference identifier for this guaranty record in Yardi Voyager. Used for cross-system reconciliation between the Silver layer and the operational system of record.' ;
    rdfs:domain ind:Guaranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorScreeningId rdf:type rdf:Property ;
    rdfs:label 'Prior Screening Id' ;
    rdfs:comment 'Self-referencing FK on screening (prior_screening_id)' ;
    rdfs:domain ind:Screening ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Screening .

ind:adverseActionNoticeDate rdf:type rdf:Property ;
    rdfs:label 'Adverse Action Notice Date' ;
    rdfs:comment 'Date on which the adverse action notice was issued to the applicant. Must be documented for FCRA compliance. Null if adverse_action_required is false or notice has not yet been sent.' ;
    rdfs:domain ind:Screening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adverseActionReasonCodes rdf:type rdf:Property ;
    rdfs:label 'Adverse Action Reason Codes' ;
    rdfs:comment 'Pipe-delimited list of standardized reason codes provided on the adverse action notice explaining the basis for denial or conditional approval (e.g., insufficient income, derogatory credit history, prior eviction). Required by FCRA Section 615 for consumer-report-based decisions.' ;
    rdfs:domain ind:Screening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adverseActionRequired rdf:type rdf:Property ;
    rdfs:label 'Adverse Action Required' ;
    rdfs:comment 'Indicates whether an adverse action notice is required to be issued to the applicant based on the screening result. Triggered when a consumer report (credit, criminal, eviction) contributed to a denial or conditional approval decision, as mandated by FCRA Section 615.' ;
    rdfs:domain ind:Screening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicantConsentObtained rdf:type rdf:Property ;
    rdfs:label 'Applicant Consent Obtained' ;
    rdfs:comment 'Indicates whether written authorization was obtained from the applicant prior to initiating the background screening, as required by FCRA Section 604(b). A prerequisite for any consumer report pull.' ;
    rdfs:domain ind:Screening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentDate rdf:type rdf:Property ;
    rdfs:label 'Consent Date' ;
    rdfs:comment 'Date on which the applicant provided written authorization for the background screening. Required for FCRA compliance documentation and GDPR lawful basis records.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditCheckResult rdf:type rdf:Property ;
    rdfs:label 'Credit Check Result' ;
    rdfs:comment 'Result of the credit bureau check component of the screening. Reflects whether the applicant\'s credit profile meets the property\'s minimum credit qualification criteria. Note: detailed credit data is stored in tenant.credit_profile.' ;
    rdfs:domain ind:Screening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditScoreAtScreening rdf:type rdf:Property ;
    rdfs:label 'Credit Score At Screening' ;
    rdfs:comment 'Credit score returned by the screening vendor at the time of this specific screening event. Captured as a point-in-time snapshot for audit and adverse action documentation purposes, independent of the ongoing credit profile record.' ;
    rdfs:domain ind:Screening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:criminalCheckResult rdf:type rdf:Property ;
    rdfs:label 'Criminal Check Result' ;
    rdfs:comment 'Result of the criminal background check component of the screening. A review_required result indicates records were found that require individualized assessment per HUD guidance before an adverse action decision is made.' ;
    rdfs:domain ind:Screening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criminalCheckScope rdf:type rdf:Property ;
    rdfs:label 'Criminal Check Scope' ;
    rdfs:comment 'Geographic scope of the criminal background check performed. Indicates whether the search covered county, state, national, or international criminal records databases, which affects the comprehensiveness of the result.' ;
    rdfs:domain ind:Screening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criteriaVersion rdf:type rdf:Property ;
    rdfs:label 'Criteria Version' ;
    rdfs:comment 'Version identifier of the standardized screening criteria policy applied to this screening event. Ensures consistent, documented criteria enforcement across all applications and supports fair housing audit trails.' ;
    rdfs:domain ind:Screening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentVerificationResult rdf:type rdf:Property ;
    rdfs:label 'Employment Verification Result' ;
    rdfs:comment 'Result of the employment verification check confirming the applicant\'s current employer, employment status, and income. Supports income-to-rent ratio qualification and FCRA-compliant underwriting.' ;
    rdfs:domain ind:Screening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evictionCheckResult rdf:type rdf:Property ;
    rdfs:label 'Eviction Check Result' ;
    rdfs:comment 'Result of the eviction history database search. Captures whether prior eviction filings or judgments were found. A fail or review_required result is a key risk indicator in the underwriting decision.' ;
    rdfs:domain ind:Screening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fairHousingReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Fair Housing Review Flag' ;
    rdfs:comment 'Indicates whether this screening result was flagged for individualized fair housing review, typically triggered when criminal history or other protected-class-adjacent findings require case-by-case assessment per HUD guidance before an adverse action decision.' ;
    rdfs:domain ind:Screening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fcraCompliant rdf:type rdf:Property ;
    rdfs:label 'Fcra Compliant' ;
    rdfs:comment 'Indicates whether all FCRA procedural requirements were met for this screening event, including permissible purpose documentation, applicant disclosure, authorization, and adverse action notice (if applicable). Critical for regulatory audit and litigation defense.' ;
    rdfs:domain ind:Screening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:identityVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Identity Verification Method' ;
    rdfs:comment 'Method used to verify the applicant\'s identity during the screening process. Captures whether SSN, ITIN, government-issued ID, or passport was used, supporting FCRA compliance documentation.' ;
    rdfs:domain ind:Screening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityVerificationResult rdf:type rdf:Property ;
    rdfs:label 'Identity Verification Result' ;
    rdfs:comment 'Result of the identity verification check, including SSN/ITIN validation and government-issued ID confirmation. A fail or unable-to-verify result typically blocks lease approval and may trigger adverse action.' ;
    rdfs:domain ind:Screening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomeToRentRatio rdf:type rdf:Property ;
    rdfs:label 'Income To Rent Ratio' ;
    rdfs:comment 'Ratio of the applicant\'s verified gross monthly income to the proposed monthly rent, calculated at the time of screening. Typically a minimum of 2.5x–3x is required. Used as a primary qualification criterion.' ;
    rdfs:domain ind:Screening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:individualizedAssessmentConducted rdf:type rdf:Property ;
    rdfs:label 'Individualized Assessment Conducted' ;
    rdfs:comment 'Indicates whether an individualized assessment was performed for this applicant prior to an adverse action based on criminal history, as required by HUD guidance to avoid disparate impact under the Fair Housing Act.' ;
    rdfs:domain ind:Screening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:landlordReferenceCount rdf:type rdf:Property ;
    rdfs:label 'Landlord Reference Count' ;
    rdfs:comment 'Number of prior landlord references contacted and verified during the screening process. Supports audit documentation of reference check thoroughness.' ;
    rdfs:domain ind:Screening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:landlordReferenceResult rdf:type rdf:Property ;
    rdfs:label 'Landlord Reference Result' ;
    rdfs:comment 'Result of the prior landlord reference check, verifying rental payment history, lease compliance, and tenancy conduct with previous landlords. A key qualitative input to the overall screening determination.' ;
    rdfs:domain ind:Screening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallResult rdf:type rdf:Property ;
    rdfs:label 'Overall Result' ;
    rdfs:comment 'Composite pass/fail determination across all screening check types performed. A conditional pass may indicate approval subject to additional conditions such as a co-signer or increased security deposit. Drives the underwriting decision in the application workflow.' ;
    rdfs:domain ind:Screening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Report Expiry Date' ;
    rdfs:comment 'Date after which the screening report is considered stale and a new screening must be ordered before a lease can be executed. Typically 30–90 days from completion date per company policy and FCRA guidelines.' ;
    rdfs:domain ind:Screening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportUrl rdf:type rdf:Property ;
    rdfs:label 'Report Url' ;
    rdfs:comment 'Secure URL or storage reference to the full screening report document returned by the vendor. Access is restricted to authorized personnel. Supports document retrieval for adverse action, audit, and underwriting review.' ;
    rdfs:domain ind:Screening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'Calendar date on which the screening order was submitted to the vendor. Establishes the start of the screening timeline and is used to calculate turnaround time and report expiry.' ;
    rdfs:domain ind:Screening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:screeningStatus rdf:type rdf:Property ;
    rdfs:label 'Screening Status' ;
    rdfs:comment 'Current lifecycle status of the screening order. Tracks progression from initial request through vendor processing to final determination. Drives workflow routing in the application qualification process.' ;
    rdfs:domain ind:Screening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sexOffenderCheckResult rdf:type rdf:Property ;
    rdfs:label 'Sex Offender Check Result' ;
    rdfs:comment 'Result of the national sex offender registry (NSOPW) check. A fail result requires individualized assessment and documented adverse action notice per FCRA and HUD fair housing guidance before denial.' ;
    rdfs:domain ind:Screening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendor rdf:type rdf:Property ;
    rdfs:label 'Vendor' ;
    rdfs:comment 'Name of the third-party background screening service provider used to conduct the checks (e.g., RentPrep, TransUnion SmartMove, Experian RentBureau, CoreLogic SafeRent). Required for FCRA adverse action notices and vendor audit trails.' ;
    rdfs:domain ind:Screening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorOrderCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Order Code' ;
    rdfs:comment 'Unique order or transaction identifier assigned by the screening vendor system for this specific screening request. Used for vendor portal reconciliation, dispute resolution, and FCRA reinvestigation requests.' ;
    rdfs:domain ind:Screening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacedAmenityId rdf:type rdf:Property ;
    rdfs:label 'Replaced Amenity Id' ;
    rdfs:comment 'Self-referencing FK on amenity (replaced_amenity_id)' ;
    rdfs:domain ind:Amenity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Amenity .

ind:accessControlType rdf:type rdf:Property ;
    rdfs:label 'Access Control Type' ;
    rdfs:comment 'Method used to control and restrict physical access to the amenity. Determines security configuration and tenant onboarding requirements.' ;
    rdfs:domain ind:Amenity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amenityDescription rdf:type rdf:Property ;
    rdfs:label 'Amenity Description' ;
    rdfs:comment 'Detailed narrative description of the amenity including features, finishes, equipment, and any notable characteristics. Used for tenant marketing materials, listing syndication, and CoStar/MLS data feeds.' ;
    rdfs:domain ind:Amenity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amenityStatus rdf:type rdf:Property ;
    rdfs:label 'Amenity Status' ;
    rdfs:comment 'Current operational lifecycle status of the amenity. \'active\' indicates available for use; \'under_maintenance\' indicates temporarily unavailable; \'seasonal\' indicates availability is time-bound; \'planned\' indicates not yet operational.' ;
    rdfs:domain ind:Amenity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualOpexBudget rdf:type rdf:Property ;
    rdfs:label 'Annual Opex Budget' ;
    rdfs:comment 'Budgeted annual operating expenditure (OPEX) for maintaining and operating this amenity, expressed in the property\'s functional currency. Used for CAM reconciliation and NOI reporting.' ;
    rdfs:domain ind:Amenity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:areaSqf rdf:type rdf:Property ;
    rdfs:label 'Area Sqf' ;
    rdfs:comment 'Total floor area of the amenity space measured in square feet (SQF). Used for space planning, Common Area Maintenance (CAM) allocation, and lease marketing.' ;
    rdfs:domain ind:Amenity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buildingEnginesAmenityCode rdf:type rdf:Property ;
    rdfs:label 'Building Engines Amenity Code' ;
    rdfs:comment 'Native amenity or space identifier from the Building Engines facility operations and work order management system. Used for cross-system reconciliation and work order routing.' ;
    rdfs:domain ind:Amenity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacity rdf:type rdf:Property ;
    rdfs:label 'Capacity' ;
    rdfs:comment 'Maximum number of persons or units the amenity can accommodate simultaneously (e.g., 50 persons for a conference room, 30 vehicles for a parking structure level). Supports occupancy compliance and reservation management.' ;
    rdfs:domain ind:Amenity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'Date on which the amenity was or is scheduled to be permanently decommissioned and removed from active service. Null for currently active amenities.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evChargingStations rdf:type rdf:Property ;
    rdfs:label 'Ev Charging Stations' ;
    rdfs:comment 'Number of electric vehicle (EV) charging stations available within or associated with this amenity. Relevant for ESG reporting and tenant attraction in commercial and residential properties.' ;
    rdfs:domain ind:Amenity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:is24Hour rdf:type rdf:Property ;
    rdfs:label 'Is 24 Hour' ;
    rdfs:comment 'Indicates whether the amenity is accessible 24 hours a day, 7 days a week. When True, operating hours fields are not applicable.' ;
    rdfs:domain ind:Amenity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReservable rdf:type rdf:Property ;
    rdfs:label 'Is Reservable' ;
    rdfs:comment 'Indicates whether the amenity requires or supports advance reservation by tenants or occupants. True for conference rooms, event spaces, and guest suites; False for open-access amenities such as lobbies or fitness centers with open access.' ;
    rdfs:domain ind:Amenity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSeasonal rdf:type rdf:Property ;
    rdfs:label 'Is Seasonal' ;
    rdfs:comment 'Indicates whether the amenity operates on a seasonal schedule (e.g., outdoor pools open only in summer months). When True, seasonal open and close dates apply.' ;
    rdfs:domain ind:Amenity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTenantExclusive rdf:type rdf:Property ;
    rdfs:label 'Is Tenant Exclusive' ;
    rdfs:comment 'Indicates whether access to this amenity is restricted exclusively to building tenants and their authorized guests, as opposed to being open to the general public or shared with other buildings.' ;
    rdfs:domain ind:Amenity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leedContribution rdf:type rdf:Property ;
    rdfs:label 'Leed Contribution' ;
    rdfs:comment 'Indicates whether this amenity contributes to the building\'s Leadership in Energy and Environmental Design (LEED) certification score (e.g., EV charging stations, bike storage, green roofs).' ;
    rdfs:domain ind:Amenity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceResponsibility rdf:type rdf:Property ;
    rdfs:label 'Maintenance Responsibility' ;
    rdfs:comment 'Party responsible for the ongoing maintenance and upkeep of the amenity. Determines Operations and Maintenance (O&M) cost allocation and work order routing in Building Engines.' ;
    rdfs:domain ind:Amenity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursWeekday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekday' ;
    rdfs:comment 'Standard weekday operating hours for the amenity expressed in HH:MM-HH:MM 24-hour format (e.g., \'06:00-22:00\'). Used for tenant communications and facility scheduling.' ;
    rdfs:domain ind:Amenity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursWeekend rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekend' ;
    rdfs:comment 'Standard weekend operating hours for the amenity expressed in HH:MM-HH:MM 24-hour format (e.g., \'08:00-20:00\'). Null if the amenity is closed on weekends.' ;
    rdfs:domain ind:Amenity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parkingStalls rdf:type rdf:Property ;
    rdfs:label 'Parking Stalls' ;
    rdfs:comment 'Number of individual parking stalls associated with this amenity, applicable when the amenity type is a parking structure, surface lot, or valet facility. Supports parking ratio calculations.' ;
    rdfs:domain ind:Amenity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:photoReference rdf:type rdf:Property ;
    rdfs:label 'Photo Reference' ;
    rdfs:comment 'URI or document management system reference path to the primary marketing photograph of the amenity. Used for tenant-facing portals, listing syndication, and property marketing collateral.' ;
    rdfs:domain ind:Amenity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalCloseDate rdf:type rdf:Property ;
    rdfs:label 'Seasonal Close Date' ;
    rdfs:comment 'Annual calendar date on which a seasonal amenity closes for the season (e.g., pool closing date). Applicable only when is_seasonal is True.' ;
    rdfs:domain ind:Amenity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seasonalOpenDate rdf:type rdf:Property ;
    rdfs:label 'Seasonal Open Date' ;
    rdfs:comment 'Annual calendar date on which a seasonal amenity opens for the season (e.g., pool opening date). Applicable only when is_seasonal is True.' ;
    rdfs:domain ind:Amenity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorCampaignId rdf:type rdf:Property ;
    rdfs:label 'Prior Campaign Id' ;
    rdfs:comment 'Self-referencing FK on campaign (prior_campaign_id)' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'The actual date the campaign concluded. Used to calculate true campaign duration and compare against planned timeline for post-campaign performance analysis.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:campaignCode rdf:type rdf:Property ;
    rdfs:label 'Campaign Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the campaign, used in cross-system references, purchase orders, and vendor invoices. Format: MARKET-YEAR-SEQUENCE (e.g., CRE-2024-QTRQ1).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignName rdf:type rdf:Property ;
    rdfs:label 'Campaign Name' ;
    rdfs:comment 'Human-readable name of the marketing campaign as displayed in Salesforce CRM and internal reporting dashboards (e.g., \'Q1 2024 Downtown Office Leasing Drive\').' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Status' ;
    rdfs:comment 'Current lifecycle state of the campaign. Controls visibility in active reporting, spend authorization, and lead attribution routing within Salesforce CRM.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignType rdf:type rdf:Property ;
    rdfs:label 'Campaign Type' ;
    rdfs:comment 'Classification of the marketing channel or medium used for the campaign. Drives channel-specific performance benchmarking and spend allocation. [ENUM-REF-CANDIDATE: digital|print|out_of_home|email|social_media|event|direct_mail|broadcast — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelMix rdf:type rdf:Property ;
    rdfs:label 'Channel Mix' ;
    rdfs:comment 'Comma-separated list of marketing channels deployed within this campaign (e.g., \'google_ads,facebook,email,mls_syndication\'). Provides a high-level channel inventory for multi-channel campaign analysis without requiring a separate channel line table.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeTheme rdf:type rdf:Property ;
    rdfs:label 'Creative Theme' ;
    rdfs:comment 'The overarching creative concept or messaging theme of the campaign (e.g., \'Urban Living Redefined\', \'Prime Office Space Available\', \'ESG-Certified Buildings\'). Used for brand consistency audits and creative performance analysis.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalPlatform rdf:type rdf:Property ;
    rdfs:label 'Digital Platform' ;
    rdfs:comment 'Name of the primary digital advertising platform used for the campaign (e.g., \'Google Ads\', \'Meta Ads Manager\', \'LinkedIn Campaign Manager\', \'CoStar Advertise\'). Supports platform-level spend and performance reconciliation.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgAlignedFlag rdf:type rdf:Property ;
    rdfs:label 'Esg Aligned Flag' ;
    rdfs:comment 'Indicates whether the campaign promotes Environmental, Social, and Governance (ESG) credentials such as Leadership in Energy and Environmental Design (LEED) certification, Building Research Establishment Environmental Assessment Method (BREEAM) ratings, or sustainability initiatives.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fairHousingCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Fair Housing Compliant Flag' ;
    rdfs:comment 'Indicates whether the campaign has been reviewed and confirmed compliant with the Fair Housing Act and U.S. Department of Housing and Urban Development (HUD) advertising guidelines. Mandatory for all residential marketing campaigns.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliant Flag' ;
    rdfs:comment 'Indicates whether the campaign\'s audience targeting, data collection, and lead capture processes comply with General Data Protection Regulation (GDPR) requirements. Required for campaigns targeting EU-based prospects.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mlsSyndicationFlag rdf:type rdf:Property ;
    rdfs:label 'Mls Syndication Flag' ;
    rdfs:comment 'Indicates whether the campaign includes syndication of property listings to Multiple Listing Service (MLS) platforms (e.g., Zillow, Realtor.com, CoStar). Drives integration with brokerage.mls_syndication records.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:objective rdf:type rdf:Property ;
    rdfs:label 'Objective' ;
    rdfs:comment 'Primary business objective the campaign is designed to achieve. Used to align campaign KPIs and measure success against strategic marketing goals across commercial and residential portfolios.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:comment 'The originally approved end date for the campaign. Used for budget period alignment, Weighted Average Lease Term (WALT) correlation analysis, and campaign lifecycle management.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemCampaignCode rdf:type rdf:Property ;
    rdfs:label 'Source System Campaign Code' ;
    rdfs:comment 'The native campaign identifier from the originating operational system (e.g., Salesforce CRM Campaign ID). Enables reconciliation between the Silver Layer and source systems during ETL validation.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetImpressionCount rdf:type rdf:Property ;
    rdfs:label 'Target Impression Count' ;
    rdfs:comment 'The planned number of ad impressions or audience reach exposures targeted for the campaign. Used for brand awareness campaigns and digital media planning benchmarks.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetLeadCount rdf:type rdf:Property ;
    rdfs:label 'Target Lead Count' ;
    rdfs:comment 'The planned number of qualified leads the campaign is expected to generate. Set during campaign planning and used as the primary lead generation KPI benchmark in Salesforce CRM pipeline reporting.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSpendToDate rdf:type rdf:Property ;
    rdfs:label 'Total Spend To Date' ;
    rdfs:comment 'Cumulative actual spend incurred against the campaign budget as of the last reconciliation date. Sourced from SAP S/4HANA Accounts Payable (AP) and reconciled with finance.ap_invoice records. Enables real-time budget utilization monitoring.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorCampaignFlightId rdf:type rdf:Property ;
    rdfs:label 'Prior Campaign Flight Id' ;
    rdfs:comment 'Self-referencing FK on campaign_flight (prior_campaign_flight_id)' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CampaignFlight .

ind:actualSpend rdf:type rdf:Property ;
    rdfs:label 'Actual Spend' ;
    rdfs:comment 'Total media spend actually incurred for this flight to date, in the operating currency (USD). Sourced from ad platform billing or vendor invoices. Used for budget pacing, ROI analysis, and OPEX reporting.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clicks rdf:type rdf:Property ;
    rdfs:label 'Clicks' ;
    rdfs:comment 'Total number of user clicks on the ad creative during this flight. Primary engagement metric for digital channels. Used in CPC (Cost Per Click) calculations and click-through rate (CTR) analysis for lead generation attribution.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cpcRate rdf:type rdf:Property ;
    rdfs:label 'Cpc Rate' ;
    rdfs:comment 'Negotiated or platform-set cost per click (CPC) for this flight, in the operating currency. Used for click-based channel cost benchmarking and ROI analysis on lead generation flights.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpmRate rdf:type rdf:Property ;
    rdfs:label 'Cpm Rate' ;
    rdfs:comment 'Negotiated or platform-set cost per one thousand impressions (CPM) for this flight, in the operating currency. Used for media buy pricing benchmarking and impression-based channel cost analysis.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creativeFormat rdf:type rdf:Property ;
    rdfs:label 'Creative Format' ;
    rdfs:comment 'Format type of the creative asset deployed in this flight. Determines rendering requirements and platform compatibility. Values: image, video, carousel, text, html5, direct_mail_piece, email_template, outdoor (billboard/signage). [ENUM-REF-CANDIDATE: image|video|carousel|text|html5|direct_mail_piece|email_template|outdoor — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for all monetary amounts on this flight record (flight_budget, actual_spend, cpm_rate, cpc_rate). Defaults to USD for domestic US real estate operations.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgAligned rdf:type rdf:Property ;
    rdfs:label 'Esg Aligned' ;
    rdfs:comment 'Indicates whether this flight promotes ESG-certified or sustainability-focused properties (e.g., LEED, BREEAM certified assets). Supports ESG marketing reporting and green portfolio brand positioning.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fairHousingCompliant rdf:type rdf:Property ;
    rdfs:label 'Fair Housing Compliant' ;
    rdfs:comment 'Indicates whether this flight\'s creative, targeting, and placement have been reviewed and confirmed compliant with the Fair Housing Act (FHA) and HUD advertising guidelines. Mandatory for residential property marketing flights. True = compliant, False = pending review or non-compliant.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flightBudget rdf:type rdf:Property ;
    rdfs:label 'Flight Budget' ;
    rdfs:comment 'Total approved budget allocated to this specific flight in the operating currency (USD). Represents the planned CAPEX/OPEX marketing spend for this channel activation. Used for budget vs. actual spend variance analysis.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flightName rdf:type rdf:Property ;
    rdfs:label 'Flight Name' ;
    rdfs:comment 'Human-readable descriptive name for this flight, typically including the channel, property portfolio, and run period (e.g., \'Q3-2024 Google Ads — Downtown Office Portfolio\').' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightNumber rdf:type rdf:Property ;
    rdfs:label 'Flight Number' ;
    rdfs:comment 'Externally-known business identifier for this flight, used in media buy orders, vendor invoices, and campaign tracking systems. Format: FLT- followed by 4–12 alphanumeric characters.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightStatus rdf:type rdf:Property ;
    rdfs:label 'Flight Status' ;
    rdfs:comment 'Current lifecycle state of the campaign flight. Tracks progression from planning through execution to closure. Values: draft (being configured), scheduled (approved, not yet started), active (currently running), paused (temporarily halted), completed (run period ended), cancelled (terminated before completion).' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impressionsDelivered rdf:type rdf:Property ;
    rdfs:label 'Impressions Delivered' ;
    rdfs:comment 'Total number of ad impressions served to target audiences during this flight. A key reach metric for brand awareness campaigns across digital channels (Google Ads, Meta, CoStar, Zillow, LoopNet). Used in CPM (Cost Per Mille) performance calculations.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:landingPageUrl rdf:type rdf:Property ;
    rdfs:label 'Landing Page Url' ;
    rdfs:comment 'The destination URL to which users are directed upon clicking the ad in this flight. Typically a property listing page, microsite, or lead capture form. Used for conversion tracking and digital experience analysis.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadsGenerated rdf:type rdf:Property ;
    rdfs:label 'Leads Generated' ;
    rdfs:comment 'Number of qualified leads (prospect inquiries, form submissions, or contact requests) directly attributed to this flight. Core lead generation KPI linking marketing spend to brokerage pipeline activity in Salesforce CRM.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:placementName rdf:type rdf:Property ;
    rdfs:label 'Placement Name' ;
    rdfs:comment 'Specific placement, ad unit, or inventory position within the channel where the flight is served (e.g., \'CoStar Featured Listing — Office\', \'Zillow Premier Agent Slot\', \'Google Search — Brand Keywords\', \'Billboard I-95 Northbound\').' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmCampaign rdf:type rdf:Property ;
    rdfs:label 'Utm Campaign' ;
    rdfs:comment 'UTM campaign parameter identifying the specific campaign name or code for this flight in web analytics. Enables end-to-end attribution from ad impression to website visit to lead conversion.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmMedium rdf:type rdf:Property ;
    rdfs:label 'Utm Medium' ;
    rdfs:comment 'UTM medium parameter identifying the marketing medium for this flight (e.g., \'cpc\', \'display\', \'email\', \'social\', \'direct_mail\'). Used alongside utm_source for multi-touch attribution modeling.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmSource rdf:type rdf:Property ;
    rdfs:label 'Utm Source' ;
    rdfs:comment 'Urchin Tracking Module (UTM) source parameter appended to landing page URLs for this flight, identifying the originating platform (e.g., \'google\', \'meta\', \'costar\', \'zillow\'). Enables web analytics attribution and lead source tracking in CRM.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Order Number' ;
    rdfs:comment 'The vendor-assigned order, insertion order (IO), or contract number for this media buy. Used to reconcile flight spend against AP invoices and vendor billing statements.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:derivedAdCreativeId rdf:type rdf:Property ;
    rdfs:label 'Derived Ad Creative Id' ;
    rdfs:comment 'Self-referencing FK on ad_creative (derived_ad_creative_id)' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdCreative .

ind:primaryAdAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Ad Asset Id' ;
    rdfs:comment 'Reference to the specific property this creative asset is associated with. Null if the creative is portfolio-level or brand-level rather than property-specific.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:agencyName rdf:type rdf:Property ;
    rdfs:label 'Agency Name' ;
    rdfs:comment 'Name of the external creative agency, photography studio, or freelance vendor responsible for producing this creative asset. Used for vendor performance tracking and procurement reporting.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aspectRatio rdf:type rdf:Property ;
    rdfs:label 'Aspect Ratio' ;
    rdfs:comment 'Aspect ratio of the creative asset expressed as width:height (e.g., \'16:9\', \'1:1\', \'4:3\'). Used for responsive ad placement and social media platform compliance.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Brand Compliance Status' ;
    rdfs:comment 'Indicates whether the creative asset has been reviewed and confirmed to meet corporate brand guidelines, including logo usage, color palette, typography, and fair housing statement requirements.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callToAction rdf:type rdf:Property ;
    rdfs:label 'Call To Action' ;
    rdfs:comment 'The primary call-to-action (CTA) instruction embedded in the creative asset. Used to measure conversion intent alignment and to standardize CTA taxonomy across campaigns. [ENUM-REF-CANDIDATE: schedule_tour|contact_agent|view_listing|download_brochure|request_info|apply_now|learn_more|get_quote — promote to reference product]' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeCode rdf:type rdf:Property ;
    rdfs:label 'Creative Code' ;
    rdfs:comment 'Externally-known unique business code assigned to the creative asset for cross-system reference, DAM cataloguing, and agency handoff (e.g., \'MKT-PROP001-001\'). Serves as the BUSINESS_IDENTIFIER for this master resource.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeName rdf:type rdf:Property ;
    rdfs:label 'Creative Name' ;
    rdfs:comment 'Human-readable name or title of the creative asset as used by the marketing team (e.g., \'Downtown Tower Q3 Banner 728x90\', \'Luxury Residences Email Header v2\').' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeSubtype rdf:type rdf:Property ;
    rdfs:label 'Creative Subtype' ;
    rdfs:comment 'Granular classification of the creative asset within its format type, specific to real estate marketing use cases. [ENUM-REF-CANDIDATE: listing_photo|virtual_tour|brochure|video_walkthrough|banner_ad|email_template|social_graphic|signage_artwork|floor_plan|aerial_photo|site_plan|renderings — promote to reference product]' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'Duration of the creative asset in seconds. Applicable to video and audio format types. Used to validate platform-specific length requirements (e.g., 15s, 30s, 60s pre-roll) and broadcast standards.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fileUrl rdf:type rdf:Property ;
    rdfs:label 'File Url' ;
    rdfs:comment 'Fully qualified URL or Digital Asset Management (DAM) system reference path to the source file of the creative asset. May be a CDN URL, cloud storage URI, or DAM permalink. Confidential as it exposes internal asset storage infrastructure.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatType rdf:type rdf:Property ;
    rdfs:label 'Format Type' ;
    rdfs:comment 'Primary format classification of the creative asset. Drives rendering, storage, and delivery logic. [ENUM-REF-CANDIDATE: image|video|pdf|html5|copy|audio|interactive|3d_tour — promote to reference product if additional formats are needed]' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headlineCopy rdf:type rdf:Property ;
    rdfs:label 'Headline Copy' ;
    rdfs:comment 'Primary headline or tagline text used in the creative asset. Captured as a business attribute to enable copy performance analysis, A/B testing tracking, and brand compliance review without opening the asset file.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heightPx rdf:type rdf:Property ;
    rdfs:label 'Height Px' ;
    rdfs:comment 'Height dimension of the creative asset in pixels. Applicable to image, HTML5, and video formats. Used alongside width_px to confirm IAB standard ad unit compliance.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isArchived rdf:type rdf:Property ;
    rdfs:label 'Is Archived' ;
    rdfs:comment 'Indicates whether the creative asset has been archived and is no longer available for active campaign use. Archived assets are retained for historical reference and compliance audit purposes but excluded from active creative libraries.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mimeType rdf:type rdf:Property ;
    rdfs:label 'Mime Type' ;
    rdfs:comment 'IANA MIME type of the creative asset file (e.g., \'image/jpeg\', \'video/mp4\', \'application/pdf\', \'text/html\'). Drives rendering engine selection and platform compatibility validation.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformTarget rdf:type rdf:Property ;
    rdfs:label 'Platform Target' ;
    rdfs:comment 'Specific platform or publisher for which this creative is sized and formatted (e.g., \'Instagram\', \'Facebook\', \'Google Display Network\', \'Zillow\', \'CoStar\', \'LoopNet\', \'Realtor.com\'). Distinct from channel — a social_media channel creative may target Instagram or LinkedIn specifically.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioScope rdf:type rdf:Property ;
    rdfs:label 'Portfolio Scope' ;
    rdfs:comment 'Indicates whether the creative asset is scoped to a single property, a portfolio of properties, a brand-level campaign, or a specific market/geography. Determines the breadth of the creative\'s applicability.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionCost rdf:type rdf:Property ;
    rdfs:label 'Production Cost' ;
    rdfs:comment 'Total cost incurred to produce this creative asset, including agency fees, photography, videography, and design costs. Expressed in the operating currency. Used for marketing Capital Expenditure (CAPEX) and Operating Expenditure (OPEX) tracking and Return on Investment (ROI) analysis.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tagsKeywords rdf:type rdf:Property ;
    rdfs:label 'Tags Keywords' ;
    rdfs:comment 'Comma-separated list of searchable tags and keywords associated with the creative asset (e.g., \'luxury, downtown, high-rise, 2BR, pet-friendly\'). Enables DAM search, campaign targeting, and content taxonomy management.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:widthPx rdf:type rdf:Property ;
    rdfs:label 'Width Px' ;
    rdfs:comment 'Width dimension of the creative asset in pixels. Applicable to image, HTML5, and video formats. Used to validate IAB standard ad unit dimensions and platform-specific size requirements.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryListingId rdf:type rdf:Property ;
    rdfs:label 'Primary Listing Id' ;
    rdfs:comment 'Reference to the source property listing being syndicated. Links to the canonical listing record in the marketing or brokerage domain.' ;
    rdfs:domain ind:ListingSyndication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Listing .

ind:supersededListingSyndicationId rdf:type rdf:Property ;
    rdfs:label 'Superseded Listing Syndication Id' ;
    rdfs:comment 'Self-referencing FK on listing_syndication (superseded_listing_syndication_id)' ;
    rdfs:domain ind:ListingSyndication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ListingSyndication .

ind:availableSqft rdf:type rdf:Property ;
    rdfs:label 'Available Sqft' ;
    rdfs:comment 'The total available square footage (SQF) of the space being marketed on the target platform. For partial-floor or suite listings, reflects the specific available area rather than the total building size.' ;
    rdfs:domain ind:ListingSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clickCount rdf:type rdf:Property ;
    rdfs:label 'Click Count' ;
    rdfs:comment 'Total number of user click-throughs on the syndicated listing on the target platform. Used for engagement rate calculation and lead attribution analysis.' ;
    rdfs:domain ind:ListingSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceVerified rdf:type rdf:Property ;
    rdfs:label 'Compliance Verified' ;
    rdfs:comment 'Indicates whether the syndicated listing has been reviewed and confirmed compliant with applicable fair housing, advertising, and platform-specific content policies prior to publication.' ;
    rdfs:domain ind:ListingSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:errorMessage rdf:type rdf:Property ;
    rdfs:label 'Error Message' ;
    rdfs:comment 'The error message or rejection reason returned by the target platform when syndication_status is \'error\'. Used for operational troubleshooting and feed quality management.' ;
    rdfs:domain ind:ListingSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featuredListing rdf:type rdf:Property ;
    rdfs:label 'Featured Listing' ;
    rdfs:comment 'Indicates whether this listing is designated as a featured or premium placement on the target platform, typically associated with additional advertising spend.' ;
    rdfs:domain ind:ListingSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feedType rdf:type rdf:Property ;
    rdfs:label 'Feed Type' ;
    rdfs:comment 'Technical protocol or method used to deliver the listing data to the target platform. RETS = Real Estate Transaction Standard; RESO_WEB_API = RESO Web API; IDX = Internet Data Exchange; MANUAL = human-entered; FTP = file-based transfer; DIRECT_API = proprietary platform API.' ;
    rdfs:domain ind:ListingSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:idxFeedCode rdf:type rdf:Property ;
    rdfs:label 'Idx Feed Code' ;
    rdfs:comment 'The Internet Data Exchange (IDX) feed identifier used when syndicating via IDX protocol. Enables tracking of IDX-specific feed configurations and broker reciprocity agreements.' ;
    rdfs:domain ind:ListingSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impressionCount rdf:type rdf:Property ;
    rdfs:label 'Impression Count' ;
    rdfs:comment 'Total number of times the syndicated listing has been displayed to users on the target platform. Retrieved via platform API or reporting feed for campaign performance measurement.' ;
    rdfs:domain ind:ListingSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Sync Timestamp' ;
    rdfs:comment 'The most recent date and time at which the listing data was successfully synchronized or refreshed on the target platform via the configured feed type.' ;
    rdfs:domain ind:ListingSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:leadCount rdf:type rdf:Property ;
    rdfs:label 'Lead Count' ;
    rdfs:comment 'Number of inbound leads (inquiries, contact form submissions, or calls) generated from this syndicated listing on the target platform. Key metric for lead attribution and channel ROI.' ;
    rdfs:domain ind:ListingSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:listingDescription rdf:type rdf:Property ;
    rdfs:label 'Listing Description' ;
    rdfs:comment 'The marketing description text published on the target platform for this listing. May be a platform-specific override of the master listing description.' ;
    rdfs:domain ind:ListingSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listingTitle rdf:type rdf:Property ;
    rdfs:label 'Listing Title' ;
    rdfs:comment 'The headline or title of the listing as published on the target platform. May differ from the internal listing name due to platform-specific character limits or SEO optimization.' ;
    rdfs:domain ind:ListingSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Next Sync Timestamp' ;
    rdfs:comment 'The scheduled date and time for the next automated data synchronization push to the target platform. Used by the feed scheduler to manage sync cadence.' ;
    rdfs:domain ind:ListingSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:overrideActive rdf:type rdf:Property ;
    rdfs:label 'Override Active' ;
    rdfs:comment 'Indicates whether platform-specific field overrides (e.g., custom title, description, price) are active for this syndication record, superseding the master listing values.' ;
    rdfs:domain ind:ListingSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideNotes rdf:type rdf:Property ;
    rdfs:label 'Override Notes' ;
    rdfs:comment 'Free-text notes documenting the reason for platform-specific field overrides, such as character limit compliance, SEO adjustments, or platform policy requirements.' ;
    rdfs:domain ind:ListingSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paidPlacement rdf:type rdf:Property ;
    rdfs:label 'Paid Placement' ;
    rdfs:comment 'Indicates whether this syndication involves a paid advertising placement (e.g., sponsored listing, premium slot) on the target platform, as opposed to a standard free syndication.' ;
    rdfs:domain ind:ListingSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:photoCount rdf:type rdf:Property ;
    rdfs:label 'Photo Count' ;
    rdfs:comment 'Number of photos included in the syndicated listing on the target platform. Platforms often have minimum photo requirements; this field supports compliance monitoring.' ;
    rdfs:domain ind:ListingSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:placementCost rdf:type rdf:Property ;
    rdfs:label 'Placement Cost' ;
    rdfs:comment 'The advertising or placement cost incurred for this syndication on the target platform. Applicable when paid_placement is true. Used for marketing spend tracking and ROI analysis.' ;
    rdfs:domain ind:ListingSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformName rdf:type rdf:Property ;
    rdfs:label 'Platform Name' ;
    rdfs:comment 'Name of the external marketing portal or platform to which the listing is syndicated (e.g., Zillow, Realtor.com, LoopNet, CoStar, Apartments.com, MLS). [ENUM-REF-CANDIDATE: Zillow|Realtor.com|LoopNet|CoStar|Apartments.com|MLS|Homes.com|Trulia|Redfin|CREXi|Ten-X|proprietary — promote to reference product]' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformUrl rdf:type rdf:Property ;
    rdfs:label 'Platform Url' ;
    rdfs:comment 'The publicly accessible URL of the listing on the target platform. Used for link verification, marketing collateral, and click-through tracking.' ;
    rdfs:domain ind:ListingSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishDate rdf:type rdf:Property ;
    rdfs:label 'Publish Date' ;
    rdfs:comment 'The date on which the listing was first published live on the target platform. Used for time-on-market calculations and campaign performance reporting.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pullReason rdf:type rdf:Property ;
    rdfs:label 'Pull Reason' ;
    rdfs:comment 'Reason code explaining why the listing was pulled from the target platform before expiry. Supports compliance auditing and platform relationship management. [ENUM-REF-CANDIDATE: sold|leased|withdrawn|duplicate|policy_violation|owner_request|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ListingSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pulledDate rdf:type rdf:Property ;
    rdfs:label 'Pulled Date' ;
    rdfs:comment 'The date on which the listing was manually removed or pulled from the target platform prior to its scheduled expiry. Populated only when syndication_status is \'pulled\'.' ;
    rdfs:domain ind:ListingSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:syndicationRef rdf:type rdf:Property ;
    rdfs:label 'Syndication Ref' ;
    rdfs:comment 'Externally-known business identifier for this syndication record, used for cross-system reconciliation and support tickets (e.g., SYN-2024-00123).' ;
    rdfs:domain ind:ListingSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syndicationSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Syndication Source System' ;
    rdfs:comment 'The operational system of record from which the listing data originates for this syndication (e.g., Yardi Voyager, MRI Software, CoStar Suite, Salesforce CRM, or manual entry).' ;
    rdfs:domain ind:ListingSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syndicationStatus rdf:type rdf:Property ;
    rdfs:label 'Syndication Status' ;
    rdfs:comment 'Current lifecycle state of the syndication record on the target platform. \'pending\' = submitted but not yet confirmed live; \'live\' = actively published; \'expired\' = past expiry date; \'pulled\' = manually removed; \'error\' = feed or API failure; \'paused\' = temporarily suspended.' ;
    rdfs:domain ind:ListingSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:virtualTourUrl rdf:type rdf:Property ;
    rdfs:label 'Virtual Tour Url' ;
    rdfs:comment 'URL of the virtual tour or 3D walkthrough associated with this syndicated listing. Included in the platform feed when available to enhance listing engagement.' ;
    rdfs:domain ind:ListingSyndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedBrokerageBrokerId rdf:type rdf:Property ;
    rdfs:label 'Assigned Brokerage Broker Id' ;
    rdfs:comment 'Foreign key linking to brokerage.brokerage_broker. Business justification: Lead routing and broker assignment is a named CRM workflow in real estate: leads are assigned to specific agents for follow-up, and agent conversion rates by lead source are a standard performance rep' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Broker .

ind:convertedInvestorId rdf:type rdf:Property ;
    rdfs:label 'Converted Investor Id' ;
    rdfs:comment 'Foreign key linking to investment.investor. Business justification: When a marketing lead (prospective LP) converts to a committed investor, linking the lead to the investor record enables full-funnel tracking from first marketing touch to capital commitment — a stand' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Investor .

ind:masterLeadId rdf:type rdf:Property ;
    rdfs:label 'Master Lead Id' ;
    rdfs:comment 'Reference to the canonical (master) lead record when is_duplicate = True. Enables deduplication merge tracking and ensures analytics roll up to the correct master record.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lead .

ind:primaryDuplicateLeadId rdf:type rdf:Property ;
    rdfs:label 'Primary Duplicate Lead Id' ;
    rdfs:comment 'Self-referencing FK on lead (duplicate_lead_id)' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lead .

ind:sizeUomId rdf:type rdf:Property ;
    rdfs:label 'Size Uom Id' ;
    rdfs:comment 'Foreign key linking to reference.uom. Business justification: lead.size_requirement_min_sqf and size_requirement_max_sqf are area measurements. International leads may specify requirements in sqm. A size_uom_id FK enables proper unit conversion when matching lea' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Uom .

ind:budgetMax rdf:type rdf:Property ;
    rdfs:label 'Budget Max' ;
    rdfs:comment 'Maximum financial budget the lead has indicated for the transaction (purchase price or annual rent), expressed in the operating currency. Used for property matching and lead qualification.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetMin rdf:type rdf:Property ;
    rdfs:label 'Budget Min' ;
    rdfs:comment 'Minimum financial budget the lead has indicated for the transaction (purchase price or annual rent), expressed in the operating currency. Used for property matching and lead qualification.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conversionDate rdf:type rdf:Property ;
    rdfs:label 'Conversion Date' ;
    rdfs:comment 'The date on which the lead was converted to a prospect, deal, or tenant record. Populated only when lead_status = \'converted\'. Used to calculate lead-to-conversion cycle time.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disqualificationReason rdf:type rdf:Property ;
    rdfs:label 'Disqualification Reason' ;
    rdfs:comment 'Reason the lead was marked as disqualified (e.g., budget mismatch, no longer interested, duplicate, outside service area). Populated only when lead_status = \'disqualified\'. Used for funnel analysis and source quality improvement.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstContactDate rdf:type rdf:Property ;
    rdfs:label 'First Contact Date' ;
    rdfs:comment 'The date on which the first outbound contact attempt was made to the lead by an agent or leasing representative. Used to measure response time SLA compliance.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdprConsent rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent' ;
    rdfs:comment 'Indicates whether the lead has provided explicit consent for data processing and marketing communications under GDPR. Mandatory for leads originating from EU/EEA jurisdictions.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grade rdf:type rdf:Property ;
    rdfs:label 'Grade' ;
    rdfs:comment 'Qualitative grade (A–D) assigned to the lead based on overall qualification assessment. A = highly qualified, D = low probability. Complements the numeric lead_score for agent prioritization.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDuplicate rdf:type rdf:Property ;
    rdfs:label 'Is Duplicate' ;
    rdfs:comment 'Indicates whether this lead record has been identified as a duplicate of another lead in the system. Used for data quality management and deduplication workflows in Salesforce CRM.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'The date of the most recent interaction or activity recorded against this lead (call, email, showing, note). Used to identify stale leads and trigger re-engagement workflows.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadNumber rdf:type rdf:Property ;
    rdfs:label 'Lead Number' ;
    rdfs:comment 'Human-readable, externally referenceable business identifier for the lead (e.g., LD-202400012345). Used in correspondence, CRM, and reporting.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadStatus rdf:type rdf:Property ;
    rdfs:label 'Lead Status' ;
    rdfs:comment 'Current lifecycle state of the lead within the marketing and sales funnel. Drives CRM workflow automation and pipeline reporting. [ENUM-REF-CANDIDATE: new|contacted|qualified|disqualified|converted|nurturing|lost — promote to reference product]' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadType rdf:type rdf:Property ;
    rdfs:label 'Lead Type' ;
    rdfs:comment 'Classification of the lead\'s intent and role in the real estate transaction. Drives routing logic and follow-up workflows. [ENUM-REF-CANDIDATE: buyer|tenant|investor|seller|landlord|other — promote to reference product]' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:score rdf:type rdf:Property ;
    rdfs:label 'Score' ;
    rdfs:comment 'Numeric score (typically 0–100) assigned to the lead based on qualification criteria such as budget, timeline, engagement level, and source quality. Used to prioritize agent follow-up and predict conversion likelihood.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sizeRequirementMaxSqf rdf:type rdf:Property ;
    rdfs:label 'Size Requirement Max Sqf' ;
    rdfs:comment 'Maximum space requirement expressed in square feet (SQF) as stated by the lead. Used for property matching against available GLA/NLA inventory.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sizeRequirementMinSqf rdf:type rdf:Property ;
    rdfs:label 'Size Requirement Min Sqf' ;
    rdfs:comment 'Minimum space requirement expressed in square feet (SQF) as stated by the lead. Used for property matching against available GLA/NLA inventory.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourcePortal rdf:type rdf:Property ;
    rdfs:label 'Source Portal' ;
    rdfs:comment 'Specific third-party listing portal or platform from which the lead originated when lead_source is \'portal\' (e.g., Zillow, CoStar, LoopNet). Enables portal-level ROI and lead quality benchmarking. [ENUM-REF-CANDIDATE: zillow|costar|loopnet|realtor_com|apartments_com|crexi|mls|other — promote to reference product]' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemLeadCode rdf:type rdf:Property ;
    rdfs:label 'Source System Lead Code' ;
    rdfs:comment 'The native identifier of this lead record in the originating source system (e.g., Salesforce Lead ID \'00Q...\'). Used for cross-system reconciliation and data lineage.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadActivityId rdf:type rdf:Property ;
    rdfs:label 'Lead Activity Id' ;
    rdfs:comment 'Unique surrogate identifier for each discrete lead activity or touchpoint record in the marketing domain. Primary key for the lead_activity data product.' ;
    rdfs:domain ind:LeadActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentLeadActivityId rdf:type rdf:Property ;
    rdfs:label 'Parent Lead Activity Id' ;
    rdfs:comment 'Self-referencing FK on lead_activity (parent_lead_activity_id)' ;
    rdfs:domain ind:LeadActivity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LeadActivity .

ind:activityDirection rdf:type rdf:Property ;
    rdfs:label 'Activity Direction' ;
    rdfs:comment 'Indicates whether the activity was initiated by the lead (inbound, e.g., a form submission or portal page view) or by the agent/system (outbound, e.g., an email send or call attempt). Critical for distinguishing lead-initiated engagement from agent-driven nurture.' ;
    rdfs:domain ind:LeadActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityStatus rdf:type rdf:Property ;
    rdfs:label 'Activity Status' ;
    rdfs:comment 'Current lifecycle state of the activity record, indicating whether the touchpoint was successfully completed, attempted but not delivered, failed, or is pending execution.' ;
    rdfs:domain ind:LeadActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activity Timestamp' ;
    rdfs:comment 'The precise date and time (with timezone offset) at which the lead activity or touchpoint occurred. This is the principal real-world event time used for funnel sequencing, nurture cadence analysis, and time-to-conversion calculations.' ;
    rdfs:domain ind:LeadActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'Categorical classification of the discrete touchpoint or interaction recorded. Drives funnel stage analysis and channel attribution. [ENUM-REF-CANDIDATE: email_open|link_click|portal_page_view|call_attempt|sms_response|chatbot_interaction|form_submission — promote to reference product]' ;
    rdfs:domain ind:LeadActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionModel rdf:type rdf:Property ;
    rdfs:label 'Attribution Model' ;
    rdfs:comment 'The marketing attribution model applied to this activity for credit assignment in conversion analysis (e.g., first touch, last touch, linear, time decay, position-based). Supports multi-touch attribution reporting.' ;
    rdfs:domain ind:LeadActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionWeight rdf:type rdf:Property ;
    rdfs:label 'Attribution Weight' ;
    rdfs:comment 'The fractional credit weight (0.0000 to 1.0000) assigned to this activity under the applied attribution model. Used in multi-touch attribution calculations to distribute conversion credit across touchpoints.' ;
    rdfs:domain ind:LeadActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:callDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Call Duration Seconds' ;
    rdfs:comment 'The duration in seconds of a phone call activity, applicable when activity_type is call_attempt. Used to assess call quality, agent engagement depth, and lead qualification effectiveness.' ;
    rdfs:domain ind:LeadActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelSubtype rdf:type rdf:Property ;
    rdfs:label 'Channel Subtype' ;
    rdfs:comment 'Further classification of the marketing channel, such as distinguishing between organic search, paid search, display advertising, or social platform (e.g., Facebook, LinkedIn) within the broader channel category.' ;
    rdfs:domain ind:LeadActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'The consent status of the lead for marketing communications at the time of this activity, as required under GDPR and applicable privacy regulations. Ensures only consented leads receive outbound marketing activities.' ;
    rdfs:domain ind:LeadActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentReference rdf:type rdf:Property ;
    rdfs:label 'Content Reference' ;
    rdfs:comment 'Identifier or URL of the content asset, page, or listing that was viewed, clicked, or interacted with during this activity (e.g., a property listing URL, email template ID, or landing page path). Supports content performance analysis.' ;
    rdfs:domain ind:LeadActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentType rdf:type rdf:Property ;
    rdfs:label 'Content Type' ;
    rdfs:comment 'Classification of the content asset or page involved in the activity (e.g., listing page, email template, landing page, virtual tour). Enables content-level engagement analytics. [ENUM-REF-CANDIDATE: listing_page|email_template|landing_page|brochure|video|virtual_tour|floor_plan — promote to reference product]' ;
    rdfs:domain ind:LeadActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionType rdf:type rdf:Property ;
    rdfs:label 'Conversion Type' ;
    rdfs:comment 'When is_conversion_event is true, classifies the type of conversion achieved (e.g., showing request, Letter of Intent (LOI) submitted, lease inquiry, purchase inquiry). Enables conversion type analysis by channel and campaign. [ENUM-REF-CANDIDATE: showing_request|loi_submitted|lease_inquiry|purchase_inquiry|callback_booked|tour_scheduled — promote to reference product]' ;
    rdfs:domain ind:LeadActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'The type of device used by the lead when the activity occurred (e.g., desktop, mobile, tablet). Supports device-level engagement analysis and responsive marketing optimization.' ;
    rdfs:domain ind:LeadActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailSubject rdf:type rdf:Property ;
    rdfs:label 'Email Subject' ;
    rdfs:comment 'The subject line of the email associated with this activity, applicable when activity_type is email_open or link_click. Supports email content performance analysis and A/B testing evaluation.' ;
    rdfs:domain ind:LeadActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formName rdf:type rdf:Property ;
    rdfs:label 'Form Name' ;
    rdfs:comment 'The name or identifier of the web form submitted during a form_submission activity (e.g., \'Contact Agent Form\', \'Schedule a Tour\', \'Request Brochure\'). Supports form-level conversion analysis.' ;
    rdfs:domain ind:LeadActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:funnelStage rdf:type rdf:Property ;
    rdfs:label 'Funnel Stage' ;
    rdfs:comment 'The marketing and sales funnel stage at which this activity occurred, enabling conversion funnel analysis and stage-level attribution modeling. Aligned with the lead nurture journey from awareness through conversion.' ;
    rdfs:domain ind:LeadActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConversionEvent rdf:type rdf:Property ;
    rdfs:label 'Is Conversion Event' ;
    rdfs:comment 'Indicates whether this activity represents a conversion event (e.g., a form submission that resulted in a qualified lead, a showing request, or a signed Letter of Intent). Used to identify conversion touchpoints in funnel analysis.' ;
    rdfs:domain ind:LeadActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadScoreAtActivity rdf:type rdf:Property ;
    rdfs:label 'Lead Score At Activity' ;
    rdfs:comment 'The numeric lead score assigned to the lead at the time this activity was recorded, as calculated by the CRM or marketing automation platform. Captures the point-in-time score for trend analysis and nurture effectiveness measurement.' ;
    rdfs:domain ind:LeadActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextAction rdf:type rdf:Property ;
    rdfs:label 'Next Action' ;
    rdfs:comment 'The next recommended or scheduled follow-up action for the lead as determined by the agent or CRM automation following this activity (e.g., \'Schedule showing\', \'Send brochure\', \'Follow-up call in 3 days\').' ;
    rdfs:domain ind:LeadActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Action Due Date' ;
    rdfs:comment 'The scheduled date by which the next follow-up action should be completed. Used for lead nurture cadence management and agent task scheduling.' ;
    rdfs:domain ind:LeadActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optOutFlag rdf:type rdf:Property ;
    rdfs:label 'Opt Out Flag' ;
    rdfs:comment 'Indicates whether this activity resulted in or was associated with the lead opting out of marketing communications. Critical for compliance with CAN-SPAM, GDPR, and TCPA regulations governing marketing consent.' ;
    rdfs:domain ind:LeadActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outcomeNotes rdf:type rdf:Property ;
    rdfs:label 'Outcome Notes' ;
    rdfs:comment 'Free-text notes recorded by the agent or system describing the qualitative result of the activity, such as voicemail left, callback requested, or specific objection raised by the prospect.' ;
    rdfs:domain ind:LeadActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pageViewDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Page View Duration Seconds' ;
    rdfs:comment 'The time in seconds the lead spent viewing a portal page or listing during a portal_page_view activity. Indicates engagement depth with a specific property listing or content asset.' ;
    rdfs:domain ind:LeadActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performerType rdf:type rdf:Property ;
    rdfs:label 'Performer Type' ;
    rdfs:comment 'Classifies whether the activity was performed by a human agent, an automated system, a chatbot, or the prospect themselves. Distinguishes human-initiated nurture from automated marketing sequences.' ;
    rdfs:domain ind:LeadActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'The ordinal position of this activity within the lead\'s overall touchpoint sequence, enabling chronological ordering of the full lead journey and nurture cadence analysis.' ;
    rdfs:domain ind:RealEstate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sessionCode rdf:type rdf:Property ;
    rdfs:label 'Session Code' ;
    rdfs:comment 'The web or app session identifier associated with this activity, used to group multiple touchpoints within a single browsing session for session-level engagement analysis and journey mapping.' ;
    rdfs:domain ind:LeadActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceActivityRef rdf:type rdf:Property ;
    rdfs:label 'Source Activity Ref' ;
    rdfs:comment 'The native identifier of this activity record in the originating source system (e.g., Salesforce Task ID, Yardi activity reference). Enables traceability and reconciliation back to the system of record.' ;
    rdfs:domain ind:LeadActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySupersededByMarketResearchId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Market Research Id' ;
    rdfs:comment 'Reference to the market_research_id of the newer research record that supersedes or replaces this study. Enables version chaining and ensures users are directed to the most current market intelligence.' ;
    rdfs:domain ind:MarketResearch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketResearch .

ind:avgAskingRentPsf rdf:type rdf:Property ;
    rdfs:label 'Avg Asking Rent Psf' ;
    rdfs:comment 'Average asking rent per square foot (PSF) for the subject market or submarket as reported in the research study. Expressed in the local currency. Core metric for rent benchmarking and lease negotiation support.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionCost rdf:type rdf:Property ;
    rdfs:label 'Commission Cost' ;
    rdfs:comment 'Total cost incurred to commission or procure the market research study from a third-party provider. Expressed in the currency defined by currency_code. Used for marketing budget tracking and vendor spend analysis.' ;
    rdfs:domain ind:MarketResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitiveSetCount rdf:type rdf:Property ;
    rdfs:label 'Competitive Set Count' ;
    rdfs:comment 'Number of comparable or competitive properties included in the research study\'s competitive set or comparable universe. Indicates the breadth and statistical robustness of the competitive analysis.' ;
    rdfs:domain ind:MarketResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataSources rdf:type rdf:Property ;
    rdfs:label 'Data Sources' ;
    rdfs:comment 'Comma-separated or narrative description of the primary data sources used in the research study (e.g., \'CoStar Suite, MLS, Census Bureau, Yardi Voyager\'). Supports data lineage, reproducibility, and quality assessment.' ;
    rdfs:domain ind:MarketResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionList rdf:type rdf:Property ;
    rdfs:label 'Distribution List' ;
    rdfs:comment 'Comma-separated list of internal teams, roles, or named stakeholders authorized to receive or access the market research report. Supports information governance and need-to-know access controls.' ;
    rdfs:domain ind:MarketResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgFocusFlag rdf:type rdf:Property ;
    rdfs:label 'Esg Focus Flag' ;
    rdfs:comment 'Indicates whether the market research study specifically addresses Environmental, Social, and Governance (ESG) factors such as green building certifications, sustainability metrics, or social impact. True = ESG-focused research.' ;
    rdfs:domain ind:MarketResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalPublicationFlag rdf:type rdf:Property ;
    rdfs:label 'External Publication Flag' ;
    rdfs:comment 'Indicates whether the market research report has been approved for external publication or distribution to clients, investors, or the public. True = approved for external release; False = internal use only.' ;
    rdfs:domain ind:MarketResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keyFindingsSummary rdf:type rdf:Property ;
    rdfs:label 'Key Findings Summary' ;
    rdfs:comment 'Executive-level narrative summary of the principal findings, conclusions, and market insights from the research study. Enables rapid consumption of intelligence without accessing the full report document.' ;
    rdfs:domain ind:MarketResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netAbsorptionSqft rdf:type rdf:Property ;
    rdfs:label 'Net Absorption Sqft' ;
    rdfs:comment 'Net absorption in square feet (SQF) for the subject market or submarket during the study period. Measures the net change in occupied space and is a primary indicator of market demand health.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newSupplySqft rdf:type rdf:Property ;
    rdfs:label 'New Supply Sqft' ;
    rdfs:comment 'Total new construction deliveries in square feet (SQF) completed in the subject market during the study period. Measures supply-side pressure on vacancy and rent levels.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next periodic review or refresh of the market research study. Ensures market intelligence remains current and triggers renewal workflows for time-sensitive research assets.' ;
    rdfs:domain ind:MarketResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:peerReviewedFlag rdf:type rdf:Property ;
    rdfs:label 'Peer Reviewed Flag' ;
    rdfs:comment 'Indicates whether the market research study has undergone formal peer review or quality assurance validation by a qualified analyst or external reviewer. True = peer reviewed; False = not yet reviewed.' ;
    rdfs:domain ind:MarketResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:providerName rdf:type rdf:Property ;
    rdfs:label 'Provider Name' ;
    rdfs:comment 'Name of the organization or internal team that produced the market research report (e.g., \'CoStar Group\', \'CBRE Research\', \'Internal Market Intelligence Team\'). Used for vendor tracking and research attribution.' ;
    rdfs:domain ind:MarketResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerType rdf:type rdf:Property ;
    rdfs:label 'Provider Type' ;
    rdfs:comment 'Indicates whether the market research was produced internally by the marketing team, commissioned from a third-party research firm, or produced jointly. Drives cost attribution and vendor management workflows.' ;
    rdfs:domain ind:MarketResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationStatus rdf:type rdf:Property ;
    rdfs:label 'Publication Status' ;
    rdfs:comment 'Current lifecycle state of the market research report within the publication workflow. Controls visibility and distribution of the research asset across the organization.' ;
    rdfs:domain ind:MarketResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportFileUrl rdf:type rdf:Property ;
    rdfs:label 'Report File Url' ;
    rdfs:comment 'Secure URL or cloud storage path to the full market research report document (PDF, XLSX, or presentation). Links to the authoritative source document stored in the document management system.' ;
    rdfs:domain ind:MarketResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchCode rdf:type rdf:Property ;
    rdfs:label 'Research Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier assigned to the market research engagement (e.g., MR-2024-00123). Used for cross-referencing with CoStar Suite reports, Argus Enterprise studies, and internal filing systems.' ;
    rdfs:domain ind:MarketResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchDate rdf:type rdf:Property ;
    rdfs:label 'Research Date' ;
    rdfs:comment 'The principal date on which the market research was conducted, data was collected, or the study period ends. Represents the as-of date for all findings and market metrics within the report.' ;
    rdfs:domain ind:MarketResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:researchMethodology rdf:type rdf:Property ;
    rdfs:label 'Research Methodology' ;
    rdfs:comment 'Description of the analytical methodology employed in the research study (e.g., \'Comparable transaction analysis\', \'Survey-based demand study\', \'DCF-based absorption model\'). Supports reproducibility and peer review.' ;
    rdfs:domain ind:MarketResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchType rdf:type rdf:Property ;
    rdfs:label 'Research Type' ;
    rdfs:comment 'Classification of the market research study by its analytical purpose. Drives filtering and categorization in the market intelligence repository. [ENUM-REF-CANDIDATE: submarket_analysis|competitive_landscape|demand_study|absorption_study|rent_survey|buyer_sentiment — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:MarketResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Study Period End' ;
    rdfs:comment 'End date of the market data observation window covered by the research study. Together with study_period_start, defines the temporal scope of the market analysis.' ;
    rdfs:domain ind:MarketResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:studyPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Study Period Start' ;
    rdfs:comment 'Start date of the market data observation window covered by the research study. Used for time-series analysis and trend identification in absorption, rent, and demand studies.' ;
    rdfs:domain ind:MarketResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submarketName rdf:type rdf:Property ;
    rdfs:label 'Submarket Name' ;
    rdfs:comment 'Specific submarket or neighborhood within the geographic market that is the focus of the research (e.g., \'Midtown Manhattan\', \'River North\'). Aligns with CoStar Suite submarket definitions for granular competitive intelligence.' ;
    rdfs:domain ind:MarketResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tags rdf:type rdf:Property ;
    rdfs:label 'Tags' ;
    rdfs:comment 'Free-text comma-separated keywords or topic tags associated with the market research study (e.g., \'ESG, LEED, sustainability, office, hybrid work\'). Supports full-text search and thematic categorization in the market intelligence repository.' ;
    rdfs:domain ind:MarketResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalInventorySqft rdf:type rdf:Property ;
    rdfs:label 'Total Inventory Sqft' ;
    rdfs:comment 'Total rentable building area (RBA) or gross leasable area (GLA) in square feet (SQF) for the subject market or submarket as reported in the research study. Provides market size context for all relative metrics.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:underConstructionSqft rdf:type rdf:Property ;
    rdfs:label 'Under Construction Sqft' ;
    rdfs:comment 'Total square footage (SQF) of space currently under construction in the subject market as of the research date. Forward-looking supply pipeline metric used in demand and absorption forecasting.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorMarketSurveyId rdf:type rdf:Property ;
    rdfs:label 'Prior Market Survey Id' ;
    rdfs:comment 'Self-referencing FK on market_survey (prior_market_survey_id)' ;
    rdfs:domain ind:MarketSurvey ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketSurvey .

ind:availabilityRate rdf:type rdf:Property ;
    rdfs:label 'Availability Rate' ;
    rdfs:comment 'Percentage of total rentable square footage that is available for lease, including both vacant space and occupied space being marketed for sublease. Broader than vacancy rate; expressed as a decimal. Used for forward-looking supply analysis.' ;
    rdfs:domain ind:MarketSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgConcessionValuePsf rdf:type rdf:Property ;
    rdfs:label 'Avg Concession Value Psf' ;
    rdfs:comment 'Average total value of landlord concessions offered per square foot across the surveyed competitive set, including free rent periods (converted to PSF equivalent) and tenant improvement (TI) allowances. Measures the gap between asking and effective rents.' ;
    rdfs:domain ind:MarketSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgEffectiveRentPsf rdf:type rdf:Property ;
    rdfs:label 'Avg Effective Rent Psf' ;
    rdfs:comment 'Average net rent actually achievable after accounting for concessions such as free rent periods, tenant improvement (TI) allowances, and other landlord incentives. Reflects true market pricing and is used in Discounted Cash Flow (DCF) and Net Operating Income (NOI) modeling.' ;
    rdfs:domain ind:MarketSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgFreeRentMonths rdf:type rdf:Property ;
    rdfs:label 'Avg Free Rent Months' ;
    rdfs:comment 'Average number of months of rent abatement (free rent) offered by landlords as a concession across the surveyed competitive set. A key component of the concession package used in effective rent calculations.' ;
    rdfs:domain ind:MarketSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgLeaseTermMonths rdf:type rdf:Property ;
    rdfs:label 'Avg Lease Term Months' ;
    rdfs:comment 'Average lease duration in months for new leases executed in the surveyed competitive set during the survey period. Informs Weighted Average Lease Term (WALT) benchmarking and portfolio duration risk analysis.' ;
    rdfs:domain ind:MarketSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgTiAllowancePsf rdf:type rdf:Property ;
    rdfs:label 'Avg Ti Allowance Psf' ;
    rdfs:comment 'Average Tenant Improvement (TI) allowance offered by landlords per square foot across the surveyed competitive set. TI allowances fund tenant fit-out costs and are a primary negotiating lever in commercial leasing.' ;
    rdfs:domain ind:MarketSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Confidence Level' ;
    rdfs:comment 'Qualitative assessment of the reliability and completeness of the survey data, based on sample size, data source quality, and surveyor judgment. High confidence indicates robust sample and verified data; low confidence indicates limited sample or unverified sources.' ;
    rdfs:domain ind:MarketSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costarMarketCode rdf:type rdf:Property ;
    rdfs:label 'Costar Market Code' ;
    rdfs:comment 'CoStar Suite\'s proprietary market or submarket identifier corresponding to the geographic area surveyed. Enables direct cross-referencing with CoStar market analytics, comparable data, and benchmarking reports.' ;
    rdfs:domain ind:MarketSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossAbsorptionSqft rdf:type rdf:Property ;
    rdfs:label 'Gross Absorption Sqft' ;
    rdfs:comment 'Total square footage of all new leases and lease renewals executed in the surveyed competitive set during the survey period, without netting out vacated space. Measures total leasing activity volume.' ;
    rdfs:domain ind:MarketSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metroArea rdf:type rdf:Property ;
    rdfs:label 'Metro Area' ;
    rdfs:comment 'The Metropolitan Statistical Area (MSA) or major market in which the surveyed submarket is located (e.g., \'New York-Newark-Jersey City\', \'Chicago-Naperville-Elgin\'). Used for macro-level market aggregation and portfolio benchmarking.' ;
    rdfs:domain ind:MarketSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertiesSurveyedCount rdf:type rdf:Property ;
    rdfs:label 'Properties Surveyed Count' ;
    rdfs:comment 'Total count of individual properties included in the competitive set for this survey period. Indicates the statistical sample size and reliability of the survey findings.' ;
    rdfs:domain ind:MarketSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publishedDate rdf:type rdf:Property ;
    rdfs:label 'Published Date' ;
    rdfs:comment 'Date on which the market survey was formally published and made available to internal stakeholders, investors, or external parties. Marks the transition from internal research to actionable market intelligence.' ;
    rdfs:domain ind:MarketSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surveyNotes rdf:type rdf:Property ;
    rdfs:label 'Survey Notes' ;
    rdfs:comment 'Free-text field for the surveyor to record qualitative observations, market commentary, anomalies, methodology notes, or contextual factors affecting the survey results (e.g., seasonal effects, major tenant move-outs, new development announcements).' ;
    rdfs:domain ind:MarketSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Survey Period End Date' ;
    rdfs:comment 'End date of the observation period covered by this market survey. Defines the closing boundary of the measurement window for activity-based metrics such as absorption and new supply.' ;
    rdfs:domain ind:MarketSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surveyPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Survey Period Start Date' ;
    rdfs:comment 'Start date of the observation period covered by this market survey. Together with survey_period_end_date, defines the window during which market activity (absorption, new leases, deliveries) was measured.' ;
    rdfs:domain ind:MarketSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surveyPeriodType rdf:type rdf:Property ;
    rdfs:label 'Survey Period Type' ;
    rdfs:comment 'Frequency classification of the survey cycle, indicating whether this is a monthly, quarterly, semi-annual, annual, or ad-hoc point-in-time survey. Determines how the record is used in trend analysis and time-series reporting.' ;
    rdfs:domain ind:MarketSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyRef rdf:type rdf:Property ;
    rdfs:label 'Survey Ref' ;
    rdfs:comment 'Externally-known business identifier for the market survey, used in reports, correspondence, and cross-system references. Format: MS-{YYYY}-{NNNNNN}.' ;
    rdfs:domain ind:MarketSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyStatus rdf:type rdf:Property ;
    rdfs:label 'Survey Status' ;
    rdfs:comment 'Current lifecycle state of the market survey record, tracking progression from initial data collection through review, publication, and archival. [ENUM-REF-CANDIDATE: draft|in_progress|completed|reviewed|published|archived — promote to reference product]' ;
    rdfs:domain ind:MarketSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyType rdf:type rdf:Property ;
    rdfs:label 'Survey Type' ;
    rdfs:comment 'Classification of the survey by the type of market data being captured. Rent surveys track asking and effective rents; vacancy surveys track occupancy; absorption surveys track net space take-up; concession surveys track landlord incentives; sales comp surveys track transaction comparables.' ;
    rdfs:domain ind:MarketSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyorCompany rdf:type rdf:Property ;
    rdfs:label 'Surveyor Company' ;
    rdfs:comment 'Name of the firm or organization that conducted the market survey, relevant when surveys are sourced from third-party research providers such as CoStar, CBRE, or JLL.' ;
    rdfs:domain ind:MarketSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyorName rdf:type rdf:Property ;
    rdfs:label 'Surveyor Name' ;
    rdfs:comment 'Full name of the analyst, researcher, or broker who conducted and recorded the market survey. Used for accountability, quality review, and attribution of market intelligence.' ;
    rdfs:domain ind:MarketSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hostingBrokerageBrokerId rdf:type rdf:Property ;
    rdfs:label 'Hosting Brokerage Broker Id' ;
    rdfs:comment 'Foreign key linking to brokerage.brokerage_broker. Business justification: Open houses and broker tours require a named hosting agent for MLS open house records, commission attribution, and agent performance reporting. marketing.event has no FK to brokerage_broker. Role pref' ;
    rdfs:domain ind:Event ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Broker .

ind:actualAttendance rdf:type rdf:Property ;
    rdfs:label 'Actual Attendance' ;
    rdfs:comment 'Confirmed number of individuals who physically or virtually attended the event. Populated post-event. Used to calculate attendance rate and measure event effectiveness.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetedCost rdf:type rdf:Property ;
    rdfs:label 'Budgeted Cost' ;
    rdfs:comment 'Planned budget allocated for the marketing event at the time of event approval. Compared against total_event_cost for variance analysis and OPEX management.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'Date and time when the marketing event is scheduled to end or actually ended. Used to calculate event duration and schedule non-overlapping events at the same venue.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'Calendar date of the marketing event, used for day-level scheduling, reporting, and calendar integrations independent of precise start/end times.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventDescription rdf:type rdf:Property ;
    rdfs:label 'Event Description' ;
    rdfs:comment 'Detailed narrative description of the event purpose, agenda, and key highlights. Used in invitations, press releases, and post-event reporting.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventName rdf:type rdf:Property ;
    rdfs:label 'Event Name' ;
    rdfs:comment 'Human-readable name of the marketing event as it appears in promotional materials, invitations, and internal reporting (e.g., \'Q3 Broker Preview — Downtown Tower\', \'Annual Investor Day 2024\').' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventNumber rdf:type rdf:Property ;
    rdfs:label 'Event Number' ;
    rdfs:comment 'Externally-visible business identifier for the marketing event, used in communications, vendor contracts, and reporting. Format: EVT-YYYY-NNNNNN.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current lifecycle state of the marketing event from planning through execution and closure. Drives workflow routing and reporting filters.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Classification of the marketing event by format and purpose. Drives reporting segmentation and lead attribution logic. [ENUM-REF-CANDIDATE: open_house|broker_preview|investor_day|property_launch|community_outreach|trade_show|webinar|networking|other — promote to reference product]' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedAttendance rdf:type rdf:Property ;
    rdfs:label 'Expected Attendance' ;
    rdfs:comment 'Planned or forecasted number of attendees for the event, set during event planning. Used for venue capacity planning, catering, and budget estimation.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invitationSentDate rdf:type rdf:Property ;
    rdfs:label 'Invitation Sent Date' ;
    rdfs:comment 'Date on which event invitations were distributed to the target audience. Used to measure lead time and optimize future event marketing timelines.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isPublic rdf:type rdf:Property ;
    rdfs:label 'Is Public' ;
    rdfs:comment 'Indicates whether the event is open to the general public (True) or restricted to invited guests only (False). Drives listing on public event portals and MLS open house feeds.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVirtual rdf:type rdf:Property ;
    rdfs:label 'Is Virtual' ;
    rdfs:comment 'Indicates whether the event is conducted entirely online (webinar, virtual tour, virtual investor day) rather than at a physical venue. Drives channel segmentation and platform cost allocation.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mlsOpenHouseCode rdf:type rdf:Property ;
    rdfs:label 'Mls Open House Code' ;
    rdfs:comment 'Identifier assigned by the Multiple Listing Service (MLS) when the event is published as an open house on the MLS feed. Nullable for non-open-house events.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postEventNotes rdf:type rdf:Property ;
    rdfs:label 'Post Event Notes' ;
    rdfs:comment 'Free-text field capturing qualitative observations, outcomes, and follow-up actions recorded by the event owner after the event concludes. Supports knowledge management and future event planning.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationCount rdf:type rdf:Property ;
    rdfs:label 'Registration Count' ;
    rdfs:comment 'Total number of individuals who registered or RSVP\'d for the event prior to the event date. Used to measure pre-event demand and plan logistics.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:registrationDeadline rdf:type rdf:Property ;
    rdfs:label 'Registration Deadline' ;
    rdfs:comment 'Last date by which attendees must register for the event. Used to close registration forms and finalize logistics planning.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiresRegistration rdf:type rdf:Property ;
    rdfs:label 'Requires Registration' ;
    rdfs:comment 'Indicates whether attendees must pre-register to attend the event. Drives registration workflow activation and capacity management.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceEventCode rdf:type rdf:Property ;
    rdfs:label 'Source Event Code' ;
    rdfs:comment 'Native identifier of this event record in the originating source system (e.g., Salesforce Event ID, Yardi event reference). Enables cross-system reconciliation and deduplication.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'Date and time when the marketing event is scheduled to begin or actually began. Principal real-world event time used for scheduling, lead attribution, and timeline reporting. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:theme rdf:type rdf:Property ;
    rdfs:label 'Theme' ;
    rdfs:comment 'Marketing theme or brand message associated with the event (e.g., \'Sustainable Living\', \'Prime CRE Investment Opportunities\'). Supports brand consistency and campaign alignment.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalEventCost rdf:type rdf:Property ;
    rdfs:label 'Total Event Cost' ;
    rdfs:comment 'Total actual expenditure incurred for the marketing event including venue rental, catering, AV equipment, marketing collateral, speaker fees, and travel. Used for OPEX tracking and marketing budget reconciliation.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:venueAddress rdf:type rdf:Property ;
    rdfs:label 'Venue Address' ;
    rdfs:comment 'Full street address of the event venue for in-person events. Used in invitations, wayfinding, and compliance records.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueName rdf:type rdf:Property ;
    rdfs:label 'Venue Name' ;
    rdfs:comment 'Name of the physical or virtual venue where the event is held (e.g., property address, hotel conference room, Zoom webinar). Used for logistics coordination and attendee communications.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:virtualEventUrl rdf:type rdf:Property ;
    rdfs:label 'Virtual Event Url' ;
    rdfs:comment 'Registration or join link for virtual events. Distributed to registrants and used for attendance tracking. Nullable for in-person events.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferredEventRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Transferred Event Registration Id' ;
    rdfs:comment 'Self-referencing FK on event_registration (transferred_event_registration_id)' ;
    rdfs:domain ind:EventRegistration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EventRegistration .

ind:accessibilityNeeds rdf:type rdf:Property ;
    rdfs:label 'Accessibility Needs' ;
    rdfs:comment 'Any accessibility or accommodation requirements noted by the registrant (e.g., wheelchair access, hearing loop, sign language interpreter). Supports ADA compliance and inclusive event management.' ;
    rdfs:domain ind:EventRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attendanceStatus rdf:type rdf:Property ;
    rdfs:label 'Attendance Status' ;
    rdfs:comment 'Current lifecycle state of the registration indicating whether the registrant ultimately attended, did not show, cancelled, or is on a waitlist. Core field for event ROI measurement and follow-up segmentation.' ;
    rdfs:domain ind:EventRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:badgePrinted rdf:type rdf:Property ;
    rdfs:label 'Badge Printed' ;
    rdfs:comment 'Indicates whether a name badge has been printed for this registrant for an in-person event. Used by event operations staff to manage check-in logistics and badge inventory.' ;
    rdfs:domain ind:EventRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetRange rdf:type rdf:Property ;
    rdfs:label 'Budget Range' ;
    rdfs:comment 'Self-reported budget or investment capacity range of the registrant (e.g., \'$1M–$5M\', \'$10M+\', \'Under $500K\'). Used for lead qualification and matching to appropriate properties or investment opportunities.' ;
    rdfs:domain ind:EventRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'Date on which the registrant cancelled their registration. Populated only when attendance_status is \'cancelled\'. Used for cancellation rate analysis and waitlist management.' ;
    rdfs:domain ind:EventRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:checkInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Check In Timestamp' ;
    rdfs:comment 'Date and time at which the registrant physically or virtually checked in to the event. Null if the registrant did not attend. Used to confirm actual attendance and calculate event attendance rates.' ;
    rdfs:domain ind:EventRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:checkOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Check Out Timestamp' ;
    rdfs:comment 'Date and time at which the registrant departed or disconnected from the event. Used to calculate dwell time and engagement depth for event analytics.' ;
    rdfs:domain ind:EventRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consentMarketing rdf:type rdf:Property ;
    rdfs:label 'Consent Marketing' ;
    rdfs:comment 'Indicates whether the registrant has provided explicit consent to receive future marketing communications from the firm. Mandatory for GDPR and CAN-SPAM compliance in post-event outreach campaigns.' ;
    rdfs:domain ind:EventRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dietaryRequirements rdf:type rdf:Property ;
    rdfs:label 'Dietary Requirements' ;
    rdfs:comment 'Special dietary requirements or restrictions noted by the registrant for in-person events with catering (e.g., vegetarian, halal, gluten-free, nut allergy). Supports event logistics and duty-of-care obligations.' ;
    rdfs:domain ind:EventRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpStatus rdf:type rdf:Property ;
    rdfs:label 'Follow Up Status' ;
    rdfs:comment 'Current status of post-event follow-up activities assigned to the marketing or brokerage team for this registrant. Drives CRM task management and ensures no warm leads are missed.' ;
    rdfs:domain ind:EventRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadConverted rdf:type rdf:Property ;
    rdfs:label 'Lead Converted' ;
    rdfs:comment 'Indicates whether this event registration has been converted into a qualified CRM lead or opportunity. True when a deal pipeline record has been created from this registration. Key metric for event ROI measurement.' ;
    rdfs:domain ind:EventRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registrantType rdf:type rdf:Property ;
    rdfs:label 'Registrant Type' ;
    rdfs:comment 'Classification of the registrant by their business relationship to the firm. Drives segmentation, follow-up workflows, and event ROI analysis by audience type. [ENUM-REF-CANDIDATE: prospect|broker|investor|tenant|media|internal_staff|sponsor|other — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:EventRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'The exact date and time (with timezone offset) at which the registrant completed their event registration. Serves as the principal business event timestamp for this transaction.' ;
    rdfs:domain ind:EventRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:registrationFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Registration Fee Amount' ;
    rdfs:comment 'Monetary fee charged to the registrant for attending the event, if applicable (e.g., paid investor summits, CRE conferences). Zero for complimentary events. Supports event revenue tracking.' ;
    rdfs:domain ind:EventRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registrationSource rdf:type rdf:Property ;
    rdfs:label 'Registration Source' ;
    rdfs:comment 'The channel or touchpoint through which the registrant signed up for the event. Enables multi-channel attribution analysis and optimization of event promotion spend. [ENUM-REF-CANDIDATE: web_form|email_invite|broker_referral|social_media|direct_outreach|phone|walk_in|partner_portal|other — promote to reference product if additional sources are needed]' ;
    rdfs:domain ind:EventRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:virtualJoinUrl rdf:type rdf:Property ;
    rdfs:label 'Virtual Join Url' ;
    rdfs:comment 'Unique personalized URL issued to the registrant for joining a virtual or hybrid event (e.g., webinar, virtual property tour, online investor briefing). Null for in-person-only events.' ;
    rdfs:domain ind:EventRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentChannelId rdf:type rdf:Property ;
    rdfs:label 'Parent Channel Id' ;
    rdfs:comment 'Self-referencing FK on channel (parent_channel_id)' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'The date on which this marketing channel was first activated and made available for campaign use within the enterprise. Used for channel lifecycle tracking and historical attribution analysis.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:audienceType rdf:type rdf:Property ;
    rdfs:label 'Audience Type' ;
    rdfs:comment 'The primary audience segment this channel is designed to reach: tenant (prospective lessees), buyer (property purchasers), investor (REIT/fund/private investors), broker (co-broker and referral network), owner (property owners seeking management or disposition), general (broad public awareness). Supports audience-based channel selection.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkCpcAmount rdf:type rdf:Property ;
    rdfs:label 'Benchmark Cpc Amount' ;
    rdfs:comment 'The enterprise\'s internal benchmark or contracted rate for Cost Per Click (CPC) on this channel. Used for paid digital channel budget planning and performance benchmarking against actual campaign spend.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchmarkCplAmount rdf:type rdf:Property ;
    rdfs:label 'Benchmark Cpl Amount' ;
    rdfs:comment 'The enterprise\'s internal benchmark or contracted rate for Cost Per Lead (CPL) on this channel, expressed in the channel\'s cost currency. Used for budget planning, campaign ROI benchmarking, and vendor performance evaluation. Not a calculated metric — this is the agreed or target rate.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchmarkCpmAmount rdf:type rdf:Property ;
    rdfs:label 'Benchmark Cpm Amount' ;
    rdfs:comment 'The enterprise\'s internal benchmark or contracted rate for Cost Per Mille (CPM — cost per 1,000 impressions) on this channel. Used for media planning and spend efficiency comparisons across digital and OOH channels.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:callTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Call Tracking Number' ;
    rdfs:comment 'Dedicated phone number assigned to this channel for call attribution tracking (e.g., a unique number displayed on a billboard or portal listing to measure inbound call volume from that channel). Confidential as it is a business operational asset.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:canSpamCompliant rdf:type rdf:Property ;
    rdfs:label 'Can Spam Compliant' ;
    rdfs:comment 'Indicates whether this channel (specifically email channels) complies with the CAN-SPAM Act requirements for commercial email, including unsubscribe mechanisms, sender identification, and subject line accuracy. Applicable to email marketing channels.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelCategory rdf:type rdf:Property ;
    rdfs:label 'Channel Category' ;
    rdfs:comment 'Standardized top-level taxonomy category classifying the channel by its nature and reach method. Enables consistent spend categorization and cross-channel attribution analysis. Values: digital_paid (paid search/display), digital_organic (SEO/content), social_media, email, direct_mail, ooh (Out-of-Home), events, referral, broker_network, mls_portal. [ENUM-REF-CANDIDATE: digital_paid|digital_organic|social_media|email|direct_mail|ooh|events|referral|broker_network|mls_portal — promote to reference product]' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelCode rdf:type rdf:Property ;
    rdfs:label 'Channel Code' ;
    rdfs:comment 'Short, unique alphanumeric code used to identify the channel across systems, campaign tagging, and UTM parameter construction (e.g., GOOG_PAID, EMAIL_DRIP, MLS_PORTAL). Serves as the externally-known business identifier for the channel.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelDescription rdf:type rdf:Property ;
    rdfs:label 'Channel Description' ;
    rdfs:comment 'Detailed narrative description of the channel\'s purpose, audience reach, typical use cases within the real estate portfolio, and any operational notes relevant to campaign planners and marketing analysts.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelName rdf:type rdf:Property ;
    rdfs:label 'Channel Name' ;
    rdfs:comment 'Human-readable name of the marketing channel as displayed in campaign management tools, dashboards, and reports (e.g., \'Google Paid Search\', \'CoStar Listings Portal\', \'Email Newsletter\', \'Broker Referral Network\').' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelStatus rdf:type rdf:Property ;
    rdfs:label 'Channel Status' ;
    rdfs:comment 'Current operational lifecycle status of the marketing channel record. Active channels are available for campaign assignment. Inactive channels are suspended. Pending channels are being onboarded. Deprecated channels are retired from use but retained for historical attribution. Under_review channels are being evaluated.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'The date on which the enterprise\'s contract or agreement with the channel platform or vendor expires or is scheduled to terminate. Used for vendor renewal management and budget cycle planning.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'The date on which the enterprise\'s contract or agreement with the channel platform or vendor becomes effective. Relevant for channels with formal vendor agreements (e.g., CoStar, LoopNet, Zillow Premier Agent).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code applicable to cost benchmarks and rate cards for this channel (e.g., \'USD\', \'CAD\', \'GBP\'). Ensures consistent financial reporting across multi-currency portfolios.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costModel rdf:type rdf:Property ;
    rdfs:label 'Cost Model' ;
    rdfs:comment 'The pricing or billing model under which this channel charges for marketing activity. CPM (Cost Per Mille/Thousand Impressions), CPC (Cost Per Click), CPL (Cost Per Lead), flat_fee (fixed periodic fee), revenue_share (percentage of transaction), CPA (Cost Per Acquisition), free (no direct cost). Drives budget planning and ROI benchmarking. [ENUM-REF-CANDIDATE: cpm|cpc|cpl|flat_fee|revenue_share|cpa|free — promote to reference product]' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalFlag rdf:type rdf:Property ;
    rdfs:label 'Digital Flag' ;
    rdfs:comment 'Indicates whether this is a digital channel (True) or a traditional/offline channel (False). Used to segment digital vs. non-digital spend reporting and to apply digital-specific tracking and compliance rules.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprCompliant rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliant' ;
    rdfs:comment 'Indicates whether this channel\'s data collection and tracking practices have been reviewed and confirmed as compliant with GDPR requirements. Relevant for digital channels collecting prospect data from EU-based audiences. Required for compliance reporting.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'The geographic reach of this marketing channel — local (single market/city), regional (multi-market/state), national (country-wide), or international. Used to match channel selection to campaign geographic targeting requirements.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:idxFeedSupported rdf:type rdf:Property ;
    rdfs:label 'Idx Feed Supported' ;
    rdfs:comment 'Indicates whether this channel supports automated IDX (Internet Data Exchange) listing feed syndication. True for portals that accept automated property data feeds from MLS or internal listing systems.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadAttributionWeight rdf:type rdf:Property ;
    rdfs:label 'Lead Attribution Weight' ;
    rdfs:comment 'The fractional weight (0.0000 to 1.0000) assigned to this channel in the enterprise\'s multi-touch lead attribution model. Used by the analytics layer to distribute lead credit across channels in the prospect journey. A value of 1.0 indicates single-touch attribution. This is a configured business rule, not a calculated metric.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Min Spend Amount' ;
    rdfs:comment 'The minimum spend commitment required to activate or maintain this channel, as defined by the vendor contract or platform policy. Used in budget planning to ensure channel activation thresholds are met.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mlsAffiliated rdf:type rdf:Property ;
    rdfs:label 'Mls Affiliated' ;
    rdfs:comment 'Indicates whether this channel is affiliated with or operates through a Multiple Listing Service (MLS) network. True for MLS portals and IDX-feed-based platforms. Relevant for compliance with MLS rules and NAR data sharing policies.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownedPaidEarned rdf:type rdf:Property ;
    rdfs:label 'Owned Paid Earned' ;
    rdfs:comment 'Classifies the channel within the standard marketing OPE (Owned, Paid, Earned) framework. Owned: channels the enterprise controls directly (website, email list, social profiles). Paid: channels requiring direct media spend (Google Ads, CoStar paid placement). Earned: channels driven by third-party advocacy (organic referrals, press, broker word-of-mouth).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pixelTagCode rdf:type rdf:Property ;
    rdfs:label 'Pixel Tag Code' ;
    rdfs:comment 'The unique identifier of the conversion or retargeting pixel deployed for this channel (e.g., Facebook Pixel ID, Google Tag Manager container ID, LinkedIn Insight Tag ID). Used for pixel-based attribution and audience retargeting configuration.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoCode rdf:type rdf:Property ;
    rdfs:label 'Promo Code' ;
    rdfs:comment 'Unique promotional or vanity code associated with this channel for offline or print attribution (e.g., \'DIRECT2024\', \'BROKER10\'). Prospects entering this code during inquiry or application are attributed to this channel.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemChannelCode rdf:type rdf:Property ;
    rdfs:label 'Source System Channel Code' ;
    rdfs:comment 'The native identifier of this channel record in the originating source system (e.g., Salesforce Campaign Source ID, Yardi Marketing Channel Code). Used for cross-system reconciliation and ETL lineage tracing.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tcpaCompliant rdf:type rdf:Property ;
    rdfs:label 'Tcpa Compliant' ;
    rdfs:comment 'Indicates whether this channel (specifically call tracking, SMS, and direct outreach channels) complies with TCPA requirements for prior express written consent before automated calls or texts. Applicable to call tracking and SMS channels.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trackingCapability rdf:type rdf:Property ;
    rdfs:label 'Tracking Capability' ;
    rdfs:comment 'The primary tracking mechanism supported by this channel for attribution and performance measurement. UTM (Urchin Tracking Module parameters for digital links), pixel (conversion/retargeting pixel), call_tracking (dedicated phone number tracking), qr_code, promo_code, none (no tracking available), multiple (supports more than one method). Critical for lead attribution accuracy. [ENUM-REF-CANDIDATE: utm|pixel|call_tracking|qr_code|promo_code|none|multiple — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energyMeterId rdf:type rdf:Property ;
    rdfs:label 'Energy Meter Id' ;
    rdfs:comment 'Unique surrogate identifier for the energy meter master record in the lakehouse silver layer. Primary key for this entity.' ;
    rdfs:domain ind:EnergyMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentMeterEnergyMeterId rdf:type rdf:Property ;
    rdfs:label 'Parent Meter Energy Meter Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent (master) meter in a hierarchical metering configuration. Null for top-level main meters. Enables submeter-to-master reconciliation for tenant utility cost allocation and loss/variance analysis.' ;
    rdfs:domain ind:EnergyMeter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnergyMeter .

ind:primaryEnergySuiteUnitId rdf:type rdf:Property ;
    rdfs:label 'Primary Energy Suite Unit Id' ;
    rdfs:comment 'Reference to the specific leasable suite or unit served by this meter, enabling direct tenant utility cost allocation and submeter reconciliation against master meter readings.' ;
    rdfs:domain ind:EnergyMeter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:primaryReplacedEnergyMeterId rdf:type rdf:Property ;
    rdfs:label 'Primary Replaced Energy Meter Id' ;
    rdfs:comment 'Self-referencing FK on energy_meter (replaced_energy_meter_id)' ;
    rdfs:domain ind:EnergyMeter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnergyMeter .

ind:buildingEnginesMeterCode rdf:type rdf:Property ;
    rdfs:label 'Building Engines Meter Code' ;
    rdfs:comment 'The native meter identifier in the Building Engines CMMS source system. Used for data lineage, reconciliation between the lakehouse silver layer and the operational system of record, and troubleshooting ETL discrepancies.' ;
    rdfs:domain ind:EnergyMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:camBillable rdf:type rdf:Property ;
    rdfs:label 'Cam Billable' ;
    rdfs:comment 'Indicates whether utility costs recorded by this meter are included in the Common Area Maintenance (CAM) expense pool for tenant pro-rata billing. Critical for NNN and gross lease CAM reconciliation under FASB ASC 842.' ;
    rdfs:domain ind:EnergyMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:communicationProtocol rdf:type rdf:Property ;
    rdfs:label 'Communication Protocol' ;
    rdfs:comment 'The data communication protocol used by the smart meter to transmit readings to the building management system or energy monitoring platform (e.g., BACnet, Modbus, DLMS/COSEM). Relevant only for smart/AMI meters; null or \'none\' for manually read meters. [ENUM-REF-CANDIDATE: Modbus|BACnet|DLMS_COSEM|ZigBee|LoRaWAN|pulse|none|other — promote to reference product]' ;
    rdfs:domain ind:EnergyMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dialDigits rdf:type rdf:Property ;
    rdfs:label 'Dial Digits' ;
    rdfs:comment 'Number of digits on the meter register dial. Used to detect meter rollover (when the reading resets to zero after reaching maximum) and ensure accurate consumption calculation between consecutive reads.' ;
    rdfs:domain ind:EnergyMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:energyStarPropertyCode rdf:type rdf:Property ;
    rdfs:label 'Energy Star Property Code' ;
    rdfs:comment 'The property identifier in the EPA ENERGY STAR Portfolio Manager platform to which this meter\'s consumption data is reported. Enables automated data push for energy benchmarking, ENERGY STAR certification, and regulatory benchmarking compliance (e.g., NYC Local Law 84).' ;
    rdfs:domain ind:EnergyMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgTracked rdf:type rdf:Property ;
    rdfs:label 'Esg Tracked' ;
    rdfs:comment 'Indicates whether consumption data from this meter is included in the portfolio\'s ESG reporting boundary for greenhouse gas emissions, energy intensity, and sustainability benchmarking (e.g., ENERGY STAR, GRESB, LEED).' ;
    rdfs:domain ind:EnergyMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSmartMeter rdf:type rdf:Property ;
    rdfs:label 'Is Smart Meter' ;
    rdfs:comment 'Indicates whether the meter is an Advanced Metering Infrastructure (AMI) smart meter capable of automated, interval-based data transmission. Drives data ingestion pipeline routing and enables real-time energy monitoring and demand response programs.' ;
    rdfs:domain ind:EnergyMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Last Calibration Date' ;
    rdfs:comment 'Date the meter was last calibrated or tested for accuracy. Supports preventive maintenance scheduling, regulatory compliance with utility measurement standards, and data quality assurance for energy benchmarking.' ;
    rdfs:domain ind:EnergyMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReadDate rdf:type rdf:Property ;
    rdfs:label 'Last Read Date' ;
    rdfs:comment 'The date of the most recent meter reading recorded for this meter. Used to identify stale or missing reads, trigger alerts for data collection failures, and support billing cycle management.' ;
    rdfs:domain ind:EnergyMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReadValue rdf:type rdf:Property ;
    rdfs:label 'Last Read Value' ;
    rdfs:comment 'The most recent consumption reading recorded for this meter, expressed in the meter\'s unit of measure. Used as the baseline for the next billing period calculation and for detecting anomalous consumption spikes.' ;
    rdfs:domain ind:EnergyMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meterName rdf:type rdf:Property ;
    rdfs:label 'Meter Name' ;
    rdfs:comment 'Human-readable descriptive label for the meter (e.g., \'Main Electric Panel — Tower A\', \'Gas Meter — Basement Boiler Room\'). Used in operational dashboards, work orders, and tenant utility billing reports.' ;
    rdfs:domain ind:EnergyMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meterNumber rdf:type rdf:Property ;
    rdfs:label 'Meter Number' ;
    rdfs:comment 'The externally-known unique identifier assigned to the meter by the utility provider or the property management system. Used for utility billing reconciliation, provider correspondence, and field identification.' ;
    rdfs:domain ind:EnergyMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meterStatus rdf:type rdf:Property ;
    rdfs:label 'Meter Status' ;
    rdfs:comment 'Current operational lifecycle status of the meter. Drives inclusion in active utility billing runs, ESG reporting, and preventive maintenance scheduling.' ;
    rdfs:domain ind:EnergyMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meterSubtype rdf:type rdf:Property ;
    rdfs:label 'Meter Subtype' ;
    rdfs:comment 'Further classification of the meter within its type, distinguishing main utility meters from submeters used for tenant-level cost allocation, check meters for validation, or smart/interval meters for real-time monitoring. [ENUM-REF-CANDIDATE: main|submeter|check_meter|interval|smart|pulse|other — promote to reference product]' ;
    rdfs:domain ind:EnergyMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meterType rdf:type rdf:Property ;
    rdfs:label 'Meter Type' ;
    rdfs:comment 'Classification of the utility commodity measured by this meter. Drives cost allocation methodology, ESG reporting categories, and benchmarking peer groups. [ENUM-REF-CANDIDATE: electric|gas|water|steam|chilled_water|solar|other — promote to reference product]' ;
    rdfs:domain ind:EnergyMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiplier rdf:type rdf:Property ;
    rdfs:label 'Multiplier' ;
    rdfs:comment 'The demand multiplier or meter constant applied to raw dial readings to calculate actual consumption. Common for high-voltage or high-volume meters where the dial registers a fraction of actual usage. Critical for accurate billing and ESG reporting.' ;
    rdfs:domain ind:EnergyMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextCalibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Calibration Due Date' ;
    rdfs:comment 'Scheduled date for the next meter calibration or accuracy test. Drives preventive maintenance work order generation and ensures continuous compliance with utility measurement standards.' ;
    rdfs:domain ind:EnergyMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:readFrequency rdf:type rdf:Property ;
    rdfs:label 'Read Frequency' ;
    rdfs:comment 'The scheduled frequency at which meter readings are collected, either automatically via AMI/smart meter or manually by a technician. Drives data ingestion scheduling, billing cycle alignment, and energy benchmarking cadence.' ;
    rdfs:domain ind:EnergyMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readMethod rdf:type rdf:Property ;
    rdfs:label 'Read Method' ;
    rdfs:comment 'Method by which meter readings are obtained. Automatic reads come from AMI/smart meter telemetry; manual reads are recorded by field technicians; estimated reads are utility-provider projections; remote reads use utility provider remote access.' ;
    rdfs:domain ind:EnergyMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilityRateSchedule rdf:type rdf:Property ;
    rdfs:label 'Utility Rate Schedule' ;
    rdfs:comment 'The tariff or rate schedule code assigned by the utility provider (e.g., \'SC-9\', \'General Service Large\'). Determines the billing rate structure applied to consumption readings and is critical for utility cost forecasting and OPEX budgeting.' ;
    rdfs:domain ind:EnergyMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yardiMeterCode rdf:type rdf:Property ;
    rdfs:label 'Yardi Meter Code' ;
    rdfs:comment 'The meter identifier in Yardi Voyager used for utility billing and accounts payable invoice matching. Enables cross-system reconciliation between the CMMS meter record and the property accounting system.' ;
    rdfs:domain ind:EnergyMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendedPurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Amended Purchase Order Id' ;
    rdfs:comment 'Self-referencing FK on purchase_order (amended_purchase_order_id)' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:billingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line2' ;
    rdfs:comment 'Second line of the billing address, typically suite or department number.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCity rdf:type rdf:Property ;
    rdfs:label 'Billing City' ;
    rdfs:comment 'City name for the billing address.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Billing Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the billing address.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the billing address.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Billing State Province' ;
    rdfs:comment 'State or province code for the billing address.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledDate rdf:type rdf:Property ;
    rdfs:label 'Cancelled Date' ;
    rdfs:comment 'The date on which the purchase order was cancelled, if applicable.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'The date on which the purchase order was closed after all goods were received and invoices processed.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isCapitalExpenditure rdf:type rdf:Property ;
    rdfs:label 'Is Capital Expenditure' ;
    rdfs:comment 'Boolean flag indicating whether this purchase order represents a capital expenditure that will be capitalized on the balance sheet rather than expensed.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUrgent rdf:type rdf:Property ;
    rdfs:label 'Is Urgent' ;
    rdfs:comment 'Boolean flag indicating whether this purchase order requires expedited processing and delivery.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'The date and time when this purchase order record was last modified. Audit trail field.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:poDate rdf:type rdf:Property ;
    rdfs:label 'Po Date' ;
    rdfs:comment 'The date on which the purchase order was created and issued to the vendor. Principal business event timestamp.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poStatus rdf:type rdf:Property ;
    rdfs:label 'Po Status' ;
    rdfs:comment 'Current lifecycle status of the purchase order in the procurement workflow.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poType rdf:type rdf:Property ;
    rdfs:label 'Po Type' ;
    rdfs:comment 'Classification of the purchase order based on procurement strategy and usage pattern.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promisedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Promised Delivery Date' ;
    rdfs:comment 'The date by which the vendor has committed to deliver goods or complete services.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'The date by which the buyer requests delivery of goods or completion of services.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shippingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Shipping Address Line1' ;
    rdfs:comment 'First line of the physical address where goods should be delivered.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Shipping Address Line2' ;
    rdfs:comment 'Second line of the physical address where goods should be delivered, typically suite or unit number.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingAmount rdf:type rdf:Property ;
    rdfs:label 'Shipping Amount' ;
    rdfs:comment 'The freight or shipping charges associated with delivery of goods for this purchase order.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shippingCity rdf:type rdf:Property ;
    rdfs:label 'Shipping City' ;
    rdfs:comment 'City name for the shipping address.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the shipping address.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingMethod rdf:type rdf:Property ;
    rdfs:label 'Shipping Method' ;
    rdfs:comment 'The method by which goods will be shipped or delivered to the buyer location.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the shipping address.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Shipping State Province' ;
    rdfs:comment 'State or province code for the shipping address.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Subtotal Amount' ;
    rdfs:comment 'The sum of all line item amounts before taxes, fees, and discounts are applied.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'The final total amount of the purchase order including subtotal, taxes, shipping, and discounts. Net payable amount.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorContactEmail rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Email' ;
    rdfs:comment 'Email address of the primary vendor contact for communication regarding this purchase order.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reprocessedPaymentRunId rdf:type rdf:Property ;
    rdfs:label 'Reprocessed Payment Run Id' ;
    rdfs:comment 'Self-referencing FK on payment_run (reprocessed_payment_run_id)' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentRun .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether this payment run requires formal approval before execution (True) or can be executed without approval (False).' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:batchReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Reference Number' ;
    rdfs:comment 'External batch reference number assigned by the payment processor or banking system for tracking purposes.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'The date and time when this payment run was cancelled.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:executedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Executed Timestamp' ;
    rdfs:comment 'The date and time when this payment run was executed and payment processing was initiated.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:failedAmount rdf:type rdf:Property ;
    rdfs:label 'Failed Amount' ;
    rdfs:comment 'The total monetary value of payments that failed to process in this run.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failedPaymentCount rdf:type rdf:Property ;
    rdfs:label 'Failed Payment Count' ;
    rdfs:comment 'The number of payments that failed to process or were rejected during this run.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentRunStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Run Status' ;
    rdfs:comment 'Current lifecycle status of the payment run indicating its stage in the approval and execution workflow.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingNotes rdf:type rdf:Property ;
    rdfs:label 'Processing Notes' ;
    rdfs:comment 'Free-text notes or comments related to the processing of this payment run, including any issues or special handling instructions.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runName rdf:type rdf:Property ;
    rdfs:label 'Run Name' ;
    rdfs:comment 'Descriptive name assigned to the payment run for identification purposes (e.g., \'Q1 2024 Vendor Payments\', \'Monthly Lease Payments - March\').' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runNumber rdf:type rdf:Property ;
    rdfs:label 'Run Number' ;
    rdfs:comment 'Business-facing unique identifier for the payment run, typically formatted as PR-YYYYMMDD-NNNN.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runType rdf:type rdf:Property ;
    rdfs:label 'Run Type' ;
    rdfs:comment 'Classification of the payment run based on the nature of payments being processed.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successfulAmount rdf:type rdf:Property ;
    rdfs:label 'Successful Amount' ;
    rdfs:comment 'The total monetary value of payments that were successfully processed in this run.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:successfulPaymentCount rdf:type rdf:Property ;
    rdfs:label 'Successful Payment Count' ;
    rdfs:comment 'The number of payments that were successfully processed and disbursed in this run.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPaymentCount rdf:type rdf:Property ;
    rdfs:label 'Total Payment Count' ;
    rdfs:comment 'The total number of individual payment transactions included in this payment run.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentLenderId rdf:type rdf:Property ;
    rdfs:label 'Parent Lender Id' ;
    rdfs:comment 'Self-referencing FK on lender (parent_lender_id)' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lender .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'First line of the lender\'s primary business address, typically street address.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Second line of the lender\'s primary business address, typically suite or floor number.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debtServiceCoverageRatioMin rdf:type rdf:Property ;
    rdfs:label 'Debt Service Coverage Ratio Min' ;
    rdfs:comment 'Minimum debt service coverage ratio required by this lender for loan approval, expressed as a decimal (e.g., 1.25 for 1.25x coverage).' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:federalReserveRoutingNumber rdf:type rdf:Property ;
    rdfs:label 'Federal Reserve Routing Number' ;
    rdfs:comment 'Nine-digit ABA routing number for the lender, used for wire transfers and ACH transactions.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lenderCode rdf:type rdf:Property ;
    rdfs:label 'Lender Code' ;
    rdfs:comment 'The externally-known unique code or identifier for the lender, used in loan documentation and financial systems.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lenderName rdf:type rdf:Property ;
    rdfs:label 'Lender Name' ;
    rdfs:comment 'The full legal name of the lending institution or financial entity.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lenderStatus rdf:type rdf:Property ;
    rdfs:label 'Lender Status' ;
    rdfs:comment 'Current operational status of the lender relationship in the system lifecycle.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lenderType rdf:type rdf:Property ;
    rdfs:label 'Lender Type' ;
    rdfs:comment 'Classification of the lender by institution type.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lendingCapacityAmount rdf:type rdf:Property ;
    rdfs:label 'Lending Capacity Amount' ;
    rdfs:comment 'Maximum lending capacity or credit line available from this lender for real estate financing.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loanToValueRatioMax rdf:type rdf:Property ;
    rdfs:label 'Loan To Value Ratio Max' ;
    rdfs:comment 'Maximum loan-to-value ratio that this lender will accept for real estate financing, expressed as a decimal (e.g., 0.75 for 75%).' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumLoanAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Loan Amount' ;
    rdfs:comment 'Maximum loan amount that this lender will underwrite for a single real estate transaction.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumLoanAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Loan Amount' ;
    rdfs:comment 'Minimum loan amount that this lender will underwrite for real estate transactions.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredLenderFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Lender Flag' ;
    rdfs:comment 'Indicates whether this lender has preferred status for financing transactions.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:propertyTypesFinanced rdf:type rdf:Property ;
    rdfs:label 'Property Types Financed' ;
    rdfs:comment 'Comma-separated list of property types that this lender will finance (e.g., multifamily, office, retail, industrial, mixed-use).' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalInterestRate rdf:type rdf:Property ;
    rdfs:label 'Typical Interest Rate' ;
    rdfs:comment 'Typical or baseline interest rate offered by this lender, expressed as a decimal (e.g., 0.0525 for 5.25%).' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Primary website URL for the lending institution.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentLedgerId rdf:type rdf:Property ;
    rdfs:label 'Parent Ledger Id' ;
    rdfs:comment 'Reference to the parent ledger in a hierarchical ledger structure, if applicable.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ledger .

ind:accountingBasis rdf:type rdf:Property ;
    rdfs:label 'Accounting Basis' ;
    rdfs:comment 'The accounting method applied to this ledger (accrual, cash, or modified accrual basis).' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Enabled Flag' ;
    rdfs:comment 'Indicates whether detailed audit trail logging is enabled for all transactions posted to this ledger.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoReversalEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Reversal Enabled Flag' ;
    rdfs:comment 'Indicates whether automatic reversal of accrual entries is enabled for this ledger.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetTrackingEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Budget Tracking Enabled Flag' ;
    rdfs:comment 'Indicates whether budget versus actual tracking and variance analysis is enabled for this ledger.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consolidationFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidation Flag' ;
    rdfs:comment 'Indicates whether this ledger is included in consolidated financial reporting.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:encumbranceAccountingFlag rdf:type rdf:Property ;
    rdfs:label 'Encumbrance Accounting Flag' ;
    rdfs:comment 'Indicates whether encumbrance accounting (commitment tracking) is enabled for this ledger.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalLedgerReference rdf:type rdf:Property ;
    rdfs:label 'External Ledger Reference' ;
    rdfs:comment 'External reference identifier or code used by upstream source systems to identify this ledger.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearStartMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Start Month' ;
    rdfs:comment 'Month number (1-12) indicating the start of the fiscal year for this ledger.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:intercompanyEliminationFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Elimination Flag' ;
    rdfs:comment 'Indicates whether intercompany transactions in this ledger are subject to elimination during consolidation.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:journalApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Journal Approval Required Flag' ;
    rdfs:comment 'Indicates whether journal entries posted to this ledger require managerial approval before posting.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ledgerCode rdf:type rdf:Property ;
    rdfs:label 'Ledger Code' ;
    rdfs:comment 'Unique business identifier code for the ledger, used for external reference and reporting.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerDescription rdf:type rdf:Property ;
    rdfs:label 'Ledger Description' ;
    rdfs:comment 'Detailed textual description of the ledger\'s purpose, scope, and usage within the financial system.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerName rdf:type rdf:Property ;
    rdfs:label 'Ledger Name' ;
    rdfs:comment 'Human-readable name of the ledger (e.g., General Ledger, Property Ledger, Subsidiary Ledger).' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerStatus rdf:type rdf:Property ;
    rdfs:label 'Ledger Status' ;
    rdfs:comment 'Current operational status of the ledger in the financial system lifecycle.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerType rdf:type rdf:Property ;
    rdfs:label 'Ledger Type' ;
    rdfs:comment 'Classification of the ledger by its functional purpose within the financial system.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiCurrencyEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Multi Currency Enabled Flag' ;
    rdfs:comment 'Indicates whether this ledger supports transactions in multiple currencies with automatic conversion.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodCloseDay rdf:type rdf:Property ;
    rdfs:label 'Period Close Day' ;
    rdfs:comment 'The day of the month (1-31) on which accounting periods are typically closed for this ledger.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingSegment rdf:type rdf:Property ;
    rdfs:label 'Reporting Segment' ;
    rdfs:comment 'Business segment or division classification for financial reporting and analysis purposes.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retainedEarningsAccountCode rdf:type rdf:Property ;
    rdfs:label 'Retained Earnings Account Code' ;
    rdfs:comment 'The general ledger account code used for retained earnings in this ledger\'s chart of accounts.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Compliant Flag' ;
    rdfs:comment 'Indicates whether this ledger is subject to Sarbanes-Oxley Act compliance controls and audit requirements.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suspenseAccountCode rdf:type rdf:Property ;
    rdfs:label 'Suspense Account Code' ;
    rdfs:comment 'The general ledger account code used for suspense or unallocated transactions in this ledger.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentPeriodReportingPeriodId rdf:type rdf:Property ;
    rdfs:label 'Parent Period Reporting Period Id' ;
    rdfs:comment 'Reference to the parent reporting period for hierarchical period structures (e.g., monthly period rolling up to quarterly period). Null for top-level periods.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReportingPeriod .

ind:primaryPriorReportingPeriodId rdf:type rdf:Property ;
    rdfs:label 'Primary Prior Reporting Period Id' ;
    rdfs:comment 'Self-referencing FK on reporting_period (prior_reporting_period_id)' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReportingPeriod .

ind:calendarMonth rdf:type rdf:Property ;
    rdfs:label 'Calendar Month' ;
    rdfs:comment 'The calendar month within the calendar year (1-12). Null for non-monthly periods.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarQuarter rdf:type rdf:Property ;
    rdfs:label 'Calendar Quarter' ;
    rdfs:comment 'The calendar quarter within the calendar year (1, 2, 3, or 4). Null for non-quarterly periods.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarYear rdf:type rdf:Property ;
    rdfs:label 'Calendar Year' ;
    rdfs:comment 'The calendar year to which this reporting period belongs (e.g., 2024).' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Month' ;
    rdfs:comment 'The fiscal month within the fiscal year (1-12). Null for non-monthly periods.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isAdjustmentPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Adjustment Period' ;
    rdfs:comment 'Indicates whether this period is designated for year-end or period-end adjustments (e.g., 13th period in some accounting systems).' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCurrentPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Current Period' ;
    rdfs:comment 'Indicates whether this is the current active reporting period for financial transactions and reporting.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLeapYear rdf:type rdf:Property ;
    rdfs:label 'Is Leap Year' ;
    rdfs:comment 'Indicates whether the reporting period falls within a leap year (366 days). Relevant for daily and annual period calculations.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lockedDate rdf:type rdf:Property ;
    rdfs:label 'Locked Date' ;
    rdfs:comment 'The date when the reporting period was locked and finalized. Null if period is not locked. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:numberOfBusinessDays rdf:type rdf:Property ;
    rdfs:label 'Number Of Business Days' ;
    rdfs:comment 'Total number of business days (excluding weekends and holidays) in the reporting period.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfDays rdf:type rdf:Property ;
    rdfs:label 'Number Of Days' ;
    rdfs:comment 'Total number of calendar days in the reporting period.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodCode rdf:type rdf:Property ;
    rdfs:label 'Period Code' ;
    rdfs:comment 'Standardized code representing the reporting period, used for system integration and reporting (e.g., \'2024Q1\', \'202401\', \'FY2024\').' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodName rdf:type rdf:Property ;
    rdfs:label 'Period Name' ;
    rdfs:comment 'Human-readable name or label for the reporting period (e.g., \'Q1 2024\', \'January 2024\', \'FY2024\').' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the primary reporting currency used in this period (e.g., \'USD\', \'EUR\', \'GBP\').' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodDescription rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Description' ;
    rdfs:comment 'Detailed description or notes about the reporting period, including any special circumstances or adjustments.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodStatus rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Status' ;
    rdfs:comment 'Current lifecycle status of the reporting period. Open: transactions can be posted; Closed: period is closed for new transactions; Locked: period is finalized and cannot be reopened; Archived: historical period retained for compliance.' ;
    rdfs:domain ind:ReportingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentFloorId rdf:type rdf:Property ;
    rdfs:label 'Parent Floor Id' ;
    rdfs:comment 'Self-referencing FK on floor (parent_floor_id)' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Floor .

ind:adaCompliant rdf:type rdf:Property ;
    rdfs:label 'Ada Compliant' ;
    rdfs:comment 'Indicates whether the floor meets ADA accessibility standards for persons with disabilities.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cctvCoverage rdf:type rdf:Property ;
    rdfs:label 'Cctv Coverage' ;
    rdfs:comment 'Indicates whether the floor is monitored by CCTV security cameras.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ceilingHeightM rdf:type rdf:Property ;
    rdfs:label 'Ceiling Height M' ;
    rdfs:comment 'Standard ceiling height from finished floor to finished ceiling, measured in meters.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificateOfOccupancyDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Occupancy Date' ;
    rdfs:comment 'Date when the Certificate of Occupancy was issued for this floor, permitting legal occupancy.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commonAreaSqft rdf:type rdf:Property ;
    rdfs:label 'Common Area Sqft' ;
    rdfs:comment 'Shared spaces on the floor such as lobbies, corridors, restrooms, and elevator lobbies. Measured in square feet.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commonAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Common Area Sqm' ;
    rdfs:comment 'Shared spaces on the floor such as lobbies, corridors, restrooms, and elevator lobbies. Measured in square meters.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:elevatorAccess rdf:type rdf:Property ;
    rdfs:label 'Elevator Access' ;
    rdfs:comment 'Indicates whether the floor is served by elevator access.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emergencyExitCount rdf:type rdf:Property ;
    rdfs:label 'Emergency Exit Count' ;
    rdfs:comment 'Number of emergency exits or egress points available on the floor.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finishType rdf:type rdf:Property ;
    rdfs:label 'Finish Type' ;
    rdfs:comment 'Type of flooring material or finish installed (e.g., carpet, tile, hardwood, concrete, vinyl).' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireZoneDesignation rdf:type rdf:Property ;
    rdfs:label 'Fire Zone Designation' ;
    rdfs:comment 'Fire safety zone classification for emergency response and compartmentalization.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorName rdf:type rdf:Property ;
    rdfs:label 'Floor Name' ;
    rdfs:comment 'Common or marketing name for the floor (e.g., Executive Suite Level, Retail Concourse, Sky Lobby).' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorNumber rdf:type rdf:Property ;
    rdfs:label 'Floor Number' ;
    rdfs:comment 'The floor number or level designation within the building (e.g., 1, 2, B1 for basement 1, M for mezzanine, PH for penthouse). May include alphanumeric codes for special levels.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorStatus rdf:type rdf:Property ;
    rdfs:label 'Floor Status' ;
    rdfs:comment 'Current operational status of the floor in its lifecycle.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorType rdf:type rdf:Property ;
    rdfs:label 'Floor Type' ;
    rdfs:comment 'Classification of the floor based on its position and function within the building structure.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossFloorAreaSqft rdf:type rdf:Property ;
    rdfs:label 'Gross Floor Area Sqft' ;
    rdfs:comment 'Total floor area measured to the exterior face of exterior walls, including all enclosed spaces. Measured in square feet.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossFloorAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Gross Floor Area Sqm' ;
    rdfs:comment 'Total floor area measured to the exterior face of exterior walls, including all enclosed spaces. Measured in square meters.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastRenovationDate rdf:type rdf:Property ;
    rdfs:label 'Last Renovation Date' ;
    rdfs:comment 'Date of the most recent renovation or refurbishment work performed on the floor.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loadCapacityKgSqm rdf:type rdf:Property ;
    rdfs:label 'Load Capacity Kg Sqm' ;
    rdfs:comment 'Maximum live load the floor structure can support, measured in kilograms per square meter.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loadCapacityLbsSqft rdf:type rdf:Property ;
    rdfs:label 'Load Capacity Lbs Sqft' ;
    rdfs:comment 'Maximum live load the floor structure can support, measured in pounds per square foot.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:naturalLightAvailability rdf:type rdf:Property ;
    rdfs:label 'Natural Light Availability' ;
    rdfs:comment 'Indicates whether the floor has access to natural daylight through windows or skylights.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netLeasableAreaSqft rdf:type rdf:Property ;
    rdfs:label 'Net Leasable Area Sqft' ;
    rdfs:comment 'The area available for lease to tenants, excluding common areas, mechanical rooms, and structural elements. Measured in square feet.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netLeasableAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Net Leasable Area Sqm' ;
    rdfs:comment 'The area available for lease to tenants, excluding common areas, mechanical rooms, and structural elements. Measured in square meters.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfUnits rdf:type rdf:Property ;
    rdfs:label 'Number Of Units' ;
    rdfs:comment 'Total count of individual units, suites, or spaces located on this floor.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:occupancyCapacity rdf:type rdf:Property ;
    rdfs:label 'Occupancy Capacity' ;
    rdfs:comment 'Maximum number of occupants permitted on the floor based on building code and fire safety regulations.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plateEfficiencyPct rdf:type rdf:Property ;
    rdfs:label 'Plate Efficiency Pct' ;
    rdfs:comment 'Ratio of net leasable area to gross floor area, expressed as a percentage. Indicates how efficiently the floor space is utilized for revenue-generating purposes.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Additional notes, comments, or special considerations related to the floor.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityAccessLevel rdf:type rdf:Property ;
    rdfs:label 'Security Access Level' ;
    rdfs:comment 'Classification of security access controls required to enter the floor.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smartBuildingEnabled rdf:type rdf:Property ;
    rdfs:label 'Smart Building Enabled' ;
    rdfs:comment 'Indicates whether the floor is equipped with smart building technologies such as IoT sensors, automated controls, or integrated building management systems.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sprinklerSystemInstalled rdf:type rdf:Property ;
    rdfs:label 'Sprinkler System Installed' ;
    rdfs:comment 'Indicates whether an automatic fire sprinkler system is installed on this floor.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stairAccess rdf:type rdf:Property ;
    rdfs:label 'Stair Access' ;
    rdfs:comment 'Indicates whether the floor is accessible via stairways.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usageType rdf:type rdf:Property ;
    rdfs:label 'Usage Type' ;
    rdfs:comment 'Primary intended use or occupancy classification for the floor.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wifiCoverage rdf:type rdf:Property ;
    rdfs:label 'Wifi Coverage' ;
    rdfs:comment 'Indicates whether the floor has wireless internet (WiFi) coverage available.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:windowLineExposure rdf:type rdf:Property ;
    rdfs:label 'Window Line Exposure' ;
    rdfs:comment 'Primary direction of exterior window exposure for natural light and views.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:navAppraisalInputId rdf:type rdf:Property ;
    rdfs:label 'Nav Appraisal Input Id' ;
    rdfs:comment 'Primary key for the nav_appraisal_input association' ;
    rdfs:domain ind:NavAppraisalInput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appraisalCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Appraisal Coverage Flag' ;
    rdfs:comment 'Indicates whether this appraisal input qualifies as an independent third-party appraisal for the purpose of calculating the portfolio-level appraisal_coverage_pct on the NAV calculation. Internal desk valuations or stale appraisals beyond the staleness threshold would be flagged FALSE. Explicitly identified in detection phase relationship data and directly drives the nav_calculation.appraisal_coverage_pct aggregate.' ;
    rdfs:domain ind:NavAppraisalInput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appraisalCoveragePct rdf:type rdf:Property ;
    rdfs:label 'Appraisal Coverage Pct' ;
    rdfs:comment 'Percentage of the portfolio GAV supported by independent third-party appraisals in this calculation cycle (e.g., 75.00 means 75% of GAV is appraiser-supported). Relevant for FASB ASC 820 Level 3 disclosure and investor transparency. [Moved from nav_calculation: This aggregate percentage on nav_calculation is DERIVED from the individual appraisal_coverage_flag values on each nav_appraisal_input record. It is a computed rollup of the association data, not an independently maintained attribute of the NAV calculation itself. It should be computed from the association table rather than stored redundantly on nav_calculation. If retained on nav_calculation for reporting performance, it should be treated as a derived/materialized field, not a source-of-truth attribute.]' ;
    rdfs:domain ind:NavAppraisalInput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contributionValue rdf:type rdf:Property ;
    rdfs:label 'Contribution Value' ;
    rdfs:comment 'The absolute dollar amount this appraisal\'s concluded market value contributes to the total Gross Asset Value (GAV) in the NAV calculation. May differ from the appraisal\'s full concluded value if a partial interest or ownership percentage is applied. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:NavAppraisalInput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Valuation Effective Date' ;
    rdfs:comment 'The as-of date of the appraisal value used in this NAV calculation. May differ from the appraisal report date (e.g., a Sept 30 appraisal may be carried forward and used in a Dec 31 NAV calculation under a recertification). Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:NavAppraisalInput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteCoverageId rdf:type rdf:Property ;
    rdfs:label 'Site Coverage Id' ;
    rdfs:comment 'Primary key for the site_coverage association' ;
    rdfs:domain ind:SiteCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coveragePercentage rdf:type rdf:Property ;
    rdfs:label 'Coverage Percentage' ;
    rdfs:comment 'The percentage of the building\'s total ground-floor footprint that falls on this specific parcel. All coverage_percentage values for a given building_id should sum to 100. Critical for FAR compliance calculations and tax apportionment across multiple parcels.' ;
    rdfs:domain ind:SiteCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageSqft rdf:type rdf:Property ;
    rdfs:label 'Coverage Sqft' ;
    rdfs:comment 'The actual square footage of the building\'s ground-floor footprint that falls on this parcel. Derived from GIS polygon intersection but stored as an operational record for tax apportionment, title encumbrance documentation, and zoning compliance reporting.' ;
    rdfs:domain ind:SiteCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageStatus rdf:type rdf:Property ;
    rdfs:label 'Coverage Status' ;
    rdfs:comment 'Lifecycle status of this building-parcel coverage record. Drives whether the record is used in active tax apportionment and title reporting.' ;
    rdfs:domain ind:SiteCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryParcel rdf:type rdf:Property ;
    rdfs:label 'Is Primary Parcel' ;
    rdfs:comment 'Indicates whether this parcel is the primary tax-situs parcel for the building. Exactly one parcel per building should carry this flag as true. Used by tax and title teams to identify the principal parcel of record.' ;
    rdfs:domain ind:SiteCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractAssetCoverageId rdf:type rdf:Property ;
    rdfs:label 'Contract Asset Coverage Id' ;
    rdfs:comment 'Primary key for the contract_asset_coverage association' ;
    rdfs:domain ind:ContractAssetCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coverageEndDate rdf:type rdf:Property ;
    rdfs:label 'Coverage End Date' ;
    rdfs:comment 'The date on which coverage for this specific building asset ends under this contract. May differ from the contract expiration date when assets are removed from scope before contract termination.' ;
    rdfs:domain ind:ContractAssetCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageScope rdf:type rdf:Property ;
    rdfs:label 'Coverage Scope' ;
    rdfs:comment 'Describes the specific services, maintenance tasks, or obligations that apply to this particular asset under this contract. May differ per asset even within the same contract (e.g., full-coverage for primary units, parts-only for secondary units).' ;
    rdfs:domain ind:ContractAssetCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageStartDate rdf:type rdf:Property ;
    rdfs:label 'Coverage Start Date' ;
    rdfs:comment 'The date on which coverage for this specific building asset becomes effective under this contract. May differ from the contract commencement date when assets are added to scope mid-term.' ;
    rdfs:domain ind:ContractAssetCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coveredEquipmentDescription rdf:type rdf:Property ;
    rdfs:label 'Covered Equipment Description' ;
    rdfs:comment 'Description of specific building equipment, systems, or assets covered under this contract (e.g., \'All rooftop HVAC units — Building A and B\', \'Passenger elevators 1-4\'). Supports asset lifecycle tracking and BIM integration. [Moved from service_contract: This free-text description of covered equipment on service_contract is a denormalized summary of what should be formally represented as individual contract_asset_coverage records. Once the association table exists, the specific equipment scope is captured per-asset in coverage_scope, making this aggregate description on the contract redundant. It may be retained on service_contract as a human-readable summary but the authoritative scope is in the association.]' ;
    rdfs:domain ind:ContractAssetCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryContract rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contract' ;
    rdfs:comment 'Indicates whether this service contract is the primary governing maintenance agreement for this building asset when multiple contracts provide overlapping coverage. Used to resolve which contract governs SLA response and compliance reporting for the asset.' ;
    rdfs:domain ind:ContractAssetCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .
