    rdfs:comment 'Reference to the parent training program or curriculum that this session belongs to.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingProgram .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'Actual date and time when the training session concluded, may differ from scheduled time.' ;
