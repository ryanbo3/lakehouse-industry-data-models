    rdfs:comment 'Notes on regulatory requirements, permits, or compliance documentation that must be completed as part of this job plan (e.g., EPA reporting, NPDES permit conditions).' ;
    rdfs:domain ind:JobPlan ;
    rdf:type owl:DatatypeProperty ;
