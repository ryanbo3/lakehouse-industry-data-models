ind:dibromochloromethaneConcentrationUgL rdf:type rdf:Property ;
    rdfs:label 'Dibromochloromethane Concentration Ug L' ;
    rdfs:comment 'Measured concentration of dibromochloromethane (CHBr2Cl), a trihalomethane species, in micrograms per liter.' ;
    rdfs:domain ind:DbpMonitoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dichloroaceticAcidConcentrationUgL rdf:type rdf:Property ;
    rdfs:label 'Dichloroacetic Acid Concentration Ug L' ;
    rdfs:comment 'Measured concentration of dichloroacetic acid (DCAA), a haloacetic acid species, in micrograms per liter.' ;
    rdfs:domain ind:DbpMonitoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freeChlorineResidualMgL rdf:type rdf:Property ;
    rdfs:label 'Free Chlorine Residual Mg L' ;
    rdfs:comment 'The free chlorine residual measured at the time of sample collection, in milligrams per liter, which influences DBP formation.' ;
    rdfs:domain ind:DbpMonitoringEvent ;
