    rdfs:comment 'Physical condition assessment of the grease interceptor or trap.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interceptorSizeGallons rdf:type rdf:Property ;
    rdfs:label 'Interceptor Size Gallons' ;
    rdfs:comment 'Capacity of the grease interceptor or trap in gallons.' ;
    rdfs:domain ind:FogMonitoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPumpOutDate rdf:type rdf:Property ;
    rdfs:label 'Last Pump Out Date' ;
    rdfs:comment 'Date when the grease interceptor was last pumped out or cleaned.' ;
    rdfs:domain ind:FogMonitoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maintenanceIssuesNoted rdf:type rdf:Property ;
    rdfs:label 'Maintenance Issues Noted' ;
    rdfs:comment 'Description of any maintenance issues or deficiencies observed during the inspection.' ;
    rdfs:domain ind:FogMonitoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentToEstablishment rdf:type rdf:Property ;
    rdfs:label 'Notification Sent To Establishment' ;
    rdfs:comment 'Indicates whether an inspection report or notification was sent to the establishment.' ;
    rdfs:domain ind:FogMonitoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ordinanceThresholdExceeded rdf:type rdf:Property ;
    rdfs:label 'Ordinance Threshold Exceeded' ;
    rdfs:comment 'Indicates whether the FOG accumulation or concentration exceeded the local ordinance threshold.' ;
    rdfs:domain ind:FogMonitoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:photoDocumentationAvailable rdf:type rdf:Property ;
    rdfs:label 'Photo Documentation Available' ;
    rdfs:comment 'Indicates whether photographic documentation of the inspection is available.' ;
    rdfs:domain ind:FogMonitoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pumpOutFrequencyCompliant rdf:type rdf:Property ;
    rdfs:label 'Pump Out Frequency Compliant' ;
    rdfs:comment 'Indicates whether the establishment is compliant with the required pump-out frequency.' ;
    rdfs:domain ind:FogMonitoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pumpOutServiceProvider rdf:type rdf:Property ;
    rdfs:label 'Pump Out Service Provider' ;
    rdfs:comment 'Name of the licensed service provider who performed the last pump-out.' ;
    rdfs:domain ind:FogMonitoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Reinspection Required' ;
    rdfs:comment 'Indicates whether a follow-up reinspection is required to verify corrective actions.' ;
    rdfs:domain ind:FogMonitoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reinspectionScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Reinspection Scheduled Date' ;
    rdfs:comment 'Scheduled date for the follow-up reinspection.' ;
    rdfs:domain ind:FogMonitoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiredPumpOutFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Required Pump Out Frequency Days' ;
    rdfs:comment 'Required frequency for pump-out service as mandated by local FOG ordinance, in days.' ;
    rdfs:domain ind:FogMonitoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ssoRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Sso Risk Level' ;
    rdfs:comment 'Assessed risk level of potential sanitary sewer overflow based on FOG accumulation and discharge quality.' ;
    rdfs:domain ind:FogMonitoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationCode rdf:type rdf:Property ;
    rdfs:label 'Violation Code' ;
    rdfs:comment 'Code identifying the specific FOG ordinance violation observed during inspection.' ;
    rdfs:domain ind:FogMonitoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationDescription rdf:type rdf:Property ;
    rdfs:label 'Violation Description' ;
    rdfs:comment 'Detailed description of the FOG ordinance violation identified during the inspection.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iupMonitoringResultId rdf:type rdf:Property ;
    rdfs:label 'Iup Monitoring Result Id' ;
    rdfs:comment 'Unique identifier for the industrial user pretreatment monitoring result record.' ;
    rdfs:domain ind:IupMonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryIupSamplerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Iup Sampler Employee Id' ;
    rdfs:comment 'Identifier for the utility employee who collected the sample, if utility-collected.' ;
    rdfs:domain ind:IupMonitoringResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:categoricalStandardValue rdf:type rdf:Property ;
    rdfs:label 'Categorical Standard Value' ;
    rdfs:comment 'The federal categorical pretreatment standard applicable to this industrial user category and parameter, if applicable.' ;
    rdfs:domain ind:IupMonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyFlowMgd rdf:type rdf:Property ;
    rdfs:label 'Daily Flow Mgd' ;
    rdfs:comment 'The total daily flow in million gallons per day from the industrial user on the sampling date.' ;
    rdfs:domain ind:IupMonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dmrReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Dmr Reporting Required' ;
    rdfs:comment 'Indicates whether this monitoring result must be included in the utility\'s Discharge Monitoring Report to the regulatory agency.' ;
    rdfs:domain ind:IupMonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdingTimeCompliant rdf:type rdf:Property ;
    rdfs:label 'Holding Time Compliant' ;
    rdfs:comment 'Indicates whether the sample was analyzed within the required holding time for the parameter.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localLimitUnit rdf:type rdf:Property ;
    rdfs:label 'Local Limit Unit' ;
    rdfs:comment 'The unit of measure for the local pretreatment limit.' ;
    rdfs:domain ind:IupMonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localLimitValue rdf:type rdf:Property ;
    rdfs:label 'Local Limit Value' ;
    rdfs:comment 'The local pretreatment limit established by the utility for this parameter under the Industrial User Permit.' ;
    rdfs:domain ind:IupMonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringType rdf:type rdf:Property ;
    rdfs:label 'Monitoring Type' ;
    rdfs:comment 'Indicates whether the sample was collected through industrial user self-monitoring, utility inspection, or third-party sampling.' ;
    rdfs:domain ind:IupMonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityControlStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Control Status' ;
    rdfs:comment 'The quality control status of the analytical result, indicating whether QC checks passed.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplerName rdf:type rdf:Property ;
    rdfs:label 'Sampler Name' ;
    rdfs:comment 'The name of the individual who collected the sample.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingDate rdf:type rdf:Property ;
    rdfs:label 'Sampling Date' ;
    rdfs:comment 'The date on which the industrial user sample was collected for pretreatment monitoring.' ;
    rdfs:domain ind:IupMonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:samplingPointDescription rdf:type rdf:Property ;
    rdfs:label 'Sampling Point Description' ;
    rdfs:comment 'Detailed description of the specific sampling location at the industrial user facility.' ;
    rdfs:domain ind:IupMonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingPointType rdf:type rdf:Property ;
    rdfs:label 'Sampling Point Type' ;
    rdfs:comment 'The type of sampling location where the industrial user sample was collected (influent to facility, effluent from pretreatment unit, process stream, final discharge point, etc.).' ;
    rdfs:domain ind:IupMonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingTime rdf:type rdf:Property ;
    rdfs:label 'Sampling Time' ;
    rdfs:comment 'The precise timestamp when the industrial user sample was collected, including time of day.' ;
    rdfs:domain ind:IupMonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:leadCopperResultId rdf:type rdf:Property ;
    rdfs:label 'Lead Copper Result Id' ;
    rdfs:comment 'Unique identifier for the lead and copper sampling result record.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleCollectorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Sample Collector Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: EPA Lead and Copper Rule requires certified personnel for sampling. Tracking collector employee enables license verification, training compliance audits, and chain-of-custody validation for regulatory' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:samplingRoundId rdf:type rdf:Property ;
    rdfs:label 'Sampling Round Id' ;
    rdfs:comment 'Reference to the 6-month monitoring period during which this sample was collected per LCRR requirements.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SamplingRound .

ind:samplingSiteId rdf:type rdf:Property ;
    rdfs:label 'Sampling Site Id' ;
    rdfs:comment 'Reference to the customer tap location selected for Lead and Copper Rule monitoring.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SamplingSite .

ind:analysisMethod rdf:type rdf:Property ;
    rdfs:label 'Analysis Method' ;
    rdfs:comment 'EPA-approved analytical method used for lead and copper determination (e.g., EPA 200.8 ICP-MS, EPA 200.9 ICP-AES).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copperActionLevelExceeded rdf:type rdf:Property ;
    rdfs:label 'Copper Action Level Exceeded' ;
    rdfs:comment 'Indicates whether the copper result exceeds the EPA action level of 1300 ppb (1.3 mg/L), triggering potential corrosion control treatment requirements.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:copperResultPpb rdf:type rdf:Property ;
    rdfs:label 'Copper Result Ppb' ;
    rdfs:comment 'Measured concentration of copper in the water sample expressed in parts per billion (ppb or µg/L). Used for 90th percentile calculation and action level comparison.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:corrosionControlTreatmentStatus rdf:type rdf:Property ;
    rdfs:label 'Corrosion Control Treatment Status' ;
    rdfs:comment 'Status of corrosion control treatment optimization at the time of sampling, indicating whether the water system has optimized corrosion control per LCRR requirements.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionLimitCopperPpb rdf:type rdf:Property ;
    rdfs:label 'Detection Limit Copper Ppb' ;
    rdfs:comment 'Minimum concentration of copper that the analytical method can reliably detect and quantify for this sample.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:detectionLimitLeadPpb rdf:type rdf:Property ;
    rdfs:label 'Detection Limit Lead Ppb' ;
    rdfs:comment 'Minimum concentration of lead that the analytical method can reliably detect and quantify for this sample.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:includedIn90thPercentile rdf:type rdf:Property ;
    rdfs:label 'Included In 90th Percentile' ;
    rdfs:comment 'Indicates whether this result was included in the 90th percentile calculation for LCRR compliance determination. Invalid or QC-failed samples are excluded.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadActionLevelExceeded rdf:type rdf:Property ;
    rdfs:label 'Lead Action Level Exceeded' ;
    rdfs:comment 'Indicates whether the lead result exceeds the EPA action level of 15 ppb, triggering potential corrosion control treatment requirements.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadResultPpb rdf:type rdf:Property ;
    rdfs:label 'Lead Result Ppb' ;
    rdfs:comment 'Measured concentration of lead in the water sample expressed in parts per billion (ppb or µg/L). Used for 90th percentile calculation and action level comparison.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryReportingStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Status' ;
    rdfs:comment 'Status of this result in the regulatory reporting workflow to state primacy agency and EPA.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplePh rdf:type rdf:Property ;
    rdfs:label 'Sample Ph' ;
    rdfs:comment 'pH measurement of the water sample at collection, relevant for corrosion control assessment.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:samplePreservationMethod rdf:type rdf:Property ;
    rdfs:label 'Sample Preservation Method' ;
    rdfs:comment 'Method used to preserve the sample for metals analysis, typically acidification with nitric acid to pH < 2.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteTier rdf:type rdf:Property ;
    rdfs:label 'Site Tier' ;
    rdfs:comment 'LCRR-mandated tier classification of the sampling site based on service line material and building construction date (Tier 1: lead service lines, Tier 2: lead status unknown, Tier 3: non-lead).' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stagnationTimeHours rdf:type rdf:Property ;
    rdfs:label 'Stagnation Time Hours' ;
    rdfs:comment 'Duration in hours that water remained stagnant in the service line prior to sample collection. LCRR requires minimum 6-hour stagnation for first-draw samples.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringWaiverId rdf:type rdf:Property ;
    rdfs:label 'Monitoring Waiver Id' ;
    rdfs:comment 'Unique identifier for the monitoring waiver record. Primary key.' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselineMonitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Baseline Monitoring Frequency' ;
    rdfs:comment 'Original required monitoring frequency before the waiver was granted (e.g., quarterly, monthly, annual). Expressed as a frequency code or description.' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccrReportingImpact rdf:type rdf:Property ;
    rdfs:label 'Ccr Reporting Impact' ;
    rdfs:comment 'Description of how the monitoring waiver affects Consumer Confidence Report (CCR) reporting requirements and public notification language.' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contaminantGroup rdf:type rdf:Property ;
    rdfs:label 'Contaminant Group' ;
    rdfs:comment 'Descriptive name of the contaminant group covered by this waiver (e.g., Disinfection Byproducts (DBP), Volatile Organic Compounds (VOC), Synthetic Organic Chemicals (SOC), Inorganic Chemicals (IOC), Radionuclides).' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:historicalMonitoringPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Historical Monitoring Period End' ;
    rdfs:comment 'End date of the historical monitoring period used to demonstrate non-detect results for waiver eligibility.' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:historicalMonitoringPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Historical Monitoring Period Start' ;
    rdfs:comment 'Start date of the historical monitoring period used to demonstrate non-detect results for waiver eligibility.' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:historicalNonDetectCount rdf:type rdf:Property ;
    rdfs:label 'Historical Non Detect Count' ;
    rdfs:comment 'Number of consecutive historical samples with non-detect results for the contaminant, supporting the waiver justification.' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Next Renewal Date' ;
    rdfs:comment 'Date by which the waiver renewal application must be submitted or the waiver reassessment must be completed.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primacyAgencyApprovalReference rdf:type rdf:Property ;
    rdfs:label 'Primacy Agency Approval Reference' ;
    rdfs:comment 'Official reference number, permit number, or document identifier issued by the primacy agency for this waiver approval.' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reducedMonitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Reduced Monitoring Frequency' ;
    rdfs:comment 'Reduced monitoring frequency allowed under the waiver (e.g., annual, triennial, once per compliance period). Expressed as a frequency code or description.' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalFrequencyYears rdf:type rdf:Property ;
    rdfs:label 'Renewal Frequency Years' ;
    rdfs:comment 'Frequency in years at which the waiver must be renewed or reassessed if renewal is required.' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Required Flag' ;
    rdfs:comment 'Indicates whether the waiver requires periodic renewal or reapplication (True) or is granted indefinitely subject to conditions (False).' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revocationTriggerConditions rdf:type rdf:Property ;
    rdfs:label 'Revocation Trigger Conditions' ;
    rdfs:comment 'Specific conditions or events that would trigger automatic revocation of the waiver (e.g., detection above action level, source water contamination, operational changes).' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingScheduleAdjustmentNotes rdf:type rdf:Property ;
    rdfs:label 'Sampling Schedule Adjustment Notes' ;
    rdfs:comment 'Operational notes describing how the sampling schedule must be adjusted to reflect the waiver-reduced monitoring frequency.' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vulnerabilityAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Vulnerability Assessment Date' ;
    rdfs:comment 'Date on which the vulnerability assessment or source water assessment supporting the waiver was completed.' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vulnerabilityAssessmentResult rdf:type rdf:Property ;
    rdfs:label 'Vulnerability Assessment Result' ;
    rdfs:comment 'Outcome of the vulnerability assessment indicating the level of vulnerability to the contaminant at the sampling point (e.g., not vulnerable, low vulnerability).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverConditions rdf:type rdf:Property ;
    rdfs:label 'Waiver Conditions' ;
    rdfs:comment 'Specific conditions, requirements, or restrictions imposed by the primacy agency for maintaining the waiver (e.g., annual source water monitoring, notification requirements, operational changes).' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverDurationYears rdf:type rdf:Property ;
    rdfs:label 'Waiver Duration Years' ;
    rdfs:comment 'Duration of the monitoring waiver in years, representing the period between effective date and expiration date.' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverJustification rdf:type rdf:Property ;
    rdfs:label 'Waiver Justification' ;
    rdfs:comment 'Detailed business and regulatory justification for granting the monitoring waiver, including vulnerability assessment results, historical non-detect data, or source water protection measures.' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverNumber rdf:type rdf:Property ;
    rdfs:label 'Waiver Number' ;
    rdfs:comment 'Externally-known unique identifier or reference number assigned by the primacy agency or utility for this monitoring waiver.' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverStatus rdf:type rdf:Property ;
    rdfs:label 'Waiver Status' ;
    rdfs:comment 'Current lifecycle status of the monitoring waiver indicating whether it is active, expired, revoked, pending approval, suspended, or renewed.' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverType rdf:type rdf:Property ;
    rdfs:label 'Waiver Type' ;
    rdfs:comment 'Classification of the monitoring waiver based on the regulatory basis for reduced monitoring (e.g., vulnerability assessment waiver, source water waiver, contaminant-specific waiver).' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onlineInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Online Instrument Id' ;
    rdfs:comment 'Unique identifier for the online water quality monitoring instrument. Primary key for the online instrument registry.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OnlineInstrument .

ind:calibrationStandardUsed rdf:type rdf:Property ;
    rdfs:label 'Calibration Standard Used' ;
    rdfs:comment 'Description of the calibration standard or reference material used during the most recent calibration (e.g., \'NIST-traceable 10 NTU formazin standard\', \'pH 7.0 buffer solution\').' ;
    rdfs:domain ind:OnlineInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationTechnician rdf:type rdf:Property ;
    rdfs:label 'Calibration Technician' ;
    rdfs:comment 'Name or identifier of the technician who performed the most recent calibration. Used for quality assurance and accountability.' ;
    rdfs:domain ind:OnlineInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataLoggingIntervalSeconds rdf:type rdf:Property ;
    rdfs:label 'Data Logging Interval Seconds' ;
    rdfs:comment 'Frequency at which the instrument records or transmits data to the SCADA/historian system, expressed in seconds (e.g., 60 for one-minute intervals, 300 for five-minute intervals).' ;
    rdfs:domain ind:OnlineInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:installationLocation rdf:type rdf:Property ;
    rdfs:label 'Installation Location' ;
    rdfs:comment 'Detailed description of where the instrument is physically installed (e.g., \'WTP Filter Effluent Gallery\', \'Distribution Pump Station 5 Discharge\', \'WWTP Final Clarifier Effluent Channel\').' ;
    rdfs:domain ind:OnlineInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceNotes rdf:type rdf:Property ;
    rdfs:label 'Maintenance Notes' ;
    rdfs:comment 'Free-text field for recording maintenance history, operational issues, calibration adjustments, or other relevant notes about the instrument\'s performance and service history.' ;
    rdfs:domain ind:OnlineInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piHistorianTag rdf:type rdf:Property ;
    rdfs:label 'Pi Historian Tag' ;
    rdfs:comment 'Tag name in the OSIsoft PI Historian or equivalent time-series database where continuous instrument readings are stored for trending and analysis.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerSupplyType rdf:type rdf:Property ;
    rdfs:label 'Power Supply Type' ;
    rdfs:comment 'Type of electrical power supply used by the instrument (e.g., AC 120V, DC 24V, battery-powered, solar-powered, loop-powered from 4-20mA signal).' ;
    rdfs:domain ind:OnlineInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentStage rdf:type rdf:Property ;
    rdfs:label 'Treatment Stage' ;
    rdfs:comment 'Stage in the water or wastewater treatment process where the instrument is monitoring. Critical for understanding data context and compliance requirements. [ENUM-REF-CANDIDATE: raw_water|pre_treatment|coagulation|flocculation|sedimentation|filtration|disinfection|post_treatment|distribution|wastewater_influent|primary_treatment|secondary_treatment|tertiary_treatment|effluent_discharge|sludge_processing — promote to reference product]' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualChlorineReadingId rdf:type rdf:Property ;
    rdfs:label 'Residual Chlorine Reading Id' ;
    rdfs:comment 'Unique identifier for the residual chlorine reading record.' ;
    rdfs:domain ind:ResidualChlorineReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processControlSetpointId rdf:type rdf:Property ;
    rdfs:label 'Process Control Setpoint Id' ;
    rdfs:comment 'Foreign key linking to treatment.process_control_setpoint. Business justification: Distribution system chlorine residual measurements are validated against treatment plant process control setpoints. Links field measurement to operational target for disinfection adequacy verification' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessControlSetpoint .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Indicates whether the measured residual meets regulatory minimum requirements. False indicates non-compliance requiring corrective action and potential reporting to primacy agency.' ;
    rdfs:domain ind:ResidualChlorineReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumAllowedResidualMgPerL rdf:type rdf:Property ;
    rdfs:label 'Maximum Allowed Residual Mg Per L' ;
    rdfs:comment 'Maximum Residual Disinfectant Level (MRDL) allowed by EPA. For chlorine and chloramine, MRDL is 4.0 mg/L as annual average; chlorine dioxide MRDL is 0.8 mg/L.' ;
    rdfs:domain ind:ResidualChlorineReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementMethod rdf:type rdf:Property ;
    rdfs:label 'Measurement Method' ;
    rdfs:comment 'Analytical method used to determine chlorine residual. DPD colorimetric is standard for field testing; amperometric is used for precise lab analysis; online analyzers provide continuous SCADA monitoring.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Timestamp' ;
    rdfs:comment 'Date and time when the chlorine residual measurement was taken in the field or recorded by SCADA system.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:minimumRequiredResidualMgPerL rdf:type rdf:Property ;
    rdfs:label 'Minimum Required Residual Mg Per L' ;
    rdfs:comment 'Regulatory or operational minimum disinfectant residual threshold applicable at this sampling point. Typically 0.2 mg/L free chlorine at distribution entry point per EPA requirements.' ;
    rdfs:domain ind:ResidualChlorineReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityControlFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Control Flag' ;
    rdfs:comment 'Data quality indicator based on QA/QC review. Suspect or invalid readings may result from instrument malfunction, calibration drift, or sampling error.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryMonitoringFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Monitoring Flag' ;
    rdfs:comment 'Indicates whether this reading is part of required regulatory compliance monitoring for state primacy agency or EPA reporting (e.g., MOR, CCR).' ;
    rdfs:domain ind:ResidualChlorineReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residualValueMgPerL rdf:type rdf:Property ;
    rdfs:label 'Residual Value Mg Per L' ;
    rdfs:comment 'Measured concentration of disinfectant residual in milligrams per liter. EPA requires minimum 0.2 mg/L free chlorine or detectable residual entering distribution system.' ;
    rdfs:domain ind:ResidualChlorineReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleCollectionMethod rdf:type rdf:Property ;
    rdfs:label 'Sample Collection Method' ;
    rdfs:comment 'Method by which the water sample was obtained. Grab samples are instantaneous; composite samples are time-weighted; continuous monitors provide real-time streaming data.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessType rdf:type rdf:Property ;
    rdfs:label 'Access Type' ;
    rdfs:comment 'Classification of physical access requirements for sampling personnel. Public = open access; restricted = requires authorization; private property = requires owner permission; confined space = requires confined space entry procedures; remote = difficult to reach, may require special equipment.' ;
    rdfs:domain ind:QualitySamplingPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccrReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Ccr Reporting Flag' ;
    rdfs:comment 'Indicates whether water quality results from this sampling point must be included in the annual Consumer Confidence Report (CCR) to customers. True = included in CCR; False = not included.' ;
    rdfs:domain ind:QualitySamplingPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dmrReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Dmr Reporting Flag' ;
    rdfs:comment 'Indicates whether effluent quality results from this sampling point must be included in monthly Discharge Monitoring Reports (DMR) submitted to EPA or state agencies. True = included in DMR; False = not included.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryContaminantGroup rdf:type rdf:Property ;
    rdfs:label 'Primary Contaminant Group' ;
    rdfs:comment 'The primary category of contaminants monitored at this sampling point (e.g., \'Microbiological\', \'Disinfection Byproducts\', \'Inorganic Chemicals\', \'Organic Chemicals\', \'Radionuclides\', \'Nutrients\', \'Metals\'). Used to organize sampling schedules and laboratory workflows.' ;
    rdfs:domain ind:QualitySamplingPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryZone rdf:type rdf:Property ;
    rdfs:label 'Regulatory Zone' ;
    rdfs:comment 'The regulatory monitoring zone or district to which this sampling point is assigned for compliance reporting purposes. Used to aggregate results for Consumer Confidence Report (CCR) and Discharge Monitoring Report (DMR).' ;
    rdfs:domain ind:QualitySamplingPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residenceTimeHours rdf:type rdf:Property ;
    rdfs:label 'Residence Time Hours' ;
    rdfs:comment 'The estimated water residence time in hours from the treatment plant to this sampling point in the distribution system. Critical for disinfection Contact Time (CT) calculations and Disinfection Byproduct (DBP) formation analysis.' ;
    rdfs:domain ind:QualitySamplingPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyNotes rdf:type rdf:Property ;
    rdfs:label 'Safety Notes' ;
    rdfs:comment 'Safety considerations and hazards specific to this sampling location (e.g., confined space, traffic hazards, chemical exposure, biological hazards, electrical equipment).' ;
    rdfs:domain ind:QualitySamplingPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingInstructions rdf:type rdf:Property ;
    rdfs:label 'Sampling Instructions' ;
    rdfs:comment 'Detailed field instructions for sample collection at this location, including access directions, safety precautions, flushing procedures, bottle types, preservation requirements, and any site-specific protocols.' ;
    rdfs:domain ind:QualitySamplingPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingPointCode rdf:type rdf:Property ;
    rdfs:label 'Sampling Point Code' ;
    rdfs:comment 'Externally-known unique business identifier for the sampling location, used in regulatory reporting and laboratory requisitions. Typically follows EPA or state-specific coding conventions.' ;
    rdfs:domain ind:QualitySamplingPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingPointName rdf:type rdf:Property ;
    rdfs:label 'Sampling Point Name' ;
    rdfs:comment 'Human-readable name or label for the sampling location (e.g., \'Main Street Entry Point\', \'WTP Clearwell Outlet\', \'WWTP Final Effluent\').' ;
    rdfs:domain ind:QualitySamplingPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingPointStatus rdf:type rdf:Property ;
    rdfs:label 'Sampling Point Status' ;
    rdfs:comment 'Current operational status of the sampling point. Active = in regular use; inactive = not currently sampled but may be reactivated; temporarily suspended = short-term pause (e.g., construction); decommissioned = permanently retired.' ;
    rdfs:domain ind:QualitySamplingPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringLocationId rdf:type rdf:Property ;
    rdfs:label 'Monitoring Location Id' ;
    rdfs:comment 'Reference to the physical location where samples are collected (e.g., treatment plant, distribution point, discharge point).' ;
    rdfs:domain ind:SamplingSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:responsibleCrewId rdf:type rdf:Property ;
    rdfs:label 'Responsible Crew Id' ;
    rdfs:comment 'Reference to the field crew or team responsible for collecting samples under this schedule.' ;
    rdfs:domain ind:SamplingSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Crew .

ind:annualBudgetAllocation rdf:type rdf:Property ;
    rdfs:label 'Annual Budget Allocation' ;
    rdfs:comment 'Total budget allocated in USD for this sampling schedule for the fiscal year.' ;
    rdfs:domain ind:SamplingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Deadline Date' ;
    rdfs:comment 'Regulatory deadline by which all samples for this schedule must be collected and analyzed to avoid violation.' ;
    rdfs:domain ind:SamplingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costPerSample rdf:type rdf:Property ;
    rdfs:label 'Cost Per Sample' ;
    rdfs:comment 'Estimated or contracted cost in USD for each sample collection and analysis event under this schedule.' ;
    rdfs:domain ind:SamplingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Notification Lead Time Days' ;
    rdfs:comment 'Number of days in advance that field crews and labs should be notified before scheduled sampling events.' ;
    rdfs:domain ind:SamplingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryRule rdf:type rdf:Property ;
    rdfs:label 'Regulatory Rule' ;
    rdfs:comment 'The specific regulatory rule or permit condition driving this schedule (e.g., \'LCRR\', \'DBP Stage 2 Rule\', \'NPDES Permit CA0012345\', \'PFAS Monitoring Advisory\', \'SDWA Coliform Rule\').' ;
    rdfs:domain ind:SamplingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplesCollectedYtd rdf:type rdf:Property ;
    rdfs:label 'Samples Collected Ytd' ;
    rdfs:comment 'Count of samples collected under this schedule in the current calendar or fiscal year.' ;
    rdfs:domain ind:SamplingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:samplesPerPeriod rdf:type rdf:Property ;
    rdfs:label 'Samples Per Period' ;
    rdfs:comment 'Number of samples required per monitoring period (e.g., 4 samples per month for DBP monitoring in a large system).' ;
    rdfs:domain ind:SamplingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:samplesRequiredYtd rdf:type rdf:Property ;
    rdfs:label 'Samples Required Ytd' ;
    rdfs:comment 'Count of samples required to be collected under this schedule by this point in the calendar or fiscal year.' ;
    rdfs:domain ind:SamplingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:samplingMethod rdf:type rdf:Property ;
    rdfs:label 'Sampling Method' ;
    rdfs:comment 'Standard method or protocol for sample collection (e.g., \'EPA Method 1694\', \'Standard Methods 9060A\', \'grab sample\', \'composite 24-hour\').' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalAdjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Adjustment Flag' ;
    rdfs:comment 'Indicates whether this schedule has seasonal variations in frequency or parameters (e.g., increased DBP monitoring in summer months).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceWaterQualityId rdf:type rdf:Property ;
    rdfs:label 'Source Water Quality Id' ;
    rdfs:comment 'Unique identifier for the source water quality measurement record.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bulkWaterAgreementId rdf:type rdf:Property ;
    rdfs:label 'Bulk Water Agreement Id' ;
    rdfs:comment 'Foreign key linking to service.bulk_water_agreement. Business justification: Bulk water agreements specify contractual water quality standards at delivery points. Source water monitoring at these points verifies compliance with contracted quality parameters, triggers price adj' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BulkWaterAgreement .

ind:sampledByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Sampled By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Source water monitoring under SDWA requires operator certification. Linking sampler employee enables compliance verification for intake monitoring programs, training record validation, and regulatory ' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sourceLocationSourceWaterIntakeId rdf:type rdf:Property ;
    rdfs:label 'Source Location Source Water Intake Id' ;
    rdfs:comment 'Reference to the specific water source intake point or well where the sample was collected.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SourceWaterIntake .

ind:sourceWaterIntakeId rdf:type rdf:Property ;
    rdfs:label 'Source Water Intake Id' ;
    rdfs:comment 'Reference to the specific water source intake point or well where the sample was collected.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SourceWaterIntake .

ind:algaeCountCellsPerMl rdf:type rdf:Property ;
    rdfs:label 'Algae Count Cells Per Ml' ;
    rdfs:comment 'Concentration of algae cells per milliliter of source water, important for taste, odor, and treatment challenges.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alkalinityMgPerL rdf:type rdf:Property ;
    rdfs:label 'Alkalinity Mg Per L' ;
    rdfs:comment 'Total alkalinity expressed as milligrams per liter of calcium carbonate equivalent, indicating buffering capacity.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ammoniaMgPerL rdf:type rdf:Property ;
    rdfs:label 'Ammonia Mg Per L' ;
    rdfs:comment 'Ammonia nitrogen concentration in milligrams per liter, affecting disinfection effectiveness and DBP formation.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chlorideMgPerL rdf:type rdf:Property ;
    rdfs:label 'Chloride Mg Per L' ;
    rdfs:comment 'Chloride concentration in milligrams per liter, affecting taste and corrosivity.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:colorPcu rdf:type rdf:Property ;
    rdfs:label 'Color Pcu' ;
    rdfs:comment 'Apparent color of the source water measured in Platinum-Cobalt Units, indicating dissolved organic matter.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conductivityUsPerCm rdf:type rdf:Property ;
    rdfs:label 'Conductivity Us Per Cm' ;
    rdfs:comment 'Electrical conductivity of the source water in microsiemens per centimeter, indicating ionic content.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cyanotoxinConcentrationUgPerL rdf:type rdf:Property ;
    rdfs:label 'Cyanotoxin Concentration Ug Per L' ;
    rdfs:comment 'Concentration of cyanotoxins in micrograms per liter if detected, null if not detected or not analyzed.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cyanotoxinDetected rdf:type rdf:Property ;
    rdfs:label 'Cyanotoxin Detected' ;
    rdfs:comment 'Boolean indicator of whether cyanotoxins (blue-green algae toxins) were detected in the screening analysis.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dissolvedOxygenMgPerL rdf:type rdf:Property ;
    rdfs:label 'Dissolved Oxygen Mg Per L' ;
    rdfs:comment 'Concentration of dissolved oxygen in milligrams per liter, indicating water quality and biological activity.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hardnessMgPerL rdf:type rdf:Property ;
    rdfs:label 'Hardness Mg Per L' ;
    rdfs:comment 'Total hardness expressed as milligrams per liter of calcium carbonate equivalent, indicating calcium and magnesium content.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ironMgPerL rdf:type rdf:Property ;
    rdfs:label 'Iron Mg Per L' ;
    rdfs:comment 'Total iron concentration in milligrams per liter, important for treatment process design and aesthetic quality.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:labAnalyzedBy rdf:type rdf:Property ;
    rdfs:label 'Lab Analyzed By' ;
    rdfs:comment 'Name or identifier of the laboratory analyst who performed the water quality analysis.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manganeseMgPerL rdf:type rdf:Property ;
    rdfs:label 'Manganese Mg Per L' ;
    rdfs:comment 'Total manganese concentration in milligrams per liter, important for treatment and aesthetic quality.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nitrateMgPerL rdf:type rdf:Property ;
    rdfs:label 'Nitrate Mg Per L' ;
    rdfs:comment 'Nitrate nitrogen concentration in milligrams per liter, a regulated contaminant under SDWA.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityControlPassed rdf:type rdf:Property ;
    rdfs:label 'Quality Control Passed' ;
    rdfs:comment 'Boolean indicator of whether the laboratory analysis passed all quality control checks and validation criteria.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryExceedance rdf:type rdf:Property ;
    rdfs:label 'Regulatory Exceedance' ;
    rdfs:comment 'Boolean indicator of whether any measured parameter exceeded regulatory action levels or Maximum Contaminant Levels (MCL).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:season rdf:type rdf:Property ;
    rdfs:label 'Season' ;
    rdfs:comment 'Season during which the source water sample was collected, used for seasonal trend analysis.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'Classification of the water source from which the sample was collected.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sulfateMgPerL rdf:type rdf:Property ;
    rdfs:label 'Sulfate Mg Per L' ;
    rdfs:comment 'Sulfate concentration in milligrams per liter, a secondary contaminant affecting taste and odor.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tdsMgPerL rdf:type rdf:Property ;
    rdfs:label 'Tds Mg Per L' ;
    rdfs:comment 'Total Dissolved Solids concentration in milligrams per liter, indicating mineral content and salinity.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tocMgPerL rdf:type rdf:Property ;
    rdfs:label 'Toc Mg Per L' ;
    rdfs:comment 'Total Organic Carbon concentration in milligrams per liter, a key indicator for disinfection byproduct formation potential.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentAdjustmentRequired rdf:type rdf:Property ;
    rdfs:label 'Treatment Adjustment Required' ;
    rdfs:comment 'Boolean indicator of whether the source water quality measurement triggered a need for Water Treatment Plant (WTP) process adjustment.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tssMgPerL rdf:type rdf:Property ;
    rdfs:label 'Tss Mg Per L' ;
    rdfs:comment 'Total Suspended Solids concentration in milligrams per liter, indicating particulate matter load.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alarmThresholdNtu rdf:type rdf:Property ;
    rdfs:label 'Alarm Threshold Ntu' ;
    rdfs:comment 'The turbidity threshold value in NTU configured in the SCADA system that triggers an operational alarm when exceeded.' ;
    rdfs:domain ind:TurbidityReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alarmTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Alarm Triggered Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether the turbidity reading triggered an automated alarm in the SCADA system due to exceeding a predefined threshold.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calibrationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calibration Timestamp' ;
    rdfs:comment 'Date and time of the most recent calibration performed on the turbidity instrument prior to this reading.' ;
    rdfs:domain ind:TurbidityReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ctComplianceContext rdf:type rdf:Property ;
    rdfs:label 'Ct Compliance Context' ;
    rdfs:comment 'Contextual information linking the turbidity reading to disinfection Contact Time (CT) compliance calculations, indicating whether the reading impacts CT credit eligibility under the Surface Water Treatment Rule.' ;
    rdfs:domain ind:TurbidityReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityCode rdf:type rdf:Property ;
    rdfs:label 'Data Quality Code' ;
    rdfs:comment 'Code indicating the quality and reliability of the turbidity reading, including flags for suspect data, instrument faults, calibration status, or manual overrides.' ;
    rdfs:domain ind:TurbidityReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'The source system from which the turbidity reading was ingested into the lakehouse: OSIsoft PI Historian, LIMS, manual entry, or direct SCADA feed.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filterUnitNumber rdf:type rdf:Property ;
    rdfs:label 'Filter Unit Number' ;
    rdfs:comment 'Identifier of the specific filter unit at the Water Treatment Plant (WTP) from which the turbidity reading was captured. Applicable for Individual Filter Effluent (IFE) measurements.' ;
    rdfs:domain ind:TurbidityReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementLocationType rdf:type rdf:Property ;
    rdfs:label 'Measurement Location Type' ;
    rdfs:comment 'Designation of where in the treatment process the turbidity measurement was taken: Individual Filter Effluent (IFE), Combined Filter Effluent (CFE), distribution system entry point, raw water intake, settled water, or filtered water.' ;
    rdfs:domain ind:TurbidityReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryLimitNtu rdf:type rdf:Property ;
    rdfs:label 'Regulatory Limit Ntu' ;
    rdfs:comment 'The applicable regulatory turbidity limit in NTU for the measurement location and context, as defined by the Surface Water Treatment Rule or state primacy agency requirements.' ;
    rdfs:domain ind:TurbidityReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Reporting Period' ;
    rdfs:comment 'The regulatory reporting period (e.g., monthly, quarterly) to which this turbidity reading applies for compliance reporting purposes.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureC rdf:type rdf:Property ;
    rdfs:label 'Temperature C' ;
    rdfs:comment 'Temperature of the water sample at the time of turbidity measurement, expressed in degrees Celsius. Temperature can affect turbidity readings and is recorded for quality assurance.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:turbidityValueNtu rdf:type rdf:Property ;
    rdfs:label 'Turbidity Value Ntu' ;
    rdfs:comment 'The measured turbidity value expressed in Nephelometric Turbidity Units (NTU), representing the cloudiness or haziness of the water sample.' ;
    rdfs:domain ind:TurbidityReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentSampleWaterSampleId rdf:type rdf:Property ;
    rdfs:label 'Parent Sample Water Sample Id' ;
    rdfs:comment 'For duplicate or split samples, reference to the original parent sample from which this sample was derived. Null for primary samples.' ;
    rdfs:domain ind:WaterSample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WaterSample .

ind:primaryWaterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Water Employee Id' ;
    rdfs:comment 'Reference to the employee or technician who collected the sample in the field or at the process point.' ;
    rdfs:domain ind:WaterSample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:analysisDueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Analysis Due Timestamp' ;
    rdfs:comment 'Calculated deadline by which analysis must be completed to meet hold-time requirements. Derived from collection timestamp plus hold time hours.' ;
    rdfs:domain ind:WaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:limsSubmissionCode rdf:type rdf:Property ;
    rdfs:label 'Lims Submission Code' ;
    rdfs:comment 'Reference identifier assigned by the LIMS when the sample is logged into the laboratory system for analysis. Links field sample to laboratory test results.' ;
    rdfs:domain ind:WaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedAnalysisGroup rdf:type rdf:Property ;
    rdfs:label 'Requested Analysis Group' ;
    rdfs:comment 'The suite or panel of tests requested for this sample (e.g., bacteriological, inorganic chemicals, volatile organic compounds (VOCs), Disinfection Byproducts (DBPs), metals, nutrients). May reference a predefined test package.' ;
    rdfs:domain ind:WaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleLocationDescription rdf:type rdf:Property ;
    rdfs:label 'Sample Location Description' ;
    rdfs:comment 'Free-text description of the sample collection location, including address, facility name, or geographic reference. Supplements the sampling point reference with human-readable context.' ;
    rdfs:domain ind:WaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplePurpose rdf:type rdf:Property ;
    rdfs:label 'Sample Purpose' ;
    rdfs:comment 'Business reason for collecting the sample (e.g., routine compliance monitoring, customer complaint investigation, process control, special study, Consumer Confidence Report (CCR) preparation, National Pollutant Discharge Elimination System (NPDES) permit monitoring).' ;
    rdfs:domain ind:WaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplerEquipmentCode rdf:type rdf:Property ;
    rdfs:label 'Sampler Equipment Code' ;
    rdfs:comment 'Reference to the automatic sampler or field equipment used to collect the sample, if applicable. Supports equipment calibration tracking and quality assurance.' ;
    rdfs:domain ind:WaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affordabilityPlanId rdf:type rdf:Property ;
    rdfs:label 'Affordability Plan Id' ;
    rdfs:comment 'Unique identifier for the affordability plan. Primary key.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AffordabilityPlan .

ind:serviceClassId rdf:type rdf:Property ;
    rdfs:label 'Service Class Id' ;
    rdfs:comment 'Foreign key linking to service.service_class. Business justification: Affordability plans apply to specific customer service classes. Currently customer_class_applicability is a STRING, but this should be a FK to service_class for referential integrity and to enable cla' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceClass .

ind:applicationProcessDescription rdf:type rdf:Property ;
    rdfs:label 'Application Process Description' ;
    rdfs:comment 'Description of the process customers must follow to apply for enrollment in this affordability plan, including required documentation and submission channels.' ;
    rdfs:domain ind:AffordabilityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoEnrollmentFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Enrollment Flag' ;
    rdfs:comment 'Indicates whether eligible customers are automatically enrolled in this affordability plan based on participation in other assistance programs (e.g., SNAP, Medicaid, LIHEAP). True if auto-enrollment is enabled, false if customers must apply.' ;
    rdfs:domain ind:AffordabilityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentEnrollmentCount rdf:type rdf:Property ;
    rdfs:label 'Current Enrollment Count' ;
    rdfs:comment 'Current number of customers actively enrolled in this affordability plan. Updated periodically to reflect enrollment changes.' ;
    rdfs:domain ind:AffordabilityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discountFixedAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Fixed Amount' ;
    rdfs:comment 'Fixed dollar credit amount applied to the customer\'s bill per billing cycle when the discount type is fixed amount. Null if discount type is not fixed amount.' ;
    rdfs:domain ind:AffordabilityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountType rdf:type rdf:Property ;
    rdfs:label 'Discount Type' ;
    rdfs:comment 'The mechanism by which the affordability benefit is applied: percentage (percent off total bill), fixed amount (dollar credit per billing cycle), rate reduction (lower volumetric or base rate), bill cap (maximum bill amount), or usage credit (free gallons or cubic meters).' ;
    rdfs:domain ind:AffordabilityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityIncomeThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Eligibility Income Threshold Amount' ;
    rdfs:comment 'Maximum annual household income amount (in local currency) that qualifies a customer for enrollment in this affordability plan. Typically expressed as a percentage of Federal Poverty Level (FPL) or Area Median Income (AMI).' ;
    rdfs:domain ind:AffordabilityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibilityIncomeThresholdBasis rdf:type rdf:Property ;
    rdfs:label 'Eligibility Income Threshold Basis' ;
    rdfs:comment 'The reference standard used to determine income eligibility: federal poverty level (FPL percentage), area median income (AMI percentage), state median income (SMI percentage), or fixed amount (absolute dollar threshold).' ;
    rdfs:domain ind:AffordabilityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityIncomeThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Eligibility Income Threshold Percent' ;
    rdfs:comment 'Percentage of the income threshold basis (e.g., 150% of FPL, 80% of AMI) used to determine customer eligibility for the affordability plan.' ;
    rdfs:domain ind:AffordabilityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentCapacity rdf:type rdf:Property ;
    rdfs:label 'Enrollment Capacity' ;
    rdfs:comment 'Maximum number of customers who can be enrolled in this affordability plan at any given time. Null if no enrollment cap applies.' ;
    rdfs:domain ind:AffordabilityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maximumBenefitAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Benefit Amount' ;
    rdfs:comment 'Maximum total dollar benefit a customer can receive per billing cycle or per enrollment period under this affordability plan. Null if no cap applies.' ;
    rdfs:domain ind:AffordabilityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumBenefitDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Maximum Benefit Duration Months' ;
    rdfs:comment 'Maximum number of months a customer can remain enrolled in this affordability plan before re-certification or plan expiration. Null if no duration limit applies.' ;
    rdfs:domain ind:AffordabilityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partnerProgramName rdf:type rdf:Property ;
    rdfs:label 'Partner Program Name' ;
    rdfs:comment 'Name of external assistance program(s) used for auto-enrollment eligibility verification (e.g., SNAP, Medicaid, LIHEAP, TANF). Null if auto-enrollment is not enabled.' ;
    rdfs:domain ind:AffordabilityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planDescription rdf:type rdf:Property ;
    rdfs:label 'Plan Description' ;
    rdfs:comment 'Detailed description of the affordability plan, including objectives, benefits, and terms of assistance provided to eligible customers.' ;
    rdfs:domain ind:AffordabilityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programWebsiteUrl rdf:type rdf:Property ;
    rdfs:label 'Program Website Url' ;
    rdfs:comment 'Web address where customers can find detailed information about this affordability plan, download application forms, and access eligibility guidelines.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recertificationFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Recertification Frequency Months' ;
    rdfs:comment 'Number of months between required recertification events for customers enrolled in this affordability plan. Null if recertification is not required.' ;
    rdfs:domain ind:AffordabilityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Recertification Required Flag' ;
    rdfs:comment 'Indicates whether customers must periodically recertify their eligibility to continue receiving benefits under this affordability plan. True if recertification is required, false otherwise.' ;
    rdfs:domain ind:AffordabilityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryApprovalNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Number' ;
    rdfs:comment 'Official approval or docket number issued by the regulatory authority authorizing this affordability plan. Null if not applicable.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryMandateFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Mandate Flag' ;
    rdfs:comment 'Indicates whether this affordability plan is mandated by state or local regulation, or is a voluntary utility program. True if mandated, false if voluntary.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredDocumentation rdf:type rdf:Property ;
    rdfs:label 'Required Documentation' ;
    rdfs:comment 'List of documents customers must provide to verify eligibility for this affordability plan (e.g., proof of income, tax returns, benefit award letters, utility bills).' ;
    rdfs:domain ind:AffordabilityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Service Type Applicability' ;
    rdfs:comment 'Specifies which utility services are covered by this affordability plan: water only, wastewater only, water and wastewater combined, stormwater, or all services.' ;
    rdfs:domain ind:AffordabilityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waitlistEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Waitlist Enabled Flag' ;
    rdfs:comment 'Indicates whether a waitlist is maintained for customers when enrollment capacity is reached. True if waitlist is enabled, false otherwise.' ;
    rdfs:domain ind:AffordabilityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryPointAssetRegistryId rdf:type rdf:Property ;
    rdfs:label 'Delivery Point Asset Registry Id' ;
    rdfs:comment 'Foreign key linking to asset.asset_registry. Business justification: Wholesale delivery points are physical assets (interconnection vaults, master meters, pressure control stations) requiring maintenance, inspection, and emergency response planning. Operations teams ne' ;
    rdfs:domain ind:BulkWaterAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Registry .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known unique business identifier for the bulk water agreement, used in contracts, invoices, and regulatory filings.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the bulk water agreement: draft (under negotiation), pending approval (awaiting regulatory or board approval), active (in force), suspended (temporarily halted), terminated (ended before expiration), or expired (reached end date).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the bulk water agreement based on the nature of service: wholesale supply (ongoing large-volume delivery), bulk purchase (one-time or periodic large purchases), emergency interconnection (backup supply during outages), seasonal supply (peak demand periods), treatment services (wastewater treatment for another utility), or wastewater discharge (acceptance of wastewater flows).' ;
    rdfs:domain ind:BulkWaterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the agreement automatically renews at the end of the contract term unless either party provides termination notice. True if auto-renewal applies, False otherwise.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseRatePerThousandGallons rdf:type rdf:Property ;
    rdfs:label 'Base Rate Per Thousand Gallons' ;
    rdfs:comment 'Base volumetric rate charged per thousand gallons of water delivered or wastewater treated under the agreement. Null if pricing is not volumetric.' ;
    rdfs:domain ind:BulkWaterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityChargeAnnual rdf:type rdf:Property ;
    rdfs:label 'Capacity Charge Annual' ;
    rdfs:comment 'Annual capacity reservation charge paid by the purchasing party to reserve a specific volume of supply or treatment capacity, independent of actual usage. Null if no capacity charge applies.' ;
    rdfs:domain ind:BulkWaterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractTermYears rdf:type rdf:Property ;
    rdfs:label 'Contract Term Years' ;
    rdfs:comment 'Duration of the agreement in years from effective start date to effective end date. Null for open-ended agreements.' ;
    rdfs:domain ind:BulkWaterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractedVolumeMgd rdf:type rdf:Property ;
    rdfs:label 'Contracted Volume Mgd' ;
    rdfs:comment 'The contracted daily volume of water supply or wastewater treatment capacity in Million Gallons per Day (MGD). Represents the baseline or maximum daily volume agreed upon in the contract.' ;
    rdfs:domain ind:BulkWaterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterpartyContactEmail rdf:type rdf:Property ;
    rdfs:label 'Counterparty Contact Email' ;
    rdfs:comment 'Primary email address for the counterparty contact person for agreement communications and notifications.' ;
    rdfs:domain ind:BulkWaterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyContactName rdf:type rdf:Property ;
    rdfs:label 'Counterparty Contact Name' ;
    rdfs:comment 'Primary contact person name at the counterparty organization for agreement administration and operational coordination.' ;
    rdfs:domain ind:BulkWaterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Counterparty Contact Phone' ;
    rdfs:comment 'Primary phone number for the counterparty contact person for operational coordination and emergency notifications.' ;
    rdfs:domain ind:BulkWaterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyName rdf:type rdf:Property ;
    rdfs:label 'Counterparty Name' ;
    rdfs:comment 'Legal name of the wholesale customer or supplying utility party to the agreement (e.g., neighboring municipality, regional water authority, industrial facility).' ;
    rdfs:domain ind:BulkWaterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyType rdf:type rdf:Property ;
    rdfs:label 'Counterparty Type' ;
    rdfs:comment 'Classification of the counterparty organization: municipality, water district, industrial customer, commercial customer, government agency, or neighboring utility.' ;
    rdfs:domain ind:BulkWaterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPointDescription rdf:type rdf:Property ;
    rdfs:label 'Delivery Point Description' ;
    rdfs:comment 'Textual description of the physical location where water is delivered or wastewater is received, including interconnection point, meter location, or facility name.' ;
    rdfs:domain ind:BulkWaterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPointLatitude rdf:type rdf:Property ;
    rdfs:label 'Delivery Point Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the delivery or acceptance point for GIS mapping and asset management integration.' ;
    rdfs:domain ind:BulkWaterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryPointLongitude rdf:type rdf:Property ;
    rdfs:label 'Delivery Point Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the delivery or acceptance point for GIS mapping and asset management integration.' ;
    rdfs:domain ind:BulkWaterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryPressurePsiMax rdf:type rdf:Property ;
    rdfs:label 'Delivery Pressure Psi Max' ;
    rdfs:comment 'Maximum allowable delivery pressure in Pounds per Square Inch (PSI) at the interconnection point to prevent damage to the receiving utilitys infrastructure.' ;
    rdfs:domain ind:BulkWaterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryPressurePsiMin rdf:type rdf:Property ;
    rdfs:label 'Delivery Pressure Psi Min' ;
    rdfs:comment 'Minimum required delivery pressure in Pounds per Square Inch (PSI) at the interconnection point to meet the purchasing utilitys distribution system requirements.' ;
    rdfs:domain ind:BulkWaterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emergencySupplyProvisionFlag rdf:type rdf:Property ;
    rdfs:label 'Emergency Supply Provision Flag' ;
    rdfs:comment 'Indicates whether the agreement includes provisions for emergency water supply during outages, droughts, or infrastructure failures. True if emergency provisions exist, False otherwise.' ;
    rdfs:domain ind:BulkWaterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emergencySupplyTerms rdf:type rdf:Property ;
    rdfs:label 'Emergency Supply Terms' ;
    rdfs:comment 'Detailed description of emergency supply terms, including trigger conditions, maximum emergency volume, duration limits, and emergency pricing. Null if no emergency provisions exist.' ;
    rdfs:domain ind:BulkWaterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intergovernmentalAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Intergovernmental Agreement Flag' ;
    rdfs:comment 'Indicates whether this is an intergovernmental agreement between two public entities (municipalities, water districts, government agencies), which may have special legal status and exemptions. True if intergovernmental, False otherwise.' ;
    rdfs:domain ind:BulkWaterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latePaymentPenaltyPercent rdf:type rdf:Property ;
    rdfs:label 'Late Payment Penalty Percent' ;
    rdfs:comment 'Percentage penalty applied to overdue balances for late payment, expressed as an annual percentage rate or per-period rate as specified in the agreement.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meteringResponsibility rdf:type rdf:Property ;
    rdfs:label 'Metering Responsibility' ;
    rdfs:comment 'Party responsible for installation, maintenance, and calibration of metering equipment at the delivery point: supplier, purchaser, or shared responsibility.' ;
    rdfs:domain ind:BulkWaterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumTakeVolumeMgd rdf:type rdf:Property ;
    rdfs:label 'Minimum Take Volume Mgd' ;
    rdfs:comment 'Minimum daily volume in Million Gallons per Day (MGD) that the purchasing party is obligated to take or pay for under take-or-pay provisions. Null if no minimum take obligation exists.' ;
    rdfs:domain ind:BulkWaterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakVolumeMgd rdf:type rdf:Property ;
    rdfs:label 'Peak Volume Mgd' ;
    rdfs:comment 'Maximum allowable daily volume in Million Gallons per Day (MGD) that can be delivered or accepted under the agreement, representing peak capacity limits.' ;
    rdfs:domain ind:BulkWaterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingStructureType rdf:type rdf:Property ;
    rdfs:label 'Pricing Structure Type' ;
    rdfs:comment 'Type of pricing mechanism used in the agreement: flat rate (fixed monthly/annual charge), volumetric (per-gallon charge), tiered (volume-based tiers), demand charge (capacity reservation fee), take-or-pay (minimum volume commitment), or cost-plus (cost recovery plus margin).' ;
    rdfs:domain ind:BulkWaterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateEscalationClause rdf:type rdf:Property ;
    rdfs:label 'Rate Escalation Clause' ;
    rdfs:comment 'Description of the rate escalation mechanism in the agreement, such as annual CPI adjustment, fixed percentage increase, or cost-of-service pass-through provisions.' ;
    rdfs:domain ind:BulkWaterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalTermYears rdf:type rdf:Property ;
    rdfs:label 'Renewal Term Years' ;
    rdfs:comment 'Duration in years of each automatic renewal period if auto-renewal provisions apply. Null if no auto-renewal.' ;
    rdfs:domain ind:BulkWaterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:takeOrPayProvisionFlag rdf:type rdf:Property ;
    rdfs:label 'Take Or Pay Provision Flag' ;
    rdfs:comment 'Indicates whether the agreement includes a take-or-pay provision requiring the purchasing party to pay for a minimum volume regardless of actual usage. True if take-or-pay applies, False otherwise.' ;
    rdfs:domain ind:BulkWaterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of days advance notice required by either party to terminate or not renew the agreement.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waterQualityStandard rdf:type rdf:Property ;
    rdfs:label 'Water Quality Standard' ;
    rdfs:comment 'Reference to the water quality specifications that delivered water must meet, typically citing EPA Safe Drinking Water Act (SDWA) standards, state primacy agency requirements, or specific contractual quality parameters (e.g., turbidity NTU limits, disinfectant residual, MCL compliance).' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectionApplicationId rdf:type rdf:Property ;
    rdfs:label 'Connection Application Id' ;
    rdfs:comment 'Unique identifier for the connection application record. Primary key.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConnectionApplication .

ind:amiEnabled rdf:type rdf:Property ;
    rdfs:label 'Ami Enabled' ;
    rdfs:comment 'Indicates whether the connection will be equipped with Advanced Metering Infrastructure (AMI) for automated meter reading and real-time monitoring.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicantEmail rdf:type rdf:Property ;
    rdfs:label 'Applicant Email' ;
    rdfs:comment 'Primary email address of the applicant for correspondence and notifications regarding the connection application.' ;
    rdfs:domain ind:ConnectionApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicantName rdf:type rdf:Property ;
    rdfs:label 'Applicant Name' ;
    rdfs:comment 'Full legal name of the individual or organization applying for the service connection.' ;
    rdfs:domain ind:ConnectionApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicantPhone rdf:type rdf:Property ;
    rdfs:label 'Applicant Phone' ;
    rdfs:comment 'Primary contact phone number of the applicant for communication regarding the connection application.' ;
    rdfs:domain ind:ConnectionApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityAvailable rdf:type rdf:Property ;
    rdfs:label 'Capacity Available' ;
    rdfs:comment 'Indicates whether sufficient system capacity (pressure, flow, treatment capacity) is available to serve the requested connection without infrastructure upgrades.' ;
    rdfs:domain ind:ConnectionApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capacityChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Capacity Charge Amount' ;
    rdfs:comment 'System development or capacity charge assessed to fund infrastructure expansion to serve the new connection, in USD.' ;
    rdfs:domain ind:ConnectionApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:connectionSizeInches rdf:type rdf:Property ;
    rdfs:label 'Connection Size Inches' ;
    rdfs:comment 'Diameter of the requested service connection in inches (e.g., 0.75, 1.0, 1.5, 2.0). Critical for capacity planning and meter sizing.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedFlowDemandGpm rdf:type rdf:Property ;
    rdfs:label 'Estimated Flow Demand Gpm' ;
    rdfs:comment 'Estimated peak flow demand in gallons per minute (GPM) for the requested service connection. Used for hydraulic modeling and capacity verification.' ;
    rdfs:domain ind:ConnectionApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:infrastructureUpgradeRequired rdf:type rdf:Property ;
    rdfs:label 'Infrastructure Upgrade Required' ;
    rdfs:comment 'Indicates whether main extensions, pump station upgrades, or other infrastructure improvements are required to serve the connection.' ;
    rdfs:domain ind:ConnectionApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meterTypeRequested rdf:type rdf:Property ;
    rdfs:label 'Meter Type Requested' ;
    rdfs:comment 'Type or model of water meter requested or recommended for the connection (e.g., positive displacement, turbine, compound, electromagnetic).' ;
    rdfs:domain ind:ConnectionApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertyType rdf:type rdf:Property ;
    rdfs:label 'Property Type' ;
    rdfs:comment 'Classification of the property requesting service: residential, commercial, industrial, institutional, agricultural, or mixed-use.' ;
    rdfs:domain ind:ConnectionApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedServiceDate rdf:type rdf:Property ;
    rdfs:label 'Requested Service Date' ;
    rdfs:comment 'Date by which the applicant requests the service connection to be activated or completed.' ;
    rdfs:domain ind:ConnectionApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Service Address Line1' ;
    rdfs:comment 'Primary street address line where the water or wastewater service connection is requested.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Service Address Line2' ;
    rdfs:comment 'Secondary address line (apartment, suite, unit number) for the service location.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCity rdf:type rdf:Property ;
    rdfs:label 'Service City' ;
    rdfs:comment 'City or municipality where the service connection is requested.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLatitude rdf:type rdf:Property ;
    rdfs:label 'Service Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the service connection location for GIS mapping and network planning.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceLongitude rdf:type rdf:Property ;
    rdfs:label 'Service Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the service connection location for GIS mapping and network planning.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:servicePostalCode rdf:type rdf:Property ;
    rdfs:label 'Service Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the service address.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceState rdf:type rdf:Property ;
    rdfs:label 'Service State' ;
    rdfs:comment 'Two-letter state or province code where the service connection is requested.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalReviewDate rdf:type rdf:Property ;
    rdfs:label 'Technical Review Date' ;
    rdfs:comment 'Date when the technical feasibility and capacity review of the connection application was completed.' ;
    rdfs:domain ind:ConnectionApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalFeesAssessed rdf:type rdf:Property ;
    rdfs:label 'Total Fees Assessed' ;
    rdfs:comment 'Total of all fees assessed for the connection application (application fee, connection fee, capacity charge, and any other charges), in USD.' ;
    rdfs:domain ind:ConnectionApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conservationProgramId rdf:type rdf:Property ;
    rdfs:label 'Conservation Program Id' ;
    rdfs:comment 'Unique identifier for the water conservation program record. Primary key.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConservationProgram .

ind:programManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Program Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Conservation programs in water utilities have designated employee program managers responsible for execution, budget, enrollment, and regulatory reporting. Links employee accountability to program per' ;
    rdfs:domain ind:ConservationProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualParticipantCount rdf:type rdf:Property ;
    rdfs:label 'Actual Participant Count' ;
    rdfs:comment 'Current count of customers or accounts enrolled and participating in the conservation program.' ;
    rdfs:domain ind:ConservationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualWaterSavingsGallons rdf:type rdf:Property ;
    rdfs:label 'Actual Water Savings Gallons' ;
    rdfs:comment 'Measured or estimated cumulative water savings achieved by the program to date, in gallons.' ;
    rdfs:domain ind:ConservationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetExpendedToDate rdf:type rdf:Property ;
    rdfs:label 'Budget Expended To Date' ;
    rdfs:comment 'Cumulative amount of program budget spent as of the last reporting period, in US dollars.' ;
    rdfs:domain ind:ConservationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerClassApplicability rdf:type rdf:Property ;
    rdfs:label 'Customer Class Applicability' ;
    rdfs:comment 'Customer class segments eligible to participate in this conservation program.' ;
    rdfs:domain ind:ConservationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityCriteria rdf:type rdf:Property ;
    rdfs:label 'Eligibility Criteria' ;
    rdfs:comment 'Detailed requirements and conditions that customers must meet to participate in the conservation program, including customer class, service type, meter size, and usage thresholds.' ;
    rdfs:domain ind:ConservationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment End Date' ;
    rdfs:comment 'Date when customer enrollment or application for the program closes. Null for open enrollment programs.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Start Date' ;
    rdfs:comment 'Date when customer enrollment or application for the program opens.' ;
    rdfs:domain ind:ConservationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incentiveAmount rdf:type rdf:Property ;
    rdfs:label 'Incentive Amount' ;
    rdfs:comment 'Fixed monetary value of the incentive provided per qualifying customer or installation, in US dollars.' ;
    rdfs:domain ind:ConservationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentiveType rdf:type rdf:Property ;
    rdfs:label 'Incentive Type' ;
    rdfs:comment 'Type of financial or non-financial incentive offered to customers participating in the program.' ;
    rdfs:domain ind:ConservationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveUnit rdf:type rdf:Property ;
    rdfs:label 'Incentive Unit' ;
    rdfs:comment 'Unit of measure for calculating and distributing the incentive to program participants.' ;
    rdfs:domain ind:ConservationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReportedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reported Date' ;
    rdfs:comment 'Date of the most recent performance report submitted for this conservation program.' ;
    rdfs:domain ind:ConservationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketingCampaignCode rdf:type rdf:Property ;
    rdfs:label 'Marketing Campaign Code' ;
    rdfs:comment 'Code linking the conservation program to specific marketing and outreach campaigns for tracking effectiveness.' ;
    rdfs:domain ind:ConservationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumIncentivePerCustomer rdf:type rdf:Property ;
    rdfs:label 'Maximum Incentive Per Customer' ;
    rdfs:comment 'Cap on the total incentive amount a single customer can receive under this program during the program period, in US dollars.' ;
    rdfs:domain ind:ConservationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceMetricDefinition rdf:type rdf:Property ;
    rdfs:label 'Performance Metric Definition' ;
    rdfs:comment 'Description of the key performance indicators (KPIs) used to measure program success, such as gallons saved per dollar spent or participation rate.' ;
    rdfs:domain ind:ConservationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programCategory rdf:type rdf:Property ;
    rdfs:label 'Program Category' ;
    rdfs:comment 'Target sector or application area for the conservation program.' ;
    rdfs:domain ind:ConservationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programDescription rdf:type rdf:Property ;
    rdfs:label 'Program Description' ;
    rdfs:comment 'Detailed description of the conservation program objectives, activities, and benefits to customers and the utility.' ;
    rdfs:domain ind:ConservationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programEndDate rdf:type rdf:Property ;
    rdfs:label 'Program End Date' ;
    rdfs:comment 'Date when the conservation program concludes and no new participants are accepted. Null for ongoing programs.' ;
    rdfs:domain ind:ConservationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programNotes rdf:type rdf:Property ;
    rdfs:label 'Program Notes' ;
    rdfs:comment 'Additional free-text notes, comments, or special instructions related to the conservation program administration and operations.' ;
    rdfs:domain ind:ConservationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStartDate rdf:type rdf:Property ;
    rdfs:label 'Program Start Date' ;
    rdfs:comment 'Date when the conservation program becomes active and customers can begin participating.' ;
    rdfs:domain ind:ConservationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current lifecycle status of the conservation program.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'Classification of the conservation program by delivery mechanism and approach. [ENUM-REF-CANDIDATE: rebate|tiered_pricing|water_audit|drought_surcharge|education|restriction|incentive — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryMandateReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Mandate Reference' ;
    rdfs:comment 'Citation or reference to the specific regulation, statute, or executive order requiring or authorizing the conservation program.' ;
    rdfs:domain ind:ConservationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetParticipantCount rdf:type rdf:Property ;
    rdfs:label 'Target Participant Count' ;
    rdfs:comment 'Goal for the number of customers or accounts participating in the conservation program.' ;
    rdfs:domain ind:ConservationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetWaterSavingsGallons rdf:type rdf:Property ;
    rdfs:label 'Target Water Savings Gallons' ;
    rdfs:comment 'Projected total water savings goal for the program over its duration, measured in gallons.' ;
    rdfs:domain ind:ConservationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tariffReference rdf:type rdf:Property ;
    rdfs:label 'Tariff Reference' ;
    rdfs:comment 'Reference to the utility tariff schedule or rate case filing that includes this conservation program.' ;
    rdfs:domain ind:ConservationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalProgramBudget rdf:type rdf:Property ;
    rdfs:label 'Total Program Budget' ;
    rdfs:comment 'Total allocated budget for the conservation program over its entire duration, in US dollars.' ;
    rdfs:domain ind:ConservationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amiEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Ami Enabled Flag' ;
    rdfs:comment 'Indicates whether this offering requires or supports Advanced Metering Infrastructure (AMI) for automated meter reading and real-time consumption monitoring. True = AMI required or available; False = manual or Automatic Meter Reading (AMR) only.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseRateAmount rdf:type rdf:Property ;
    rdfs:label 'Base Rate Amount' ;
    rdfs:comment 'Fixed monthly or periodic base charge for the service offering, independent of consumption. Covers fixed costs such as meter maintenance, billing, and infrastructure access. Expressed in local currency (USD for U.S. utilities).' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityCharge rdf:type rdf:Property ;
    rdfs:label 'Capacity Charge' ;
    rdfs:comment 'Fee for reserving system capacity or infrastructure access, common in industrial and municipal bulk water agreements. May be based on meter size, peak demand, or contracted volume. Also known as a demand charge or readiness-to-serve charge.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:connectionFee rdf:type rdf:Property ;
    rdfs:label 'Connection Fee' ;
    rdfs:comment 'One-time fee charged to establish a new service connection, including meter installation, service line connection, and administrative setup. May vary by customer class and service type.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conservationProgramEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Conservation Program Eligible Flag' ;
    rdfs:comment 'Indicates whether customers enrolled in this offering are eligible for water conservation programs, rebates, or incentives (e.g., low-flow fixture rebates, landscape conversion incentives). True = eligible; False = not eligible.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractTermMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Term Months' ;
    rdfs:comment 'Standard contract duration in months for this offering. Common for commercial, industrial, and municipal agreements. Null for month-to-month residential service.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryMode rdf:type rdf:Property ;
    rdfs:label 'Delivery Mode' ;
    rdfs:comment 'Method by which the service is delivered and billed. Metered = consumption-based billing via Advanced Metering Infrastructure (AMI) or Automatic Meter Reading (AMR); Unmetered = fixed-rate service without consumption measurement; Flat rate = fixed periodic charge regardless of usage; Seasonal = service active only during specific periods; Temporary = short-term service for construction or events; Emergency = contingency supply during outages or disasters.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireProtectionServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Fire Protection Service Flag' ;
    rdfs:comment 'Indicates whether this offering includes dedicated fire protection service (e.g., fire hydrant access, private fire line). True = fire protection included; False = potable water or wastewater service only.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meterSizeRequiredInches rdf:type rdf:Property ;
    rdfs:label 'Meter Size Required Inches' ;
    rdfs:comment 'Standard meter size in inches required or recommended for this offering based on expected flow and customer class. Common sizes: 0.625 (5/8 inch), 0.75 (3/4 inch), 1.0, 1.5, 2.0, 3.0, 4.0, 6.0, 8.0 inches. Null for unmetered service.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumMonthlyCharge rdf:type rdf:Property ;
    rdfs:label 'Minimum Monthly Charge' ;
    rdfs:comment 'Minimum amount a customer will be billed each billing period, regardless of consumption. Ensures cost recovery for fixed infrastructure and service availability. Null if no minimum applies.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offeringCode rdf:type rdf:Property ;
    rdfs:label 'Offering Code' ;
    rdfs:comment 'Externally-known unique code for the service offering used in billing systems, tariff schedules, and customer communications. Examples: WTR-RES-01, WWC-COM-02, RCW-IND-01.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offeringDescription rdf:type rdf:Property ;
    rdfs:label 'Offering Description' ;
    rdfs:comment 'Detailed description of the service offering including scope, delivery specifications, and any special conditions or limitations. Used in customer agreements and regulatory filings.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offeringName rdf:type rdf:Property ;
    rdfs:label 'Offering Name' ;
    rdfs:comment 'Human-readable name of the service offering as presented to customers and in regulatory tariff filings. Examples: Residential Potable Water Service, Commercial Wastewater Collection, Industrial Recycled Water Supply.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pressureRangePsiMax rdf:type rdf:Property ;
    rdfs:label 'Pressure Range Psi Max' ;
    rdfs:comment 'Maximum water pressure in PSI at the customer service connection under normal operating conditions. Excessive pressure may require Pressure Reducing Valve (PRV) installation. Null for wastewater or non-pressurized services.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pressureRangePsiMin rdf:type rdf:Property ;
    rdfs:label 'Pressure Range Psi Min' ;
    rdfs:comment 'Minimum water pressure in PSI guaranteed at the customer service connection under normal operating conditions. Part of service delivery specifications. Null for wastewater or non-pressurized services.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaResponseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Sla Response Time Hours' ;
    rdfs:comment 'Maximum time in hours within which the utility commits to respond to service requests, outages, or quality complaints for this offering. Part of the contractual Service Level Agreement (SLA). Null if no formal SLA applies.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaRestorationTimeHours rdf:type rdf:Property ;
    rdfs:label 'Sla Restoration Time Hours' ;
    rdfs:comment 'Maximum time in hours within which the utility commits to restore service following an outage or interruption for this offering. Part of the contractual Service Level Agreement (SLA). Null if no formal SLA applies.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumetricRateAmount rdf:type rdf:Property ;
    rdfs:label 'Volumetric Rate Amount' ;
    rdfs:comment 'Per-unit charge for water or wastewater service based on consumption volume. Typically expressed in dollars per thousand gallons ($/kgal) or dollars per hundred cubic feet ($/CCF). Null for unmetered or flat-rate offerings.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumetricRateUnit rdf:type rdf:Property ;
    rdfs:label 'Volumetric Rate Unit' ;
    rdfs:comment 'Unit of measure for volumetric billing. kgal = thousand gallons; CCF = hundred cubic feet; gallon = individual gallon; cubic meter = m³ (common in international contexts); acre-foot = volume unit for large agricultural or municipal contracts.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceProgramEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Service Program Enrollment Id' ;
    rdfs:comment 'Unique identifier for the program enrollment record. Primary key.' ;
    rdfs:domain ind:ServiceProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountBillingAccountId rdf:type rdf:Property ;
    rdfs:label 'Account Billing Account Id' ;
    rdfs:comment 'Foreign key linking to the billing account enrolled in the conservation program' ;
    rdfs:domain ind:ServiceProgramEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingAccount .

ind:primaryServiceProgramConservationProgramId rdf:type rdf:Property ;
    rdfs:label 'Primary Service Program Conservation Program Id' ;
    rdfs:comment 'Reference to the conservation, assistance, or demand management program.' ;
    rdfs:domain ind:ServiceProgramEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConservationProgram .

ind:baselineConsumptionGallons rdf:type rdf:Property ;
    rdfs:label 'Baseline Consumption Gallons' ;
    rdfs:comment 'Customer water consumption baseline measured in gallons prior to program enrollment. Used to calculate savings.' ;
    rdfs:domain ind:ServiceProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselinePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Period End Date' ;
    rdfs:comment 'End date of the baseline measurement period used to establish pre-program consumption.' ;
    rdfs:domain ind:ServiceProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselinePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Period Start Date' ;
    rdfs:comment 'Start date of the baseline measurement period used to establish pre-program consumption.' ;
    rdfs:domain ind:ServiceProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'Date when the enrollment was cancelled or terminated.' ;
    rdfs:domain ind:ServiceProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for enrollment cancellation. [ENUM-REF-CANDIDATE: customer_request|non_compliance|program_ended|moved|ineligible|duplicate|other — promote to reference product]' ;
    rdfs:domain ind:ServiceProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Description' ;
    rdfs:comment 'Detailed explanation of why the enrollment was cancelled.' ;
    rdfs:domain ind:ServiceProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Eligibility Verification Date' ;
    rdfs:comment 'Date when customer eligibility was verified.' ;
    rdfs:domain ind:ServiceProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eligibilityVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Eligibility Verified Date' ;
    rdfs:comment 'Date when the utility verified that this billing account met the eligibility criteria for this conservation program.' ;
    rdfs:domain ind:ServiceProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eligibilityVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Eligibility Verified Flag' ;
    rdfs:comment 'Indicates whether customer eligibility for the program has been verified (e.g., income verification for assistance programs).' ;
    rdfs:domain ind:ServiceProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incentiveAmountApproved rdf:type rdf:Property ;
    rdfs:label 'Incentive Amount Approved' ;
    rdfs:comment 'Total monetary incentive amount approved for this enrollment in USD. Includes rebates, credits, or financial assistance.' ;
    rdfs:domain ind:ServiceProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentiveAmountPaid rdf:type rdf:Property ;
    rdfs:label 'Incentive Amount Paid' ;
    rdfs:comment 'Actual monetary incentive amount paid to the customer in USD.' ;
    rdfs:domain ind:ServiceProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentiveAmountReceived rdf:type rdf:Property ;
    rdfs:label 'Incentive Amount Received' ;
    rdfs:comment 'Total monetary incentive amount paid to this billing account for participation in this specific conservation program. Identified in detection phase as relationship data.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentivePaymentDate rdf:type rdf:Property ;
    rdfs:label 'Incentive Payment Date' ;
    rdfs:comment 'Date when the incentive payment was issued to the customer.' ;
    rdfs:domain ind:ServiceProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incentivePaymentMethod rdf:type rdf:Property ;
    rdfs:label 'Incentive Payment Method' ;
    rdfs:comment 'Method used to deliver the incentive payment to the customer.' ;
    rdfs:domain ind:ServiceProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Program Enrollment Id' ;
    rdfs:comment 'Unique identifier for this program enrollment record. Primary key.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceProgramEnrollment .

ind:programTermMonths rdf:type rdf:Property ;
    rdfs:label 'Program Term Months' ;
    rdfs:comment 'Duration of the program enrollment commitment measured in months.' ;
    rdfs:domain ind:ServiceProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryProgramCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Program Code' ;
    rdfs:comment 'Code identifying the regulatory program category for compliance reporting (e.g., state-mandated conservation, drought response).' ;
    rdfs:domain ind:ServiceProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Verified By User' ;
    rdfs:comment 'Username or identifier of the staff member or auditor who performed the verification.' ;
    rdfs:domain ind:ServiceProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterSavingsAchieved rdf:type rdf:Property ;
    rdfs:label 'Water Savings Achieved' ;
    rdfs:comment 'Measured water savings in gallons achieved by this billing account through participation in this specific conservation program. Identified in detection phase as relationship data.' ;
    rdfs:domain ind:ServiceProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waterSavingsActualGallons rdf:type rdf:Property ;
    rdfs:label 'Water Savings Actual Gallons' ;
    rdfs:comment 'Actual water savings achieved through this enrollment measured in gallons. Calculated from meter reading analysis or engineering estimates.' ;
    rdfs:domain ind:ServiceProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterSavingsCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Water Savings Calculation Method' ;
    rdfs:comment 'Methodology used to calculate actual water savings (e.g., meter-based analysis, engineering estimate, deemed savings).' ;
    rdfs:domain ind:ServiceProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterSavingsTargetGallons rdf:type rdf:Property ;
    rdfs:label 'Water Savings Target Gallons' ;
    rdfs:comment 'Target water savings goal for this enrollment measured in gallons. Used for conservation program performance tracking.' ;
    rdfs:domain ind:ServiceProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceOfferingId rdf:type rdf:Property ;
    rdfs:label 'Service Offering Id' ;
    rdfs:comment 'Reference to the specific service offering (water, wastewater, reclaimed water, stormwater) that this agreement covers. Links to the service catalog.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offering .

ind:autoPayEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Pay Enabled' ;
    rdfs:comment 'Indicates whether automatic payment is enabled for this service agreement. When true, invoices are automatically paid from the customers designated payment method.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoRenewalEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Enabled' ;
    rdfs:comment 'Indicates whether the service agreement automatically renews at the end of the contract term. When false, agreement requires explicit renewal action.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:backflowPreventionRequired rdf:type rdf:Property ;
    rdfs:label 'Backflow Prevention Required' ;
    rdfs:comment 'Indicates whether backflow prevention device installation and annual testing is required for this service agreement per SDWA (Safe Drinking Water Act) cross-connection control requirements.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetBillingEnabled rdf:type rdf:Property ;
    rdfs:label 'Budget Billing Enabled' ;
    rdfs:comment 'Indicates whether the customer is enrolled in budget billing program, which averages annual usage into equal monthly payments to reduce seasonal bill variation.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:depositStatus rdf:type rdf:Property ;
    rdfs:label 'Deposit Status' ;
    rdfs:comment 'Current status of the security deposit for this agreement. Tracks whether deposit is required, currently held, waived based on credit, or refunded.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Date when the service agreement terminates or is scheduled to terminate. Null for open-ended agreements. Used for final billing and account closure.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'External system identifier for this service agreement in legacy or third-party systems. Used for cross-system reconciliation and data migration tracking.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industrialUserPermitRequired rdf:type rdf:Property ;
    rdfs:label 'Industrial User Permit Required' ;
    rdfs:comment 'Indicates whether this service agreement requires an Industrial User Permit for wastewater discharge per NPDES (National Pollutant Discharge Elimination System) pretreatment program requirements.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irrigationServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Irrigation Service Flag' ;
    rdfs:comment 'Indicates whether this agreement includes irrigation or outdoor water service, which may be billed separately or subject to seasonal rates and wastewater exemptions.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lowIncomeAssistanceEligible rdf:type rdf:Property ;
    rdfs:label 'Low Income Assistance Eligible' ;
    rdfs:comment 'Indicates whether this service agreement qualifies for low-income customer assistance programs, rate discounts, or payment plans per regulatory requirements.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumUsageCommitmentGallons rdf:type rdf:Property ;
    rdfs:label 'Minimum Usage Commitment Gallons' ;
    rdfs:comment 'Minimum water usage volume (in gallons) that the customer commits to consume per billing period. Common for commercial and industrial agreements. Used for minimum charge calculations.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paperlessBillingEnabled rdf:type rdf:Property ;
    rdfs:label 'Paperless Billing Enabled' ;
    rdfs:comment 'Indicates whether the customer has opted for electronic billing instead of paper invoices. Supports environmental sustainability initiatives.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seniorCitizenDiscountEligible rdf:type rdf:Property ;
    rdfs:label 'Senior Citizen Discount Eligible' ;
    rdfs:comment 'Indicates whether this service agreement qualifies for senior citizen rate discounts or special programs as defined by utility tariff.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialConditions rdf:type rdf:Property ;
    rdfs:label 'Special Conditions' ;
    rdfs:comment 'Free-text field capturing any special contractual conditions, exceptions, or custom terms negotiated for this service agreement. Examples include seasonal rate adjustments, volume discounts, or regulatory exemptions.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'Date when the service agreement becomes effective and service delivery begins. Used for billing proration and regulatory compliance reporting.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Termination Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for service agreement termination. Examples include customer move-out, non-payment, property demolition, or service transfer.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageMonthlyConsumptionGallons rdf:type rdf:Property ;
    rdfs:label 'Average Monthly Consumption Gallons' ;
    rdfs:comment 'Typical average monthly water consumption in gallons for accounts in this service class. Used for rate modeling and demand forecasting.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awwaClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Awwa Classification Code' ;
    rdfs:comment 'Standard classification code from AWWA M1 Manual used for industry benchmarking and best practice alignment.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCycleType rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle Type' ;
    rdfs:comment 'Standard billing frequency for accounts in this service class (e.g., monthly, bimonthly, quarterly). Determines meter reading and invoice generation schedules.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classType rdf:type rdf:Property ;
    rdfs:label 'Class Type' ;
    rdfs:comment 'High-level category of the service class used for grouping and analysis. Aligns with regulatory reporting categories. [ENUM-REF-CANDIDATE: residential|commercial|industrial|irrigation|fire_protection|municipal|wholesale|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conservationProgramEligible rdf:type rdf:Property ;
    rdfs:label 'Conservation Program Eligible' ;
    rdfs:comment 'Indicates whether accounts in this service class are eligible for water conservation programs, rebates, or incentives.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consumptionTierStructure rdf:type rdf:Property ;
    rdfs:label 'Consumption Tier Structure' ;
    rdfs:comment 'Type of rate structure applied to consumption for this class (e.g., flat rate, tiered/block rates, seasonal rates, time-of-use rates).' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositRequirementAmount rdf:type rdf:Property ;
    rdfs:label 'Deposit Requirement Amount' ;
    rdfs:comment 'Standard security deposit amount required for new accounts in this service class. May vary based on credit risk and consumption history.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disconnectionPolicy rdf:type rdf:Property ;
    rdfs:label 'Disconnection Policy' ;
    rdfs:comment 'Policy governing service disconnection for non-payment for this class (e.g., standard, protected for vulnerable populations, restricted for essential services).' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireFlowRequirementGpm rdf:type rdf:Property ;
    rdfs:label 'Fire Flow Requirement Gpm' ;
    rdfs:comment 'Minimum fire flow capacity requirement in gallons per minute (GPM) for properties served under this class. Applicable primarily to commercial, industrial, and fire protection classes.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:latePaymentPenaltyRate rdf:type rdf:Property ;
    rdfs:label 'Late Payment Penalty Rate' ;
    rdfs:comment 'Percentage rate applied to overdue balances for accounts in this service class. Subject to regulatory limits.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumChargeApplicable rdf:type rdf:Property ;
    rdfs:label 'Minimum Charge Applicable' ;
    rdfs:comment 'Indicates whether a minimum monthly or periodic charge applies to accounts in this service class, regardless of consumption.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:peakDemandFactor rdf:type rdf:Property ;
    rdfs:label 'Peak Demand Factor' ;
    rdfs:comment 'Multiplier representing the ratio of peak demand to average demand for this service class. Used in capacity planning and infrastructure sizing.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pressureRequirementPsi rdf:type rdf:Property ;
    rdfs:label 'Pressure Requirement Psi' ;
    rdfs:comment 'Minimum service pressure requirement in pounds per square inch (PSI) for accounts in this service class. Ensures adequate pressure for intended use.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pucApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Puc Approval Date' ;
    rdfs:comment 'Date when the Public Utilities Commission approved this service class and its associated rate structure. Required for regulated utilities.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pucFilingReference rdf:type rdf:Property ;
    rdfs:label 'Puc Filing Reference' ;
    rdfs:comment 'Reference number or identifier of the PUC rate case filing or tariff document that established or modified this service class.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateScheduleGroup rdf:type rdf:Property ;
    rdfs:label 'Rate Schedule Group' ;
    rdfs:comment 'Identifier of the rate schedule group applicable to this service class. Links the class to specific rate structures and tariff schedules for billing purposes.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNotificationDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notification Days' ;
    rdfs:comment 'Number of days advance notice required before contract renewal or rate changes for this service class.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonalRateApplicable rdf:type rdf:Property ;
    rdfs:label 'Seasonal Rate Applicable' ;
    rdfs:comment 'Indicates whether seasonal rate variations (e.g., higher summer rates for irrigation) apply to this service class.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceClassStatus rdf:type rdf:Property ;
    rdfs:label 'Service Class Status' ;
    rdfs:comment 'Current lifecycle status of the service class. Active classes are available for new account assignments; deprecated classes are phased out but may have existing accounts.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelAgreementTier rdf:type rdf:Property ;
    rdfs:label 'Service Level Agreement Tier' ;
    rdfs:comment 'Service level tier defining response times, service restoration priorities, and quality commitments for this class (e.g., standard, priority, premium, critical).' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffClassification rdf:type rdf:Property ;
    rdfs:label 'Tariff Classification' ;
    rdfs:comment 'Official tariff classification as filed with and approved by the Public Utilities Commission. Used for rate case modeling and tariff compliance.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterQualityMonitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Water Quality Monitoring Frequency' ;
    rdfs:comment 'Required frequency of water quality monitoring or testing for accounts in this service class. More stringent for industrial and high-risk classes.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedCrewId rdf:type rdf:Property ;
    rdfs:label 'Assigned Crew Id' ;
    rdfs:comment 'Reference to the field crew or work team assigned to perform the service order.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Crew .

ind:orderCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Order Created By User Employee Id' ;
    rdfs:comment 'System user identifier of the person or process that created the service order record.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:orderEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Order Employee Id' ;
    rdfs:comment 'Reference to the individual field technician assigned to perform the service order.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:orderMeteringMeterId rdf:type rdf:Property ;
    rdfs:label 'Order Metering Meter Id' ;
    rdfs:comment 'Serial number or identifier of the meter removed during a meter exchange service order.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MeteringMeter .

ind:orderModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Order Modified By User Employee Id' ;
    rdfs:comment 'System user identifier of the person or process that last modified the service order record.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:orderNewMeterMeteringMeterId rdf:type rdf:Property ;
    rdfs:label 'Order New Meter Metering Meter Id' ;
    rdfs:comment 'Serial number or identifier of the meter installed during a meter set or exchange service order.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MeteringMeter .

ind:slaDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Sla Definition Id' ;
    rdfs:comment 'Foreign key linking to service.sla_definition. Business justification: Service orders are executed according to defined SLA standards. order currently has sla_target_hours, sla_actual_hours, and sla_met_flag. The target hours should be derived from sla_definition rather ' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaDefinition .

ind:actualEndTime rdf:type rdf:Property ;
    rdfs:label 'Actual End Time' ;
    rdfs:comment 'Actual date and time when the field crew completed the service order activity.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Time' ;
    rdfs:comment 'Actual date and time when the field crew began performing the service order activity.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:appointmentWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Appointment Window End' ;
    rdfs:comment 'End of the time window communicated to the customer for the service order appointment.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:appointmentWindowStart rdf:type rdf:Property ;
    rdfs:label 'Appointment Window Start' ;
    rdfs:comment 'Beginning of the time window communicated to the customer for the service order appointment.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerContactName rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Name' ;
    rdfs:comment 'Name of the customer contact person for this service order, used for appointment confirmation and access coordination.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Phone' ;
    rdfs:comment 'Phone number of the customer contact person for appointment confirmation and field crew communication.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meterReadingUnit rdf:type rdf:Property ;
    rdfs:label 'Meter Reading Unit' ;
    rdfs:comment 'Unit of measure for the meter reading value captured during the service order.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meterReadingValue rdf:type rdf:Property ;
    rdfs:label 'Meter Reading Value' ;
    rdfs:comment 'Final meter reading captured during the service order activity, measured in appropriate units (gallons, cubic meters, etc.).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Externally visible business identifier for the service order, used for customer communication and field crew reference.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the service order in the field service workflow. [ENUM-REF-CANDIDATE: draft|scheduled|dispatched|in_progress|completed|cancelled|on_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of the service order activity. Defines the nature of field work to be performed. [ENUM-REF-CANDIDATE: turn_on|turn_off|reconnection|meter_set|meter_exchange|service_upgrade|final_read|leak_investigation — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeCode rdf:type rdf:Property ;
    rdfs:label 'Outcome Code' ;
    rdfs:comment 'Standardized code indicating the final outcome or result of the service order execution.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDate rdf:type rdf:Property ;
    rdfs:label 'Requested Date' ;
    rdfs:comment 'Date when the customer or system requested the service order to be performed.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledEndTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Time' ;
    rdfs:comment 'Planned date and time when the field crew is expected to complete the service order activity.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Time' ;
    rdfs:comment 'Precise date and time when the field crew is scheduled to begin the service order activity.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Service Fee Amount' ;
    rdfs:comment 'Monetary charge assessed to the customer for the service order activity, in US dollars.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaActualHours rdf:type rdf:Property ;
    rdfs:label 'Sla Actual Hours' ;
    rdfs:comment 'Actual number of hours elapsed from order creation to completion, used for SLA compliance tracking.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaMetFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Met Flag' ;
    rdfs:comment 'Indicates whether the service order was completed within the target SLA timeframe.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workPerformedDescription rdf:type rdf:Property ;
    rdfs:label 'Work Performed Description' ;
    rdfs:comment 'Detailed narrative description of the work actually performed by the field crew, including any findings or issues encountered.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'Date when service delivery was first activated at this service point, marking the beginning of billable service. May differ from installation date if there was a delay between physical installation and service turn-on.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backflowDeviceType rdf:type rdf:Property ;
    rdfs:label 'Backflow Device Type' ;
    rdfs:comment 'Type of backflow prevention device installed at this service point. RPZ is Reduced Pressure Zone; DCVA is Double Check Valve Assembly; PVB is Pressure Vacuum Breaker; AG is Air Gap; none indicates no device required; unknown indicates status not verified.' ;
    rdfs:domain ind:Point ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectionMaterial rdf:type rdf:Property ;
    rdfs:label 'Connection Material' ;
    rdfs:comment 'Material composition of the service line connecting the distribution main to the customer premises. Critical for Lead and Copper Rule Revisions (LCRR) compliance and service line inventory reporting. [ENUM-REF-CANDIDATE: copper|pvc|hdpe|galvanized_steel|lead|ductile_iron|pex|unknown — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Point ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireServiceIndicator rdf:type rdf:Property ;
    rdfs:label 'Fire Service Indicator' ;
    rdfs:comment 'Indicates whether this service point includes fire protection service (fire sprinkler system or fire hydrant connection). True if fire service is provided; false for domestic-only service.' ;
    rdfs:domain ind:Point ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routeCode rdf:type rdf:Property ;
    rdfs:label 'Route Code' ;
    rdfs:comment 'Identifier for the meter reading or field service route to which this service point is assigned. Used for scheduling meter reading, field inspections, and maintenance activities.' ;
    rdfs:domain ind:Point ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCountryCode rdf:type rdf:Property ;
    rdfs:label 'Service Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code where the service point is located (e.g., USA, CAN, MEX).' ;
    rdfs:domain ind:Point ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicePointDescription rdf:type rdf:Property ;
    rdfs:label 'Service Point Description' ;
    rdfs:comment 'Free-text description providing additional context about the service point location, special characteristics, or access instructions for field personnel.' ;
    rdfs:domain ind:Point ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicePointNumber rdf:type rdf:Property ;
    rdfs:label 'Service Point Number' ;
    rdfs:comment 'Externally-known business identifier for the service point, typically displayed on customer bills and used in customer service interactions. Unique across the utility service territory.' ;
    rdfs:domain ind:Point ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicePointStatus rdf:type rdf:Property ;
    rdfs:label 'Service Point Status' ;
    rdfs:comment 'Current operational status of the service point in its lifecycle. Active indicates service is being delivered; inactive indicates no current service; suspended indicates temporary service hold; pending_activation indicates awaiting turn-on; disconnected indicates service terminated; abandoned indicates permanently retired.' ;
    rdfs:domain ind:Point ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaSquareMiles rdf:type rdf:Property ;
    rdfs:label 'Area Square Miles' ;
    rdfs:comment 'Total geographic area of the service territory measured in square miles.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commercialCustomerCount rdf:type rdf:Property ;
    rdfs:label 'Commercial Customer Count' ;
    rdfs:comment 'Number of commercial customer accounts within the territory.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:countyName rdf:type rdf:Property ;
    rdfs:label 'County Name' ;
    rdfs:comment 'Primary county in which the service territory is located, used for regulatory reporting and jurisdictional analysis.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Franchise Agreement Number' ;
    rdfs:comment 'Identifier of the regulatory franchise agreement or certificate of public convenience and necessity (CPCN) authorizing service in this territory.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Franchise Expiration Date' ;
    rdfs:comment 'Date when the current franchise agreement or certificate expires and requires renewal or renegotiation.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:industrialCustomerCount rdf:type rdf:Property ;
    rdfs:label 'Industrial Customer Count' ;
    rdfs:comment 'Number of industrial customer accounts within the territory.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:npdesPermitJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Npdes Permit Jurisdiction' ;
    rdfs:comment 'Regulatory authority responsible for wastewater discharge permits under the Clean Water Act (CWA) in this territory.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingDivisionCode rdf:type rdf:Property ;
    rdfs:label 'Operating Division Code' ;
    rdfs:comment 'Internal code identifying the utility\'s operating division or business unit responsible for service delivery in this territory.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peakDailyDemandMgd rdf:type rdf:Property ;
    rdfs:label 'Peak Daily Demand Mgd' ;
    rdfs:comment 'Peak daily water demand for the territory measured in million gallons per day, used for infrastructure sizing and emergency planning.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:potableWaterServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Potable Water Service Flag' ;
    rdfs:comment 'Indicates whether the utility provides potable (drinking) water service within this territory.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:predecessorUtilityName rdf:type rdf:Property ;
    rdfs:label 'Predecessor Utility Name' ;
    rdfs:comment 'Name of the previous utility that served this territory before acquisition or transfer, used for historical data lineage.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primacyAgencyJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Primacy Agency Jurisdiction' ;
    rdfs:comment 'State or federal agency with primary regulatory authority over drinking water quality in this territory (e.g., \'California State Water Resources Control Board\').' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateZoneCode rdf:type rdf:Property ;
    rdfs:label 'Rate Zone Code' ;
    rdfs:comment 'Code identifying the rate zone or pricing district applicable to customers in this territory.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recycledWaterServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Recycled Water Service Flag' ;
    rdfs:comment 'Indicates whether the utility provides recycled (reclaimed) water service for non-potable uses within this territory.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Name' ;
    rdfs:comment 'Name of the state or local regulatory body with jurisdiction over rates and service quality in this territory (e.g., \'California Public Utilities Commission\').' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residentialCustomerCount rdf:type rdf:Property ;
    rdfs:label 'Residential Customer Count' ;
    rdfs:comment 'Number of residential customer accounts within the territory.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceCenterLocation rdf:type rdf:Property ;
    rdfs:label 'Service Center Location' ;
    rdfs:comment 'Name or identifier of the primary service center or operations facility serving this territory.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceClassification rdf:type rdf:Property ;
    rdfs:label 'Service Classification' ;
    rdfs:comment 'Geographic and demographic classification of the territory, used for rate design and infrastructure planning.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stormwaterServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Stormwater Service Flag' ;
    rdfs:comment 'Indicates whether the utility provides stormwater management service within this territory.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tariffScheduleReference rdf:type rdf:Property ;
    rdfs:label 'Tariff Schedule Reference' ;
    rdfs:comment 'Reference to the applicable rate tariff schedule approved by the regulatory authority for this territory.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Code' ;
    rdfs:comment 'Externally-known unique code identifying the service territory, used in regulatory filings and franchise agreements.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryName rdf:type rdf:Property ;
    rdfs:label 'Territory Name' ;
    rdfs:comment 'Human-readable name of the service territory (e.g., \'Downtown District\', \'North County Service Area\').' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryStatus rdf:type rdf:Property ;
    rdfs:label 'Territory Status' ;
    rdfs:comment 'Current operational status of the service territory in the utility\'s service portfolio.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryType rdf:type rdf:Property ;
    rdfs:label 'Territory Type' ;
    rdfs:comment 'Classification of the service territory based on regulatory authorization and service delivery model.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wastewaterServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Wastewater Service Flag' ;
    rdfs:comment 'Indicates whether the utility provides wastewater collection and treatment service within this territory.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compliancePercentage rdf:type rdf:Property ;
    rdfs:label 'Compliance Percentage' ;
    rdfs:comment 'Required percentage of time or occurrences that the SLA target must be met to maintain compliance, expressed as a percentage (e.g., 99.5% for high-availability commitments).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationProcedure rdf:type rdf:Property ;
    rdfs:label 'Escalation Procedure' ;
    rdfs:comment 'Defined escalation path or procedure to be followed when the SLA is breached, including management notification, regulatory reporting, and customer communication steps.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionConditions rdf:type rdf:Property ;
    rdfs:label 'Exclusion Conditions' ;
    rdfs:comment 'Conditions or circumstances under which the SLA does not apply or is temporarily suspended, such as force majeure events, natural disasters, regulatory-mandated shutdowns, or customer-requested service interruptions.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'Geographic area or service territory to which this SLA applies: system-wide across all service areas, specific district, pressure zone, District Metered Area (DMA), or specific customer location.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumValue rdf:type rdf:Property ;
    rdfs:label 'Maximum Value' ;
    rdfs:comment 'Maximum acceptable value for the SLA metric, above which the SLA is considered breached. Applicable for metrics with upper bounds such as Maximum Contaminant Level (MCL), turbidity (NTU), or response time.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metricName rdf:type rdf:Property ;
    rdfs:label 'Metric Name' ;
    rdfs:comment 'Specific metric or parameter being measured for this SLA, such as \'Outage Response Time\', \'Service Restoration Time\', \'Minimum Water Pressure (PSI)\', \'Maximum Turbidity (NTU)\', \'pH Range\', \'Maximum Contaminant Level (MCL)\', or \'Notification Time\'.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Value' ;
    rdfs:comment 'Minimum acceptable value for the SLA metric, below which the SLA is considered breached. Applicable for metrics with lower bounds such as minimum water pressure (PSI) or minimum pH.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationRequirement rdf:type rdf:Property ;
    rdfs:label 'Notification Requirement' ;
    rdfs:comment 'Timeframe within which customers or regulatory agencies must be notified of an SLA breach or service issue, such as immediate notification for water quality violations or 24-hour notice for planned outages.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Penalty Calculation Method' ;
    rdfs:comment 'Method used to calculate the penalty or credit: fixed amount per breach, per occurrence, per hour of non-compliance, per day, percentage of customer bill, or tiered based on severity or duration.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyType rdf:type rdf:Property ;
    rdfs:label 'Penalty Type' ;
    rdfs:comment 'Type of penalty or consequence applied when the SLA is breached: customer credit, service rebate, regulatory fine, escalation to management, or no penalty.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaCode rdf:type rdf:Property ;
    rdfs:label 'Sla Code' ;
    rdfs:comment 'Business identifier code for the SLA definition, used for external reference and regulatory tariff filings.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDefinitionDescription rdf:type rdf:Property ;
    rdfs:label 'Sla Definition Description' ;
    rdfs:comment 'Detailed description of the SLA commitment, including the business purpose, customer benefit, and operational context.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDefinitionStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Definition Status' ;
    rdfs:comment 'Current lifecycle status of the SLA definition: active and enforceable, inactive, pending regulatory approval, superseded by a newer version, or temporarily suspended.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaName rdf:type rdf:Property ;
    rdfs:label 'Sla Name' ;
    rdfs:comment 'Human-readable name of the SLA definition, describing the commitment or guarantee.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaType rdf:type rdf:Property ;
    rdfs:label 'Sla Type' ;
    rdfs:comment 'Category of SLA commitment: response time for outage acknowledgment, restoration time for service recovery, water quality guarantee parameters, pressure guarantee thresholds, customer notification requirements, or system availability targets.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'Numeric target or threshold value for the SLA metric, representing the committed performance level or guarantee.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseRatePerUnit rdf:type rdf:Property ;
    rdfs:label 'Base Rate Per Unit' ;
    rdfs:comment 'Negotiated base rate per unit of water (typically per thousand gallons or per cubic meter) under the special contract.' ;
    rdfs:domain ind:SpecialContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingCycle rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle' ;
    rdfs:comment 'Frequency at which the customer is billed under the special contract: monthly, quarterly, annual, or custom.' ;
    rdfs:domain ind:SpecialContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Contract Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the signed contract document stored in the document management system.' ;
    rdfs:domain ind:SpecialContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Duration Months' ;
    rdfs:comment 'Total duration of the contract term expressed in months, used for renewal planning and rate case modeling.' ;
    rdfs:domain ind:SpecialContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractSignedDate rdf:type rdf:Property ;
    rdfs:label 'Contract Signed Date' ;
    rdfs:comment 'Date when the contract was executed and signed by all parties.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractValueTotal rdf:type rdf:Property ;
    rdfs:label 'Contract Value Total' ;
    rdfs:comment 'Estimated total monetary value of the contract over its full term, used for financial planning and revenue forecasting.' ;
    rdfs:domain ind:SpecialContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Demand Charge Amount' ;
    rdfs:comment 'Fixed monthly or periodic demand charge assessed to reserve capacity for the customer, independent of actual consumption.' ;
    rdfs:domain ind:SpecialContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dischargeLimitBodMgPerL rdf:type rdf:Property ;
    rdfs:label 'Discharge Limit Bod Mg Per L' ;
    rdfs:comment 'Maximum allowable BOD concentration in wastewater discharge under the special contract, measured in mg/L.' ;
    rdfs:domain ind:SpecialContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dischargeLimitTssMgPerL rdf:type rdf:Property ;
    rdfs:label 'Discharge Limit Tss Mg Per L' ;
    rdfs:comment 'Maximum allowable TSS concentration in wastewater discharge under the special contract, measured in mg/L.' ;
    rdfs:domain ind:SpecialContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iupComplianceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Iup Compliance Required Flag' ;
    rdfs:comment 'Indicates whether the customer is required to maintain an Industrial User Permit (IUP) and comply with pretreatment requirements as a condition of the contract.' ;
    rdfs:domain ind:SpecialContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumVolumeLimitMgd rdf:type rdf:Property ;
    rdfs:label 'Maximum Volume Limit Mgd' ;
    rdfs:comment 'Maximum daily water volume (in MGD) that the utility agrees to supply under the contract, defining capacity allocation limits.' ;
    rdfs:domain ind:SpecialContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumVolumeCommitmentMgd rdf:type rdf:Property ;
    rdfs:label 'Minimum Volume Commitment Mgd' ;
    rdfs:comment 'Minimum daily water volume (in MGD) that the customer commits to purchase under the contract, used for capacity planning and revenue forecasting.' ;
    rdfs:domain ind:SpecialContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:negotiatedRateStructure rdf:type rdf:Property ;
    rdfs:label 'Negotiated Rate Structure' ;
    rdfs:comment 'Type of rate structure negotiated in the special contract: flat rate, tiered volume, demand charge, time-of-use, seasonal, or custom.' ;
    rdfs:domain ind:SpecialContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Notice Period Days' ;
    rdfs:comment 'Number of days advance notice required by either party to terminate or modify the contract.' ;
    rdfs:domain ind:SpecialContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:penaltyForOverConsumption rdf:type rdf:Property ;
    rdfs:label 'Penalty For Over Consumption' ;
    rdfs:comment 'Financial penalty or surcharge assessed if the customer exceeds the maximum volume limit, typically expressed as a per-unit overage charge.' ;
    rdfs:domain ind:SpecialContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyForUnderConsumption rdf:type rdf:Property ;
    rdfs:label 'Penalty For Under Consumption' ;
    rdfs:comment 'Financial penalty assessed if the customer fails to meet the minimum volume commitment, typically expressed as a fixed amount or per-unit shortfall charge.' ;
    rdfs:domain ind:SpecialContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pretreatmentRequirements rdf:type rdf:Property ;
    rdfs:label 'Pretreatment Requirements' ;
    rdfs:comment 'Detailed description of wastewater pretreatment requirements the customer must meet, including discharge limits for BOD, COD, TSS, TDS, pH, FOG, and other pollutants.' ;
    rdfs:domain ind:SpecialContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Status' ;
    rdfs:comment 'Status of regulatory approval from the Public Utilities Commission or other governing body for this special contract.' ;
    rdfs:domain ind:SpecialContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFilingReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Reference' ;
    rdfs:comment 'Reference number or docket number assigned by the regulatory authority for the special contract filing.' ;
    rdfs:domain ind:SpecialContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalTerms rdf:type rdf:Property ;
    rdfs:label 'Renewal Terms' ;
    rdfs:comment 'Textual description of contract renewal terms, including automatic renewal provisions, notice periods, and renegotiation conditions.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryName rdf:type rdf:Property ;
    rdfs:label 'Signatory Name' ;
    rdfs:comment 'Name of the authorized representative who signed the contract on behalf of the customer.' ;
    rdfs:domain ind:SpecialContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Signatory Title' ;
    rdfs:comment 'Job title or position of the authorized representative who signed the contract on behalf of the customer.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaUptimePercentage rdf:type rdf:Property ;
    rdfs:label 'Sla Uptime Percentage' ;
    rdfs:comment 'Guaranteed service uptime percentage under the SLA, typically expressed as a percentage (e.g., 99.50 for 99.5% uptime).' ;
    rdfs:domain ind:SpecialContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tariffDeviationJustification rdf:type rdf:Property ;
    rdfs:label 'Tariff Deviation Justification' ;
    rdfs:comment 'Business and regulatory justification for deviating from standard published tariff terms, required for regulatory approval.' ;
    rdfs:domain ind:SpecialContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededTariffId rdf:type rdf:Property ;
    rdfs:label 'Superseded Tariff Id' ;
    rdfs:comment 'Reference to the prior tariff that this tariff replaces. Establishes the lineage of rate changes and enables historical rate analysis.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tariff .

ind:adjustmentClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Clause Flag' ;
    rdfs:comment 'Indicates whether the tariff includes automatic adjustment clauses or riders that allow for rate changes without a full rate case. Common adjustment clauses include purchased water adjustment clauses (PWAC), infrastructure surcharges, and cost recovery mechanisms for specific capital programs.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Order Number' ;
    rdfs:comment 'The official order or docket number issued by the regulatory authority approving this tariff. This reference links the tariff to the formal regulatory decision and provides traceability to the rate case proceeding.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conservationRateFlag rdf:type rdf:Property ;
    rdfs:label 'Conservation Rate Flag' ;
    rdfs:comment 'Indicates whether the tariff incorporates conservation-oriented rate design features such as increasing block rates, seasonal pricing, or water budget-based rates intended to promote efficient water use.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costOfServiceStudyReference rdf:type rdf:Property ;
    rdfs:label 'Cost Of Service Study Reference' ;
    rdfs:comment 'Reference to the cost-of-service study or rate design analysis that supports the tariff rates. This study allocates utility costs to customer classes and justifies the rate structure to the regulatory authority.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateOfReturnPercent rdf:type rdf:Property ;
    rdfs:label 'Rate Of Return Percent' ;
    rdfs:comment 'The allowed rate of return on rate base approved by the regulatory authority. Expressed as a decimal percentage (e.g., 0.0725 for 7.25%). This is the weighted average cost of capital (WACC) the utility is permitted to earn.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateScheduleReference rdf:type rdf:Property ;
    rdfs:label 'Rate Schedule Reference' ;
    rdfs:comment 'Reference to the detailed rate schedule document or section number within the tariff filing that specifies the complete pricing structure, including block tiers, surcharges, and adjustments.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRequirementAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Requirement Amount' ;
    rdfs:comment 'The total annual revenue requirement approved by the regulatory authority for the utility under this tariff. This is the aggregate revenue the utility is authorized to collect to cover operating expenses, capital costs, and allowed return on investment.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceRulesReference rdf:type rdf:Property ;
    rdfs:label 'Service Rules Reference' ;
    rdfs:comment 'Reference to the service rules, terms, and conditions document or section number within the tariff filing that governs service delivery, customer obligations, disconnection policies, and dispute resolution procedures.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffDescription rdf:type rdf:Property ;
    rdfs:label 'Tariff Description' ;
    rdfs:comment 'A detailed narrative description of the tariff, including its purpose, scope, applicability, and key terms. This field captures the regulatory intent and business context of the tariff.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffName rdf:type rdf:Property ;
    rdfs:label 'Tariff Name' ;
    rdfs:comment 'The official name or title of the tariff as it appears in regulatory filings and customer communications.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffNumber rdf:type rdf:Property ;
    rdfs:label 'Tariff Number' ;
    rdfs:comment 'The official regulatory tariff number assigned by the Public Utilities Commission or state regulatory authority. This is the externally-known identifier used in all regulatory filings and rate case proceedings.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffStatus rdf:type rdf:Property ;
    rdfs:label 'Tariff Status' ;
    rdfs:comment 'Current lifecycle status of the tariff filing. Draft indicates internal preparation, filed means submitted to the regulator, pending approval is under regulatory review, approved means accepted by the commission, active is currently in force, suspended is temporarily halted, superseded is replaced by a newer tariff, and withdrawn is retracted before approval. [ENUM-REF-CANDIDATE: draft|filed|pending_approval|approved|active|suspended|superseded|withdrawn — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffType rdf:type rdf:Property ;
    rdfs:label 'Tariff Type' ;
    rdfs:comment 'Classification of the tariff based on the customer segment and service arrangement it governs. General service tariffs apply to standard retail customers, special contracts cover negotiated agreements with large users, wholesale tariffs govern bulk water sales to other utilities, and industrial/municipal/residential/commercial designate specific customer classes. [ENUM-REF-CANDIDATE: general_service|special_contract|wholesale|industrial|municipal|residential|commercial — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedVendorListId rdf:type rdf:Property ;
    rdfs:label 'Approved Vendor List Id' ;
    rdfs:comment 'Unique identifier for the approved vendor list entry. Primary key for this registry of pre-qualified vendors authorized to supply specific materials or service categories.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:procurementCategoryId rdf:type rdf:Property ;
    rdfs:label 'Procurement Category Id' ;
    rdfs:comment 'Foreign key linking to supply.procurement_category. Business justification: Vendor approvals are category-specific (e.g., approved for chemicals, not for construction services). Currently uses denormalized material_category_code STRING; should be proper FK to procurement_cate' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcurementCategory .

ind:approvalJustification rdf:type rdf:Property ;
    rdfs:label 'Approval Justification' ;
    rdfs:comment 'Business rationale and supporting documentation summary for why this vendor was approved for the specified category. May reference evaluation scores, past performance, unique capabilities, or sole-source justifications.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Number' ;
    rdfs:comment 'Unique business identifier assigned to this vendor approval record for tracking and audit purposes. Used in procurement compliance reporting.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalType rdf:type rdf:Property ;
    rdfs:label 'Approval Type' ;
    rdfs:comment 'Classification of the approval level. Preferred vendors receive priority consideration; emergency vendors are pre-approved for urgent procurements; conditional approvals have restrictions; trial approvals are temporary for evaluation.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedSpendLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Spend Limit Amount' ;
    rdfs:comment 'The maximum cumulative purchase amount authorized for this vendor in the approved category without requiring additional approval authority. Null indicates no limit. Used to enforce procurement controls and delegation of authority.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedSpendLimitCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Approved Spend Limit Currency Code' ;
    rdfs:comment 'The currency in which the approved spend limit is denominated, using ISO 4217 three-letter currency codes (e.g., USD, CAD, EUR).' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedSpendLimitPeriod rdf:type rdf:Property ;
    rdfs:label 'Approved Spend Limit Period' ;
    rdfs:comment 'The time period over which the approved spend limit applies. Per-transaction limits apply to individual purchase orders; annual limits reset each fiscal year; contract lifetime limits apply to the duration of the approval.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awwaStandardsComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Awwa Standards Compliance Flag' ;
    rdfs:comment 'Indicates whether the vendor supplies materials or services that comply with AWWA standards for water treatment chemicals, pipes, valves, and equipment. Critical for ensuring product quality and regulatory compliance.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalQualificationMetFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Qualification Met Flag' ;
    rdfs:comment 'Indicates whether the vendor has met environmental compliance criteria including EPA permits, waste disposal certifications, and environmental management system standards (ISO 14001). Required for chemical suppliers and waste management vendors.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialQualificationMetFlag rdf:type rdf:Property ;
    rdfs:label 'Financial Qualification Met Flag' ;
    rdfs:comment 'Indicates whether the vendor has met financial stability criteria including credit rating, financial statements review, and bonding capacity. Required for high-value or critical procurements.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceQualificationMetFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Qualification Met Flag' ;
    rdfs:comment 'Indicates whether the vendor maintains required insurance coverage including general liability, professional liability, and workers compensation at levels specified in procurement policy.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPerformanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Performance Review Date' ;
    rdfs:comment 'The date of the most recent formal performance evaluation for this vendor. Used to ensure periodic assessment of vendor performance against service level agreements and quality standards.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:localVendorFlag rdf:type rdf:Property ;
    rdfs:label 'Local Vendor Flag' ;
    rdfs:comment 'Indicates whether the vendor is located within the utility\'s service area or designated local procurement zone. Used to support local economic development and reduce transportation costs and lead times.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minorityOwnedBusinessFlag rdf:type rdf:Property ;
    rdfs:label 'Minority Owned Business Flag' ;
    rdfs:comment 'Indicates whether the vendor is certified as a minority-owned business enterprise. Used to track diversity spend and meet regulatory or policy goals for supplier diversity.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nsfCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Nsf Certification Flag' ;
    rdfs:comment 'Indicates whether the vendor supplies products certified by NSF International for use in drinking water systems. NSF 60 certification is required for treatment chemicals; NSF 61 for materials in contact with drinking water.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceRatingScore rdf:type rdf:Property ;
    rdfs:label 'Performance Rating Score' ;
    rdfs:comment 'Quantitative performance score for this vendor in the approved category, based on delivery timeliness, quality, responsiveness, and compliance. Used for vendor selection and re-qualification decisions. Typically on a scale of 0-100 or 1-5.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualificationDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Date' ;
    rdfs:comment 'The date on which the vendor successfully completed the qualification process and was approved for the specified category. Used to track vendor tenure and re-qualification cycles.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityQualificationMetFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Qualification Met Flag' ;
    rdfs:comment 'Indicates whether the vendor has demonstrated quality management capabilities including ISO 9001 certification, quality control procedures, and product testing protocols. Critical for treatment chemicals and critical spare parts.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reinstatementDate rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Date' ;
    rdfs:comment 'The date on which a previously suspended or revoked vendor approval was reinstated after corrective actions were completed and verified. Null if never suspended or not yet reinstated.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewingAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Reviewing Authority Name' ;
    rdfs:comment 'The name of the individual or committee that reviewed and approved this vendor qualification. Used for accountability and audit trail purposes.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewingAuthorityTitle rdf:type rdf:Property ;
    rdfs:label 'Reviewing Authority Title' ;
    rdfs:comment 'The job title or role of the reviewing authority who approved this vendor qualification (e.g., Procurement Manager, Director of Supply Chain, Vendor Review Committee Chair).' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyQualificationMetFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Qualification Met Flag' ;
    rdfs:comment 'Indicates whether the vendor has met safety requirements including OSHA compliance, safety training records, and incident history review. Mandatory for vendors providing on-site services or hazardous materials.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Service Category Code' ;
    rdfs:comment 'The service category for which this vendor is approved, such as construction, engineering, laboratory testing, or maintenance services. Used when approval is for services rather than materials.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smallBusinessFlag rdf:type rdf:Property ;
    rdfs:label 'Small Business Flag' ;
    rdfs:comment 'Indicates whether the vendor is certified as a small business. Used to track small business spend and meet regulatory requirements for small business participation in public utility procurement.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suspensionDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Date' ;
    rdfs:comment 'The date on which this vendor approval was suspended or revoked. Used to track the duration of suspension and enforce procurement blocks in SAP MM.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'Explanation for why this vendor approval was suspended or revoked, such as performance issues, compliance violations, insurance lapse, or safety incidents. Null when approval status is active.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalQualificationMetFlag rdf:type rdf:Property ;
    rdfs:label 'Technical Qualification Met Flag' ;
    rdfs:comment 'Indicates whether the vendor has demonstrated technical competence for the approved category, including certifications, past performance, and capability assessments. Critical for specialized materials and services.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:womanOwnedBusinessFlag rdf:type rdf:Property ;
    rdfs:label 'Woman Owned Business Flag' ;
    rdfs:comment 'Indicates whether the vendor is certified as a woman-owned business enterprise. Used to track diversity spend and meet regulatory or policy goals for supplier diversity.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Unique identifier for the goods receipt transaction. Primary key for the goods receipt record.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:materialMasterId rdf:type rdf:Property ;
    rdfs:label 'Material Material Master Id' ;
    rdfs:comment 'Reference to the material master record for the item received. Links to chemicals, spare parts, equipment, or other materials.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:poLineItemId rdf:type rdf:Property ;
    rdfs:label 'Po Line Item Id' ;
    rdfs:comment 'Foreign key linking to supply.po_line_item. Business justification: Goods receipts are posted against specific PO line items, not just the header. This is critical for three-way matching (PO line, GR, Invoice) in accounts payable. Currently uses denormalized purchase_' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PoLineItem .

ind:receivingPersonnelEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Receiving Personnel Employee Id' ;
    rdfs:comment 'The employee identifier of the person who received the goods. Links to workforce management systems.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:warehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location Id' ;
    rdfs:comment 'Foreign key linking to supply.warehouse_location. Business justification: Goods receipts post inventory to specific warehouse locations. Currently uses denormalized storage_location_code STRING; should be proper FK to enable location-based inventory tracking and capacity ma' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:deliveryCondition rdf:type rdf:Property ;
    rdfs:label 'Delivery Condition' ;
    rdfs:comment 'The physical condition of the delivered goods at the time of receipt. Good indicates acceptable condition, damaged indicates physical damage, partial indicates incomplete delivery, incorrect indicates wrong items, contaminated indicates quality issues.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Note Number' ;
    rdfs:comment 'The delivery note or packing slip number provided by the vendor at the time of delivery. Used for cross-referencing with vendor documentation.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNotes rdf:type rdf:Property ;
    rdfs:label 'Delivery Notes' ;
    rdfs:comment 'Free-text notes or comments recorded by receiving personnel regarding the delivery. May include observations about packaging, condition, discrepancies, or special handling.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grDocumentDate rdf:type rdf:Property ;
    rdfs:label 'Gr Document Date' ;
    rdfs:comment 'The date on the goods receipt document, typically the date of physical receipt or delivery note date.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Gr Document Number' ;
    rdfs:comment 'The externally-known goods receipt document number generated by the ERP system. Used for tracking and audit purposes.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gr Posting Date' ;
    rdfs:comment 'The date when the goods receipt was posted in the system. This is the principal business event timestamp for inventory valuation and financial accounting.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grStatus rdf:type rdf:Property ;
    rdfs:label 'Gr Status' ;
    rdfs:comment 'Current status of the goods receipt transaction in its lifecycle. Posted indicates successful receipt, reversed indicates cancellation, pending inspection indicates awaiting QC, completed indicates fully processed.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionLotNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Number' ;
    rdfs:comment 'The quality inspection lot number created for this goods receipt if quality inspection is required. Links to quality management records.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Verification Date' ;
    rdfs:comment 'The date when the vendor invoice was verified and matched against this goods receipt. Null if invoice not yet received or verified.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialDocumentYear rdf:type rdf:Property ;
    rdfs:label 'Material Document Year' ;
    rdfs:comment 'The fiscal year in which the goods receipt material document was created. Used as part of the document key in SAP MM.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'SAP movement type code that classifies the type of goods receipt transaction. Common types: 101 (GR for PO), 103 (GR into blocked stock), 105 (GR from release order), 161 (GR for returnable transport packaging), 501 (GR without PO), 511 (GR from delivery without PO). [ENUM-REF-CANDIDATE: 101|103|105|161|501|511|Z01|Z02 — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required Flag' ;
    rdfs:comment 'Indicates whether the received material requires quality inspection before it can be released for use. True if inspection is required, False otherwise.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Received Quantity' ;
    rdfs:comment 'The quantity of material or service received and accepted. Measured in the base unit of measure for the material.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivingPersonnelName rdf:type rdf:Property ;
    rdfs:label 'Receiving Personnel Name' ;
    rdfs:comment 'The name of the warehouse or operations personnel who physically received and verified the goods. Used for accountability and audit purposes.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversal Document Number' ;
    rdfs:comment 'The document number of the reversal transaction if this goods receipt was cancelled. Used for audit trail and reconciliation.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialStockIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Stock Indicator' ;
    rdfs:comment 'Indicator for special stock types such as consignment stock, returnable packaging, or project stock. Blank for standard stock.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockType rdf:type rdf:Property ;
    rdfs:label 'Stock Type' ;
    rdfs:comment 'The type of stock into which the material was received. Unrestricted stock is available for use, quality inspection stock is pending QC, blocked stock is not available, restricted stock has limited use.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'The total value of the goods receipt calculated as received quantity multiplied by unit price. Used for financial posting and invoice verification.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'The price per unit of measure for the received material as per the purchase order. Used for inventory valuation and three-way match.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unloadingPoint rdf:type rdf:Property ;
    rdfs:label 'Unloading Point' ;
    rdfs:comment 'The specific physical location or dock where the goods were unloaded at the facility. Used for logistics tracking and facility management.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationType rdf:type rdf:Property ;
    rdfs:label 'Valuation Type' ;
    rdfs:comment 'The valuation type used for split valuation of materials with different prices or qualities. Used when the same material is valued differently based on source or quality.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Batch Number' ;
    rdfs:comment 'The batch or lot number provided by the vendor on the delivery documentation. Used for vendor traceability and quality issues.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryStockId rdf:type rdf:Property ;
    rdfs:label 'Inventory Stock Id' ;
    rdfs:comment 'Unique identifier for the inventory stock record. Primary key for the inventory stock data product.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Inventory Material Master Id' ;
    rdfs:comment 'FK to supply.material_master' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:primaryInventoryMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Inventory Material Master Id' ;
    rdfs:comment 'Reference to the material master record. Links to the material being stocked (chemicals, spare parts, equipment, consumables).' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:abcIndicator rdf:type rdf:Property ;
    rdfs:label 'Abc Indicator' ;
    rdfs:comment 'ABC classification for inventory management prioritization. A = high-value/critical items requiring tight control; B = moderate-value items; C = low-value items with relaxed controls.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableQuantity rdf:type rdf:Property ;
    rdfs:label 'Available Quantity' ;
    rdfs:comment 'Quantity of material available for new consumption or reservation. Calculated as unrestricted stock minus reserved quantity.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageDailyConsumption rdf:type rdf:Property ;
    rdfs:label 'Average Daily Consumption' ;
    rdfs:comment 'Average quantity consumed per day based on historical usage. Used for demand forecasting and reorder point calculation.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchManagedFlag rdf:type rdf:Property ;
    rdfs:label 'Batch Managed Flag' ;
    rdfs:comment 'Indicates whether this material is managed at the batch level. True for chemicals and materials requiring lot tracking for quality, expiration, or regulatory compliance.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockedStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Blocked Stock Quantity' ;
    rdfs:comment 'Quantity of material blocked from use due to quality issues, expiration, damage, or regulatory hold. Cannot be issued until block is removed.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consignmentStockFlag rdf:type rdf:Property ;
    rdfs:label 'Consignment Stock Flag' ;
    rdfs:comment 'Indicates whether this stock is held on consignment from a vendor. Consignment stock remains vendor-owned until consumed, reducing carrying costs.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cycleCountIndicator rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Indicator' ;
    rdfs:comment 'Frequency classification for cycle counting. A = high-frequency (monthly); B = medium-frequency (quarterly); C = low-frequency (annual); X = excluded from cycle counting.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysOfSupply rdf:type rdf:Property ;
    rdfs:label 'Days Of Supply' ;
    rdfs:comment 'Number of days the current available stock will last based on average daily consumption. Calculated as available quantity divided by average daily consumption.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expirationControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Expiration Controlled Flag' ;
    rdfs:comment 'Indicates whether the material has a limited shelf life and requires expiration date tracking. True for chemicals, reagents, and time-sensitive consumables.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazardousMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Flag' ;
    rdfs:comment 'Indicates whether the material is classified as hazardous and requires special handling, storage, and regulatory compliance (e.g., chlorine gas, sodium hypochlorite, acids).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastGoodsIssueDate rdf:type rdf:Property ;
    rdfs:label 'Last Goods Issue Date' ;
    rdfs:comment 'Date of the most recent goods issue transaction that decreased stock for this material at this location.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastGoodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Last Goods Receipt Date' ;
    rdfs:comment 'Date of the most recent goods receipt transaction that increased stock for this material at this location.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPhysicalInventoryDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Inventory Date' ;
    rdfs:comment 'Date of the most recent physical inventory count for this material at this storage location. Used to track inventory accuracy and compliance with audit requirements.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastStockAdjustmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Stock Adjustment Date' ;
    rdfs:comment 'Date of the most recent manual stock adjustment or inventory correction transaction for this material at this location.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialDescription rdf:type rdf:Property ;
    rdfs:label 'Material Description' ;
    rdfs:comment 'Short text description of the material for identification and reporting purposes.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumStockLevel rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Level' ;
    rdfs:comment 'Maximum quantity to be maintained in stock. Used for inventory optimization and to prevent overstocking of chemicals with limited shelf life or high carrying costs.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mrpType rdf:type rdf:Property ;
    rdfs:label 'Mrp Type' ;
    rdfs:comment 'MRP procedure used for automatic replenishment. PD = MRP; VB = manual reorder point; VM = forecast-based planning; ND = no planning.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantCode rdf:type rdf:Property ;
    rdfs:label 'Plant Code' ;
    rdfs:comment 'Four-character code identifying the plant or facility (e.g., WTP1, WWTP2, DIST).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementType rdf:type rdf:Property ;
    rdfs:label 'Procurement Type' ;
    rdfs:comment 'Indicates how the material is procured. External = purchased from vendors; In-house = manufactured or produced internally; Both = can be procured either way.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Stock Quantity' ;
    rdfs:comment 'Quantity of material currently under quality inspection. Stock is on hold pending laboratory testing or quality assurance approval before release to unrestricted use.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reorderPoint rdf:type rdf:Property ;
    rdfs:label 'Reorder Point' ;
    rdfs:comment 'Minimum stock level that triggers automatic replenishment. When available quantity falls below this threshold, a purchase requisition is generated.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reservedQuantity rdf:type rdf:Property ;
    rdfs:label 'Reserved Quantity' ;
    rdfs:comment 'Quantity of unrestricted stock reserved for specific work orders, maintenance activities, or planned consumption. Reserved stock is committed but not yet issued.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Quantity' ;
    rdfs:comment 'Buffer stock maintained to protect against stockouts due to demand variability or supply delays. Critical for chemicals required for continuous treatment operations.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumberManagedFlag rdf:type rdf:Property ;
    rdfs:label 'Serial Number Managed Flag' ;
    rdfs:comment 'Indicates whether this material is managed at the serial number level. True for high-value equipment and assets requiring individual unit tracking.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stockStatus rdf:type rdf:Property ;
    rdfs:label 'Stock Status' ;
    rdfs:comment 'Current status of stock availability. Derived from comparison of available quantity against reorder point and maximum stock level thresholds.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockTurnoverRatio rdf:type rdf:Property ;
    rdfs:label 'Stock Turnover Ratio' ;
    rdfs:comment 'Number of times inventory is consumed and replenished during a period. Indicates inventory efficiency and demand velocity.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockValueAmount rdf:type rdf:Property ;
    rdfs:label 'Stock Value Amount' ;
    rdfs:comment 'Total monetary value of unrestricted stock at this location. Calculated as unrestricted quantity multiplied by material standard price or moving average price.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'Four-character alphanumeric code identifying the storage location (e.g., WTP chemical storage, WWTP chemical storage, central warehouse, field storeroom).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unrestrictedStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Unrestricted Stock Quantity' ;
    rdfs:comment 'Quantity of material available for unrestricted use. This stock is available for consumption, transfer, or issue to work orders and operations.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Valuation Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for stock valuation (e.g., USD for United States Dollar).' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Base Unit Of Measure' ;
    rdfs:comment 'Primary unit of measure for inventory management and procurement. Common units: EA (each), LB (pounds), GAL (gallons), KG (kilograms), L (liters), M (meters), FT (feet), M3 (cubic meters), CF (cubic feet), TON (tons), BOX, DRUM, PAIL. [ENUM-REF-CANDIDATE: EA|LB|GAL|KG|L|M|FT|M3|CF|TON|BOX|DRUM|PAIL — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalSpareFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Spare Flag' ;
    rdfs:comment 'Indicates whether the material is a critical spare part required for emergency repairs of high-criticality assets (pumps, motors, valves, SCADA components). True for items with long lead times or single-source suppliers.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discontinuedDate rdf:type rdf:Property ;
    rdfs:label 'Discontinued Date' ;
    rdfs:comment 'Date when the material was marked as obsolete or phased out. Used for lifecycle management and historical procurement analysis.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hazmatClass rdf:type rdf:Property ;
    rdfs:label 'Hazmat Class' ;
    rdfs:comment 'DOT hazard class for transportation and storage (e.g., Class 2.3 Toxic Gas for chlorine, Class 8 Corrosive for caustic soda). Required for hazardous materials only.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Issue Unit Of Measure' ;
    rdfs:comment 'Unit of measure used when issuing materials from warehouse to work orders, maintenance activities, or treatment operations. [ENUM-REF-CANDIDATE: EA|LB|GAL|KG|L|M|FT|M3|CF|TON|BOX|DRUM|PAIL — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Part Number' ;
    rdfs:comment 'Manufacturers unique part number or catalog identifier. Critical for cross-referencing spare parts, ensuring correct replacements, and warranty claims.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialGroup rdf:type rdf:Property ;
    rdfs:label 'Material Group' ;
    rdfs:comment 'Hierarchical classification grouping materials by procurement category (e.g., water treatment chemicals, mechanical spares, electrical components, pipe fittings, meters, PPE). Used for purchasing analytics and vendor management.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialNumber rdf:type rdf:Property ;
    rdfs:label 'Material Number' ;
    rdfs:comment 'Externally-known unique material identifier used across procurement, inventory, and operations. Aligns with SAP MM material number format.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialStatus rdf:type rdf:Property ;
    rdfs:label 'Material Status' ;
    rdfs:comment 'Current lifecycle status of the material in the catalog. Active materials are available for procurement and use; obsolete materials are retained for historical reference only.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Quantity' ;
    rdfs:comment 'Maximum inventory level for the material. Used to prevent overstocking and optimize warehouse space utilization.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumRemainingShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Minimum Remaining Shelf Life Days' ;
    rdfs:comment 'Minimum acceptable remaining shelf life at time of goods receipt. Materials received with less remaining shelf life are rejected or flagged for immediate use.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:movingAveragePrice rdf:type rdf:Property ;
    rdfs:label 'Moving Average Price' ;
    rdfs:comment 'Continuously updated average unit cost based on actual procurement transactions. Used for materials with price volatility (chemicals, fuel, metals).' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceUnit rdf:type rdf:Property ;
    rdfs:label 'Price Unit' ;
    rdfs:comment 'Quantity unit for which the price is specified (e.g., price per 1, per 100, per 1000). Used when materials are priced in bulk quantities.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:purchaseUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Purchase Unit Of Measure' ;
    rdfs:comment 'Unit of measure used for procurement transactions and purchase orders. May differ from base UOM for bulk chemical purchases. [ENUM-REF-CANDIDATE: EA|LB|GAL|KG|L|M|FT|M3|CF|TON|BOX|DRUM|PAIL — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serializedFlag rdf:type rdf:Property ;
    rdfs:label 'Serialized Flag' ;
    rdfs:comment 'Indicates whether individual units of this material are tracked by unique serial numbers. True for high-value equipment, meters, and assets requiring individual lifecycle tracking.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'Maximum number of days the material remains usable from receipt date. Critical for chemicals with expiration dates (polymers, coagulants) and perishable consumables.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shortDescription rdf:type rdf:Property ;
    rdfs:label 'Short Description' ;
    rdfs:comment 'Abbreviated material description for display in transaction screens, purchase orders, and inventory reports.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardPrice rdf:type rdf:Property ;
    rdfs:label 'Standard Price' ;
    rdfs:comment 'Standard unit cost used for inventory valuation and cost accounting. Updated periodically based on procurement history and market conditions.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageCondition rdf:type rdf:Property ;
    rdfs:label 'Storage Condition' ;
    rdfs:comment 'Required storage conditions for the material including temperature range, humidity control, ventilation requirements, and segregation rules. Critical for chemicals and temperature-sensitive spare parts.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unNumber rdf:type rdf:Property ;
    rdfs:label 'Un Number' ;
    rdfs:comment 'Four-digit UN identification number for hazardous materials used in international shipping and regulatory compliance (e.g., UN1017 for chlorine gas).' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationClass rdf:type rdf:Property ;
    rdfs:label 'Valuation Class' ;
    rdfs:comment 'Four-digit code linking material to general ledger accounts for inventory valuation, cost of goods sold, and procurement expense posting.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deletedFlag rdf:type rdf:Property ;
    rdfs:label 'Deleted Flag' ;
    rdfs:comment 'Indicates whether the reservation has been marked for deletion. Deleted reservations are retained for audit purposes but excluded from active processing.' ;
    rdfs:domain ind:MaterialRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:finalIssueFlag rdf:type rdf:Property ;
    rdfs:label 'Final Issue Flag' ;
    rdfs:comment 'Indicates whether the reservation is marked for final issue. When true, no further material withdrawals are expected and the reservation can be closed.' ;
    rdfs:domain ind:MaterialRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuedBy rdf:type rdf:Property ;
    rdfs:label 'Issued By' ;
    rdfs:comment 'Name or identifier of the warehouse personnel who fulfilled the requisition and issued the material. Null if not yet issued.' ;
    rdfs:domain ind:MaterialRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuedQuantity rdf:type rdf:Property ;
    rdfs:label 'Issued Quantity' ;
    rdfs:comment 'Quantity of material actually issued from warehouse to fulfill this requisition. May differ from requested quantity due to stock availability or adjustments.' ;
    rdfs:domain ind:MaterialRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Material Document Number' ;
    rdfs:comment 'Material document number generated upon goods issue. Links the requisition to the actual inventory transaction in SAP MM.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingQuantity rdf:type rdf:Property ;
    rdfs:label 'Outstanding Quantity' ;
    rdfs:comment 'Remaining quantity yet to be issued. Calculated as requested quantity minus issued quantity.' ;
    rdfs:domain ind:MaterialRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedQuantity rdf:type rdf:Property ;
    rdfs:label 'Requested Quantity' ;
    rdfs:comment 'Quantity of material requested for reservation. Original demand quantity before any adjustments or partial issues.' ;
    rdfs:domain ind:MaterialRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestingDepartment rdf:type rdf:Property ;
    rdfs:label 'Requesting Department' ;
    rdfs:comment 'Department or organizational unit that initiated the material requisition. Typically the maintenance, operations, or project team.' ;
    rdfs:domain ind:MaterialRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredDate rdf:type rdf:Property ;
    rdfs:label 'Required Date' ;
    rdfs:comment 'Date by which the material is needed to support the work order or operation. Drives warehouse picking and fulfillment priority.' ;
    rdfs:domain ind:MaterialRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Requisition Status' ;
    rdfs:comment 'Current lifecycle status of the material requisition: open (not yet fulfilled), partially issued (some materials released), fully issued (complete), cancelled, or closed.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionType rdf:type rdf:Property ;
    rdfs:label 'Requisition Type' ;
    rdfs:comment 'Classification of the requisition based on its purpose: maintenance work, treatment operations, capital improvement program, emergency response, or planned activity.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationDate rdf:type rdf:Property ;
    rdfs:label 'Reservation Date' ;
    rdfs:comment 'Date when the material reservation was created in the system. Represents the business event timestamp for demand registration.' ;
    rdfs:domain ind:MaterialRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reservationItemNumber rdf:type rdf:Property ;
    rdfs:label 'Reservation Item Number' ;
    rdfs:comment 'Line item number within the reservation document. Identifies individual material line within a multi-line reservation.' ;
    rdfs:domain ind:MaterialRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationNumber rdf:type rdf:Property ;
    rdfs:label 'Reservation Number' ;
    rdfs:comment 'Business identifier for the material reservation in the source system. Externally-known unique code for tracking and reference.' ;
    rdfs:domain ind:MaterialRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseLocation rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location' ;
    rdfs:comment 'Warehouse or storage location from which the material will be issued. Identifies the physical inventory source.' ;
    rdfs:domain ind:MaterialRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPoMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Po Material Master Id' ;
    rdfs:comment 'Foreign key reference to the material master record being procured. Identifies the specific chemical, spare part, equipment, or service item.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:purchaseRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Purchase Requisition Id' ;
    rdfs:comment 'Foreign key linking to supply.purchase_requisition. Business justification: PO line items are created FROM purchase requisition line items in the procurement workflow. This traces each PO line back to the originating business need for audit and requirement fulfillment trackin' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseRequisition .

ind:confirmationControlKey rdf:type rdf:Property ;
    rdfs:label 'Confirmation Control Key' ;
    rdfs:comment 'Control key determining whether and how vendor confirmations (order acknowledgments, shipping notifications) are required for this line item. Used for supply chain visibility and delivery tracking.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deletionIndicator rdf:type rdf:Property ;
    rdfs:label 'Deletion Indicator' ;
    rdfs:comment 'Flag indicating whether this line item has been marked for deletion. Deleted line items are excluded from further processing but retained for audit trail.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'Requested or committed delivery date for this line item. Critical for chemical inventory management and project scheduling in Capital Improvement Program (CIP) and Operations and Maintenance (O&M) activities.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current delivery fulfillment status of this line item. Tracks progress from order placement through complete goods receipt.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptIndicator rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Indicator' ;
    rdfs:comment 'Flag indicating whether a goods receipt is required for this line item. True for materials requiring physical receipt confirmation; false for services or non-stock items.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptQuantity rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Quantity' ;
    rdfs:comment 'Cumulative quantity of goods received against this line item to date. Updated as goods receipts are posted. Used to track delivery fulfillment and outstanding quantities.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceQuantity rdf:type rdf:Property ;
    rdfs:label 'Invoice Quantity' ;
    rdfs:comment 'Cumulative quantity invoiced against this line item to date. Used for invoice verification and to identify discrepancies between ordered, received, and invoiced quantities.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceReceiptIndicator rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Indicator' ;
    rdfs:comment 'Flag indicating whether an invoice is expected for this line item. Used to control invoice verification and three-way matching (PO, goods receipt, invoice) in accounts payable processing.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemCategory rdf:type rdf:Property ;
    rdfs:label 'Item Category' ;
    rdfs:comment 'Classification of the procurement line item type. Determines procurement processing rules, inventory treatment, and account assignment behavior.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netOrderValue rdf:type rdf:Property ;
    rdfs:label 'Net Order Value' ;
    rdfs:comment 'Total net value for this line item, calculated as quantity_ordered multiplied by net_price, adjusted for price_unit. Excludes taxes.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPrice rdf:type rdf:Property ;
    rdfs:label 'Net Price' ;
    rdfs:comment 'Net price per unit of measure for this line item, excluding taxes and discounts. Used to calculate line item total value.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overDeliveryTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Over Delivery Tolerance Percent' ;
    rdfs:comment 'Allowable percentage by which the vendor may over-deliver beyond the ordered quantity without requiring approval. Expressed as a percentage (e.g., 5.00 for 5%).' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseRequisitionItem rdf:type rdf:Property ;
    rdfs:label 'Purchase Requisition Item' ;
    rdfs:comment 'Line item number within the source purchase requisition. Used in conjunction with purchase_requisition_number for complete requisition-to-PO traceability.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:purchasingGroup rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group' ;
    rdfs:comment 'Three-character code identifying the buyer or purchasing team responsible for this procurement. Used for workload distribution and buyer performance tracking.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityOrdered rdf:type rdf:Property ;
    rdfs:label 'Quantity Ordered' ;
    rdfs:comment 'Quantity of material or service ordered on this line item. Expressed in the unit of measure specified for this line.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shortText rdf:type rdf:Property ;
    rdfs:label 'Short Text' ;
    rdfs:comment 'Brief description of the material or service being procured on this line. Provides human-readable context for the line item, especially useful for non-stock materials or services.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underDeliveryTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Under Delivery Tolerance Percent' ;
    rdfs:comment 'Allowable percentage by which the vendor may under-deliver below the ordered quantity without penalty. Expressed as a percentage (e.g., 2.00 for 2%).' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Material Number' ;
    rdfs:comment 'Vendor\'s own material or catalog number for the item being procured. Used for cross-reference and to ensure correct item is supplied, especially critical for chemical procurement (chlorine, coagulants, polymers, fluoride).' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Category Manager Employee Id' ;
    rdfs:comment 'Employee identifier for the procurement professional responsible for managing sourcing strategy, supplier relationships, and spend optimization for this category.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:parentCategoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Category Id' ;
    rdfs:comment 'Reference to the parent category in the hierarchical taxonomy. Null for top-level categories.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcurementCategory .

ind:annualSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Spend Amount' ;
    rdfs:comment 'Total annual procurement spend for this category in the most recent fiscal year, used for spend analytics and sourcing prioritization.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Average Lead Time Days' ;
    rdfs:comment 'Typical procurement lead time in days for items in this category, used for materials planning and inventory management.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetCode rdf:type rdf:Property ;
    rdfs:label 'Budget Code' ;
    rdfs:comment 'Default budget or cost center code for purchases in this category, used for financial planning and cost allocation.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Capital Eligible Flag' ;
    rdfs:comment 'Indicates whether purchases in this category are eligible for capitalization under GAAP or GASB accounting standards as part of Capital Improvement Program (CIP) expenditures.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capitalVsOpexClassification rdf:type rdf:Property ;
    rdfs:label 'Capital Vs Opex Classification' ;
    rdfs:comment 'Accounting classification indicating whether purchases in this category are typically capitalized as assets or expensed as operations and maintenance costs.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the procurement category. Used for classification and reporting purposes.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryDescription rdf:type rdf:Property ;
    rdfs:label 'Category Description' ;
    rdfs:comment 'Detailed description of the goods and services included in this procurement category, including scope and boundaries.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryLevel rdf:type rdf:Property ;
    rdfs:label 'Category Level' ;
    rdfs:comment 'Hierarchical level of the category in the taxonomy tree. Level 1 is top-level, increasing numbers represent deeper nesting.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:categoryName rdf:type rdf:Property ;
    rdfs:label 'Category Name' ;
    rdfs:comment 'Full descriptive name of the procurement category. Human-readable label for the category.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryStatus rdf:type rdf:Property ;
    rdfs:label 'Category Status' ;
    rdfs:comment 'Current lifecycle status of the procurement category. Active categories are available for use in requisitions and purchase orders.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryType rdf:type rdf:Property ;
    rdfs:label 'Category Type' ;
    rdfs:comment 'High-level classification of the procurement category distinguishing between materials, services, chemicals, equipment, utilities, and professional services.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chemicalCategoryFlag rdf:type rdf:Property ;
    rdfs:label 'Chemical Category Flag' ;
    rdfs:comment 'Indicates whether this category includes water or wastewater treatment chemicals (chlorine, coagulants, polymers, fluoride, etc.) requiring specialized procurement and inventory management.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commodityCode rdf:type rdf:Property ;
    rdfs:label 'Commodity Code' ;
    rdfs:comment 'Standard commodity classification code aligned with NIGP (National Institute of Governmental Purchasing) or UNSPSC (United Nations Standard Products and Services Code) for procurement standardization.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityGroup rdf:type rdf:Property ;
    rdfs:label 'Commodity Group' ;
    rdfs:comment 'High-level commodity grouping for the category. Aligns with water utility operational needs including treatment chemicals, infrastructure components, and support services.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveBidRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Competitive Bid Required Flag' ;
    rdfs:comment 'Indicates whether purchases in this category require competitive bidding process per procurement regulations and internal policy.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competitiveBiddingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Competitive Bidding Required Flag' ;
    rdfs:comment 'Indicates whether purchases in this category require competitive bidding or request for quotation (RFQ) processes per regulatory or organizational procurement policies.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Contract Required Flag' ;
    rdfs:comment 'Indicates whether purchases in this category must be made under an established contract or blanket purchase agreement.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defaultLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Default Lead Time Days' ;
    rdfs:comment 'Standard procurement lead time in days for items in this category, used for materials planning and inventory replenishment calculations.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:diversityPreferenceFlag rdf:type rdf:Property ;
    rdfs:label 'Diversity Preference Flag' ;
    rdfs:comment 'Indicates whether this procurement category has organizational or regulatory preferences for minority-owned, woman-owned, or small business enterprise (MBE/WBE/SBE) vendors.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalComplianceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Required Flag' ;
    rdfs:comment 'Indicates whether procurement in this category requires environmental compliance certifications or assessments (e.g., ISO 14001, EPA environmental standards).' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazardousMaterialCategoryFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Category Flag' ;
    rdfs:comment 'Indicates whether this category includes hazardous materials requiring special handling, storage, and regulatory compliance per OSHA and EPA standards.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Flag' ;
    rdfs:comment 'Indicates whether materials in this category are classified as hazardous materials requiring special handling, storage, and regulatory compliance per OSHA and EPA standards.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceRequirementDescription rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirement Description' ;
    rdfs:comment 'Description of insurance coverage requirements for vendors supplying goods or services in this category, including liability limits and coverage types.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryManagedFlag rdf:type rdf:Property ;
    rdfs:label 'Inventory Managed Flag' ;
    rdfs:comment 'Indicates whether items in this category are tracked in inventory management systems and subject to stock level monitoring, reorder points, and cycle counting.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localPreferenceFlag rdf:type rdf:Property ;
    rdfs:label 'Local Preference Flag' ;
    rdfs:comment 'Indicates whether this category has a local sourcing preference to support regional economic development and reduce supply chain risk.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialGroupCode rdf:type rdf:Property ;
    rdfs:label 'Material Group Code' ;
    rdfs:comment 'SAP MM material group code for integration with enterprise resource planning systems. Used for procurement planning and materials management.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumOrderThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Threshold Amount' ;
    rdfs:comment 'Minimum dollar value threshold for purchase orders in this category. Orders below this threshold may require different approval workflows or procurement methods.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumOrderValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Value' ;
    rdfs:comment 'Minimum dollar threshold for purchase orders in this category, used to enforce procurement policy and prevent maverick spending.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minorityBusinessEnterpriseGoalPercent rdf:type rdf:Property ;
    rdfs:label 'Minority Business Enterprise Goal Percent' ;
    rdfs:comment 'Target percentage of spend in this category to be directed to certified minority-owned businesses to support supplier diversity objectives.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nsfCertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Nsf Certification Required Flag' ;
    rdfs:comment 'Indicates whether materials in this category require NSF/ANSI 60 or NSF/ANSI 61 certification for use in drinking water systems per EPA and state drinking water program requirements.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredSourcingStrategy rdf:type rdf:Property ;
    rdfs:label 'Preferred Sourcing Strategy' ;
    rdfs:comment 'Recommended procurement approach for this category based on market dynamics, risk profile, and spend characteristics.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementCategoryStatus rdf:type rdf:Property ;
    rdfs:label 'Procurement Category Status' ;
    rdfs:comment 'Current lifecycle status of the procurement category indicating whether it is actively used for procurement operations.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingGroupCode rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group Code' ;
    rdfs:comment 'Code identifying the purchasing group or buyer team responsible for procuring items in this category.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Certification Required' ;
    rdfs:comment 'Industry or regulatory quality certifications required for suppliers in this category, such as ISO 9001, NSF/ANSI 60/61 for water treatment chemicals, or AWWA standards.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleBuyerEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Buyer Email' ;
    rdfs:comment 'Email address of the procurement specialist responsible for this category for vendor inquiries and procurement coordination.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleBuyerName rdf:type rdf:Property ;
    rdfs:label 'Responsible Buyer Name' ;
    rdfs:comment 'Name of the procurement specialist or buyer responsible for managing vendor relationships and purchase orders for this category.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendVisibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Spend Visibility Flag' ;
    rdfs:comment 'Indicates whether this category is included in executive spend analytics dashboards and strategic sourcing reviews.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Standard Unit Of Measure' ;
    rdfs:comment 'Default unit of measure for procurement and inventory tracking of items in this category (e.g., EA, LB, GAL, FT, TON).' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicCategoryFlag rdf:type rdf:Property ;
    rdfs:label 'Strategic Category Flag' ;
    rdfs:comment 'Indicates whether this category is designated as strategic for the utility, requiring enhanced sourcing governance and supplier relationship management.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unspscCode rdf:type rdf:Property ;
    rdfs:label 'Unspsc Code' ;
    rdfs:comment 'Eight-digit UNSPSC classification code for global procurement standardization and spend analytics.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unspscDescription rdf:type rdf:Property ;
    rdfs:label 'Unspsc Description' ;
    rdfs:comment 'Descriptive label corresponding to the UNSPSC code for reference and validation purposes.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:womanBusinessEnterpriseGoalPercent rdf:type rdf:Property ;
    rdfs:label 'Woman Business Enterprise Goal Percent' ;
    rdfs:comment 'Target percentage of spend in this category to be directed to certified woman-owned businesses to support supplier diversity objectives.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commodityCategory rdf:type rdf:Property ;
    rdfs:label 'Commodity Category' ;
    rdfs:comment 'High-level classification of the goods or services covered by this contract. Chemicals include chlorine, coagulants, polymers, fluoride, and other treatment chemicals. Other categories support infrastructure maintenance, capital projects, and operations. [ENUM-REF-CANDIDATE: chemicals|pipes_fittings|pumps_motors|valves_actuators|meters_instrumentation|electrical_components|laboratory_supplies|vehicles_equipment|professional_services|maintenance_services — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Contract Approval Date' ;
    rdfs:comment 'The date on which the contract was formally approved by the authorized signatory or approval authority, such as the procurement director, CFO, or board of directors for high-value contracts.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Contract Document Url' ;
    rdfs:comment 'The file path or URL to the signed contract document stored in the document management system or contract repository. Enables quick access to the full legal agreement for review and audit purposes.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractOwner rdf:type rdf:Property ;
    rdfs:label 'Contract Owner' ;
    rdfs:comment 'The name or identifier of the procurement professional or contract manager responsible for administering this contract, including renewals, amendments, and vendor performance monitoring.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLocation rdf:type rdf:Property ;
    rdfs:label 'Delivery Location' ;
    rdfs:comment 'The default delivery destination for goods or services under this contract, typically a Water Treatment Plant (WTP), Wastewater Treatment Plant (WWTP), warehouse, or central receiving facility. May reference a facility code or address.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTerms rdf:type rdf:Property ;
    rdfs:label 'Delivery Terms' ;
    rdfs:comment 'International Commercial Terms (Incoterms) defining the responsibilities for shipping, insurance, and risk transfer. FOB (Free On Board), CIF (Cost Insurance Freight), DDP (Delivered Duty Paid), EXW (Ex Works), and FCA (Free Carrier) are common in chemical and materials procurement.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequirements rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirements' ;
    rdfs:comment 'Description of the insurance coverage the vendor must maintain, including general liability, product liability, workers compensation, and environmental liability. Specifies minimum coverage amounts and certificate of insurance requirements.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minorityBusinessEnterprise rdf:type rdf:Property ;
    rdfs:label 'Minority Business Enterprise' ;
    rdfs:comment 'Indicates whether the vendor is certified as a Minority Business Enterprise, supporting diversity and inclusion goals in procurement. Used for compliance reporting and supplier diversity tracking.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceClause rdf:type rdf:Property ;
    rdfs:label 'Performance Clause' ;
    rdfs:comment 'Description of performance standards, service level agreements (SLAs), quality requirements, and penalties or incentives tied to vendor performance. May include delivery time commitments, product quality specifications, and response time requirements for emergency chemical deliveries.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceEscalationClause rdf:type rdf:Property ;
    rdfs:label 'Price Escalation Clause' ;
    rdfs:comment 'Details of any provisions allowing the vendor to adjust prices during the contract term, including triggers (e.g., CPI increases, raw material cost changes), frequency of adjustments, and caps on increases. Critical for budget forecasting and OPEX management.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingCondition rdf:type rdf:Property ;
    rdfs:label 'Pricing Condition' ;
    rdfs:comment 'The pricing structure defined in the contract. Fixed price remains constant, variable price adjusts based on market conditions or volume, cost-plus adds a markup to vendor costs, index-linked ties pricing to a commodity index, and tiered pricing offers volume discounts.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrganization rdf:type rdf:Property ;
    rdfs:label 'Purchasing Organization' ;
    rdfs:comment 'The organizational unit responsible for negotiating and managing this contract. In multi-site utilities, different purchasing organizations may handle different regions or commodity categories.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingContractValue rdf:type rdf:Property ;
    rdfs:label 'Remaining Contract Value' ;
    rdfs:comment 'The remaining monetary value available for future releases under this contract, calculated as total contract value minus total released value. Used for budget planning and procurement decision-making.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:smallBusinessEnterprise rdf:type rdf:Property ;
    rdfs:label 'Small Business Enterprise' ;
    rdfs:comment 'Indicates whether the vendor is certified as a Small Business Enterprise, supporting local economic development and small business participation goals. Used for compliance reporting and procurement policy adherence.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationClause rdf:type rdf:Property ;
    rdfs:label 'Termination Clause' ;
    rdfs:comment 'Summary of the conditions under which either party may terminate the contract early, including notice periods, penalties, and force majeure provisions. Important for risk management and vendor relationship governance.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalContractValue rdf:type rdf:Property ;
    rdfs:label 'Total Contract Value' ;
    rdfs:comment 'The maximum monetary value committed under this contract for value contracts, or the estimated total spend for quantity and framework agreements. Used for budget tracking and OPEX (Operating Expenditure) or CAPEX (Capital Expenditure) allocation. Currency is USD unless otherwise specified in contract terms.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalReleasedQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Released Quantity' ;
    rdfs:comment 'The cumulative quantity of goods or services released against this contract to date, measured in the contract\'s unit of measure. Used to track contract utilization for quantity contracts.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalReleasedValue rdf:type rdf:Property ;
    rdfs:label 'Total Released Value' ;
    rdfs:comment 'The cumulative monetary value of all purchase orders or releases issued against this contract to date. Used to track contract utilization and remaining available value for value contracts.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipToWarehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Ship To Warehouse Location Id' ;
    rdfs:comment 'Foreign key linking to supply.warehouse_location. Business justification: Purchase orders specify delivery location. Currently uses denormalized ship_to_location_code STRING; should be proper FK to warehouse_location. Label prefix \'ship_to_\' distinguishes this from other po' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:buyerEmail rdf:type rdf:Property ;
    rdfs:label 'Buyer Email' ;
    rdfs:comment 'Email address of the procurement buyer for vendor communication and order inquiries.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerPhone rdf:type rdf:Property ;
    rdfs:label 'Buyer Phone' ;
    rdfs:comment 'Contact phone number of the procurement buyer.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line1' ;
    rdfs:comment 'Primary street address line for delivery location. May be Water Treatment Plant (WTP), Wastewater Treatment Plant (WWTP), warehouse, or field site.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line2' ;
    rdfs:comment 'Secondary address line for delivery location (building, suite, department).' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCity rdf:type rdf:Property ;
    rdfs:label 'Delivery City' ;
    rdfs:comment 'City name for the delivery location.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the delivery location.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPostalCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the delivery location.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryState rdf:type rdf:Property ;
    rdfs:label 'Delivery State' ;
    rdfs:comment 'Two-letter state or province code for the delivery location.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Amount' ;
    rdfs:comment 'Shipping and freight charges associated with this purchase order. May be included in line items or as separate charge.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incoterms rdf:type rdf:Property ;
    rdfs:label 'Incoterms' ;
    rdfs:comment 'International Commercial Terms defining the responsibilities of buyer and seller for shipping, insurance, and risk transfer. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCapitalPurchase rdf:type rdf:Property ;
    rdfs:label 'Is Capital Purchase' ;
    rdfs:comment 'Indicates whether this purchase order is for capital assets (CAPEX) versus operating expenses (OPEX). True for Capital Improvement Program (CIP) purchases.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:poDate rdf:type rdf:Property ;
    rdfs:label 'Po Date' ;
    rdfs:comment 'Date when the purchase order was created or issued. Principal business event timestamp for procurement tracking.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'Externally-known business identifier for the purchase order. Unique document number used in vendor communications and invoice matching.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poStatus rdf:type rdf:Property ;
    rdfs:label 'Po Status' ;
    rdfs:comment 'Current lifecycle state of the purchase order. Tracks progression from creation through approval, issuance, receipt, and closure. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|issued|partially_received|fully_received|closed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poType rdf:type rdf:Property ;
    rdfs:label 'Po Type' ;
    rdfs:comment 'Classification of the purchase order by procurement category. Standard for one-time purchases, blanket for recurring, contract for long-term agreements, emergency for urgent needs, capital for Capital Improvement Program (CIP) assets, service for professional services.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promisedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Promised Delivery Date' ;
    rdfs:comment 'Date confirmed by the vendor for delivery. May differ from requested date based on vendor capacity and lead time.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'Date by which the buyer requests delivery of goods or completion of services. Used for planning and vendor performance tracking.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalAmountWithTax rdf:type rdf:Property ;
    rdfs:label 'Total Amount With Tax' ;
    rdfs:comment 'Grand total of the purchase order including base amount, taxes, and freight. Represents total financial commitment.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorSiteCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Site Code' ;
    rdfs:comment 'Specific vendor location or site code for delivery and invoicing purposes. Used when vendor has multiple facilities.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPurchaseRequisitionerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Purchase Requisitioner Employee Id' ;
    rdfs:comment 'Employee identifier of the person who created or submitted the requisition. Used for accountability and audit trail.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:estimatedTotalValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Value' ;
    rdfs:comment 'Total estimated value of the requisition (quantity × estimated unit price), used for financial approval routing.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Estimated Unit Price' ;
    rdfs:comment 'Estimated price per unit of the requested material or service, used for budget planning and approval thresholds.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRequested rdf:type rdf:Property ;
    rdfs:label 'Quantity Requested' ;
    rdfs:comment 'Quantity of material or service units requested in the requisition.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestingPlantCode rdf:type rdf:Property ;
    rdfs:label 'Requesting Plant Code' ;
    rdfs:comment 'Plant or facility code where the materials or services are required. Corresponds to Water Treatment Plant (WTP) or Wastewater Treatment Plant (WWTP) location.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Requesting Storage Location' ;
    rdfs:comment 'Storage location or warehouse code within the plant where materials should be delivered.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Required Delivery Date' ;
    rdfs:comment 'Date by which the requested materials or services must be delivered to meet operational or project needs.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionDate rdf:type rdf:Property ;
    rdfs:label 'Requisition Date' ;
    rdfs:comment 'Date when the purchase requisition was created or submitted by the requesting department.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Requisition Number' ;
    rdfs:comment 'Business identifier for the purchase requisition, externally visible and used in procurement workflows. Corresponds to SAP BANF number.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Code' ;
    rdfs:comment 'Preferred or suggested vendor code for the procurement. May be populated if the requisitioner has a specific supplier in mind.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqId rdf:type rdf:Property ;
    rdfs:label 'Rfq Id' ;
    rdfs:comment 'Unique identifier for the request for quotation record. Primary key.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:awardedVendorId rdf:type rdf:Property ;
    rdfs:label 'Awarded Vendor Id' ;
    rdfs:comment 'Reference to the vendor selected and awarded the contract resulting from this RFQ. Populated when rfq_status = \'awarded\'. Links to supply.vendor.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:awardedAmount rdf:type rdf:Property ;
    rdfs:label 'Awarded Amount' ;
    rdfs:comment 'Total contract value or purchase order amount awarded to the selected vendor. Confidential business data.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awardedDate rdf:type rdf:Property ;
    rdfs:label 'Awarded Date' ;
    rdfs:comment 'Date the RFQ was awarded to the selected vendor and purchase order was issued or contract was executed.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bondingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Bonding Required Flag' ;
    rdfs:comment 'Indicates whether vendors must provide bid bonds, performance bonds, or payment bonds. Common for construction and large equipment procurements. True if bonding is required.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closingTime rdf:type rdf:Property ;
    rdfs:label 'Closing Time' ;
    rdfs:comment 'Precise timestamp (date and time) when the RFQ closes for quote submissions. Used when exact time matters for competitive bidding.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:competitiveBiddingFlag rdf:type rdf:Property ;
    rdfs:label 'Competitive Bidding Flag' ;
    rdfs:comment 'Indicates whether this RFQ is part of a formal competitive bidding process requiring multiple vendor quotes. True if competitive bidding is required, False if sole-source or limited competition.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryRequiredDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Required Date' ;
    rdfs:comment 'Target date by which the materials or services must be delivered or completed. Critical for operational planning and vendor evaluation.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Budget Amount' ;
    rdfs:comment 'Internal estimated budget or cost target for this procurement. Typically not disclosed to vendors but used for internal approval and evaluation. Confidential business data.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationCriteria rdf:type rdf:Property ;
    rdfs:label 'Evaluation Criteria' ;
    rdfs:comment 'Criteria and weighting factors used to evaluate and compare vendor quotations (e.g., \'Price 50%, Delivery Time 20%, Quality 20%, Vendor Experience 10%\'). Ensures transparent and objective vendor selection.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generalLedgerAccount rdf:type rdf:Property ;
    rdfs:label 'General Ledger Account' ;
    rdfs:comment 'General ledger account code to which the procurement cost will be charged. Used for financial accounting and expense classification (OPEX vs CAPEX).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Required Flag' ;
    rdfs:comment 'Indicates whether vendors must provide proof of insurance (general liability, workers compensation, professional liability) to be eligible for award. True if insurance is required.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invitedVendorCount rdf:type rdf:Property ;
    rdfs:label 'Invited Vendor Count' ;
    rdfs:comment 'Total number of vendors invited to submit quotations for this RFQ. Used to track solicitation breadth and competitive participation.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumVendorsRequired rdf:type rdf:Property ;
    rdfs:label 'Minimum Vendors Required' ;
    rdfs:comment 'Minimum number of vendor quotations required to satisfy competitive procurement policies. Typically 3 for formal competitive bids.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preBidAttendanceMandatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Pre Bid Attendance Mandatory Flag' ;
    rdfs:comment 'Indicates whether vendor attendance at the pre-bid meeting is mandatory to submit a valid quotation. True if mandatory, False if optional.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preBidMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Pre Bid Meeting Date' ;
    rdfs:comment 'Date of optional pre-bid or pre-proposal meeting where vendors can ask questions and clarify requirements before submitting quotes. Common for complex procurements.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preBidMeetingLocation rdf:type rdf:Property ;
    rdfs:label 'Pre Bid Meeting Location' ;
    rdfs:comment 'Physical or virtual location of the pre-bid meeting (e.g., \'Main Office Conference Room\', \'Microsoft Teams Virtual Meeting\').' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotesReceivedCount rdf:type rdf:Property ;
    rdfs:label 'Quotes Received Count' ;
    rdfs:comment 'Number of vendor quotations actually received in response to this RFQ. Used to assess vendor interest and competitive response rate.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfqDescription rdf:type rdf:Property ;
    rdfs:label 'Rfq Description' ;
    rdfs:comment 'Detailed description of the materials, services, or scope of work being solicited. May include technical specifications, performance requirements, and background context.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqNumber rdf:type rdf:Property ;
    rdfs:label 'Rfq Number' ;
    rdfs:comment 'Business identifier for the RFQ document, externally visible and used for vendor communication and tracking. Typically system-generated sequential or pattern-based number.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqStatus rdf:type rdf:Property ;
    rdfs:label 'Rfq Status' ;
    rdfs:comment 'Current lifecycle status of the RFQ: draft (being prepared), issued (sent to vendors), open (accepting quotes), closed (quote period ended), cancelled (RFQ withdrawn), awarded (vendor selected and purchase order issued).' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqType rdf:type rdf:Property ;
    rdfs:label 'Rfq Type' ;
    rdfs:comment 'Classification of the RFQ by procurement category: materials (spare parts, consumables), services (maintenance, consulting), equipment (capital assets), chemicals (treatment chemicals), construction (infrastructure projects), or professional services (engineering, legal).' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalContactEmail rdf:type rdf:Property ;
    rdfs:label 'Technical Contact Email' ;
    rdfs:comment 'Email address of the technical contact for vendor technical inquiries. Confidential organizational contact information.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalContactName rdf:type rdf:Property ;
    rdfs:label 'Technical Contact Name' ;
    rdfs:comment 'Name of the technical subject matter expert (e.g., plant operator, engineer) who can answer technical questions about specifications and requirements.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockMovementId rdf:type rdf:Property ;
    rdfs:label 'Stock Movement Id' ;
    rdfs:comment 'Unique identifier for the stock movement transaction. Primary key for the stock movement record.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fromWarehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'From Warehouse Location Id' ;
    rdfs:comment 'Foreign key linking to supply.warehouse_location. Business justification: Stock movements track transfers between warehouse locations. Currently uses denormalized storage_location_from STRING; should be proper FK. Label prefix \'from_\' distinguishes source location from dest' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:amountInLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount In Local Currency' ;
    rdfs:comment 'The monetary value of the material movement in the local currency of the plant (typically USD for U.S. water utilities). Calculated as quantity × unit price.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Date' ;
    rdfs:comment 'The date on which the material document was created in the system. Audit timestamp for record creation.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entryTime rdf:type rdf:Property ;
    rdfs:label 'Entry Time' ;
    rdfs:comment 'Timestamp when the material document was created in the system. Provides precise audit trail for transaction timing.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:movementIndicator rdf:type rdf:Property ;
    rdfs:label 'Movement Indicator' ;
    rdfs:comment 'Single-character indicator for special movement scenarios: B=Goods Movement for Purchase Order, H=Reversal Movement, F=Goods Movement for Production Order, E=Goods Movement for Sales Order, L=Goods Movement for Delivery.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementStatus rdf:type rdf:Property ;
    rdfs:label 'Movement Status' ;
    rdfs:comment 'Current lifecycle status of the material movement transaction: posted=Successfully posted to inventory and accounting, pending=Awaiting approval or verification, cancelled=Reversed or voided, error=Failed posting requiring correction.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalInventoryDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Physical Inventory Document Number' ;
    rdfs:comment 'Reference to the physical inventory count document if this movement is an inventory adjustment resulting from a cycle count or annual physical inventory.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenter rdf:type rdf:Property ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'Ten-character profit center code for internal management accounting and segment reporting. Used to allocate costs and revenues to business units or service areas.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderItem rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Item' ;
    rdfs:comment 'Line item number within the purchase order that this goods receipt fulfills. Typically a sequential integer (10, 20, 30, etc.).' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageLocationTo rdf:type rdf:Property ;
    rdfs:label 'Storage Location To' ;
    rdfs:comment 'Four-character code identifying the destination storage location to which material was moved. Null for goods issues to external consumption.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:textHeader rdf:type rdf:Property ;
    rdfs:label 'Text Header' ;
    rdfs:comment 'Free-form text field at the document header level providing additional context, notes, or instructions for the entire material movement transaction.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:textItem rdf:type rdf:Property ;
    rdfs:label 'Text Item' ;
    rdfs:comment 'Free-form text field at the line item level providing specific notes or details about this particular material movement (e.g., condition observed, special handling instructions).' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userName rdf:type rdf:Property ;
    rdfs:label 'User Name' ;
    rdfs:comment 'System user ID of the person who created or posted the material movement transaction. Used for audit trail and accountability.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversityCertification rdf:type rdf:Property ;
    rdfs:label 'Diversity Certification' ;
    rdfs:comment 'Diversity business certification status: Minority-owned Business Enterprise (MBE), Women-owned Business Enterprise (WBE), Disadvantaged Business Enterprise (DBE), Small Business Enterprise (SBE), Veteran-owned Business Enterprise (VBE), Service-Disabled Veteran-Owned Small Business (SDVOSB), Historically Underutilized Business Zone (HUBZone), or none. [ENUM-REF-CANDIDATE: mbe|wbe|dbe|sbe|vbe|sdvosb|hubzone|none — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Nine-digit unique identifier assigned by Dun & Bradstreet used for vendor credit assessment and business verification.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCertificateOnFileFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate On File Flag' ;
    rdfs:comment 'Indicates whether a current certificate of insurance meeting utility requirements is on file for this vendor.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPurchaseDate rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Date' ;
    rdfs:comment 'Date of the most recent purchase order or invoice transaction with this vendor, used to identify inactive vendors.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minorityOwnedFlag rdf:type rdf:Property ;
    rdfs:label 'Minority Owned Flag' ;
    rdfs:comment 'Indicates whether the vendor is certified as a minority-owned business enterprise.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nameShort rdf:type rdf:Property ;
    rdfs:label 'Name Short' ;
    rdfs:comment 'Abbreviated or common name of the vendor used for display and reporting purposes.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceRating rdf:type rdf:Property ;
    rdfs:label 'Performance Rating' ;
    rdfs:comment 'Overall vendor performance rating based on quality, delivery, service, and compliance metrics from vendor scorecards.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary business phone number for vendor contact.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'Federal Employer Identification Number (EIN) or Tax Identification Number used for tax reporting and 1099 processing.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'Full legal name of the vendor organization as registered with tax authorities and used in contracts.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Number' ;
    rdfs:comment 'External business identifier for the vendor, typically assigned by SAP MM or procurement system. Used in purchase orders and invoices.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorStatus rdf:type rdf:Property ;
    rdfs:label 'Vendor Status' ;
    rdfs:comment 'Current lifecycle status of the vendor record indicating whether the vendor is approved for procurement transactions.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorType rdf:type rdf:Property ;
    rdfs:label 'Vendor Type' ;
    rdfs:comment 'Classification of the vendor based on the primary goods or services provided to the water utility.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:w9OnFileFlag rdf:type rdf:Property ;
    rdfs:label 'W9 On File Flag' ;
    rdfs:comment 'Indicates whether a current IRS Form W-9 (Request for Taxpayer Identification Number and Certification) is on file for this vendor.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:womanOwnedFlag rdf:type rdf:Property ;
    rdfs:label 'Woman Owned Flag' ;
    rdfs:comment 'Indicates whether the vendor is certified as a woman-owned business enterprise.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Vendor Invoice Id' ;
    rdfs:comment 'Unique identifier for the vendor invoice record. Primary key.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exceptionDescription rdf:type rdf:Property ;
    rdfs:label 'Exception Description' ;
    rdfs:comment 'Detailed description of the invoice exception or discrepancy requiring resolution before payment can be released.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Date' ;
    rdfs:comment 'Date the physical or electronic invoice was received by the accounts payable department. Used for processing time metrics.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentBlockCode rdf:type rdf:Property ;
    rdfs:label 'Payment Block Code' ;
    rdfs:comment 'Code indicating if payment is blocked and the reason (e.g., price variance, quantity variance, quality issue, missing documentation). Blank if no block.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentBlockReason rdf:type rdf:Property ;
    rdfs:label 'Payment Block Reason' ;
    rdfs:comment 'Detailed explanation of why the invoice payment is blocked. Used for exception management and resolution tracking.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentClearedDate rdf:type rdf:Property ;
    rdfs:label 'Payment Cleared Date' ;
    rdfs:comment 'Date the invoice was fully paid and cleared from open items. Used for cash flow analysis and vendor payment performance.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'Date by which payment must be made to the vendor per the agreed payment terms. Used for cash flow planning and avoiding late payment penalties.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethodCode rdf:type rdf:Property ;
    rdfs:label 'Payment Method Code' ;
    rdfs:comment 'Code indicating the method by which payment will be made (e.g., check, wire transfer, ACH, credit card).' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentRunDate rdf:type rdf:Property ;
    rdfs:label 'Payment Run Date' ;
    rdfs:comment 'Date the invoice was included in an automatic payment run. Null if not yet paid or paid manually.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'Code representing the payment terms agreed with the vendor (e.g., Net 30, 2/10 Net 30). Defines due date and discount conditions.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Code identifying the tax jurisdiction applicable to this invoice (state, county, city). Used for tax compliance and reporting.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Vendor Performance Id' ;
    rdfs:comment 'Unique identifier for the vendor performance evaluation record.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evaluatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Evaluator Employee Id' ;
    rdfs:comment 'Employee identifier of the procurement or supply chain professional who conducted the vendor performance evaluation.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:coaComplianceRatePct rdf:type rdf:Property ;
    rdfs:label 'Coa Compliance Rate Pct' ;
    rdfs:comment 'Percentage of chemical deliveries accompanied by valid Certificate of Analysis (COA) documentation meeting regulatory and quality standards. Essential for water treatment chemicals to ensure Safe Drinking Water Act (SDWA) compliance.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Date' ;
    rdfs:comment 'Date when the vendor performance evaluation was conducted and finalized.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationNotes rdf:type rdf:Property ;
    rdfs:label 'Evaluation Notes' ;
    rdfs:comment 'Free-text notes and comments from the evaluator providing additional context, observations, or qualitative feedback about vendor performance during the evaluation period.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationNumber rdf:type rdf:Property ;
    rdfs:label 'Evaluation Number' ;
    rdfs:comment 'Business identifier for the vendor performance evaluation, typically generated by SAP MM or procurement system.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period End Date' ;
    rdfs:comment 'End date of the period covered by this vendor performance evaluation.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Start Date' ;
    rdfs:comment 'Start date of the period covered by this vendor performance evaluation.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationStatus rdf:type rdf:Property ;
    rdfs:label 'Evaluation Status' ;
    rdfs:comment 'Current workflow status of the vendor performance evaluation record (e.g., draft, submitted for approval, approved, rejected, closed).' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluatorName rdf:type rdf:Property ;
    rdfs:label 'Evaluator Name' ;
    rdfs:comment 'Name of the procurement or supply chain professional who conducted the vendor performance evaluation.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onTimeDeliveryRatePct rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Rate Pct' ;
    rdfs:comment 'Percentage of purchase orders delivered on or before the scheduled delivery date during the evaluation period. Key Performance Indicator (KPI) for vendor reliability.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderFillRatePct rdf:type rdf:Property ;
    rdfs:label 'Order Fill Rate Pct' ;
    rdfs:comment 'Percentage of purchase order line items delivered in full (complete quantity) during the evaluation period. Measures vendor ability to fulfill orders completely.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallPerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Overall Performance Rating' ;
    rdfs:comment 'Composite rating summarizing vendor performance across all Key Performance Indicators (KPIs) during the evaluation period. Used for vendor qualification decisions and contract renewals.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallPerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Overall Performance Score' ;
    rdfs:comment 'Numeric composite score (typically 0-100 scale) calculated from weighted individual Key Performance Indicator (KPI) scores. Supports quantitative vendor comparison and ranking.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingAccuracyRatePct rdf:type rdf:Property ;
    rdfs:label 'Pricing Accuracy Rate Pct' ;
    rdfs:comment 'Percentage of invoices that matched contracted pricing without discrepancies during the evaluation period. Measures vendor adherence to contract terms and billing accuracy.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityConformanceRatePct rdf:type rdf:Property ;
    rdfs:label 'Quality Conformance Rate Pct' ;
    rdfs:comment 'Percentage of delivered goods or services that met quality specifications and acceptance criteria during the evaluation period. Critical for chemical procurement (chlorine, coagulants, polymers, fluoride) where quality directly impacts water treatment efficacy.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendation rdf:type rdf:Property ;
    rdfs:label 'Recommendation' ;
    rdfs:comment 'Evaluator recommendation for future business relationship with the vendor based on performance evaluation results (e.g., continue current relationship, renew contract, renegotiate terms, place on probation, discontinue).' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsivenessScore rdf:type rdf:Property ;
    rdfs:label 'Responsiveness Score' ;
    rdfs:comment 'Qualitative score (typically 1-5 or 1-10 scale) rating vendor responsiveness to inquiries, issue resolution, and communication timeliness during the evaluation period.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderValue rdf:type rdf:Property ;
    rdfs:label 'Total Order Value' ;
    rdfs:comment 'Total monetary value of all purchase orders from the vendor during the evaluation period. Provides spend context for vendor importance and risk assessment.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrdersEvaluated rdf:type rdf:Property ;
    rdfs:label 'Total Orders Evaluated' ;
    rdfs:comment 'Total number of purchase orders from the vendor included in this performance evaluation period. Provides context for the statistical significance of Key Performance Indicator (KPI) scores.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessHours rdf:type rdf:Property ;
    rdfs:label 'Access Hours' ;
    rdfs:comment 'Standard operating hours or access schedule for the warehouse location. May be 24/7, business hours only, or by appointment.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableCapacitySqft rdf:type rdf:Property ;
    rdfs:label 'Available Capacity Sqft' ;
    rdfs:comment 'Currently available storage capacity in square feet. Updated based on inventory levels and space allocation.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:custodianContactEmail rdf:type rdf:Property ;
    rdfs:label 'Custodian Contact Email' ;
    rdfs:comment 'Email address for the warehouse custodian. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodianContactPhone rdf:type rdf:Property ;
    rdfs:label 'Custodian Contact Phone' ;
    rdfs:comment 'Primary contact phone number for the warehouse custodian. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireSuppressionSystem rdf:type rdf:Property ;
    rdfs:label 'Fire Suppression System' ;
    rdfs:comment 'Type of fire suppression system installed at the warehouse location. Critical for chemical storage safety and insurance compliance.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatCertified rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified' ;
    rdfs:comment 'Indicates whether the location is certified for storage of hazardous materials such as chlorine, coagulants, polymers, and other treatment chemicals. Required for chemical procurement and FOG (Fats Oils and Grease) management compliance.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventoryCycleCountFrequency rdf:type rdf:Property ;
    rdfs:label 'Inventory Cycle Count Frequency' ;
    rdfs:comment 'Standard frequency for physical inventory cycle counts at this location. Supports inventory accuracy and audit compliance.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleCustodian rdf:type rdf:Property ;
    rdfs:label 'Responsible Custodian' ;
    rdfs:comment 'Name or identifier of the person or role responsible for managing and securing the warehouse location. Accountable for inventory accuracy and safety compliance.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPlantCode rdf:type rdf:Property ;
    rdfs:label 'Sap Plant Code' ;
    rdfs:comment 'SAP MM plant code to which this warehouse location is assigned. Links warehouse location to the SAP organizational structure for materials management and procurement.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapStorageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Sap Storage Location Code' ;
    rdfs:comment 'SAP MM storage location code within the plant. Used for inventory transactions, goods receipts, and goods issues in SAP ERP.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityLevel rdf:type rdf:Property ;
    rdfs:label 'Security Level' ;
    rdfs:comment 'Physical security classification of the warehouse location. Determines access control requirements and monitoring protocols.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spillContainmentAvailable rdf:type rdf:Property ;
    rdfs:label 'Spill Containment Available' ;
    rdfs:comment 'Indicates whether the location has spill containment infrastructure for chemical storage. Required for EPA SPCC (Spill Prevention Control and Countermeasure) compliance.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureControlAvailable rdf:type rdf:Property ;
    rdfs:label 'Temperature Control Available' ;
    rdfs:comment 'Indicates whether the location has active temperature control systems (HVAC). Required for certain chemical and equipment storage.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureRangeMaxF rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max F' ;
    rdfs:comment 'Maximum temperature maintained at the warehouse location in degrees Fahrenheit. Relevant for temperature-controlled storage.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMinF rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min F' ;
    rdfs:comment 'Minimum temperature maintained at the warehouse location in degrees Fahrenheit. Relevant for temperature-controlled storage.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCapacitySqft rdf:type rdf:Property ;
    rdfs:label 'Total Capacity Sqft' ;
    rdfs:comment 'Total storage capacity of the warehouse location measured in square feet. Used for space utilization analysis and capacity planning.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ventilationType rdf:type rdf:Property ;
    rdfs:label 'Ventilation Type' ;
    rdfs:comment 'Type of ventilation system in the warehouse. Important for chemical storage safety and worker health compliance.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backwashEventId rdf:type rdf:Property ;
    rdfs:label 'Backwash Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each filter backwash event record in the Silver Layer lakehouse. Primary key for this data product.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BackwashEvent .

ind:filterUnitId rdf:type rdf:Property ;
    rdfs:label 'Filter Unit Id' ;
    rdfs:comment 'Reference to the specific filter unit (filter cell/bed) at the WTP that underwent the backwash event. Links to the filter unit asset record in IBM Maximo CMMS.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FilterUnit .

ind:morSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Mor Submission Id' ;
    rdfs:comment 'Foreign key linking to treatment.mor_submission. Business justification: Backwash events are aggregated and reported in Monthly Operating Reports (MOR). The mor_reporting_period string on backwash_event should be replaced by FK to the mor_submission that includes this even' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MorSubmission .

ind:processReadingId rdf:type rdf:Property ;
    rdfs:label 'Process Reading Id' ;
    rdfs:comment 'Foreign key linking to treatment.process_alarm. Business justification: Backwash events may be triggered by process alarms (e.g., high headloss alarm, turbidity breakthrough alarm). The initiation_type and trigger_reason fields indicate whether backwash was alarm-triggere' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessReading .

ind:abnormalEventFlag rdf:type rdf:Property ;
    rdfs:label 'Abnormal Event Flag' ;
    rdfs:comment 'Indicates whether this backwash event was flagged as abnormal due to unexpected conditions such as media loss, turbidity exceedance, premature termination, or equipment malfunction (True = abnormal, False = normal). Triggers follow-up investigation workflow.' ;
    rdfs:domain ind:BackwashEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:airScourDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Air Scour Duration Minutes' ;
    rdfs:comment 'Duration of the air scour phase of the backwash cycle in minutes. Null if air scour was not used. Supports optimization of combined air-water backwash procedures per AWWA guidelines.' ;
    rdfs:domain ind:BackwashEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:airScourRateScfm rdf:type rdf:Property ;
    rdfs:label 'Air Scour Rate Scfm' ;
    rdfs:comment 'Air flow rate applied during the air scour phase, measured in Standard Cubic Feet Per Minute (SCFM). Null if air scour was not used. Used to verify compliance with design air scour intensity specifications.' ;
    rdfs:domain ind:BackwashEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:airScourUsed rdf:type rdf:Property ;
    rdfs:label 'Air Scour Used' ;
    rdfs:comment 'Indicates whether air scour was employed as part of the backwash cycle (True) or not (False). Air scour enhances filter media cleaning efficiency and is tracked for process optimization and media longevity analysis.' ;
    rdfs:domain ind:BackwashEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:backwashEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Backwash End Timestamp' ;
    rdfs:comment 'Date and time when the backwash cycle was completed or terminated, recorded from SCADA/OSIsoft PI Historian. Used with start timestamp to calculate total backwash duration. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:BackwashEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:backwashFlowRateGpm rdf:type rdf:Property ;
    rdfs:label 'Backwash Flow Rate Gpm' ;
    rdfs:comment 'Average flow rate of backwash water through the filter media during the backwash cycle, measured in Gallons Per Minute (GPM). Used to assess backwash effectiveness and compliance with design specifications.' ;
    rdfs:domain ind:BackwashEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backwashFlowRateMaxGpm rdf:type rdf:Property ;
    rdfs:label 'Backwash Flow Rate Max Gpm' ;
    rdfs:comment 'Peak flow rate recorded during the backwash cycle in Gallons Per Minute (GPM). Supports detection of hydraulic surges that may damage filter media and comparison against design maximum flow rate.' ;
    rdfs:domain ind:BackwashEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backwashRecycleVolumeGal rdf:type rdf:Property ;
    rdfs:label 'Backwash Recycle Volume Gal' ;
    rdfs:comment 'Volume of backwash waste water recovered and recycled back to the plant headworks for re-treatment, measured in gallons. Null if recycle was not performed. Supports backwash water recovery tracking and NRW reduction reporting.' ;
    rdfs:domain ind:BackwashEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backwashStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Backwash Start Timestamp' ;
    rdfs:comment 'Date and time when the backwash cycle was initiated, recorded from SCADA/OSIsoft PI Historian. Principal business event timestamp for this transaction. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:BackwashEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:backwashWasteDisposalMethod rdf:type rdf:Property ;
    rdfs:label 'Backwash Waste Disposal Method' ;
    rdfs:comment 'Method used to dispose of backwash waste water and solids. Options include: \'lagoon\' (settling lagoon), \'sewer_discharge\' (to sanitary sewer), \'recycle_to_head\' (recycled to plant headworks), \'dewatering\' (mechanical dewatering), \'land_application\'. Tracked for NPDES permit compliance and environmental reporting.' ;
    rdfs:domain ind:BackwashEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backwashWaterSource rdf:type rdf:Property ;
    rdfs:label 'Backwash Water Source' ;
    rdfs:comment 'Source of water used for the backwash cycle. Supports hydraulic capacity planning and ensures backwash water quality meets operational requirements.' ;
    rdfs:domain ind:BackwashEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backwashWaterTempC rdf:type rdf:Property ;
    rdfs:label 'Backwash Water Temp C' ;
    rdfs:comment 'Temperature of the backwash water at the time of the backwash event, measured in degrees Celsius. Water temperature affects backwash expansion rate and media cleaning efficiency; used for seasonal performance analysis.' ;
    rdfs:domain ind:BackwashEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backwashWaterVolumeGal rdf:type rdf:Property ;
    rdfs:label 'Backwash Water Volume Gal' ;
    rdfs:comment 'Total volume of water used during the backwash cycle, measured in gallons. Critical input for Non-Revenue Water (NRW) calculations, backwash water recovery tracking, and operational efficiency reporting.' ;
    rdfs:domain ind:BackwashEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chemicalAidDoseMgL rdf:type rdf:Property ;
    rdfs:label 'Chemical Aid Dose Mg L' ;
    rdfs:comment 'Concentration of chemical ripening aid applied to the filter during the ripening period, measured in milligrams per liter (mg/L). Null if no chemical aid was used. Supports chemical dosing optimization and cost tracking.' ;
    rdfs:domain ind:BackwashEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chemicalAidUsed rdf:type rdf:Property ;
    rdfs:label 'Chemical Aid Used' ;
    rdfs:comment 'Indicates whether a chemical ripening aid (e.g., polymer or coagulant) was dosed to the filter during the ripening period to accelerate turbidity reduction (True) or not (False). Supports chemical dosing optimization and cost tracking.' ;
    rdfs:domain ind:BackwashEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eventReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Event Reference Number' ;
    rdfs:comment 'Externally-known business identifier for the backwash event, used in operational logs, MOR submissions, and CMMS work order references. Format: BWE-{YYYY}-{NNNNNN}.' ;
    rdfs:domain ind:BackwashEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filterMediaType rdf:type rdf:Property ;
    rdfs:label 'Filter Media Type' ;
    rdfs:comment 'Type of filter media in the filter unit at the time of the backwash event. Supports media-specific backwash protocol compliance and performance benchmarking. [ENUM-REF-CANDIDATE: sand|anthracite|dual_media|tri_media|gac|membrane — promote to reference product if additional media types are needed]' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filterRipeningDurationMin rdf:type rdf:Property ;
    rdfs:label 'Filter Ripening Duration Min' ;
    rdfs:comment 'Time elapsed in minutes between the end of the backwash cycle and the point when the filter was returned to full production service, representing the filter ripening/maturation period. Supports optimization of filter-to-waste procedures and ripening aid chemical dosing.' ;
    rdfs:domain ind:BackwashEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:filterRunTimePriorHrs rdf:type rdf:Property ;
    rdfs:label 'Filter Run Time Prior Hrs' ;
    rdfs:comment 'Total hours the filter operated in service since the previous backwash event. Key metric for filter media performance trending, backwash frequency optimization, and detection of premature filter breakthrough.' ;
    rdfs:domain ind:BackwashEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:filterToWasteUsed rdf:type rdf:Property ;
    rdfs:label 'Filter To Waste Used' ;
    rdfs:comment 'Indicates whether the filter-to-waste procedure was employed during the ripening period (True) or the filter was returned directly to service (False). Filter-to-waste diverts initial filtered water to waste to prevent turbidity spikes from entering the distribution system.' ;
    rdfs:domain ind:BackwashEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:filterToWasteVolumeGal rdf:type rdf:Property ;
    rdfs:label 'Filter To Waste Volume Gal' ;
    rdfs:comment 'Volume of water diverted to waste during the filter ripening period, measured in gallons. Null if filter-to-waste was not used. Contributes to total Non-Revenue Water (NRW) and backwash water recovery calculations.' ;
    rdfs:domain ind:BackwashEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:initiationType rdf:type rdf:Property ;
    rdfs:label 'Initiation Type' ;
    rdfs:comment 'Indicates how the backwash event was triggered: \'manual\' by operator command, \'automatic\' by SCADA/PLC logic based on headloss or turbidity threshold, \'scheduled\' per routine maintenance plan, or \'emergency\' due to abnormal filter performance.' ;
    rdfs:domain ind:BackwashEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaExpansionPct rdf:type rdf:Property ;
    rdfs:label 'Media Expansion Pct' ;
    rdfs:comment 'Percentage expansion of the filter media bed during the backwash cycle. Optimal expansion (typically 20-50%) ensures effective cleaning without media loss. Supports media performance trending and backwash protocol optimization.' ;
    rdfs:domain ind:BackwashEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatorConfirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Operator Confirmation Timestamp' ;
    rdfs:comment 'Date and time when the certified operator formally confirmed the backwash event and authorized filter return to service. Null if operator confirmation is pending. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:BackwashEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:operatorConfirmed rdf:type rdf:Property ;
    rdfs:label 'Operator Confirmed' ;
    rdfs:comment 'Indicates whether a certified water treatment operator formally confirmed the backwash event completion and filter return-to-service (True) or not (False). Required for regulatory accountability and MOR documentation.' ;
    rdfs:domain ind:BackwashEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postBackwashHeadlossFt rdf:type rdf:Property ;
    rdfs:label 'Post Backwash Headloss Ft' ;
    rdfs:comment 'Differential pressure head loss across the filter media immediately after the backwash cycle completed, measured in feet of water column. Indicates backwash effectiveness; elevated post-backwash headloss may signal media fouling or mudball formation.' ;
    rdfs:domain ind:BackwashEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postBackwashTurbidityNtu rdf:type rdf:Property ;
    rdfs:label 'Post Backwash Turbidity Ntu' ;
    rdfs:comment 'Filtered water turbidity reading in Nephelometric Turbidity Units (NTU) measured after the backwash cycle and filter ripening period. Critical compliance metric; must meet MCL turbidity limits per EPA Surface Water Treatment Rule before filter is returned to service.' ;
    rdfs:domain ind:BackwashEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preBackwashHeadlossFt rdf:type rdf:Property ;
    rdfs:label 'Pre Backwash Headloss Ft' ;
    rdfs:comment 'Differential pressure head loss across the filter media immediately before the backwash cycle began, measured in feet of water column. Primary trigger metric for headloss-initiated backwash events and filter media fouling assessment.' ;
    rdfs:domain ind:BackwashEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preBackwashTurbidityNtu rdf:type rdf:Property ;
    rdfs:label 'Pre Backwash Turbidity Ntu' ;
    rdfs:comment 'Filtered water turbidity reading in Nephelometric Turbidity Units (NTU) immediately before the backwash cycle. Provides baseline filter performance context and supports turbidity-triggered backwash analysis.' ;
    rdfs:domain ind:BackwashEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scadaEventTag rdf:type rdf:Property ;
    rdfs:label 'Scada Event Tag' ;
    rdfs:comment 'OSIsoft PI Historian tag or SCADA event identifier associated with this backwash event, enabling direct traceability to the source process control system record for audit and data lineage purposes.' ;
    rdfs:domain ind:BackwashEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surfaceWashUsed rdf:type rdf:Property ;
    rdfs:label 'Surface Wash Used' ;
    rdfs:comment 'Indicates whether a surface wash (rotary or fixed nozzle) was employed as part of the backwash cycle (True) or not (False). Surface wash breaks up surface mud accumulation and is tracked for process optimization.' ;
    rdfs:domain ind:BackwashEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:triggerReason rdf:type rdf:Property ;
    rdfs:label 'Trigger Reason' ;
    rdfs:comment 'Specific reason that triggered the backwash event. Supports filter performance trending and optimization of backwash frequency. [ENUM-REF-CANDIDATE: headloss_threshold|turbidity_threshold|runtime_threshold|scheduled_interval|operator_initiated|emergency — promote to reference product if additional values are needed]' ;
    rdfs:domain ind:BackwashEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turbidityComplianceMet rdf:type rdf:Property ;
    rdfs:label 'Turbidity Compliance Met' ;
    rdfs:comment 'Indicates whether the post-backwash turbidity reading met the applicable Maximum Contaminant Level (MCL) turbidity standard before the filter was returned to service (True = compliant, False = non-compliant). Supports regulatory compliance tracking for MOR submissions.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chemicalDoseEventId rdf:type rdf:Property ;
    rdfs:label 'Chemical Dose Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each chemical dosing event record in the treatment domain. Primary key for the chemical_dose_event data product.' ;
    rdfs:domain ind:ChemicalDoseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chemicalId rdf:type rdf:Property ;
    rdfs:label 'Chemical Id' ;
    rdfs:comment 'Reference to the chemical substance master record (e.g., chlorine, alum, polymer, lime, caustic soda, fluoride, potassium permanganate, sodium hypochlorite, GAC). Links to the chemical inventory/supply chain product catalog.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Chemical .

ind:chemicalInventoryId rdf:type rdf:Property ;
    rdfs:label 'Chemical Inventory Id' ;
    rdfs:comment 'Foreign key linking to treatment.chemical_inventory. Business justification: Each chemical dose event draws from a specific on-site inventory lot. This FK enables lot traceability for regulatory compliance and quality control. The chemical_lot_number on chemical_dose_event sho' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChemicalInventory .

ind:chemicalSupplierVendorId rdf:type rdf:Property ;
    rdfs:label 'Chemical Supplier Vendor Id' ;
    rdfs:comment 'Reference to the chemical supplier/vendor master record in SAP MM. Used for chemical cost allocation by supplier, supplier performance analytics, and procurement planning.' ;
    rdfs:domain ind:ChemicalDoseEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:treatmentProcessProcessUnitId rdf:type rdf:Property ;
    rdfs:label 'Treatment Process Process Unit Id' ;
    rdfs:comment 'Reference to the specific treatment process unit (e.g., coagulation basin, filter, chlorine contact chamber, RO train) where the chemical was dosed. Sourced from IBM Maximo Asset Management (CMMS) asset registry.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessUnit .

ind:chemicalConcentrationPct rdf:type rdf:Property ;
    rdfs:label 'Chemical Concentration Pct' ;
    rdfs:comment 'The concentration of the chemical solution as dosed, expressed as a percentage (e.g., 12.5% sodium hypochlorite, 48% alum solution). Required for accurate mass-to-volume conversion and chemical inventory reconciliation.' ;
    rdfs:domain ind:ChemicalDoseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chemicalMassAppliedKg rdf:type rdf:Property ;
    rdfs:label 'Chemical Mass Applied Kg' ;
    rdfs:comment 'Total mass of active chemical ingredient applied during the dosing event, expressed in kilograms. Calculated from volume and concentration for solid or concentrated liquid chemicals. Used for regulatory reporting and chemical cost accounting.' ;
    rdfs:domain ind:ChemicalDoseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chemicalType rdf:type rdf:Property ;
    rdfs:label 'Chemical Type' ;
    rdfs:comment 'Functional classification of the chemical dosed. Used for cost allocation by treatment function, regulatory reporting by chemical category, and chemical consumption analytics. [ENUM-REF-CANDIDATE: disinfectant|coagulant|flocculant|pH_adjustment|fluoridation|oxidant|corrosion_inhibitor|adsorbent — promote to reference product]' ;
    rdfs:domain ind:ChemicalDoseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Ct Compliance Flag' ;
    rdfs:comment 'Indicates whether the dosing event achieved the required CT value for regulatory disinfection compliance (True = compliant, False = non-compliant). Used for automated MOR/DMR compliance reporting and regulatory violation tracking.' ;
    rdfs:domain ind:ChemicalDoseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ctRequiredMgMinPerL rdf:type rdf:Property ;
    rdfs:label 'Ct Required Mg Min Per L' ;
    rdfs:comment 'The minimum CT value required by EPA Surface Water Treatment Rule (SWTR) for the applicable temperature and pH conditions to achieve required log inactivation credits. Compared against ct_value_mg_min_per_l for compliance determination.' ;
    rdfs:domain ind:ChemicalDoseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctValueMgMinPerL rdf:type rdf:Property ;
    rdfs:label 'Ct Value Mg Min Per L' ;
    rdfs:comment 'The calculated CT (Contact Time for Disinfection) value in mg·min/L, representing the product of disinfectant residual concentration and contact time. Required for Surface Water Treatment Rule (SWTR) compliance and Giardia/virus inactivation credit calculations.' ;
    rdfs:domain ind:ChemicalDoseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dbpFormationRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Dbp Formation Risk Flag' ;
    rdfs:comment 'Indicates whether the dosing event parameters (dose rate, TOC level, temperature, pH) present an elevated risk of Disinfection Byproduct (DBP) formation, specifically Trihalomethanes (THM) and Haloacetic Acids (HAA5). Supports proactive DBP compliance management.' ;
    rdfs:domain ind:ChemicalDoseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doseEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dose End Timestamp' ;
    rdfs:comment 'The exact date and time when the chemical dosing event concluded. Used with dose_start_timestamp to calculate dosing duration and total chemical volume applied. Sourced from SCADA/OSIsoft PI Historian.' ;
    rdfs:domain ind:ChemicalDoseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:doseEventNumber rdf:type rdf:Property ;
    rdfs:label 'Dose Event Number' ;
    rdfs:comment 'Externally-known business identifier for the chemical dosing event, typically sourced from OSIsoft PI Historian or SCADA event log (e.g., \'CDE-2024-00123\'). Used for cross-system traceability and regulatory audit trails.' ;
    rdfs:domain ind:ChemicalDoseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doseEventStatus rdf:type rdf:Property ;
    rdfs:label 'Dose Event Status' ;
    rdfs:comment 'Current lifecycle status of the chemical dosing event record. \'completed\' indicates normal termination; \'aborted\' indicates operator-interrupted dosing; \'failed\' indicates pump or system failure; \'pending_review\' indicates the record requires QA validation before regulatory submission.' ;
    rdfs:domain ind:ChemicalDoseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doseRateMgPerL rdf:type rdf:Property ;
    rdfs:label 'Dose Rate Mg Per L' ;
    rdfs:comment 'The chemical dose rate expressed in milligrams per liter (mg/L) of water treated. This is the primary dosing metric used for regulatory compliance verification, CT calculations, and comparison against Maximum Contaminant Level (MCL) limits.' ;
    rdfs:domain ind:ChemicalDoseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:doseStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dose Start Timestamp' ;
    rdfs:comment 'The exact date and time (ISO 8601 with timezone offset) when the chemical dosing event commenced, as recorded by SCADA/OSIsoft PI Historian. This is the principal real-world event timestamp for regulatory CT (Contact Time) compliance calculations.' ;
    rdfs:domain ind:ChemicalDoseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:doseTriggerType rdf:type rdf:Property ;
    rdfs:label 'Dose Trigger Type' ;
    rdfs:comment 'Indicates what initiated the dosing event: automatic SCADA/PLC control loop, manual operator action, scheduled dosing program, alarm response (e.g., low residual alarm), or regulatory requirement (e.g., CT compliance mandate).' ;
    rdfs:domain ind:ChemicalDoseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dosingMethod rdf:type rdf:Property ;
    rdfs:label 'Dosing Method' ;
    rdfs:comment 'The method by which the chemical was applied: \'continuous\' (steady-state pump injection), \'batch\' (fixed volume addition), \'slug\' (rapid high-concentration dose), or \'intermittent\' (cyclic on/off dosing). Affects dose efficacy calculations and regulatory reporting.' ;
    rdfs:domain ind:ChemicalDoseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dosingPumpCode rdf:type rdf:Property ;
    rdfs:label 'Dosing Pump Code' ;
    rdfs:comment 'Reference to the dosing pump asset used to inject the chemical, as registered in IBM Maximo CMMS. Enables pump performance tracking, maintenance scheduling, and dose accuracy auditing.' ;
    rdfs:domain ind:ChemicalDoseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventDoseCostUsd rdf:type rdf:Property ;
    rdfs:label 'Event Dose Cost Usd' ;
    rdfs:comment 'The total chemical cost in USD for this dosing event, calculated as chemical_mass_applied_kg multiplied by unit_cost_per_kg. Used for per-event cost allocation, treatment cost-per-MGD analytics, and OPEX reporting in SAP FI/CO.' ;
    rdfs:domain ind:ChemicalDoseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mclLimitMgPerL rdf:type rdf:Property ;
    rdfs:label 'Mcl Limit Mg Per L' ;
    rdfs:comment 'The applicable Maximum Contaminant Level (MCL) or Maximum Contaminant Level Goal (MCLG) for the target parameter as set by EPA or state primacy agency. Stored at event time for point-in-time regulatory compliance verification.' ;
    rdfs:domain ind:ChemicalDoseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatorNotes rdf:type rdf:Property ;
    rdfs:label 'Operator Notes' ;
    rdfs:comment 'Free-text field for the licensed operator to record observations, anomalies, equipment issues, or contextual information about the dosing event (e.g., \'pump cavitation observed\', \'manual override due to analyzer failure\'). Supports operational audit trail and incident investigation.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postDoseResidualMgPerL rdf:type rdf:Property ;
    rdfs:label 'Post Dose Residual Mg Per L' ;
    rdfs:comment 'Actual measured residual concentration of the target parameter (e.g., free chlorine residual, pH) after the dosing event. Critical for CT compliance verification, MCL compliance, and dose efficacy reporting in Monthly Operating Reports (MOR).' ;
    rdfs:domain ind:ChemicalDoseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preDoseResidualMgPerL rdf:type rdf:Property ;
    rdfs:label 'Pre Dose Residual Mg Per L' ;
    rdfs:comment 'Measured concentration of the target parameter (e.g., chlorine residual, pH) immediately before the dosing event commenced. Provides baseline for dose efficacy assessment and regulatory compliance documentation.' ;
    rdfs:domain ind:ChemicalDoseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pumpFlowRateGpm rdf:type rdf:Property ;
    rdfs:label 'Pump Flow Rate Gpm' ;
    rdfs:comment 'The dosing pump flow rate in Gallons per Minute (GPM) during the event, as recorded by SCADA/OSIsoft PI Historian via the pump tag. Used for pump calibration verification and dose accuracy auditing.' ;
    rdfs:domain ind:ChemicalDoseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pumpScadaTag rdf:type rdf:Property ;
    rdfs:label 'Pump Scada Tag' ;
    rdfs:comment 'The OSIsoft PI Historian or SCADA tag identifier for the dosing pump instrument (e.g., \'WTP1.PUMP.CL2.FLOW.001\'). Enables direct linkage to real-time process data in PI Historian for trend analysis and audit trail verification.' ;
    rdfs:domain ind:ChemicalDoseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryEventFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Event Flag' ;
    rdfs:comment 'Indicates whether this dosing event is subject to regulatory reporting requirements (True = must be included in MOR, DMR, or CCR submissions). Enables automated filtering of reportable events for EPA and state primacy agency compliance reporting.' ;
    rdfs:domain ind:ChemicalDoseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetDoseRateMgPerL rdf:type rdf:Property ;
    rdfs:label 'Target Dose Rate Mg Per L' ;
    rdfs:comment 'The planned or setpoint dose rate in mg/L as configured in the SCADA/PLC control system or operator dosing schedule. Compared against actual dose_rate_mg_per_l to assess dosing accuracy and control loop performance.' ;
    rdfs:domain ind:ChemicalDoseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetParameter rdf:type rdf:Property ;
    rdfs:label 'Target Parameter' ;
    rdfs:comment 'The water quality parameter that the dosing event is intended to control or achieve (e.g., \'free_chlorine_residual\', \'turbidity\', \'pH\', \'fluoride_level\', \'TOC\', \'PFAS\', \'BOD\', \'TSS\'). Links dosing events to water quality outcomes for efficacy analysis.' ;
    rdfs:domain ind:ChemicalDoseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetResidualMgPerL rdf:type rdf:Property ;
    rdfs:label 'Target Residual Mg Per L' ;
    rdfs:comment 'The desired or regulatory-required residual concentration of the target parameter after dosing. Compared against post_dose_residual_mg_per_l to determine compliance status. Derived from MCL/MCLG standards or internal treatment targets.' ;
    rdfs:domain ind:ChemicalDoseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentProcessStage rdf:type rdf:Property ;
    rdfs:label 'Treatment Process Stage' ;
    rdfs:comment 'The stage in the water treatment process where the chemical was dosed. [ENUM-REF-CANDIDATE: pre_treatment|coagulation|flocculation|sedimentation|filtration|disinfection|post_treatment|distribution — promote to reference product]' ;
    rdfs:domain ind:ChemicalDoseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCostPerKg rdf:type rdf:Property ;
    rdfs:label 'Unit Cost Per Kg' ;
    rdfs:comment 'The unit cost of the chemical in USD per kilogram at the time of the dosing event, sourced from SAP MM purchase order pricing. Used for chemical cost allocation per dosing event and OPEX analytics. Classified as confidential due to supplier contract pricing sensitivity.' ;
    rdfs:domain ind:ChemicalDoseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeAppliedL rdf:type rdf:Property ;
    rdfs:label 'Volume Applied L' ;
    rdfs:comment 'Total volume of chemical solution applied during the dosing event, expressed in liters. Used for chemical inventory consumption tracking, cost allocation, and procurement planning in SAP MM.' ;
    rdfs:domain ind:ChemicalDoseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterFlowRateMgd rdf:type rdf:Property ;
    rdfs:label 'Water Flow Rate Mgd' ;
    rdfs:comment 'The water flow rate in Million Gallons per Day (MGD) at the dosing point during the event, as recorded by SCADA/OSIsoft PI Historian. Used to validate dose rate calculations and for CT compliance verification.' ;
    rdfs:domain ind:ChemicalDoseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterPh rdf:type rdf:Property ;
    rdfs:label 'Water Ph' ;
    rdfs:comment 'The pH (Potential of Hydrogen) of the water at the dosing point during the event. Critical for CT compliance calculations (CT requirements vary with pH for chlorine disinfection), DBP formation potential, and corrosion control under LCRR.' ;
    rdfs:domain ind:ChemicalDoseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageAssetLocationId rdf:type rdf:Property ;
    rdfs:label 'Storage Asset Location Id' ;
    rdfs:comment 'Foreign key linking to asset.asset_location. Business justification: Chemical inventory management requires precise physical location tracking within facilities for safety compliance (EPCRA Tier II reporting), emergency response planning, and operational logistics. Sto' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:averageDailyUsage rdf:type rdf:Property ;
    rdfs:label 'Average Daily Usage' ;
    rdfs:comment 'Average quantity of the chemical consumed per day at the facility, expressed in the designated unit of measure. Calculated from historical dosing records and used to estimate days of supply remaining and optimize reorder frequency.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgQuantityInYear rdf:type rdf:Property ;
    rdfs:label 'Avg Quantity In Year' ;
    rdfs:comment 'Average daily quantity of the chemical present at the facility during the Tier II reporting year, expressed in the designated unit of measure. Required field for OSHA EPCRA Section 312 Tier II annual report submission.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:containerIdentifier rdf:type rdf:Property ;
    rdfs:label 'Container Identifier' ;
    rdfs:comment 'Unique identifier or tag number assigned to the specific storage tank or container holding this chemical (e.g., T-101, DRUM-045). Used for physical asset tracking, maintenance records in IBM Maximo, and OSHA Tier II site maps.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dosingPoint rdf:type rdf:Property ;
    rdfs:label 'Dosing Point' ;
    rdfs:comment 'Specific treatment process stage or location where this chemical is applied (e.g., pre-chlorination, coagulation basin, filtration, post-disinfection, pH correction, fluoride addition). Supports process mapping and SCADA integration.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Status' ;
    rdfs:comment 'Current lifecycle status of the chemical inventory record indicating whether the chemical is actively in use, on order, depleted, quarantined due to quality concerns, expired, or discontinued from use at the facility.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEpcraReportable rdf:type rdf:Property ;
    rdfs:label 'Is Epcra Reportable' ;
    rdfs:comment 'Indicates whether this chemical meets the threshold quantity for mandatory reporting under EPCRA Section 312 (Tier II) to state and local emergency planning committees. True if the chemical is an Extremely Hazardous Substance (EHS) or meets reporting thresholds.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRmpRegulated rdf:type rdf:Property ;
    rdfs:label 'Is Rmp Regulated' ;
    rdfs:comment 'Indicates whether this chemical is a regulated substance under EPA Risk Management Program (RMP) rules (40 CFR Part 68). True if the chemical is listed and stored above the threshold quantity, requiring an RMP plan submission.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Last Delivery Date' ;
    rdfs:comment 'Date of the most recent chemical delivery received at the facility. Used to track supply chain cadence, validate inventory levels, and support procurement planning.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPhysicalCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Count Date' ;
    rdfs:comment 'Date of the most recent physical inventory count or verification performed at the storage location. Required for inventory accuracy audits and OSHA Tier II annual reporting reconciliation.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPhysicalCountQuantity rdf:type rdf:Property ;
    rdfs:label 'Last Physical Count Quantity' ;
    rdfs:comment 'Actual quantity recorded during the most recent physical inventory count, expressed in the designated unit of measure. Used to reconcile system quantity against physical stock and identify discrepancies.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxQuantityInYear rdf:type rdf:Property ;
    rdfs:label 'Max Quantity In Year' ;
    rdfs:comment 'Maximum quantity of the chemical present at the facility at any point during the Tier II reporting year, expressed in the designated unit of measure. Required field for OSHA EPCRA Section 312 Tier II annual report submission.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxStorageCapacity rdf:type rdf:Property ;
    rdfs:label 'Max Storage Capacity' ;
    rdfs:comment 'Maximum allowable quantity of the chemical that can be stored at the facility location, expressed in the designated unit of measure. Governed by OSHA PSM thresholds, EPA RMP requirements, and local fire codes. Used for OSHA Tier II reporting.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximoItemNumber rdf:type rdf:Property ;
    rdfs:label 'Maximo Item Number' ;
    rdfs:comment 'Item number assigned to this chemical in IBM Maximo Asset Management (CMMS) storeroom inventory. Enables cross-referencing between the lakehouse chemical inventory and the operational CMMS for work order material consumption tracking.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nfpaFireRating rdf:type rdf:Property ;
    rdfs:label 'Nfpa Fire Rating' ;
    rdfs:comment 'NFPA 704 flammability hazard rating for the chemical on a scale of 0 (will not burn) to 4 (extremely flammable). Used for fire safety planning, storage segregation requirements, and emergency response.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nfpaHealthRating rdf:type rdf:Property ;
    rdfs:label 'Nfpa Health Rating' ;
    rdfs:comment 'NFPA 704 health hazard rating for the chemical on a scale of 0 (minimal hazard) to 4 (deadly). Used for emergency response planning, worker safety training, and facility hazard communication.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nfpaReactivityRating rdf:type rdf:Property ;
    rdfs:label 'Nfpa Reactivity Rating' ;
    rdfs:comment 'NFPA 704 instability/reactivity hazard rating for the chemical on a scale of 0 (stable) to 4 (may detonate). Critical for chemical storage segregation, incompatibility management, and emergency response planning.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityOnHand rdf:type rdf:Property ;
    rdfs:label 'Quantity On Hand' ;
    rdfs:comment 'Current physical quantity of the chemical available in storage at the facility, expressed in the designated unit of measure (lbs or gallons). Updated after each delivery receipt and physical count. Critical for treatment process continuity and procurement planning.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Material Number' ;
    rdfs:comment 'SAP ERP material master number assigned to this chemical in the MM module. Enables traceability between the lakehouse silver layer and SAP procurement, goods receipt, and inventory management transactions.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sds Reference Number' ;
    rdfs:comment 'Document reference number or identifier for the Safety Data Sheet (SDS) associated with this chemical, as required by OSHA Hazard Communication Standard (HazCom). Links to the SDS document management system for emergency response and worker safety.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsRevisionDate rdf:type rdf:Property ;
    rdfs:label 'Sds Revision Date' ;
    rdfs:comment 'Date of the most current revision of the Safety Data Sheet (SDS) on file for this chemical. OSHA requires SDS documents to be current; outdated SDS may indicate a compliance gap.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:secondaryContainmentAvailable rdf:type rdf:Property ;
    rdfs:label 'Secondary Containment Available' ;
    rdfs:comment 'Indicates whether the storage location for this chemical has secondary containment (e.g., berm, dike, containment basin) to prevent spills from reaching the environment. Required for SPCC plan compliance and OSHA PSM.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageContainerType rdf:type rdf:Property ;
    rdfs:label 'Storage Container Type' ;
    rdfs:comment 'Type of storage vessel or container used to hold the chemical at the facility (e.g., bulk tank, day tank, drum, cylinder, tote, bag). Relevant for spill response planning, OSHA Tier II, and maintenance scheduling. [ENUM-REF-CANDIDATE: bulk_tank|day_tank|drum|cylinder|tote|bag|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTemperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Max C' ;
    rdfs:comment 'Maximum allowable storage temperature for the chemical in degrees Celsius, as specified in the SDS. Exceeding this threshold may cause chemical degradation, hazardous reactions, or loss of treatment efficacy.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Min C' ;
    rdfs:comment 'Minimum allowable storage temperature for the chemical in degrees Celsius, as specified in the SDS. Ensures chemical integrity and prevents hazardous reactions due to improper storage conditions.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierPartNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Part Number' ;
    rdfs:comment 'Vendor-assigned part or catalog number for this chemical product as used in purchase orders and delivery documentation. Facilitates accurate procurement and receiving.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tier2ReportingYear rdf:type rdf:Property ;
    rdfs:label 'Tier2 Reporting Year' ;
    rdfs:comment 'Calendar year for which this chemical inventory record is applicable for OSHA EPCRA Section 312 Tier II annual hazardous chemical inventory reporting. Supports annual regulatory submission to state and local emergency planning committees.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'Cost per unit of measure for the chemical as established in the most recent purchase order or contract. Used for chemical cost tracking, OPEX budgeting, and treatment cost-per-gallon calculations. Expressed in USD.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctComplianceRecordId rdf:type rdf:Property ;
    rdfs:label 'Ct Compliance Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each CT compliance calculation record in the Silver Layer lakehouse. Primary key for this entity. Entity role: TRANSACTION_HEADER — represents a discrete regulatory compliance calculation event with a clear lifecycle under the Surface Water Treatment Rule (SWTR).' ;
    rdfs:domain ind:CtComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:treatmentUnitId rdf:type rdf:Property ;
    rdfs:label 'Treatment Unit Id' ;
    rdfs:comment 'Reference to the specific treatment unit or disinfection contact basin within the WTP where CT was measured (e.g., chlorine contact chamber, UV reactor, ozone contactor). Sourced from OSIsoft PI Historian asset hierarchy or IBM Maximo asset register.' ;
    rdfs:domain ind:CtComplianceRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessUnit .

ind:bafflingFactor rdf:type rdf:Property ;
    rdfs:label 'Baffling Factor' ;
    rdfs:comment 'The dimensionless baffling factor (T10/T) applied to the theoretical hydraulic detention time to calculate the effective T10 contact time. Ranges from 0.1 (poor baffling) to 1.0 (plug flow). Determined by tracer study or EPA baffling factor table per SWTR guidance.' ;
    rdfs:domain ind:CtComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contactTimeMin rdf:type rdf:Property ;
    rdfs:label 'Contact Time Min' ;
    rdfs:comment 'The effective hydraulic contact time (T10 — time for 10% of tracer to pass through) in minutes for the disinfection contact basin or reactor at the measured flow rate. T10 is the regulatory-accepted contact time per EPA guidance, accounting for short-circuiting.' ;
    rdfs:domain ind:CtComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctCalculated rdf:type rdf:Property ;
    rdfs:label 'Ct Calculated' ;
    rdfs:comment 'The actual CT (Contact Time for Disinfection) value achieved during the measurement period, expressed in mg/L·min (disinfectant concentration multiplied by contact time). This is the primary quantitative result of the compliance calculation. Sourced from SCADA/OSIsoft PI Historian real-time process data.' ;
    rdfs:domain ind:CtComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctRatio rdf:type rdf:Property ;
    rdfs:label 'Ct Ratio' ;
    rdfs:comment 'The ratio of CT calculated to CT required (ct_calculated / ct_required). A value >= 1.0 indicates compliance (pass); a value < 1.0 indicates a compliance failure. Critical metric for MOR regulatory submissions and EPA primacy agency reporting under SWTR.' ;
    rdfs:domain ind:CtComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctRequired rdf:type rdf:Property ;
    rdfs:label 'Ct Required' ;
    rdfs:comment 'The minimum CT value required by regulation to achieve the target log inactivation credit for Giardia lamblia and/or viruses, expressed in mg/L·min. Derived from EPA CT tables based on disinfectant type, temperature, and pH. Used as the denominator in the CT ratio calculation.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctTableReference rdf:type rdf:Property ;
    rdfs:label 'Ct Table Reference' ;
    rdfs:comment 'The specific EPA CT table identifier used to determine the required CT value for this calculation (e.g., \'Table C-1 Free Chlorine Giardia\', \'Table C-3 Chloramines Virus\'). Provides regulatory traceability for the ct_required value and supports MOR documentation.' ;
    rdfs:domain ind:CtComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disinfectantConcentration rdf:type rdf:Property ;
    rdfs:label 'Disinfectant Concentration' ;
    rdfs:comment 'The measured residual concentration of the disinfectant at the point of CT measurement, expressed in mg/L. For free chlorine, this is the free chlorine residual; for chloramines, the total chloramine residual. Sourced from SCADA/OSIsoft PI Historian or LIMS grab sample results.' ;
    rdfs:domain ind:CtComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:logInactivationAchieved rdf:type rdf:Property ;
    rdfs:label 'Log Inactivation Achieved' ;
    rdfs:comment 'The actual log inactivation credit achieved based on the calculated CT value, expressed as a log10 value. Derived from EPA CT tables using disinfectant type, temperature, pH, and ct_calculated. Compared against log_inactivation_required to determine compliance status.' ;
    rdfs:domain ind:CtComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:logInactivationRequired rdf:type rdf:Property ;
    rdfs:label 'Log Inactivation Required' ;
    rdfs:comment 'The minimum log inactivation credit required by regulation for the target organism at this treatment facility, expressed as a log10 value (e.g., 3.0 for Giardia, 4.0 for viruses). Determined by the primacy agency based on source water quality and treatment technique requirements.' ;
    rdfs:domain ind:CtComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatorVerificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Operator Verification Timestamp' ;
    rdfs:comment 'The timestamp when the certified operator verified and approved this CT compliance calculation record. Provides audit trail for regulatory defensibility. Null if operator_verified = False. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:CtComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:operatorVerified rdf:type rdf:Property ;
    rdfs:label 'Operator Verified' ;
    rdfs:comment 'Indicates whether a certified water treatment plant operator has reviewed and verified the accuracy of this CT compliance calculation record (True = verified; False = pending verification). Required for regulatory defensibility of MOR submissions.' ;
    rdfs:domain ind:CtComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:piTagConcentration rdf:type rdf:Property ;
    rdfs:label 'Pi Tag Concentration' ;
    rdfs:comment 'The OSIsoft PI Historian tag name for the disinfectant concentration measurement used in this CT calculation (e.g., \'WTP01.CL2.RESIDUAL.MGL\'). Enables direct traceability from the compliance record back to the source PI Historian time-series data point for audit and verification.' ;
    rdfs:domain ind:CtComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piTagFlow rdf:type rdf:Property ;
    rdfs:label 'Pi Tag Flow' ;
    rdfs:comment 'The OSIsoft PI Historian tag name for the flow rate measurement used in this CT calculation (e.g., \'WTP01.FLOW.INFLUENT.MGD\'). Enables direct traceability from the compliance record back to the source PI Historian time-series data point for audit and verification.' ;
    rdfs:domain ind:CtComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordNumber rdf:type rdf:Property ;
    rdfs:label 'Record Number' ;
    rdfs:comment 'Externally-known business identifier for this CT compliance calculation record, formatted as CT-{YYYY}-{MM}-{NNNNNN}. Used in Monthly Operating Reports (MOR) and EPA primacy agency submissions to uniquely reference a specific compliance calculation event.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End' ;
    rdfs:comment 'The end date of the regulatory reporting period to which this CT compliance record belongs. Together with reporting_period_start, defines the MOR submission window for CT compliance data to the EPA primacy agency.' ;
    rdfs:domain ind:CtComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start' ;
    rdfs:comment 'The start date of the regulatory reporting period (typically monthly) to which this CT compliance record belongs. Used for aggregating CT compliance data into Monthly Operating Reports (MOR) and Discharge Monitoring Reports (DMR) submitted to the primacy agency.' ;
    rdfs:domain ind:CtComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:t10Basis rdf:type rdf:Property ;
    rdfs:label 'T10 Basis' ;
    rdfs:comment 'The method used to establish the T10 hydraulic contact time for the disinfection basin. \'tracer_study\' = validated tracer study per EPA guidance; \'baffling_factor\' = EPA baffling factor table applied to theoretical detention time; \'cfd_model\' = computational fluid dynamics model; \'conservative_estimate\' = conservative regulatory default.' ;
    rdfs:domain ind:CtComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetOrganism rdf:type rdf:Property ;
    rdfs:label 'Target Organism' ;
    rdfs:comment 'The pathogenic organism for which the CT log inactivation credit is being calculated. \'giardia\' = Giardia lamblia (3-log inactivation required under SWTR); \'virus\' = enteric viruses (4-log inactivation); \'cryptosporidium\' = Cryptosporidium parvum (LT2ESWTR); \'combined\' = combined credit calculation.' ;
    rdfs:domain ind:CtComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:theoreticalDetentionTimeMin rdf:type rdf:Property ;
    rdfs:label 'Theoretical Detention Time Min' ;
    rdfs:comment 'The theoretical hydraulic detention time (volume / flow rate) of the disinfection contact basin in minutes, before applying the baffling factor to derive T10. Used in conjunction with baffling_factor to calculate contact_time_min.' ;
    rdfs:domain ind:CtComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uvDoseMjCm2 rdf:type rdf:Property ;
    rdfs:label 'Uv Dose Mj Cm2' ;
    rdfs:comment 'The measured UV (Ultraviolet Disinfection) dose delivered by the UV reactor, expressed in mJ/cm² (millijoules per square centimeter). Applicable only when disinfectant_type = \'uv\'. UV dose replaces concentration-based CT for UV disinfection compliance under SWTR and LT2ESWTR. Sourced from UV reactor SCADA/PI Historian.' ;
    rdfs:domain ind:CtComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:filterRunId rdf:type rdf:Property ;
    rdfs:label 'Filter Run Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual filter run record in the water treatment process. Primary key for the filter_run data product.' ;
    rdfs:domain ind:FilterRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backwashSequenceBackwashEventId rdf:type rdf:Property ;
    rdfs:label 'Backwash Sequence Backwash Event Id' ;
    rdfs:comment 'Reference to the backwash cycle record that was triggered at the end of this filter run. Links the filter run to its associated backwash event for end-to-end filter cycle analysis and backwash optimization.' ;
    rdfs:domain ind:FilterRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BackwashEvent .

ind:backwashTriggerReason rdf:type rdf:Property ;
    rdfs:label 'Backwash Trigger Reason' ;
    rdfs:comment 'The primary reason that terminated this filter run and initiated a backwash cycle. \'time\' indicates the run reached its maximum configured duration; \'head_loss\' indicates terminal head loss threshold was reached; \'turbidity_breakthrough\' indicates effluent turbidity exceeded the threshold; \'operator_initiated\' indicates manual operator decision; \'scheduled\' indicates a pre-programmed backwash schedule; \'emergency\' indicates an unplanned operational event.' ;
    rdfs:domain ind:FilterRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coagulantDoseMgL rdf:type rdf:Property ;
    rdfs:label 'Coagulant Dose Mg L' ;
    rdfs:comment 'The coagulant chemical dose applied upstream of the filter during this run, expressed in milligrams per liter (mg/L). Coagulation quality directly impacts filter performance and turbidity removal efficiency. Sourced from chemical dosing SCADA records.' ;
    rdfs:domain ind:FilterRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysSinceLastBackwash rdf:type rdf:Property ;
    rdfs:label 'Days Since Last Backwash' ;
    rdfs:comment 'Number of calendar days elapsed since the previous backwash cycle for this filter unit, at the time this run commenced. Used to assess backwash frequency compliance and filter maintenance scheduling.' ;
    rdfs:domain ind:FilterRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:filterToWasteDurationMin rdf:type rdf:Property ;
    rdfs:label 'Filter To Waste Duration Min' ;
    rdfs:comment 'Duration in minutes of the filter-to-waste (ripening) phase at the start of this filter run. Null if filter_to_waste_flag is False. Used to optimize ripening time and minimize water loss while ensuring effluent quality compliance.' ;
    rdfs:domain ind:FilterRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:filterToWasteFlag rdf:type rdf:Property ;
    rdfs:label 'Filter To Waste Flag' ;
    rdfs:comment 'Indicates whether a filter-to-waste (ripening) phase was employed at the start of this filter run, diverting initial effluent to waste rather than the distribution system. Filter-to-waste is used to prevent turbidity spikes from entering the treated water supply during the filter ripening period post-backwash.' ;
    rdfs:domain ind:FilterRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:filterToWasteVolumeMg rdf:type rdf:Property ;
    rdfs:label 'Filter To Waste Volume Mg' ;
    rdfs:comment 'Volume of water in Million Gallons (MG) diverted to waste during the filter-to-waste ripening phase. Contributes to Non-Revenue Water (NRW) calculations and water loss accounting. Null if filter_to_waste_flag is False.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headLossThresholdFt rdf:type rdf:Property ;
    rdfs:label 'Head Loss Threshold Ft' ;
    rdfs:comment 'The maximum allowable head loss in feet of water column configured for this filter unit, above which a backwash is automatically triggered. Stored per run to capture any threshold changes over time for audit and optimization purposes.' ;
    rdfs:domain ind:FilterRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hydraulicLoadingRateGpmSqft rdf:type rdf:Property ;
    rdfs:label 'Hydraulic Loading Rate Gpm Sqft' ;
    rdfs:comment 'The hydraulic loading rate applied to the filter during this run, expressed as Gallons Per Minute per square foot of filter surface area. A key operational parameter for filter performance assessment and comparison against AWWA design standards.' ;
    rdfs:domain ind:FilterRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:influentTurbidityNtu rdf:type rdf:Property ;
    rdfs:label 'Influent Turbidity Ntu' ;
    rdfs:comment 'Turbidity of the water entering the filter at the start of the run, measured in Nephelometric Turbidity Units (NTU). Provides context for filter loading conditions and is used in performance analysis and regulatory compliance reporting.' ;
    rdfs:domain ind:FilterRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:initialEffluentTurbidityNtu rdf:type rdf:Property ;
    rdfs:label 'Initial Effluent Turbidity Ntu' ;
    rdfs:comment 'Turbidity of the filtered water (effluent) at the beginning of the filter run, measured in Nephelometric Turbidity Units (NTU). Establishes the baseline effluent quality at run start for performance trending.' ;
    rdfs:domain ind:FilterRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:initialHeadLossFt rdf:type rdf:Property ;
    rdfs:label 'Initial Head Loss Ft' ;
    rdfs:comment 'Differential pressure head loss across the filter media at the start of the filter run, measured in feet of water column. Establishes the baseline for head loss progression monitoring and backwash trigger evaluation.' ;
    rdfs:domain ind:FilterRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:particleCountPerMl rdf:type rdf:Property ;
    rdfs:label 'Particle Count Per Ml' ;
    rdfs:comment 'Average particle count in the filter effluent during this run, expressed as particles per milliliter. Particle counting provides a more sensitive measure of filter performance than turbidity alone and is used for Cryptosporidium and Giardia removal credit under the LT2ESWTR.' ;
    rdfs:domain ind:FilterRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakEffluentTurbidityNtu rdf:type rdf:Property ;
    rdfs:label 'Peak Effluent Turbidity Ntu' ;
    rdfs:comment 'The highest turbidity reading recorded in the filter effluent during the run, measured in NTU. Critical for regulatory compliance — the EPA Surface Water Treatment Rule requires individual filter effluent turbidity not to exceed 1.0 NTU (or 0.3 NTU in 95% of measurements). Triggers turbidity breakthrough alerts.' ;
    rdfs:domain ind:FilterRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:runDurationHours rdf:type rdf:Property ;
    rdfs:label 'Run Duration Hours' ;
    rdfs:comment 'Total elapsed time of the filter run in hours, from run_start_timestamp to run_end_timestamp. Used for filter performance benchmarking, backwash frequency analysis, and O&M optimization. Populated upon run completion.' ;
    rdfs:domain ind:FilterRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:runSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Run Sequence Number' ;
    rdfs:comment 'Sequential count of filter runs for this filter unit since the last media replacement or major rehabilitation. Used to track cumulative filter usage, assess media aging, and plan media replacement schedules.' ;
    rdfs:domain ind:FilterRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:terminalEffluentTurbidityNtu rdf:type rdf:Property ;
    rdfs:label 'Terminal Effluent Turbidity Ntu' ;
    rdfs:comment 'Turbidity of the filter effluent at the end of the run (at backwash trigger or run termination), measured in NTU. Used to assess whether turbidity breakthrough was the cause of run termination and for regulatory compliance documentation.' ;
    rdfs:domain ind:FilterRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminalHeadLossFt rdf:type rdf:Property ;
    rdfs:label 'Terminal Head Loss Ft' ;
    rdfs:comment 'Differential pressure head loss across the filter media at the end of the filter run (at backwash trigger or run termination), measured in feet of water column. Used to assess filter loading and determine if head loss was the backwash trigger. Compared against the head loss threshold to evaluate filter condition.' ;
    rdfs:domain ind:FilterRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tocEffluentMgL rdf:type rdf:Property ;
    rdfs:label 'Toc Effluent Mg L' ;
    rdfs:comment 'Total Organic Carbon (TOC) concentration in the filter effluent during this run, measured in mg/L. Used to calculate TOC removal efficiency across the filter and assess GAC adsorption capacity. Sourced from LIMS or inline TOC analyzers.' ;
    rdfs:domain ind:FilterRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tocInfluentMgL rdf:type rdf:Property ;
    rdfs:label 'Toc Influent Mg L' ;
    rdfs:comment 'Total Organic Carbon (TOC) concentration in the filter influent during this run, measured in mg/L. TOC is a key parameter for GAC filter performance assessment and Disinfection Byproduct (DBP) precursor removal tracking. Sourced from LIMS or inline TOC analyzers.' ;
    rdfs:domain ind:FilterRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:turbidityMclExceedance rdf:type rdf:Property ;
    rdfs:label 'Turbidity Mcl Exceedance' ;
    rdfs:comment 'Indicates whether the peak effluent turbidity during this filter run exceeded the regulatory Maximum Contaminant Level (MCL) threshold of 1.0 NTU as defined by the EPA Surface Water Treatment Rule. True triggers regulatory notification and MOR documentation requirements.' ;
    rdfs:domain ind:FilterRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:turbidityThresholdNtu rdf:type rdf:Property ;
    rdfs:label 'Turbidity Threshold Ntu' ;
    rdfs:comment 'The effluent turbidity level in NTU configured as the breakthrough trigger for this filter unit. When peak_effluent_turbidity_ntu exceeds this value, a backwash may be triggered. Stored per run to capture threshold configuration at time of run.' ;
    rdfs:domain ind:FilterRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeFilteredMg rdf:type rdf:Property ;
    rdfs:label 'Volume Filtered Mg' ;
    rdfs:comment 'Total volume of water processed through the filter unit during this run, expressed in Million Gallons (MG). A key performance indicator for filter throughput and backwash optimization. Sourced from SCADA flow meters integrated with OSIsoft PI Historian.' ;
    rdfs:domain ind:FilterRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionPumpStationId rdf:type rdf:Property ;
    rdfs:label 'Distribution Pump Station Id' ;
    rdfs:comment 'Foreign key linking to distribution.pump_station. Business justification: Finished water is pumped into distribution via specific pump stations. Essential for tracking the physical handoff between treatment and distribution, hydraulic modeling, and water quality tracing. Op' ;
    rdfs:domain ind:FinishedWaterProduction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PumpStation .

ind:primaryFinishedEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Finished Employee Id' ;
    rdfs:comment 'Reference to the licensed water treatment operator responsible for this production shift. Used for operator accountability, regulatory certification compliance, and shift-level quality ownership. Links to workforce/employee master data.' ;
    rdfs:domain ind:FinishedWaterProduction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:productionMeterInstallationId rdf:type rdf:Property ;
    rdfs:label 'Production Meter Installation Id' ;
    rdfs:comment 'Foreign key linking to metering.installation. Business justification: Finished water production records must reference the master meter installation measuring total plant output for regulatory compliance. MOR/DMR submissions require certified metered production volumes.' ;
    rdfs:domain ind:FinishedWaterProduction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Installation .

ind:avgProductionRateGpm rdf:type rdf:Property ;
    rdfs:label 'Avg Production Rate Gpm' ;
    rdfs:comment 'Average finished water production flow rate during this production period, measured in Gallons per Minute (GPM). Derived from SCADA/OSIsoft PI Historian flow meter data. Used for hydraulic loading analysis, pump performance monitoring, and comparison against design flow rates.' ;
    rdfs:domain ind:FinishedWaterProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backwashVolumeMg rdf:type rdf:Property ;
    rdfs:label 'Backwash Volume Mg' ;
    rdfs:comment 'Volume of water used specifically for filter backwash operations during this production period, measured in Million Gallons (MG). A sub-component of plant operations water. Tracked separately for filter performance monitoring and optimization of backwash frequency and duration.' ;
    rdfs:domain ind:FinishedWaterProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chemicalDosingEvent rdf:type rdf:Property ;
    rdfs:label 'Chemical Dosing Event' ;
    rdfs:comment 'Indicates whether any unplanned or emergency chemical dosing event occurred during this production period (True = yes, False = no). Flags records requiring additional review in LIMS or SCADA systems. Supports operational exception reporting and chemical usage variance analysis.' ;
    rdfs:domain ind:FinishedWaterProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cl2ResidualAvgMgL rdf:type rdf:Property ;
    rdfs:label 'Cl2 Residual Avg Mg L' ;
    rdfs:comment 'Average free chlorine residual concentration in finished water at the WTP effluent during this production period, measured in milligrams per liter (mg/L). Must meet the minimum residual disinfectant level of 0.2 mg/L at the point of entry to the distribution system. Critical for disinfection compliance and MOR reporting.' ;
    rdfs:domain ind:FinishedWaterProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cl2ResidualMinMgL rdf:type rdf:Property ;
    rdfs:label 'Cl2 Residual Min Mg L' ;
    rdfs:comment 'Minimum free chlorine residual concentration recorded in finished water during this production period, measured in milligrams per liter (mg/L). Tracked to identify potential disinfection deficiency events. Any reading below 0.2 mg/L triggers regulatory notification requirements.' ;
    rdfs:domain ind:FinishedWaterProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctAchievedMgMinL rdf:type rdf:Property ;
    rdfs:label 'Ct Achieved Mg Min L' ;
    rdfs:comment 'Actual disinfection Contact Time (CT) value achieved during this production period, expressed in mg·min/L (disinfectant concentration × contact time). Must meet or exceed the CT required for 3-log Giardia and 4-log virus inactivation under the Surface Water Treatment Rule (SWTR). A critical regulatory compliance metric reported in MOR submissions.' ;
    rdfs:domain ind:FinishedWaterProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctRequiredMgMinL rdf:type rdf:Property ;
    rdfs:label 'Ct Required Mg Min L' ;
    rdfs:comment 'Minimum required disinfection Contact Time (CT) value for this production period based on source water temperature and pH, expressed in mg·min/L. Determined from EPA CT tables for the applicable disinfectant. Stored alongside achieved CT to enable direct compliance gap analysis without recalculation.' ;
    rdfs:domain ind:FinishedWaterProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finishedWaterVolumeMg rdf:type rdf:Property ;
    rdfs:label 'Finished Water Volume Mg' ;
    rdfs:comment 'Total volume of finished (treated) water produced by the WTP during this production period, measured in Million Gallons (MG). This is the primary production output metric used in MOR reporting, water balance calculations, and capacity utilization analysis. Sourced from SCADA/OSIsoft PI Historian clearwell/effluent flow meters.' ;
    rdfs:domain ind:FinishedWaterProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakProductionRateGpm rdf:type rdf:Property ;
    rdfs:label 'Peak Production Rate Gpm' ;
    rdfs:comment 'Maximum instantaneous finished water production flow rate recorded during this production period, measured in Gallons per Minute (GPM). Sourced from SCADA/OSIsoft PI Historian. Used for peak demand analysis, pump sizing validation, and hydraulic capacity planning.' ;
    rdfs:domain ind:FinishedWaterProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plantEfficiencyRatio rdf:type rdf:Property ;
    rdfs:label 'Plant Efficiency Ratio' ;
    rdfs:comment 'Ratio of finished water volume produced to source water volume intake, expressed as a decimal (e.g., 0.9250 = 92.50% efficiency). Calculated as finished_water_volume_mg / source_water_volume_mg. A key operational Key Performance Indicator (KPI) for WTP performance benchmarking and water loss identification. Stored as a raw ratio to support analytics without recalculation.' ;
    rdfs:domain ind:FinishedWaterProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plantOpsWaterVolumeMg rdf:type rdf:Property ;
    rdfs:label 'Plant Ops Water Volume Mg' ;
    rdfs:comment 'Total volume of finished water consumed for internal plant operations during this production period, measured in Million Gallons (MG). Includes filter backwash water, filter-to-waste volumes, and other in-plant process uses. Used in water balance accounting and plant efficiency calculations.' ;
    rdfs:domain ind:FinishedWaterProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionDate rdf:type rdf:Property ;
    rdfs:label 'Production Date' ;
    rdfs:comment 'Calendar date on which the finished water production occurred (yyyy-MM-dd). The principal real-world event date for this production record. Used as the primary time dimension for MOR reporting, water balance calculations, and daily production trend analysis. Serves as the BUSINESS_EVENT_TIMESTAMP category for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Production Record Number' ;
    rdfs:comment 'Externally-known business identifier for this production record, used in Monthly Operating Reports (MOR) and regulatory submissions. Format: WTP-PRD-YYYY-MM-DD-SHIFT. Serves as the BUSINESS_IDENTIFIER category for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:FinishedWaterProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionStatus rdf:type rdf:Property ;
    rdfs:label 'Production Status' ;
    rdfs:comment 'Current lifecycle state of the production record workflow. \'draft\' indicates data entry in progress; \'submitted\' indicates sent for supervisor review; \'approved\' indicates validated and accepted for MOR reporting; \'rejected\' indicates returned for correction; \'superseded\' indicates replaced by a corrected record. Serves as the LIFECYCLE_STATUS category for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftCode rdf:type rdf:Property ;
    rdfs:label 'Shift Code' ;
    rdfs:comment 'Operational shift during which this production record applies. \'DAY\' typically covers 06:00–14:00, \'EVENING\' covers 14:00–22:00, \'NIGHT\' covers 22:00–06:00, and \'FULL_DAY\' represents a consolidated 24-hour daily record. Used for shift-level production analysis and operator accountability.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Shift End Timestamp' ;
    rdfs:comment 'Exact timestamp when the production shift ended (yyyy-MM-ddTHH:mm:ss.SSSXXX). Used to precisely bound the production measurement window for SCADA/OSIsoft PI Historian data integration and shift-level volume reconciliation.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Shift Start Timestamp' ;
    rdfs:comment 'Exact timestamp when the production shift began (yyyy-MM-ddTHH:mm:ss.SSSXXX). Used to precisely bound the production measurement window for SCADA/OSIsoft PI Historian data integration and shift-level volume reconciliation.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceWaterVolumeMg rdf:type rdf:Property ;
    rdfs:label 'Source Water Volume Mg' ;
    rdfs:comment 'Total volume of raw source water drawn into the WTP during this production period, measured in Million Gallons (MG). Used as the input denominator for plant efficiency ratio calculations and water balance accounting. Sourced from SCADA/OSIsoft PI Historian intake flow meters.' ;
    rdfs:domain ind:FinishedWaterProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureAvgC rdf:type rdf:Property ;
    rdfs:label 'Temperature Avg C' ;
    rdfs:comment 'Average temperature of finished water at the WTP effluent during this production period, measured in degrees Celsius (°C). Temperature affects disinfection Contact Time (CT) calculations, chlorine decay rates, and distribution system water quality. Sourced from SCADA/OSIsoft PI Historian.' ;
    rdfs:domain ind:FinishedWaterProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tocAvgMgL rdf:type rdf:Property ;
    rdfs:label 'Toc Avg Mg L' ;
    rdfs:comment 'Average Total Organic Carbon (TOC) concentration in finished water during this production period, measured in milligrams per liter (mg/L). TOC is a precursor to Disinfection Byproducts (DBPs) including Trihalomethanes (THMs) and Haloacetic Acids (HAA5). Monitored for Stage 2 Disinfectants and Disinfection Byproducts Rule (DBPR) compliance.' ;
    rdfs:domain ind:FinishedWaterProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentProcessType rdf:type rdf:Property ;
    rdfs:label 'Treatment Process Type' ;
    rdfs:comment 'Primary treatment process technology employed at the WTP for this production record. \'CONVENTIONAL\' includes coagulation/flocculation/sedimentation/filtration; \'DIRECT_FILTRATION\' omits sedimentation; \'MEMBRANE\' includes Reverse Osmosis (RO), Ultrafiltration (UF), or Microfiltration (MF); \'SOFTENING\' includes lime softening; \'GROUNDWATER\' includes well-based supply with disinfection only.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turbidityAvgNtu rdf:type rdf:Property ;
    rdfs:label 'Turbidity Avg Ntu' ;
    rdfs:comment 'Average turbidity of finished water measured at the WTP effluent during this production period, in Nephelometric Turbidity Units (NTU). Must comply with the Surface Water Treatment Rule (SWTR) maximum of 0.3 NTU in 95% of monthly samples. Primary finished water quality summary metric for MOR reporting.' ;
    rdfs:domain ind:FinishedWaterProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:turbidityMaxNtu rdf:type rdf:Property ;
    rdfs:label 'Turbidity Max Ntu' ;
    rdfs:comment 'Maximum turbidity value recorded in finished water at the WTP effluent during this production period, in Nephelometric Turbidity Units (NTU). The regulatory Maximum Contaminant Level (MCL) for turbidity is 1 NTU. Tracked separately from average to identify peak exceedance events for regulatory reporting.' ;
    rdfs:domain ind:FinishedWaterProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumePumpedToDistributionMg rdf:type rdf:Property ;
    rdfs:label 'Volume Pumped To Distribution Mg' ;
    rdfs:comment 'Total volume of finished water pumped from the WTP clearwell into the distribution network during this production period, measured in Million Gallons (MG). Distinct from finished water produced — the difference represents storage changes. Critical for water balance and Non-Revenue Water (NRW) calculations.' ;
    rdfs:domain ind:FinishedWaterProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:membranePerformanceId rdf:type rdf:Property ;
    rdfs:label 'Membrane Performance Id' ;
    rdfs:comment 'Unique surrogate identifier for each membrane performance record in the Silver Layer lakehouse. Primary key for this data product.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backwashFrequencyPerDay rdf:type rdf:Property ;
    rdfs:label 'Backwash Frequency Per Day' ;
    rdfs:comment 'Number of backwash cycles performed per day on the membrane unit. Applicable to UF and MF systems. Increasing frequency indicates fouling progression and may trigger a chemical cleaning event.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chemicalCleaningCount rdf:type rdf:Property ;
    rdfs:label 'Chemical Cleaning Count' ;
    rdfs:comment 'Cumulative number of chemical cleaning events (Clean-In-Place / CIP) performed on this membrane unit since installation. Excessive cleaning frequency indicates accelerated fouling and may signal replacement need.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cleaningChemicalType rdf:type rdf:Property ;
    rdfs:label 'Cleaning Chemical Type' ;
    rdfs:comment 'Type of chemical agent used in the most recent Clean-In-Place (CIP) cleaning event (e.g., citric acid, sodium hydroxide, sodium hypochlorite, EDTA, enzyme cleaner). Relevant for chemical compatibility and O&M cost tracking. [ENUM-REF-CANDIDATE: citric_acid|sodium_hydroxide|sodium_hypochlorite|EDTA|enzyme|sulfuric_acid|hydrochloric_acid — promote to reference product]' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentratePressurePsi rdf:type rdf:Property ;
    rdfs:label 'Concentrate Pressure Psi' ;
    rdfs:comment 'Pressure of the concentrate (reject) stream exiting the membrane system in Pounds per Square Inch (PSI). Used in net driving pressure calculations and energy recovery assessments.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feedFlowRateGpm rdf:type rdf:Property ;
    rdfs:label 'Feed Flow Rate Gpm' ;
    rdfs:comment 'Volumetric flow rate of feed water entering the membrane system in Gallons Per Minute (GPM). Sourced from OSIsoft PI Historian SCADA data.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feedPressurePsi rdf:type rdf:Property ;
    rdfs:label 'Feed Pressure Psi' ;
    rdfs:comment 'Inlet feed water pressure to the membrane system in Pounds per Square Inch (PSI). Used to calculate net driving pressure and assess pump performance.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feedTdsMgL rdf:type rdf:Property ;
    rdfs:label 'Feed Tds Mg L' ;
    rdfs:comment 'Total Dissolved Solids (TDS) concentration of the feed water in milligrams per litre (mg/L). Used to calculate salt rejection rate for RO systems and assess scaling potential.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feedTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Feed Temperature C' ;
    rdfs:comment 'Temperature of the feed water in degrees Celsius at the membrane inlet. Used for temperature correction of normalized flux calculations per ASTM D6908. Lower temperatures increase viscosity and reduce flux.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feedTurbidityNtu rdf:type rdf:Property ;
    rdfs:label 'Feed Turbidity Ntu' ;
    rdfs:comment 'Turbidity of the feed water entering the membrane system measured in Nephelometric Turbidity Units (NTU). Elevated feed turbidity increases fouling rate and cleaning frequency.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fluxDeclinePct rdf:type rdf:Property ;
    rdfs:label 'Flux Decline Pct' ;
    rdfs:comment 'Percentage decline in normalized permeate flux from the baseline (clean membrane) value, calculated as (baseline flux - current flux) / baseline flux × 100. Triggers chemical cleaning when threshold is exceeded per O&M protocol.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:foulingIndex rdf:type rdf:Property ;
    rdfs:label 'Fouling Index' ;
    rdfs:comment 'Silt Density Index (SDI) or Modified Fouling Index (MFI) of the feed water, indicating the fouling potential. Higher values indicate greater particulate loading and predict more frequent cleaning cycles. Applicable primarily to RO systems.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:integrityTestDate rdf:type rdf:Property ;
    rdfs:label 'Integrity Test Date' ;
    rdfs:comment 'Date on which the most recent Direct Integrity Test (DIT) was performed on the membrane unit. Required at minimum daily under EPA LT2ESWTR for membrane systems claiming Cryptosporidium log removal credit.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:integrityTestResult rdf:type rdf:Property ;
    rdfs:label 'Integrity Test Result' ;
    rdfs:comment 'Outcome of the Direct Integrity Test (DIT) or pressure decay test for the membrane unit: pass, fail, or inconclusive. A fail result triggers regulatory notification and corrective action under EPA LT2ESWTR.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastChemicalCleaningDate rdf:type rdf:Property ;
    rdfs:label 'Last Chemical Cleaning Date' ;
    rdfs:comment 'Date of the most recent chemical cleaning event (Clean-In-Place / CIP) performed on the membrane unit. Used to track cleaning frequency and correlate with performance recovery.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:logRemovalValue rdf:type rdf:Property ;
    rdfs:label 'Log Removal Value' ;
    rdfs:comment 'Calculated Log Removal Value (LRV) for Cryptosporidium or other target pathogens based on the integrity test results. Must meet or exceed the treatment credit assigned by the state primacy agency under EPA LT2ESWTR.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:membraneAgeDays rdf:type rdf:Property ;
    rdfs:label 'Membrane Age Days' ;
    rdfs:comment 'Number of days the membrane has been in service since installation date. Used for lifecycle management, replacement planning, and performance degradation trending.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:membraneConfiguration rdf:type rdf:Property ;
    rdfs:label 'Membrane Configuration' ;
    rdfs:comment 'Physical configuration of the membrane element: spiral wound (common for RO/NF), hollow fiber (common for UF/MF), tubular, or flat sheet. Affects cleaning protocols and flux benchmarks.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membraneTechnologyType rdf:type rdf:Property ;
    rdfs:label 'Membrane Technology Type' ;
    rdfs:comment 'Classification of the membrane filtration technology: Reverse Osmosis (RO), Ultrafiltration (UF), Microfiltration (MF), Nanofiltration (NF), or Electrodialysis Reversal (EDR). Drives applicable performance benchmarks and regulatory thresholds.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membraneUnitTag rdf:type rdf:Property ;
    rdfs:label 'Membrane Unit Tag' ;
    rdfs:comment 'Plant-level equipment tag identifier for the specific membrane module, rack, or train (e.g., MEM-RO-01, UF-RACK-03). Aligns with P&ID and SCADA/HMI tag naming conventions.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:morReportable rdf:type rdf:Property ;
    rdfs:label 'Mor Reportable' ;
    rdfs:comment 'Indicates whether this performance record contains data that must be included in the Monthly Operating Report (MOR) submitted to the state primacy agency. Supports regulatory compliance workflow.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:normalizedPermeateFlux rdf:type rdf:Property ;
    rdfs:label 'Normalized Permeate Flux' ;
    rdfs:comment 'Temperature-corrected normalized permeate flux in litres per square metre per hour (L/m²/h). The principal performance indicator for membrane productivity; decline over time indicates fouling or scaling. Normalized to 25°C per ASTM D6908.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:observationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Observation Timestamp' ;
    rdfs:comment 'The principal real-world timestamp when the membrane performance measurement or test was recorded, sourced from OSIsoft PI Historian or SCADA system. Distinct from record audit timestamps.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:permeateFlowRateGpm rdf:type rdf:Property ;
    rdfs:label 'Permeate Flow Rate Gpm' ;
    rdfs:comment 'Volumetric flow rate of product water (permeate) exiting the membrane system in Gallons Per Minute (GPM). Used to calculate system recovery and normalized flux.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permeatePressurePsi rdf:type rdf:Property ;
    rdfs:label 'Permeate Pressure Psi' ;
    rdfs:comment 'Pressure on the permeate (product water) side of the membrane in Pounds per Square Inch (PSI). Used in TMP calculation and system hydraulic analysis.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permeateTdsMgL rdf:type rdf:Property ;
    rdfs:label 'Permeate Tds Mg L' ;
    rdfs:comment 'Total Dissolved Solids (TDS) concentration of the permeate (product water) in milligrams per litre (mg/L). Used to calculate salt rejection rate and verify finished water quality compliance.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permeateTurbidityNtu rdf:type rdf:Property ;
    rdfs:label 'Permeate Turbidity Ntu' ;
    rdfs:comment 'Turbidity of the permeate (filtered product water) exiting the membrane system in Nephelometric Turbidity Units (NTU). Must meet MCL of 0.3 NTU (95th percentile) under EPA Surface Water Treatment Rule.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pressureDecayRate rdf:type rdf:Property ;
    rdfs:label 'Pressure Decay Rate' ;
    rdfs:comment 'Rate of pressure decay (psi/min or kPa/min) measured during a Direct Integrity Test (DIT) / pressure decay test. Exceeding the control limit indicates a breach in membrane integrity requiring investigation per EPA LT2ESWTR.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveryRatePct rdf:type rdf:Property ;
    rdfs:label 'Recovery Rate Pct' ;
    rdfs:comment 'Percentage of feed water converted to permeate (product water), calculated as (permeate flow / feed flow) × 100. Higher recovery reduces waste but increases scaling risk. Key operational efficiency metric.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replacementRecommended rdf:type rdf:Property ;
    rdfs:label 'Replacement Recommended' ;
    rdfs:comment 'Flag indicating whether the membrane unit has been assessed as requiring replacement based on performance degradation, age, or failed integrity tests. Drives capital planning and procurement activities.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:saltRejectionRatePct rdf:type rdf:Property ;
    rdfs:label 'Salt Rejection Rate Pct' ;
    rdfs:comment 'Percentage of dissolved salts (Total Dissolved Solids / TDS) rejected by the RO or NF membrane, calculated as (1 - permeate TDS / feed TDS) × 100. Applicable to RO and NF systems only. Decline indicates membrane integrity loss.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specificEnergyConsumptionKwhM3 rdf:type rdf:Property ;
    rdfs:label 'Specific Energy Consumption Kwh M3' ;
    rdfs:comment 'Energy consumed per cubic metre of permeate produced (kWh/m³). Key operational efficiency and OPEX metric for membrane systems, particularly RO. Increasing values indicate pump inefficiency or fouling.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tmpIncreasePct rdf:type rdf:Property ;
    rdfs:label 'Tmp Increase Pct' ;
    rdfs:comment 'Percentage increase in Transmembrane Pressure (TMP) from the baseline (clean membrane) value. A TMP increase exceeding the O&M threshold (typically 15-20%) triggers a chemical cleaning event.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transmembranePressurePsi rdf:type rdf:Property ;
    rdfs:label 'Transmembrane Pressure Psi' ;
    rdfs:comment 'Transmembrane Pressure (TMP) measured in Pounds per Square Inch (PSI), representing the pressure differential across the membrane. Rising TMP at constant flux indicates fouling. Key SCADA-sourced process control parameter.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:turbidityRemovalEfficiencyPct rdf:type rdf:Property ;
    rdfs:label 'Turbidity Removal Efficiency Pct' ;
    rdfs:comment 'Percentage reduction in turbidity (NTU) across the membrane system, calculated as (1 - permeate NTU / feed NTU) × 100. Applicable to UF and MF systems. Regulatory compliance metric under EPA LT2ESWTR.' ;
    rdfs:domain ind:MembranePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceMorId rdf:type rdf:Property ;
    rdfs:label 'Compliance Mor Id' ;
    rdfs:comment 'Foreign key linking to compliance.mor. Business justification: Treatment MOR submissions feed compliance MOR records for regulatory submission. Business process: monthly operating report workflows where treatment operators prepare operational data (production, CT' ;
    rdfs:domain ind:MorSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Mor .

ind:originalSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Original Submission Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the original MOR submission record when this record is a resubmission or amendment. Null for original submissions. Enables lineage tracking across submission versions.' ;
    rdfs:domain ind:MorSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MorSubmission .

ind:supervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Supervisor Employee Id' ;
    rdfs:comment 'Identifier of the supervising operator or plant manager who reviewed and approved the monthly operating report before submission.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:avgDailyFlowMgd rdf:type rdf:Property ;
    rdfs:label 'Avg Daily Flow Mgd' ;
    rdfs:comment 'Average daily flow volume processed at the facility during the reporting month, expressed in Million Gallons per Day (MGD). Key operational metric reported in MOR and used for capacity planning and regulatory compliance.' ;
    rdfs:domain ind:MorSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgTurbidityNtu rdf:type rdf:Property ;
    rdfs:label 'Avg Turbidity Ntu' ;
    rdfs:comment 'Average turbidity of finished water or effluent during the reporting month, measured in Nephelometric Turbidity Units (NTU). Reported in MOR as an indicator of filtration and treatment effectiveness.' ;
    rdfs:domain ind:MorSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bodAvgMgL rdf:type rdf:Property ;
    rdfs:label 'Bod Avg Mg L' ;
    rdfs:comment 'Average Biochemical Oxygen Demand (BOD) of treated effluent during the reporting month, expressed in milligrams per liter (mg/L). Applicable to WWTP/STP MOR submissions; reported for NPDES permit compliance against effluent limits.' ;
    rdfs:domain ind:MorSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chlorineResidualAvgMgL rdf:type rdf:Property ;
    rdfs:label 'Chlorine Residual Avg Mg L' ;
    rdfs:comment 'Average free or total chlorine residual concentration in finished water or distribution system during the reporting month, expressed in milligrams per liter (mg/L). Reported in MOR to demonstrate disinfection maintenance compliance.' ;
    rdfs:domain ind:MorSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chlorineResidualComplianceMet rdf:type rdf:Property ;
    rdfs:label 'Chlorine Residual Compliance Met' ;
    rdfs:comment 'Indicates whether chlorine residual levels in the distribution system during the reporting month met the minimum required disinfectant residual of 0.2 milligrams per liter.' ;
    rdfs:domain ind:MorSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Number' ;
    rdfs:comment 'Confirmation or tracking number issued by the regulatory agency upon receipt of the monthly operating report submission.' ;
    rdfs:domain ind:MorSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctComplianceMet rdf:type rdf:Property ;
    rdfs:label 'Ct Compliance Met' ;
    rdfs:comment 'Indicates whether all disinfection contact time calculations during the reporting month achieved the required CT values for pathogen inactivation.' ;
    rdfs:domain ind:MorSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ctCompliancePct rdf:type rdf:Property ;
    rdfs:label 'Ct Compliance Pct' ;
    rdfs:comment 'Percentage of operating days during the reporting month where the facility achieved the required CT (Contact Time for Disinfection) value as mandated by the Surface Water Treatment Rule. Critical SDWA compliance metric reported in MOR.' ;
    rdfs:domain ind:MorSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:haa5LevelUgL rdf:type rdf:Property ;
    rdfs:label 'Haa5 Level Ug L' ;
    rdfs:comment 'Measured concentration of Haloacetic Acids (HAA5), a class of Disinfection Byproducts (DBPs), in finished water during the reporting month, expressed in micrograms per liter (µg/L). Reported in MOR for DBP Rule compliance; MCL is 60 µg/L.' ;
    rdfs:domain ind:MorSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hasMclExceedance rdf:type rdf:Property ;
    rdfs:label 'Has Mcl Exceedance' ;
    rdfs:comment 'Indicates whether any Maximum Contaminant Level (MCL) was exceeded at the facility during the reporting month (True = exceedance occurred). Triggers public notification and corrective action requirements under SDWA.' ;
    rdfs:domain ind:MorSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasSsoEvent rdf:type rdf:Property ;
    rdfs:label 'Has Sso Event' ;
    rdfs:comment 'Indicates whether a Sanitary Sewer Overflow (SSO) event occurred at or associated with the facility during the reporting month (True = SSO occurred). Applicable to WWTP submissions; triggers mandatory regulatory notification under NPDES.' ;
    rdfs:domain ind:MorSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxDailyFlowMgd rdf:type rdf:Property ;
    rdfs:label 'Max Daily Flow Mgd' ;
    rdfs:comment 'Maximum single-day flow volume processed at the facility during the reporting month, expressed in Million Gallons per Day (MGD). Used to assess peak demand and permit compliance against maximum daily flow limits.' ;
    rdfs:domain ind:MorSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxTurbidityNtu rdf:type rdf:Property ;
    rdfs:label 'Max Turbidity Ntu' ;
    rdfs:comment 'Maximum single turbidity reading recorded during the reporting month, measured in Nephelometric Turbidity Units (NTU). Used to identify peak exceedance events and assess MCL compliance.' ;
    rdfs:domain ind:MorSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mclExceedanceCount rdf:type rdf:Property ;
    rdfs:label 'Mcl Exceedance Count' ;
    rdfs:comment 'Number of maximum contaminant level exceedances detected during the reporting month across all monitored parameters.' ;
    rdfs:domain ind:MorSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minDailyFlowMgd rdf:type rdf:Property ;
    rdfs:label 'Min Daily Flow Mgd' ;
    rdfs:comment 'Minimum single-day flow volume processed at the facility during the reporting month, expressed in Million Gallons per Day (MGD). Used for operational range analysis and low-flow condition monitoring.' ;
    rdfs:domain ind:MorSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:narrativeSummary rdf:type rdf:Property ;
    rdfs:label 'Narrative Summary' ;
    rdfs:comment 'Operator-provided narrative summary describing significant operational events, process adjustments, equipment issues, or unusual conditions during the reporting month.' ;
    rdfs:domain ind:MorSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorCertificationGrade rdf:type rdf:Property ;
    rdfs:label 'Operator Certification Grade' ;
    rdfs:comment 'Certification grade level of the submitting operator (e.g., Grade 1, Grade 2, Grade 3, Grade 4) as issued by the state primacy agency. Must meet or exceed the classification grade of the facility being reported on.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Operator Certification Number' ;
    rdfs:comment 'State-issued certification number of the licensed operator who prepared and certified the monthly operating report.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Operator License Number' ;
    rdfs:comment 'State-issued certification license number of the responsible operator who signed and submitted this MOR. Required by state drinking water programs to verify that reports are prepared by a certified operator.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAcceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Acceptance Date' ;
    rdfs:comment 'Date on which the regulatory agency officially accepted the monthly operating report as complete and compliant.' ;
    rdfs:domain ind:MorSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resubmissionDueDate rdf:type rdf:Property ;
    rdfs:label 'Resubmission Due Date' ;
    rdfs:comment 'Deadline by which a corrected monthly operating report must be resubmitted to the regulatory agency.' ;
    rdfs:domain ind:MorSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resubmissionNumber rdf:type rdf:Property ;
    rdfs:label 'Resubmission Number' ;
    rdfs:comment 'Sequential resubmission count for this reporting period and facility (0 = original submission, 1 = first resubmission, 2 = second resubmission, etc.). Used to track amendment history following regulatory rejection or voluntary correction.' ;
    rdfs:domain ind:MorSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supervisorApprovalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Supervisor Approval Timestamp' ;
    rdfs:comment 'Date and time when the supervising operator or plant manager approved the monthly operating report for submission.' ;
    rdfs:domain ind:MorSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalProductionVolumeMg rdf:type rdf:Property ;
    rdfs:label 'Total Production Volume Mg' ;
    rdfs:comment 'Total volume of finished water produced or wastewater treated during the reporting month, measured in million gallons.' ;
    rdfs:domain ind:MorSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVolumeTreatedMg rdf:type rdf:Property ;
    rdfs:label 'Total Volume Treated Mg' ;
    rdfs:comment 'Total volume of water or wastewater treated at the facility during the reporting month, expressed in Million Gallons. Derived from daily flow records and reported in the MOR for production accounting.' ;
    rdfs:domain ind:MorSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tssAvgMgL rdf:type rdf:Property ;
    rdfs:label 'Tss Avg Mg L' ;
    rdfs:comment 'Average Total Suspended Solids (TSS) concentration in treated effluent during the reporting month, expressed in milligrams per liter (mg/L). Applicable to WWTP/STP MOR submissions; reported for NPDES permit compliance.' ;
    rdfs:domain ind:MorSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tthmLevelUgL rdf:type rdf:Property ;
    rdfs:label 'Tthm Level Ug L' ;
    rdfs:comment 'Measured concentration of Total Trihalomethanes (THMs), a class of Disinfection Byproducts (DBPs), in finished water during the reporting month, expressed in micrograms per liter (µg/L). Reported in MOR for DBP Rule compliance; MCL is 80 µg/L.' ;
    rdfs:domain ind:MorSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:turbidityCompliancePct rdf:type rdf:Property ;
    rdfs:label 'Turbidity Compliance Pct' ;
    rdfs:comment 'Percentage of turbidity measurements during the reporting month that met the Maximum Contaminant Level (MCL) or treatment technique standard, expressed in Nephelometric Turbidity Units (NTU). Key finished water quality metric in MOR.' ;
    rdfs:domain ind:MorSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:piPointId rdf:type rdf:Property ;
    rdfs:label 'Pi Point Id' ;
    rdfs:comment 'The unique PI Point identifier in the OSIsoft PI Historian system corresponding to this setpoint\'s SCADA tag. Used for direct data retrieval and synchronization between the Silver Layer setpoint register and the PI Historian real-time data store.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Point .

ind:previousSetpointProcessControlSetpointId rdf:type rdf:Property ;
    rdfs:label 'Previous Setpoint Process Control Setpoint Id' ;
    rdfs:comment 'Reference to the immediately preceding version of this setpoint record (self-referential). Enables reconstruction of the full setpoint change history chain for regulatory audit and process optimization analysis.' ;
    rdfs:domain ind:ProcessControlSetpoint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessControlSetpoint .

ind:alarmDelaySeconds rdf:type rdf:Property ;
    rdfs:label 'Alarm Delay Seconds' ;
    rdfs:comment 'The time delay in seconds before an alarm is activated after the process variable crosses an alarm limit. Prevents nuisance alarms from transient spikes. A value of 0 means immediate alarm activation.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alarmPriority rdf:type rdf:Property ;
    rdfs:label 'Alarm Priority' ;
    rdfs:comment 'The priority classification of alarms generated when this setpoint\'s limits are breached. \'critical\' alarms require immediate operator response and may trigger automatic shutdown; \'high\' requires prompt response; \'medium\' and \'low\' are advisory. Aligns with ISA-18.2 alarm management philosophy.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReason rdf:type rdf:Property ;
    rdfs:label 'Change Reason' ;
    rdfs:comment 'Free-text description of the business or operational reason for creating or modifying this setpoint record (e.g., \'Seasonal chloramine conversion\', \'Post-LCRR compliance adjustment\', \'Filter media replacement\', \'Regulatory agency directive\'). Required for change management audit trails.' ;
    rdfs:domain ind:ProcessControlSetpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlMode rdf:type rdf:Property ;
    rdfs:label 'Control Mode' ;
    rdfs:comment 'The control mode under which this setpoint operates in the SCADA/PLC system. \'automatic\' means the control loop maintains the setpoint autonomously; \'manual\' means operator-directed; \'cascade\' means the output of one controller drives the setpoint of another; \'ratio\' and \'feedforward\' are advanced control strategies.' ;
    rdfs:domain ind:ProcessControlSetpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deadbandValue rdf:type rdf:Property ;
    rdfs:label 'Deadband Value' ;
    rdfs:comment 'The deadband or hysteresis value around the setpoint within which no corrective control action is taken. Prevents excessive actuator cycling (e.g., chemical dosing pump hunting). Expressed in the same engineering unit as setpoint_value.' ;
    rdfs:domain ind:ProcessControlSetpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:highAlarmLimit rdf:type rdf:Property ;
    rdfs:label 'High Alarm Limit' ;
    rdfs:comment 'The high alarm threshold for the process variable. When the measured value exceeds this limit, a high alarm is triggered in the SCADA/HMI system, alerting operators to take corrective action. Expressed in the same engineering unit as setpoint_value.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:highTripLimit rdf:type rdf:Property ;
    rdfs:label 'High Trip Limit' ;
    rdfs:comment 'The high-high (HH) trip or shutdown limit for the process variable. Exceeding this value triggers an automatic safety interlock or process shutdown (e.g., chlorine over-feed trip, filter bypass). More severe than the high alarm limit. Expressed in the same engineering unit as setpoint_value.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCtComplianceParameter rdf:type rdf:Property ;
    rdfs:label 'Is Ct Compliance Parameter' ;
    rdfs:comment 'Indicates whether this setpoint is a CT (Contact Time for Disinfection) compliance parameter as required under the EPA Surface Water Treatment Rule. CT compliance parameters (e.g., chlorine residual, contact time) are subject to heightened regulatory scrutiny and must be tracked in MOR submissions.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMclRelated rdf:type rdf:Property ;
    rdfs:label 'Is Mcl Related' ;
    rdfs:comment 'Indicates whether this setpoint is directly associated with an EPA or state MCL parameter (e.g., chlorine residual, turbidity, pH for corrosion control under LCRR). MCL-related setpoints require additional documentation and regulatory reporting.' ;
    rdfs:domain ind:ProcessControlSetpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lowAlarmLimit rdf:type rdf:Property ;
    rdfs:label 'Low Alarm Limit' ;
    rdfs:comment 'The low alarm threshold for the process variable. When the measured value falls below this limit, a low alarm is triggered in the SCADA/HMI system. Expressed in the same engineering unit as setpoint_value.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowTripLimit rdf:type rdf:Property ;
    rdfs:label 'Low Trip Limit' ;
    rdfs:comment 'The low-low (LL) trip or shutdown limit for the process variable. Falling below this value triggers an automatic safety interlock or process shutdown (e.g., chlorine under-feed trip, pump cavitation protection). More severe than the low alarm limit. Expressed in the same engineering unit as setpoint_value.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parameterType rdf:type rdf:Property ;
    rdfs:label 'Parameter Type' ;
    rdfs:comment 'Categorical classification of the process variable being controlled (e.g., water_quality for chlorine/pH/turbidity, flow_rate for GPM targets, pressure for PSI limits, chemical_dose for mg/L targets, equipment_runtime for filter run time). Drives analytics segmentation and alarm management. [ENUM-REF-CANDIDATE: water_quality|flow_rate|pressure|chemical_dose|equipment_runtime|level|temperature — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processArea rdf:type rdf:Property ;
    rdfs:label 'Process Area' ;
    rdfs:comment 'The treatment process area or stage to which this setpoint belongs. Classifies the setpoint within the treatment train for process control, analytics, and regulatory reporting. [ENUM-REF-CANDIDATE: coagulation_flocculation|sedimentation|filtration|disinfection|chemical_dosing|membrane_treatment|residuals_management|distribution_pumping|wastewater_primary|wastewater_secondary|wastewater_tertiary — promote to reference product]' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rampRate rdf:type rdf:Property ;
    rdfs:label 'Ramp Rate' ;
    rdfs:comment 'The maximum rate at which the setpoint value may be changed per unit time (expressed in engineering_unit per minute). Prevents sudden process upsets during setpoint transitions (e.g., gradual chlorine dose ramp-up after a plant restart). Null if no ramp rate constraint applies.' ;
    rdfs:domain ind:ProcessControlSetpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rampRateUnit rdf:type rdf:Property ;
    rdfs:label 'Ramp Rate Unit' ;
    rdfs:comment 'The time unit denominator for the ramp_rate field (e.g., per_minute, per_hour). Clarifies the rate of change constraint for the setpoint transition.' ;
    rdfs:domain ind:ProcessControlSetpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryMclLimit rdf:type rdf:Property ;
    rdfs:label 'Regulatory Mcl Limit' ;
    rdfs:comment 'The applicable EPA or state Maximum Contaminant Level (MCL) or permit limit for this parameter, expressed in the same engineering unit as setpoint_value. Used to verify that the operational setpoint provides adequate safety margin above the regulatory threshold. Null if no MCL applies to this parameter.' ;
    rdfs:domain ind:ProcessControlSetpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:setpointCode rdf:type rdf:Property ;
    rdfs:label 'Setpoint Code' ;
    rdfs:comment 'Standardized alphanumeric code uniquely identifying the setpoint parameter type within the facility\'s process control register (e.g., CL2_RESIDUAL_SP, PH_TARGET_SP, TURB_ALARM_HI). Used for cross-system integration and MOR regulatory submissions.' ;
    rdfs:domain ind:ProcessControlSetpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setpointName rdf:type rdf:Property ;
    rdfs:label 'Setpoint Name' ;
    rdfs:comment 'Human-readable name of the process control setpoint parameter (e.g., \'Chlorine Residual Target\', \'pH Target\', \'Turbidity Alarm Threshold\', \'Filter Run Time Limit\', \'Chemical Dose Rate\'). Serves as the primary identity label for the setpoint in operator interfaces and regulatory reports.' ;
    rdfs:domain ind:ProcessControlSetpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setpointStatus rdf:type rdf:Property ;
    rdfs:label 'Setpoint Status' ;
    rdfs:comment 'Current lifecycle status of the setpoint record. \'active\' indicates the setpoint is currently enforced in the control system. \'pending_approval\' indicates it has been proposed but not yet approved by a certified operator. \'superseded\' indicates it has been replaced by a newer version. \'under_review\' indicates it is being evaluated for change.' ;
    rdfs:domain ind:ProcessControlSetpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setpointValue rdf:type rdf:Property ;
    rdfs:label 'Setpoint Value' ;
    rdfs:comment 'The target or nominal value for the process control parameter. This is the principal quantitative fact — the value the control system actively maintains (e.g., 1.5 for chlorine residual in mg/L, 7.2 for pH, 0.1 for turbidity in NTU). Corresponds to the SP (setpoint) field in OSIsoft PI Historian.' ;
    rdfs:domain ind:ProcessControlSetpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:instrumentId rdf:type rdf:Property ;
    rdfs:label 'Instrument Id' ;
    rdfs:comment 'Reference to the physical instrument or sensor asset (e.g., flow meter, pressure transducer, turbidimeter, pH probe, chlorine analyzer) that generated this reading. Links to the asset management record in IBM Maximo for calibration tracking, maintenance history, and instrument lifecycle management.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WaterUtilities .

ind:qualityMclExceedanceId rdf:type rdf:Property ;
    rdfs:label 'Quality Mcl Exceedance Id' ;
    rdfs:comment 'Foreign key linking to quality.exceedance. Business justification: Treatment process alarms (MCL trips, CT failures, turbidity spikes) trigger quality exceedance records for regulatory reporting. Links operational alarm event to compliance exceedance record for MOR/D' ;
    rdfs:domain ind:ProcessReading ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Exceedance .

ind:shiftAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Shift Assignment Id' ;
    rdfs:comment 'Reference to the operational shift during which this process reading was captured. Links to the workforce shift schedule for operator accountability, shift-based performance reporting, and MOR (Monthly Operating Report) compilation. Enables shift-level process performance analysis.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShiftAssignment .

ind:alarmState rdf:type rdf:Property ;
    rdfs:label 'Alarm State' ;
    rdfs:comment 'The SCADA alarm state associated with this reading at the time of capture. Reflects the process control alarm condition: normal (within operational bounds), low_alarm (below low setpoint), high_alarm (above high setpoint), low_low_alarm (critical low condition), high_high_alarm (critical high condition), sensor_fault (instrument malfunction detected). Used for operational response and incident tracking.' ;
    rdfs:domain ind:ProcessReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Due Date' ;
    rdfs:comment 'The date by which the instrument generating this reading is due for its next calibration verification. Sourced from the IBM Maximo asset management calibration schedule. Readings captured after the calibration_due_date may require additional quality review. Supports instrument reliability and regulatory compliance for monitoring equipment.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compressionApplied rdf:type rdf:Property ;
    rdfs:label 'Compression Applied' ;
    rdfs:comment 'Indicates whether OSIsoft PI Historian exception and compression algorithms were applied to this data point before archiving. When True, the stored value may represent a compressed/exception-filtered point rather than a raw scan value. Important for understanding data density and potential gaps in high-frequency process data.' ;
    rdfs:domain ind:ProcessReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ctValue rdf:type rdf:Property ;
    rdfs:label 'Ct Value' ;
    rdfs:comment 'The calculated CT (Contact Time for Disinfection) value in mg·min/L for disinfection process readings. CT is the product of disinfectant residual concentration (mg/L) and contact time (minutes), used to demonstrate compliance with the Surface Water Treatment Rule (SWTR) inactivation requirements for Giardia and viruses. Applicable only to disinfection process stage readings; null for non-disinfection parameters.' ;
    rdfs:domain ind:ProcessReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:highRangeLimit rdf:type rdf:Property ;
    rdfs:label 'High Range Limit' ;
    rdfs:comment 'The maximum operational range limit for this process parameter as configured in the SCADA/PI Historian system. Values above this threshold may indicate sensor malfunction, process upset, or out-of-range conditions. Used in data quality validation and alarm management.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ingestionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingestion Timestamp' ;
    rdfs:comment 'The date and time when this process reading record was ingested into the Databricks Lakehouse silver layer from the source system (OSIsoft PI Historian or SCADA). Distinct from reading_timestamp (the real-world event time). Used for data pipeline latency monitoring and ETL audit trails.' ;
    rdfs:domain ind:ProcessReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isManualEntry rdf:type rdf:Property ;
    rdfs:label 'Is Manual Entry' ;
    rdfs:comment 'Indicates whether this process reading was manually entered by a licensed operator rather than automatically captured by the SCADA/PI Historian system. True for manual readings (e.g., grab sample results, field measurements, backup readings during SCADA outages). Required for data integrity auditing and regulatory compliance documentation under EPA SDWA.' ;
    rdfs:domain ind:ProcessReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryExceedance rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Exceedance' ;
    rdfs:comment 'Indicates whether the measured_value exceeds the applicable regulatory_limit_value for this process parameter. True when the reading constitutes a regulatory violation requiring notification, corrective action, and reporting under SDWA or NPDES permit conditions. Critical flag for compliance monitoring and MOR/DMR generation.' ;
    rdfs:domain ind:ProcessReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lowRangeLimit rdf:type rdf:Property ;
    rdfs:label 'Low Range Limit' ;
    rdfs:comment 'The minimum operational range limit for this process parameter as configured in the SCADA/PI Historian system. Values below this threshold may indicate sensor malfunction, process upset, or out-of-range conditions. Used in data quality validation and alarm management.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:morReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Mor Reporting Flag' ;
    rdfs:comment 'Indicates whether this process reading is designated for inclusion in the Monthly Operating Report (MOR) submitted to the state primacy agency. True for readings that represent regulatory compliance monitoring points required under the facility\'s operating permit. Enables automated MOR data extraction from the silver layer.' ;
    rdfs:domain ind:ProcessReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:piServerName rdf:type rdf:Property ;
    rdfs:label 'Pi Server Name' ;
    rdfs:comment 'The name of the OSIsoft PI Historian server instance from which this reading was sourced. Water utilities may operate multiple PI servers across different facilities or regions. Used for data lineage, source system reconciliation, and multi-server federation queries.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processStage rdf:type rdf:Property ;
    rdfs:label 'Process Stage' ;
    rdfs:comment 'The treatment process stage at which this reading was captured. Identifies the position within the treatment train for process control and regulatory compliance tracking. Key stages include intake (raw water source), coagulation, flocculation, sedimentation, filtration, disinfection (UV/chlorination/RO/UF/MF/GAC), finished_water (post-treatment), and distribution_entry (point of entry to distribution network). [ENUM-REF-CANDIDATE: intake|coagulation|flocculation|sedimentation|filtration|disinfection|finished_water|distribution_entry|wastewater_influent|secondary_treatment|tertiary_treatment|wastewater_effluent — promote to reference product]' ;
    rdfs:domain ind:ProcessReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Flag' ;
    rdfs:comment 'The OSIsoft PI Historian data quality status code associated with this reading. Indicates the reliability and validity of the measured value. \'Good\' indicates a valid, reliable reading. \'Bad\' indicates a sensor fault or communication failure. \'Uncertain\' indicates the value may be unreliable. \'Substituted\' indicates a manually entered or interpolated value. \'Shutdown\' indicates the process unit was offline. \'ConfigError\' indicates a tag configuration issue.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rawValue rdf:type rdf:Property ;
    rdfs:label 'Raw Value' ;
    rdfs:comment 'The unprocessed, unconditioned sensor output value as received directly from the SCADA/PI Historian system before any silver-layer transformations, scaling, or quality adjustments. Preserved for audit and reconciliation against the source system. May differ from measured_value if scaling, offset correction, or substitution was applied.' ;
    rdfs:domain ind:ProcessReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:readingDate rdf:type rdf:Property ;
    rdfs:label 'Reading Date' ;
    rdfs:comment 'The calendar date (yyyy-MM-dd) on which this process reading was recorded. Derived from reading_timestamp for partitioning, daily aggregation, and regulatory reporting purposes. Stored as a separate DATE column to support efficient date-based partitioning in the Databricks Lakehouse and daily compliance reporting.' ;
    rdfs:domain ind:ProcessReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:readingStatus rdf:type rdf:Property ;
    rdfs:label 'Reading Status' ;
    rdfs:comment 'The silver-layer curation lifecycle status of this process reading record. \'raw\' indicates the record has been ingested but not yet validated. \'validated\' indicates the record has passed data quality checks. \'rejected\' indicates the record failed validation rules. \'substituted\' indicates the value was replaced by an operator-approved substitute. \'archived\' indicates the record has been moved to long-term storage.' ;
    rdfs:domain ind:ProcessReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryLimitType rdf:type rdf:Property ;
    rdfs:label 'Regulatory Limit Type' ;
    rdfs:comment 'The type of regulatory standard that the regulatory_limit_value represents. MCL (Maximum Contaminant Level) is the enforceable standard under SDWA. MCLG (Maximum Contaminant Level Goal) is the non-enforceable health goal. action_level applies to Lead and Copper Rule Revisions (LCRR). permit_limit applies to NPDES discharge permits. treatment_technique applies where no MCL is set but a treatment method is required.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryLimitValue rdf:type rdf:Property ;
    rdfs:label 'Regulatory Limit Value' ;
    rdfs:comment 'The applicable regulatory threshold (MCL, MCLG, or permit limit) for this process parameter as defined by the EPA or state primacy agency. For example, the MCL for turbidity is 1 NTU (0.3 NTU for filtered systems), and the MCL for total trihalomethanes (THMs) is 0.080 mg/L. Used for real-time compliance monitoring and MOR/DMR reporting.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleIntervalSeconds rdf:type rdf:Property ;
    rdfs:label 'Sample Interval Seconds' ;
    rdfs:comment 'The configured sampling or scan interval in seconds at which this PI tag is polled or archived by the OSIsoft PI Historian system. Common intervals include 1 second (continuous process), 60 seconds (1-minute averages), 900 seconds (15-minute averages), and 3600 seconds (hourly averages). Used for time-series aggregation and data completeness assessment.' ;
    rdfs:domain ind:ProcessReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scadaSystemCode rdf:type rdf:Property ;
    rdfs:label 'Scada System Code' ;
    rdfs:comment 'Reference to the SCADA (Supervisory Control and Data Acquisition) system instance that collected and transmitted this process reading. Identifies the specific PLC, RTU, or HMI node in the control network. Used for source system traceability and SCADA infrastructure management.' ;
    rdfs:domain ind:ProcessReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceTagName rdf:type rdf:Property ;
    rdfs:label 'Source Tag Name' ;
    rdfs:comment 'The original PI tag name or SCADA point name as it exists in the source system (OSIsoft PI Historian or SCADA). Preserved for data lineage and reconciliation purposes. May differ from the normalized tag_id if tag renaming or aliasing has occurred during silver-layer curation.' ;
    rdfs:domain ind:ProcessReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionReason rdf:type rdf:Property ;
    rdfs:label 'Substitution Reason' ;
    rdfs:comment 'The reason code explaining why the measured_value was substituted or manually overridden from the raw_value. Applicable when reading_status is \'substituted\' or quality_flag is \'Substituted\'. Required for regulatory audit trails under EPA SDWA data integrity requirements. Null when no substitution was applied.' ;
    rdfs:domain ind:ProcessReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validated Timestamp' ;
    rdfs:comment 'The date and time when this process reading record was validated and promoted to \'validated\' status in the silver layer. Null if the record has not yet been validated or was rejected. Supports data quality audit trails and SLA monitoring for data availability.' ;
    rdfs:domain ind:ProcessReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:primaryScadaRegistryId rdf:type rdf:Property ;
    rdfs:label 'Primary Scada Registry Id' ;
    rdfs:comment 'Reference to the physical instrument or sensor asset (e.g., flow meter, pressure transmitter, turbidimeter, chlorine analyzer, pH probe, level sensor) registered in the asset management system (IBM Maximo) that this tag represents.' ;
    rdfs:domain ind:ScadaTag ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Registry .

ind:compressionDeviation rdf:type rdf:Property ;
    rdfs:label 'Compression Deviation' ;
    rdfs:comment 'The exception/compression deviation threshold configured in PI Historian for this tag. Values within this deviation from the last stored value are suppressed to reduce archive storage. Critical for balancing data fidelity against storage efficiency. Expressed in the tag\'s engineering units.' ;
    rdfs:domain ind:ScadaTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compressionEnabled rdf:type rdf:Property ;
    rdfs:label 'Compression Enabled' ;
    rdfs:comment 'Boolean flag indicating whether data compression is enabled for this SCADA tag in the historian system. Compression reduces storage requirements by only recording values when they change significantly, rather than at every scan interval.' ;
    rdfs:domain ind:ScadaTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compressionMaxTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Compression Max Time Seconds' ;
    rdfs:comment 'The maximum time in seconds that PI Historian will suppress a value due to compression before forcing a new archive event, even if the value has not changed beyond the compression deviation. Ensures regulatory compliance data is recorded at minimum required intervals.' ;
    rdfs:domain ind:ScadaTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataType rdf:type rdf:Property ;
    rdfs:label 'Data Type' ;
    rdfs:comment 'The native data type of the tag value as stored in the PI Historian archive. Determines precision, storage requirements, and compatibility with downstream analytics. \'float32\'/\'float64\' for analog measurements, \'int16\'/\'int32\' for integer counts, \'boolean\'/\'digital\' for on/off states, \'string\' for text-based status tags. [ENUM-REF-CANDIDATE: float32|float64|int16|int32|int64|boolean|string|digital — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ScadaTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayDigits rdf:type rdf:Property ;
    rdfs:label 'Display Digits' ;
    rdfs:comment 'The number of decimal places to display for this tag\'s value in HMI screens, PI Vision dashboards, and operator reports. Configured per instrument precision requirements (e.g., 2 for turbidity in NTU, 3 for chlorine residual in mg/L, 0 for integer counts).' ;
    rdfs:domain ind:ScadaTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:highLimit rdf:type rdf:Property ;
    rdfs:label 'High Limit' ;
    rdfs:comment 'The critical upper alarm threshold for this tag. When the process variable exceeds this value, a high-priority (Level 1) alarm is triggered in the SCADA/HMI system, typically requiring immediate operator intervention. For regulatory parameters (e.g., turbidity, chlorine residual), this may align with MCL exceedance thresholds.' ;
    rdfs:domain ind:ScadaTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCriticalControlPoint rdf:type rdf:Property ;
    rdfs:label 'Is Critical Control Point' ;
    rdfs:comment 'Indicates whether this tag monitors a Critical Control Point (CCP) in the treatment process as defined by the facility\'s Water Safety Plan or Process Control Plan. CCP tags require enhanced monitoring, alarm management, and data quality assurance per AWWA and EPA guidance.' ;
    rdfs:domain ind:ScadaTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCtComplianceTag rdf:type rdf:Property ;
    rdfs:label 'Is Ct Compliance Tag' ;
    rdfs:comment 'Indicates whether this tag is used in the calculation of CT (Contact Time for Disinfection) compliance values per the Surface Water Treatment Rule. CT compliance tags (disinfectant residual and flow rate) require continuous monitoring and are critical for regulatory reporting.' ;
    rdfs:domain ind:ScadaTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDmrReportable rdf:type rdf:Property ;
    rdfs:label 'Is Dmr Reportable' ;
    rdfs:comment 'Boolean flag indicating whether this SCADA tag\'s data must be included in the Discharge Monitoring Report (DMR) submitted under the NPDES (National Pollutant Discharge Elimination System) permit for wastewater discharge compliance.' ;
    rdfs:domain ind:ScadaTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMorReportable rdf:type rdf:Property ;
    rdfs:label 'Is Mor Reportable' ;
    rdfs:comment 'Indicates whether data from this tag is included in the Monthly Operating Report (MOR) submitted to the state primacy agency. MOR-reportable tags require higher data quality standards, complete audit trails, and validated calibration records.' ;
    rdfs:domain ind:ScadaTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lowLimit rdf:type rdf:Property ;
    rdfs:label 'Low Limit' ;
    rdfs:comment 'The lower warning alarm threshold for this tag. When the process variable falls below this value, a low-priority warning alarm is triggered (e.g., low chlorine residual warning before MCL violation, low flow rate indicating pump issue).' ;
    rdfs:domain ind:ScadaTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parameterMeasured rdf:type rdf:Property ;
    rdfs:label 'Parameter Measured' ;
    rdfs:comment 'The physical or chemical parameter that this SCADA tag measures or controls, such as flow rate, pressure, turbidity, chlorine residual, pH, temperature, level, or valve position. Uses industry-standard terminology.' ;
    rdfs:domain ind:ScadaTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piAfElementPath rdf:type rdf:Property ;
    rdfs:label 'Pi Af Element Path' ;
    rdfs:comment 'The full hierarchical path of this tag within the OSIsoft PI Asset Framework (AF) element hierarchy (e.g., \'\\\\WaterUtilities\\WTP1\\Filtration\\Filter1\\EffluentTurbidity\'). Enables contextual analytics, template-based reporting, and structured navigation of the treatment process hierarchy in PI Vision and PI DataLink.' ;
    rdfs:domain ind:ScadaTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plcControllerCode rdf:type rdf:Property ;
    rdfs:label 'Plc Controller Code' ;
    rdfs:comment 'The identifier of the PLC or RTU (Remote Terminal Unit) that physically reads or controls this SCADA tag. Links the tag to the specific control hardware in the field.' ;
    rdfs:domain ind:ScadaTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryParameter rdf:type rdf:Property ;
    rdfs:label 'Regulatory Parameter' ;
    rdfs:comment 'Identifies whether this tag monitors a parameter subject to EPA or state drinking water/wastewater regulatory compliance requirements. Maps the tag to specific regulatory frameworks: turbidity (Surface Water Treatment Rule), chlorine_residual (SDWA disinfection), ct_value (CT compliance), uv_dose (UV disinfection rule), dbp_thm (THM/TTHM rule), dbp_haa5 (HAA5 rule), pfas (PFAS MCL), none (non-regulatory operational tag). [ENUM-REF-CANDIDATE: turbidity|chlorine_residual|ph|fluoride|ct_value|uv_dose|toc|bod|tss|tds|pfas|dbp_thm|dbp_haa5|none — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ScadaTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaSystem rdf:type rdf:Property ;
    rdfs:label 'Scada System' ;
    rdfs:comment 'Identifies the SCADA or DCS platform that is the originating source of this tag\'s data before it is archived in PI Historian. Supports multi-vendor SCADA environments and data lineage tracking.' ;
    rdfs:domain ind:ScadaTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanIntervalSeconds rdf:type rdf:Property ;
    rdfs:label 'Scan Interval Seconds' ;
    rdfs:comment 'The frequency at which the SCADA system reads or updates this tag\'s value, expressed in seconds. Critical for understanding data granularity and system performance. Typical values range from 1 second for critical control loops to 300 seconds (5 minutes) for slow-changing parameters.' ;
    rdfs:domain ind:ScadaTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scanRateSeconds rdf:type rdf:Property ;
    rdfs:label 'Scan Rate Seconds' ;
    rdfs:comment 'The frequency in seconds at which the PI Historian interface scans the PLC/RTU/SCADA source for new data values for this tag. Common values: 1 (high-frequency process control), 5, 10, 30, 60 (regulatory compliance monitoring), 300 (trend monitoring). Directly impacts data storage volume and process control responsiveness.' ;
    rdfs:domain ind:ScadaTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceAddress rdf:type rdf:Property ;
    rdfs:label 'Source Address' ;
    rdfs:comment 'The register address or OPC-UA node identifier on the PLC/RTU from which the PI Historian interface reads this tag\'s value (e.g., Modbus register address, OPC item path). Essential for SCADA interface configuration and data quality troubleshooting.' ;
    rdfs:domain ind:ScadaTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spanValue rdf:type rdf:Property ;
    rdfs:label 'Span Value' ;
    rdfs:comment 'The maximum (span) end of the instrument\'s calibrated measurement range, expressed in engineering units. Used for signal scaling, over-range detection, and calibration verification (e.g., 10.0 for a 0–10 NTU turbidimeter, 200.0 for a 0–200 PSI pressure transmitter).' ;
    rdfs:domain ind:ScadaTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:substitutionMode rdf:type rdf:Property ;
    rdfs:label 'Substitution Mode' ;
    rdfs:comment 'Defines how PI Historian handles missing or bad-quality data values for this tag during data gaps (e.g., instrument offline, communication failure). \'none\' = no substitution, gap remains; \'last_value\' = hold last good value; \'interpolated\' = linear interpolation; \'manual_entry\' = operator-entered substitute value for regulatory reporting.' ;
    rdfs:domain ind:ScadaTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagAlias rdf:type rdf:Property ;
    rdfs:label 'Tag Alias' ;
    rdfs:comment 'An alternative short name or alias for the tag used in HMI displays, operator logs, or legacy SCADA systems where the full PI tag name is too long. Facilitates cross-system tag mapping and operator familiarity.' ;
    rdfs:domain ind:ScadaTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagDescription rdf:type rdf:Property ;
    rdfs:label 'Tag Description' ;
    rdfs:comment 'Human-readable description of the tag\'s measurement purpose and physical location (e.g., \'Filter 1 Effluent Turbidity Process Variable - WTP1\'). Used in operator HMI displays, PI Vision dashboards, and MOR reporting.' ;
    rdfs:domain ind:ScadaTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagName rdf:type rdf:Property ;
    rdfs:label 'Tag Name' ;
    rdfs:comment 'The unique alphanumeric name or identifier assigned to the SCADA tag within the SCADA system. This is the human-readable tag name used by operators and engineers to identify the measurement point or control point.' ;
    rdfs:domain ind:ScadaTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagStatus rdf:type rdf:Property ;
    rdfs:label 'Tag Status' ;
    rdfs:comment 'Current operational lifecycle status of the SCADA tag. \'active\' = tag is live and collecting data; \'inactive\' = tag exists but data collection is paused; \'decommissioned\' = tag retired from service; \'maintenance\' = tag temporarily offline for instrument servicing; \'spare\' = tag reserved for future instrument.' ;
    rdfs:domain ind:ScadaTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagType rdf:type rdf:Property ;
    rdfs:label 'Tag Type' ;
    rdfs:comment 'The OSIsoft PI Historian tag data class type. \'analog_input\' = continuous process variable (e.g., turbidity, flow, pressure); \'analog_output\' = control output signal; \'digital_input\' = discrete on/off state; \'digital_output\' = discrete control command; \'calculated\' = PI Performance Equation derived tag; \'accumulator\' = totalizer tag; \'string\' = text-based state tag. [ENUM-REF-CANDIDATE: analog_input|analog_output|digital_input|digital_output|calculated|accumulator|string — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ScadaTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zeroValue rdf:type rdf:Property ;
    rdfs:label 'Zero Value' ;
    rdfs:comment 'The minimum (zero) end of the instrument\'s calibrated measurement range, expressed in engineering units. Used for signal scaling, calibration verification, and alarm setpoint validation (e.g., 0.0 for a 0–10 NTU turbidimeter).' ;
    rdfs:domain ind:ScadaTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sludgeProductionId rdf:type rdf:Property ;
    rdfs:label 'Sludge Production Id' ;
    rdfs:comment 'Unique surrogate identifier for each sludge production record in the treatment domain. Primary key for the sludge_production data product.' ;
    rdfs:domain ind:SludgeProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:haulerVendorId rdf:type rdf:Property ;
    rdfs:label 'Hauler Vendor Id' ;
    rdfs:comment 'Foreign key linking to supply.vendor. Business justification: Biosolids hauling and disposal contractors are vendors providing services under contracts with performance requirements, insurance, and regulatory compliance. Essential for vendor performance tracking' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:biosolidsClass rdf:type rdf:Property ;
    rdfs:label 'Biosolids Class' ;
    rdfs:comment 'EPA biosolids quality classification under 40 CFR Part 503. \'Class_A\' indicates pathogen reduction to below detectable levels (suitable for unrestricted land application); \'Class_B\' indicates reduced but detectable pathogens (restricted land application with site restrictions); \'not_classified\' for non-biosolids residuals such as alum or lime sludge.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bodMgPerL rdf:type rdf:Property ;
    rdfs:label 'Bod Mg Per L' ;
    rdfs:comment 'Biochemical Oxygen Demand of the sludge liquor expressed in milligrams per liter (mg/L). Indicates organic loading returned to the treatment process via sludge liquors (reject water/filtrate). Sourced from LIMS analytical results.' ;
    rdfs:domain ind:SludgeProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cakeSolidsPct rdf:type rdf:Property ;
    rdfs:label 'Cake Solids Pct' ;
    rdfs:comment 'Solids content of the dewatered sludge cake expressed as a percentage by weight after dewatering. Indicates dewatering efficiency; higher values reduce disposal volume and cost. Applicable when a dewatering method is applied.' ;
    rdfs:domain ind:SludgeProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dewateringMethod rdf:type rdf:Property ;
    rdfs:label 'Dewatering Method' ;
    rdfs:comment 'The mechanical or passive method used to reduce moisture content of the sludge prior to disposal. Options include centrifuge, belt press, filter press, drying beds, gravity thickener, or none (liquid sludge). Drives cake solids content and disposal cost.' ;
    rdfs:domain ind:SludgeProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalCostUsd rdf:type rdf:Property ;
    rdfs:label 'Disposal Cost Usd' ;
    rdfs:comment 'Total cost incurred for sludge disposal or beneficial use for this production event, expressed in US dollars. Includes hauling, tipping fees, and land application costs. Used for Operations and Maintenance (O&M) cost tracking, OPEX reporting, and Capital Improvement Program (CIP) planning.' ;
    rdfs:domain ind:SludgeProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disposalManifestNumber rdf:type rdf:Property ;
    rdfs:label 'Disposal Manifest Number' ;
    rdfs:comment 'Reference number of the waste disposal manifest or shipping document associated with the sludge disposal event. Required for chain-of-custody tracking and regulatory compliance under state solid waste and biosolids regulations.' ;
    rdfs:domain ind:SludgeProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalSiteName rdf:type rdf:Property ;
    rdfs:label 'Disposal Site Name' ;
    rdfs:comment 'Name of the landfill, land application site, incineration facility, or composting facility receiving the sludge. Used for disposal tracking, permit compliance, and annual biosolids reporting.' ;
    rdfs:domain ind:SludgeProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dryWeightTons rdf:type rdf:Property ;
    rdfs:label 'Dry Weight Tons' ;
    rdfs:comment 'Dry solids weight of the sludge expressed in dry tons (US short tons). Calculated from volume and total solids concentration; used for biosolids land application permitting, disposal cost tracking, and EPA 40 CFR Part 503 annual reporting.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:haulerPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Hauler Permit Number' ;
    rdfs:comment 'State-issued waste transporter permit number for the sludge hauler. Required for regulatory compliance verification and manifest documentation under state solid waste and biosolids regulations.' ;
    rdfs:domain ind:SludgeProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBiosolidsReportable rdf:type rdf:Property ;
    rdfs:label 'Is Biosolids Reportable' ;
    rdfs:comment 'Indicates whether this sludge production event must be included in the EPA annual biosolids report (40 CFR Part 503) or state biosolids program report. True = reportable; False = exempt (e.g., alum sludge disposed to landfill under solid waste rules).' ;
    rdfs:domain ind:SludgeProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximoWorkOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Maximo Work Order Number' ;
    rdfs:comment 'Work order number from IBM Maximo Asset Management (CMMS) associated with the dewatering or sludge handling maintenance activity. Supports Operations and Maintenance (O&M) cost tracking and asset performance management.' ;
    rdfs:domain ind:SludgeProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metalsCompliance rdf:type rdf:Property ;
    rdfs:label 'Metals Compliance' ;
    rdfs:comment 'Indicates whether the biosolids meet EPA 40 CFR Part 503 Table 1 ceiling concentration limits for regulated metals (arsenic, cadmium, copper, lead, mercury, molybdenum, nickel, selenium, zinc). True = all metals within ceiling limits; False = one or more exceedances detected. Sourced from LIMS metals analysis.' ;
    rdfs:domain ind:SludgeProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pathogenReductionMethod rdf:type rdf:Property ;
    rdfs:label 'Pathogen Reduction Method' ;
    rdfs:comment 'The process used to reduce pathogen levels in biosolids to meet EPA 40 CFR Part 503 Class A or Class B requirements. Determines land application site restrictions and public access limitations. [ENUM-REF-CANDIDATE: anaerobic_digestion|aerobic_digestion|composting|heat_drying|lime_stabilization|alkaline_stabilization|none — promote to reference product]' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionNumber rdf:type rdf:Property ;
    rdfs:label 'Production Number' ;
    rdfs:comment 'Externally-known business identifier for this sludge production event, formatted as SLG-{YYYY}-{NNNNNN}. Used in residuals management logs, disposal manifests, and regulatory submissions.' ;
    rdfs:domain ind:SludgeProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Production Timestamp' ;
    rdfs:comment 'Precise date and time when sludge generation or withdrawal was recorded, sourced from SCADA/OSIsoft PI Historian. Supports process analytics and shift-level reporting.' ;
    rdfs:domain ind:SludgeProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scadaEventReference rdf:type rdf:Property ;
    rdfs:label 'Scada Event Reference' ;
    rdfs:comment 'Reference tag or event identifier from the OSIsoft PI Historian SCADA system corresponding to the sludge withdrawal or dewatering operation. Enables traceability between process control data and residuals management records.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sludgeType rdf:type rdf:Property ;
    rdfs:label 'Sludge Type' ;
    rdfs:comment 'Classification of the sludge by its chemical or biological origin. \'alum_sludge\' results from coagulation with aluminum sulfate; \'lime_sludge\' from lime softening; \'biological_sludge\' from activated sludge or biofilm processes at WWTPs; \'filter_backwash_solids\' from filter media cleaning; \'mixed_sludge\' from combined streams; \'digested_sludge\' from anaerobic or aerobic digestion. [ENUM-REF-CANDIDATE: alum_sludge|lime_sludge|biological_sludge|filter_backwash_solids|mixed_sludge|digested_sludge — promote to reference product]' ;
    rdfs:domain ind:SludgeProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSolidsPct rdf:type rdf:Property ;
    rdfs:label 'Total Solids Pct' ;
    rdfs:comment 'Concentration of total solids in the sludge expressed as a percentage by weight (% TS). Key parameter for dewatering performance assessment and dry weight calculation. Sourced from LIMS analytical results.' ;
    rdfs:domain ind:SludgeProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentProcess rdf:type rdf:Property ;
    rdfs:label 'Treatment Process' ;
    rdfs:comment 'The specific water or wastewater treatment process that generated the sludge. Supports process-level residuals tracking and optimization. [ENUM-REF-CANDIDATE: coagulation|lime_softening|filtration|biological_treatment|anaerobic_digestion|aerobic_digestion|membrane_filtration|chemical_precipitation — promote to reference product]' ;
    rdfs:domain ind:SludgeProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vectorAttractionReduction rdf:type rdf:Property ;
    rdfs:label 'Vector Attraction Reduction' ;
    rdfs:comment 'Indicates whether the sludge or biosolids meets vector attraction reduction (VAR) requirements under EPA 40 CFR Part 503.33. True = VAR requirements met; False = not met or not applicable. Required for land application permit compliance.' ;
    rdfs:domain ind:SludgeProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volatileSolidsPct rdf:type rdf:Property ;
    rdfs:label 'Volatile Solids Pct' ;
    rdfs:comment 'Percentage of volatile (organic) solids in the sludge relative to total solids. Indicates organic content and biological stability; used to assess vector attraction reduction compliance under EPA 40 CFR Part 503.' ;
    rdfs:domain ind:SludgeProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeGallons rdf:type rdf:Property ;
    rdfs:label 'Volume Gallons' ;
    rdfs:comment 'Volume of liquid sludge generated during the production event, measured in gallons. Primary quantitative measure for residuals management planning and NPDES permit compliance reporting.' ;
    rdfs:domain ind:SludgeProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intakeMeterInstallationId rdf:type rdf:Property ;
    rdfs:label 'Intake Meter Installation Id' ;
    rdfs:comment 'Foreign key linking to metering.installation. Business justification: Source water intake events reference the meter installation at the intake point measuring raw water withdrawal volumes. Withdrawal permits require metered intake volumes for compliance tracking. Water' ;
    rdfs:domain ind:SourceWaterIntake ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Installation .

ind:intakePumpStationId rdf:type rdf:Property ;
    rdfs:label 'Intake Pump Station Id' ;
    rdfs:comment 'Identifier referencing the pump station asset through which raw water was drawn from the source. Links to the asset/facility master record managed in IBM Maximo CMMS.' ;
    rdfs:domain ind:SourceWaterIntake ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PumpStation .

ind:waterSourceId rdf:type rdf:Property ;
    rdfs:label 'Water Source Id' ;
    rdfs:comment 'Identifier referencing the specific raw water source body or groundwater well from which water was withdrawn. Links to the water source master record (e.g., river, reservoir, aquifer, well).' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WaterSource .

ind:intakeEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Intake End Timestamp' ;
    rdfs:comment 'Date and time at which the raw water intake event concluded. Used with intake_timestamp to calculate duration and total volume withdrawn during the event.' ;
    rdfs:domain ind:SourceWaterIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:intakeEventNumber rdf:type rdf:Property ;
    rdfs:label 'Intake Event Number' ;
    rdfs:comment 'Externally-known business identifier for the intake event, used in operational logs, regulatory submissions, and Monthly Operating Reports (MOR). Format: SWI-{YYYY}-{NNNNNN}.' ;
    rdfs:domain ind:SourceWaterIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intakeMethod rdf:type rdf:Property ;
    rdfs:label 'Intake Method' ;
    rdfs:comment 'Method by which raw water was conveyed from the source to the treatment facility. \'gravity\' indicates flow by gravity through an intake channel or conduit; \'pumped\' indicates mechanical pumping; \'combined\' indicates both methods; \'emergency_bypass\' indicates use of an emergency intake route.' ;
    rdfs:domain ind:SourceWaterIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intakeScreenCondition rdf:type rdf:Property ;
    rdfs:label 'Intake Screen Condition' ;
    rdfs:comment 'Operational condition of the intake screening equipment (bar screens, traveling screens) at the time of the intake event. Blocked or bypassed screens affect flow rates and may allow debris into the treatment process, impacting downstream equipment and water quality.' ;
    rdfs:domain ind:SourceWaterIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intakeStatus rdf:type rdf:Property ;
    rdfs:label 'Intake Status' ;
    rdfs:comment 'Current lifecycle status of the intake event record. \'active\' indicates intake is in progress; \'completed\' indicates the event concluded normally; \'suspended\' indicates intake was halted due to quality or operational issue; \'cancelled\' indicates the event was voided; \'pending_review\' indicates the record requires quality assurance review.' ;
    rdfs:domain ind:SourceWaterIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intakeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Intake Timestamp' ;
    rdfs:comment 'The principal real-world date and time at which the raw water intake event commenced, as recorded by the SCADA/OSIsoft PI Historian system at the intake pump station. Conforms to ISO 8601 format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:SourceWaterIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:numberOfPumpsActive rdf:type rdf:Property ;
    rdfs:label 'Number Of Pumps Active' ;
    rdfs:comment 'Count of intake pumps operating simultaneously during the intake event. Used for energy consumption analysis, pump performance benchmarking, and maintenance scheduling in IBM Maximo CMMS.' ;
    rdfs:domain ind:SourceWaterIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:permitComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Permit Compliance Status' ;
    rdfs:comment 'Compliance status of this intake event relative to the applicable water withdrawal permit limits. \'compliant\' indicates volume is within permit limits; \'non_compliant\' indicates a permit exceedance requiring regulatory notification; \'approaching_limit\' indicates volume is within 90% of the permit limit; \'under_review\' indicates compliance determination is pending.' ;
    rdfs:domain ind:SourceWaterIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitDailyLimitMg rdf:type rdf:Property ;
    rdfs:label 'Permit Daily Limit Mg' ;
    rdfs:comment 'Maximum daily volume of raw water authorized for withdrawal under the applicable water withdrawal permit, expressed in Million Gallons (MG). Used to assess compliance status against actual volume withdrawn.' ;
    rdfs:domain ind:SourceWaterIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pumpStationOperatingPressurePsi rdf:type rdf:Property ;
    rdfs:label 'Pump Station Operating Pressure Psi' ;
    rdfs:comment 'Operating pressure at the intake pump station during the intake event, measured in Pounds per Square Inch (PSI). Monitored via SCADA to ensure pumps operate within design parameters and to detect potential main breaks or pressure anomalies.' ;
    rdfs:domain ind:SourceWaterIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rawWaterColorCpu rdf:type rdf:Property ;
    rdfs:label 'Raw Water Color Cpu' ;
    rdfs:comment 'Apparent color of raw water at intake, measured in Color Units (CPU) using the platinum-cobalt standard. High color values indicate elevated natural organic matter (NOM) and humic substances, which are precursors to Disinfection Byproducts (DBP) including Trihalomethanes (THM) and Haloacetic Acids (HAA5).' ;
    rdfs:domain ind:SourceWaterIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceWaterAlertActive rdf:type rdf:Property ;
    rdfs:label 'Source Water Alert Active' ;
    rdfs:comment 'Indicates whether an active source water quality alert or advisory was in effect at the time of this intake event (e.g., algal bloom advisory, upstream contamination notice, drought restriction). When True, triggers enhanced monitoring protocols and treatment process review.' ;
    rdfs:domain ind:SourceWaterIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceWaterProtectionZone rdf:type rdf:Property ;
    rdfs:label 'Source Water Protection Zone' ;
    rdfs:comment 'Designation of the source water protection zone or wellhead protection area associated with this intake point, as defined in the utility\'s Source Water Assessment and Protection (SWAP) program. Used for land use management and contamination risk assessment.' ;
    rdfs:domain ind:SourceWaterIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upstreamEventDescription rdf:type rdf:Property ;
    rdfs:label 'Upstream Event Description' ;
    rdfs:comment 'Free-text description of any known upstream events or conditions that may affect raw water quality at the time of intake (e.g., upstream spill, agricultural runoff, upstream WWTP discharge, construction activity). Supports source water protection program documentation.' ;
    rdfs:domain ind:SourceWaterIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeWithdrawnMg rdf:type rdf:Property ;
    rdfs:label 'Volume Withdrawn Mg' ;
    rdfs:comment 'Total volume of raw water withdrawn during the intake event, expressed in Million Gallons (MG). This is the principal quantitative measurement for the intake event, used for permit compliance, production planning, and Non-Revenue Water (NRW) calculations.' ;
    rdfs:domain ind:SourceWaterIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dischargePointId rdf:type rdf:Property ;
    rdfs:label 'Discharge Point Id' ;
    rdfs:comment 'Regulatory identifier for the permitted discharge point or outfall as designated in the NPDES permit (e.g., \'Outfall 001\'). Used in Discharge Monitoring Reports (DMRs) and effluent sampling records. May be null for non-discharge permits such as drinking water operating permits.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DischargePoint .

ind:biosolidsPermitFlag rdf:type rdf:Property ;
    rdfs:label 'Biosolids Permit Flag' ;
    rdfs:comment 'Indicates whether this permit includes authorization for biosolids or residuals management (land application, incineration, or landfill disposal). Relevant for WWTPs subject to EPA 40 CFR Part 503 biosolids regulations.' ;
    rdfs:domain ind:TreatmentPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bodLimitMgL rdf:type rdf:Property ;
    rdfs:label 'Bod Limit Mg L' ;
    rdfs:comment 'Permitted maximum concentration of Biochemical Oxygen Demand (BOD) in treated effluent, expressed in milligrams per liter (mg/L). A primary indicator of organic pollution load in wastewater discharge. Used for DMR compliance evaluation.' ;
    rdfs:domain ind:TreatmentPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chlorineResidualLimitMgL rdf:type rdf:Property ;
    rdfs:label 'Chlorine Residual Limit Mg L' ;
    rdfs:comment 'Minimum or maximum permitted chlorine residual concentration in finished water or treated effluent, expressed in mg/L. For drinking water, a minimum residual is required at the point of entry to the distribution system. For NPDES discharge, a maximum may be set to protect aquatic life.' ;
    rdfs:domain ind:TreatmentPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceScheduleEndDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Schedule End Date' ;
    rdfs:comment 'The final date by which the facility must achieve full compliance with all permit limits per the regulatory-approved compliance schedule. Null if no compliance schedule is in effect. Used to track CIP project milestones and regulatory commitments.' ;
    rdfs:domain ind:TreatmentPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ctRequirementMgMinL rdf:type rdf:Property ;
    rdfs:label 'Ct Requirement Mg Min L' ;
    rdfs:comment 'Minimum required CT (Contact Time) value for disinfection as specified in the permit, expressed in mg·min/L (product of disinfectant concentration and contact time). CT compliance is a core Surface Water Treatment Rule requirement for Giardia and virus inactivation credit.' ;
    rdfs:domain ind:TreatmentPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dmrSubmissionMethod rdf:type rdf:Property ;
    rdfs:label 'Dmr Submission Method' ;
    rdfs:comment 'The required or preferred method for submitting Discharge Monitoring Reports (DMRs) or Monthly Operating Reports (MORs) to the regulatory agency. NetDMR is the EPA\'s electronic DMR system; eDMR refers to state-specific electronic systems; paper and state_portal are alternatives.' ;
    rdfs:domain ind:TreatmentPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Date' ;
    rdfs:comment 'Anticipated or scheduled date of the next regulatory compliance inspection. Supports proactive compliance preparation and internal audit scheduling. May be estimated based on inspection frequency requirements.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:npdesMajorMinorClass rdf:type rdf:Property ;
    rdfs:label 'Npdes Major Minor Class' ;
    rdfs:comment 'EPA classification of the NPDES permit as major or minor based on facility size, discharge volume, and potential environmental impact. Major facilities are subject to more stringent oversight, mandatory DMR reporting, and EPA inspection priorities. Applicable only to NPDES permit types.' ;
    rdfs:domain ind:TreatmentPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitCategory rdf:type rdf:Property ;
    rdfs:label 'Permit Category' ;
    rdfs:comment 'Indicates whether the permit is an individual permit (facility-specific terms and conditions), a general permit (covers a category of similar dischargers), or an emergency permit (temporary authorization). Determines the regulatory review process and compliance obligations.' ;
    rdfs:domain ind:TreatmentPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitName rdf:type rdf:Property ;
    rdfs:label 'Permit Name' ;
    rdfs:comment 'Descriptive name or title of the permit as assigned by the issuing agency or used internally (e.g., \'City Water Treatment Plant NPDES Discharge Permit\', \'Regional WTP Drinking Water Operating Permit\'). Supports human-readable identification in compliance registers and reports.' ;
    rdfs:domain ind:TreatmentPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permittedAvgFlowMgd rdf:type rdf:Property ;
    rdfs:label 'Permitted Avg Flow Mgd' ;
    rdfs:comment 'Monthly average flow rate authorized under this permit in Million Gallons per Day (MGD). Distinct from the peak daily limit; used for long-term capacity planning and average-basis compliance evaluation in DMR submissions.' ;
    rdfs:domain ind:TreatmentPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permittedFlowMgd rdf:type rdf:Property ;
    rdfs:label 'Permitted Flow Mgd' ;
    rdfs:comment 'Maximum daily flow rate authorized under this permit, expressed in Million Gallons per Day (MGD). This is the principal quantitative limit governing facility capacity and is used for capacity planning, compliance monitoring, and MOR/DMR reporting.' ;
    rdfs:domain ind:TreatmentPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pfasMonitoringRequired rdf:type rdf:Property ;
    rdfs:label 'Pfas Monitoring Required' ;
    rdfs:comment 'Indicates whether the permit requires monitoring for Per- and Polyfluoroalkyl Substances (PFAS) compounds. Reflects EPA\'s PFAS Action Plan and emerging state-level PFAS MCLs. Drives LIMS sampling plan configuration and CCR disclosure requirements.' ;
    rdfs:domain ind:TreatmentPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phLimitMax rdf:type rdf:Property ;
    rdfs:label 'Ph Limit Max' ;
    rdfs:comment 'Maximum permitted pH value for treated effluent or finished water as specified in the permit. Used alongside ph_limit_min to define the acceptable pH range for compliance monitoring and corrosion control program evaluation.' ;
    rdfs:domain ind:TreatmentPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phLimitMin rdf:type rdf:Property ;
    rdfs:label 'Ph Limit Min' ;
    rdfs:comment 'Minimum permitted pH value for treated effluent or finished water as specified in the permit. pH is a key indicator of water chemistry and corrosion control. Typically 6.0–9.0 for NPDES effluent; 6.5–8.5 for drinking water under SDWA.' ;
    rdfs:domain ind:TreatmentPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'Current status of the permit renewal process. Tracks progression from initial application through agency review to final determination. Supports compliance calendar management and regulatory relationship tracking.' ;
    rdfs:domain ind:TreatmentPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termYears rdf:type rdf:Property ;
    rdfs:label 'Term Years' ;
    rdfs:comment 'Duration of the permit in years as specified by the issuing agency. NPDES permits are typically issued for 5-year terms; state drinking water operating permits may vary. Used for renewal planning and compliance scheduling.' ;
    rdfs:domain ind:TreatmentPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tssLimitMgL rdf:type rdf:Property ;
    rdfs:label 'Tss Limit Mg L' ;
    rdfs:comment 'Permitted maximum concentration of Total Suspended Solids (TSS) in treated effluent, expressed in milligrams per liter (mg/L). Core secondary treatment standard for WWTP NPDES compliance. Used in DMR reporting and effluent quality monitoring.' ;
    rdfs:domain ind:TreatmentPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:turbidityLimitNtu rdf:type rdf:Property ;
    rdfs:label 'Turbidity Limit Ntu' ;
    rdfs:comment 'Maximum permitted turbidity of finished water or treated effluent in Nephelometric Turbidity Units (NTU). For WTPs, the Surface Water Treatment Rule requires combined filter effluent turbidity not to exceed 0.3 NTU in 95% of measurements. Critical for MCL compliance.' ;
    rdfs:domain ind:TreatmentPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:violationCountActive rdf:type rdf:Property ;
    rdfs:label 'Violation Count Active' ;
    rdfs:comment 'Number of currently unresolved permit violations (effluent limit exceedances, reporting violations, or schedule of compliance violations) associated with this permit. Sourced from the regulatory agency\'s compliance tracking system. Used for compliance risk scoring and executive reporting.' ;
    rdfs:domain ind:TreatmentPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTreatmentLabSampleId rdf:type rdf:Property ;
    rdfs:label 'Primary Treatment Lab Sample Id' ;
    rdfs:comment 'Laboratory sample identifier from the LIMS (LabWare or similar) that produced the analytical result triggering this violation. Enables traceability from violation back to the original lab sample and chain of custody.' ;
    rdfs:domain ind:TreatmentViolation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabSample .

ind:ccrReportable rdf:type rdf:Property ;
    rdfs:label 'Ccr Reportable' ;
    rdfs:comment 'Indicates whether this violation must be disclosed in the annual Consumer Confidence Report (CCR) sent to customers, as required by EPA SDWA regulations for community water systems.' ;
    rdfs:domain ind:TreatmentViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enforcementActionTaken rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Taken' ;
    rdfs:comment 'Indicates whether the regulatory agency has initiated a formal enforcement action (e.g., Notice of Violation, Administrative Order, Consent Order, penalty) in response to this violation.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceedanceMagnitude rdf:type rdf:Property ;
    rdfs:label 'Exceedance Magnitude' ;
    rdfs:comment 'The numeric difference between the measured value and the regulatory limit (measured_value minus regulatory_limit). Positive values indicate the degree of exceedance above the limit, supporting severity assessment and trend analysis.' ;
    rdfs:domain ind:TreatmentViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isRepeatViolation rdf:type rdf:Property ;
    rdfs:label 'Is Repeat Violation' ;
    rdfs:comment 'Indicates whether this violation is a repeat occurrence of the same contaminant or parameter violation at the same facility within the preceding 12-month period. Repeat violations may trigger escalated regulatory response and increased penalties.' ;
    rdfs:domain ind:TreatmentViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measuredValueUom rdf:type rdf:Property ;
    rdfs:label 'Measured Value Uom' ;
    rdfs:comment 'Unit of measure for the measured_value field (e.g., mg/L for chemical concentrations, NTU for Nephelometric Turbidity Units, mg·min/L for CT Contact Time, CFU/100mL for microbial counts). [ENUM-REF-CANDIDATE: mg/L|NTU|mg·min/L|CFU/100mL|pH|mg/kg|ug/L|pCi/L|MPN/100mL — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TreatmentViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryLimit rdf:type rdf:Property ;
    rdfs:label 'Regulatory Limit' ;
    rdfs:comment 'The applicable Maximum Contaminant Level (MCL), treatment technique standard, or permit limit that was exceeded or violated. For CT violations, this is the required CT value in mg·min/L.' ;
    rdfs:domain ind:TreatmentViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Status' ;
    rdfs:comment 'Status of the formal notification to the regulatory agency (EPA or State Primacy Agency) regarding this violation. Tracks whether notification is pending, has been submitted, has been acknowledged, or is overdue per regulatory deadlines.' ;
    rdfs:domain ind:TreatmentViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationNumber rdf:type rdf:Property ;
    rdfs:label 'Violation Number' ;
    rdfs:comment 'Externally-known, human-readable unique reference number assigned to this violation record, used in regulatory correspondence, public notifications, and compliance tracking systems.' ;
    rdfs:domain ind:TreatmentViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationStatus rdf:type rdf:Property ;
    rdfs:label 'Violation Status' ;
    rdfs:comment 'Current lifecycle status of the violation record, tracking its progression from identification through corrective action to regulatory closure.' ;
    rdfs:domain ind:TreatmentViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uvDisinfectionEventId rdf:type rdf:Property ;
    rdfs:label 'Uv Disinfection Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each UV disinfection operational event record in the Silver Layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:UvDisinfectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maximoWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Maximo Work Order Id' ;
    rdfs:comment 'Reference to the IBM Maximo Asset Management work order created in response to a UV system fault, alarm, or maintenance event. Links the disinfection event to the maintenance activity for asset lifecycle tracking and O&M cost analysis.' ;
    rdfs:domain ind:UvDisinfectionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:reactorProcessUnitId rdf:type rdf:Property ;
    rdfs:label 'Reactor Process Unit Id' ;
    rdfs:comment 'Reference to the specific UV reactor unit that generated this disinfection event. Links to the asset registry for the UV reactor equipment.' ;
    rdfs:domain ind:UvDisinfectionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessUnit .

ind:acknowledgmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Timestamp' ;
    rdfs:comment 'Date and time when the certified operator acknowledged this UV disinfection event record. Null if not yet acknowledged. Provides audit trail for regulatory compliance and response time tracking.' ;
    rdfs:domain ind:UvDisinfectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:doseComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Dose Compliance Flag' ;
    rdfs:comment 'Boolean indicator of whether the delivered UV dose (uv_dose_delivered_mj_cm2) met or exceeded the required UV dose (uv_dose_required_mj_cm2) for regulatory log inactivation credit. True = compliant; False = non-compliant. Core field for regulatory reporting and MOR submissions.' ;
    rdfs:domain ind:UvDisinfectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lampHoursElapsed rdf:type rdf:Property ;
    rdfs:label 'Lamp Hours Elapsed' ;
    rdfs:comment 'Cumulative operating hours logged on the UV lamp(s) at the time of this event. Used to track lamp aging, predict end-of-life, and schedule preventive lamp replacement per manufacturer recommendations and CMMS work orders.' ;
    rdfs:domain ind:UvDisinfectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lampPowerPct rdf:type rdf:Property ;
    rdfs:label 'Lamp Power Pct' ;
    rdfs:comment 'Current power output of the UV lamp(s) expressed as a percentage of rated maximum power (0–100%). Controlled by the Variable Frequency Drive (VFD) or ballast controller. Used to assess lamp performance degradation and energy efficiency.' ;
    rdfs:domain ind:UvDisinfectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lampRatedHours rdf:type rdf:Property ;
    rdfs:label 'Lamp Rated Hours' ;
    rdfs:comment 'Manufacturer-rated maximum operating hours for the UV lamp before replacement is required. Used in conjunction with lamp_hours_elapsed to calculate remaining lamp life and trigger preventive maintenance work orders in IBM Maximo.' ;
    rdfs:domain ind:UvDisinfectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lampStatus rdf:type rdf:Property ;
    rdfs:label 'Lamp Status' ;
    rdfs:comment 'Operational status of the UV lamp(s) in the reactor at the time of the event: on (operating normally), off (intentionally de-energized), fault (lamp failure or electrical fault detected), warming_up (lamp in pre-operational warm-up phase), or end_of_life (lamp hours exceeded rated life). Sourced from SCADA/PLC lamp monitoring.' ;
    rdfs:domain ind:UvDisinfectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logInactivationTarget rdf:type rdf:Property ;
    rdfs:label 'Log Inactivation Target' ;
    rdfs:comment 'The required log inactivation credit (e.g., 2.0-log, 3.0-log, 4.0-log) for the target pathogen as mandated by the applicable regulatory treatment technique (e.g., LT2ESWTR Cryptosporidium bin assignment). Expressed as a decimal log value. Determines the required UV dose threshold.' ;
    rdfs:domain ind:UvDisinfectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:morIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Mor Included Flag' ;
    rdfs:comment 'Boolean indicator of whether this UV disinfection event record has been included in the Monthly Operating Report (MOR) submission for the applicable reporting period. True = included in MOR; False = excluded (e.g., voided, data quality issue). Supports MOR completeness verification.' ;
    rdfs:domain ind:UvDisinfectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatorAcknowledgedFlag rdf:type rdf:Property ;
    rdfs:label 'Operator Acknowledged Flag' ;
    rdfs:comment 'Boolean indicator of whether a certified operator has reviewed and acknowledged this UV disinfection event record, particularly for non-compliant or alarm events. True = acknowledged; False = pending acknowledgment. Required for regulatory audit trails and MOR documentation.' ;
    rdfs:domain ind:UvDisinfectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reactorBankNumber rdf:type rdf:Property ;
    rdfs:label 'Reactor Bank Number' ;
    rdfs:comment 'Sequential number identifying the UV reactor bank or train within the treatment facility (e.g., Bank 1, Bank 2). Multiple reactor banks may operate in series or parallel. Used for bank-level performance comparison and redundancy management.' ;
    rdfs:domain ind:UvDisinfectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sensorReadingMv rdf:type rdf:Property ;
    rdfs:label 'Sensor Reading Mv' ;
    rdfs:comment 'Raw millivolt (mV) output from the UV intensity sensor (radiometer) within the reactor, as recorded by the SCADA/PI Historian system before conversion to mW/cm². Retained for sensor calibration verification and data quality auditing.' ;
    rdfs:domain ind:UvDisinfectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sleeveFoulingFactor rdf:type rdf:Property ;
    rdfs:label 'Sleeve Fouling Factor' ;
    rdfs:comment 'Dimensionless correction factor (0.0–1.0) representing the degree of fouling on the UV lamp quartz sleeve. A value of 1.0 indicates a clean sleeve; lower values indicate fouling that reduces UV transmittance through the sleeve and effective dose delivery. Used in dose calculation models and sleeve cleaning scheduling.' ;
    rdfs:domain ind:UvDisinfectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPathogen rdf:type rdf:Property ;
    rdfs:label 'Target Pathogen' ;
    rdfs:comment 'The primary pathogen for which the UV dose and log inactivation credit is being calculated and verified: Cryptosporidium, Giardia, virus, or bacteria. Determines the applicable dose-response curve and regulatory credit table used in compliance assessment.' ;
    rdfs:domain ind:UvDisinfectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uvDoseDeliveredMjCm2 rdf:type rdf:Property ;
    rdfs:label 'Uv Dose Delivered Mj Cm2' ;
    rdfs:comment 'Calculated UV dose actually delivered to the water stream, expressed in millijoules per square centimeter (mJ/cm²). Computed by the UV reactor control system using validated dose-response models incorporating UV intensity, UVT, and flow rate. This is the primary metric for log inactivation credit verification.' ;
    rdfs:domain ind:UvDisinfectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uvDoseRequiredMjCm2 rdf:type rdf:Property ;
    rdfs:label 'Uv Dose Required Mj Cm2' ;
    rdfs:comment 'Minimum UV dose required to achieve the regulatory log inactivation credit for the target pathogen (e.g., Cryptosporidium, Giardia, viruses), expressed in mJ/cm². Defined by the applicable regulatory treatment technique requirement (e.g., LT2ESWTR). Used to determine dose compliance status.' ;
    rdfs:domain ind:UvDisinfectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uvIntensityMwCm2 rdf:type rdf:Property ;
    rdfs:label 'Uv Intensity Mw Cm2' ;
    rdfs:comment 'Measured UV irradiance at the sensor within the reactor, expressed in milliwatts per square centimeter (mW/cm²). Sourced from the UV sensor array via SCADA/PI Historian. Critical input for UV dose calculation and lamp performance monitoring.' ;
    rdfs:domain ind:UvDisinfectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uvTransmittancePct rdf:type rdf:Property ;
    rdfs:label 'Uv Transmittance Pct' ;
    rdfs:comment 'Ultraviolet transmittance of the water at 254 nm, expressed as a percentage (UVT%). Measured by an online UVT analyzer or photometer. Directly affects the effective UV dose delivered to pathogens; lower UVT reduces dose efficiency.' ;
    rdfs:domain ind:UvDisinfectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:biosolidsBatchId rdf:type rdf:Property ;
    rdfs:label 'Biosolids Batch Id' ;
    rdfs:comment 'Unique identifier for the biosolids production batch. Primary key for the biosolids batch record.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BiosolidsBatch .

ind:treatmentProcessUnitId rdf:type rdf:Property ;
    rdfs:label 'Treatment Process Unit Id' ;
    rdfs:comment 'Reference to the specific treatment process unit (digester, dewatering equipment, stabilization system) that produced this batch.' ;
    rdfs:domain ind:BiosolidsBatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessUnit .

ind:arsenicConcentrationMgPerKg rdf:type rdf:Property ;
    rdfs:label 'Arsenic Concentration Mg Per Kg' ;
    rdfs:comment 'Arsenic concentration in milligrams per kilogram dry weight. Ceiling concentration limit: 75 mg/kg per 40 CFR Part 503 Table 1.' ;
    rdfs:domain ind:BiosolidsBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchDate rdf:type rdf:Property ;
    rdfs:label 'Batch Date' ;
    rdfs:comment 'The date when this biosolids batch was produced and removed from the treatment process. Critical for regulatory compliance and shelf-life tracking.' ;
    rdfs:domain ind:BiosolidsBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:batchEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Batch End Timestamp' ;
    rdfs:comment 'Timestamp when the biosolids batch production process was completed and the material was ready for disposition.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:batchStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Batch Start Timestamp' ;
    rdfs:comment 'Timestamp when the biosolids batch production process began, including dewatering or stabilization initiation.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cadmiumConcentrationMgPerKg rdf:type rdf:Property ;
    rdfs:label 'Cadmium Concentration Mg Per Kg' ;
    rdfs:comment 'Cadmium concentration in milligrams per kilogram dry weight. Ceiling concentration limit: 85 mg/kg per 40 CFR Part 503 Table 1.' ;
    rdfs:domain ind:BiosolidsBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:copperConcentrationMgPerKg rdf:type rdf:Property ;
    rdfs:label 'Copper Concentration Mg Per Kg' ;
    rdfs:comment 'Copper concentration in milligrams per kilogram dry weight. Ceiling concentration limit: 4,300 mg/kg per 40 CFR Part 503 Table 1.' ;
    rdfs:domain ind:BiosolidsBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dispositionMethod rdf:type rdf:Property ;
    rdfs:label 'Disposition Method' ;
    rdfs:comment 'The final disposition method for this biosolids batch. Determines applicable regulatory requirements under 40 CFR Part 503 Subparts B, C, D, or E.' ;
    rdfs:domain ind:BiosolidsBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionSiteName rdf:type rdf:Property ;
    rdfs:label 'Disposition Site Name' ;
    rdfs:comment 'Name of the land application site, landfill, incinerator, or beneficial reuse facility where this batch was sent.' ;
    rdfs:domain ind:BiosolidsBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionSitePermitNumber rdf:type rdf:Property ;
    rdfs:label 'Disposition Site Permit Number' ;
    rdfs:comment 'Regulatory permit number for the disposition site (land application permit, landfill permit, incinerator air permit, etc.).' ;
    rdfs:domain ind:BiosolidsBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionalQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Exceptional Quality Flag' ;
    rdfs:comment 'Indicates whether this batch meets Exceptional Quality criteria (Class A pathogen reduction, pollutant concentration limits per Table 3, and vector attraction reduction). EQ biosolids have no federal land application restrictions.' ;
    rdfs:domain ind:BiosolidsBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fecalColiformDensityMpnPerGram rdf:type rdf:Property ;
    rdfs:label 'Fecal Coliform Density Mpn Per Gram' ;
    rdfs:comment 'Fecal coliform density in MPN per gram of total solids (dry weight basis). Class A requires <1,000 MPN/g; Class B requires <2,000,000 MPN/g.' ;
    rdfs:domain ind:BiosolidsBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laboratoryAnalysisDate rdf:type rdf:Property ;
    rdfs:label 'Laboratory Analysis Date' ;
    rdfs:comment 'Date when laboratory analysis of this batch was completed. Used to verify compliance with monitoring frequency requirements.' ;
    rdfs:domain ind:BiosolidsBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadConcentrationMgPerKg rdf:type rdf:Property ;
    rdfs:label 'Lead Concentration Mg Per Kg' ;
    rdfs:comment 'Lead concentration in milligrams per kilogram dry weight. Ceiling concentration limit: 840 mg/kg per 40 CFR Part 503 Table 1.' ;
    rdfs:domain ind:BiosolidsBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mercuryConcentrationMgPerKg rdf:type rdf:Property ;
    rdfs:label 'Mercury Concentration Mg Per Kg' ;
    rdfs:comment 'Mercury concentration in milligrams per kilogram dry weight. Ceiling concentration limit: 57 mg/kg per 40 CFR Part 503 Table 1.' ;
    rdfs:domain ind:BiosolidsBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nickelConcentrationMgPerKg rdf:type rdf:Property ;
    rdfs:label 'Nickel Concentration Mg Per Kg' ;
    rdfs:comment 'Nickel concentration in milligrams per kilogram dry weight. Ceiling concentration limit: 420 mg/kg per 40 CFR Part 503 Table 1.' ;
    rdfs:domain ind:BiosolidsBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pathogenClass rdf:type rdf:Property ;
    rdfs:label 'Pathogen Class' ;
    rdfs:comment 'Classification of pathogen reduction achieved: Class A (unrestricted use, meets PFRP requirements) or Class B (restricted use, meets PSRP requirements) per 40 CFR Part 503.' ;
    rdfs:domain ind:BiosolidsBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:percentSolids rdf:type rdf:Property ;
    rdfs:label 'Percent Solids' ;
    rdfs:comment 'Percentage of total solids content in the biosolids batch. Typical range: 15-30% for dewatered cake, 90%+ for dried pellets. Critical for vector attraction reduction Option 7 (75% solids minimum).' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salmonellaDensityMpnPer4Grams rdf:type rdf:Property ;
    rdfs:label 'Salmonella Density Mpn Per 4 Grams' ;
    rdfs:comment 'Salmonella sp. bacteria density in MPN per 4 grams of total solids (dry weight basis). Class A requires <3 MPN/4g.' ;
    rdfs:domain ind:BiosolidsBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seleniumConcentrationMgPerKg rdf:type rdf:Property ;
    rdfs:label 'Selenium Concentration Mg Per Kg' ;
    rdfs:comment 'Selenium concentration in milligrams per kilogram dry weight. Ceiling concentration limit: 100 mg/kg per 40 CFR Part 503 Table 1.' ;
    rdfs:domain ind:BiosolidsBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNitrogenPercent rdf:type rdf:Property ;
    rdfs:label 'Total Nitrogen Percent' ;
    rdfs:comment 'Total nitrogen content as percentage of dry weight. Important for agronomic application rate calculations and nutrient management planning.' ;
    rdfs:domain ind:BiosolidsBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPhosphorusPercent rdf:type rdf:Property ;
    rdfs:label 'Total Phosphorus Percent' ;
    rdfs:comment 'Total phosphorus content as percentage of dry weight. Critical for land application planning and nutrient management compliance.' ;
    rdfs:domain ind:BiosolidsBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPotassiumPercent rdf:type rdf:Property ;
    rdfs:label 'Total Potassium Percent' ;
    rdfs:comment 'Total potassium content as percentage of dry weight. Used for fertilizer value assessment and agronomic rate calculations.' ;
    rdfs:domain ind:BiosolidsBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vectorAttractionReductionMethod rdf:type rdf:Property ;
    rdfs:label 'Vector Attraction Reduction Method' ;
    rdfs:comment 'The specific vector attraction reduction option (1-10) applied per 40 CFR Part 503.33. Options include volatile solids reduction, digestion, pH adjustment, moisture reduction, and others.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volatileSolidsReductionPercent rdf:type rdf:Property ;
    rdfs:label 'Volatile Solids Reduction Percent' ;
    rdfs:comment 'Percentage reduction in volatile solids achieved during treatment. Required for vector attraction reduction Options 1 and 2 (38% minimum reduction).' ;
    rdfs:domain ind:BiosolidsBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wetWeightTons rdf:type rdf:Property ;
    rdfs:label 'Wet Weight Tons' ;
    rdfs:comment 'Total wet weight (as-hauled) of the biosolids batch in US tons. Used for transportation logistics and disposal facility invoicing.' ;
    rdfs:domain ind:BiosolidsBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zincConcentrationMgPerKg rdf:type rdf:Property ;
    rdfs:label 'Zinc Concentration Mg Per Kg' ;
    rdfs:comment 'Zinc concentration in milligrams per kilogram dry weight. Ceiling concentration limit: 7,500 mg/kg per 40 CFR Part 503 Table 1.' ;
    rdfs:domain ind:BiosolidsBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:biosolidsLandApplicationId rdf:type rdf:Property ;
    rdfs:label 'Biosolids Land Application Id' ;
    rdfs:comment 'Unique identifier for the biosolids land application event. Primary key for this transactional record.' ;
    rdfs:domain ind:BiosolidsLandApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Applicator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: EPA Part 503 and state biosolids regulations require certified applicator tracking for land application events. Links enable certification verification (applicator_certification_number validation), tr' ;
    rdfs:domain ind:BiosolidsLandApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:siteId rdf:type rdf:Property ;
    rdfs:label 'Site Id' ;
    rdfs:comment 'Reference to the approved land application site where biosolids were applied.' ;
    rdfs:domain ind:BiosolidsLandApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LandApplicationSite .

ind:agronomicRateJustification rdf:type rdf:Property ;
    rdfs:label 'Agronomic Rate Justification' ;
    rdfs:comment 'Documentation explaining how the application rate meets agronomic requirements based on crop nitrogen needs and soil conditions.' ;
    rdfs:domain ind:BiosolidsLandApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationMethod rdf:type rdf:Property ;
    rdfs:label 'Application Method' ;
    rdfs:comment 'Method used to apply biosolids to the land (surface spreading, subsurface injection, or incorporation).' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationRateDryTonsPerAcre rdf:type rdf:Property ;
    rdfs:label 'Application Rate Dry Tons Per Acre' ;
    rdfs:comment 'Rate at which biosolids were applied to the field, measured in dry tons per acre.' ;
    rdfs:domain ind:BiosolidsLandApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicatorCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Applicator Certification Number' ;
    rdfs:comment 'State-issued certification or license number of the biosolids applicator.' ;
    rdfs:domain ind:BiosolidsLandApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arsenicLoadingKgPerHectare rdf:type rdf:Property ;
    rdfs:label 'Arsenic Loading Kg Per Hectare' ;
    rdfs:comment 'Cumulative arsenic loading on the site after this application, measured in kilograms per hectare.' ;
    rdfs:domain ind:BiosolidsLandApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bufferZoneCompliant rdf:type rdf:Property ;
    rdfs:label 'Buffer Zone Compliant' ;
    rdfs:comment 'Indicates whether the application maintained required buffer distances from water bodies, property lines, and other sensitive areas.' ;
    rdfs:domain ind:BiosolidsLandApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cadmiumLoadingKgPerHectare rdf:type rdf:Property ;
    rdfs:label 'Cadmium Loading Kg Per Hectare' ;
    rdfs:comment 'Cumulative cadmium loading on the site after this application, measured in kilograms per hectare.' ;
    rdfs:domain ind:BiosolidsLandApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:copperLoadingKgPerHectare rdf:type rdf:Property ;
    rdfs:label 'Copper Loading Kg Per Hectare' ;
    rdfs:comment 'Cumulative copper loading on the site after this application, measured in kilograms per hectare.' ;
    rdfs:domain ind:BiosolidsLandApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cropType rdf:type rdf:Property ;
    rdfs:label 'Crop Type' ;
    rdfs:comment 'Type of crop grown or planned for the field receiving biosolids application.' ;
    rdfs:domain ind:BiosolidsLandApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativePollutantLoadingRateCompliant rdf:type rdf:Property ;
    rdfs:label 'Cumulative Pollutant Loading Rate Compliant' ;
    rdfs:comment 'Indicates whether the cumulative pollutant loading rates for heavy metals remain within EPA limits after this application.' ;
    rdfs:domain ind:BiosolidsLandApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fieldAcreage rdf:type rdf:Property ;
    rdfs:label 'Field Acreage' ;
    rdfs:comment 'Total acreage of the field receiving biosolids application, measured in acres.' ;
    rdfs:domain ind:BiosolidsLandApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fieldIdentifier rdf:type rdf:Property ;
    rdfs:label 'Field Identifier' ;
    rdfs:comment 'Specific field or parcel identifier within the land application site where biosolids were applied.' ;
    rdfs:domain ind:BiosolidsLandApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haulerCompanyName rdf:type rdf:Property ;
    rdfs:label 'Hauler Company Name' ;
    rdfs:comment 'Name of the company or contractor responsible for transporting and applying the biosolids.' ;
    rdfs:domain ind:BiosolidsLandApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadLoadingKgPerHectare rdf:type rdf:Property ;
    rdfs:label 'Lead Loading Kg Per Hectare' ;
    rdfs:comment 'Cumulative lead loading on the site after this application, measured in kilograms per hectare.' ;
    rdfs:domain ind:BiosolidsLandApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mercuryLoadingKgPerHectare rdf:type rdf:Property ;
    rdfs:label 'Mercury Loading Kg Per Hectare' ;
    rdfs:comment 'Cumulative mercury loading on the site after this application, measured in kilograms per hectare.' ;
    rdfs:domain ind:BiosolidsLandApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nickelLoadingKgPerHectare rdf:type rdf:Property ;
    rdfs:label 'Nickel Loading Kg Per Hectare' ;
    rdfs:comment 'Cumulative nickel loading on the site after this application, measured in kilograms per hectare.' ;
    rdfs:domain ind:BiosolidsLandApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nitrogenContentPercent rdf:type rdf:Property ;
    rdfs:label 'Nitrogen Content Percent' ;
    rdfs:comment 'Total nitrogen content of the biosolids as a percentage of dry weight, used for agronomic rate calculations.' ;
    rdfs:domain ind:BiosolidsLandApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plantAvailableNitrogenLbsPerAcre rdf:type rdf:Property ;
    rdfs:label 'Plant Available Nitrogen Lbs Per Acre' ;
    rdfs:comment 'Estimated plant-available nitrogen applied per acre, accounting for mineralization rates and crop uptake.' ;
    rdfs:domain ind:BiosolidsLandApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seleniumLoadingKgPerHectare rdf:type rdf:Property ;
    rdfs:label 'Selenium Loading Kg Per Hectare' ;
    rdfs:comment 'Cumulative selenium loading on the site after this application, measured in kilograms per hectare.' ;
    rdfs:domain ind:BiosolidsLandApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteAccessRestrictionEndDate rdf:type rdf:Property ;
    rdfs:label 'Site Access Restriction End Date' ;
    rdfs:comment 'Date when site access restrictions expire and public access is permitted.' ;
    rdfs:domain ind:BiosolidsLandApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteAccessRestrictionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Site Access Restriction Period Days' ;
    rdfs:comment 'Number of days that public access to the site must be restricted following biosolids application.' ;
    rdfs:domain ind:BiosolidsLandApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteAccessRestrictionRequired rdf:type rdf:Property ;
    rdfs:label 'Site Access Restriction Required' ;
    rdfs:comment 'Indicates whether site access restrictions are required following application based on biosolids class and pathogen reduction level.' ;
    rdfs:domain ind:BiosolidsLandApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalDryTonsApplied rdf:type rdf:Property ;
    rdfs:label 'Total Dry Tons Applied' ;
    rdfs:comment 'Total quantity of biosolids applied during this event, measured in dry metric tons.' ;
    rdfs:domain ind:BiosolidsLandApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWetTonsApplied rdf:type rdf:Property ;
    rdfs:label 'Total Wet Tons Applied' ;
    rdfs:comment 'Total quantity of biosolids applied during this event, measured in wet (as-applied) metric tons.' ;
    rdfs:domain ind:BiosolidsLandApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zincLoadingKgPerHectare rdf:type rdf:Property ;
    rdfs:label 'Zinc Loading Kg Per Hectare' ;
    rdfs:comment 'Cumulative zinc loading on the site after this application, measured in kilograms per hectare.' ;
    rdfs:domain ind:BiosolidsLandApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionSystemBlockageId rdf:type rdf:Property ;
    rdfs:label 'Collection System Blockage Id' ;
    rdfs:comment 'Unique identifier for each sewer blockage or stoppage event in the collection system.' ;
    rdfs:domain ind:CollectionSystemBlockage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:correctiveCipProjectId rdf:type rdf:Property ;
    rdfs:label 'Corrective Cip Project Id' ;
    rdfs:comment 'Foreign key linking to project.cip_project. Business justification: Chronic blockage locations trigger rehabilitation CIP projects. Tracking this relationship justifies capital investment (demonstrating O&M cost avoidance), measures project effectiveness (blockage rec' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CipProject .

ind:manholeId rdf:type rdf:Property ;
    rdfs:label 'Manhole Id' ;
    rdfs:comment 'Reference to the manhole location associated with the blockage event if applicable.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Manhole .

ind:respondingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responding Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Emergency blockage response requires individual technician accountability beyond crew_id for certification verification (confined space entry, vactor operation), training compliance, and performance m' ;
    rdfs:domain ind:CollectionSystemBlockage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sewerNetworkId rdf:type rdf:Property ;
    rdfs:label 'Sewer Network Id' ;
    rdfs:comment 'Reference to the specific pipe segment where the blockage occurred.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SewerNetwork .

ind:basinCode rdf:type rdf:Property ;
    rdfs:label 'Basin Code' ;
    rdfs:comment 'Code identifying the wastewater collection basin or drainage area where the blockage occurred.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockageCause rdf:type rdf:Property ;
    rdfs:label 'Blockage Cause' ;
    rdfs:comment 'Primary cause of the blockage event. FOG = Fats, Oils, and Grease; I&I = Inflow and Infiltration. [ENUM-REF-CANDIDATE: FOG|roots|debris|structural_collapse|grease_buildup|foreign_object|sediment|pipe_defect|I&I|unknown — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CollectionSystemBlockage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockageNumber rdf:type rdf:Property ;
    rdfs:label 'Blockage Number' ;
    rdfs:comment 'Externally-known unique identifier or ticket number assigned to this blockage event for tracking and reporting purposes.' ;
    rdfs:domain ind:CollectionSystemBlockage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockageSeverity rdf:type rdf:Property ;
    rdfs:label 'Blockage Severity' ;
    rdfs:comment 'Severity classification of the blockage based on impact to service and risk of overflow.' ;
    rdfs:domain ind:CollectionSystemBlockage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockageType rdf:type rdf:Property ;
    rdfs:label 'Blockage Type' ;
    rdfs:comment 'Indicates whether the blockage was partial (reduced flow) or complete (no flow).' ;
    rdfs:domain ind:CollectionSystemBlockage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceMethod rdf:type rdf:Property ;
    rdfs:label 'Clearance Method' ;
    rdfs:comment 'Method or technique used by the crew to clear the blockage and restore flow.' ;
    rdfs:domain ind:CollectionSystemBlockage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Clearance Time Minutes' ;
    rdfs:comment 'Elapsed time in minutes from crew arrival to successful clearance of the blockage.' ;
    rdfs:domain ind:CollectionSystemBlockage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clearanceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clearance Timestamp' ;
    rdfs:comment 'Date and time when the blockage was successfully cleared and flow was restored.' ;
    rdfs:domain ind:CollectionSystemBlockage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerComplaintCount rdf:type rdf:Property ;
    rdfs:label 'Customer Complaint Count' ;
    rdfs:comment 'Number of customer complaints received related to this blockage event.' ;
    rdfs:domain ind:CollectionSystemBlockage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Impact Flag' ;
    rdfs:comment 'Indicates whether the blockage event impacted customer service (e.g., backup into property, service disruption).' ;
    rdfs:domain ind:CollectionSystemBlockage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preventiveMaintenanceRecommendation rdf:type rdf:Property ;
    rdfs:label 'Preventive Maintenance Recommendation' ;
    rdfs:comment 'Recommended preventive maintenance actions to reduce future blockage risk at this location (e.g., scheduled cleaning, root treatment, pipe rehabilitation).' ;
    rdfs:domain ind:CollectionSystemBlockage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousBlockageCount rdf:type rdf:Property ;
    rdfs:label 'Previous Blockage Count' ;
    rdfs:comment 'Number of previous blockage events recorded at this location within the past 12 months.' ;
    rdfs:domain ind:CollectionSystemBlockage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rainfallAmountInches rdf:type rdf:Property ;
    rdfs:label 'Rainfall Amount Inches' ;
    rdfs:comment 'Measured rainfall amount in inches during the 24-hour period preceding the blockage event.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Timestamp' ;
    rdfs:comment 'Date and time when regulatory notification was submitted to the appropriate agency.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:repeatBlockageFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Blockage Flag' ;
    rdfs:comment 'Indicates whether this location has experienced previous blockage events within a defined time period.' ;
    rdfs:domain ind:CollectionSystemBlockage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Response Time Minutes' ;
    rdfs:comment 'Elapsed time in minutes from when the blockage was reported to when the crew arrived on site.' ;
    rdfs:domain ind:CollectionSystemBlockage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Timestamp' ;
    rdfs:comment 'Date and time when the response crew arrived on site to address the blockage.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ssoLocationDescription rdf:type rdf:Property ;
    rdfs:label 'Sso Location Description' ;
    rdfs:comment 'Description of the location where the SSO occurred (e.g., street, property, receiving water body).' ;
    rdfs:domain ind:CollectionSystemBlockage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ssoOccurredFlag rdf:type rdf:Property ;
    rdfs:label 'Sso Occurred Flag' ;
    rdfs:comment 'Indicates whether a Sanitary Sewer Overflow occurred as a result of this blockage event.' ;
    rdfs:domain ind:CollectionSystemBlockage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ssoVolumeGallons rdf:type rdf:Property ;
    rdfs:label 'Sso Volume Gallons' ;
    rdfs:comment 'Estimated volume of wastewater overflow in gallons if an SSO occurred due to the blockage.' ;
    rdfs:domain ind:CollectionSystemBlockage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Duration Minutes' ;
    rdfs:comment 'Total elapsed time in minutes from blockage detection to clearance completion.' ;
    rdfs:domain ind:CollectionSystemBlockage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:csoEventId rdf:type rdf:Property ;
    rdfs:label 'Cso Event Id' ;
    rdfs:comment 'Unique identifier for the Combined Sewer Overflow event record. Primary key for the CSO event entity.' ;
    rdfs:domain ind:CsoEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ltcpCipProjectId rdf:type rdf:Property ;
    rdfs:label 'Ltcp Cip Project Id' ;
    rdfs:comment 'Foreign key linking to project.cip_project. Business justification: CSO events drive Long-Term Control Plan (LTCP) projects mandated by EPA consent decrees. Linking events to the projects designed to eliminate them is required for regulatory reporting, demonstrating c' ;
    rdfs:domain ind:CsoEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CipProject .

ind:stormEventId rdf:type rdf:Property ;
    rdfs:label 'Storm Event Id' ;
    rdfs:comment 'Identifier linking this CSO event to the broader storm event record that triggered multiple overflows across the system.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StormEvent .

ind:bodConcentrationMgL rdf:type rdf:Property ;
    rdfs:label 'Bod Concentration Mg L' ;
    rdfs:comment 'Measured Biochemical Oxygen Demand concentration in milligrams per liter from post-event water quality sampling, indicating organic pollution level.' ;
    rdfs:domain ind:CsoEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:causeCategory rdf:type rdf:Property ;
    rdfs:label 'Cause Category' ;
    rdfs:comment 'Primary cause category of the CSO event: wet weather event exceeding system capacity, equipment failure, operational error, or unknown.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:causeDescription rdf:type rdf:Property ;
    rdfs:label 'Cause Description' ;
    rdfs:comment 'Detailed narrative description of the root cause and contributing factors that led to the CSO event.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlMeasureActive rdf:type rdf:Property ;
    rdfs:label 'Control Measure Active' ;
    rdfs:comment 'Indicates whether CSO control measures (storage tanks, green infrastructure, real-time control) were operational and active during this event.' ;
    rdfs:domain ind:CsoEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlMeasureDescription rdf:type rdf:Property ;
    rdfs:label 'Control Measure Description' ;
    rdfs:comment 'Description of the CSO control measures that were in place or activated during the event (e.g., storage tank diversion, sewer separation, green infrastructure capture).' ;
    rdfs:domain ind:CsoEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmrSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Dmr Submission Date' ;
    rdfs:comment 'Date when the DMR containing this CSO event was submitted to the regulatory agency.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dmrSubmitted rdf:type rdf:Property ;
    rdfs:label 'Dmr Submitted' ;
    rdfs:comment 'Indicates whether this CSO event has been included in a submitted DMR to the regulatory agency.' ;
    rdfs:domain ind:CsoEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eventDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Event Duration Minutes' ;
    rdfs:comment 'Total duration of the CSO event in minutes, calculated from start to end timestamp.' ;
    rdfs:domain ind:CsoEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event End Timestamp' ;
    rdfs:comment 'Date and time when the Combined Sewer Overflow event concluded and discharge ceased.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Start Timestamp' ;
    rdfs:comment 'Date and time when the Combined Sewer Overflow event began, marking the initiation of discharge to the receiving water body.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ltcpReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Ltcp Reference Code' ;
    rdfs:comment 'Identifier linking this CSO event to the relevant Long-Term Control Plan project or mitigation strategy designed to reduce or eliminate overflows at this outfall.' ;
    rdfs:domain ind:CsoEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monitoringSampleDate rdf:type rdf:Property ;
    rdfs:label 'Monitoring Sample Date' ;
    rdfs:comment 'Date when post-event water quality samples were collected from the receiving water body.' ;
    rdfs:domain ind:CsoEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatorResponseTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Operator Response Time Minutes' ;
    rdfs:comment 'Time in minutes from CSO event detection or alarm to operator acknowledgment and response initiation.' ;
    rdfs:domain ind:CsoEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outfallDesignation rdf:type rdf:Property ;
    rdfs:label 'Outfall Designation' ;
    rdfs:comment 'Regulatory designation or permit number assigned to the CSO outfall by the state or EPA.' ;
    rdfs:domain ind:CsoEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overflowVolumeMgd rdf:type rdf:Property ;
    rdfs:label 'Overflow Volume Mgd' ;
    rdfs:comment 'Overflow volume normalized to Million Gallons per Day for regulatory reporting and comparison purposes.' ;
    rdfs:domain ind:CsoEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postEventMonitoringCompleted rdf:type rdf:Property ;
    rdfs:label 'Post Event Monitoring Completed' ;
    rdfs:comment 'Indicates whether required post-event water quality monitoring has been completed and results documented.' ;
    rdfs:domain ind:CsoEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postEventMonitoringRequired rdf:type rdf:Property ;
    rdfs:label 'Post Event Monitoring Required' ;
    rdfs:comment 'Indicates whether post-event water quality monitoring of the receiving water body is required per permit conditions or LTCP commitments.' ;
    rdfs:domain ind:CsoEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:precipitationAmountInches rdf:type rdf:Property ;
    rdfs:label 'Precipitation Amount Inches' ;
    rdfs:comment 'Total rainfall amount in inches recorded during the storm event that triggered the CSO, measured at the nearest rain gauge or weather station.' ;
    rdfs:domain ind:CsoEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:precipitationDurationHours rdf:type rdf:Property ;
    rdfs:label 'Precipitation Duration Hours' ;
    rdfs:comment 'Duration of the precipitation event in hours that contributed to the CSO occurrence.' ;
    rdfs:domain ind:CsoEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publicNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Public Notification Timestamp' ;
    rdfs:comment 'Date and time when public notification was issued regarding the CSO event and potential water quality impacts.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receivingWaterBodyClassification rdf:type rdf:Property ;
    rdfs:label 'Receiving Water Body Classification' ;
    rdfs:comment 'State-designated use classification of the receiving water body (e.g., Class A, Class B, recreational, drinking water source) per state water quality standards.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingWaterBodyName rdf:type rdf:Property ;
    rdfs:label 'Receiving Water Body Name' ;
    rdfs:comment 'Name of the river, stream, lake, or other water body that received the CSO discharge.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required' ;
    rdfs:comment 'Indicates whether this CSO event triggered regulatory notification requirements to EPA or state environmental agency based on volume, duration, or receiving water sensitivity.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scadaAlarmTriggered rdf:type rdf:Property ;
    rdfs:label 'Scada Alarm Triggered' ;
    rdfs:comment 'Indicates whether a SCADA system alarm was triggered at the time of the CSO event, alerting operators to the overflow condition.' ;
    rdfs:domain ind:CsoEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tssConcentrationMgL rdf:type rdf:Property ;
    rdfs:label 'Tss Concentration Mg L' ;
    rdfs:comment 'Measured Total Suspended Solids concentration in milligrams per liter from post-event water quality sampling.' ;
    rdfs:domain ind:CsoEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeEstimationMethod rdf:type rdf:Property ;
    rdfs:label 'Volume Estimation Method' ;
    rdfs:comment 'Method used to determine the overflow volume: measured via flow meter, modeled using hydraulic simulation, estimated from duration and outfall characteristics, or calculated from SCADA data.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalSubmissionDmrSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Original Submission Dmr Submission Id' ;
    rdfs:comment 'If this is an amended or corrected DMR, this field references the dmr_submission_id of the original submission being replaced.' ;
    rdfs:domain ind:DmrSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DmrSubmission .

ind:signatoryEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Signatory Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: NPDES DMR submissions require certified operator signature with operator license verification. FK enables validation of signatory_certification_date against operator_license expiration, audit trail fo' ;
    rdfs:domain ind:DmrSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bypassEventFlag rdf:type rdf:Property ;
    rdfs:label 'Bypass Event Flag' ;
    rdfs:comment 'Indicates whether an intentional diversion of waste streams from any portion of the treatment facility occurred during this reporting period, as defined in 40 CFR 122.41(m).' ;
    rdfs:domain ind:DmrSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctionDueDate rdf:type rdf:Property ;
    rdfs:label 'Correction Due Date' ;
    rdfs:comment 'The deadline by which deficiencies must be corrected and a revised DMR must be resubmitted to the regulatory authority.' ;
    rdfs:domain ind:DmrSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deficiencyNoticeDate rdf:type rdf:Property ;
    rdfs:label 'Deficiency Notice Date' ;
    rdfs:comment 'The date on which the regulatory authority issued a deficiency notice for this DMR submission, indicating missing or incorrect data that must be corrected.' ;
    rdfs:domain ind:DmrSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dmrSubmissionNumber rdf:type rdf:Property ;
    rdfs:label 'Dmr Submission Number' ;
    rdfs:comment 'Externally-known unique identifier or tracking number for this DMR submission, often assigned by the regulatory authority or NetDMR system.' ;
    rdfs:domain ind:DmrSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netdmrTransactionCode rdf:type rdf:Property ;
    rdfs:label 'Netdmr Transaction Code' ;
    rdfs:comment 'The unique transaction identifier assigned by the EPA NetDMR system upon successful electronic submission. Used for tracking and audit purposes.' ;
    rdfs:domain ind:DmrSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodiFlag rdf:type rdf:Property ;
    rdfs:label 'Nodi Flag' ;
    rdfs:comment 'Indicates whether the facility had no discharge during the reporting period.' ;
    rdfs:domain ind:DmrSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nodiSubmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Nodi Submitted Flag' ;
    rdfs:comment 'Indicates whether a Notice of Discharge Intent (NODI) or No Discharge (NODI) certification was submitted for this reporting period, typically used when no discharge occurred.' ;
    rdfs:domain ind:DmrSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outfallCount rdf:type rdf:Property ;
    rdfs:label 'Outfall Count' ;
    rdfs:comment 'The number of discharge outfalls included in this DMR submission.' ;
    rdfs:domain ind:DmrSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outfallIdentifier rdf:type rdf:Property ;
    rdfs:label 'Outfall Identifier' ;
    rdfs:comment 'The unique identifier for the discharge outfall as specified in the NPDES permit (e.g., Outfall 001, Outfall 002). Each outfall may require separate DMR submissions.' ;
    rdfs:domain ind:DmrSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterCount rdf:type rdf:Property ;
    rdfs:label 'Parameter Count' ;
    rdfs:comment 'The total number of water quality parameters reported in this DMR submission.' ;
    rdfs:domain ind:DmrSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preparedByEmail rdf:type rdf:Property ;
    rdfs:label 'Prepared By Email' ;
    rdfs:comment 'The email address of the staff member or consultant who prepared this DMR submission.' ;
    rdfs:domain ind:DmrSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAgencyCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Agency Code' ;
    rdfs:comment 'The standardized code identifying the regulatory authority (e.g., EPA Region number or state agency code).' ;
    rdfs:domain ind:DmrSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Regulatory Contact Email' ;
    rdfs:comment 'The email address of the regulatory authority contact or inspector responsible for reviewing this DMR submission.' ;
    rdfs:domain ind:DmrSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Signatory Certification Date' ;
    rdfs:comment 'The date on which the authorized signatory certified the accuracy and completeness of the DMR data under penalty of law.' ;
    rdfs:domain ind:DmrSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signatoryDate rdf:type rdf:Property ;
    rdfs:label 'Signatory Date' ;
    rdfs:comment 'The date on which the authorized signatory certified the DMR submission.' ;
    rdfs:domain ind:DmrSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalFlowVolumeMg rdf:type rdf:Property ;
    rdfs:label 'Total Flow Volume Mg' ;
    rdfs:comment 'The total volume of wastewater discharged during the reporting period, measured in million gallons.' ;
    rdfs:domain ind:DmrSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalParameterExceedances rdf:type rdf:Property ;
    rdfs:label 'Total Parameter Exceedances' ;
    rdfs:comment 'The total count of permit limit exceedances reported in this DMR submission across all monitored parameters. Zero indicates full compliance for the reporting period.' ;
    rdfs:domain ind:DmrSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:upsetEventFlag rdf:type rdf:Property ;
    rdfs:label 'Upset Event Flag' ;
    rdfs:comment 'Indicates whether an exceptional incident occurred during this reporting period that caused temporary noncompliance with permit effluent limitations, as defined in 40 CFR 122.41(n).' ;
    rdfs:domain ind:DmrSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effluentDischargeEventId rdf:type rdf:Property ;
    rdfs:label 'Effluent Discharge Event Id' ;
    rdfs:comment 'Unique identifier for the effluent discharge event record. Primary key for tracking individual discharge occurrences from WWTP outfalls.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EffluentDischargeEvent .

ind:bypassNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Bypass Notification Timestamp' ;
    rdfs:comment 'Date and time when regulatory authorities were notified of an emergency bypass or unauthorized discharge event, as required by NPDES permit conditions.' ;
    rdfs:domain ind:EffluentDischargeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bypassReasonCode rdf:type rdf:Property ;
    rdfs:label 'Bypass Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for a treatment bypass or emergency discharge (e.g., equipment failure, extreme weather, power outage).' ;
    rdfs:domain ind:EffluentDischargeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dischargeAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Discharge Authorization Number' ;
    rdfs:comment 'External authorization or permit number assigned by the regulatory agency for this discharge event or outfall.' ;
    rdfs:domain ind:EffluentDischargeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dischargeDurationHours rdf:type rdf:Property ;
    rdfs:label 'Discharge Duration Hours' ;
    rdfs:comment 'Total duration of the discharge event measured in hours. Calculated from start and end timestamps.' ;
    rdfs:domain ind:EffluentDischargeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dischargeEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Discharge End Timestamp' ;
    rdfs:comment 'Date and time when the effluent discharge event ended. Used to calculate total discharge duration and volume.' ;
    rdfs:domain ind:EffluentDischargeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dischargeFlowRateGpm rdf:type rdf:Property ;
    rdfs:label 'Discharge Flow Rate Gpm' ;
    rdfs:comment 'Average flow rate of effluent discharge measured in gallons per minute during the event.' ;
    rdfs:domain ind:EffluentDischargeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dischargeStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Discharge Start Timestamp' ;
    rdfs:comment 'Date and time when the effluent discharge event began. Critical for calculating discharge duration and compliance with permit limits.' ;
    rdfs:domain ind:EffluentDischargeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dischargeStatus rdf:type rdf:Property ;
    rdfs:label 'Discharge Status' ;
    rdfs:comment 'Current operational status of the discharge event indicating whether it was authorized under permit conditions, an emergency bypass, or an unauthorized release.' ;
    rdfs:domain ind:EffluentDischargeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dischargeType rdf:type rdf:Property ;
    rdfs:label 'Discharge Type' ;
    rdfs:comment 'Classification of the discharge event based on operational pattern: continuous flow, intermittent release, batch discharge, or bypass event.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dischargeVolumeMgd rdf:type rdf:Property ;
    rdfs:label 'Discharge Volume Mgd' ;
    rdfs:comment 'Total volume of treated effluent discharged during this event, measured in million gallons per day. Core metric for NPDES permit compliance and DMR reporting.' ;
    rdfs:domain ind:EffluentDischargeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dmrSubmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Dmr Submitted Flag' ;
    rdfs:comment 'Indicates whether this discharge event has been included in a submitted DMR to the regulatory authority.' ;
    rdfs:domain ind:EffluentDischargeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatorName rdf:type rdf:Property ;
    rdfs:label 'Operator Name' ;
    rdfs:comment 'Name of the certified wastewater treatment plant operator on duty during the discharge event.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitLimitApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Permit Limit Applicable Flag' ;
    rdfs:comment 'Indicates whether NPDES permit discharge limits apply to this specific discharge event. False for emergency bypasses or non-permitted discharges.' ;
    rdfs:domain ind:EffluentDischargeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:treatmentLevelAchieved rdf:type rdf:Property ;
    rdfs:label 'Treatment Level Achieved' ;
    rdfs:comment 'Level of wastewater treatment achieved prior to discharge (primary, secondary, tertiary, advanced, or partial treatment during bypass).' ;
    rdfs:domain ind:EffluentDischargeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effluentParameterResultId rdf:type rdf:Property ;
    rdfs:label 'Effluent Parameter Result Id' ;
    rdfs:comment 'Unique identifier for the effluent parameter measurement result record.' ;
    rdfs:domain ind:EffluentParameterResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryEffluentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Effluent Employee Id' ;
    rdfs:comment 'Reference to the laboratory analyst who performed the analysis.' ;
    rdfs:domain ind:EffluentParameterResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:dataValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Data Validation Status' ;
    rdfs:comment 'Internal validation status of the result data before regulatory submission (draft, validated by supervisor, approved for submission, or rejected).' ;
    rdfs:domain ind:EffluentParameterResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmrSubmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Dmr Submission Status' ;
    rdfs:comment 'Status of the DMR submission that includes this result (pending, submitted to EPA, accepted by EPA, or rejected).' ;
    rdfs:domain ind:EffluentParameterResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Laboratory Batch Number' ;
    rdfs:comment 'Laboratory-assigned batch or run number for quality control and traceability purposes.' ;
    rdfs:domain ind:EffluentParameterResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:massLoadingLbsPerDay rdf:type rdf:Property ;
    rdfs:label 'Mass Loading Lbs Per Day' ;
    rdfs:comment 'Calculated mass loading of the parameter in pounds per day, derived from concentration and flow rate (concentration * flow * 8.34).' ;
    rdfs:domain ind:EffluentParameterResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validationDate rdf:type rdf:Property ;
    rdfs:label 'Validation Date' ;
    rdfs:comment 'Date when the result was validated and approved for regulatory reporting.' ;
    rdfs:domain ind:EffluentParameterResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fogInspectionId rdf:type rdf:Property ;
    rdfs:label 'Fog Inspection Id' ;
    rdfs:comment 'Unique identifier for the FOG inspection record. Primary key for the fog_inspection product.' ;
    rdfs:domain ind:FogInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:greaseInterceptorId rdf:type rdf:Property ;
    rdfs:label 'Grease Interceptor Id' ;
    rdfs:comment 'Identifier or tag number of the grease interceptor (grease trap) inspected at the establishment.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GreaseInterceptor .

ind:primaryFogSourceId rdf:type rdf:Property ;
    rdfs:label 'Primary Fog Source Id' ;
    rdfs:comment 'Identifier of the grease-generating establishment (food service establishment, restaurant, commercial kitchen) being inspected under the FOG program.' ;
    rdfs:domain ind:FogInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FogSource .

ind:enforcementActionRecommended rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Recommended' ;
    rdfs:comment 'Indicates whether the inspector recommends formal enforcement action (notice of violation, administrative order, penalty) based on inspection findings.' ;
    rdfs:domain ind:FogInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:establishmentContactName rdf:type rdf:Property ;
    rdfs:label 'Establishment Contact Name' ;
    rdfs:comment 'Name of the establishment representative (owner, manager, or designated contact) present during the inspection.' ;
    rdfs:domain ind:FogInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishmentContactSignature rdf:type rdf:Property ;
    rdfs:label 'Establishment Contact Signature' ;
    rdfs:comment 'Digital signature or acknowledgment indicator from the establishment contact confirming receipt of inspection findings and corrective action requirements.' ;
    rdfs:domain ind:FogInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:greaseDepthInches rdf:type rdf:Property ;
    rdfs:label 'Grease Depth Inches' ;
    rdfs:comment 'Measured depth of accumulated grease layer in the interceptor in inches. Excessive depth indicates need for pumping and cleaning.' ;
    rdfs:domain ind:FogInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:greaseDepthPercentage rdf:type rdf:Property ;
    rdfs:label 'Grease Depth Percentage' ;
    rdfs:comment 'Grease accumulation as a percentage of total interceptor capacity. Regulatory thresholds typically require pumping at 25% accumulation.' ;
    rdfs:domain ind:FogInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:haulerLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Hauler License Number' ;
    rdfs:comment 'License number of the grease hauling contractor used by the establishment for interceptor pumping and waste disposal.' ;
    rdfs:domain ind:FogInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionTime rdf:type rdf:Property ;
    rdfs:label 'Inspection Time' ;
    rdfs:comment 'Precise timestamp when the FOG inspection began, including time of day.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interceptorCapacityGallons rdf:type rdf:Property ;
    rdfs:label 'Interceptor Capacity Gallons' ;
    rdfs:comment 'Rated capacity of the grease interceptor in gallons, indicating the volume of wastewater it can process.' ;
    rdfs:domain ind:FogInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interceptorType rdf:type rdf:Property ;
    rdfs:label 'Interceptor Type' ;
    rdfs:comment 'Type of grease interceptor installed: gravity interceptor, hydromechanical grease interceptor, automatic grease removal device, or passive grease trap.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPumpingDate rdf:type rdf:Property ;
    rdfs:label 'Last Pumping Date' ;
    rdfs:comment 'Date when the grease interceptor was last pumped and cleaned, as reported by the establishment or verified from manifest records.' ;
    rdfs:domain ind:FogInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:photosTaken rdf:type rdf:Property ;
    rdfs:label 'Photos Taken' ;
    rdfs:comment 'Indicates whether photographic documentation was captured during the inspection for evidence and record-keeping purposes.' ;
    rdfs:domain ind:FogInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pumpingFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Pumping Frequency Days' ;
    rdfs:comment 'Required or observed frequency of grease interceptor pumping in days, based on establishment type and grease generation rate.' ;
    rdfs:domain ind:FogInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pumpingManifestVerified rdf:type rdf:Property ;
    rdfs:label 'Pumping Manifest Verified' ;
    rdfs:comment 'Indicates whether the inspector verified the pumping manifest documentation from a licensed hauler for the most recent grease interceptor pumping event.' ;
    rdfs:domain ind:FogInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Re Inspection Date' ;
    rdfs:comment 'Scheduled date for the follow-up re-inspection to verify corrective action completion.' ;
    rdfs:domain ind:FogInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Re Inspection Required' ;
    rdfs:comment 'Indicates whether a follow-up re-inspection is required to verify corrective action completion and compliance restoration.' ;
    rdfs:domain ind:FogInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:solidsDepthInches rdf:type rdf:Property ;
    rdfs:label 'Solids Depth Inches' ;
    rdfs:comment 'Measured depth of settled solids at the bottom of the interceptor in inches.' ;
    rdfs:domain ind:FogInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ssoRiskAssessment rdf:type rdf:Property ;
    rdfs:label 'Sso Risk Assessment' ;
    rdfs:comment 'Inspector assessment of the risk that this establishments FOG discharge practices pose to causing a sanitary sewer overflow event: low, moderate, high, or imminent risk.' ;
    rdfs:domain ind:FogInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationSeverity rdf:type rdf:Property ;
    rdfs:label 'Violation Severity' ;
    rdfs:comment 'Severity classification of the most serious violation identified: minor administrative issue, moderate operational deficiency, major compliance failure, or critical risk to sewer system.' ;
    rdfs:domain ind:FogInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationsNoted rdf:type rdf:Property ;
    rdfs:label 'Violations Noted' ;
    rdfs:comment 'Indicates whether any FOG program violations were identified during this inspection.' ;
    rdfs:domain ind:FogInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bestManagementPracticesRequired rdf:type rdf:Property ;
    rdfs:label 'Best Management Practices Required' ;
    rdfs:comment 'Description of specific best management practices required for the establishment to control FOG discharge and prevent sewer blockages.' ;
    rdfs:domain ind:FogSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishmentName rdf:type rdf:Property ;
    rdfs:label 'Establishment Name' ;
    rdfs:comment 'Legal or trade name of the FOG generating establishment (restaurant, food processor, institutional kitchen).' ;
    rdfs:domain ind:FogSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Permit Expiration Date' ;
    rdfs:comment 'Date when the current FOG permit expires and requires renewal.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permitIssueDate rdf:type rdf:Property ;
    rdfs:label 'Permit Issue Date' ;
    rdfs:comment 'Date when the FOG permit was originally issued to the establishment.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiredPumpingFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Required Pumping Frequency Days' ;
    rdfs:comment 'Mandated frequency in days for pumping and cleaning the grease interceptor to prevent FOG buildup and sewer blockages.' ;
    rdfs:domain ind:FogSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Risk classification of the establishment based on FOG generation volume, compliance history, and potential for sewer blockages.' ;
    rdfs:domain ind:FogSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ssoContributionFlag rdf:type rdf:Property ;
    rdfs:label 'Sso Contribution Flag' ;
    rdfs:comment 'Indicator of whether the establishment has been identified as a contributing source to a sanitary sewer overflow event.' ;
    rdfs:domain ind:FogSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iiFlowMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Ii Flow Measurement Id' ;
    rdfs:comment 'Unique identifier for the I&I flow measurement record.' ;
    rdfs:domain ind:IiFlowMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iiMonitoringPointId rdf:type rdf:Property ;
    rdfs:label 'Ii Monitoring Point Id' ;
    rdfs:comment 'Reference to the specific I&I monitoring point where this flow measurement was captured.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IiMonitoringPoint .

ind:primaryIiRegistryId rdf:type rdf:Property ;
    rdfs:label 'Primary Ii Registry Id' ;
    rdfs:comment 'Reference to the rain gauge station used to capture rainfall data for this measurement.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Registry .

ind:primaryIiSewerNetworkId rdf:type rdf:Property ;
    rdfs:label 'Primary Ii Sewer Network Id' ;
    rdfs:comment 'Reference to the specific sewer network segment (pipe, manhole, or structure) associated with this monitoring point.' ;
    rdfs:domain ind:IiFlowMeasurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SewerNetwork .

ind:averageFlowRateGpm rdf:type rdf:Property ;
    rdfs:label 'Average Flow Rate Gpm' ;
    rdfs:comment 'Average flow rate over the measurement period, expressed in gallons per minute.' ;
    rdfs:domain ind:IiFlowMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculatedIiVolumeGallons rdf:type rdf:Property ;
    rdfs:label 'Calculated Ii Volume Gallons' ;
    rdfs:comment 'Calculated volume of inflow and infiltration for the measurement period, derived by subtracting the dry weather baseline from the measured flow and integrating over time.' ;
    rdfs:domain ind:IiFlowMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dryWeatherBaselineGpm rdf:type rdf:Property ;
    rdfs:label 'Dry Weather Baseline Gpm' ;
    rdfs:comment 'Established baseline flow rate during dry weather conditions at this monitoring point, used as the reference for calculating I&I contributions.' ;
    rdfs:domain ind:IiFlowMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flowVelocityFps rdf:type rdf:Property ;
    rdfs:label 'Flow Velocity Fps' ;
    rdfs:comment 'Measured velocity of wastewater flow at the monitoring point, expressed in feet per second.' ;
    rdfs:domain ind:IiFlowMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iiType rdf:type rdf:Property ;
    rdfs:label 'Ii Type' ;
    rdfs:comment 'Classification of the I&I contribution type: infiltration (groundwater seepage), inflow (direct stormwater entry), combined (both), or unknown.' ;
    rdfs:domain ind:IiFlowMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measuredFlowRateGpm rdf:type rdf:Property ;
    rdfs:label 'Measured Flow Rate Gpm' ;
    rdfs:comment 'Instantaneous flow rate measured at the monitoring point expressed in gallons per minute.' ;
    rdfs:domain ind:IiFlowMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measuredFlowRateMgd rdf:type rdf:Property ;
    rdfs:label 'Measured Flow Rate Mgd' ;
    rdfs:comment 'Instantaneous flow rate measured at the monitoring point expressed in million gallons per day.' ;
    rdfs:domain ind:IiFlowMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Measurement Duration Minutes' ;
    rdfs:comment 'Duration over which the flow measurement was averaged or integrated, expressed in minutes.' ;
    rdfs:domain ind:IiFlowMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:peakFlowRateGpm rdf:type rdf:Property ;
    rdfs:label 'Peak Flow Rate Gpm' ;
    rdfs:comment 'Maximum instantaneous flow rate observed during the measurement period, expressed in gallons per minute.' ;
    rdfs:domain ind:IiFlowMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pipeDepthFillPercent rdf:type rdf:Property ;
    rdfs:label 'Pipe Depth Fill Percent' ;
    rdfs:comment 'Percentage of pipe cross-sectional area filled with wastewater at the time of measurement, indicating hydraulic loading.' ;
    rdfs:domain ind:IiFlowMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rainGaugeReference rdf:type rdf:Property ;
    rdfs:label 'Rain Gauge Reference' ;
    rdfs:comment 'Reference to the rain gauge station used to capture rainfall data for this measurement.' ;
    rdfs:domain ind:IiFlowMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rainfallDepthInches rdf:type rdf:Property ;
    rdfs:label 'Rainfall Depth Inches' ;
    rdfs:comment 'Cumulative rainfall depth recorded at the nearest rain gauge corresponding to the measurement timestamp, used to correlate wet-weather flow contributions.' ;
    rdfs:domain ind:IiFlowMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rehabilitationPriorityScore rdf:type rdf:Property ;
    rdfs:label 'Rehabilitation Priority Score' ;
    rdfs:comment 'Calculated priority score for infrastructure rehabilitation investment based on I&I volume, frequency, and impact, used to rank capital improvement projects.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scadaSystemReference rdf:type rdf:Property ;
    rdfs:label 'Scada System Reference' ;
    rdfs:comment 'Reference to the SCADA system that collected and transmitted this measurement data.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensorReference rdf:type rdf:Property ;
    rdfs:label 'Sensor Reference' ;
    rdfs:comment 'Reference to the flow sensor or metering device that captured this measurement.' ;
    rdfs:domain ind:IiFlowMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ssesStudyId rdf:type rdf:Property ;
    rdfs:label 'Sses Study Id' ;
    rdfs:comment 'Reference to the SSES study or I&I reduction program under which this monitoring point was established.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SsesStudy .

ind:watershedId rdf:type rdf:Property ;
    rdfs:label 'Watershed Id' ;
    rdfs:comment 'Reference to the watershed or drainage basin in which this monitoring point is located for hydrologic analysis.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Watershed .

ind:baselineDryWeatherFlowGpd rdf:type rdf:Property ;
    rdfs:label 'Baseline Dry Weather Flow Gpd' ;
    rdfs:comment 'Established baseline flow rate during dry weather conditions measured in gallons per day, used as reference for I&I calculations.' ;
    rdfs:domain ind:IiMonitoringPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contributingAreaAcres rdf:type rdf:Property ;
    rdfs:label 'Contributing Area Acres' ;
    rdfs:comment 'Size of the drainage area contributing flow to this monitoring point measured in acres.' ;
    rdfs:domain ind:IiMonitoringPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataLoggerReference rdf:type rdf:Property ;
    rdfs:label 'Data Logger Reference' ;
    rdfs:comment 'Identifier for the data logger or SCADA Remote Terminal Unit (RTU) collecting data from this monitoring point.' ;
    rdfs:domain ind:IiMonitoringPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iiMonitoringPointStatus rdf:type rdf:Property ;
    rdfs:label 'Ii Monitoring Point Status' ;
    rdfs:comment 'Current operational status of the monitoring point in the I&I monitoring program.' ;
    rdfs:domain ind:IiMonitoringPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:infiltrationRateGpd rdf:type rdf:Property ;
    rdfs:label 'Infiltration Rate Gpd' ;
    rdfs:comment 'Estimated infiltration component of I&I measured in gallons per day, representing groundwater entering the sewer system through defects.' ;
    rdfs:domain ind:IiMonitoringPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inflowRateGpd rdf:type rdf:Property ;
    rdfs:label 'Inflow Rate Gpd' ;
    rdfs:comment 'Estimated inflow component of I&I measured in gallons per day, representing stormwater entering the sewer system through direct connections.' ;
    rdfs:domain ind:IiMonitoringPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:instrumentSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Instrument Serial Number' ;
    rdfs:comment 'Manufacturer serial number of the monitoring instrument for asset tracking and calibration management.' ;
    rdfs:domain ind:IiMonitoringPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringPointCode rdf:type rdf:Property ;
    rdfs:label 'Monitoring Point Code' ;
    rdfs:comment 'Business identifier or code assigned to the monitoring point for operational reference and field reporting.' ;
    rdfs:domain ind:IiMonitoringPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringPointName rdf:type rdf:Property ;
    rdfs:label 'Monitoring Point Name' ;
    rdfs:comment 'Descriptive name or label for the monitoring point, typically referencing location or purpose.' ;
    rdfs:domain ind:IiMonitoringPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringPointType rdf:type rdf:Property ;
    rdfs:label 'Monitoring Point Type' ;
    rdfs:comment 'Classification of the monitoring point by instrumentation or inspection method used to detect or measure inflow and infiltration.' ;
    rdfs:domain ind:IiMonitoringPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Inspection Date' ;
    rdfs:comment 'Planned date for the next inspection or monitoring event at this point.' ;
    rdfs:domain ind:IiMonitoringPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:peakWetWeatherFlowGpd rdf:type rdf:Property ;
    rdfs:label 'Peak Wet Weather Flow Gpd' ;
    rdfs:comment 'Maximum recorded flow rate during wet weather events measured in gallons per day.' ;
    rdfs:domain ind:IiMonitoringPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rehabilitationPriorityCategory rdf:type rdf:Property ;
    rdfs:label 'Rehabilitation Priority Category' ;
    rdfs:comment 'Categorical classification of rehabilitation priority for capital planning and work scheduling.' ;
    rdfs:domain ind:IiMonitoringPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wetWeatherFlowMultiplier rdf:type rdf:Property ;
    rdfs:label 'Wet Weather Flow Multiplier' ;
    rdfs:comment 'Multiplier factor representing the ratio of wet weather flow to dry weather flow, indicating the severity of inflow and infiltration.' ;
    rdfs:domain ind:IiMonitoringPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:industrialUserPermitId rdf:type rdf:Property ;
    rdfs:label 'Industrial User Permit Id' ;
    rdfs:comment 'Unique identifier for the industrial user permit record. Primary key for the IUP registry.' ;
    rdfs:domain ind:IndustrialUserPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dischargeMeteringMeteringMeterId rdf:type rdf:Property ;
    rdfs:label 'Discharge Metering Metering Meter Id' ;
    rdfs:comment 'Foreign key linking to metering.metering_meter. Business justification: Industrial pretreatment permits require discharge volume monitoring for compliance and flow-based surcharge calculations. Utilities install dedicated wastewater discharge meters at industrial faciliti' ;
    rdfs:domain ind:IndustrialUserPermit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MeteringMeter .

ind:facilityLocationId rdf:type rdf:Property ;
    rdfs:label 'Facility Location Id' ;
    rdfs:comment 'Foreign key linking to asset.asset_location. Business justification: Industrial user permits are tied to specific facility locations for inspection scheduling, compliance tracking, and enforcement actions. Asset location integration enables spatial analysis of pretreat' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:pretreatmentServiceVendorId rdf:type rdf:Property ;
    rdfs:label 'Pretreatment Service Vendor Id' ;
    rdfs:comment 'Foreign key linking to supply.vendor. Business justification: Industrial users often contract pretreatment system maintenance, chemical supply, or waste hauling services. Linking permits to service vendors supports compliance monitoring (ensuring contracted pret' ;
    rdfs:domain ind:IndustrialUserPermit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:bodLimitMgPerL rdf:type rdf:Property ;
    rdfs:label 'Bod Limit Mg Per L' ;
    rdfs:comment 'Maximum permitted concentration of BOD in milligrams per liter that the industrial user may discharge to the wastewater collection system.' ;
    rdfs:domain ind:IndustrialUserPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cadmiumLimitMgPerL rdf:type rdf:Property ;
    rdfs:label 'Cadmium Limit Mg Per L' ;
    rdfs:comment 'Maximum permitted concentration of cadmium in milligrams per liter. Heavy metal limit for metal finishing and plating industries.' ;
    rdfs:domain ind:IndustrialUserPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:categoricalStandardCitation rdf:type rdf:Property ;
    rdfs:label 'Categorical Standard Citation' ;
    rdfs:comment 'Specific CFR citation for the applicable categorical pretreatment standard (e.g., 40 CFR Part 433 for Metal Finishing). Null if non-categorical.' ;
    rdfs:domain ind:IndustrialUserPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chromiumLimitMgPerL rdf:type rdf:Property ;
    rdfs:label 'Chromium Limit Mg Per L' ;
    rdfs:comment 'Maximum permitted concentration of total chromium in milligrams per liter. Heavy metal limit for metal finishing and plating industries.' ;
    rdfs:domain ind:IndustrialUserPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:codLimitMgPerL rdf:type rdf:Property ;
    rdfs:label 'Cod Limit Mg Per L' ;
    rdfs:comment 'Maximum permitted concentration of COD in milligrams per liter that the industrial user may discharge to the wastewater collection system.' ;
    rdfs:domain ind:IndustrialUserPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceScheduleFinalDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Schedule Final Date' ;
    rdfs:comment 'Final date by which the industrial user must achieve full compliance with all permit discharge limits. Null if no compliance schedule is required.' ;
    rdfs:domain ind:IndustrialUserPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceScheduleRequired rdf:type rdf:Property ;
    rdfs:label 'Compliance Schedule Required' ;
    rdfs:comment 'Indicates whether the permit includes a compliance schedule with milestones for achieving full compliance with discharge limits.' ;
    rdfs:domain ind:IndustrialUserPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:copperLimitMgPerL rdf:type rdf:Property ;
    rdfs:label 'Copper Limit Mg Per L' ;
    rdfs:comment 'Maximum permitted concentration of copper in milligrams per liter. Heavy metal limit for metal finishing and plating industries.' ;
    rdfs:domain ind:IndustrialUserPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flowLimitGpd rdf:type rdf:Property ;
    rdfs:label 'Flow Limit Gpd' ;
    rdfs:comment 'Maximum permitted daily discharge flow rate in gallons per day (GPD) that the industrial user may discharge to the wastewater collection system.' ;
    rdfs:domain ind:IndustrialUserPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fogLimitMgPerL rdf:type rdf:Property ;
    rdfs:label 'Fog Limit Mg Per L' ;
    rdfs:comment 'Maximum permitted concentration of FOG in milligrams per liter that the industrial user may discharge. Critical for food service and processing facilities.' ;
    rdfs:domain ind:IndustrialUserPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadLimitMgPerL rdf:type rdf:Property ;
    rdfs:label 'Lead Limit Mg Per L' ;
    rdfs:comment 'Maximum permitted concentration of lead in milligrams per liter. Heavy metal limit for metal finishing and plating industries.' ;
    rdfs:domain ind:IndustrialUserPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mercuryLimitMgPerL rdf:type rdf:Property ;
    rdfs:label 'Mercury Limit Mg Per L' ;
    rdfs:comment 'Maximum permitted concentration of mercury in milligrams per liter. Heavy metal limit for dental and medical facilities.' ;
    rdfs:domain ind:IndustrialUserPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nickelLimitMgPerL rdf:type rdf:Property ;
    rdfs:label 'Nickel Limit Mg Per L' ;
    rdfs:comment 'Maximum permitted concentration of nickel in milligrams per liter. Heavy metal limit for metal finishing and plating industries.' ;
    rdfs:domain ind:IndustrialUserPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phMaximum rdf:type rdf:Property ;
    rdfs:label 'Ph Maximum' ;
    rdfs:comment 'Maximum permitted pH level for industrial discharge. Typically 9.0 to 12.5 per local limits.' ;
    rdfs:domain ind:IndustrialUserPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phMinimum rdf:type rdf:Property ;
    rdfs:label 'Ph Minimum' ;
    rdfs:comment 'Minimum permitted pH level for industrial discharge. Typically 5.0 to 6.0 per local limits.' ;
    rdfs:domain ind:IndustrialUserPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:silverLimitMgPerL rdf:type rdf:Property ;
    rdfs:label 'Silver Limit Mg Per L' ;
    rdfs:comment 'Maximum permitted concentration of silver in milligrams per liter. Heavy metal limit for photographic and metal finishing industries.' ;
    rdfs:domain ind:IndustrialUserPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNitrogenLimitMgPerL rdf:type rdf:Property ;
    rdfs:label 'Total Nitrogen Limit Mg Per L' ;
    rdfs:comment 'Maximum permitted concentration of total nitrogen in milligrams per liter that the industrial user may discharge.' ;
    rdfs:domain ind:IndustrialUserPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPhosphorusLimitMgPerL rdf:type rdf:Property ;
    rdfs:label 'Total Phosphorus Limit Mg Per L' ;
    rdfs:comment 'Maximum permitted concentration of total phosphorus in milligrams per liter that the industrial user may discharge.' ;
    rdfs:domain ind:IndustrialUserPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tssLimitMgPerL rdf:type rdf:Property ;
    rdfs:label 'Tss Limit Mg Per L' ;
    rdfs:comment 'Maximum permitted concentration of TSS in milligrams per liter that the industrial user may discharge to the wastewater collection system.' ;
    rdfs:domain ind:IndustrialUserPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zincLimitMgPerL rdf:type rdf:Property ;
    rdfs:label 'Zinc Limit Mg Per L' ;
    rdfs:comment 'Maximum permitted concentration of zinc in milligrams per liter. Heavy metal limit for metal finishing and plating industries.' ;
    rdfs:domain ind:IndustrialUserPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iupComplianceSampleId rdf:type rdf:Property ;
    rdfs:label 'Iup Compliance Sample Id' ;
    rdfs:comment 'Unique identifier for the compliance sampling event record. Primary key for the IUP compliance sample entity.' ;
    rdfs:domain ind:IupComplianceSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iupIndustrialUserPermitId rdf:type rdf:Property ;
    rdfs:label 'Iup Industrial User Permit Id' ;
    rdfs:comment 'Reference to the industrial user permit under which this compliance sample was collected. Links the sample to the specific permit being monitored.' ;
    rdfs:domain ind:IupComplianceSample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IndustrialUserPermit .

ind:primaryIupIndustrialUserPermitId rdf:type rdf:Property ;
    rdfs:label 'Primary Iup Industrial User Permit Id' ;
    rdfs:comment 'Reference to the industrial user permit under which this compliance sample was collected. Links the sample to the specific permit being monitored.' ;
    rdfs:domain ind:IupComplianceSample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IndustrialUserPermit .

ind:flowRateAtSampling rdf:type rdf:Property ;
    rdfs:label 'Flow Rate At Sampling' ;
    rdfs:comment 'The wastewater flow rate at the time of sample collection, expressed in gallons per minute (GPM) or million gallons per day (MGD). Used for load calculations.' ;
    rdfs:domain ind:IupComplianceSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flowRateUnit rdf:type rdf:Property ;
    rdfs:label 'Flow Rate Unit' ;
    rdfs:comment 'The unit of measure for the flow rate (gallons per minute, million gallons per day, liters per minute, cubic meters per day).' ;
    rdfs:domain ind:IupComplianceSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryReportNumber rdf:type rdf:Property ;
    rdfs:label 'Laboratory Report Number' ;
    rdfs:comment 'The unique report or case number assigned by the laboratory to the analytical results. Used for traceability and audit purposes.' ;
    rdfs:domain ind:IupComplianceSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitLimit rdf:type rdf:Property ;
    rdfs:label 'Permit Limit' ;
    rdfs:comment 'The maximum allowable concentration or discharge limit for this parameter as specified in the industrial user permit. Used to determine compliance status.' ;
    rdfs:domain ind:IupComplianceSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleDate rdf:type rdf:Property ;
    rdfs:label 'Sample Date' ;
    rdfs:comment 'The date on which the compliance sample was physically collected from the industrial user facility.' ;
    rdfs:domain ind:IupComplianceSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleLocation rdf:type rdf:Property ;
    rdfs:label 'Sample Location' ;
    rdfs:comment 'Description of the specific sampling point or location within the industrial facility where the sample was collected (e.g., final discharge point, process outfall).' ;
    rdfs:domain ind:IupComplianceSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleTemperature rdf:type rdf:Property ;
    rdfs:label 'Sample Temperature' ;
    rdfs:comment 'The temperature of the sample at the time of collection, typically in degrees Celsius. Important for certain parameter analyses and quality control.' ;
    rdfs:domain ind:IupComplianceSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleTime rdf:type rdf:Property ;
    rdfs:label 'Sample Time' ;
    rdfs:comment 'The precise timestamp when the compliance sample was collected, including time of day. Critical for composite sample timing and chain of custody.' ;
    rdfs:domain ind:IupComplianceSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sampleVolume rdf:type rdf:Property ;
    rdfs:label 'Sample Volume' ;
    rdfs:comment 'The volume of sample collected, typically expressed in milliliters or liters. Required for composite sample calculations and quality control.' ;
    rdfs:domain ind:IupComplianceSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleVolumeUnit rdf:type rdf:Property ;
    rdfs:label 'Sample Volume Unit' ;
    rdfs:comment 'The unit of measure for the sample volume (milliliters, liters, gallons).' ;
    rdfs:domain ind:IupComplianceSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationNoticeDate rdf:type rdf:Property ;
    rdfs:label 'Violation Notice Date' ;
    rdfs:comment 'The date on which the notice of violation was issued to the industrial user. Null if no violation notice was issued.' ;
    rdfs:domain ind:IupComplianceSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:violationNoticeIssued rdf:type rdf:Property ;
    rdfs:label 'Violation Notice Issued' ;
    rdfs:comment 'Indicates whether a notice of violation (NOV) was issued to the industrial user as a result of this sample exceedance. True if NOV issued, false otherwise.' ;
    rdfs:domain ind:IupComplianceSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liftStationId rdf:type rdf:Property ;
    rdfs:label 'Lift Station Id' ;
    rdfs:comment 'Unique identifier for the wastewater lift station (pump station). Primary key.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LiftStation .

ind:scadaPointId rdf:type rdf:Property ;
    rdfs:label 'Scada Point Id' ;
    rdfs:comment 'Unique SCADA system point identifier or tag name for the lift station. Used to link real-time telemetry data (flow, level, pump status, alarms) from OSIsoft PI Historian or similar SCADA platforms.' ;
    rdfs:domain ind:LiftStation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Point .

ind:annualOperatingCostUsd rdf:type rdf:Property ;
    rdfs:label 'Annual Operating Cost Usd' ;
    rdfs:comment 'Estimated annual operating cost of the lift station in USD, including energy, routine maintenance, and labor. Used for budgeting and lifecycle cost analysis.' ;
    rdfs:domain ind:LiftStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetConditionScore rdf:type rdf:Property ;
    rdfs:label 'Asset Condition Score' ;
    rdfs:comment 'Quantitative condition assessment score (typically 0-100 scale) based on physical inspection, performance metrics, and age. Higher scores indicate better condition. Used for capital planning and risk assessment.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backupPowerCapacityKw rdf:type rdf:Property ;
    rdfs:label 'Backup Power Capacity Kw' ;
    rdfs:comment 'Rated capacity of the backup power system in kilowatts (kW). Determines how long the lift station can operate during a utility power outage.' ;
    rdfs:domain ind:LiftStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backupPowerType rdf:type rdf:Property ;
    rdfs:label 'Backup Power Type' ;
    rdfs:comment 'Type of backup power system installed at the lift station: generator (diesel or natural gas), battery (UPS), dual feed (redundant utility feeds), or none. Critical for emergency preparedness and SSO prevention.' ;
    rdfs:domain ind:LiftStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designCapacityGpm rdf:type rdf:Property ;
    rdfs:label 'Design Capacity Gpm' ;
    rdfs:comment 'Maximum rated pumping capacity of the lift station in gallons per minute (GPM) under design conditions. Critical for hydraulic modeling and capacity planning.' ;
    rdfs:domain ind:LiftStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forceMainDiameterInches rdf:type rdf:Property ;
    rdfs:label 'Force Main Diameter Inches' ;
    rdfs:comment 'Diameter of the force main (pressurized discharge pipe) in inches that conveys wastewater from the lift station to the downstream collection system or treatment plant.' ;
    rdfs:domain ind:LiftStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forceMainLengthFeet rdf:type rdf:Property ;
    rdfs:label 'Force Main Length Feet' ;
    rdfs:comment 'Total length of the force main in feet from the lift station discharge to the downstream connection point. Used for hydraulic calculations and asset valuation.' ;
    rdfs:domain ind:LiftStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forceMainMaterial rdf:type rdf:Property ;
    rdfs:label 'Force Main Material' ;
    rdfs:comment 'Material composition of the force main pipe: ductile iron (DI), polyvinyl chloride (PVC), high-density polyethylene (HDPE), steel, or concrete. Impacts corrosion resistance, lifespan, and maintenance requirements.' ;
    rdfs:domain ind:LiftStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRehabilitationDate rdf:type rdf:Property ;
    rdfs:label 'Last Rehabilitation Date' ;
    rdfs:comment 'Date of the most recent major rehabilitation or upgrade of the lift station. Used to track asset condition and plan future capital improvements.' ;
    rdfs:domain ind:LiftStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextScheduledMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Maintenance Date' ;
    rdfs:comment 'Date of the next planned preventive maintenance activity for the lift station. Used for work order scheduling and resource planning.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pumpConfiguration rdf:type rdf:Property ;
    rdfs:label 'Pump Configuration' ;
    rdfs:comment 'Pump redundancy configuration: simplex (1 pump, no backup), duplex (2 pumps, 1 duty + 1 standby), triplex (3 pumps), quadruplex (4 pumps). Determines operational reliability and maintenance flexibility.' ;
    rdfs:domain ind:LiftStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pumpHorsepower rdf:type rdf:Property ;
    rdfs:label 'Pump Horsepower' ;
    rdfs:comment 'Total rated horsepower (HP) of the primary duty pump(s). Used for energy consumption analysis and operational cost estimation.' ;
    rdfs:domain ind:LiftStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replacementCostUsd rdf:type rdf:Property ;
    rdfs:label 'Replacement Cost Usd' ;
    rdfs:comment 'Estimated current replacement cost of the lift station in USD. Used for insurance valuation, capital improvement program (CIP) planning, and asset valuation under GASB 34.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceAreaName rdf:type rdf:Property ;
    rdfs:label 'Service Area Name' ;
    rdfs:comment 'Name or designation of the geographic service area or collection basin served by this lift station. Used for operational planning and customer communication.' ;
    rdfs:domain ind:LiftStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAreaPopulation rdf:type rdf:Property ;
    rdfs:label 'Service Area Population' ;
    rdfs:comment 'Estimated population served by the lift station within its collection basin. Used for capacity planning, regulatory reporting, and capital improvement prioritization.' ;
    rdfs:domain ind:LiftStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ssoRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Sso Risk Flag' ;
    rdfs:comment 'Indicates whether the lift station is identified as high-risk for sanitary sewer overflow (SSO) events due to capacity constraints, equipment age, or historical performance. True if high SSO risk, False otherwise.' ;
    rdfs:domain ind:LiftStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalDynamicHeadFeet rdf:type rdf:Property ;
    rdfs:label 'Total Dynamic Head Feet' ;
    rdfs:comment 'Total dynamic head (TDH) in feet that the pumps must overcome, including static lift, friction losses, and discharge pressure. Critical for pump selection and hydraulic modeling.' ;
    rdfs:domain ind:LiftStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wetWellVolumeGallons rdf:type rdf:Property ;
    rdfs:label 'Wet Well Volume Gallons' ;
    rdfs:comment 'Total storage volume of the wet well (sump) in gallons. Determines pump cycle frequency and emergency storage capacity during power outages or pump failures.' ;
    rdfs:domain ind:LiftStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverType rdf:type rdf:Property ;
    rdfs:label 'Cover Type' ;
    rdfs:comment 'Type of cover installed on the manhole. Watertight covers prevent Inflow and Infiltration (I&I); bolted covers provide security; vented covers allow gas release; traffic-rated covers support vehicular loads.' ;
    rdfs:domain ind:Manhole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inflowInfiltrationFlag rdf:type rdf:Property ;
    rdfs:label 'Inflow Infiltration Flag' ;
    rdfs:comment 'Indicates whether the manhole has been identified as a source of Inflow and Infiltration (I&I) into the wastewater collection system. True if I&I has been observed or suspected; false otherwise. Used for prioritizing I&I reduction programs.' ;
    rdfs:domain ind:Manhole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invertElevationFeet rdf:type rdf:Property ;
    rdfs:label 'Invert Elevation Feet' ;
    rdfs:comment 'Elevation of the lowest point inside the manhole where wastewater flows, measured in feet above a reference datum. Critical for calculating pipe slopes and flow gradients.' ;
    rdfs:domain ind:Manhole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:macpScore rdf:type rdf:Property ;
    rdfs:label 'Macp Score' ;
    rdfs:comment 'Numerical condition score assigned using the NASSCO Manhole Assessment and Certification Program (MACP) methodology. Higher scores indicate worse condition. Used for prioritizing rehabilitation and capital planning.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:manholeNumber rdf:type rdf:Property ;
    rdfs:label 'Manhole Number' ;
    rdfs:comment 'Business identifier or asset tag assigned to the manhole for field operations and maintenance tracking. Typically displayed on manhole covers or in field maps.' ;
    rdfs:domain ind:Manhole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manholeStatus rdf:type rdf:Property ;
    rdfs:label 'Manhole Status' ;
    rdfs:comment 'Current operational status of the manhole in the wastewater collection system lifecycle. Active manholes are in service; inactive are temporarily out of service; abandoned are no longer used but not removed; planned are in design phase; under construction are being installed; decommissioned are permanently removed from service.' ;
    rdfs:domain ind:Manhole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manholeType rdf:type rdf:Property ;
    rdfs:label 'Manhole Type' ;
    rdfs:comment 'Classification of the manhole based on its function in the wastewater collection network. Standard manholes provide access; drop manholes accommodate elevation changes; junction manholes connect multiple pipes; terminal manholes mark the end of a line; diversion manholes route flow; metering manholes house flow measurement equipment. [ENUM-REF-CANDIDATE: standard|drop|junction|terminal|diversion|metering|special — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manhole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownership rdf:type rdf:Property ;
    rdfs:label 'Ownership' ;
    rdfs:comment 'Entity that owns the manhole asset. Utility-owned assets are maintained by the water utility; municipal assets may be owned by the city; private assets are on private property; joint ownership involves shared responsibility.' ;
    rdfs:domain ind:Manhole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rimElevationFeet rdf:type rdf:Property ;
    rdfs:label 'Rim Elevation Feet' ;
    rdfs:comment 'Elevation of the manhole rim (top of cover) above a reference datum, typically mean sea level, measured in feet. Used for hydraulic modeling and flood risk assessment.' ;
    rdfs:domain ind:Manhole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ssoHistoryFlag rdf:type rdf:Property ;
    rdfs:label 'Sso History Flag' ;
    rdfs:comment 'Indicates whether the manhole has a history of Sanitary Sewer Overflows (SSO). True if SSO events have occurred at this location; false otherwise. Used for identifying high-risk locations and prioritizing capacity improvements.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trafficLoadRating rdf:type rdf:Property ;
    rdfs:label 'Traffic Load Rating' ;
    rdfs:comment 'Load rating classification of the manhole cover based on expected vehicular traffic. Light duty for pedestrian areas; medium duty for residential streets; heavy duty for arterial roads; extra heavy duty for highways and industrial areas.' ;
    rdfs:domain ind:Manhole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sewerInspectionId rdf:type rdf:Property ;
    rdfs:label 'Sewer Inspection Id' ;
    rdfs:comment 'Unique identifier for each sewer inspection event. Primary key for the sewer inspection data product.' ;
    rdfs:domain ind:SewerInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetIdentifier rdf:type rdf:Property ;
    rdfs:label 'Asset Identifier' ;
    rdfs:comment 'Business-facing identifier or tag of the specific asset inspected (pipe segment number, manhole number, etc.), used for field reference and reporting.' ;
    rdfs:domain ind:SewerInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalDefectFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Defect Flag' ;
    rdfs:comment 'Boolean indicator of whether any critical or high-severity defects were identified that require immediate attention or emergency repair.' ;
    rdfs:domain ind:SewerInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defectCodes rdf:type rdf:Property ;
    rdfs:label 'Defect Codes' ;
    rdfs:comment 'Comma-separated list of NASSCO defect codes identified during the inspection (e.g., CL for crack longitudinal, RB for roots, DP for deformed pipe), used for detailed condition analysis.' ;
    rdfs:domain ind:SewerInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downstreamManholeNumber rdf:type rdf:Property ;
    rdfs:label 'Downstream Manhole Number' ;
    rdfs:comment 'Identifier of the downstream manhole for pipe segment inspections, establishing the ending point of the inspection run.' ;
    rdfs:domain ind:SewerInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedRepairCostUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Repair Cost Usd' ;
    rdfs:comment 'Preliminary cost estimate in US dollars for the recommended repair or rehabilitation action, used for capital planning and budget forecasting.' ;
    rdfs:domain ind:SewerInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flowCondition rdf:type rdf:Property ;
    rdfs:label 'Flow Condition' ;
    rdfs:comment 'Flow level observed in the pipe during inspection, impacting visibility and the ability to assess certain defects.' ;
    rdfs:domain ind:SewerInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fogAccumulationFlag rdf:type rdf:Property ;
    rdfs:label 'Fog Accumulation Flag' ;
    rdfs:comment 'Boolean indicator of whether FOG buildup was observed, requiring cleaning and potentially indicating FOG program enforcement needs.' ;
    rdfs:domain ind:SewerInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:infiltrationObservedFlag rdf:type rdf:Property ;
    rdfs:label 'Infiltration Observed Flag' ;
    rdfs:comment 'Boolean indicator of whether infiltration or inflow was observed during the inspection, contributing to non-revenue water and treatment plant overload.' ;
    rdfs:domain ind:SewerInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionDirection rdf:type rdf:Property ;
    rdfs:label 'Inspection Direction' ;
    rdfs:comment 'Direction of travel during the inspection relative to flow direction, relevant for CCTV and sonar inspections of pipe segments.' ;
    rdfs:domain ind:SewerInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionLengthFeet rdf:type rdf:Property ;
    rdfs:label 'Inspection Length Feet' ;
    rdfs:comment 'Total length of pipe segment inspected, measured in feet, used to calculate condition per linear foot and prioritize rehabilitation.' ;
    rdfs:domain ind:SewerInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionMethod rdf:type rdf:Property ;
    rdfs:label 'Inspection Method' ;
    rdfs:comment 'The technology or technique used to perform the inspection. CCTV is the most common method for pipe condition assessment.' ;
    rdfs:domain ind:SewerInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Inspector Certification Number' ;
    rdfs:comment 'Professional certification number of the inspector, typically NASSCO PACP or MACP certification, ensuring qualified personnel perform assessments.' ;
    rdfs:domain ind:SewerInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalDefectFlag rdf:type rdf:Property ;
    rdfs:label 'Operational Defect Flag' ;
    rdfs:comment 'Boolean indicator of whether operational defects (roots, grease, debris, infiltration, exfiltration) were observed, impacting flow capacity.' ;
    rdfs:domain ind:SewerInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pacpScore rdf:type rdf:Property ;
    rdfs:label 'Pacp Score' ;
    rdfs:comment 'Numeric PACP score calculated from defect observations, representing the overall structural and operational condition of the pipe segment.' ;
    rdfs:domain ind:SewerInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rehabilitationMethod rdf:type rdf:Property ;
    rdfs:label 'Rehabilitation Method' ;
    rdfs:comment 'Specific rehabilitation technique recommended if repair or renewal is needed (e.g., CIPP lining, pipe bursting, open-cut replacement, spot repair, manhole lining).' ;
    rdfs:domain ind:SewerInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportFilePath rdf:type rdf:Property ;
    rdfs:label 'Report File Path' ;
    rdfs:comment 'File system path or URL to the formal inspection report document, typically in PDF format, for regulatory and asset management records.' ;
    rdfs:domain ind:SewerInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootIntrusionFlag rdf:type rdf:Property ;
    rdfs:label 'Root Intrusion Flag' ;
    rdfs:comment 'Boolean indicator of whether tree root intrusion was observed, a common cause of blockages and structural damage in gravity sewers.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:structuralDefectFlag rdf:type rdf:Property ;
    rdfs:label 'Structural Defect Flag' ;
    rdfs:comment 'Boolean indicator of whether structural defects (cracks, fractures, collapse, deformation) were observed, impacting asset integrity.' ;
    rdfs:domain ind:SewerInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:upstreamManholeNumber rdf:type rdf:Property ;
    rdfs:label 'Upstream Manhole Number' ;
    rdfs:comment 'Identifier of the upstream manhole for pipe segment inspections, establishing the starting point of the inspection run.' ;
    rdfs:domain ind:SewerInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:urgencyClassification rdf:type rdf:Property ;
    rdfs:label 'Urgency Classification' ;
    rdfs:comment 'Priority level assigned to the recommended action, used to sequence capital projects and maintenance work in the CIP and O&M budgets.' ;
    rdfs:domain ind:SewerInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoFilePath rdf:type rdf:Property ;
    rdfs:label 'Video File Path' ;
    rdfs:comment 'File system path or URL to the recorded CCTV or sonar video file, enabling review and validation of inspection findings.' ;
    rdfs:domain ind:SewerInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basinId rdf:type rdf:Property ;
    rdfs:label 'Basin Id' ;
    rdfs:comment 'Identifier of the drainage or sewershed basin that this segment serves. Critical for capacity planning, CSO (Combined Sewer Overflow) and SSO (Sanitary Sewer Overflow) management.' ;
    rdfs:domain ind:SewerNetwork ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SewershedBasin .

ind:primarySewerUpstreamManholeId rdf:type rdf:Property ;
    rdfs:label 'Primary Sewer Upstream Manhole Id' ;
    rdfs:comment 'Identifier of the manhole or node at the upstream end of the sewer segment. Establishes network topology for hydraulic modeling and GIS routing.' ;
    rdfs:domain ind:SewerNetwork ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Manhole .

ind:coordinateSystem rdf:type rdf:Property ;
    rdfs:label 'Coordinate System' ;
    rdfs:comment 'Spatial reference system identifier (e.g., EPSG code) for the GIS geometry. Ensures spatial data interoperability and accurate georeferencing.' ;
    rdfs:domain ind:SewerNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalityScore rdf:type rdf:Property ;
    rdfs:label 'Criticality Score' ;
    rdfs:comment 'Risk-based criticality rating (typically 1-100 scale) reflecting consequence of failure, service impact, and environmental risk. Drives capital investment prioritization.' ;
    rdfs:domain ind:SewerNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:downstreamInvertElevationFeet rdf:type rdf:Property ;
    rdfs:label 'Downstream Invert Elevation Feet' ;
    rdfs:comment 'Elevation of the inside bottom of the pipe at the downstream end in feet above mean sea level. Used with upstream invert to calculate slope and hydraulic capacity.' ;
    rdfs:domain ind:SewerNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:easementRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Easement Required Flag' ;
    rdfs:comment 'Indicates whether a legal easement is required for utility access to the sewer segment. Critical for maintenance planning and right-of-way management.' ;
    rdfs:domain ind:SewerNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fogRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Fog Risk Flag' ;
    rdfs:comment 'Indicates whether the segment is at elevated risk for FOG (Fats, Oils, and Grease) blockages based on upstream land use (restaurants, food processing). Drives preventive maintenance frequency.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hydrogenSulfideRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Hydrogen Sulfide Risk Flag' ;
    rdfs:comment 'Indicates elevated risk of hydrogen sulfide gas generation and corrosion. Common in force mains and long gravity sewers with low flow velocity.' ;
    rdfs:domain ind:SewerNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liningInstallationDate rdf:type rdf:Property ;
    rdfs:label 'Lining Installation Date' ;
    rdfs:comment 'Date when pipe lining or rehabilitation was completed. Resets the effective age for condition assessment and extends asset useful life.' ;
    rdfs:domain ind:SewerNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:peakFlowGpm rdf:type rdf:Property ;
    rdfs:label 'Peak Flow Gpm' ;
    rdfs:comment 'Maximum observed or modeled flow rate in Gallons per Minute (GPM) during peak wet weather or high demand periods. Critical for SSO risk assessment.' ;
    rdfs:domain ind:SewerNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:segmentIdentifier rdf:type rdf:Property ;
    rdfs:label 'Segment Identifier' ;
    rdfs:comment 'Externally-known unique identifier for the sewer segment used in GIS systems, field operations, and regulatory reporting. Aligns with Esri ArcGIS feature identifiers.' ;
    rdfs:domain ind:SewerNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slopePercent rdf:type rdf:Property ;
    rdfs:label 'Slope Percent' ;
    rdfs:comment 'Gradient of the sewer pipe expressed as a percentage. Critical for gravity sewer hydraulic performance and self-cleansing velocity calculations.' ;
    rdfs:domain ind:SewerNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ssoHistoryCount rdf:type rdf:Property ;
    rdfs:label 'Sso History Count' ;
    rdfs:comment 'Number of Sanitary Sewer Overflow (SSO) events recorded for this segment. High counts trigger regulatory scrutiny and prioritize capacity upgrades.' ;
    rdfs:domain ind:SewerNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trafficImpactLevel rdf:type rdf:Property ;
    rdfs:label 'Traffic Impact Level' ;
    rdfs:comment 'Assessment of traffic disruption risk if the segment requires excavation or repair. High-traffic segments require special permitting and coordination.' ;
    rdfs:domain ind:SewerNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upstreamInvertElevationFeet rdf:type rdf:Property ;
    rdfs:label 'Upstream Invert Elevation Feet' ;
    rdfs:comment 'Elevation of the inside bottom of the pipe at the upstream end in feet above mean sea level. Essential for hydraulic grade line analysis and I&I (Inflow and Infiltration) assessment.' ;
    rdfs:domain ind:SewerNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sewerNetworkSegmentId rdf:type rdf:Property ;
    rdfs:label 'Sewer Network Segment Id' ;
    rdfs:comment 'Reference to the public sewer main segment to which this service lateral connects. Establishes the topology link between customer service and the collection network.' ;
    rdfs:domain ind:SewerServiceConnection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:abandonmentDate rdf:type rdf:Property ;
    rdfs:label 'Abandonment Date' ;
    rdfs:comment 'Date when the service connection was permanently abandoned and removed from active service. Abandoned connections are typically capped or filled.' ;
    rdfs:domain ind:SewerServiceConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backwaterValveInstalledFlag rdf:type rdf:Property ;
    rdfs:label 'Backwater Valve Installed Flag' ;
    rdfs:comment 'Indicates whether a backwater valve (backflow preventer) is installed on the service lateral to prevent sewage backup into the premise during system surcharge events.' ;
    rdfs:domain ind:SewerServiceConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cleanoutAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Cleanout Available Flag' ;
    rdfs:comment 'Indicates whether a cleanout access point is available on the service lateral for maintenance and inspection purposes. Cleanouts facilitate camera inspection and clearing blockages.' ;
    rdfs:domain ind:SewerServiceConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Date when the service connection was deactivated or taken out of service, either temporarily or permanently.' ;
    rdfs:domain ind:SewerServiceConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grinderPumpInstallationDate rdf:type rdf:Property ;
    rdfs:label 'Grinder Pump Installation Date' ;
    rdfs:comment 'Date when the grinder pump was installed at this service connection. Used for warranty tracking and lifecycle management.' ;
    rdfs:domain ind:SewerServiceConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grinderPumpManufacturer rdf:type rdf:Property ;
    rdfs:label 'Grinder Pump Manufacturer' ;
    rdfs:comment 'Manufacturer name of the grinder pump installed at this service connection, if applicable.' ;
    rdfs:domain ind:SewerServiceConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grinderPumpModel rdf:type rdf:Property ;
    rdfs:label 'Grinder Pump Model' ;
    rdfs:comment 'Model number or designation of the grinder pump installed at this service connection, if applicable.' ;
    rdfs:domain ind:SewerServiceConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grinderPumpSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Grinder Pump Serial Number' ;
    rdfs:comment 'Manufacturer serial number of the grinder pump installed at this service connection, if applicable. Used for warranty tracking, maintenance scheduling, and parts ordering.' ;
    rdfs:domain ind:SewerServiceConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lateralDiameterInches rdf:type rdf:Property ;
    rdfs:label 'Lateral Diameter Inches' ;
    rdfs:comment 'Internal diameter of the service lateral pipe measured in inches. Typical residential laterals range from 4 to 6 inches; commercial and industrial connections may be larger.' ;
    rdfs:domain ind:SewerServiceConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lateralLengthFeet rdf:type rdf:Property ;
    rdfs:label 'Lateral Length Feet' ;
    rdfs:comment 'Total length of the service lateral pipe from the premise connection point to the public sewer main, measured in feet. Used for capacity analysis, maintenance planning, and replacement cost estimation.' ;
    rdfs:domain ind:SewerServiceConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lateralPipeMaterial rdf:type rdf:Property ;
    rdfs:label 'Lateral Pipe Material' ;
    rdfs:comment 'Material composition of the service lateral pipe. Common materials include PVC (polyvinyl chloride), vitrified clay, cast iron, ductile iron, concrete, Orangeburg (bituminized fiber), ABS (acrylonitrile butadiene styrene), and HDPE (high-density polyethylene). Material affects durability, corrosion resistance, and maintenance needs. [ENUM-REF-CANDIDATE: pvc|vitrified_clay|cast_iron|ductile_iron|concrete|orangeburg|abs|hdpe — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SewerServiceConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceConnectionNumber rdf:type rdf:Property ;
    rdfs:label 'Service Connection Number' ;
    rdfs:comment 'Business identifier for the sewer service connection, typically used in field operations, customer service, and billing. May follow utility-specific numbering conventions.' ;
    rdfs:domain ind:SewerServiceConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceStateProvince rdf:type rdf:Property ;
    rdfs:label 'Service State Province' ;
    rdfs:comment 'State or province code for the service address location.' ;
    rdfs:domain ind:SewerServiceConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceStatus rdf:type rdf:Property ;
    rdfs:label 'Service Status' ;
    rdfs:comment 'Current operational status of the sewer service connection. Active connections are in use; inactive connections are temporarily out of service; abandoned connections are permanently closed; capped connections are physically sealed; pending activation connections are installed but not yet in service.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ssoEventId rdf:type rdf:Property ;
    rdfs:label 'Sso Event Id' ;
    rdfs:comment 'Unique identifier for the sanitary sewer overflow event. Primary key.' ;
    rdfs:domain ind:SsoEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discoveredBy rdf:type rdf:Property ;
    rdfs:label 'Discovered By' ;
    rdfs:comment 'Source or party that discovered and reported the overflow event.' ;
    rdfs:domain ind:SsoEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Discovery Timestamp' ;
    rdfs:comment 'Date and time when the overflow event was first discovered or reported.' ;
    rdfs:domain ind:SsoEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dmrReported rdf:type rdf:Property ;
    rdfs:label 'Dmr Reported' ;
    rdfs:comment 'Boolean flag indicating whether the overflow event was included in the monthly Discharge Monitoring Report (DMR) submitted under the NPDES permit.' ;
    rdfs:domain ind:SsoEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedVolumeGallons rdf:type rdf:Property ;
    rdfs:label 'Estimated Volume Gallons' ;
    rdfs:comment 'Estimated volume of untreated or partially treated wastewater discharged during the SSO event, measured in gallons. Critical metric for regulatory reporting and environmental impact assessment.' ;
    rdfs:domain ind:SsoEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overflowLocationType rdf:type rdf:Property ;
    rdfs:label 'Overflow Location Type' ;
    rdfs:comment 'Type of infrastructure asset where the overflow occurred.' ;
    rdfs:domain ind:SsoEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveActionPlanned rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Planned' ;
    rdfs:comment 'Description of long-term preventive measures planned to prevent recurrence (e.g., pipe replacement, capacity upgrade, enhanced maintenance).' ;
    rdfs:domain ind:SsoEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachedSurfaceWater rdf:type rdf:Property ;
    rdfs:label 'Reached Surface Water' ;
    rdfs:comment 'Boolean flag indicating whether the overflow reached a surface water body, triggering enhanced regulatory reporting requirements.' ;
    rdfs:domain ind:SsoEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivingEnvironment rdf:type rdf:Property ;
    rdfs:label 'Receiving Environment' ;
    rdfs:comment 'Type of environment that received the discharged wastewater: surface water body, storm drainage system, land surface, building interior, or other.' ;
    rdfs:domain ind:SsoEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeRecoveredGallons rdf:type rdf:Property ;
    rdfs:label 'Volume Recovered Gallons' ;
    rdfs:comment 'Volume of spilled wastewater that was recovered and returned to the collection system or treatment plant, measured in gallons.' ;
    rdfs:domain ind:SsoEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weatherRelated rdf:type rdf:Property ;
    rdfs:label 'Weather Related' ;
    rdfs:comment 'Boolean flag indicating whether the overflow was caused or exacerbated by wet weather conditions, inflow, or infiltration (I&I).' ;
    rdfs:domain ind:SsoEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:biosolidsManagementMethod rdf:type rdf:Property ;
    rdfs:label 'Biosolids Management Method' ;
    rdfs:comment 'Primary method used for disposal or beneficial reuse of biosolids (treated sewage sludge) generated by the treatment process.' ;
    rdfs:domain ind:Wwtp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effluentDischargePoint rdf:type rdf:Property ;
    rdfs:label 'Effluent Discharge Point' ;
    rdfs:comment 'Geographic or infrastructure identifier for the outfall location where treated effluent is discharged from the facility.' ;
    rdfs:domain ind:Wwtp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energyConsumptionKwhPerMg rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Kwh Per Mg' ;
    rdfs:comment 'Average energy intensity of the treatment process measured in kilowatt-hours per million gallons treated. Key performance indicator for operational efficiency.' ;
    rdfs:domain ind:Wwtp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityCode rdf:type rdf:Property ;
    rdfs:label 'Facility Code' ;
    rdfs:comment 'Internal facility code or identifier used for operational reference and asset management integration.' ;
    rdfs:domain ind:Wwtp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityEmail rdf:type rdf:Property ;
    rdfs:label 'Facility Email' ;
    rdfs:comment 'Primary email address for facility operations and regulatory correspondence.' ;
    rdfs:domain ind:Wwtp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityPhone rdf:type rdf:Property ;
    rdfs:label 'Facility Phone' ;
    rdfs:comment 'Primary contact phone number for the wastewater treatment plant operations center.' ;
    rdfs:domain ind:Wwtp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorCertificationLevel rdf:type rdf:Property ;
    rdfs:label 'Operator Certification Level' ;
    rdfs:comment 'Minimum operator certification level or class required to operate this facility (e.g., Class I, Class II, Class III, Class IV).' ;
    rdfs:domain ind:Wwtp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Operator Certification Required' ;
    rdfs:comment 'Indicates whether state-certified operators are required to manage this facility per regulatory requirements.' ;
    rdfs:domain ind:Wwtp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:peakFlowMgd rdf:type rdf:Property ;
    rdfs:label 'Peak Flow Mgd' ;
    rdfs:comment 'Maximum instantaneous or daily flow capacity the facility can handle during wet weather or peak demand events.' ;
    rdfs:domain ind:Wwtp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permitEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Permit Effective Date' ;
    rdfs:comment 'Date on which the current NPDES permit became effective and enforceable.' ;
    rdfs:domain ind:Wastewater ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receivingWaterClassification rdf:type rdf:Property ;
    rdfs:label 'Receiving Water Classification' ;
    rdfs:comment 'Regulatory classification of the receiving water body (e.g., Class A, Class B, impaired, sensitive) that determines discharge limits.' ;
    rdfs:domain ind:Wwtp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentLevel rdf:type rdf:Property ;
    rdfs:label 'Treatment Level' ;
    rdfs:comment 'Highest level of treatment provided by the facility process train, indicating the degree of pollutant removal achieved.' ;
    rdfs:domain ind:Wwtp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentProcessDescription rdf:type rdf:Property ;
    rdfs:label 'Treatment Process Description' ;
    rdfs:comment 'Detailed description of the treatment process train including primary, secondary, and tertiary treatment technologies employed (e.g., activated sludge, trickling filter, membrane bioreactor, UV disinfection).' ;
    rdfs:domain ind:Wwtp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationId rdf:type rdf:Property ;
    rdfs:label 'Certification Id' ;
    rdfs:comment 'Unique identifier for the certification record. Primary key.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attachmentUrl rdf:type rdf:Property ;
    rdfs:label 'Attachment Url' ;
    rdfs:comment 'URL or file path to the scanned certificate document, training completion certificate, or other supporting documentation stored in the document management system.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationName rdf:type rdf:Property ;
    rdfs:label 'Certification Name' ;
    rdfs:comment 'Full name of the certification, credential, or qualification (e.g., OSHA 30-Hour Construction, Confined Space Entry, CDL Class A, Backflow Prevention Tester, HAZWOPER 40-Hour, First Aid/CPR, Forklift Operator, AWWA Water Distribution Operator Grade 3).' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceuEarned rdf:type rdf:Property ;
    rdfs:label 'Ceu Earned' ;
    rdfs:comment 'Number of Continuing Education Units (CEUs) or contact hours the employee has earned toward renewal of this certification. Null if not applicable.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ceuRequired rdf:type rdf:Property ;
    rdfs:label 'Ceu Required' ;
    rdfs:comment 'Number of Continuing Education Units (CEUs) or contact hours required for renewal of this certification. Null if no CEU requirement exists.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'Total cost incurred for obtaining or renewing this certification, including training fees, exam fees, and certification fees. Null if not tracked.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the cost amount. Defaults to USD for U.S. water utilities.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMandatory rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory' ;
    rdfs:comment 'Indicates whether this certification is mandatory for the employees current role or job function (True) or optional/recommended (False).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryRequired rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Required' ;
    rdfs:comment 'Indicates whether this certification is required by federal, state, or local regulation (True) or is a voluntary professional credential (False).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reimbursementStatus rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Status' ;
    rdfs:comment 'Status of employee reimbursement for certification costs: not_applicable (employer-paid), pending (reimbursement requested), approved (approved for payment), reimbursed (payment completed), denied (reimbursement denied).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Training Completion Date' ;
    rdfs:comment 'Date the employee completed the training course or program that led to this certification. May differ from issue_date if there is a delay in certification issuance.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingHours rdf:type rdf:Property ;
    rdfs:label 'Training Hours' ;
    rdfs:comment 'Total number of training hours completed for this certification (e.g., OSHA 10-Hour, OSHA 30-Hour, HAZWOPER 40-Hour). Null if not applicable.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingProvider rdf:type rdf:Property ;
    rdfs:label 'Training Provider' ;
    rdfs:comment 'Name of the organization or institution that provided the training leading to this certification (e.g., local community college, AWWA training center, in-house training department, third-party safety training vendor).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Crew Employee Id' ;
    rdfs:comment 'Identifier of the system user who created this crew record.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:crewLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Crew Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the system user who most recently modified this crew record.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:serviceAreaTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Service Area Territory Id' ;
    rdfs:comment 'Identifier of the geographic service area or DMA (District Metered Area) primarily served by this crew.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:averageResponseTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Average Response Time Minutes' ;
    rdfs:comment 'Average time in minutes from dispatch to on-site arrival for this crew, used for SLA (Service Level Agreement) tracking and crew performance evaluation.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confinedSpaceCertified rdf:type rdf:Property ;
    rdfs:label 'Confined Space Certified' ;
    rdfs:comment 'Indicates whether all crew members hold valid confined space entry certification required for work in manholes, vaults, and tanks.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crewCode rdf:type rdf:Property ;
    rdfs:label 'Crew Code' ;
    rdfs:comment 'Business identifier code for the crew used in field service dispatch and work order assignment. Typically alphanumeric format used in Microsoft Dynamics 365 Field Service.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewName rdf:type rdf:Property ;
    rdfs:label 'Crew Name' ;
    rdfs:comment 'Human-readable name of the crew for identification in dispatch and scheduling systems.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewStatus rdf:type rdf:Property ;
    rdfs:label 'Crew Status' ;
    rdfs:comment 'Current operational status of the crew: active (available for dispatch), inactive (temporarily unavailable), on_leave (scheduled time off), or disbanded (permanently decommissioned).' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewType rdf:type rdf:Property ;
    rdfs:label 'Crew Type' ;
    rdfs:comment 'Classification of crew by specialized function: leak repair, main break response, meter installation/replacement, CIPP (Cured-in-Place Pipe) lining, pump maintenance, or valve maintenance.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyResponseQualified rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Qualified' ;
    rdfs:comment 'Indicates whether crew is qualified and equipped for emergency response including main breaks, SSO (Sanitary Sewer Overflow), and water quality incidents.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentInventoryComplete rdf:type rdf:Property ;
    rdfs:label 'Equipment Inventory Complete' ;
    rdfs:comment 'Indicates whether the crew has a complete inventory of required tools, safety equipment, and materials as defined in crew type standards.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:excavationCertified rdf:type rdf:Property ;
    rdfs:label 'Excavation Certified' ;
    rdfs:comment 'Indicates whether crew members hold valid excavation and trenching safety certification for underground utility work.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gpsTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Gps Tracking Enabled' ;
    rdfs:comment 'Indicates whether real-time GPS tracking is enabled for this crew\'s vehicle for dispatch optimization and safety monitoring.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hourlyLaborRate rdf:type rdf:Property ;
    rdfs:label 'Hourly Labor Rate' ;
    rdfs:comment 'Standard hourly labor rate for this crew used in work order costing and budget planning. Represents blended rate for all crew members.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastSafetyTrainingDate rdf:type rdf:Property ;
    rdfs:label 'Last Safety Training Date' ;
    rdfs:comment 'Date of the most recent safety training completed by all crew members, used to ensure compliance with annual or periodic training requirements.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mobileDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Mobile Device Code' ;
    rdfs:comment 'Identifier of the mobile device (tablet, rugged handheld) assigned to crew for field data capture, work order updates, and GIS (Geographic Information System) access.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overtimeEligible rdf:type rdf:Property ;
    rdfs:label 'Overtime Eligible' ;
    rdfs:comment 'Indicates whether crew members are eligible for overtime compensation under labor agreements and regulations.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyIncidentCountYtd rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Count Ytd' ;
    rdfs:comment 'Count of OSHA recordable safety incidents involving this crew in the current calendar year, tracked for safety performance and compliance reporting.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shiftSchedule rdf:type rdf:Property ;
    rdfs:label 'Shift Schedule' ;
    rdfs:comment 'Standard shift assignment for the crew: day shift (typically 7am-3pm), night shift (typically 11pm-7am), rotating schedule, on-call availability, or dedicated emergency response.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:size rdf:type rdf:Property ;
    rdfs:label 'Size' ;
    rdfs:comment 'Number of employees assigned to this crew. Typical water utility field crews range from 2 to 6 members depending on crew type and task complexity.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unionAffiliation rdf:type rdf:Property ;
    rdfs:label 'Union Affiliation' ;
    rdfs:comment 'Labor union or collective bargaining unit affiliation for crew members, relevant for scheduling, overtime rules, and labor relations.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleCode rdf:type rdf:Property ;
    rdfs:label 'Vehicle Code' ;
    rdfs:comment 'Identifier of the primary vehicle or mobile equipment unit assigned to this crew for field operations.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workOrdersCompletedYtd rdf:type rdf:Property ;
    rdfs:label 'Work Orders Completed Ytd' ;
    rdfs:comment 'Count of work orders completed by this crew in the current calendar year, used for productivity tracking and resource planning.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cdlClass rdf:type rdf:Property ;
    rdfs:label 'Cdl Class' ;
    rdfs:comment 'CDL classification level. Class A for combination vehicles over 26,001 lbs, Class B for single vehicles over 26,001 lbs, Class C for vehicles designed to transport 16+ passengers or hazardous materials.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdlExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Cdl Expiration Date' ;
    rdfs:comment 'Expiration date of the CDL license. Used for compliance tracking to ensure field service technicians maintain valid licenses for vehicle operation.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cdlLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Cdl License Number' ;
    rdfs:comment 'Commercial Driver License number for employees authorized to operate utility vehicles requiring CDL certification. Nullable for employees without CDL requirements.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confinedSpaceCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Confined Space Certified Flag' ;
    rdfs:comment 'Indicates whether the employee is certified for confined space entry operations. Required for employees working in tanks, vaults, manholes, and other confined spaces per OSHA 1910.146.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:departmentName rdf:type rdf:Property ;
    rdfs:label 'Department Name' ;
    rdfs:comment 'Full name of the organizational department or division. Examples include Water Treatment Operations, Distribution Network Maintenance, Wastewater Treatment Operations, Water Quality Laboratory, Asset Management, Customer Service.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactName rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Name' ;
    rdfs:comment 'Full name of the employee\'s designated emergency contact person. Used for notification in case of workplace incidents or emergencies.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactRelationship rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Relationship' ;
    rdfs:comment 'Relationship of the emergency contact to the employee (e.g., spouse, parent, sibling, friend). Provides context for emergency notification protocols.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentStatus rdf:type rdf:Property ;
    rdfs:label 'Employment Status' ;
    rdfs:comment 'Current employment status of the employee. Active indicates currently working, inactive for temporary status, leave for approved absence, suspended for disciplinary hold, terminated for ended employment, retired for retirement status.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentType rdf:type rdf:Property ;
    rdfs:label 'Employment Type' ;
    rdfs:comment 'Classification of employment arrangement. Full-time for standard 40-hour week employees, part-time for reduced hours, contract for fixed-term contractors, temporary for short-term assignments, seasonal for peak-demand periods, intern for training programs.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Legal first name of the employee as recorded in official employment records.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified Flag' ;
    rdfs:comment 'Indicates whether the employee is certified to handle hazardous materials including treatment chemicals (chlorine, sodium hypochlorite, alum, polymers). Required for chemical handling and storage operations.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'Date the employee was originally hired by the utility. Used for seniority calculations, benefit eligibility, and tenure reporting.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:jobClassification rdf:type rdf:Property ;
    rdfs:label 'Job Classification' ;
    rdfs:comment 'Standardized job classification code used for pay grade determination, union contract alignment, and workforce planning. Aligns with utility industry job classification frameworks.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'Official job title or position name. Examples include Water Treatment Plant Operator, Distribution System Technician, Wastewater Engineer, Field Service Supervisor, SCADA Specialist, Laboratory Analyst.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Legal last name (surname) of the employee as recorded in official employment records.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:middleName rdf:type rdf:Property ;
    rdfs:label 'Middle Name' ;
    rdfs:comment 'Middle name or initial of the employee. Nullable field for employees without a middle name.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorLicenseClass rdf:type rdf:Property ;
    rdfs:label 'Operator License Class' ;
    rdfs:comment 'Classification level of the operator license (e.g., Class I, Class II, Class III, Class IV). Higher classes authorize operation of larger or more complex treatment facilities. Varies by state primacy agency.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorLicenseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Operator License Expiration Date' ;
    rdfs:comment 'Date the operator license expires. Critical for compliance tracking to ensure only licensed operators are assigned to treatment plant operations per SDWA and CWA requirements.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatorLicenseIssueDate rdf:type rdf:Property ;
    rdfs:label 'Operator License Issue Date' ;
    rdfs:comment 'Date the current operator license was issued by the state primacy agency. Used for tracking license validity and renewal scheduling.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatorLicenseType rdf:type rdf:Property ;
    rdfs:label 'Operator License Type' ;
    rdfs:comment 'Type of operator certification held. Water treatment for WTP operations, water distribution for distribution network operations, wastewater treatment for WWTP operations, wastewater collection for collection system operations.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaTrainingCurrentFlag rdf:type rdf:Property ;
    rdfs:label 'Osha Training Current Flag' ;
    rdfs:comment 'Indicates whether the employee has completed all required OSHA safety training and certifications are current. True for compliant employees, False for employees requiring training updates.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payGrade rdf:type rdf:Property ;
    rdfs:label 'Pay Grade' ;
    rdfs:comment 'Compensation pay grade or band assigned to the employee. Determines salary range and is aligned with job classification and union contract provisions.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personnelNumber rdf:type rdf:Property ;
    rdfs:label 'Personnel Number' ;
    rdfs:comment 'SAP HR system personnel number. Eight-digit unique identifier assigned by SAP ERP HR module for payroll and human capital management integration.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionLocal rdf:type rdf:Property ;
    rdfs:label 'Union Local' ;
    rdfs:comment 'Identifier for the specific union local chapter to which the employee belongs. Nullable for non-union employees. Used for collective bargaining agreement administration.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionMembershipFlag rdf:type rdf:Property ;
    rdfs:label 'Union Membership Flag' ;
    rdfs:comment 'Indicates whether the employee is a member of a labor union. True for union members, False for non-union employees. Used for contract compliance and labor relations management.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workLocationCode rdf:type rdf:Property ;
    rdfs:label 'Work Location Code' ;
    rdfs:comment 'Code identifying the primary physical work location or facility. Examples include WTP-01 (Water Treatment Plant 1), WWTP-02 (Wastewater Treatment Plant 2), DIST-NORTH (North Distribution Yard), LAB-CENTRAL (Central Laboratory).' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldServiceDispatchId rdf:type rdf:Property ;
    rdfs:label 'Field Service Dispatch Id' ;
    rdfs:comment 'Unique identifier for the field service dispatch record. Primary key.' ;
    rdfs:domain ind:FieldServiceDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pickupWarehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Pickup Warehouse Location Id' ;
    rdfs:comment 'Foreign key linking to supply.warehouse_location. Business justification: Dispatchers direct field crews to specific warehouse locations to pick up parts, meters, or specialized equipment before proceeding to service addresses. Critical for emergency repair dispatch workflo' ;
    rdfs:domain ind:FieldServiceDispatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:primaryFieldEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Field Employee Id' ;
    rdfs:comment 'Identifier for the individual technician assigned to this dispatch. Nullable if dispatch is assigned to a crew. Links to employee record.' ;
    rdfs:domain ind:FieldServiceDispatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualArrivalDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Datetime' ;
    rdfs:comment 'Actual date and time when the crew or technician arrived on-site. Captured via mobile device or field service app.' ;
    rdfs:domain ind:FieldServiceDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDepartureDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Datetime' ;
    rdfs:comment 'Actual date and time when the crew or technician departed from the service site after completing or suspending work.' ;
    rdfs:domain ind:FieldServiceDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDurationHours rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Hours' ;
    rdfs:comment 'Actual duration in hours spent on-site performing the field service work. Calculated from arrival and departure timestamps.' ;
    rdfs:domain ind:FieldServiceDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationDatetime rdf:type rdf:Property ;
    rdfs:label 'Cancellation Datetime' ;
    rdfs:comment 'Date and time when the dispatch was cancelled. Nullable if dispatch was not cancelled.' ;
    rdfs:domain ind:FieldServiceDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:completionDatetime rdf:type rdf:Property ;
    rdfs:label 'Completion Datetime' ;
    rdfs:comment 'Date and time when the dispatch was marked as completed in the field service system. Indicates successful closure of the dispatch.' ;
    rdfs:domain ind:FieldServiceDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispatchDatetime rdf:type rdf:Property ;
    rdfs:label 'Dispatch Datetime' ;
    rdfs:comment 'Date and time when the dispatch was created and assigned to a crew or technician. Primary business event timestamp.' ;
    rdfs:domain ind:FieldServiceDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispatchNumber rdf:type rdf:Property ;
    rdfs:label 'Dispatch Number' ;
    rdfs:comment 'Human-readable unique dispatch identifier generated by the field service management system. Format: DISP-YYYYMMDD-NNNN.' ;
    rdfs:domain ind:FieldServiceDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchStatus rdf:type rdf:Property ;
    rdfs:label 'Dispatch Status' ;
    rdfs:comment 'Current lifecycle status of the dispatch. Tracks progression from initial dispatch through completion or cancellation.' ;
    rdfs:domain ind:FieldServiceDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchType rdf:type rdf:Property ;
    rdfs:label 'Dispatch Type' ;
    rdfs:comment 'Classification of the field service activity being dispatched. Aligns with work order type and determines required skills and equipment. [ENUM-REF-CANDIDATE: leak_repair|meter_install|meter_replacement|service_call|main_break|valve_maintenance|hydrant_repair — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FieldServiceDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatcherNotes rdf:type rdf:Property ;
    rdfs:label 'Dispatcher Notes' ;
    rdfs:comment 'Free-text notes entered by the dispatcher providing additional context, special instructions, safety warnings, or customer information for the field crew.' ;
    rdfs:domain ind:FieldServiceDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmaZoneCode rdf:type rdf:Property ;
    rdfs:label 'Dma Zone Code' ;
    rdfs:comment 'District Metered Area zone identifier for the dispatch location. Used for hydraulic isolation and non-revenue water tracking.' ;
    rdfs:domain ind:FieldServiceDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentRequired rdf:type rdf:Property ;
    rdfs:label 'Equipment Required' ;
    rdfs:comment 'Comma-separated list or description of specialized equipment required for this dispatch (e.g., backhoe, leak detection equipment, meter testing kit).' ;
    rdfs:domain ind:FieldServiceDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedTravelTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Travel Time Minutes' ;
    rdfs:comment 'Estimated travel time in minutes from the crew or technician\'s current location to the service site. Calculated by routing engine.' ;
    rdfs:domain ind:FieldServiceDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledArrivalEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival End Datetime' ;
    rdfs:comment 'End of the scheduled arrival window. Defines the latest expected arrival time within the service level agreement.' ;
    rdfs:domain ind:FieldServiceDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledArrivalStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival Start Datetime' ;
    rdfs:comment 'Start of the scheduled arrival window communicated to the customer or stakeholder. Defines the earliest expected arrival time.' ;
    rdfs:domain ind:FieldServiceDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaActualResponseMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Actual Response Minutes' ;
    rdfs:comment 'Actual response time in minutes from dispatch creation to on-site arrival. Used for SLA compliance tracking.' ;
    rdfs:domain ind:FieldServiceDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Flag' ;
    rdfs:comment 'Boolean indicator of whether the dispatch met the SLA target response time. True if compliant, False if SLA was breached.' ;
    rdfs:domain ind:FieldServiceDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetResponseMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Response Minutes' ;
    rdfs:comment 'Target response time in minutes as defined by the service level agreement for this dispatch priority level.' ;
    rdfs:domain ind:FieldServiceDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:technicianNotes rdf:type rdf:Property ;
    rdfs:label 'Technician Notes' ;
    rdfs:comment 'Free-text notes entered by the technician or crew documenting field observations, work performed, issues encountered, or follow-up actions required.' ;
    rdfs:domain ind:FieldServiceDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborTimesheetId rdf:type rdf:Property ;
    rdfs:label 'Labor Timesheet Id' ;
    rdfs:comment 'Unique identifier for the labor timesheet record.' ;
    rdfs:domain ind:LaborTimesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryLaborEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Labor Employee Id' ;
    rdfs:comment 'Identifier of the employee who performed the work. Links to SAP HR employee master data.' ;
    rdfs:domain ind:LaborTimesheet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:callOutHours rdf:type rdf:Property ;
    rdfs:label 'Call Out Hours' ;
    rdfs:comment 'Number of hours worked during emergency call-out outside regular shift. Typically compensated at premium rate with minimum guarantee.' ;
    rdfs:domain ind:LaborTimesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crewAssignment rdf:type rdf:Property ;
    rdfs:label 'Crew Assignment' ;
    rdfs:comment 'Identifier of the crew or work team to which the employee was assigned for this work period. Used for crew productivity analysis.' ;
    rdfs:domain ind:LaborTimesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hoursWorked rdf:type rdf:Property ;
    rdfs:label 'Hours Worked' ;
    rdfs:comment 'Total number of hours worked by the employee on the specified date and activity. Includes regular and overtime hours.' ;
    rdfs:domain ind:LaborTimesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborCost rdf:type rdf:Property ;
    rdfs:label 'Labor Cost' ;
    rdfs:comment 'Total labor cost for this timesheet entry (hours_worked × labor_rate). Used for O&M expense tracking and CAPEX project cost accumulation. Confidential business data.' ;
    rdfs:domain ind:LaborTimesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborRate rdf:type rdf:Property ;
    rdfs:label 'Labor Rate' ;
    rdfs:comment 'Hourly labor rate applied for cost calculation. May include base wage plus burden (benefits, taxes, overhead). Confidential business data.' ;
    rdfs:domain ind:LaborTimesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeHours rdf:type rdf:Property ;
    rdfs:label 'Overtime Hours' ;
    rdfs:comment 'Number of overtime hours worked at premium pay rate. Typically hours exceeding 40 per week or 8 per day per FLSA and union agreements.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payCode rdf:type rdf:Property ;
    rdfs:label 'Pay Code' ;
    rdfs:comment 'Payroll system code that determines compensation rate and benefits treatment. Maps to SAP HR wage type or payroll category.' ;
    rdfs:domain ind:LaborTimesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollPeriod rdf:type rdf:Property ;
    rdfs:label 'Payroll Period' ;
    rdfs:comment 'Identifier of the payroll period to which this timesheet entry belongs. Format typically YYYY-PP where PP is period number.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regularHours rdf:type rdf:Property ;
    rdfs:label 'Regular Hours' ;
    rdfs:comment 'Number of regular hours worked at standard pay rate. Typically up to 8 hours per day or 40 hours per week per FLSA.' ;
    rdfs:domain ind:LaborTimesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftType rdf:type rdf:Property ;
    rdfs:label 'Shift Type' ;
    rdfs:comment 'Classification of the work shift. Determines pay rate multiplier and labor cost allocation rules.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standbyHours rdf:type rdf:Property ;
    rdfs:label 'Standby Hours' ;
    rdfs:comment 'Number of hours employee was on standby or on-call status. May be compensated at a different rate than regular hours.' ;
    rdfs:domain ind:LaborTimesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taskDescription rdf:type rdf:Property ;
    rdfs:label 'Task Description' ;
    rdfs:comment 'Free-text description of the work task or activity performed. Provides operational detail for labor tracking and audit purposes.' ;
    rdfs:domain ind:LaborTimesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timesheetDate rdf:type rdf:Property ;
    rdfs:label 'Timesheet Date' ;
    rdfs:comment 'The calendar date on which the labor hours were worked. Used for payroll period assignment and labor cost allocation.' ;
    rdfs:domain ind:LaborTimesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaveRequestId rdf:type rdf:Property ;
    rdfs:label 'Leave Request Id' ;
    rdfs:comment 'Unique identifier for the leave request record. Primary key.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryLeaveEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Leave Employee Id' ;
    rdfs:comment 'Identifier of the employee submitting the leave request. Links to employee master data in SAP HR.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryLeaveBackupEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Leave Backup Employee Id' ;
    rdfs:comment 'Identifier of the employee assigned to cover the absent employee\'s duties during the leave period. Links to employee master data.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:workLocationId rdf:type rdf:Property ;
    rdfs:label 'Work Location Id' ;
    rdfs:comment 'Identifier of the employee\'s primary work location (e.g., WTP (Water Treatment Plant), WWTP (Wastewater Treatment Plant), field service area) affected by the leave. Used for shift coverage planning.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:accrualBalanceAfter rdf:type rdf:Property ;
    rdfs:label 'Accrual Balance After' ;
    rdfs:comment 'Employee\'s leave accrual balance (in hours) after this leave request is applied. Used to prevent negative balances and enforce policy limits.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accrualBalanceBefore rdf:type rdf:Property ;
    rdfs:label 'Accrual Balance Before' ;
    rdfs:comment 'Employee\'s leave accrual balance (in hours) before this leave request is applied. Snapshot for audit and verification purposes.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedEndDate rdf:type rdf:Property ;
    rdfs:label 'Approved End Date' ;
    rdfs:comment 'The actual last date of absence approved by the supervisor. May differ from requested end date based on operational needs.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedStartDate rdf:type rdf:Property ;
    rdfs:label 'Approved Start Date' ;
    rdfs:comment 'The actual first date of absence approved by the supervisor. May differ from requested start date based on operational needs.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationReceived rdf:type rdf:Property ;
    rdfs:label 'Certification Received' ;
    rdfs:comment 'Flag indicating whether the required certification documentation has been received and verified by HR.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Certification Received Date' ;
    rdfs:comment 'Date when the supporting certification documentation was received by HR. Used to track compliance with submission deadlines.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationRequired rdf:type rdf:Property ;
    rdfs:label 'Certification Required' ;
    rdfs:comment 'Indicates whether medical or other official certification is required to support the leave request (e.g., doctor\'s note for sick leave, FMLA certification form).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coveragePlan rdf:type rdf:Property ;
    rdfs:label 'Coverage Plan' ;
    rdfs:comment 'Description of how the employee\'s absence will be covered, including backfill assignments, overtime scheduling, or workload redistribution. Feeds shift scheduling system.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denialReason rdf:type rdf:Property ;
    rdfs:label 'Denial Reason' ;
    rdfs:comment 'Explanation provided by the supervisor for denying the leave request. Required for transparency and potential grievance resolution.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmlaCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Fmla Case Number' ;
    rdfs:comment 'Unique case identifier for FMLA-protected leave, used to track the 12-week entitlement period and ensure compliance with federal regulations.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hoursApproved rdf:type rdf:Property ;
    rdfs:label 'Hours Approved' ;
    rdfs:comment 'Total number of work hours approved by the supervisor for the leave period. Used for payroll deduction and accrual balance updates.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hoursRequested rdf:type rdf:Property ;
    rdfs:label 'Hours Requested' ;
    rdfs:comment 'Total number of work hours the employee is requesting as leave. Calculated based on the employee\'s standard work schedule and requested date range.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isEmergencyLeave rdf:type rdf:Property ;
    rdfs:label 'Is Emergency Leave' ;
    rdfs:comment 'Flag indicating whether this is an emergency or unplanned leave request (e.g., sudden illness, family emergency) that may bypass standard advance notice requirements.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFmlaEligible rdf:type rdf:Property ;
    rdfs:label 'Is Fmla Eligible' ;
    rdfs:comment 'Flag indicating whether this leave request qualifies for FMLA protection based on employee tenure, hours worked, and reason for leave. Critical for compliance reporting.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPaid rdf:type rdf:Property ;
    rdfs:label 'Is Paid' ;
    rdfs:comment 'Indicates whether the approved leave is paid (true) or unpaid (false). Determines payroll processing treatment.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaveSubtype rdf:type rdf:Property ;
    rdfs:label 'Leave Subtype' ;
    rdfs:comment 'Detailed classification within the leave type, such as continuous FMLA, intermittent FMLA, short-term disability, or personal leave. Provides granular categorization for reporting and compliance.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveType rdf:type rdf:Property ;
    rdfs:label 'Leave Type' ;
    rdfs:comment 'Category of leave being requested: vacation (paid time off), sick (illness or medical appointments), FMLA (Family and Medical Leave Act protected leave), military (active duty or reserve service), bereavement (death of family member), or jury duty (civic obligation).' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Business-facing unique identifier for the leave request, formatted as LR-YYYYNNNN for tracking and reference.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current lifecycle state of the leave request: draft (being prepared), submitted (awaiting review), pending_approval (under supervisor review), approved (authorized for absence), denied (rejected by supervisor), cancelled (system-cancelled due to business rule), or withdrawn (employee retracted request). [ENUM-REF-CANDIDATE: draft|submitted|pending_approval|approved|denied|cancelled|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestSubmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Submission Timestamp' ;
    rdfs:comment 'Date and time when the employee submitted the leave request. Used to track advance notice compliance and approval SLA (Service Level Agreement).' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestedEndDate rdf:type rdf:Property ;
    rdfs:label 'Requested End Date' ;
    rdfs:comment 'The last date of absence requested by the employee. Defines the duration of the leave period.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedStartDate rdf:type rdf:Property ;
    rdfs:label 'Requested Start Date' ;
    rdfs:comment 'The first date of absence requested by the employee. Used for shift coverage planning and payroll processing.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shiftCoverageImpact rdf:type rdf:Property ;
    rdfs:label 'Shift Coverage Impact' ;
    rdfs:comment 'Assessment of the operational impact of the leave on shift coverage and crew availability. Used by supervisors to evaluate approval feasibility and plan backfill resources.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorLicenseId rdf:type rdf:Property ;
    rdfs:label 'Operator License Id' ;
    rdfs:comment 'Unique identifier for the operator license record. Primary key.' ;
    rdfs:domain ind:OperatorLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAssignmentFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Assignment Facility Id' ;
    rdfs:comment 'Reference to the primary Water Treatment Plant (WTP) or Wastewater Treatment Plant (WWTP) where this operator is currently assigned. Links to the facility master record.' ;
    rdfs:domain ind:OperatorLicense ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:backupOperatorFlag rdf:type rdf:Property ;
    rdfs:label 'Backup Operator Flag' ;
    rdfs:comment 'Indicates whether this operator is designated as a backup or relief operator for their assigned facility. Backup operators provide coverage during absences of the primary ORC.' ;
    rdfs:domain ind:OperatorLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:continuingEducationHoursCompleted rdf:type rdf:Property ;
    rdfs:label 'Continuing Education Hours Completed' ;
    rdfs:comment 'Total number of continuing education hours the operator has completed toward the current renewal cycle. Tracked to ensure compliance with renewal requirements.' ;
    rdfs:domain ind:OperatorLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:continuingEducationHoursRequired rdf:type rdf:Property ;
    rdfs:label 'Continuing Education Hours Required' ;
    rdfs:comment 'Total number of continuing education hours required for license renewal as mandated by the issuing agency. Typically ranges from 12 to 48 hours per renewal cycle.' ;
    rdfs:domain ind:OperatorLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:examDate rdf:type rdf:Property ;
    rdfs:label 'Exam Date' ;
    rdfs:comment 'The date the operator successfully passed the certification exam for this license grade. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:OperatorLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:examScore rdf:type rdf:Property ;
    rdfs:label 'Exam Score' ;
    rdfs:comment 'The score achieved by the operator on the certification exam, typically expressed as a percentage (0-100). Null if score is not recorded.' ;
    rdfs:domain ind:OperatorLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityClassificationAuthorized rdf:type rdf:Property ;
    rdfs:label 'Facility Classification Authorized' ;
    rdfs:comment 'The maximum facility classification or complexity level the operator is authorized to manage based on their license grade (e.g., Class 1 WTP, Class 4 WWTP). Aligns with state facility classification systems.' ;
    rdfs:domain ind:OperatorLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingState rdf:type rdf:Property ;
    rdfs:label 'Issuing State' ;
    rdfs:comment 'Two-letter state code of the primacy agency that issued the license (e.g., CA, TX, NY). Follows USPS state abbreviation standard.' ;
    rdfs:domain ind:OperatorLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'License Document Url' ;
    rdfs:comment 'URL or file path to the scanned copy of the physical operator license certificate stored in the document management system. Used for audit and verification purposes.' ;
    rdfs:domain ind:OperatorLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseGrade rdf:type rdf:Property ;
    rdfs:label 'License Grade' ;
    rdfs:comment 'The grade or class of the operator license (e.g., Grade 1, Grade 2, Grade 3, Grade 4 for water; Class A, Class B, Class C, Class D for wastewater). Grade indicates the complexity and size of facilities the operator is qualified to manage. [ENUM-REF-CANDIDATE: grade_1|grade_2|grade_3|grade_4|class_a|class_b|class_c|class_d|trainee|provisional — promote to reference product]' ;
    rdfs:domain ind:OperatorLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'The unique license number issued by the state primacy agency. This is the official identifier on the physical license certificate.' ;
    rdfs:domain ind:OperatorLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseStatus rdf:type rdf:Property ;
    rdfs:label 'License Status' ;
    rdfs:comment 'Current status of the operator license in its lifecycle. Active licenses are valid for operations; expired, suspended, or revoked licenses require immediate action to maintain regulatory compliance.' ;
    rdfs:domain ind:OperatorLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseType rdf:type rdf:Property ;
    rdfs:label 'License Type' ;
    rdfs:comment 'The category of operator license indicating the operational domain (e.g., Water Treatment, Water Distribution, Wastewater Treatment, Wastewater Collection, Dual Certification, Backflow Prevention).' ;
    rdfs:domain ind:OperatorLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseVerificationDate rdf:type rdf:Property ;
    rdfs:label 'License Verification Date' ;
    rdfs:comment 'The date the license was last verified with the issuing state agency. Regular verification is required for audit and compliance purposes. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:OperatorLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'License Verification Method' ;
    rdfs:comment 'The method used to verify the license status with the issuing agency (e.g., online portal, phone verification, email confirmation, physical document review, third-party verification service).' ;
    rdfs:domain ind:OperatorLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorInResponsibleChargeFlag rdf:type rdf:Property ;
    rdfs:label 'Operator In Responsible Charge Flag' ;
    rdfs:comment 'Indicates whether this operator is designated as the Operator in Responsible Charge (ORC) for their assigned facility. ORC designation is a regulatory requirement under SDWA and state primacy rules.' ;
    rdfs:domain ind:OperatorLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reciprocityState rdf:type rdf:Property ;
    rdfs:label 'Reciprocity State' ;
    rdfs:comment 'Two-letter state code indicating if this license is recognized in another state through reciprocity agreements. Null if no reciprocity applies.' ;
    rdfs:domain ind:OperatorLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalApplicationSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Application Submitted Date' ;
    rdfs:comment 'The date the operator submitted their license renewal application to the issuing agency. Null if renewal has not been initiated. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:OperatorLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Renewal Fee Amount' ;
    rdfs:comment 'The fee amount charged by the issuing agency for license renewal. Expressed in USD. Null if no fee applies or if not yet determined.' ;
    rdfs:domain ind:OperatorLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalFeePaidDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Fee Paid Date' ;
    rdfs:comment 'The date the renewal fee was paid to the issuing agency. Null if fee has not been paid. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:OperatorLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalNotificationSentDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Notification Sent Date' ;
    rdfs:comment 'The date a renewal reminder notification was sent to the operator and their supervisor. Typically sent 60-90 days before expiration. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:OperatorLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionEndDate rdf:type rdf:Property ;
    rdfs:label 'Suspension End Date' ;
    rdfs:comment 'The date the license suspension was lifted and the license was reinstated. Null if suspension is ongoing or if license has never been suspended. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:OperatorLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionStartDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Start Date' ;
    rdfs:comment 'The date the license suspension became effective. Null if license has never been suspended. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:OperatorLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:managerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Manager Employee Id' ;
    rdfs:comment 'Reference to the employee who manages this organizational unit. Used for reporting hierarchy and approval workflows.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:parentOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Parent Org Unit Id' ;
    rdfs:comment 'Reference to the parent organizational unit in the hierarchy. Enables multi-level organizational structure modeling.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:budgetAmountAnnual rdf:type rdf:Property ;
    rdfs:label 'Budget Amount Annual' ;
    rdfs:comment 'Total annual operating budget allocated to this organizational unit in US dollars.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetFiscalYear rdf:type rdf:Property ;
    rdfs:label 'Budget Fiscal Year' ;
    rdfs:comment 'Fiscal year for which the annual budget amount applies.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headcountActual rdf:type rdf:Property ;
    rdfs:label 'Headcount Actual' ;
    rdfs:comment 'Current number of filled full-time equivalent (FTE) positions in this organizational unit.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headcountAuthorized rdf:type rdf:Property ;
    rdfs:label 'Headcount Authorized' ;
    rdfs:comment 'Number of authorized full-time equivalent (FTE) positions allocated to this organizational unit.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operates247 rdf:type rdf:Property ;
    rdfs:label 'Operates 24 7' ;
    rdfs:comment 'Indicates whether this organizational unit operates on a 24-hour, 7-day-per-week schedule (typical for Water Treatment Plant (WTP) and Wastewater Treatment Plant (WWTP) operations).' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orgUnitDescription rdf:type rdf:Property ;
    rdfs:label 'Org Unit Description' ;
    rdfs:comment 'Detailed description of the organizational unit\'s mission, responsibilities, and scope of operations.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryOversightAgency rdf:type rdf:Property ;
    rdfs:label 'Regulatory Oversight Agency' ;
    rdfs:comment 'Primary regulatory agency with oversight authority over this organizational unit (e.g., U.S. Environmental Protection Agency (EPA), state primacy agency, Public Utilities Commission (PUC)).' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetySensitiveFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Sensitive Flag' ;
    rdfs:comment 'Indicates whether this organizational unit performs safety-sensitive functions requiring enhanced Occupational Safety and Health Administration (OSHA) compliance and monitoring.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shiftScheduleType rdf:type rdf:Property ;
    rdfs:label 'Shift Schedule Type' ;
    rdfs:comment 'Type of shift schedule used by this organizational unit (standard business hours, rotating shifts, fixed shifts, on-call, flexible).' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionRepresentation rdf:type rdf:Property ;
    rdfs:label 'Union Representation' ;
    rdfs:comment 'Indicates whether employees in this organizational unit are represented by a labor union.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitCode rdf:type rdf:Property ;
    rdfs:label 'Unit Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the organizational unit. Used for reporting and system integration.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitName rdf:type rdf:Property ;
    rdfs:label 'Unit Name' ;
    rdfs:comment 'Full business name of the organizational unit (e.g., Water Operations Division, Wastewater Treatment Department).' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitShortName rdf:type rdf:Property ;
    rdfs:label 'Unit Short Name' ;
    rdfs:comment 'Abbreviated name of the organizational unit for display in constrained UI contexts and reports.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitStatus rdf:type rdf:Property ;
    rdfs:label 'Unit Status' ;
    rdfs:comment 'Current lifecycle status of the organizational unit. Active units are operational; planned units are future; dissolved units are historical.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitType rdf:type rdf:Property ;
    rdfs:label 'Unit Type' ;
    rdfs:comment 'Classification of the organizational unit within the hierarchy (division, department, work group, section, team, cost center).' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceReviewId rdf:type rdf:Property ;
    rdfs:label 'Performance Review Id' ;
    rdfs:comment 'Unique identifier for the performance review record. Primary key.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPerformanceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Performance Employee Id' ;
    rdfs:comment 'Identifier of the employee being reviewed. Links to the employee master record in SAP HR.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:areasForImprovement rdf:type rdf:Property ;
    rdfs:label 'Areas For Improvement' ;
    rdfs:comment 'Narrative description of areas where the employee needs development, improvement, or additional training.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerServiceRating rdf:type rdf:Property ;
    rdfs:label 'Customer Service Rating' ;
    rdfs:comment 'Performance rating for customer interaction quality, responsiveness, and service delivery to utility customers and stakeholders.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerServiceScore rdf:type rdf:Property ;
    rdfs:label 'Customer Service Score' ;
    rdfs:comment 'Numeric score for customer service competency assessment.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:developmentPlanNotes rdf:type rdf:Property ;
    rdfs:label 'Development Plan Notes' ;
    rdfs:comment 'Detailed notes on the employee development plan, including training recommendations, skill-building activities, and career progression guidance.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeAcknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgment Date' ;
    rdfs:comment 'The date on which the employee acknowledged the performance review.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employeeAcknowledgmentStatus rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgment Status' ;
    rdfs:comment 'Status indicating whether the employee has acknowledged receipt and review of the performance evaluation.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeComments rdf:type rdf:Property ;
    rdfs:label 'Employee Comments' ;
    rdfs:comment 'Comments or feedback provided by the employee in response to the performance review.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalAchievementRating rdf:type rdf:Property ;
    rdfs:label 'Goal Achievement Rating' ;
    rdfs:comment 'Performance rating for achievement of individual goals and Key Performance Indicators (KPIs) set for the review period.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalAchievementScore rdf:type rdf:Property ;
    rdfs:label 'Goal Achievement Score' ;
    rdfs:comment 'Numeric score representing the percentage or level of goal achievement during the review period.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meritIncreasePercentage rdf:type rdf:Property ;
    rdfs:label 'Merit Increase Percentage' ;
    rdfs:comment 'The recommended percentage increase in salary based on performance, if applicable.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meritIncreaseRecommendedFlag rdf:type rdf:Property ;
    rdfs:label 'Merit Increase Recommended Flag' ;
    rdfs:comment 'Indicates whether a merit-based salary increase is recommended based on the performance review outcome.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Due Date' ;
    rdfs:comment 'The scheduled date for the next performance review cycle.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overallRating rdf:type rdf:Property ;
    rdfs:label 'Overall Rating' ;
    rdfs:comment 'The overall performance rating assigned to the employee for the review period.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallRatingScore rdf:type rdf:Property ;
    rdfs:label 'Overall Rating Score' ;
    rdfs:comment 'Numeric score representing the overall performance rating, typically on a scale (e.g., 1.0 to 5.0).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionRecommendedFlag rdf:type rdf:Property ;
    rdfs:label 'Promotion Recommended Flag' ;
    rdfs:comment 'Indicates whether the employee is recommended for promotion based on performance and readiness for increased responsibility.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryKnowledgeRating rdf:type rdf:Property ;
    rdfs:label 'Regulatory Knowledge Rating' ;
    rdfs:comment 'Performance rating for understanding and application of Safe Drinking Water Act (SDWA), Clean Water Act (CWA), and Environmental Protection Agency (EPA) regulations.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryKnowledgeScore rdf:type rdf:Property ;
    rdfs:label 'Regulatory Knowledge Score' ;
    rdfs:comment 'Numeric score for regulatory knowledge competency assessment.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Review Document Url' ;
    rdfs:comment 'URL or file path to the stored performance review document or attachment in the document management system.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Review Period End Date' ;
    rdfs:comment 'The end date of the performance evaluation period being assessed.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Period Start Date' ;
    rdfs:comment 'The start date of the performance evaluation period being assessed.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Current workflow status of the performance review (draft, in progress, pending employee acknowledgment, completed, or cancelled).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewType rdf:type rdf:Property ;
    rdfs:label 'Review Type' ;
    rdfs:comment 'The type or category of performance review being conducted (annual, mid-year, probationary, project-based, or ad-hoc).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerComments rdf:type rdf:Property ;
    rdfs:label 'Reviewer Comments' ;
    rdfs:comment 'Additional comments or observations provided by the reviewer or supervisor regarding the employee\'s performance.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyComplianceRating rdf:type rdf:Property ;
    rdfs:label 'Safety Compliance Rating' ;
    rdfs:comment 'Performance rating for adherence to Occupational Safety and Health Administration (OSHA) safety protocols and utility safety procedures.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Safety Compliance Score' ;
    rdfs:comment 'Numeric score for safety compliance competency assessment.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strengthsSummary rdf:type rdf:Property ;
    rdfs:label 'Strengths Summary' ;
    rdfs:comment 'Narrative summary of the employee\'s key strengths, accomplishments, and positive contributions during the review period.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successionPlanningCandidateFlag rdf:type rdf:Property ;
    rdfs:label 'Succession Planning Candidate Flag' ;
    rdfs:comment 'Indicates whether the employee is identified as a candidate for succession planning for critical roles within the utility.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:teamworkRating rdf:type rdf:Property ;
    rdfs:label 'Teamwork Rating' ;
    rdfs:comment 'Performance rating for collaboration, communication, and teamwork with colleagues and cross-functional teams.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamworkScore rdf:type rdf:Property ;
    rdfs:label 'Teamwork Score' ;
    rdfs:comment 'Numeric score for teamwork and collaboration competency assessment.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicalSkillsRating rdf:type rdf:Property ;
    rdfs:label 'Technical Skills Rating' ;
    rdfs:comment 'Performance rating for technical competencies and job-specific skills required for water and wastewater operations.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalSkillsScore rdf:type rdf:Property ;
    rdfs:label 'Technical Skills Score' ;
    rdfs:comment 'Numeric score for technical skills competency assessment.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positionId rdf:type rdf:Property ;
    rdfs:label 'Position Id' ;
    rdfs:comment 'Unique identifier for the organizational position. Primary key.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:departmentOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Department Org Unit Id' ;
    rdfs:comment 'Reference to the organizational department or division to which this position is assigned (e.g., Water Treatment Operations, Distribution Maintenance, Wastewater Collections).' ;
    rdfs:domain ind:Position ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:supervisorPositionId rdf:type rdf:Property ;
    rdfs:label 'Supervisor Position Id' ;
    rdfs:comment 'Reference to the position that supervises this position in the organizational hierarchy. Enables reporting structure and span-of-control analysis.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:bargainingUnit rdf:type rdf:Property ;
    rdfs:label 'Bargaining Unit' ;
    rdfs:comment 'Name or code of the collective bargaining unit to which this position belongs, if applicable (e.g., AFSCME Local 123, Teamsters Local 456). Null for non-union positions.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flsaStatus rdf:type rdf:Property ;
    rdfs:label 'Flsa Status' ;
    rdfs:comment 'Classification under the Fair Labor Standards Act. Exempt positions are salaried and not eligible for overtime pay; non-exempt positions are eligible for overtime compensation for hours worked beyond 40 per week.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fteCount rdf:type rdf:Property ;
    rdfs:label 'Fte Count' ;
    rdfs:comment 'Number of full-time equivalent employees authorized for this position. Typically 1.0 for full-time positions; may be fractional for part-time or shared positions (e.g., 0.5 FTE).' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jobCode rdf:type rdf:Property ;
    rdfs:label 'Job Code' ;
    rdfs:comment 'Standardized job classification code linking the position to a job family and career ladder. Used for compensation benchmarking and workforce analytics.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationalLevel rdf:type rdf:Property ;
    rdfs:label 'Organizational Level' ;
    rdfs:comment 'Hierarchical level of this position within the organizational structure. Level 1 is typically executive leadership; higher numbers represent deeper levels in the hierarchy. Used for span-of-control analysis and reporting structure visualization.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payRangeMaximum rdf:type rdf:Property ;
    rdfs:label 'Pay Range Maximum' ;
    rdfs:comment 'Maximum annual salary or hourly wage for this position in USD. Defines the top of the compensation band for this position.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payRangeMinimum rdf:type rdf:Property ;
    rdfs:label 'Pay Range Minimum' ;
    rdfs:comment 'Minimum annual salary or hourly wage for this position in USD. Used for budgeting and compensation planning.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positionCode rdf:type rdf:Property ;
    rdfs:label 'Position Code' ;
    rdfs:comment 'Business identifier for the position used in SAP HR and workforce planning systems. Unique alphanumeric code assigned to each authorized position.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionDescription rdf:type rdf:Property ;
    rdfs:label 'Position Description' ;
    rdfs:comment 'Detailed narrative description of the position\'s responsibilities, duties, and accountabilities. Typically includes essential functions, working conditions, and physical requirements.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionStatus rdf:type rdf:Property ;
    rdfs:label 'Position Status' ;
    rdfs:comment 'Current lifecycle status of the position. Active positions are authorized and may be filled or vacant; frozen positions are temporarily unfunded; eliminated positions are closed and no longer part of the organizational structure.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionType rdf:type rdf:Property ;
    rdfs:label 'Position Type' ;
    rdfs:comment 'Classification of the position by employment type. Full-time positions are permanent and year-round; seasonal positions support peak demand periods (e.g., summer water demand); temporary positions are project-based.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredCertifications rdf:type rdf:Property ;
    rdfs:label 'Required Certifications' ;
    rdfs:comment 'Comma-separated list of mandatory professional certifications or licenses required for this position (e.g., CDL Class A, OSHA 30-Hour, Confined Space Entry, Backflow Prevention Certification, SCADA System Operator). Used for compliance tracking and training planning.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredOperatorLicenseGrade rdf:type rdf:Property ;
    rdfs:label 'Required Operator License Grade' ;
    rdfs:comment 'Minimum water or wastewater operator license grade required for this position as mandated by state drinking water or wastewater discharge programs. Grades typically range from 1 (entry-level) to 4 (advanced treatment plant operations). Critical for regulatory compliance under Safe Drinking Water Act (SDWA) and Clean Water Act (CWA).' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresCdl rdf:type rdf:Property ;
    rdfs:label 'Requires Cdl' ;
    rdfs:comment 'Indicates whether this position requires a valid Commercial Driver License (CDL) for operating utility vehicles (e.g., tanker trucks, heavy equipment). CDL class and endorsements are specified in required_certifications.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresConfinedSpaceEntry rdf:type rdf:Property ;
    rdfs:label 'Requires Confined Space Entry' ;
    rdfs:comment 'Indicates whether this position requires confined space entry certification and training for work in tanks, manholes, vaults, and other permit-required confined spaces. Critical for safety compliance under OSHA 1910.146.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresOnCall rdf:type rdf:Property ;
    rdfs:label 'Requires On Call' ;
    rdfs:comment 'Indicates whether this position requires 24/7 on-call availability for emergency response (e.g., water main breaks, treatment plant alarms, wastewater overflows). Critical for Operations and Maintenance (O&M) workforce planning.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetySensitive rdf:type rdf:Property ;
    rdfs:label 'Safety Sensitive' ;
    rdfs:comment 'Indicates whether this position is classified as safety-sensitive under OSHA or Department of Transportation (DOT) regulations, requiring enhanced safety training, drug testing, and incident tracking.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shiftRotationRequired rdf:type rdf:Property ;
    rdfs:label 'Shift Rotation Required' ;
    rdfs:comment 'Indicates whether this position requires rotating shift work (e.g., 24/7 treatment plant operations with day/evening/night shifts). Used for crew scheduling and workforce planning.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:successionCriticality rdf:type rdf:Property ;
    rdfs:label 'Succession Criticality' ;
    rdfs:comment 'Assessment of the criticality of this position for succession planning. Critical positions have limited internal talent pools and require proactive succession planning (e.g., licensed operators, specialized engineers).' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionClassification rdf:type rdf:Property ;
    rdfs:label 'Union Classification' ;
    rdfs:comment 'Indicates whether this position is covered by a collective bargaining agreement. Union positions are subject to negotiated labor contracts; management positions are typically excluded from union representation.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyIncidentId rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Id' ;
    rdfs:comment 'Unique identifier for the safety incident record. Primary key.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySafetyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Safety Employee Id' ;
    rdfs:comment 'Identifier of the employee involved in or affected by the incident. Links to SAP HR employee master.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiarySafetyReportedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Safety Reported By Employee Id' ;
    rdfs:comment 'Identifier of the employee who reported the incident. May be the affected employee, a witness, or a supervisor.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bodyPartAffected rdf:type rdf:Property ;
    rdfs:label 'Body Part Affected' ;
    rdfs:comment 'Body part or region affected by the injury (e.g., hand, back, leg, eye, head). Required for OSHA 300 log if injury occurred.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysAwayFromWork rdf:type rdf:Property ;
    rdfs:label 'Days Away From Work' ;
    rdfs:comment 'Number of calendar days the employee was unable to work as a result of the incident. Used for OSHA 300 log and lost-time injury rate calculation.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysOfRestrictedDuty rdf:type rdf:Property ;
    rdfs:label 'Days Of Restricted Duty' ;
    rdfs:comment 'Number of calendar days the employee was on restricted or light duty as a result of the incident. Used for OSHA 300 log.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'Department or organizational unit where the employee was assigned at the time of the incident (e.g., Water Treatment, Distribution Operations, Wastewater Collection).' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalReleaseFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Release Flag' ;
    rdfs:comment 'Indicates whether the incident involved an environmental release (spill, discharge, or emission). True if release occurred, False if no release.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalReleaseVolume rdf:type rdf:Property ;
    rdfs:label 'Environmental Release Volume' ;
    rdfs:comment 'Volume of environmental release in gallons, if applicable. Used for regulatory reporting and environmental impact assessment.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fieldLocationDescription rdf:type rdf:Property ;
    rdfs:label 'Field Location Description' ;
    rdfs:comment 'Textual description of the field location where the incident occurred, if not at a fixed facility (e.g., intersection of Main St and Oak Ave, water main break site at 123 Elm Street).' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentDate rdf:type rdf:Property ;
    rdfs:label 'Incident Date' ;
    rdfs:comment 'Date when the safety incident occurred.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incidentDescription rdf:type rdf:Property ;
    rdfs:label 'Incident Description' ;
    rdfs:comment 'Detailed narrative description of how the incident occurred, including sequence of events, conditions, and contributing factors.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Number' ;
    rdfs:comment 'Business-facing unique incident number used for tracking and reporting. Format: INC-YYYYMMDD.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentTime rdf:type rdf:Property ;
    rdfs:label 'Incident Time' ;
    rdfs:comment 'Precise timestamp when the safety incident occurred, including time zone.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:incidentType rdf:type rdf:Property ;
    rdfs:label 'Incident Type' ;
    rdfs:comment 'Classification of the safety incident: injury (physical harm to employee), near-miss (potential incident with no harm), property damage (damage to utility assets or equipment), environmental release (spill or discharge), vehicle accident (fleet-related collision), or occupational illness (work-related disease).' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuryNature rdf:type rdf:Property ;
    rdfs:label 'Injury Nature' ;
    rdfs:comment 'Nature or type of injury sustained (e.g., laceration, contusion, fracture, sprain, burn, chemical exposure, respiratory illness).' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injurySeverity rdf:type rdf:Property ;
    rdfs:label 'Injury Severity' ;
    rdfs:comment 'Severity classification of the injury: first aid (minor treatment only), medical treatment (beyond first aid), lost time (days away from work), restricted duty (work restrictions applied), fatality (death), or none (no injury, e.g., near-miss or property damage).' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Completed Date' ;
    rdfs:comment 'Date when the incident investigation was completed and the investigation report was finalized.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationStatus rdf:type rdf:Property ;
    rdfs:label 'Investigation Status' ;
    rdfs:comment 'Current status of the incident investigation: pending (not yet started), in progress (investigation underway), completed (investigation finished, report submitted), or closed (all corrective actions completed and verified).' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaLogReference rdf:type rdf:Property ;
    rdfs:label 'Osha Log Reference' ;
    rdfs:comment 'Reference to the OSHA 300 log entry number if the incident is OSHA-recordable. Format varies by utility (e.g., 2024-001, 300-2024-0015).' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaRecordableFlag rdf:type rdf:Property ;
    rdfs:label 'Osha Recordable Flag' ;
    rdfs:comment 'Indicates whether the incident meets OSHA criteria for recordability on the OSHA 300 log. True if recordable, False if not recordable.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:propertyDamageAmount rdf:type rdf:Property ;
    rdfs:label 'Property Damage Amount' ;
    rdfs:comment 'Estimated or actual cost of property damage resulting from the incident, in US dollars. Includes damage to utility assets, equipment, vehicles, or third-party property.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed description of the root cause identified through incident investigation, including contributing factors and systemic issues.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisorName rdf:type rdf:Property ;
    rdfs:label 'Supervisor Name' ;
    rdfs:comment 'Name of the supervisor responsible for the employee or work area at the time of the incident.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessCount rdf:type rdf:Property ;
    rdfs:label 'Witness Count' ;
    rdfs:comment 'Number of witnesses to the incident. Used for investigation completeness tracking.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crewAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Crew Assignment Id' ;
    rdfs:comment 'Identifier of the crew or team this shift assignment belongs to. Used for coordinated multi-person work assignments.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CrewAssignment .

ind:primaryShiftEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Shift Employee Id' ;
    rdfs:comment 'Identifier of the employee assigned to this shift. Links to the employee master record in SAP HR.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryShiftApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Shift Approved By Employee Id' ;
    rdfs:comment 'Identifier of the user who approved this shift assignment or any changes to it. Used for audit trail and accountability.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:shiftScheduleId rdf:type rdf:Property ;
    rdfs:label 'Shift Schedule Id' ;
    rdfs:comment 'Identifier of the shift schedule template or pattern this assignment belongs to. Links to the shift schedule master.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShiftSchedule .

ind:swapRequestId rdf:type rdf:Property ;
    rdfs:label 'Swap Request Id' ;
    rdfs:comment 'Identifier of the shift swap request if this assignment resulted from an approved employee shift exchange.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SwapRequest .

ind:tertiaryShiftSupervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Shift Supervisor Employee Id' ;
    rdfs:comment 'Identifier of the supervisor or manager responsible for this shift assignment. Used for approval workflows and escalation.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:absenceNotes rdf:type rdf:Property ;
    rdfs:label 'Absence Notes' ;
    rdfs:comment 'Free-text notes providing additional context about an absence or shift assignment change.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:absenceReason rdf:type rdf:Property ;
    rdfs:label 'Absence Reason' ;
    rdfs:comment 'The reason code if the employee was absent for this scheduled shift. Used for attendance tracking and leave management. [ENUM-REF-CANDIDATE: sick_leave|vacation|personal|bereavement|jury_duty|military|fmla|no_show|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'The actual date and time when the employee clocked out or completed the shift. Used for actual hours worked calculation.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualHours rdf:type rdf:Property ;
    rdfs:label 'Actual Hours' ;
    rdfs:comment 'The actual duration worked in hours. Calculated from actual start and end timestamps. Used for payroll and labor cost tracking.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Verified Flag' ;
    rdfs:comment 'Indicates whether the assigned employee holds valid certification for the required role. True if certification is current and verified.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emergencyCalloutFlag rdf:type rdf:Property ;
    rdfs:label 'Emergency Callout Flag' ;
    rdfs:comment 'Indicates whether this shift was an unscheduled emergency callout. True for emergency response assignments outside regular schedule.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborCostAmount rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Amount' ;
    rdfs:comment 'The total labor cost for this shift assignment including base pay, overtime premium, and shift differentials. Used for operational cost tracking and Capital Improvement Program (CIP) labor allocation.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the labor cost amount. Typically USD for U.S. water utilities.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onCallFlag rdf:type rdf:Property ;
    rdfs:label 'On Call Flag' ;
    rdfs:comment 'Indicates whether this is an on-call shift assignment. True if the employee is on standby for emergency response.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overtimeFlag rdf:type rdf:Property ;
    rdfs:label 'Overtime Flag' ;
    rdfs:comment 'Indicates whether this shift qualifies as overtime under labor regulations or collective bargaining agreements. True if overtime applies.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledHours rdf:type rdf:Property ;
    rdfs:label 'Scheduled Hours' ;
    rdfs:comment 'The planned duration of the shift in hours. Calculated from shift start and end timestamps.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftRole rdf:type rdf:Property ;
    rdfs:label 'Shift Role' ;
    rdfs:comment 'The functional role the employee performs during this shift. Determines responsibilities and required certifications. [ENUM-REF-CANDIDATE: lead_operator|assistant_operator|field_technician|maintenance_crew|on_call|supervisor|lab_technician — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCourseId rdf:type rdf:Property ;
    rdfs:label 'Training Course Id' ;
    rdfs:comment 'Unique identifier for the training course record. Primary key.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingCourse .

ind:approvedProviderVendorId rdf:type rdf:Property ;
    rdfs:label 'Approved Provider Vendor Id' ;
    rdfs:comment 'Unique identifier or accreditation number assigned to the approved training provider by the regulatory or certifying body. Used to verify provider credentials and course eligibility for CEU credits.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:courseOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Course Owner Employee Id' ;
    rdfs:comment 'Identifier of the employee responsible for maintaining the training course content, scheduling offerings, and ensuring regulatory compliance. Typically a training coordinator, subject matter expert, or department manager.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accessibilityAccommodations rdf:type rdf:Property ;
    rdfs:label 'Accessibility Accommodations' ;
    rdfs:comment 'Description of accessibility features and accommodations available for this training course to support participants with disabilities. May include closed captioning, sign language interpretation, wheelchair accessibility, assistive technology, or alternative formats.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Assessment Required Flag' ;
    rdfs:comment 'Indicates whether participants must pass a test, exam, or practical assessment to successfully complete the training course. True if assessment required; false if completion based on attendance only.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationAwarded rdf:type rdf:Property ;
    rdfs:label 'Certification Awarded' ;
    rdfs:comment 'Name of the professional certification, license, or credential awarded upon successful completion of this training course. Examples include Water Treatment Operator Grade I, OSHA 10-Hour Construction, Confined Space Entry Certification. Null if no formal certification awarded.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceuCredits rdf:type rdf:Property ;
    rdfs:label 'Ceu Credits' ;
    rdfs:comment 'Number of Continuing Education Unit credits awarded upon successful completion of the course. CEUs are required for maintaining water and wastewater operator licenses and professional certifications. One CEU equals 10 contact hours of participation in an organized continuing education experience.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cmmsSystemFlag rdf:type rdf:Property ;
    rdfs:label 'Cmms System Flag' ;
    rdfs:comment 'Indicates whether this training course covers CMMS software operation, work order management, or asset maintenance workflows. True if CMMS-related; false otherwise.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costPerParticipant rdf:type rdf:Property ;
    rdfs:label 'Cost Per Participant' ;
    rdfs:comment 'Standard cost in US dollars charged per participant for enrollment in this training course. Includes tuition, materials, and certification fees. May be zero for internal courses or subsidized programs.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:courseCategory rdf:type rdf:Property ;
    rdfs:label 'Course Category' ;
    rdfs:comment 'Primary classification of the training course by subject area. Regulatory compliance includes EPA, OSHA, and state requirements; operations and maintenance covers WTP, WWTP, and distribution; safety includes OSHA and utility-specific programs; technical skills covers SCADA, CMMS, GIS, and equipment operation; leadership development includes supervisory and management training; system-specific covers proprietary systems and equipment.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseCode rdf:type rdf:Property ;
    rdfs:label 'Course Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the training course for identification and registration purposes. Used in training management systems and employee records.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseDescription rdf:type rdf:Property ;
    rdfs:label 'Course Description' ;
    rdfs:comment 'Detailed description of the training course content, learning objectives, target audience, and prerequisites.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseMaterialsUrl rdf:type rdf:Property ;
    rdfs:label 'Course Materials Url' ;
    rdfs:comment 'Web address or file path where course materials, handouts, presentations, and reference documents are stored and accessible to participants. May link to learning management system (LMS) or document repository.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseStatus rdf:type rdf:Property ;
    rdfs:label 'Course Status' ;
    rdfs:comment 'Current lifecycle status of the training course in the catalog. Active courses are available for enrollment; inactive courses are temporarily unavailable; under development courses are being created or updated; retired courses are no longer offered; suspended courses are on hold pending review or regulatory changes.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseTitle rdf:type rdf:Property ;
    rdfs:label 'Course Title' ;
    rdfs:comment 'Full official title of the training course as it appears in the training catalog and on certificates.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationHours rdf:type rdf:Property ;
    rdfs:label 'Duration Hours' ;
    rdfs:comment 'Total instructional time required to complete the training course, measured in hours. Includes classroom time, online modules, and hands-on practice but excludes breaks and meals.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gisSystemFlag rdf:type rdf:Property ;
    rdfs:label 'Gis System Flag' ;
    rdfs:comment 'Indicates whether this training course covers GIS software operation, network mapping, or spatial analysis. True if GIS-related; false otherwise.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'Three-letter ISO 639-2 language code indicating the primary language in which the training course is delivered. Examples: ENG for English, SPA for Spanish.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastContentReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Content Review Date' ;
    rdfs:comment 'Date on which the training course content, materials, and curriculum were last reviewed and validated for accuracy, relevance, and regulatory compliance. Used to ensure training materials remain current.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumEnrollment rdf:type rdf:Property ;
    rdfs:label 'Maximum Enrollment' ;
    rdfs:comment 'Maximum number of participants that can be enrolled in a single offering of this training course. Driven by classroom capacity, instructor-to-student ratios, or equipment availability. Null if no enrollment limit.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passingScorePercentage rdf:type rdf:Property ;
    rdfs:label 'Passing Score Percentage' ;
    rdfs:comment 'Minimum percentage score required on the course assessment to achieve successful completion and receive credit or certification. Null if no assessment required.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prerequisiteCourses rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Courses' ;
    rdfs:comment 'Comma-separated list of course codes that must be completed before enrolling in this training course. Null if no prerequisites required.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Required Frequency Months' ;
    rdfs:comment 'Interval in months at which employees must retake or refresh this training course to maintain compliance or certification. For example, 12 for annual training, 36 for triennial. Null if one-time or no recurring requirement.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyTrainingFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Training Flag' ;
    rdfs:comment 'Indicates whether this training course addresses workplace safety, hazard recognition, personal protective equipment (PPE), or emergency response. True if safety-related; false otherwise. Used to track OSHA compliance training.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scadaSystemFlag rdf:type rdf:Property ;
    rdfs:label 'Scada System Flag' ;
    rdfs:comment 'Indicates whether this training course covers SCADA system operation, monitoring, or troubleshooting. True if SCADA-related; false otherwise. Used to track critical infrastructure training compliance.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetAudience rdf:type rdf:Property ;
    rdfs:label 'Target Audience' ;
    rdfs:comment 'Description of the employee roles, job functions, or departments for which this training course is designed. Examples include water treatment operators, distribution technicians, maintenance crews, supervisors, laboratory staff, or all employees.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContractNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Contract Number' ;
    rdfs:comment 'Reference number of the contract or purchase order with the external training provider, if applicable. Used for procurement tracking and invoice reconciliation. Null for internal courses.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRecordId rdf:type rdf:Property ;
    rdfs:label 'Training Record Id' ;
    rdfs:comment 'Unique identifier for the training record. Primary key.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attendancePercentage rdf:type rdf:Property ;
    rdfs:label 'Attendance Percentage' ;
    rdfs:comment 'Percentage of the training session that the employee attended, used to determine eligibility for completion credit.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationIssued rdf:type rdf:Property ;
    rdfs:label 'Certification Issued' ;
    rdfs:comment 'Name or identifier of the certification or credential issued upon successful completion of the training (e.g., Water Treatment Operator Grade II, OSHA 10-Hour Safety).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceuCreditsEarned rdf:type rdf:Property ;
    rdfs:label 'Ceu Credits Earned' ;
    rdfs:comment 'Number of Continuing Education Unit credits earned upon successful completion of the training. Required for maintaining water and wastewater operator licenses.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:courseName rdf:type rdf:Property ;
    rdfs:label 'Course Name' ;
    rdfs:comment 'Full name of the training course completed by the employee.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructorName rdf:type rdf:Property ;
    rdfs:label 'Instructor Name' ;
    rdfs:comment 'Name of the instructor or facilitator who conducted the training session.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Is Compliance Required' ;
    rdfs:comment 'Flag indicating whether this training satisfies internal compliance requirements, safety protocols, or operational standards.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingCategory rdf:type rdf:Property ;
    rdfs:label 'Training Category' ;
    rdfs:comment 'High-level category or classification of the training content (e.g., technical, safety, regulatory, leadership, operational, customer service).' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingLocation rdf:type rdf:Property ;
    rdfs:label 'Training Location' ;
    rdfs:comment 'Physical or virtual location where the training was conducted (e.g., facility name, city, online platform).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingMaterialsProvided rdf:type rdf:Property ;
    rdfs:label 'Training Materials Provided' ;
    rdfs:comment 'Flag indicating whether training materials (manuals, handouts, digital resources) were provided to the employee.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingResult rdf:type rdf:Property ;
    rdfs:label 'Training Result' ;
    rdfs:comment 'Outcome of the training event indicating whether the employee passed, failed, or did not complete the training.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingStatus rdf:type rdf:Property ;
    rdfs:label 'Training Status' ;
    rdfs:comment 'Current status of the training record in its lifecycle (e.g., scheduled, in progress, completed, cancelled, no show).' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingType rdf:type rdf:Property ;
    rdfs:label 'Training Type' ;
    rdfs:comment 'Type of training event indicating whether it is initial training, a refresher, recertification, advanced, or specialized training.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceRateScheduleId rdf:type rdf:Property ;
    rdfs:label 'Service Rate Schedule Id' ;
    rdfs:comment 'Unique identifier for the service_rate_schedule data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceRateCaseId rdf:type rdf:Property ;
    rdfs:label 'Service Rate Case Id' ;
    rdfs:comment 'Unique identifier for the service_rate_case data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:ServiceRateCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerAssistanceEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Customer Assistance Enrollment Id' ;
    rdfs:comment 'Unique identifier for the customer_assistance_enrollment data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:CustomerAssistanceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:depositId rdf:type rdf:Property ;
    rdfs:label 'Deposit Id' ;
    rdfs:comment 'Unique identifier for the customer_deposit data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:Deposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:networkReadingId rdf:type rdf:Property ;
    rdfs:label 'Network Reading Id' ;
    rdfs:comment 'Primary key for network_reading' ;
    rdfs:domain ind:NetworkReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:meteringNrwWaterBalanceId rdf:type rdf:Property ;
    rdfs:label 'Metering Nrw Water Balance Id' ;
    rdfs:comment 'Unique identifier for the metering_nrw_water_balance data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:MeteringNrwWaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nrwLossGeneralLedgerId rdf:type rdf:Property ;
    rdfs:label 'Nrw Loss General Ledger Id' ;
    rdfs:comment 'Foreign key linking to finance.general_ledger. Business justification: Non-revenue water losses must be recorded in specific GL accounts for regulatory compliance, rate case justification, and financial transparency. NRW water balance calculations drive loss accounting e' ;
    rdfs:domain ind:MeteringNrwWaterBalance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeneralLedger .

ind:discoveredByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Discovered By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Violations are discovered during operations by specific employees (operators, lab staff, inspectors). Tracks who identified the issue for follow-up, training needs assessment, and internal audit trail' ;
    rdfs:domain ind:ComplianceViolation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:qualityPublicNotificationId rdf:type rdf:Property ;
    rdfs:label 'Quality Public Notification Id' ;
    rdfs:comment 'Unique identifier for the quality_public_notification data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:QualityPublicNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityInstrumentCalibrationId rdf:type rdf:Property ;
    rdfs:label 'Quality Instrument Calibration Id' ;
    rdfs:comment 'Unique identifier for the quality_instrument_calibration data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityInstrumentCalibration .

ind:laboratoryInstrumentCalibrationId rdf:type rdf:Property ;
    rdfs:label 'Laboratory Instrument Calibration Id' ;
    rdfs:comment 'Unique identifier for the laboratory_instrument_calibration data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:LaboratoryInstrumentCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:laboratoryCorrectiveActionId rdf:type rdf:Property ;
    rdfs:label 'Laboratory Corrective Action Id' ;
    rdfs:comment 'Unique identifier for the laboratory_corrective_action data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:LaboratoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:punchListId rdf:type rdf:Property ;
    rdfs:label 'Punch List Id' ;
    rdfs:comment 'Unique identifier for the punch_list data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:PunchList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectScheduleId rdf:type rdf:Property ;
    rdfs:label 'Project Schedule Id' ;
    rdfs:comment 'Unique identifier for the project_schedule data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interfundTransferId rdf:type rdf:Property ;
    rdfs:label 'Interfund Transfer Id' ;
    rdfs:comment 'Unique identifier for the interfund_transfer data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:InterfundTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceFundId rdf:type rdf:Property ;
    rdfs:label 'Source Fund Id' ;
    rdfs:comment 'Foreign key linking to finance.fund. Business justification: Interfund transfers move money from a source fund. The interfund_transfer table has no visible attributes other than PK, so this FK is needed to link to the source fund. The FK uses the descriptive pr' ;
    rdfs:domain ind:InterfundTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fund .

ind:complianceDeterminationId rdf:type rdf:Property ;
    rdfs:label 'Compliance Determination Id' ;
    rdfs:comment 'Unique identifier for the compliance_determination data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:ComplianceDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:installationId rdf:type rdf:Property ;
    rdfs:label 'Installation Id' ;
    rdfs:comment 'Primary key for installation' ;
    rdfs:domain ind:Installation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pfasMonitoringId rdf:type rdf:Property ;
    rdfs:label 'Pfas Monitoring Id' ;
    rdfs:comment 'Primary key for pfas_monitoring' ;
    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disconnectionServiceOrderId rdf:type rdf:Property ;
    rdfs:label 'Disconnection Service Order Id' ;
    rdfs:comment 'Foreign key linking to service.service_order. Business justification: Collection notices for non-payment trigger disconnection service orders when payment is not received by due date. Collections workflow requires linking the delinquency notice to the scheduled disconne' ;
    rdfs:domain ind:CollectionNotice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:generatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Generated By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Collection notices require employee accountability tracking for customer service quality assurance and dispute resolution. Water utilities need to identify which employee generated each notice for aud' ;
    rdfs:domain ind:CollectionNotice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tamperEventId rdf:type rdf:Property ;
    rdfs:label 'Tamper Event Id' ;
    rdfs:comment 'Primary key for tamper_event' ;
    rdfs:domain ind:TamperEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replacementProgramId rdf:type rdf:Property ;
    rdfs:label 'Replacement Program Id' ;
    rdfs:comment 'Primary key for replacement_program' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReplacementProgram .

ind:replacementOrderId rdf:type rdf:Property ;
    rdfs:label 'Replacement Order Id' ;
    rdfs:comment 'Primary key for replacement_order' ;
    rdfs:domain ind:ReplacementOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accuracyTestId rdf:type rdf:Property ;
    rdfs:label 'Accuracy Test Id' ;
    rdfs:comment 'Foreign key linking to metering.accuracy_test. Business justification: replacement_order captures old_meter_accuracy_test_result as a scalar value but lacks FK to the actual accuracy_test record that triggered the replacement. Meter replacements are often driven by faile' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccuracyTest .

ind:oldMeteringMeterId rdf:type rdf:Property ;
    rdfs:label 'Old Metering Meter Id' ;
    rdfs:comment 'Foreign key linking to metering.metering_meter. Business justification: A replacement order replaces an existing (old) meter with a new meter. This FK tracks which physical meter device was removed/replaced. This is the first of two FKs to metering_meter (old and new), re' ;
    rdfs:domain ind:ReplacementOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MeteringMeter .

ind:meteringComplaintId rdf:type rdf:Property ;
    rdfs:label 'Metering Complaint Id' ;
    rdfs:comment 'Primary key for complaint' ;
    rdfs:domain ind:MeteringComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exceedanceId rdf:type rdf:Property ;
    rdfs:label 'Exceedance Id' ;
    rdfs:comment 'Primary key for exceedance' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Exceedance .

ind:customerProgramEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Customer Program Enrollment Id' ;
    rdfs:comment 'Primary key for customer_program_enrollment' ;
    rdfs:domain ind:CustomerProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:participationEndDate rdf:type rdf:Property ;
    rdfs:label 'Participation End Date' ;
    rdfs:comment 'Date when the customer completed or exited the conservation program. Null for ongoing enrollments. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:CustomerProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:participationStartDate rdf:type rdf:Property ;
    rdfs:label 'Participation Start Date' ;
    rdfs:comment 'Date when the customer began active participation in the conservation program activities. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:CustomerProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rebatePaymentDate rdf:type rdf:Property ;
    rdfs:label 'Rebate Payment Date' ;
    rdfs:comment 'Date when the rebate or incentive payment was issued to the customer for this program enrollment. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:CustomerProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waterSavingsAchievedGallons rdf:type rdf:Property ;
    rdfs:label 'Water Savings Achieved Gallons' ;
    rdfs:comment 'Measured or estimated water savings in gallons achieved by this specific customer through this specific program enrollment. Used for program performance reporting and regulatory compliance. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:CustomerProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:analystMethodQualificationId rdf:type rdf:Property ;
    rdfs:label 'Analyst Method Qualification Id' ;
    rdfs:comment 'Unique identifier for this analyst-method qualification record. Primary key.' ;
    rdfs:domain ind:AnalystMethodQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedTestMethods rdf:type rdf:Property ;
    rdfs:label 'Approved Test Methods' ;
    rdfs:comment 'Comma-separated list or structured text of EPA method numbers and analytical procedures the analyst is qualified and authorized to perform. Examples include EPA 200.7 (metals by ICP), EPA 300.0 (anions by IC), EPA 524.2 (VOCs by GC/MS), Standard Methods 2540 (solids), etc. [Moved from certified_analyst: This comma-separated list attribute in certified_analyst is a denormalized representation of the many-to-many relationship. The proper model is to track each analyst-method qualification as a separate record in the association table with full qualification details. This attribute should be removed and replaced by queries against the analyst_method_qualification association.]' ;
    rdfs:domain ind:AnalystMethodQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demonstrationOfCapabilityDate rdf:type rdf:Property ;
    rdfs:label 'Demonstration Of Capability Date' ;
    rdfs:comment 'Date on which the analyst successfully completed the Demonstration of Capability (DOC) for this method, proving they can meet method performance criteria. Required by TNI and NELAC standards.' ;
    rdfs:domain ind:AnalystMethodQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initialTrainingDate rdf:type rdf:Property ;
    rdfs:label 'Initial Training Date' ;
    rdfs:comment 'Date on which the analyst completed initial training for this specific test method. Part of the qualification documentation trail.' ;
    rdfs:domain ind:AnalystMethodQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proficiencyTestStatus rdf:type rdf:Property ;
    rdfs:label 'Proficiency Test Status' ;
    rdfs:comment 'Status of the analyst\'s most recent proficiency testing for this specific method. Proficiency testing is required by accreditation bodies to verify analyst competency.' ;
    rdfs:domain ind:AnalystMethodQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Status' ;
    rdfs:comment 'Current lifecycle status of this analyst-method qualification. Active qualifications authorize the analyst to perform the method; expired or suspended qualifications require remediation.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountEnforcementImpactId rdf:type rdf:Property ;
    rdfs:label 'Account Enforcement Impact Id' ;
    rdfs:comment 'Unique identifier for this account-enforcement impact record. Primary key.' ;
    rdfs:domain ind:AccountEnforcementImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Account Customer Account Id' ;
    rdfs:comment 'Foreign key linking to the affected customer account' ;
    rdfs:domain ind:AccountEnforcementImpact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:accountRestrictionType rdf:type rdf:Property ;
    rdfs:label 'Account Restriction Type' ;
    rdfs:comment 'Type of operational restriction imposed on this account as a result of the enforcement action. Values: SERVICE_SUSPENSION (service temporarily halted), BILLING_HOLD (billing suspended pending resolution), NEW_CONNECTION_BLOCK (no new service connections allowed), USAGE_RESTRICTION (volumetric limits imposed), DISCHARGE_LIMIT (wastewater discharge restrictions for industrial accounts), NONE (no restrictions)' ;
    rdfs:domain ind:AccountEnforcementImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedServiceCount rdf:type rdf:Property ;
    rdfs:label 'Affected Service Count' ;
    rdfs:comment 'Number of active service connections at this account affected by the enforcement action (e.g., water service, wastewater service, stormwater service)' ;
    rdfs:domain ind:AccountEnforcementImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerResponseDueDate rdf:type rdf:Property ;
    rdfs:label 'Customer Response Due Date' ;
    rdfs:comment 'Deadline by which the customer must respond or complete required actions. Null if no customer response is required.' ;
    rdfs:domain ind:AccountEnforcementImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerResponseReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Customer Response Received Date' ;
    rdfs:comment 'Date the utility received the required response or confirmation of action completion from the customer. Null if response not yet received or not required.' ;
    rdfs:domain ind:AccountEnforcementImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerResponseRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Response Required Flag' ;
    rdfs:comment 'Indicates whether the customer account holder is required to take specific action or provide information in response to the enforcement action (e.g., industrial customer must submit discharge monitoring reports, commercial customer must install backflow prevention)' ;
    rdfs:domain ind:AccountEnforcementImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impactResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Impact Resolution Date' ;
    rdfs:comment 'Date when all account-level impacts from the enforcement action were fully resolved (restrictions lifted, financial impacts settled, customer actions completed). Null if impact is ongoing.' ;
    rdfs:domain ind:AccountEnforcementImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:impactSeverity rdf:type rdf:Property ;
    rdfs:label 'Impact Severity' ;
    rdfs:comment 'Severity level of the enforcement action impact on this specific account. CRITICAL (service interruption or health/safety risk), HIGH (significant operational or financial impact), MEDIUM (moderate restrictions or costs), LOW (minor administrative impact), MINIMAL (informational only)' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionEndDate rdf:type rdf:Property ;
    rdfs:label 'Restriction End Date' ;
    rdfs:comment 'Date when account-level restrictions were lifted or are scheduled to be lifted. Null if restrictions are ongoing or no restrictions were imposed.' ;
    rdfs:domain ind:AccountEnforcementImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restrictionStartDate rdf:type rdf:Property ;
    rdfs:label 'Restriction Start Date' ;
    rdfs:comment 'Date when account-level restrictions resulting from the enforcement action became effective. Null if no restrictions imposed.' ;
    rdfs:domain ind:AccountEnforcementImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:premiseOverflowImpactId rdf:type rdf:Property ;
    rdfs:label 'Premise Overflow Impact Id' ;
    rdfs:comment 'Unique identifier for this premise-overflow impact record. Primary key.' ;
    rdfs:domain ind:PremiseOverflowImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cleanupCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Cleanup Completion Date' ;
    rdfs:comment 'Date when cleanup or remediation was completed at this premise. Null if cleanup was not required. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:PremiseOverflowImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cleanupRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cleanup Required Flag' ;
    rdfs:comment 'Indicates whether cleanup or remediation was required at this specific premise as a result of the overflow event. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:PremiseOverflowImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerCompensationAmount rdf:type rdf:Property ;
    rdfs:label 'Customer Compensation Amount' ;
    rdfs:comment 'Dollar amount of compensation provided to the customer at this premise due to the overflow impact. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:PremiseOverflowImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impactType rdf:type rdf:Property ;
    rdfs:label 'Impact Type' ;
    rdfs:comment 'Classification of the type of impact this overflow event had on this specific premise. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:PremiseOverflowImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planAnalyteRequirementId rdf:type rdf:Property ;
    rdfs:label 'Plan Analyte Requirement Id' ;
    rdfs:comment 'Unique identifier for this plan-analyte requirement record. Primary key.' ;
    rdfs:domain ind:PlanAnalyteRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:analyteList rdf:type rdf:Property ;
    rdfs:label 'Analyte List' ;
    rdfs:comment 'Comma-separated list of required analytes or parameters to be tested under this sampling plan (e.g., pH, turbidity, chlorine residual, THM, HAA5, lead, copper, PFAS, BOD, TSS, E. coli). Detailed test methods are specified separately. [Moved from sampling_plan: This comma-separated list in sampling_plan is a denormalized representation of the M:N relationship. The proper model is to have individual plan_analyte_requirement records rather than a text list. This attribute should be deprecated in favor of querying the association table.]' ;
    rdfs:domain ind:PlanAnalyteRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceThresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Compliance Threshold Unit' ;
    rdfs:comment 'Unit of measure for the compliance threshold (e.g., mg/L, µg/L, CFU/100mL). Stored at the requirement level because different plans may report the same analyte in different units.' ;
    rdfs:domain ind:PlanAnalyteRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Compliance Threshold Value' ;
    rdfs:comment 'The specific regulatory or permit limit for this analyte under this sampling plan. May differ from the default MCL in the analyte table if the plan is driven by a specific permit or state regulation with stricter limits.' ;
    rdfs:domain ind:PlanAnalyteRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mandatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Flag' ;
    rdfs:comment 'Indicates whether testing for this analyte is mandatory (true) or optional (false) under this sampling plan. Some plans may include optional analytes for operational monitoring beyond regulatory requirements.' ;
    rdfs:domain ind:PlanAnalyteRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planAnalyteRequirementStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Analyte Requirement Status' ;
    rdfs:comment 'Current status of this analyte requirement: active (currently in effect), inactive (temporarily suspended), pending (scheduled for future activation), superseded (replaced by updated requirement).' ;
    rdfs:domain ind:PlanAnalyteRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredDetectionLimit rdf:type rdf:Property ;
    rdfs:label 'Required Detection Limit' ;
    rdfs:comment 'The minimum detection limit required for this analyte under this plan. May be more stringent than the analyte\'s default detection limit if the plan is driven by a regulatory program requiring lower detection limits (e.g., PFAS monitoring).' ;
    rdfs:domain ind:PlanAnalyteRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testMethodCode rdf:type rdf:Property ;
    rdfs:label 'Test Method Code' ;
    rdfs:comment 'The specific EPA, Standard Methods, or ASTM method code required for testing this analyte under this sampling plan. Different plans may require different methods for the same analyte based on regulatory driver or detection limit requirements.' ;
    rdfs:domain ind:PlanAnalyteRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testMethodList rdf:type rdf:Property ;
    rdfs:label 'Test Method List' ;
    rdfs:comment 'Comma-separated list of required analytical test methods or standard method references (e.g., EPA 200.8, SM 2320B, ASTM D1067) corresponding to the analyte list. Ensures regulatory compliance and analytical consistency. [Moved from sampling_plan: This comma-separated list in sampling_plan is a denormalized representation of test methods that should be stored at the plan-analyte requirement level. Different analytes under the same plan require different test methods, so this belongs in the association, not as a plan-level list.]' ;
    rdfs:domain ind:PlanAnalyteRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitVendorServiceId rdf:type rdf:Property ;
    rdfs:label 'Permit Vendor Service Id' ;
    rdfs:comment 'Unique identifier for the permit vendor service relationship record. Primary key.' ;
    rdfs:domain ind:PermitVendorService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractAmount rdf:type rdf:Property ;
    rdfs:label 'Contract Amount' ;
    rdfs:comment 'Total contracted dollar amount for vendor services specific to this permit engagement.' ;
    rdfs:domain ind:PermitVendorService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliverableStatus rdf:type rdf:Property ;
    rdfs:label 'Deliverable Status' ;
    rdfs:comment 'Current status of the vendor deliverables for this permit service engagement. Identified in detection phase as relationship-specific data.' ;
    rdfs:domain ind:PermitVendorService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedDate rdf:type rdf:Property ;
    rdfs:label 'Modified Date' ;
    rdfs:comment 'Timestamp when this permit vendor service record was last modified.' ;
    rdfs:domain ind:PermitVendorService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceScope rdf:type rdf:Property ;
    rdfs:label 'Service Scope' ;
    rdfs:comment 'Detailed description of the scope of work and deliverables the vendor is contracted to provide for this specific permit. Identified in detection phase as relationship-specific data.' ;
    rdfs:domain ind:PermitVendorService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryContaminantMonitoringRequirementId rdf:type rdf:Property ;
    rdfs:label 'Territory Contaminant Monitoring Requirement Id' ;
    rdfs:comment 'Primary key for the territory_contaminant_monitoring_requirement association' ;
    rdfs:domain ind:TerritoryContaminantMonitoringRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:localActionLevel rdf:type rdf:Property ;
    rdfs:label 'Local Action Level' ;
    rdfs:comment 'Action level specific to this territory that may differ from the federal standard due to state primacy agency requirements or local conditions. Exists because state agencies with primacy can set more stringent requirements than federal MCLs.' ;
    rdfs:domain ind:TerritoryContaminantMonitoringRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringFrequencyOverride rdf:type rdf:Property ;
    rdfs:label 'Monitoring Frequency Override' ;
    rdfs:comment 'Territory-specific monitoring frequency that overrides the default contaminant monitoring_frequency_code based on primacy agency approval, vulnerability assessment results, or granted waivers. This attribute exists because different territories may have different monitoring requirements for the same contaminant.' ;
    rdfs:domain ind:TerritoryContaminantMonitoringRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primacyAgencyOverride rdf:type rdf:Property ;
    rdfs:label 'Primacy Agency Override' ;
    rdfs:comment 'Identification of the specific primacy agency (state or EPA regional office) that issued the territory-specific requirement or variance. Necessary because different territories may fall under different primacy jurisdictions.' ;
    rdfs:domain ind:TerritoryContaminantMonitoringRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territorySpecificMcl rdf:type rdf:Property ;
    rdfs:label 'Territory Specific Mcl' ;
    rdfs:comment 'Maximum contaminant level specific to this territory, typically more stringent than federal MCL when set by state primacy agencies. This attribute captures jurisdiction-specific regulatory limits that vary by territory.' ;
    rdfs:domain ind:TerritoryContaminantMonitoringRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceApprovalNumber rdf:type rdf:Property ;
    rdfs:label 'Variance Approval Number' ;
    rdfs:comment 'Official reference number of the variance, waiver, or exemption approval issued by the primacy agency. Used for regulatory correspondence and audit trail.' ;
    rdfs:domain ind:TerritoryContaminantMonitoringRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceStatus rdf:type rdf:Property ;
    rdfs:label 'Variance Status' ;
    rdfs:comment 'Current status of any monitoring variance, waiver, or exemption granted by the primacy agency for this contaminant in this territory. Tracks whether the utility has been granted relief from standard monitoring requirements.' ;
    rdfs:domain ind:TerritoryContaminantMonitoringRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingParticipationId rdf:type rdf:Property ;
    rdfs:label 'Sampling Participation Id' ;
    rdfs:comment 'Unique identifier for this sampling participation record. Primary key.' ;
    rdfs:domain ind:SamplingParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessInstructions rdf:type rdf:Property ;
    rdfs:label 'Access Instructions' ;
    rdfs:comment 'Site-specific instructions for laboratory staff to access the customer\'s property for sample collection, including gate codes, contact procedures, preferred sampling times, and special access requirements. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:SamplingParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participationNotes rdf:type rdf:Property ;
    rdfs:label 'Participation Notes' ;
    rdfs:comment 'Free-text field for operational notes about this customer\'s participation, including special circumstances, historical issues, or coordination requirements.' ;
    rdfs:domain ind:SamplingParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participationStatus rdf:type rdf:Property ;
    rdfs:label 'Participation Status' ;
    rdfs:comment 'Current status of the customer\'s participation in this sampling plan: enrolled (registered but not yet active), active (currently participating), suspended (temporarily paused), withdrawn (customer opted out), completed (sampling program concluded). Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingFrequencyOverride rdf:type rdf:Property ;
    rdfs:label 'Sampling Frequency Override' ;
    rdfs:comment 'Customer-specific override of the default sampling frequency defined in the sampling plan. Used when a particular customer requires more or less frequent sampling due to site-specific conditions or regulatory requirements. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volunteerConsentDate rdf:type rdf:Property ;
    rdfs:label 'Volunteer Consent Date' ;
    rdfs:comment 'Date when the customer provided formal consent to participate in the sampling program, particularly important for voluntary programs and residential tap sampling under LCRR. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:SamplingParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:facilityServiceAllocationId rdf:type rdf:Property ;
    rdfs:label 'Facility Service Allocation Id' ;
    rdfs:comment 'Unique identifier for this facility-territory allocation record. Primary key.' ;
    rdfs:domain ind:FacilityServiceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interconnectionPointId rdf:type rdf:Property ;
    rdfs:label 'Interconnection Point Id' ;
    rdfs:comment 'Reference identifier for the physical interconnection point (valve, pump station, pipeline junction) where this facility connects to the distribution system serving this territory. Used for hydraulic modeling and emergency operations.' ;
    rdfs:domain ind:FacilityServiceAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Point .

ind:serviceTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Service Territory Id' ;
    rdfs:comment 'Foreign key to service.service_territory identifying the territory receiving service from this facility' ;
    rdfs:domain ind:FacilityServiceAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:backupFacilityFlag rdf:type rdf:Property ;
    rdfs:label 'Backup Facility Flag' ;
    rdfs:comment 'Indicates whether this facility serves as a backup/redundant water source for this territory. Critical for emergency response and system resilience planning.' ;
    rdfs:domain ind:FacilityServiceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilityServiceAllocationStatus rdf:type rdf:Property ;
    rdfs:label 'Facility Service Allocation Status' ;
    rdfs:comment 'Current operational status of this facility-territory allocation. ACTIVE = currently serving, INACTIVE = temporarily offline, PLANNED = future allocation, DECOMMISSIONED = historical record.' ;
    rdfs:domain ind:FacilityServiceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Last Updated Date' ;
    rdfs:comment 'Timestamp when this allocation record was last modified' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:primaryFacilityFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Facility Flag' ;
    rdfs:comment 'Indicates whether this facility is the primary (normal operations) water source for this territory. Used for emergency response protocols and operational planning.' ;
    rdfs:domain ind:FacilityServiceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:projectFundingAllocationId rdf:type rdf:Property ;
    rdfs:label 'Project Funding Allocation Id' ;
    rdfs:comment 'Unique identifier for this grant-to-project funding allocation record. Primary key.' ;
    rdfs:domain ind:ProjectFundingAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationCloseoutDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Closeout Date' ;
    rdfs:comment 'Date on which this allocation was formally closed out, indicating all eligible costs have been charged and final reporting completed. Null if allocation is still active.' ;
    rdfs:domain ind:ProjectFundingAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastDrawdownDate rdf:type rdf:Property ;
    rdfs:label 'Last Drawdown Date' ;
    rdfs:comment 'Date of the most recent drawdown or reimbursement request submitted for this allocation. Null if no drawdowns have occurred yet.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remainingAllocationBalance rdf:type rdf:Property ;
    rdfs:label 'Remaining Allocation Balance' ;
    rdfs:comment 'Dollar amount of allocated grant funds still available for this project. Calculated as allocation_amount minus amount_drawn_to_date.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:labAccreditationGrantId rdf:type rdf:Property ;
    rdfs:label 'Lab Accreditation Grant Id' ;
    rdfs:comment 'Primary key for the lab_accreditation_grant association' ;
    rdfs:domain ind:LabAccreditationGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accreditationContactEmail rdf:type rdf:Property ;
    rdfs:label 'Accreditation Contact Email' ;
    rdfs:comment 'Email address of the laboratory staff member responsible for managing this accreditation. [Moved from lab_accreditation: Contact email for managing this specific agency relationship. Relationship-specific.]' ;
    rdfs:domain ind:LabAccreditationGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationContactName rdf:type rdf:Property ;
    rdfs:label 'Accreditation Contact Name' ;
    rdfs:comment 'Name of the laboratory staff member responsible for managing this accreditation and serving as the primary contact with the accrediting body. [Moved from lab_accreditation: The lab contact responsible for managing this specific accreditation relationship with this agency. Relationship-specific.]' ;
    rdfs:domain ind:LabAccreditationGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationContactPhone rdf:type rdf:Property ;
    rdfs:label 'Accreditation Contact Phone' ;
    rdfs:comment 'Phone number of the laboratory staff member responsible for managing this accreditation. [Moved from lab_accreditation: Contact phone for managing this specific agency relationship. Relationship-specific.]' ;
    rdfs:domain ind:LabAccreditationGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditedAnalyteCount rdf:type rdf:Property ;
    rdfs:label 'Accredited Analyte Count' ;
    rdfs:comment 'The total number of analytes for which the laboratory is accredited under this accreditation. [Moved from lab_accreditation: The count of accredited analytes varies by agency and their scope. This is relationship-specific or derivable.]' ;
    rdfs:domain ind:LabAccreditationGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accreditedMatrixList rdf:type rdf:Property ;
    rdfs:label 'Accredited Matrix List' ;
    rdfs:comment 'Comma-separated or structured list of matrices (e.g., drinking water, wastewater, soil, sludge) covered under this accreditation. [Moved from lab_accreditation: The list of accredited matrices varies by agency. EPA may accredit for drinking water while state accredits for wastewater.]' ;
    rdfs:domain ind:LabAccreditationGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditedMethodList rdf:type rdf:Property ;
    rdfs:label 'Accredited Method List' ;
    rdfs:comment 'Comma-separated or structured list of test methods (e.g., EPA 200.7, SM 2540C) for which the laboratory is accredited. [Moved from lab_accreditation: The list of accredited methods varies by agency and their program scope. This is relationship-specific.]' ;
    rdfs:domain ind:LabAccreditationGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditingOrganizationName rdf:type rdf:Property ;
    rdfs:label 'Accrediting Organization Name' ;
    rdfs:comment 'Name of the accrediting body that issued this accreditation (e.g., state primacy agency, NELAC/TNI, A2LA, DoD ELAP). [Moved from lab_accreditation: This is redundant with the regulatory_agency reference and should be derived from the agency master record, not stored in the association or lab_accreditation.]' ;
    rdfs:domain ind:LabAccreditationGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Assessment Frequency Months' ;
    rdfs:comment 'The frequency in months at which the accrediting body conducts assessments (e.g., 12, 24, 36 months). [Moved from lab_accreditation: Assessment frequency is determined by the agency\'s program requirements, not the lab. This should be an attribute of the agency or the relationship.]' ;
    rdfs:domain ind:LabAccreditationGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificateEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Effective Date' ;
    rdfs:comment 'The effective start date of this accreditation certificate issued by this agency to this laboratory.' ;
    rdfs:domain ind:LabAccreditationGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Expiry Date' ;
    rdfs:comment 'The expiration date of this accreditation certificate. Critical for renewal tracking and ensuring regulatory defensibility.' ;
    rdfs:domain ind:LabAccreditationGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentCertificateEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Current Certificate Effective Date' ;
    rdfs:comment 'The effective start date of the current accreditation certificate. [Moved from lab_accreditation: Each agency issues its own certificate with its own effective date. This is relationship-specific.]' ;
    rdfs:domain ind:LabAccreditationGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentCertificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Current Certificate Expiry Date' ;
    rdfs:comment 'The expiration date of the current accreditation certificate. Critical for ensuring continuous regulatory defensibility. [Moved from lab_accreditation: Each agency\'s certificate has its own expiry date. This is relationship-specific and critical for renewal tracking per agency.]' ;
    rdfs:domain ind:LabAccreditationGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Assessment Date' ;
    rdfs:comment 'The date of the most recent on-site assessment conducted by this agency for this accreditation.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastOnsiteAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Onsite Assessment Date' ;
    rdfs:comment 'The date of the most recent on-site assessment conducted by the accrediting body. [Moved from lab_accreditation: Each agency conducts its own assessments on its own schedule. This is relationship-specific.]' ;
    rdfs:domain ind:LabAccreditationGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proficiencyTestPassRatePercent rdf:type rdf:Property ;
    rdfs:label 'Proficiency Test Pass Rate Percent' ;
    rdfs:comment 'The percentage of proficiency test samples that passed acceptance criteria in the most recent testing cycle. [Moved from lab_accreditation: PT pass rates are evaluated per agency program. This is relationship-specific.]' ;
    rdfs:domain ind:LabAccreditationGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proficiencyTestingProvider rdf:type rdf:Property ;
    rdfs:label 'Proficiency Testing Provider' ;
    rdfs:comment 'Name of the proficiency testing provider used to satisfy accreditation requirements (e.g., ERA, APHA, NELAP PT providers). [Moved from lab_accreditation: PT provider requirements may vary by agency program. This is relationship-specific or should be on the agency.]' ;
    rdfs:domain ind:LabAccreditationGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNotificationDaysPrior rdf:type rdf:Property ;
    rdfs:label 'Renewal Notification Days Prior' ;
    rdfs:comment 'Number of days before expiry that renewal notifications should be triggered to ensure timely renewal. [Moved from lab_accreditation: Renewal notification timing may vary by agency program requirements. This is relationship-specific or agency-specific.]' ;
    rdfs:domain ind:LabAccreditationGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grantAllocationId rdf:type rdf:Property ;
    rdfs:label 'Grant Allocation Id' ;
    rdfs:comment 'Unique identifier for this grant allocation record. Primary key.' ;
    rdfs:domain ind:GrantAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Date' ;
    rdfs:comment 'Date on which the utility certified compliance with grant conditions for this lift station project (e.g., Davis-Bacon wage requirements, environmental review, AIS compliance). Required for final reimbursement and closeout.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:constructionCost rdf:type rdf:Property ;
    rdfs:label 'Construction Cost' ;
    rdfs:comment 'Total estimated or actual construction cost for the lift station improvements funded by this grant allocation. May exceed allocation_amount if matching funds or other grants are involved.' ;
    rdfs:domain ind:GrantAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibleCostAmount rdf:type rdf:Property ;
    rdfs:label 'Eligible Cost Amount' ;
    rdfs:comment 'Dollar amount of project costs that are eligible for grant reimbursement under the grant agreement terms (excludes ineligible costs like land acquisition, certain administrative costs).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grantPercentage rdf:type rdf:Property ;
    rdfs:label 'Grant Percentage' ;
    rdfs:comment 'Percentage of the lift station project cost covered by this specific grant (e.g., 75.00 for 75% grant funding, 25% local match). Used for cost allocation and compliance reporting.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ineligibleCostAmount rdf:type rdf:Property ;
    rdfs:label 'Ineligible Cost Amount' ;
    rdfs:comment 'Dollar amount of project costs that are not eligible for grant reimbursement and must be funded by local sources.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Project Completion Date' ;
    rdfs:comment 'Date on which the grant-funded lift station improvements were substantially completed and the asset was returned to service. Used for final reimbursement requests.' ;
    rdfs:domain ind:GrantAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectMilestone rdf:type rdf:Property ;
    rdfs:label 'Project Milestone' ;
    rdfs:comment 'Current milestone status of the grant-funded lift station project: design_complete, construction_started, construction_complete, operational, closeout. Used for progress reporting to grantor and drawdown eligibility.' ;
    rdfs:domain ind:GrantAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectStartDate rdf:type rdf:Property ;
    rdfs:label 'Project Start Date' ;
    rdfs:comment 'Date on which construction or improvement work began on this grant-funded lift station project. Used for period of performance tracking.' ;
    rdfs:domain ind:GrantAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reimbursementAmount rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Amount' ;
    rdfs:comment 'Cumulative dollar amount of grant funds that have been drawn down or reimbursed for this specific lift station project. Tracks expenditure against allocation_amount.' ;
    rdfs:domain ind:GrantAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialComplianceCertificationId rdf:type rdf:Property ;
    rdfs:label 'Material Compliance Certification Id' ;
    rdfs:comment 'Unique identifier for this material-requirement compliance certification record. Primary key.' ;
    rdfs:domain ind:MaterialComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Certification Document Url' ;
    rdfs:comment 'URL or file path to the official certification document, approval letter, or compliance attestation for this material-requirement pair' ;
    rdfs:domain ind:MaterialComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dosageUnit rdf:type rdf:Property ;
    rdfs:label 'Dosage Unit' ;
    rdfs:comment 'Unit of measure for the maximum dosage rate (e.g., mg/L, ppm, lbs/day). Null if maximum_dosage_rate is not applicable.' ;
    rdfs:domain ind:MaterialComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent internal or external audit verifying that this material remains in compliance with this regulatory requirement' ;
    rdfs:domain ind:MaterialComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumDosageRate rdf:type rdf:Property ;
    rdfs:label 'Maximum Dosage Rate' ;
    rdfs:comment 'Maximum allowable dosage or application rate for this material as specified by the regulatory requirement certification. Applicable primarily to treatment chemicals. Null if not applicable.' ;
    rdfs:domain ind:MaterialComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nsfAnsiStandard rdf:type rdf:Property ;
    rdfs:label 'Nsf Ansi Standard' ;
    rdfs:comment 'Specific NSF/ANSI standard number and version under which this material is certified for use in drinking water systems (e.g., NSF/ANSI 60-2021, NSF/ANSI 61-2020)' ;
    rdfs:domain ind:MaterialComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleComplianceOfficer rdf:type rdf:Property ;
    rdfs:label 'Responsible Compliance Officer' ;
    rdfs:comment 'Name or employee ID of the compliance officer responsible for maintaining and monitoring this material-requirement certification' ;
    rdfs:domain ind:MaterialComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantFundedSegmentId rdf:type rdf:Property ;
    rdfs:label 'Grant Funded Segment Id' ;
    rdfs:comment 'Unique identifier for this grant-segment funding relationship. Primary key.' ;
    rdfs:domain ind:GrantFundedSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eligibleCostFlag rdf:type rdf:Property ;
    rdfs:label 'Eligible Cost Flag' ;
    rdfs:comment 'Indicates whether costs for this segment are eligible for reimbursement under this grant\'s allowable cost categories and compliance conditions. False if segment work does not meet grantor requirements.' ;
    rdfs:domain ind:GrantFundedSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expenditureToDate rdf:type rdf:Property ;
    rdfs:label 'Expenditure To Date' ;
    rdfs:comment 'Cumulative dollar amount of grant funds expended on this segment to date. Calculated from individual expenditure transactions. Used for drawdown reconciliation and remaining balance tracking.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchRequirementAmount rdf:type rdf:Property ;
    rdfs:label 'Match Requirement Amount' ;
    rdfs:comment 'Dollar amount of local matching funds required for this segment based on the grant\'s matching percentage. Calculated as segment_rehabilitation_cost × grant.matching_requirement_percentage.' ;
    rdfs:domain ind:GrantFundedSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:segmentRehabilitationCost rdf:type rdf:Property ;
    rdfs:label 'Segment Rehabilitation Cost' ;
    rdfs:comment 'Total estimated or actual cost of rehabilitation work on this sewer segment funded by this grant. May exceed allocation if multiple funding sources are used.' ;
    rdfs:domain ind:GrantFundedSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Work Completion Date' ;
    rdfs:comment 'Date when rehabilitation work was completed on this segment. Triggers final expenditure reconciliation and closeout processes for this segment-grant relationship.' ;
    rdfs:domain ind:GrantFundedSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workStartDate rdf:type rdf:Property ;
    rdfs:label 'Work Start Date' ;
    rdfs:comment 'Date when rehabilitation work began on this segment under this grant. Used for period of performance compliance and project timeline tracking.' ;
    rdfs:domain ind:GrantFundedSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:methodMaterialUsageId rdf:type rdf:Property ;
    rdfs:label 'Method Material Usage Id' ;
    rdfs:comment 'Unique identifier for this method-material usage record. Primary key.' ;
    rdfs:domain ind:MethodMaterialUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alternativeMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Alternative Material Flag' ;
    rdfs:comment 'Indicates whether this material is an approved alternative or substitute for the primary material specified in the method. True if alternative, false if primary/required material.' ;
    rdfs:domain ind:MethodMaterialUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consumptionRate rdf:type rdf:Property ;
    rdfs:label 'Consumption Rate' ;
    rdfs:comment 'Average consumption rate of this material for this method, expressed as quantity per time period (e.g., liters per month). Used for procurement planning and reorder point calculations.' ;
    rdfs:domain ind:MethodMaterialUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumptionRateUnit rdf:type rdf:Property ;
    rdfs:label 'Consumption Rate Unit' ;
    rdfs:comment 'Time unit for the consumption rate (per_test, per_day, per_week, per_month).' ;
    rdfs:domain ind:MethodMaterialUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerTest rdf:type rdf:Property ;
    rdfs:label 'Cost Per Test' ;
    rdfs:comment 'Calculated material cost for this specific material per single test execution. Derived from quantity_per_test and material standard_price. Used for test method cost accounting and pricing.' ;
    rdfs:domain ind:MethodMaterialUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticality rdf:type rdf:Property ;
    rdfs:label 'Criticality' ;
    rdfs:comment 'Criticality classification for this material in the context of this method. Critical materials have no substitutes and stockouts halt testing; important materials have limited alternatives; standard materials are readily substitutable.' ;
    rdfs:domain ind:MethodMaterialUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialRole rdf:type rdf:Property ;
    rdfs:label 'Material Role' ;
    rdfs:comment 'The functional role this material plays in the execution of this test method (reagent, standard, calibration_solution, preservative, consumable, quality_control_sample).' ;
    rdfs:domain ind:MethodMaterialUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredVendorFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Flag' ;
    rdfs:comment 'Indicates whether the vendor associated with this material is the preferred vendor for this specific method-material combination, based on quality, reliability, or regulatory acceptance.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityPerTest rdf:type rdf:Property ;
    rdfs:label 'Quantity Per Test' ;
    rdfs:comment 'Standard quantity of this material consumed per single test execution. Used for inventory forecasting and cost allocation. Units align with material base_unit_of_measure.' ;
    rdfs:domain ind:MethodMaterialUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:updatedBy rdf:type rdf:Property ;
    rdfs:label 'Updated By' ;
    rdfs:comment 'User ID or name of the laboratory staff member who last updated this method-material usage record.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityGrantAllocationId rdf:type rdf:Property ;
    rdfs:label 'Facility Grant Allocation Id' ;
    rdfs:comment 'Unique identifier for this facility-grant allocation record. Primary key.' ;
    rdfs:domain ind:FacilityGrantAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationEndDate rdf:type rdf:Property ;
    rdfs:label 'Allocation End Date' ;
    rdfs:comment 'Date by which all allocated grant funds for this facility must be expended or obligated. May differ from the grant period_of_performance_end_date if allocations are phased.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationStartDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Start Date' ;
    rdfs:comment 'Date on which grant funding became available for expenditure on this facility. May differ from the grant period_of_performance_start_date if allocations are phased.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:facilityProjectManagerName rdf:type rdf:Property ;
    rdfs:label 'Facility Project Manager Name' ;
    rdfs:comment 'Name of the utility employee responsible for managing the grant-funded project at this specific facility.' ;
    rdfs:domain ind:FacilityGrantAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchingFundsContributed rdf:type rdf:Property ;
    rdfs:label 'Matching Funds Contributed' ;
    rdfs:comment 'Dollar amount of local matching funds contributed by the utility for this facility-grant allocation, tracked separately to demonstrate compliance with matching requirements.' ;
    rdfs:domain ind:FacilityGrantAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextReportingDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Reporting Due Date' ;
    rdfs:comment 'Date by which the next progress or financial report is due to the grantor for this facility-grant allocation.' ;
    rdfs:domain ind:FacilityGrantAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:endpointProcurementId rdf:type rdf:Property ;
    rdfs:label 'Endpoint Procurement Id' ;
    rdfs:comment 'Primary key for the endpoint_procurement association' ;
    rdfs:domain ind:EndpointProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:procurementDate rdf:type rdf:Property ;
    rdfs:label 'Procurement Date' ;
    rdfs:comment 'Date when this endpoint was procured from this vendor. Used for tracking procurement history.' ;
    rdfs:domain ind:EndpointProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:procurementOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Procurement Order Number' ;
    rdfs:comment 'Purchase order number associated with this procurement transaction.' ;
    rdfs:domain ind:EndpointProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasePrice rdf:type rdf:Property ;
    rdfs:label 'Purchase Price' ;
    rdfs:comment 'Price paid to this vendor for this specific endpoint device. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportContractNumber rdf:type rdf:Property ;
    rdfs:label 'Support Contract Number' ;
    rdfs:comment 'Vendor-assigned support contract identifier for technical support escalation. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:EndpointProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorPartNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Part Number' ;
    rdfs:comment 'Vendor-specific part number or SKU for this endpoint model. Used for reordering and warranty claims. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyEndDate rdf:type rdf:Property ;
    rdfs:label 'Warranty End Date' ;
    rdfs:comment 'Date when the vendor warranty coverage expires for this endpoint. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:procurementMappingId rdf:type rdf:Property ;
    rdfs:label 'Procurement Mapping Id' ;
    rdfs:comment 'Unique surrogate identifier for the asset class to procurement category mapping record' ;
    rdfs:domain ind:ProcurementMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:updatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Updated By Employee Id' ;
    rdfs:comment 'Employee identifier for the procurement professional who last updated this mapping' ;
    rdfs:domain ind:ProcurementMapping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvedVendorCount rdf:type rdf:Property ;
    rdfs:label 'Approved Vendor Count' ;
    rdfs:comment 'Number of approved vendors for this asset class within this procurement category. Used for supplier diversity analysis and sourcing risk assessment.' ;
    rdfs:domain ind:ProcurementMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageUnitCost rdf:type rdf:Property ;
    rdfs:label 'Average Unit Cost' ;
    rdfs:comment 'Benchmark average unit cost in USD for items of this asset class when procured through this category. Used for budgeting, cost variance analysis, and procurement performance tracking.' ;
    rdfs:domain ind:ProcurementMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastProcurementDate rdf:type rdf:Property ;
    rdfs:label 'Last Procurement Date' ;
    rdfs:comment 'Most recent date when an item of this asset class was procured through this procurement category. Used to identify inactive mappings and refresh cost benchmarks.' ;
    rdfs:domain ind:ProcurementMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mappingStatus rdf:type rdf:Property ;
    rdfs:label 'Mapping Status' ;
    rdfs:comment 'Current lifecycle status of this asset class to procurement category mapping. Active mappings are used in procurement workflows and materials planning.' ;
    rdfs:domain ind:ProcurementMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Standard Lead Time Days' ;
    rdfs:comment 'Typical procurement lead time in days for items of this asset class when sourced through this procurement category. Used for materials planning and inventory reorder point calculations.' ;
    rdfs:domain ind:ProcurementMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetSamplingPointId rdf:type rdf:Property ;
    rdfs:label 'Asset Sampling Point Id' ;
    rdfs:comment 'Primary key for asset_sampling_point' ;
    rdfs:domain ind:AssetSamplingPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:configurationStatus rdf:type rdf:Property ;
    rdfs:label 'Configuration Status' ;
    rdfs:comment 'Current operational status of this asset-sampling point configuration. Active = in use; suspended = temporarily inactive; under_review = pending validation; decommissioned = permanently retired.' ;
    rdfs:domain ind:AssetSamplingPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastConfigurationReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Configuration Review Date' ;
    rdfs:comment 'Date when this asset-sampling point configuration was last reviewed and validated as part of monitoring plan audits or regulatory compliance reviews.' ;
    rdfs:domain ind:AssetSamplingPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipEndDate rdf:type rdf:Property ;
    rdfs:label 'Relationship End Date' ;
    rdfs:comment 'Date when this asset-sampling point configuration was deactivated (e.g., asset decommissioned, sampling point relocated, monitoring requirements changed). Null if currently active.' ;
    rdfs:domain ind:AssetSamplingPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipStartDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Start Date' ;
    rdfs:comment 'Date when this asset-sampling point configuration became active and sampling began for this specific asset at this location. Used to track historical changes in monitoring configurations.' ;
    rdfs:domain ind:AssetSamplingPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleCollectionResponsibility rdf:type rdf:Property ;
    rdfs:label 'Sample Collection Responsibility' ;
    rdfs:comment 'Identifies which team or entity is responsible for collecting samples at this asset-sampling point combination (may vary by asset even at the same sampling location based on access requirements or operational constraints).' ;
    rdfs:domain ind:AssetSamplingPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingAccessNotes rdf:type rdf:Property ;
    rdfs:label 'Sampling Access Notes' ;
    rdfs:comment 'Asset-specific access instructions, safety requirements, or logistical notes for sampling personnel collecting samples at this location for this particular asset (e.g., \'Requires confined space entry permit for tank interior sampling\', \'Access via north valve vault only\', \'Coordinate with operations for pump shutdown\').' ;
    rdfs:domain ind:AssetSamplingPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingPriorityRank rdf:type rdf:Property ;
    rdfs:label 'Sampling Priority Rank' ;
    rdfs:comment 'Priority ranking (1=highest) for this asset-sampling point combination used to sequence sampling activities when multiple assets are monitored at the same location. Based on asset criticality, regulatory requirements, and operational risk.' ;
    rdfs:domain ind:AssetSamplingPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grantFundingId rdf:type rdf:Property ;
    rdfs:label 'Grant Funding Id' ;
    rdfs:comment 'Unique identifier for this asset-grant funding relationship record. Primary key.' ;
    rdfs:domain ind:GrantFunding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amountReimbursed rdf:type rdf:Property ;
    rdfs:label 'Amount Reimbursed' ;
    rdfs:comment 'Cumulative dollar amount that has been reimbursed by the grantor for this asset under this grant. Used to calculate remaining funding balance.' ;
    rdfs:domain ind:GrantFunding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundingEndDate rdf:type rdf:Property ;
    rdfs:label 'Funding End Date' ;
    rdfs:comment 'Date on which funding for this asset under this grant ends, typically aligned with the grant\'s period of performance end date or asset completion date.' ;
    rdfs:domain ind:GrantFunding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fundingStartDate rdf:type rdf:Property ;
    rdfs:label 'Funding Start Date' ;
    rdfs:comment 'Date on which this asset became eligible for funding under this grant, typically aligned with the grant\'s period of performance start date or asset installation date.' ;
    rdfs:domain ind:GrantFunding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastDrawdownRequestDate rdf:type rdf:Property ;
    rdfs:label 'Last Drawdown Request Date' ;
    rdfs:comment 'Date of the most recent drawdown request submitted to the grantor for reimbursement of costs associated with this asset under this grant.' ;
    rdfs:domain ind:GrantFunding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceRequirementId rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirement Id' ;
    rdfs:comment 'Unique surrogate primary key for each asset-requirement compliance relationship record' ;
    rdfs:domain ind:ComplianceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceMethod rdf:type rdf:Property ;
    rdfs:label 'Compliance Method' ;
    rdfs:comment 'The specific method, control, or operational practice by which this asset achieves compliance with this requirement (e.g., \'continuous monitoring\', \'quarterly sampling\', \'treatment technique\', \'operational control\'). Varies by asset-requirement combination.' ;
    rdfs:domain ind:ComplianceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePerson rdf:type rdf:Property ;
    rdfs:label 'Responsible Person' ;
    rdfs:comment 'Name or identifier of the individual responsible for ensuring this specific asset maintains compliance with this specific requirement. May differ from the general requirement owner based on asset location or operational area.' ;
    rdfs:domain ind:ComplianceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Variance Expiry Date' ;
    rdfs:comment 'Expiration date of the granted variance or exemption for this asset-requirement pair. Null if no variance is granted or if variance is permanent.' ;
    rdfs:domain ind:ComplianceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:varianceGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Variance Granted Flag' ;
    rdfs:comment 'Indicates whether a regulatory variance, exemption, or waiver has been granted for this specific asset-requirement combination. True if variance is active, false otherwise.' ;
    rdfs:domain ind:ComplianceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:analystGrantAllocationId rdf:type rdf:Property ;
    rdfs:label 'Analyst Grant Allocation Id' ;
    rdfs:comment 'Primary key for the analyst_grant_allocation association' ;
    rdfs:domain ind:AnalystGrantAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Period End Date' ;
    rdfs:comment 'End date of the period during which this effort allocation is effective. Used to track historical allocations and support quarterly effort certification reporting.' ;
    rdfs:domain ind:AnalystGrantAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Period Start Date' ;
    rdfs:comment 'Start date of the period during which this effort allocation is effective. Typically aligns with grant quarters or fiscal periods for effort certification.' ;
    rdfs:domain ind:AnalystGrantAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effortCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Effort Certification Date' ;
    rdfs:comment 'Date on which the analyst or authorized representative certified the effort allocation for this grant period. Required for federal grant compliance.' ;
    rdfs:domain ind:AnalystGrantAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effortCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Effort Certification Status' ;
    rdfs:comment 'Status of the quarterly effort certification for this analyst-grant allocation. Federal grants require analysts to certify their effort quarterly.' ;
    rdfs:domain ind:AnalystGrantAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effortPercentage rdf:type rdf:Property ;
    rdfs:label 'Effort Percentage' ;
    rdfs:comment 'Percentage of the analyst\'s total work time allocated to this grant. Used for quarterly effort certification required by federal grants. Must sum to 100% or less across all grants for each analyst.' ;
    rdfs:domain ind:AnalystGrantAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grantAccountCode rdf:type rdf:Property ;
    rdfs:label 'Grant Account Code' ;
    rdfs:comment 'General ledger account code to which this analyst\'s labor costs are charged. Links the allocation to the utility\'s chart of accounts for grant accounting.' ;
    rdfs:domain ind:AnalystGrantAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantRole rdf:type rdf:Property ;
    rdfs:label 'Grant Role' ;
    rdfs:comment 'The specific role the analyst performs on this grant project. Required for federal grant reporting to distinguish between PI, co-investigators, and support staff.' ;
    rdfs:domain ind:AnalystGrantAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborCostAllocation rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Allocation' ;
    rdfs:comment 'Dollar amount of the analyst\'s labor costs charged to this grant during the allocation period. Calculated from effort percentage and analyst\'s salary/benefits. Used for grant drawdown requests and SEFA reporting.' ;
    rdfs:domain ind:AnalystGrantAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chemicalSupplyAgreementId rdf:type rdf:Property ;
    rdfs:label 'Chemical Supply Agreement Id' ;
    rdfs:comment 'Unique identifier for the chemical supply agreement record. Primary key.' ;
    rdfs:domain ind:ChemicalSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:treatmentChemicalId rdf:type rdf:Property ;
    rdfs:label 'Treatment Chemical Id' ;
    rdfs:comment 'Foreign key linking to the treatment chemical being sourced under this supply agreement' ;
    rdfs:domain ind:ChemicalSupplyAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Chemical .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'Minimum order quantity required by the vendor for this chemical, typically in gallons, pounds, or tons. Impacts procurement batch sizing and inventory holding costs.' ;
    rdfs:domain ind:ChemicalSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permitGrantAllocationId rdf:type rdf:Property ;
    rdfs:label 'Permit Grant Allocation Id' ;
    rdfs:comment 'Unique identifier for this permit-grant allocation record. Primary key.' ;
    rdfs:domain ind:PermitGrantAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:permitCompliancePermitId rdf:type rdf:Property ;
    rdfs:label 'Permit Compliance Permit Id' ;
    rdfs:comment 'Foreign key linking to the compliance permit being funded by the grant' ;
    rdfs:domain ind:PermitGrantAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompliancePermit .

ind:allocationNotes rdf:type rdf:Property ;
    rdfs:label 'Allocation Notes' ;
    rdfs:comment 'Free-text notes documenting special conditions, restrictions, or coordination requirements for this permit-grant allocation (e.g., matching fund requirements, specific grantor approval needed for certain activities).' ;
    rdfs:domain ind:PermitGrantAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amountExpendedToDate rdf:type rdf:Property ;
    rdfs:label 'Amount Expended To Date' ;
    rdfs:comment 'Cumulative dollar amount of the allocation that has been expended on permit compliance activities as of the current date. Used to track spending against the allocation_amount.' ;
    rdfs:domain ind:PermitGrantAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceMilestone rdf:type rdf:Property ;
    rdfs:label 'Compliance Milestone' ;
    rdfs:comment 'Key compliance milestones tied to this grant allocation, such as permit renewal dates, discharge limit achievement targets, or infrastructure completion deadlines required by the grant agreement.' ;
    rdfs:domain ind:PermitGrantAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drawdownSchedule rdf:type rdf:Property ;
    rdfs:label 'Drawdown Schedule' ;
    rdfs:comment 'Schedule or milestones for drawing down allocated grant funds for this permit, including quarterly targets, project phase gates, or compliance milestone triggers.' ;
    rdfs:domain ind:PermitGrantAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleActivities rdf:type rdf:Property ;
    rdfs:label 'Eligible Activities' ;
    rdfs:comment 'Description of the specific compliance activities and capital projects eligible for funding under this permit-grant allocation (e.g., NPDES discharge monitoring equipment, drinking water treatment upgrades, stormwater infrastructure).' ;
    rdfs:domain ind:PermitGrantAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountAssetResponsibilityId rdf:type rdf:Property ;
    rdfs:label 'Account Asset Responsibility Id' ;
    rdfs:comment 'Unique surrogate primary key for each account-asset responsibility record' ;
    rdfs:domain ind:AccountAssetResponsibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingResponsibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Billing Responsibility Flag' ;
    rdfs:comment 'Indicates whether this account receives bills for asset-related charges (true) or if another account is billed (false). In master-metered scenarios, the master account may be billed while sub-accounts have usage responsibility' ;
    rdfs:domain ind:AccountAssetResponsibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceResponsibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Maintenance Responsibility Flag' ;
    rdfs:comment 'Indicates whether this account is responsible for maintenance and repair of the asset (true) or if maintenance is handled by the utility (false). Critical for determining who responds to asset failures and who bears repair costs' ;
    rdfs:domain ind:AccountAssetResponsibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'Percentage of ownership or cost responsibility this account holds for the asset (0.00 to 100.00). Used for shared assets where multiple accounts split costs proportionally (e.g., HOA shared infrastructure, multi-tenant buildings)' ;
    rdfs:domain ind:AccountAssetResponsibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsibilityType rdf:type rdf:Property ;
    rdfs:label 'Responsibility Type' ;
    rdfs:comment 'Classification of the responsibility relationship: OWNER (full ownership), SHARED_OWNER (co-ownership with other accounts), MAINTENANCE_ONLY (maintenance responsibility without ownership), COST_ALLOCATION (cost sharing arrangement), MASTER_METER (master-metered multi-unit property)' ;
    rdfs:domain ind:AccountAssetResponsibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rotationPoolId rdf:type rdf:Property ;
    rdfs:label 'Rotation Pool Id' ;
    rdfs:comment 'Identifier for the sampling site rotation pool to which this customer-sampling point relationship belongs for LCRR compliance' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RotationPool .

ind:accessAuthorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Access Authorization Status' ;
    rdfs:comment 'Current status of the utility\'s authorization to access the customer premises for sampling purposes' ;
    rdfs:domain ind:SamplingSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerConsentDate rdf:type rdf:Property ;
    rdfs:label 'Customer Consent Date' ;
    rdfs:comment 'Date when the customer provided written consent to participate in the water quality sampling program at this location' ;
    rdfs:domain ind:SamplingSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredSamplingTime rdf:type rdf:Property ;
    rdfs:label 'Preferred Sampling Time' ;
    rdfs:comment 'Customer\'s preferred time window for sampling visits (e.g., weekday mornings, weekends only) to coordinate access' ;
    rdfs:domain ind:SamplingSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:siteActivationDate rdf:type rdf:Property ;
    rdfs:label 'Site Activation Date' ;
    rdfs:comment 'Date when this customer-sampling point relationship became active for regulatory monitoring purposes' ;
    rdfs:domain ind:SamplingSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteDeactivationDate rdf:type rdf:Property ;
    rdfs:label 'Site Deactivation Date' ;
    rdfs:comment 'Date when this customer-sampling point relationship was terminated due to customer withdrawal, property sale, or site rotation requirements' ;
    rdfs:domain ind:SamplingSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specialAccessInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Access Instructions' ;
    rdfs:comment 'Site-specific instructions for utility personnel to access the sampling location (gate codes, parking, entry procedures)' ;
    rdfs:domain ind:SamplingSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierClassification rdf:type rdf:Property ;
    rdfs:label 'Tier Classification' ;
    rdfs:comment 'Lead and Copper Rule Revisions tier classification for this customer tap site based on service line material and building plumbing risk factors' ;
    rdfs:domain ind:SamplingSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Grant Enrollment Id' ;
    rdfs:comment 'Unique identifier for this customer grant enrollment record. Primary key.' ;
    rdfs:domain ind:GrantEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benefitAmount rdf:type rdf:Property ;
    rdfs:label 'Benefit Amount' ;
    rdfs:comment 'Dollar amount of financial assistance provided to this customer account under this grant enrollment. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:GrantEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibilityPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Eligibility Period End' ;
    rdfs:comment 'End date of the period during which this customer account is eligible for benefits under this grant. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:GrantEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eligibilityPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Eligibility Period Start' ;
    rdfs:comment 'Start date of the period during which this customer account is eligible for benefits under this grant. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:GrantEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dmaCrewCoverageId rdf:type rdf:Property ;
    rdfs:label 'Dma Crew Coverage Id' ;
    rdfs:comment 'Unique identifier for this DMA-crew coverage assignment record. Primary key.' ;
    rdfs:domain ind:DmaCrewCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:afterHoursResponsibilityFlag rdf:type rdf:Property ;
    rdfs:label 'After Hours Responsibility Flag' ;
    rdfs:comment 'Indicates whether this crew has after-hours (night/weekend/holiday) emergency response responsibility for this DMA. Used for on-call scheduling and emergency dispatch routing.' ;
    rdfs:domain ind:DmaCrewCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assignmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Assignment End Date' ;
    rdfs:comment 'Date when this crew coverage assignment ended or is scheduled to end. Null for current active assignments. Supports crew rotation and reassignment tracking.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Date' ;
    rdfs:comment 'Date when this crew began coverage responsibility for this DMA. Used to track historical crew assignments and support crew rotation analysis.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageType rdf:type rdf:Property ;
    rdfs:label 'Coverage Type' ;
    rdfs:comment 'Classification of the coverage responsibility: routine (scheduled maintenance and monitoring), emergency (main break and leak response), after_hours (night/weekend coverage), on_call (standby), primary (first responder), backup (secondary responder). Determines dispatch priority and labor costing.' ;
    rdfs:domain ind:DmaCrewCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmaCrewCoverageStatus rdf:type rdf:Property ;
    rdfs:label 'Dma Crew Coverage Status' ;
    rdfs:comment 'Current operational status of this coverage assignment: active (currently in effect), inactive (ended), suspended (temporarily paused), seasonal (active only during specific periods). Used to filter current assignments for dispatch.' ;
    rdfs:domain ind:DmaCrewCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsePriority rdf:type rdf:Property ;
    rdfs:label 'Response Priority' ;
    rdfs:comment 'Numeric priority rank for this crew when multiple crews cover the same DMA (1=primary responder, 2=backup, etc.). Used by dispatch systems to route emergency work orders.' ;
    rdfs:domain ind:DmaCrewCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilityProjectId rdf:type rdf:Property ;
    rdfs:label 'Facility Project Id' ;
    rdfs:comment 'Unique identifier for this facility-project involvement record. Primary key for the association.' ;
    rdfs:domain ind:FacilityProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilityContactEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Facility Contact Employee Id' ;
    rdfs:comment 'Identifier of the facility operations staff member serving as primary contact for this project. Coordinates operational constraints, access, and commissioning activities.' ;
    rdfs:domain ind:FacilityProject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualCompletionDateAtFacility rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date At Facility' ;
    rdfs:comment 'Actual date project work was completed at this facility and turned over to operations. Null if work is ongoing.' ;
    rdfs:domain ind:FacilityProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualCostAtFacility rdf:type rdf:Property ;
    rdfs:label 'Actual Cost At Facility' ;
    rdfs:comment 'Actual project expenditures incurred for work at this facility. Cumulative from project start through current date.' ;
    rdfs:domain ind:FacilityProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStartDateAtFacility rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date At Facility' ;
    rdfs:comment 'Actual date project work commenced at this facility. Null if work has not yet started. Used for schedule variance tracking.' ;
    rdfs:domain ind:FacilityProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capacityImpactMgd rdf:type rdf:Property ;
    rdfs:label 'Capacity Impact Mgd' ;
    rdfs:comment 'Change in treatment capacity (million gallons per day) resulting from this project at this facility. Positive for capacity expansion, negative for temporary capacity reduction during construction.' ;
    rdfs:domain ind:FacilityProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:constructionImpactLevel rdf:type rdf:Property ;
    rdfs:label 'Construction Impact Level' ;
    rdfs:comment 'Severity of operational impact to the facility during construction. Critical impacts require detailed contingency planning and may affect treatment capacity or regulatory compliance.' ;
    rdfs:domain ind:FacilityProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCostAtFacility rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost At Facility' ;
    rdfs:comment 'Estimated project cost allocated to work at this specific facility. For multi-facility projects, enables cost tracking by site.' ;
    rdfs:domain ind:FacilityProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityAreaAffected rdf:type rdf:Property ;
    rdfs:label 'Facility Area Affected' ;
    rdfs:comment 'Specific functional area or process unit within the facility that is affected by this project. Enables facility operators to understand which treatment processes will be impacted and plan operational adjustments.' ;
    rdfs:domain ind:FacilityProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalStatusDuringConstruction rdf:type rdf:Property ;
    rdfs:label 'Operational Status During Construction' ;
    rdfs:comment 'Operating mode of the facility or affected area during project construction. Tracks whether the facility can maintain normal treatment operations or requires operational adjustments.' ;
    rdfs:domain ind:FacilityProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitModificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Permit Modification Required Flag' ;
    rdfs:comment 'Indicates whether this project requires modification of the facility\'s operating permit (NPDES, discharge permit, or air quality permit).' ;
    rdfs:domain ind:FacilityProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedCompletionDateAtFacility rdf:type rdf:Property ;
    rdfs:label 'Planned Completion Date At Facility' ;
    rdfs:comment 'Planned date for project work to be completed at this facility, including commissioning and operational turnover.' ;
    rdfs:domain ind:FacilityProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedStartDateAtFacility rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date At Facility' ;
    rdfs:comment 'Planned date for project work to commence at this specific facility. In phased multi-facility projects, each site has its own start date.' ;
    rdfs:domain ind:FacilityProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectPhaseAtFacility rdf:type rdf:Property ;
    rdfs:label 'Project Phase At Facility' ;
    rdfs:comment 'Current phase of the project work at this specific facility. In multi-facility projects, different sites may be at different phases (e.g., Site A in construction while Site B still in design).' ;
    rdfs:domain ind:FacilityProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectRole rdf:type rdf:Property ;
    rdfs:label 'Project Role' ;
    rdfs:comment 'Role of this facility within the overall project scope. For regional projects, distinguishes between primary implementation sites, pilot sites for testing, and future phase sites.' ;
    rdfs:domain ind:FacilityProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meterProcurementId rdf:type rdf:Property ;
    rdfs:label 'Meter Procurement Id' ;
    rdfs:comment 'Unique identifier for this meter-vendor procurement record. Primary key.' ;
    rdfs:domain ind:MeterProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:procurementStatus rdf:type rdf:Property ;
    rdfs:label 'Procurement Status' ;
    rdfs:comment 'Current status of this meter-vendor procurement relationship: Active (current source), Discontinued (no longer available), Preferred (primary supplier), Backup (secondary source), Under_Review (being evaluated).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offeringTerritoryAvailabilityId rdf:type rdf:Property ;
    rdfs:label 'Offering Territory Availability Id' ;
    rdfs:comment 'Unique identifier for this offering-territory availability record. Primary key.' ;
    rdfs:domain ind:OfferingTerritoryAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Availability Status' ;
    rdfs:comment 'Current operational status of this offering within this territory. Available = open for new enrollments; Suspended = temporarily unavailable due to capacity or regulatory issues; Pending_Approval = awaiting regulatory authorization; Discontinued = no longer offered; Restricted = available only to specific customer classes.' ;
    rdfs:domain ind:OfferingTerritoryAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityReservedMgd rdf:type rdf:Property ;
    rdfs:label 'Capacity Reserved Mgd' ;
    rdfs:comment 'Amount of system capacity in million gallons per day reserved or allocated for this offering within this territory. Used for capacity planning and to ensure infrastructure can support the offering\'s demand.' ;
    rdfs:domain ind:OfferingTerritoryAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:franchiseAuthorizationDate rdf:type rdf:Property ;
    rdfs:label 'Franchise Authorization Date' ;
    rdfs:comment 'Date when the regulatory authority or franchise agreement authorized the utility to provide this specific offering within this territory. Critical for regulatory compliance and audit trails.' ;
    rdfs:domain ind:OfferingTerritoryAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketingLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Marketing Launch Date' ;
    rdfs:comment 'Date when marketing and customer outreach for this offering began in this territory. May differ from effective_start_date due to phased rollout strategies.' ;
    rdfs:domain ind:OfferingTerritoryAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorityServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Service Flag' ;
    rdfs:comment 'Indicates whether this offering receives priority deployment or enhanced service levels in this territory, often due to regulatory mandates, environmental justice requirements, or infrastructure investment priorities.' ;
    rdfs:domain ind:OfferingTerritoryAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:territorySpecificRateAdjustment rdf:type rdf:Property ;
    rdfs:label 'Territory Specific Rate Adjustment' ;
    rdfs:comment 'Multiplier or adjustment factor applied to the offering\'s base rates for this specific territory. Used when regulatory authorities approve territory-specific rate variations due to infrastructure costs, population density, or other geographic factors. 1.0 = no adjustment.' ;
    rdfs:domain ind:OfferingTerritoryAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectStakeholderId rdf:type rdf:Property ;
    rdfs:label 'Project Stakeholder Id' ;
    rdfs:comment 'Unique system identifier for the project stakeholder engagement record. Primary key.' ;
    rdfs:domain ind:ProjectStakeholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:engagementEndDate rdf:type rdf:Property ;
    rdfs:label 'Engagement End Date' ;
    rdfs:comment 'Date when stakeholder engagement concluded, typically at project closeout or when the organization\'s involvement ended. Null for ongoing stakeholder relationships.' ;
    rdfs:domain ind:ProjectStakeholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engagementLevel rdf:type rdf:Property ;
    rdfs:label 'Engagement Level' ;
    rdfs:comment 'IAP2 spectrum classification of stakeholder engagement intensity: inform (one-way communication), consult (feedback solicited), involve (concerns directly reflected in decisions), collaborate (partnership in decision-making), empower (final decision authority delegated). Explicitly identified in detection phase.' ;
    rdfs:domain ind:ProjectStakeholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementStartDate rdf:type rdf:Property ;
    rdfs:label 'Engagement Start Date' ;
    rdfs:comment 'Date when the organization was formally identified as a stakeholder and engagement activities commenced. Used for tracking engagement timeline and compliance with notification requirements.' ;
    rdfs:domain ind:ProjectStakeholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastEngagementDate rdf:type rdf:Property ;
    rdfs:label 'Last Engagement Date' ;
    rdfs:comment 'Date of the most recent engagement activity with this stakeholder (meeting, notification, consultation). Used for tracking engagement frequency and compliance.' ;
    rdfs:domain ind:ProjectStakeholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mitigationAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Mitigation Agreement Reference' ;
    rdfs:comment 'Reference number or identifier for formal mitigation agreements, MOUs, or impact compensation arrangements between the utility and the stakeholder organization. Null if no formal agreement exists. Explicitly identified in detection phase.' ;
    rdfs:domain ind:ProjectStakeholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextEngagementDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Engagement Due Date' ;
    rdfs:comment 'Scheduled date for the next required engagement activity with this stakeholder. Used for proactive stakeholder management and compliance with engagement commitments.' ;
    rdfs:domain ind:ProjectStakeholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Required Flag' ;
    rdfs:comment 'Indicates whether the organization must receive formal project notifications (construction schedules, service interruptions, public meetings) per regulatory requirements or stakeholder agreements. Explicitly identified in detection phase.' ;
    rdfs:domain ind:ProjectStakeholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stakeholderRole rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Role' ;
    rdfs:comment 'Classification of the organization\'s role in the project: affected_party (impacted by construction or service changes), contributor (providing resources or expertise), permitting_authority (regulatory approval required), funding_partner (co-funding the project), community_representative (HOA or business district), regulatory_oversight (compliance monitoring). Explicitly identified in detection phase.' ;
    rdfs:domain ind:ProjectStakeholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stakeholderStatus rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Status' ;
    rdfs:comment 'Current status of the stakeholder relationship: active (ongoing engagement), satisfied (no concerns), concerns_raised (issues identified), escalated (formal complaint or dispute), disengaged (non-responsive), closed (engagement concluded).' ;
    rdfs:domain ind:ProjectStakeholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipeProcurementId rdf:type rdf:Property ;
    rdfs:label 'Pipe Procurement Id' ;
    rdfs:comment 'Unique identifier for this pipe procurement line item record. Primary key.' ;
    rdfs:domain ind:PipeProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'The actual date the pipe material was delivered to the job site or utility warehouse. Used for vendor performance measurement and project schedule variance analysis.' ;
    rdfs:domain ind:PipeProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractLineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Line Item Number' ;
    rdfs:comment 'The specific line item number within the procurement contract that covers this pipe main procurement. Allows traceability to contract terms, pricing schedules, and delivery conditions specific to this material specification.' ;
    rdfs:domain ind:PipeProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverySchedule rdf:type rdf:Property ;
    rdfs:label 'Delivery Schedule' ;
    rdfs:comment 'The scheduled delivery date for this pipe main material as coordinated between procurement and the construction project schedule. Used for project planning and vendor performance tracking.' ;
    rdfs:domain ind:PipeProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:installationSpecification rdf:type rdf:Property ;
    rdfs:label 'Installation Specification' ;
    rdfs:comment 'Reference to the technical specification or standard that governs the installation of this pipe main under the contract terms. May reference AWWA standards, utility-specific installation procedures, or project-specific engineering drawings. Ensures contract compliance and warranty validity.' ;
    rdfs:domain ind:PipeProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Material Certification Number' ;
    rdfs:comment 'The manufacturer\'s material certification or mill test report number for this specific pipe main batch. Required for quality assurance, regulatory compliance, and warranty claims. Links physical asset to material traceability documentation.' ;
    rdfs:domain ind:PipeProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAllocated rdf:type rdf:Property ;
    rdfs:label 'Quantity Allocated' ;
    rdfs:comment 'The quantity of pipe material allocated from the contract for this specific pipe main installation, typically measured in linear feet or number of pipe segments. Used for contract consumption tracking and remaining balance calculation.' ;
    rdfs:domain ind:PipeProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLineValue rdf:type rdf:Property ;
    rdfs:label 'Total Line Value' ;
    rdfs:comment 'The total monetary value of this procurement line item (quantity_allocated × unit_price). Used for contract consumption tracking, budget management, and asset capitalization.' ;
    rdfs:domain ind:PipeProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zoneOperatorAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Zone Operator Assignment Id' ;
    rdfs:comment 'Unique identifier for each pressure zone operator assignment record. Primary key.' ;
    rdfs:domain ind:ZoneOperatorAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationLevelRequired rdf:type rdf:Property ;
    rdfs:label 'Certification Level Required' ;
    rdfs:comment 'Minimum operator certification grade or class required for this zone assignment per state regulatory requirements. Varies by zone complexity, population served, and treatment processes.' ;
    rdfs:domain ind:ZoneOperatorAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCoverageDate rdf:type rdf:Property ;
    rdfs:label 'Last Coverage Date' ;
    rdfs:comment 'Most recent date when this operator provided coverage for this pressure zone. Used for rotation balancing and workload distribution analysis.' ;
    rdfs:domain ind:ZoneOperatorAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onCallRotationFlag rdf:type rdf:Property ;
    rdfs:label 'On Call Rotation Flag' ;
    rdfs:comment 'Indicates whether this operator is part of the on-call rotation schedule for this pressure zone. True for operators in rotation, false for fixed assignments.' ;
    rdfs:domain ind:ZoneOperatorAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatorRole rdf:type rdf:Property ;
    rdfs:label 'Operator Role' ;
    rdfs:comment 'Role of the operator for this specific pressure zone assignment. Defines responsibility level and coverage type (Primary, Backup, On-Call, Relief).' ;
    rdfs:domain ind:ZoneOperatorAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryBackupFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Backup Flag' ;
    rdfs:comment 'Indicates whether this operator serves as the primary backup for this pressure zone. True for designated primary backup, false otherwise.' ;
    rdfs:domain ind:ZoneOperatorAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rotationSequence rdf:type rdf:Property ;
    rdfs:label 'Rotation Sequence' ;
    rdfs:comment 'Sequence number for on-call rotation scheduling. Defines the order in which operators are called for this pressure zone. Nullable for non-rotation assignments.' ;
    rdfs:domain ind:ZoneOperatorAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatorQualificationId rdf:type rdf:Property ;
    rdfs:label 'Operator Qualification Id' ;
    rdfs:comment 'Unique identifier for this operator qualification record. Primary key for the association.' ;
    rdfs:domain ind:OperatorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certifyingSupervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Certifying Supervisor Employee Id' ;
    rdfs:comment 'Employee ID of the supervisor or lead operator who certified this qualification. Used for audit trail and accountability in the qualification process.' ;
    rdfs:domain ind:OperatorQualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:authorizationExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Expiration Date' ;
    rdfs:comment 'Date when the operator authorization expires for this process unit. Requires recertification assessment before this date to maintain qualification status. Critical for regulatory compliance.' ;
    rdfs:domain ind:OperatorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:competencyLevel rdf:type rdf:Property ;
    rdfs:label 'Competency Level' ;
    rdfs:comment 'Assessed competency level of the operator for this process unit. Trainee for operators in training under supervision, Qualified for independent operation, Advanced for complex troubleshooting, Lead for shift leadership, Instructor for training others.' ;
    rdfs:domain ind:OperatorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTrainingDate rdf:type rdf:Property ;
    rdfs:label 'Last Training Date' ;
    rdfs:comment 'Date of the most recent training session completed for this process unit. Used for tracking continuing education requirements and recertification scheduling.' ;
    rdfs:domain ind:OperatorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryOperatorFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Operator Flag' ;
    rdfs:comment 'Indicates whether this operator is designated as the primary operator for this process unit. Used for shift scheduling and responsibility assignment. True for primary operator, false for backup qualified operators.' ;
    rdfs:domain ind:OperatorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processMaintenancePlanId rdf:type rdf:Property ;
    rdfs:label 'Process Maintenance Plan Id' ;
    rdfs:comment 'Unique identifier for this process unit-job plan maintenance configuration record. Primary key.' ;
    rdfs:domain ind:ProcessMaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyOverride rdf:type rdf:Property ;
    rdfs:label 'Frequency Override' ;
    rdfs:comment 'Process-specific maintenance frequency that overrides the default frequency_code from the job plan. Allows customization based on process unit operating conditions, flow rates, or regulatory requirements specific to this unit.' ;
    rdfs:domain ind:ProcessMaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processMaintenancePlanStatus rdf:type rdf:Property ;
    rdfs:label 'Process Maintenance Plan Status' ;
    rdfs:comment 'Current status of this process unit-job plan maintenance configuration. Only ACTIVE plans generate scheduled work orders.' ;
    rdfs:domain ind:ProcessMaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processSpecificSteps rdf:type rdf:Property ;
    rdfs:label 'Process Specific Steps' ;
    rdfs:comment 'Additional or modified task instructions specific to this process unit that supplement the standard job plan task_sequence. Captures unit-specific SCADA tag references, valve numbers, sensor IDs, or equipment configurations.' ;
    rdfs:domain ind:ProcessMaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processComplianceMonitoringId rdf:type rdf:Property ;
    rdfs:label 'Process Compliance Monitoring Id' ;
    rdfs:comment 'Unique identifier for this process-condition compliance monitoring record. Primary key.' ;
    rdfs:domain ind:ProcessComplianceMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastExceedanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Exceedance Date' ;
    rdfs:comment 'Date of the most recent permit limit exceedance for this process-condition combination. Null if no exceedances have occurred. This attribute was explicitly identified in the detection phase.' ;
    rdfs:domain ind:ProcessComplianceMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sewerRepairId rdf:type rdf:Property ;
    rdfs:label 'Sewer Repair Id' ;
    rdfs:comment 'Unique identifier for this sewer segment repair record. Primary key.' ;
    rdfs:domain ind:SewerRepair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectCodesAddressed rdf:type rdf:Property ;
    rdfs:label 'Defect Codes Addressed' ;
    rdfs:comment 'Comma-separated list of NASSCO PACP defect codes that this repair addressed for this segment (e.g., \'CL-Crack Longitudinal, DL-Deformed\', \'RB-Roots at Joint\'). Links repair activity to specific observed defects from CCTV inspection.' ;
    rdfs:domain ind:SewerRepair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postRepairConditionGrade rdf:type rdf:Property ;
    rdfs:label 'Post Repair Condition Grade' ;
    rdfs:comment 'The condition assessment grade of the sewer segment after this repair work was completed. Captured from post-repair CCTV inspection. Used to validate repair effectiveness and reset asset condition for predictive maintenance models.' ;
    rdfs:domain ind:SewerRepair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preRepairConditionGrade rdf:type rdf:Property ;
    rdfs:label 'Pre Repair Condition Grade' ;
    rdfs:comment 'The condition assessment grade of the sewer segment immediately before this repair work was performed. Captured from CCTV inspection. Used to track condition improvement and validate repair effectiveness. Follows NASSCO PACP grading (Grade 1=Excellent to Grade 5=Imminent Failure).' ;
    rdfs:domain ind:SewerRepair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repairCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Repair Completion Date' ;
    rdfs:comment 'The date when repair work on this specific sewer segment was completed. May differ from the overall work order completion date if the work order addressed multiple segments sequentially. Used for segment-specific maintenance history and warranty tracking.' ;
    rdfs:domain ind:SewerRepair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:repairCostAllocationPercent rdf:type rdf:Property ;
    rdfs:label 'Repair Cost Allocation Percent' ;
    rdfs:comment 'The percentage of the total work order cost allocated to this specific sewer segment. Used when a single work order addresses multiple segments (e.g., CIPP lining across 5 pipe runs). Enables accurate per-segment cost tracking for asset valuation and rate case justification. Sum across all segments for a work order should equal 100%.' ;
    rdfs:domain ind:SewerRepair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repairEndStation rdf:type rdf:Property ;
    rdfs:label 'Repair End Station' ;
    rdfs:comment 'The ending station or offset in feet from the upstream end of the sewer segment where repair work concluded. Used with repair_start_station to define the precise spatial extent of the repair within the segment.' ;
    rdfs:domain ind:SewerRepair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repairSegmentLengthFeet rdf:type rdf:Property ;
    rdfs:label 'Repair Segment Length Feet' ;
    rdfs:comment 'The length in feet of the sewer segment portion addressed by this work order. May be less than the full segment length if only a section was repaired. Critical for cost-per-foot analysis and partial segment rehabilitation tracking.' ;
    rdfs:domain ind:SewerRepair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repairStartStation rdf:type rdf:Property ;
    rdfs:label 'Repair Start Station' ;
    rdfs:comment 'The starting station or offset in feet from the upstream end of the sewer segment where repair work began. Used for partial segment repairs to precisely locate the repair extent within the segment. Supports spatial analysis and future work planning.' ;
    rdfs:domain ind:SewerRepair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permitComplianceObligationId rdf:type rdf:Property ;
    rdfs:label 'Permit Compliance Obligation Id' ;
    rdfs:comment 'Unique surrogate identifier for this permit-requirement compliance obligation record' ;
    rdfs:domain ind:PermitComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:permitTreatmentPermitId rdf:type rdf:Property ;
    rdfs:label 'Permit Treatment Permit Id' ;
    rdfs:comment 'Foreign key linking to the treatment permit that must comply with the regulatory requirement' ;
    rdfs:domain ind:PermitComplianceObligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TreatmentPermit .

ind:waiverExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Expiration Date' ;
    rdfs:comment 'The date on which any granted waiver expires and full compliance is required. Null if no waiver granted or waiver is permanent.' ;
    rdfs:domain ind:PermitComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverGranted rdf:type rdf:Property ;
    rdfs:label 'Waiver Granted' ;
    rdfs:comment 'Indicates whether a regulatory waiver or exemption has been granted for this specific requirement on this specific permit.' ;
    rdfs:domain ind:PermitComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:projectVendorEngagementId rdf:type rdf:Property ;
    rdfs:label 'Project Vendor Engagement Id' ;
    rdfs:comment 'Unique identifier for this project-vendor engagement record. Primary key.' ;
    rdfs:domain ind:ProjectVendorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualAmountPaid rdf:type rdf:Property ;
    rdfs:label 'Actual Amount Paid' ;
    rdfs:comment 'Cumulative actual payments made to this vendor for work on this project. Used to track contract spend against awarded value.' ;
    rdfs:domain ind:ProjectVendorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractAwardDate rdf:type rdf:Property ;
    rdfs:label 'Contract Award Date' ;
    rdfs:comment 'Date the construction contract was awarded to the general contractor. Marks the formal start of the construction procurement phase. [Moved from cip_project: This attribute on the CIP project appears to reference a single contract award date, but projects have multiple contracts with different vendors awarded at different times. Each vendor engagement has its own contract_start_date. This project-level attribute is ambiguous when multiple vendors are involved.]' ;
    rdfs:domain ind:ProjectVendorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractValue rdf:type rdf:Property ;
    rdfs:label 'Contract Value' ;
    rdfs:comment 'The total awarded contract value for this vendor\'s engagement on this project. Identified in detection reasoning as relationship data. Represents the financial commitment for this specific vendor-project combination.' ;
    rdfs:domain ind:ProjectVendorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designFirmName rdf:type rdf:Property ;
    rdfs:label 'Design Firm Name' ;
    rdfs:comment 'Name of the engineering or architectural firm contracted to provide design services for the project. Null if design is performed in-house. [Moved from cip_project: This attribute currently stores a single design firm name on the CIP project, but in reality multiple vendors can serve in design roles (architectural, civil, electrical, environmental). This should be captured as vendor engagements with role_type=\'design_engineer\' rather than a single text field on the project.]' ;
    rdfs:domain ind:ProjectVendorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generalContractorName rdf:type rdf:Property ;
    rdfs:label 'General Contractor Name' ;
    rdfs:comment 'Name of the general contractor or construction manager awarded the construction contract. Null if project has not reached construction phase or is performed by utility forces. [Moved from cip_project: This attribute currently stores a single general contractor name on the CIP project, but this is actually a vendor engagement relationship. The general contractor is a vendor with role_type=\'general_contractor\'. Storing the name redundantly on the project creates data integrity issues when the same information exists in the vendor master.]' ;
    rdfs:domain ind:ProjectVendorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Verified Flag' ;
    rdfs:comment 'Indicates whether required insurance certificates (general liability, workers comp, professional liability) have been verified for this vendor on this project.' ;
    rdfs:domain ind:ProjectVendorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Last Updated By' ;
    rdfs:comment 'User ID or name of the person who last updated this engagement record.' ;
    rdfs:domain ind:ProjectVendorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleType rdf:type rdf:Property ;
    rdfs:label 'Role Type' ;
    rdfs:comment 'The specific role this vendor plays in the CIP project. Identified in detection reasoning as relationship data. Examples: general_contractor, design_engineer, specialty_subcontractor, materials_supplier, testing_lab, environmental_consultant.' ;
    rdfs:domain ind:ProjectVendorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityVendorContractId rdf:type rdf:Property ;
    rdfs:label 'Facility Vendor Contract Id' ;
    rdfs:comment 'Unique identifier for this facility-vendor contract relationship. Primary key.' ;
    rdfs:domain ind:FacilityVendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualContractValue rdf:type rdf:Property ;
    rdfs:label 'Annual Contract Value' ;
    rdfs:comment 'Estimated or committed annual spend for this vendor at this specific facility under this contract.' ;
    rdfs:domain ind:FacilityVendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emergencyContactAvailable rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Available' ;
    rdfs:comment 'Indicates whether this vendor provides 24/7 emergency response services to this facility under this contract.' ;
    rdfs:domain ind:FacilityVendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:updatedDate rdf:type rdf:Property ;
    rdfs:label 'Updated Date' ;
    rdfs:comment 'Timestamp when this facility-vendor contract record was last modified.' ;
    rdfs:domain ind:FacilityVendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:analystTrainingCompletionId rdf:type rdf:Property ;
    rdfs:label 'Analyst Training Completion Id' ;
    rdfs:comment 'Unique identifier for this analyst training completion record. Primary key.' ;
    rdfs:domain ind:AnalystTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentScore rdf:type rdf:Property ;
    rdfs:label 'Assessment Score' ;
    rdfs:comment 'Percentage score achieved by the analyst on the training course assessment or exam. Null if no assessment was required.' ;
    rdfs:domain ind:AnalystTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attendanceHours rdf:type rdf:Property ;
    rdfs:label 'Attendance Hours' ;
    rdfs:comment 'Actual number of hours the analyst attended or participated in the training. May differ from the course duration if partial attendance occurred.' ;
    rdfs:domain ind:AnalystTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCharged rdf:type rdf:Property ;
    rdfs:label 'Cost Charged' ;
    rdfs:comment 'Actual cost in US dollars charged for this analyst\'s enrollment in this training course offering. May differ from standard cost due to discounts or group rates.' ;
    rdfs:domain ind:AnalystTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passFailStatus rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Status' ;
    rdfs:comment 'Status indicating whether the analyst passed, failed, or is still in progress with the training course.' ;
    rdfs:domain ind:AnalystTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Date' ;
    rdfs:comment 'Date when this crew was assigned to work on this compliance obligation. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:crewRole rdf:type rdf:Property ;
    rdfs:label 'Crew Role' ;
    rdfs:comment 'Role of this crew in fulfilling the compliance obligation: primary (main crew responsible), support (assisting crew), specialist (crew with specific certification required), backup (standby crew), emergency_response (crew responding to compliance-related emergency). Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Hours' ;
    rdfs:comment 'Estimated number of labor hours for this specific crew to complete their portion of the compliance obligation. Explicitly identified in detection phase relationship data. Differs from compliance_obligation.estimated_effort_hours which is total across all crews.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workOrderReference rdf:type rdf:Property ;
    rdfs:label 'Work Order Reference' ;
    rdfs:comment 'Reference to the work order number in Microsoft Dynamics 365 Field Service or IBM Maximo CMMS that tracks this crew\'s work on this compliance obligation. Links compliance tracking to operational work management.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programMaterialEligibilityId rdf:type rdf:Property ;
    rdfs:label 'Program Material Eligibility Id' ;
    rdfs:comment 'Unique identifier for this program-material eligibility record. Primary key.' ;
    rdfs:domain ind:ProgramMaterialEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eligibilityEndDate rdf:type rdf:Property ;
    rdfs:label 'Eligibility End Date' ;
    rdfs:comment 'Date when rebates for this material under this program expire. May differ from program end date if materials are phased out early.' ;
    rdfs:domain ind:ProgramMaterialEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eligibilityStartDate rdf:type rdf:Property ;
    rdfs:label 'Eligibility Start Date' ;
    rdfs:comment 'Date when rebates for this material under this program become effective. May differ from program start date if materials are added mid-program.' ;
    rdfs:domain ind:ProgramMaterialEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eligibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Eligibility Status' ;
    rdfs:comment 'Current status of this material\'s eligibility under this program: Active (accepting claims), Suspended (temporarily unavailable), Expired (no longer eligible), Pending (awaiting approval).' ;
    rdfs:domain ind:ProgramMaterialEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleQuantityLimit rdf:type rdf:Property ;
    rdfs:label 'Eligible Quantity Limit' ;
    rdfs:comment 'Maximum number of units of this material that a customer can claim rebates for under this program (e.g., max 2 high-efficiency toilets per household).' ;
    rdfs:domain ind:ProgramMaterialEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumEfficiencyRating rdf:type rdf:Property ;
    rdfs:label 'Minimum Efficiency Rating' ;
    rdfs:comment 'Required efficiency certification or rating for this material to qualify (e.g., WaterSense certified, EPA WaterSense, ENERGY STAR). Specific to this program-material combination.' ;
    rdfs:domain ind:ProgramMaterialEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Program Enrollment Date' ;
    rdfs:comment 'Date when this material became available for customer enrollment and rebate claims under this program.' ;
    rdfs:domain ind:ProgramMaterialEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rebateAmount rdf:type rdf:Property ;
    rdfs:label 'Rebate Amount' ;
    rdfs:comment 'Specific rebate or incentive amount offered for this material under this program. May differ from the program\'s default incentive_amount based on material type or efficiency rating.' ;
    rdfs:domain ind:ProgramMaterialEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRebateAmountPaid rdf:type rdf:Property ;
    rdfs:label 'Total Rebate Amount Paid' ;
    rdfs:comment 'Cumulative dollar amount paid in rebates for this material under this program. Used for budget tracking against program allocation.' ;
    rdfs:domain ind:ProgramMaterialEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRebatesIssued rdf:type rdf:Property ;
    rdfs:label 'Total Rebates Issued' ;
    rdfs:comment 'Cumulative count of rebates issued for this material under this program to date. Used for budget tracking and program evaluation.' ;
    rdfs:domain ind:ProgramMaterialEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityCorrectiveActionId rdf:type rdf:Property ;
    rdfs:label 'Quality Corrective Action Id' ;
    rdfs:comment 'Primary key for corrective_action' ;
    rdfs:domain ind:QualityCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:laborRelationsCaseId rdf:type rdf:Property ;
    rdfs:label 'Labor Relations Case Id' ;
    rdfs:comment 'Primary key for labor_relations_case' ;
    rdfs:domain ind:LaborRelationsCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableAssetCategory rdf:type rdf:Property ;
    rdfs:label 'Applicable Asset Category' ;
    rdfs:comment 'Asset category for which this checklist is intended.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:author rdf:type rdf:Property ;
    rdfs:label 'Author' ;
    rdfs:comment 'Name of the person who authored the checklist.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistType rdf:type rdf:Property ;
    rdfs:label 'Checklist Type' ;
    rdfs:comment 'Category of the checklist indicating its primary focus.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:description rdf:type rdf:Property ;
    rdfs:label 'Description' ;
    rdfs:comment 'Detailed description of the purpose and scope of the checklist.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'Date from which the checklist becomes valid.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'Date after which the checklist is no longer valid (nullable).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Minutes' ;
    rdfs:comment 'Estimated time required to complete the checklist, in minutes.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastUsedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Used Timestamp' ;
    rdfs:comment 'Date and time when the checklist was last applied to an inspection.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:name rdf:type rdf:Property ;
    rdfs:label 'Name' ;
    rdfs:comment 'Descriptive name of the checklist used to identify it in the system.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfItems rdf:type rdf:Property ;
    rdfs:label 'Number Of Items' ;
    rdfs:comment 'Total count of individual inspection items in the checklist.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulationReference rdf:type rdf:Property ;
    rdfs:label 'Regulation Reference' ;
    rdfs:comment 'Identifier of the regulation that mandates this checklist.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredByRegulation rdf:type rdf:Property ;
    rdfs:label 'Required By Regulation' ;
    rdfs:comment 'Indicates whether the checklist is mandated by regulation.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewer rdf:type rdf:Property ;
    rdfs:label 'Reviewer' ;
    rdfs:comment 'Name of the person who reviewed and approved the checklist.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:status rdf:type rdf:Property ;
    rdfs:label 'Status' ;
    rdfs:comment 'Current lifecycle status of the checklist.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumptionMax rdf:type rdf:Property ;
    rdfs:label 'Consumption Max' ;
    rdfs:comment 'Upper bound of consumption for which this tier applies; null for no upper limit.' ;
    rdfs:domain ind:RateTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumptionMin rdf:type rdf:Property ;
    rdfs:label 'Consumption Min' ;
    rdfs:comment 'Lower bound of consumption (in unit_of_measure) for which this tier applies.' ;
    rdfs:domain ind:RateTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fixedCharge rdf:type rdf:Property ;
    rdfs:label 'Fixed Charge' ;
    rdfs:comment 'Flat fee applied for this tier regardless of consumption.' ;
    rdfs:domain ind:RateTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratePerUnit rdf:type rdf:Property ;
    rdfs:label 'Rate Per Unit' ;
    rdfs:comment 'Price charged per unit of consumption within this tier (currency per unit).' ;
    rdfs:domain ind:RateTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Surcharge Amount' ;
    rdfs:comment 'Amount of surcharge applied when surcharge_applicable is true.' ;
    rdfs:domain ind:RateTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surchargeApplicable rdf:type rdf:Property ;
    rdfs:label 'Surcharge Applicable' ;
    rdfs:comment 'Indicates whether a surcharge is applied to this tier.' ;
    rdfs:domain ind:RateTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxRate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate' ;
    rdfs:comment 'Applicable tax rate percentage for the tier when not tax-exempt.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierCode rdf:type rdf:Property ;
    rdfs:label 'Tier Code' ;
    rdfs:comment 'Short alphanumeric code used to identify the tier in billing systems.' ;
    rdfs:domain ind:RateTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierName rdf:type rdf:Property ;
    rdfs:label 'Tier Name' ;
    rdfs:comment 'Human-readable name of the rate tier (e.g., "Residential Tier 1").' ;
    rdfs:domain ind:RateTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierType rdf:type rdf:Property ;
    rdfs:label 'Tier Type' ;
    rdfs:comment 'Category of customers or service that the tier applies to.' ;
    rdfs:domain ind:RateTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variableCharge rdf:type rdf:Property ;
    rdfs:label 'Variable Charge' ;
    rdfs:comment 'Additional variable component (e.g., service fee) applied per billing period.' ;
    rdfs:domain ind:RateTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountId rdf:type rdf:Property ;
    rdfs:label 'Account Id' ;
    rdfs:comment 'Identifier of the utility account associated with the delinquent balance.' ;
    rdfs:domain ind:DelinquencyNotice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingAccount .

ind:amountDue rdf:type rdf:Property ;
    rdfs:label 'Amount Due' ;
    rdfs:comment 'Original delinquent balance before penalties or adjustments.' ;
    rdfs:domain ind:DelinquencyNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionAgencyFlag rdf:type rdf:Property ;
    rdfs:label 'Collection Agency Flag' ;
    rdfs:comment 'True if the delinquent account has been forwarded to a third-party collection agency.' ;
    rdfs:domain ind:DelinquencyNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:generatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Generated Timestamp' ;
    rdfs:comment 'Exact date-time when the notice was created in the system.' ;
    rdfs:domain ind:DelinquencyNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:legalActionDate rdf:type rdf:Property ;
    rdfs:label 'Legal Action Date' ;
    rdfs:comment 'Date on which legal action was formally started against the customer.' ;
    rdfs:domain ind:DelinquencyNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalActionFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Action Flag' ;
    rdfs:comment 'Indicates whether legal proceedings have been initiated for the delinquent balance.' ;
    rdfs:domain ind:DelinquencyNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noticeLastSentDate rdf:type rdf:Property ;
    rdfs:label 'Notice Last Sent Date' ;
    rdfs:comment 'Date of the most recent re-send of the notice after the initial send.' ;
    rdfs:domain ind:DelinquencyNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:noticeNumber rdf:type rdf:Property ;
    rdfs:label 'Notice Number' ;
    rdfs:comment 'External reference number assigned to the notice for customer communication and tracking.' ;
    rdfs:domain ind:DelinquencyNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeType rdf:type rdf:Property ;
    rdfs:label 'Notice Type' ;
    rdfs:comment 'Category of the notice indicating its purpose and severity.' ;
    rdfs:domain ind:DelinquencyNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDue rdf:type rdf:Property ;
    rdfs:label 'Total Due' ;
    rdfs:comment 'Sum of principal and penalties representing the amount the customer must pay.' ;
    rdfs:domain ind:DelinquencyNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:areaSqft rdf:type rdf:Property ;
    rdfs:label 'Area Sqft' ;
    rdfs:comment 'Total land area of the parcel in square feet.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cadastralReference rdf:type rdf:Property ;
    rdfs:label 'Cadastral Reference' ;
    rdfs:comment 'Official cadastral registry identifier for the parcel.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geometryWkt rdf:type rdf:Property ;
    rdfs:label 'Geometry Wkt' ;
    rdfs:comment 'Well-Known Text representation of the parcel\'s spatial geometry.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHistorical rdf:type rdf:Property ;
    rdfs:label 'Is Historical' ;
    rdfs:comment 'Indicates whether the record represents a historical (true) or current (false) parcel.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:landUseDescription rdf:type rdf:Property ;
    rdfs:label 'Land Use Description' ;
    rdfs:comment 'Narrative description of the parcel\'s land use.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Owner Contact Phone' ;
