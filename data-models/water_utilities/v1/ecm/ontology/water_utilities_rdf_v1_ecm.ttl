# --- Attribute Properties ---
ind:acquisitionId rdf:type rdf:Property ;
    rdfs:label 'Acquisition Id' ;
    rdfs:comment 'Unique identifier for the asset acquisition record. Primary key for the asset acquisition data product.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetRegistryId rdf:type rdf:Property ;
    rdfs:label 'Asset Registry Id' ;
    rdfs:comment 'Reference to the asset being acquired in the asset registry. Links this acquisition to the corresponding asset_registry record.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Registry .

ind:cipProjectId rdf:type rdf:Property ;
    rdfs:label 'Cip Project Id' ;
    rdfs:comment 'Capital Improvement Program project identifier if the asset was acquired as part of a capital project. Links to project management and budget tracking.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CipProject .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Acquisitions are charged to departmental cost centers for capital budget tracking, CIP program management, and accountability. Supports budget-to-actual variance reporting for capital projects.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:facilityId rdf:type rdf:Property ;
    rdfs:label 'Facility Id' ;
    rdfs:comment 'Identifier for the Water Treatment Plant (WTP), Wastewater Treatment Plant (WWTP), pump station, or other facility where the asset is located.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:generalLedgerId rdf:type rdf:Property ;
    rdfs:label 'General Ledger Id' ;
    rdfs:comment 'Foreign key linking to finance.general_ledger. Business justification: Capital asset acquisitions post to specific GL accounts for capitalization, depreciation tracking, and GASB 34 infrastructure reporting. Critical for financial statement preparation and regulatory com' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeneralLedger .

ind:registryId rdf:type rdf:Property ;
    rdfs:label 'Registry Id' ;
    rdfs:comment 'Reference to the asset being acquired in the asset registry. Links this acquisition to the corresponding asset_registry record.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Registry .

ind:vendorId rdf:type rdf:Property ;
    rdfs:label 'Vendor Id' ;
    rdfs:comment 'Unique identifier for the vendor in the procurement or Enterprise Resource Planning (ERP) system.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'Date on which the asset was legally acquired or title transferred to the utility. Used for depreciation start date calculation and asset lifecycle tracking.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acquisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Acquisition Status' ;
    rdfs:comment 'Current status of the acquisition record in the workflow. Tracks progression from initiation through completion and asset registry creation.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionType rdf:type rdf:Property ;
    rdfs:label 'Acquisition Type' ;
    rdfs:comment 'Method by which the asset was acquired into the utility\'s asset base. Determines accounting treatment and capitalization rules.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date on which the asset acquisition was formally approved by the designated authority. Part of the audit trail.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or identifier of the manager or authority who approved the asset acquisition. Required for audit trail and governance.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetCategory rdf:type rdf:Property ;
    rdfs:label 'Asset Category' ;
    rdfs:comment 'Detailed categorization within the asset class such as pump, valve, pipe, tank, or vehicle. Supports asset hierarchy and reporting.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetClass rdf:type rdf:Property ;
    rdfs:label 'Asset Class' ;
    rdfs:comment 'High-level classification of the asset type such as treatment equipment, distribution infrastructure, collection system, or vehicle. Used for depreciation schedule assignment.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Capitalization Threshold Amount' ;
    rdfs:comment 'Minimum dollar amount threshold for capitalizing an asset as defined by the utility\'s accounting policy. Typically ranges from $1,000 to $5,000 for water utilities.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalizationThresholdMetFlag rdf:type rdf:Property ;
    rdfs:label 'Capitalization Threshold Met Flag' ;
    rdfs:comment 'Indicates whether the acquisition cost meets the utility\'s capitalization threshold for fixed asset recording. Determines if asset is capitalized or expensed.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissioningDate rdf:type rdf:Property ;
    rdfs:label 'Commissioning Date' ;
    rdfs:comment 'Date on which the asset was placed into service and became operational. Marks the start of depreciation for accounting purposes.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractorName rdf:type rdf:Property ;
    rdfs:label 'Contractor Name' ;
    rdfs:comment 'Name of the construction contractor who built or installed the asset, applicable for construction acquisition type.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cost rdf:type rdf:Property ;
    rdfs:label 'Cost' ;
    rdfs:comment 'Total cost of acquiring the asset including purchase price, installation, freight, and other capitalizable costs. Basis for depreciation calculation.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Timestamp when the asset acquisition record was first created in the system. Audit field for data lineage and compliance.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the acquisition cost. Typically USD for United States water utilities.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method' ;
    rdfs:comment 'Accounting method used to depreciate the asset over its useful life. Straight-line is most common for water utility infrastructure.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalLocation rdf:type rdf:Property ;
    rdfs:label 'Functional Location' ;
    rdfs:comment 'SAP PM functional location code representing the hierarchical location of the asset within the utility\'s infrastructure. Supports Geographic Information System (GIS) integration.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingSource rdf:type rdf:Property ;
    rdfs:label 'Funding Source' ;
    rdfs:comment 'Source of funds used to finance the asset acquisition. Critical for Capital Expenditure (CAPEX) tracking and regulatory rate case filings.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantAwardNum rdf:type rdf:Property ;
    rdfs:label 'Grant Award Num' ;
    rdfs:comment 'Unique identifier for the grant award that funded the acquisition, required for grant compliance reporting.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantProgramName rdf:type rdf:Property ;
    rdfs:label 'Grant Program Name' ;
    rdfs:comment 'Name of the federal, state, or local grant program that funded the acquisition, if applicable. Examples include EPA Water Infrastructure Finance and Innovation Act (WIFIA) or State Revolving Fund (SRF).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialConditionGrade rdf:type rdf:Property ;
    rdfs:label 'Initial Condition Grade' ;
    rdfs:comment 'Condition assessment grade assigned at the time of acquisition. Baseline for future condition monitoring and asset health tracking.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Timestamp when the asset acquisition record was last updated. Audit field for change tracking and data quality monitoring.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maximoAssetNum rdf:type rdf:Property ;
    rdfs:label 'Maximo Asset Num' ;
    rdfs:comment 'IBM Maximo Computerized Maintenance Management System (CMMS) asset number assigned at acquisition. External system identifier for cross-reference.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text notes documenting special circumstances, conditions, or details about the asset acquisition. Supports audit trail and historical context.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderNum rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Num' ;
    rdfs:comment 'Purchase order number from SAP Materials Management (MM) or procurement system authorizing the asset acquisition. Links to procurement transaction.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salvageValue rdf:type rdf:Property ;
    rdfs:label 'Salvage Value' ;
    rdfs:comment 'Estimated residual value of the asset at the end of its useful life. Used in depreciation calculation for certain methods.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapEquipmentNum rdf:type rdf:Property ;
    rdfs:label 'Sap Equipment Num' ;
    rdfs:comment 'SAP Enterprise Resource Planning (ERP) Plant Maintenance (PM) equipment number assigned at acquisition. External system identifier for cross-reference.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'Expected useful life of the asset in years for depreciation calculation. Varies by asset class per Generally Accepted Accounting Principles (GAAP) and Governmental Accounting Standards Board (GASB) guidelines.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Warranty Duration Months' ;
    rdfs:comment 'Duration of the warranty period in months. Calculated from warranty start and expiry dates for reporting purposes.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiry Date' ;
    rdfs:comment 'Date on which the manufacturer or contractor warranty period ends. Critical for maintenance planning and defect liability tracking.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:warrantyStartDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Start Date' ;
    rdfs:comment 'Date on which the manufacturer or contractor warranty period begins for the acquired asset.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workOrderNum rdf:type rdf:Property ;
    rdfs:label 'Work Order Num' ;
    rdfs:comment 'Work order number from IBM Maximo or SAP PM for construction or installation activities related to the acquisition.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetClassId rdf:type rdf:Property ;
    rdfs:label 'Asset Class Id' ;
    rdfs:comment 'Unique surrogate identifier for the asset class record in the enterprise asset management system. Primary key for the asset_class reference taxonomy. [ROLE: REFERENCE_LOOKUP — this entity is a reference taxonomy/classification table defining the hierarchy of utility asset types; per-role minimums are exempt, but MASTER_RESOURCE categories are applied for completeness given the entity carries rich business metadata beyond a simple code list.]' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetClass .

ind:createdByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Asset class definition authorship for configuration management, subject matter expert identification, and asset hierarchy governance.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:amiApplicable rdf:type rdf:Property ;
    rdfs:label 'Ami Applicable' ;
    rdfs:comment 'Indicates whether assets of this class are part of the AMI/AMR metering infrastructure managed via the Sensus FlexNet AMI Platform. True for smart meters and communication endpoints; False for all other asset classes.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assetDomain rdf:type rdf:Property ;
    rdfs:label 'Asset Domain' ;
    rdfs:comment 'Operational domain to which this asset class primarily belongs within the utility (e.g., Water Treatment, Water Distribution, Wastewater Collection, Wastewater Treatment, Metering, Fleet, Facilities, Cross-Domain). Drives domain-specific maintenance strategies and regulatory reporting alignment. [ENUM-REF-CANDIDATE: Water Treatment|Water Distribution|Wastewater Collection|Wastewater Treatment|Metering|Fleet|Facilities|Cross-Domain — promote to reference product]' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capexThresholdUsd rdf:type rdf:Property ;
    rdfs:label 'Capex Threshold Usd' ;
    rdfs:comment 'Minimum acquisition or renewal cost in USD above which expenditures on assets of this class are capitalized as CAPEX rather than expensed as OPEX. Aligned with GAAP/GASB capitalization policies and SAP FI/CO asset accounting rules.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cipProgramCategory rdf:type rdf:Property ;
    rdfs:label 'Cip Program Category' ;
    rdfs:comment 'CIP program category under which capital renewal projects for assets of this class are budgeted and tracked. Aligns with the utility\'s multi-year CIP planning structure in SAP PS and financial reporting to the Public Utilities Commission. [ENUM-REF-CANDIDATE: Water Supply|Water Treatment|Water Distribution|Wastewater Collection|Wastewater Treatment|Metering|Facilities|Fleet|Cross-Program — promote to reference product]' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classCode rdf:type rdf:Property ;
    rdfs:label 'Class Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the asset class within the enterprise taxonomy (e.g., MECH-PUMP, ELEC-TRANS, CIVIL-PIPE). Used as the externally-known business identifier in IBM Maximo, SAP PM, and GIS integrations.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classDescription rdf:type rdf:Property ;
    rdfs:label 'Class Description' ;
    rdfs:comment 'Detailed narrative description of the asset class, including its functional role within water or wastewater operations, typical installation context, and distinguishing characteristics from adjacent classes.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:className rdf:type rdf:Property ;
    rdfs:label 'Class Name' ;
    rdfs:comment 'Human-readable name of the asset class (e.g., \'Centrifugal Pump\', \'Distribution Main Pipe\', \'UV Disinfection Unit\'). Used in reports, work orders, and CAPEX planning documents.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classStatus rdf:type rdf:Property ;
    rdfs:label 'Class Status' ;
    rdfs:comment 'Current lifecycle status of the asset class record within the reference taxonomy. \'Active\' classes are available for new asset registrations; \'Deprecated\' classes are retained for historical assets but cannot be assigned to new assets.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionAssessmentMethod rdf:type rdf:Property ;
    rdfs:label 'Condition Assessment Method' ;
    rdfs:comment 'Default method used to assess the physical condition of assets in this class. CIPP and pipe assets typically use CCTV; rotating equipment uses vibration analysis; distribution mains may use acoustic leak detection. Drives field inspection work order types in Maximo. [ENUM-REF-CANDIDATE: Visual Inspection|CCTV|Acoustic Leak Detection|Vibration Analysis|Ultrasonic Testing|Hydraulic Testing|SCADA Monitoring|Not Applicable — promote to reference product]' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consequenceOfFailure rdf:type rdf:Property ;
    rdfs:label 'Consequence Of Failure' ;
    rdfs:comment 'Primary category of consequence if assets of this class fail. Drives risk-based maintenance prioritization and emergency response planning. [ENUM-REF-CANDIDATE: Service Interruption|Public Health Risk|Environmental Non-Compliance|Safety Hazard|Financial Loss|Reputational — promote to reference product]' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalityTier rdf:type rdf:Property ;
    rdfs:label 'Criticality Tier' ;
    rdfs:comment 'Default criticality tier classification for assets of this class based on consequence of failure analysis. Critical assets (e.g., primary WTP pumps, transmission mains) receive highest maintenance priority and fastest response SLAs.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalityWeight rdf:type rdf:Property ;
    rdfs:label 'Criticality Weight' ;
    rdfs:comment 'Numeric weighting factor (typically 0.00–10.00) applied to assets of this class during criticality assessment scoring. Higher values indicate greater consequence of failure on service delivery, public health, or regulatory compliance. Used in risk-based asset prioritization per ISO 55001.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Date from which this asset class definition became effective and available for use in asset registrations. Supports temporal validity tracking of the reference taxonomy.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:environmentalRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Risk Flag' ;
    rdfs:comment 'Indicates whether failure of assets in this class poses a direct environmental risk requiring regulatory notification (e.g., SSO, CSO, chemical spill, NPDES permit exceedance). True triggers mandatory environmental incident reporting workflows.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gisFeatureClass rdf:type rdf:Property ;
    rdfs:label 'Gis Feature Class' ;
    rdfs:comment 'Corresponding feature class name in Esri ArcGIS geodatabase for assets of this class (e.g., \'wDistributionMain\', \'wValve\', \'wPump\'). Enables spatial analysis, network modeling in Innovyze InfoWater, and GIS-CMMS integration for field crew dispatch.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'Default General Ledger account code in SAP FI/CO to which asset acquisitions, depreciation, and disposals for this class are posted. Ensures consistent financial reporting and CAPEX/OPEX tracking across the utility.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric depth of this class within the classification hierarchy (1 = top-level category, 2 = sub-category, 3 = class, 4 = sub-class). Drives roll-up aggregation logic in CAPEX planning and maintenance reporting.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Inspection Frequency Days' ;
    rdfs:comment 'Default interval in calendar days between mandatory regulatory or condition inspections for assets of this class. Distinct from PM frequency — this is driven by regulatory compliance requirements (e.g., EPA, state primacy agency mandates) rather than maintenance strategy.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iso55001Aligned rdf:type rdf:Property ;
    rdfs:label 'Iso 55001 Aligned' ;
    rdfs:comment 'Indicates whether the maintenance strategy, criticality assessment, and lifecycle management approach for this asset class have been formally aligned with ISO 55001 Asset Management System requirements. Used for ISO certification audit evidence.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Timestamp when this asset class record was most recently modified in the enterprise data platform. Used for change tracking, data synchronization with source systems (Maximo, SAP), and audit compliance.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lcrrApplicable rdf:type rdf:Property ;
    rdfs:label 'Lcrr Applicable' ;
    rdfs:comment 'Indicates whether assets of this class are subject to EPA Lead and Copper Rule Revisions (LCRR) compliance requirements, such as lead service line inventory and replacement tracking. Applicable to service lines, connectors, and plumbing components.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceStrategy rdf:type rdf:Property ;
    rdfs:label 'Maintenance Strategy' ;
    rdfs:comment 'Default O&M maintenance strategy applied to assets of this class in IBM Maximo CMMS. Drives automatic PM schedule generation. Preventive and Condition-Based strategies are typical for critical water infrastructure; Run-to-Failure may apply to low-criticality ancillary assets.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialStandard rdf:type rdf:Property ;
    rdfs:label 'Material Standard' ;
    rdfs:comment 'Default material specification or construction standard applicable to assets of this class (e.g., \'AWWA C900 PVC\', \'AWWA C200 Steel\', \'ASTM A536 Ductile Iron\', \'HDPE ASTM D3035\'). Used in procurement specifications and asset registry for infrastructure renewal planning.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximoClassCode rdf:type rdf:Property ;
    rdfs:label 'Maximo Class Code' ;
    rdfs:comment 'Corresponding asset class identifier in IBM Maximo Asset Management CMMS. Used for bidirectional synchronization between the Silver Layer lakehouse and Maximo for work order generation, PM scheduling, and asset lifecycle management.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meanTimeBetweenFailuresDays rdf:type rdf:Property ;
    rdfs:label 'Mean Time Between Failures Days' ;
    rdfs:comment 'Industry benchmark mean time between failures in days for assets of this class, used as a baseline for reliability-centered maintenance planning and failure probability modeling. Sourced from AWWA reliability benchmarks and historical Maximo work order data.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanTimeToRepairHours rdf:type rdf:Property ;
    rdfs:label 'Mean Time To Repair Hours' ;
    rdfs:comment 'Industry benchmark mean time to repair in hours for assets of this class, used for SLA setting, crew resource planning, and service restoration time estimation. Sourced from AWWA benchmarks and historical Maximo corrective work order durations.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberSap rdf:type rdf:Property ;
    rdfs:label 'Number Sap' ;
    rdfs:comment 'Corresponding asset class number in SAP FI/CO Asset Accounting module (transaction AS02/AS03). Enables direct cross-reference between the enterprise data lakehouse and the SAP ERP system of record for financial reconciliation.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Pm Frequency Days' ;
    rdfs:comment 'Default interval in calendar days between scheduled preventive maintenance activities for assets of this class. Used by IBM Maximo PM scheduling engine to auto-generate work orders. Overridable at the individual asset level.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCategory rdf:type rdf:Property ;
    rdfs:label 'Primary Category' ;
    rdfs:comment 'Top-level classification grouping for the asset class aligned with standard utility asset taxonomy: Mechanical (pumps, blowers, mixers), Electrical (transformers, switchgear), Civil (pipes, structures, tanks), Instrumentation (sensors, meters, SCADA RTUs), Vehicle (fleet), Information Technology, or Other. [ENUM-REF-CANDIDATE: Mechanical|Electrical|Civil|Instrumentation|Vehicle|Information Technology|Other — promote to reference product]' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryStandardRef rdf:type rdf:Property ;
    rdfs:label 'Regulatory Standard Ref' ;
    rdfs:comment 'Primary regulatory standard or code applicable to assets of this class (e.g., \'SDWA Section 1412\', \'NPDES Permit\', \'AWWA C900\', \'ASME B31.3\'). Drives compliance inspection scheduling and regulatory reporting requirements in DMR/MOR submissions.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalStrategy rdf:type rdf:Property ;
    rdfs:label 'Renewal Strategy' ;
    rdfs:comment 'Default end-of-life renewal strategy for assets of this class used in CIP planning. CIPP (Cured-in-Place Pipe) and trenchless methods are common for buried pipe rehabilitation; rotating equipment typically follows Replace-in-Kind or Upgrade strategies.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'Date on which this asset class was retired or deprecated from the active taxonomy. Null for currently active classes. Retained for historical asset records that were registered under this class prior to retirement.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyClassification rdf:type rdf:Property ;
    rdfs:label 'Safety Classification' ;
    rdfs:comment 'Primary safety hazard classification for work activities on assets of this class. Drives OSHA-compliant safety permit requirements (e.g., confined space entry permits, lockout/tagout procedures) when generating work orders in Maximo.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salvageValuePct rdf:type rdf:Property ;
    rdfs:label 'Salvage Value Pct' ;
    rdfs:comment 'Default residual/salvage value expressed as a percentage of original acquisition cost at end of useful life for assets in this class. Used in depreciation calculations and asset disposal planning within SAP FI/CO.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scadaMonitored rdf:type rdf:Property ;
    rdfs:label 'Scada Monitored' ;
    rdfs:comment 'Indicates whether assets of this class are typically monitored via SCADA (Supervisory Control and Data Acquisition) systems integrated with OSIsoft PI Historian. True for pumps, valves, flow meters, and treatment equipment; False for passive civil assets such as buried pipes.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sizeUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Size Unit Of Measure' ;
    rdfs:comment 'Standard unit of measure used to express the principal sizing attribute for assets of this class (e.g., \'inches\' for pipe diameter, \'HP\' for pump motor horsepower, \'kVA\' for transformer capacity, \'GPM\' for flow capacity). Ensures consistent sizing data entry across the asset registry. [ENUM-REF-CANDIDATE: inches|mm|feet|meters|kVA|HP|kW|GPM|MGD|gallons|cubic feet — promote to reference product]' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sparePartsRequired rdf:type rdf:Property ;
    rdfs:label 'Spare Parts Required' ;
    rdfs:comment 'Indicates whether assets of this class typically require dedicated spare parts inventory to be maintained in the storeroom (SAP MM / Maximo Inventory). True for critical rotating equipment and instrumentation; False for passive civil assets.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workOrderTypeDefault rdf:type rdf:Property ;
    rdfs:label 'Work Order Type Default' ;
    rdfs:comment 'Default work order type generated in IBM Maximo for assets of this class when a maintenance event is triggered. Drives labor planning, cost coding, and CAPEX vs OPEX classification of maintenance expenditures.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalId rdf:type rdf:Property ;
    rdfs:label 'Disposal Id' ;
    rdfs:comment 'Unique identifier for the asset disposal record. Primary key for the asset disposal transaction.' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disposalRegistryId rdf:type rdf:Property ;
    rdfs:label 'Disposal Registry Id' ;
    rdfs:comment 'Reference to the asset being disposed from the asset registry. Links to the physical infrastructure asset (pipe, pump, valve, equipment, vehicle) that is being retired or decommissioned.' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Registry .

ind:disposalReplacementAssetAssetRegistryId rdf:type rdf:Property ;
    rdfs:label 'Disposal Replacement Asset Asset Registry Id' ;
    rdfs:comment 'Reference to the new asset that replaced the disposed asset, if disposal reason was replacement. Links retired asset to its successor for lifecycle tracking.' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Registry .

ind:replacementAssetRegistryId rdf:type rdf:Property ;
    rdfs:label 'Replacement Asset Registry Id' ;
    rdfs:comment 'Reference to the new asset that replaced the disposed asset, if disposal reason was replacement. Links retired asset to its successor for lifecycle tracking.' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Registry .

ind:accumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Accumulated Depreciation' ;
    rdfs:comment 'The total depreciation expense accumulated on the asset from installation date through disposal date. Used in calculating book value and gain/loss on disposal.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookValueAtDisposal rdf:type rdf:Property ;
    rdfs:label 'Book Value At Disposal' ;
    rdfs:comment 'The net book value (original acquisition cost minus accumulated depreciation) of the asset at the time of disposal. Used to calculate gain or loss on disposal for financial reporting.' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buyerContactInfo rdf:type rdf:Property ;
    rdfs:label 'Buyer Contact Info' ;
    rdfs:comment 'Contact information (phone, email, or address) for the buyer of the asset. Used for transfer documentation and warranty transfer. Confidential business contact data.' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerName rdf:type rdf:Property ;
    rdfs:label 'Buyer Name' ;
    rdfs:comment 'Name of the individual or organization that purchased the asset, if disposal method was sale or auction. Null for other disposal methods.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'The date on which the physical disposal activity was completed. May differ from disposal effective date if removal or demolition took multiple days.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'The cost center responsible for the asset at the time of disposal. Used for departmental cost allocation and budget tracking.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalDate rdf:type rdf:Property ;
    rdfs:label 'Disposal Date' ;
    rdfs:comment 'The date on which the asset was officially retired or disposed. This is the principal business event date that triggers SAP FI-AA asset retirement posting and updates the asset registry operational status to Retired.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalMethod rdf:type rdf:Property ;
    rdfs:label 'Disposal Method' ;
    rdfs:comment 'The method by which the asset was disposed. Indicates whether the asset was sold, scrapped, transferred to another entity, donated, demolished, or salvaged for parts. [ENUM-REF-CANDIDATE: salvage|demolition|sale|donation|transfer|scrap|auction — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalNumber rdf:type rdf:Property ;
    rdfs:label 'Disposal Number' ;
    rdfs:comment 'Business identifier for the disposal transaction. Externally-known unique number used for tracking and audit purposes across SAP FI-AA and Maximo.' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalStatus rdf:type rdf:Property ;
    rdfs:label 'Disposal Status' ;
    rdfs:comment 'Current lifecycle status of the disposal transaction. Tracks workflow from initiation through final completion and posting to financial systems. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|in_progress|completed|cancelled|reversed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalClearanceDate rdf:type rdf:Property ;
    rdfs:label 'Environmental Clearance Date' ;
    rdfs:comment 'The date on which environmental clearance was obtained, if required. Null if no clearance was required.' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:environmentalClearanceNotes rdf:type rdf:Property ;
    rdfs:label 'Environmental Clearance Notes' ;
    rdfs:comment 'Free-text notes documenting environmental clearance process, remediation actions taken, or hazardous material handling procedures followed during disposal.' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Environmental Clearance Required' ;
    rdfs:comment 'Indicates whether environmental clearance or remediation was required before disposal. True for assets containing hazardous materials, lead pipes, asbestos insulation, or contaminated equipment.' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gainLossOnDisposal rdf:type rdf:Property ;
    rdfs:label 'Gain Loss On Disposal' ;
    rdfs:comment 'The accounting gain or loss recognized on the disposal transaction, calculated as net disposal value minus book value at disposal. Positive values represent gains, negative values represent losses.' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:initiatedBy rdf:type rdf:Property ;
    rdfs:label 'Initiated By' ;
    rdfs:comment 'Name or identifier of the employee or department that initiated the disposal request. Typically an asset manager, operations supervisor, or maintenance planner.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'The user identifier or name of the person who last modified this disposal record. Audit trail for accountability.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:location rdf:type rdf:Property ;
    rdfs:label 'Location' ;
    rdfs:comment 'The physical location or facility where the asset was disposed, demolished, or removed from. May be a treatment plant, pump station, or field location.' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximoDisposalCode rdf:type rdf:Property ;
    rdfs:label 'Maximo Disposal Code' ;
    rdfs:comment 'The disposal transaction identifier in IBM Maximo CMMS. Used for cross-system reconciliation and audit trail between Maximo and SAP FI-AA.' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netDisposalValue rdf:type rdf:Property ;
    rdfs:label 'Net Disposal Value' ;
    rdfs:comment 'The net financial result of the disposal transaction, calculated as disposal proceeds minus disposal costs. May be positive (gain) or negative (loss).' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proceeds rdf:type rdf:Property ;
    rdfs:label 'Proceeds' ;
    rdfs:comment 'The monetary amount received from the disposal of the asset, if any. Represents sale price, salvage value, or auction proceeds. Zero for demolition or scrap with no recovery value.' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retirementReason rdf:type rdf:Property ;
    rdfs:label 'Retirement Reason' ;
    rdfs:comment 'The primary business or operational reason for retiring the asset. Captures whether disposal was due to end of useful life, failure, regulatory mandate, planned replacement, or other strategic decision. [ENUM-REF-CANDIDATE: end_of_life|catastrophic_failure|obsolescence|regulatory_requirement|replacement|consolidation|capacity_reduction|safety_hazard|environmental_compliance — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementReasonNotes rdf:type rdf:Property ;
    rdfs:label 'Retirement Reason Notes' ;
    rdfs:comment 'Free-text narrative providing additional context and details about the reason for asset retirement. May include failure analysis, condition assessment summary, or regulatory citation.' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapAssetRetirementDoc rdf:type rdf:Property ;
    rdfs:label 'Sap Asset Retirement Doc' ;
    rdfs:comment 'The SAP FI-AA asset retirement document number generated when the disposal transaction was posted to the financial system. Used for financial audit and reconciliation.' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPostingDate rdf:type rdf:Property ;
    rdfs:label 'Sap Posting Date' ;
    rdfs:comment 'The date on which the asset retirement transaction was posted to SAP FI-AA general ledger. May differ from disposal date due to period-end closing rules.' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transferToEntity rdf:type rdf:Property ;
    rdfs:label 'Transfer To Entity' ;
    rdfs:comment 'Name of the entity (department, municipality, or organization) to which the asset was transferred, if disposal method was transfer. Null for other disposal methods.' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'The Maximo work order number associated with the physical removal, demolition, or disposal activity. Links disposal transaction to field execution.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'The user identifier or name of the person who created this disposal record. Audit trail for accountability.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentId rdf:type rdf:Property ;
    rdfs:label 'Document Id' ;
    rdfs:comment 'Unique identifier for the asset document record. Primary key for the asset document registry.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificateOfAnalysisId rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Id' ;
    rdfs:comment 'Foreign key linking to laboratory.certificate_of_analysis. Business justification: Asset files contain certificates of analysis for treatment chemicals, pipe materials, coatings, and construction materials. Standard procurement documentation and regulatory compliance requirement for' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CertificateOfAnalysis .

ind:designContractId rdf:type rdf:Property ;
    rdfs:label 'Design Contract Id' ;
    rdfs:comment 'Foreign key linking to project.design_contract. Business justification: Design deliverables (calculations, specifications, technical memoranda, basis-of-design reports) are design contract work products; professional liability claims, design standard compliance verificati' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DesignContract .

ind:documentApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Document Approved By Employee Id' ;
    rdfs:comment 'Employee identifier for the internal staff member who approved the document.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:documentAuthorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Document Author Employee Id' ;
    rdfs:comment 'Employee identifier for the internal staff member who authored the document, if applicable.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:permitId rdf:type rdf:Property ;
    rdfs:label 'Permit Id' ;
    rdfs:comment 'Reference to the regulatory permit this document is associated with, if applicable.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompliancePermit .

ind:relatedWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Related Work Order Id' ;
    rdfs:comment 'Reference to a work order that generated or is associated with this document, such as inspection reports or maintenance records.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:supersededByDocumentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Document Id' ;
    rdfs:comment 'Reference to the newer document that replaces this document. Maintains document version lineage and ensures users access the current revision.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:supersededDocumentId rdf:type rdf:Property ;
    rdfs:label 'Superseded Document Id' ;
    rdfs:comment 'Reference to the previous version or document that this document replaces or supersedes.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:testResultId rdf:type rdf:Property ;
    rdfs:label 'Test Result Id' ;
    rdfs:comment 'Foreign key linking to laboratory.test_result. Business justification: Asset documentation packages include laboratory test results for commissioning reports, material certifications, water quality compliance records, and coating/lining verification. Required for regulat' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestResult .

ind:accessRestriction rdf:type rdf:Property ;
    rdfs:label 'Access Restriction' ;
    rdfs:comment 'Description of who may access the document. Defines user roles, departments, or security clearances required for document access.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'Date when the document was formally approved. Marks the transition to active status.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorName rdf:type rdf:Property ;
    rdfs:label 'Author Name' ;
    rdfs:comment 'Name of the individual or organization that created the document. Identifies the document originator for accountability.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorOrganization rdf:type rdf:Property ;
    rdfs:label 'Author Organization' ;
    rdfs:comment 'Organization or company that produced the document. Relevant for vendor-supplied documentation and external engineering firms.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStandard rdf:type rdf:Property ;
    rdfs:label 'Compliance Standard' ;
    rdfs:comment 'Industry or regulatory standard that the document complies with. Examples include AWWA standards, ISO 55001, SDWA, CWA, or OSHA regulations.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'Data classification level of the document content. Determines access controls and distribution restrictions.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destructionEligibleDate rdf:type rdf:Property ;
    rdfs:label 'Destruction Eligible Date' ;
    rdfs:comment 'Calculated date when the document becomes eligible for destruction based on retention policies.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentCategory rdf:type rdf:Property ;
    rdfs:label 'Document Category' ;
    rdfs:comment 'High-level categorization of the document by business function. Supports document organization and retrieval.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDescription rdf:type rdf:Property ;
    rdfs:label 'Document Description' ;
    rdfs:comment 'Detailed description of the document content, scope, and purpose. Supports document search and classification.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'Unique business identifier for the document. Used for tracking and retrieval in document management systems and regulatory audits.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStatus rdf:type rdf:Property ;
    rdfs:label 'Document Status' ;
    rdfs:comment 'Current lifecycle status of the document. Tracks document progression through review, approval, and archival processes. [ENUM-REF-CANDIDATE: draft|under_review|approved|active|superseded|archived|obsolete — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Classification of the document type. Categorizes documents by their purpose and content to support ISO 55001 documentation requirements and regulatory audit readiness. [ENUM-REF-CANDIDATE: as_built_drawing|om_manual|equipment_datasheet|commissioning_report|test_certificate|regulatory_permit|warranty_document|inspection_report|maintenance_procedure|safety_data_sheet — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Date when the document expires or is no longer valid. Applicable to permits, certifications, and time-limited approvals.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'Digital file format of the document. Identifies the software and tools required to view and edit the document. [ENUM-REF-CANDIDATE: pdf|dwg|dxf|docx|xlsx|jpg|png|tif — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileName rdf:type rdf:Property ;
    rdfs:label 'File Name' ;
    rdfs:comment 'Name of the digital file as stored in the document management system. Includes file extension for format identification.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeKb rdf:type rdf:Property ;
    rdfs:label 'File Size Kb' ;
    rdfs:comment 'Size of the electronic document file measured in kilobytes.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fileSizeMb rdf:type rdf:Property ;
    rdfs:label 'File Size Mb' ;
    rdfs:comment 'Size of the document file in megabytes. Used for storage management and download time estimation.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gisFeatureCode rdf:type rdf:Property ;
    rdfs:label 'Gis Feature Code' ;
    rdfs:comment 'Identifier for the associated GIS feature in Esri ArcGIS. Links documents to spatial assets such as pipes, valves, and facilities.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'Date when the document was officially issued or published for use.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:keywords rdf:type rdf:Property ;
    rdfs:label 'Keywords' ;
    rdfs:comment 'Comma-separated list of keywords or tags for document search and classification. Enhances document discoverability in the document management system.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'Three-letter ISO 639-2 language code indicating the primary language of the document. Supports multilingual document management.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximoDocumentCode rdf:type rdf:Property ;
    rdfs:label 'Maximo Document Code' ;
    rdfs:comment 'Document identifier in IBM Maximo CMMS. Provides traceability to the source system for asset management integration.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAgency rdf:type rdf:Property ;
    rdfs:label 'Regulatory Agency' ;
    rdfs:comment 'Name of the regulatory agency that requires or issued the document. Examples include EPA, state drinking water programs, OSHA, or local health departments.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Citation or reference to the regulatory requirement, permit, or compliance obligation that this document supports or fulfills.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Flag' ;
    rdfs:comment 'Indicates whether the document is required by regulatory agencies such as EPA, state primacy agencies, or OSHA. Critical for compliance audit readiness.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Retention Period Years' ;
    rdfs:comment 'Number of years the document must be retained per regulatory or business policy requirements. Supports records management and compliance.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retentionTriggerDate rdf:type rdf:Property ;
    rdfs:label 'Retention Trigger Date' ;
    rdfs:comment 'Date from which the retention period begins, typically the document effective date or superseded date.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Review Due Date' ;
    rdfs:comment 'Scheduled date for the next periodic review of the document to ensure continued accuracy and relevance.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Months' ;
    rdfs:comment 'Standard interval in months between scheduled reviews of the document.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewedBy rdf:type rdf:Property ;
    rdfs:label 'Reviewed By' ;
    rdfs:comment 'Name of the individual who reviewed the document for technical accuracy and completeness. Part of document quality control process.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedDate rdf:type rdf:Property ;
    rdfs:label 'Reviewed Date' ;
    rdfs:comment 'Date when the document review was completed. Tracks document quality assurance timeline.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisionDate rdf:type rdf:Property ;
    rdfs:label 'Revision Date' ;
    rdfs:comment 'Date when the current revision of the document was created or last modified. Supports version tracking and audit trails.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Version or revision identifier for the document. Tracks document changes and updates over time to maintain version control.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Document Number' ;
    rdfs:comment 'Document number in SAP ERP system. Links to SAP PM or MM modules for equipment documentation and procurement records.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Physical or electronic location where the document is stored, such as file path, cabinet number, or repository identifier.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationUrl rdf:type rdf:Property ;
    rdfs:label 'Storage Location Url' ;
    rdfs:comment 'URL or file path to the document in the document management system. Provides direct access to the digital document file.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Descriptive title of the document. Provides human-readable identification of the document content and purpose.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:url rdf:type rdf:Property ;
    rdfs:label 'Url' ;
    rdfs:comment 'Web address or hyperlink to access the electronic document in the document management system or external repository.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationId rdf:type rdf:Property ;
    rdfs:label 'Location Id' ;
    rdfs:comment 'Unique identifier for the asset location record. Primary key.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:parentLocationId rdf:type rdf:Property ;
    rdfs:label 'Parent Location Id' ;
    rdfs:comment 'Reference to the parent location in the hierarchical location structure (e.g., a room\'s parent is a floor, a floor\'s parent is a building).' ;
    rdfs:domain ind:Location ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:accessRestrictions rdf:type rdf:Property ;
    rdfs:label 'Access Restrictions' ;
    rdfs:comment 'Description of physical or security access restrictions for the location (e.g., \'Restricted - Badge Required\', \'Public Access\', \'Confined Space\').' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address of the location. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address information (suite, unit, building number). Organizational contact data classified as confidential.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaSquareFeet rdf:type rdf:Property ;
    rdfs:label 'Area Square Feet' ;
    rdfs:comment 'Physical area of the location in square feet, used for space planning and asset density analysis.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityRating rdf:type rdf:Property ;
    rdfs:label 'Capacity Rating' ;
    rdfs:comment 'Rated capacity of the location for asset storage or operational throughput (e.g., MGD for treatment facilities, gallons for storage tanks).' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityUnit rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit' ;
    rdfs:comment 'Unit of measure for the capacity rating (e.g., Million Gallons per Day (MGD), Gallons per Minute (GPM), gallons, cubic meters).' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City or municipality where the location is situated.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'Three-letter ISO country code (e.g., \'USA\', \'CAN\', \'MEX\').' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmaZone rdf:type rdf:Property ;
    rdfs:label 'Dma Zone' ;
    rdfs:comment 'District Metered Area zone identifier for water distribution network segmentation and Non-Revenue Water (NRW) analysis.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date when the location was decommissioned or removed from active service (null for active locations).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date when the location became operational or was added to the asset registry.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:elevationFt rdf:type rdf:Property ;
    rdfs:label 'Elevation Ft' ;
    rdfs:comment 'Elevation above sea level in feet, used for hydraulic modeling and pressure zone analysis.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalConditions rdf:type rdf:Property ;
    rdfs:label 'Environmental Conditions' ;
    rdfs:comment 'Description of environmental conditions at the location (e.g., \'Indoor Climate Controlled\', \'Outdoor Exposed\', \'Wet Environment\', \'Corrosive Atmosphere\').' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorLevel rdf:type rdf:Property ;
    rdfs:label 'Floor Level' ;
    rdfs:comment 'Floor or level number within a building (e.g., 1 for ground floor, 2 for second floor, -1 for basement).' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hazardClassification rdf:type rdf:Property ;
    rdfs:label 'Hazard Classification' ;
    rdfs:comment 'Safety hazard classification for the location (e.g., \'Confined Space\', \'High Voltage\', \'Chemical Storage\', \'None\').' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate in decimal degrees for GIS integration with Esri ArcGIS.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Business identifier code for the location, used for operational reference and integration with IBM Maximo CMMS and SAP PM systems.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationDescription rdf:type rdf:Property ;
    rdfs:label 'Location Description' ;
    rdfs:comment 'Detailed description of the location, including physical characteristics, purpose, and operational context.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Human-readable name of the asset location (e.g., \'Main Street Pump Station\', \'North WTP Filter Building\').' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationStatus rdf:type rdf:Property ;
    rdfs:label 'Location Status' ;
    rdfs:comment 'Current operational status of the location in its lifecycle.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the location type within the asset hierarchy.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate in decimal degrees for GIS integration with Esri ArcGIS.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximoLocationCode rdf:type rdf:Property ;
    rdfs:label 'Maximo Location Code' ;
    rdfs:comment 'Location identifier in IBM Maximo CMMS for work order management and maintenance routing integration.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'ZIP or postal code for the location. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pressureZone rdf:type rdf:Property ;
    rdfs:label 'Pressure Zone' ;
    rdfs:comment 'Pressure zone designation for hydraulic modeling and distribution network operations, typically defined by elevation and Pressure Reducing Valve (PRV) boundaries.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction' ;
    rdfs:comment 'Regulatory jurisdiction or primacy agency responsible for oversight (e.g., state EPA, local health department).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roomNumber rdf:type rdf:Property ;
    rdfs:label 'Room Number' ;
    rdfs:comment 'Room or space identifier within a floor or building (e.g., \'Room 101\', \'Electrical Vault A\').' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapFunctionalLocation rdf:type rdf:Property ;
    rdfs:label 'Sap Functional Location' ;
    rdfs:comment 'SAP PM functional location code for asset hierarchy and maintenance planning integration.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Scada Integration Flag' ;
    rdfs:comment 'Indicates whether the location is integrated with SCADA systems (OSIsoft PI Historian) for real-time monitoring and control.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceTerritory rdf:type rdf:Property ;
    rdfs:label 'Service Territory' ;
    rdfs:comment 'Service territory or jurisdiction code defining the geographic area served by the utility.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spatialReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Spatial Reference Code' ;
    rdfs:comment 'Coordinate system reference identifier (EPSG code) used for GIS spatial data (e.g., \'EPSG:4326\' for WGS 84).' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'Two-letter state or province code (e.g., \'CA\', \'TX\', \'NY\').' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watershed rdf:type rdf:Property ;
    rdfs:label 'Watershed' ;
    rdfs:comment 'Watershed or drainage basin identifier for regulatory reporting and environmental compliance under the Clean Water Act (CWA).' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetMeterId rdf:type rdf:Property ;
    rdfs:label 'Asset Meter Id' ;
    rdfs:comment 'Unique surrogate identifier for the asset meter record in the enterprise data platform. Primary key for the asset_meter product. Role: MASTER_RESOURCE.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetMeter .

ind:meteringMeterId rdf:type rdf:Property ;
    rdfs:label 'Metering Meter Id' ;
    rdfs:comment 'The native meter identifier from IBM Maximo Asset Management CMMS (METERNAME or internal Maximo meter key). Used for system-of-record traceability and bidirectional synchronization between the Silver Layer and Maximo.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MeteringMeter .

ind:alarmHighThreshold rdf:type rdf:Property ;
    rdfs:label 'Alarm High Threshold' ;
    rdfs:comment 'The upper alarm threshold value for this meter. When the reading exceeds this value, a SCADA or CMMS alarm is triggered. For example, high vibration alarm at 0.5 in/s for a pump motor. Supports integration with SCADA HMI alarm management.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alarmLowThreshold rdf:type rdf:Property ;
    rdfs:label 'Alarm Low Threshold' ;
    rdfs:comment 'The lower alarm threshold value for this meter. When the reading falls below this value, a SCADA or CMMS alarm is triggered. For example, low flow alarm at 0.1 MGD for a treatment process feed pump.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageReadingRate rdf:type rdf:Property ;
    rdfs:label 'Average Reading Rate' ;
    rdfs:comment 'The average rate of change per day for this meter, calculated and stored by the CMMS during reading entry (not a derived KPI — stored as a CMMS field used for PM trigger forecasting). For example, average run-hours per day for a pump. Used by meter-based PM triggers to forecast next maintenance due date.' ;
    rdfs:domain ind:AssetMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Avg Calculation Method' ;
    rdfs:comment 'Method used by the CMMS to compute the average_reading_rate. SLIDING_WINDOW: rolling average over a configurable number of recent readings. FIXED_PERIOD: average over a fixed calendar period. LAST_READING: uses only the most recent reading interval.' ;
    rdfs:domain ind:AssetMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Calibration Interval Days' ;
    rdfs:comment 'The required frequency of calibration expressed in calendar days. Used to compute next_calibration_date from last_calibration_date and to schedule calibration work orders in IBM Maximo.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calibrationStatus rdf:type rdf:Property ;
    rdfs:label 'Calibration Status' ;
    rdfs:comment 'Current calibration status of the meter instrument. CALIBRATED: within valid calibration period. DUE: calibration due within the next calibration_interval_days. OVERDUE: calibration date has passed without recalibration. IN_PROGRESS: currently being calibrated. NOT_REQUIRED: meter type does not require formal calibration (e.g., simple cycle counters).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationTolerance rdf:type rdf:Property ;
    rdfs:label 'Calibration Tolerance' ;
    rdfs:comment 'Acceptable measurement tolerance or accuracy specification for this meter expressed in the meter\'s unit of measure. Readings outside this tolerance trigger recalibration. For example, ±0.5 PSI for a pressure transducer or ±0.01 MGD for a flow totalizer.' ;
    rdfs:domain ind:AssetMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentReading rdf:type rdf:Property ;
    rdfs:label 'Current Reading' ;
    rdfs:comment 'The most recent recorded value of the meter or counter as of the last_reading_date. For CONTINUOUS meters this is the cumulative total; for GAUGE meters this is the last observed point-in-time value. Principal quantitative fact for this MASTER_RESOURCE.' ;
    rdfs:domain ind:AssetMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'Date on which the meter was permanently removed from service and retired. Null for active meters. Used for lifecycle reporting and asset history.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date on which the meter was physically installed on the asset. Used to calculate meter age, warranty expiry, and to establish the baseline reading at installation.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isRegulatoryMeter rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Meter' ;
    rdfs:comment 'Indicates whether readings from this meter are used in regulatory compliance reporting (e.g., EPA NPDES Discharge Monitoring Reports, Safe Drinking Water Act compliance, Monthly Operating Reports). True = regulatory-grade meter subject to calibration and data integrity requirements.' ;
    rdfs:domain ind:AssetMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Last Calibration Date' ;
    rdfs:comment 'Date on which the meter was most recently calibrated and certified as accurate. Critical for regulatory compliance where metered values (e.g., flow, pressure, chemical dosing) are used in EPA/NPDES reporting.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReadingDate rdf:type rdf:Property ;
    rdfs:label 'Last Reading Date' ;
    rdfs:comment 'Timestamp of the most recent meter reading captured, whether from SCADA/OSIsoft PI Historian automated feed or manual entry in IBM Maximo. Formatted as yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:AssetMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manufacturer rdf:type rdf:Property ;
    rdfs:label 'Manufacturer' ;
    rdfs:comment 'Name of the manufacturer of the meter instrument or sensor hardware, e.g., Endress+Hauser, Yokogawa, Emerson, Siemens. Used for procurement, warranty tracking, and spare parts management.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementUnit rdf:type rdf:Property ;
    rdfs:label 'Measurement Unit' ;
    rdfs:comment 'Engineering unit of measure for the meter reading, e.g., HOURS (run-hours), STARTS (motor starts), CYCLES (valve cycles), MGD (Million Gallons per Day), GPM (Gallons per Minute), PSI (Pounds per Square Inch), NTU (Nephelometric Turbidity Units), RPM, DEGREES_F, INCHES. Aligns with OSIsoft PI Historian tag engineering units.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meterName rdf:type rdf:Property ;
    rdfs:label 'Meter Name' ;
    rdfs:comment 'Human-readable descriptive name for the meter or counter, e.g., \'Pump 3 Run Hours\', \'Valve 12 Cycle Count\', \'Influent Flow Totalizer\'. Used for display in CMMS work orders and PM triggers.' ;
    rdfs:domain ind:AssetMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meterNumber rdf:type rdf:Property ;
    rdfs:label 'Meter Number' ;
    rdfs:comment 'Externally-known unique alphanumeric identifier for the meter as assigned in IBM Maximo CMMS or SAP PM. Used for cross-system reference and field identification. Distinct from customer billing meter numbers managed by the Metering domain.' ;
    rdfs:domain ind:AssetMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meterStatus rdf:type rdf:Property ;
    rdfs:label 'Meter Status' ;
    rdfs:comment 'Current operational lifecycle status of the meter. ACTIVE: in service and collecting readings. INACTIVE: temporarily not in use. RETIRED: permanently decommissioned. SUSPENDED: readings paused (e.g., asset out of service). PENDING_CALIBRATION: due for or undergoing calibration.' ;
    rdfs:domain ind:AssetMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meterType rdf:type rdf:Property ;
    rdfs:label 'Meter Type' ;
    rdfs:comment 'Classification of the meter per IBM Maximo meter type taxonomy. CONTINUOUS: accumulating counter that never resets (e.g., run-hours, cycle counts, flow totalizer). GAUGE: point-in-time measurement that can go up or down (e.g., PSI, vibration amplitude, temperature). CHARACTERISTIC: qualitative or categorical observation (e.g., condition rating, oil color).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelNumber rdf:type rdf:Property ;
    rdfs:label 'Model Number' ;
    rdfs:comment 'Manufacturer\'s model or part number for the meter instrument. Used for procurement, spare parts identification, and technical documentation lookup.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Next Calibration Date' ;
    rdfs:comment 'Scheduled date by which the meter must next be calibrated to maintain measurement accuracy and regulatory compliance. Drives calibration work order generation in IBM Maximo.' ;
    rdfs:domain ind:AssetMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:piTagName rdf:type rdf:Property ;
    rdfs:label 'Pi Tag Name' ;
    rdfs:comment 'The OSIsoft PI Historian tag identifier associated with this meter for automated SCADA data ingestion. Enables direct linkage between the CMMS meter record and the PI Historian time-series data stream. Null if the meter is not integrated with PI Historian.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmTriggerInterval rdf:type rdf:Property ;
    rdfs:label 'Pm Trigger Interval' ;
    rdfs:comment 'The recurring interval of meter units between successive PM work order generations. For example, every 500 run-hours or every 1000 valve cycles. Works in conjunction with pm_trigger_threshold for ongoing PM scheduling.' ;
    rdfs:domain ind:AssetMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pmTriggerThreshold rdf:type rdf:Property ;
    rdfs:label 'Pm Trigger Threshold' ;
    rdfs:comment 'The meter reading value at which a Preventive Maintenance (PM) work order is automatically generated. For example, a pump PM triggered every 2000 run-hours. Core field enabling meter-based PM scheduling in IBM Maximo.' ;
    rdfs:domain ind:AssetMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousReading rdf:type rdf:Property ;
    rdfs:label 'Previous Reading' ;
    rdfs:comment 'The meter reading value recorded immediately prior to the current reading. Used to calculate consumption delta between readings and to detect anomalous jumps or rollover events.' ;
    rdfs:domain ind:AssetMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousReadingDate rdf:type rdf:Property ;
    rdfs:label 'Previous Reading Date' ;
    rdfs:comment 'Timestamp of the meter reading that preceded the current reading. Used in conjunction with previous_reading to compute usage rate and validate reading intervals.' ;
    rdfs:domain ind:AssetMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:readingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reading Frequency' ;
    rdfs:comment 'Expected frequency at which meter readings are collected. CONTINUOUS: real-time SCADA/PI Historian streaming. HOURLY/DAILY/WEEKLY/MONTHLY: scheduled batch collection. ON_DEMAND: readings taken only when required (e.g., during inspections or work orders).' ;
    rdfs:domain ind:AssetMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingRangeMax rdf:type rdf:Property ;
    rdfs:label 'Reading Range Max' ;
    rdfs:comment 'Maximum valid reading value for this meter as defined by the instrument\'s operating range or process design limits. Readings above this value are flagged as suspect or trigger alarms. For example, 150 PSI maximum for a distribution pressure transducer.' ;
    rdfs:domain ind:AssetMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:readingRangeMin rdf:type rdf:Property ;
    rdfs:label 'Reading Range Min' ;
    rdfs:comment 'Minimum valid reading value for this meter as defined by the instrument\'s operating range or process design limits. Readings below this value are flagged as suspect. For example, 0 PSI minimum for a pressure transducer.' ;
    rdfs:domain ind:AssetMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:readingSource rdf:type rdf:Property ;
    rdfs:label 'Reading Source' ;
    rdfs:comment 'The system or method by which the current meter reading was captured. SCADA: from Supervisory Control and Data Acquisition system. PI_HISTORIAN: from OSIsoft PI Historian automated feed. MANUAL: entered manually by a technician in IBM Maximo. AMI: from Advanced Metering Infrastructure. CMMS_IMPORT: batch import from CMMS. FIELD_DEVICE: direct PLC/RTU feed.' ;
    rdfs:domain ind:AssetMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Code' ;
    rdfs:comment 'The regulatory parameter code or identifier associated with this meter for compliance reporting submissions, e.g., EPA DMR parameter code, NPDES permit parameter identifier, or state drinking water program monitoring code. Null if is_regulatory_meter is False.' ;
    rdfs:domain ind:AssetMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Free-text field for operational notes, technician observations, or special instructions related to this meter. For example, notes about known reading anomalies, temporary bypass conditions, or pending replacement. Sourced from IBM Maximo meter remarks field.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rolloverValue rdf:type rdf:Property ;
    rdfs:label 'Rollover Value' ;
    rdfs:comment 'The maximum value the meter counter can reach before rolling over to zero. Applicable to CONTINUOUS meters with fixed-digit displays (e.g., 99999.9 hours). Used to correctly compute cumulative usage across rollover events. Null if the meter has no rollover limit.' ;
    rdfs:domain ind:AssetMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapMeasuringPointCode rdf:type rdf:Property ;
    rdfs:label 'Sap Measuring Point Code' ;
    rdfs:comment 'The measuring point identifier from SAP Plant Maintenance (PM) module corresponding to this asset meter. Enables reconciliation between IBM Maximo CMMS and SAP PM for assets managed across both systems.' ;
    rdfs:domain ind:AssetMeter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Manufacturer\'s serial number uniquely identifying the physical meter instrument. Used for warranty claims, calibration certificates, and asset tracking.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp when the asset meter record was most recently modified in the enterprise data platform. Used for change tracking, incremental data loads, and audit compliance. Formatted as yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:parentAssetRegistryId rdf:type rdf:Property ;
    rdfs:label 'Parent Asset Registry Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent asset in the asset hierarchy (e.g., a pump impeller\'s parent is the pump assembly; the pump assembly\'s parent is the pump station). Enables parent-child asset hierarchy navigation for maintenance cost roll-up and condition assessment aggregation. Null for top-level assets.' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Registry .

ind:procurementContractId rdf:type rdf:Property ;
    rdfs:label 'Procurement Contract Id' ;
    rdfs:comment 'Foreign key linking to supply.procurement_contract. Business justification: Critical assets (SCADA systems, treatment equipment, pump stations) often have long-term service/maintenance contracts. Links enable contract compliance tracking, SLA monitoring, preventive maintenanc' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcurementContract .

ind:serviceAddressId rdf:type rdf:Property ;
    rdfs:label 'Service Address Id' ;
    rdfs:comment 'Foreign key linking to customer.service_address. Business justification: Distribution assets (hydrants, valves, mains) serve specific service addresses. Critical for emergency response, outage notifications, GIS integration, and customer impact analysis during main breaks ' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceAddress .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'Original purchase or construction cost of the asset in US dollars at the time of acquisition. Represents the capitalized cost basis used for depreciation calculations and fixed asset register reporting. Sourced from SAP FI/CO asset accounting module. Required for GASB Statement No. 34 infrastructure asset reporting.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetName rdf:type rdf:Property ;
    rdfs:label 'Asset Name' ;
    rdfs:comment 'Human-readable name or short description of the asset (e.g., \'Raw Water Pump No. 3\', \'Influent Gate Valve 12-inch\', \'Chlorine Contact Basin Filter 2\'). Used as the primary display label in CMMS, GIS, and reporting interfaces.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTag rdf:type rdf:Property ;
    rdfs:label 'Asset Tag' ;
    rdfs:comment 'Physical asset tag number (barcode, QR code, or RFID label) affixed to the asset in the field. Used by field technicians for asset identification during inspections, maintenance, and inventory audits. Corresponds to the Maximo asset tag field.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetType rdf:type rdf:Property ;
    rdfs:label 'Asset Type' ;
    rdfs:comment 'Sub-classification within the asset class providing more granular categorization (e.g., Centrifugal Pump, Gate Valve, Ductile Iron Pipe, AMI Smart Meter). Aligns with IBM Maximo asset type and SAP PM equipment category for maintenance planning and spare parts management.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Condition Assessment Date' ;
    rdfs:comment 'Date of the most recent formal condition assessment performed on the asset. Used to determine assessment currency and schedule the next inspection cycle. Condition assessments may be visual inspections, CCTV surveys, vibration analysis, or other diagnostic methods.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conditionGrade rdf:type rdf:Property ;
    rdfs:label 'Condition Grade' ;
    rdfs:comment 'Standardized condition rating of the asset based on the most recent condition assessment, using a 1-5 scale where 1=Excellent/New, 2=Good, 3=Fair, 4=Poor, 5=Very Poor/Failed. Aligned with AWWA and WEF condition assessment frameworks. Drives maintenance prioritization and renewal planning.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalityRating rdf:type rdf:Property ;
    rdfs:label 'Criticality Rating' ;
    rdfs:comment 'Risk-based criticality classification of the asset based on consequence of failure analysis (CoFA). \'critical\' assets have the highest consequence of failure impacting public health, regulatory compliance, or major service disruption. Used to prioritize maintenance resources, Capital Improvement Program (CIP) investments, and emergency response planning. Aligned with AWWA risk and resilience assessment methodology.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diameterMm rdf:type rdf:Property ;
    rdfs:label 'Diameter Mm' ;
    rdfs:comment 'Nominal diameter of the asset in millimeters. For pipes and valves, this is the internal bore diameter. For pumps, this is the discharge diameter. Used for hydraulic capacity calculations, spare parts specification, and network modeling in Innovyze InfoWater.' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:elevationM rdf:type rdf:Property ;
    rdfs:label 'Elevation M' ;
    rdfs:comment 'Elevation of the asset above mean sea level in meters. Critical for hydraulic modeling, pressure zone assignment, and gravity-fed system design. Used in Innovyze InfoWater hydraulic models and Esri ArcGIS 3D network analysis.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedUsefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Expected Useful Life Years' ;
    rdfs:comment 'The estimated total useful life of the asset in years as defined by engineering standards, manufacturer specifications, or utility policy. Used for depreciation calculations, Capital Improvement Program (CIP) planning, and asset renewal forecasting. Aligns with GASB Statement No. 34 infrastructure reporting requirements.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isLeadServiceLine rdf:type rdf:Property ;
    rdfs:label 'Is Lead Service Line' ;
    rdfs:comment 'Indicates whether this asset is a lead service line or contains lead components. Critical for compliance with the EPA Lead and Copper Rule Revisions (LCRR) which requires utilities to inventory and replace lead service lines. True = confirmed lead service line; False = non-lead or unknown.' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date of the most recently completed maintenance activity (preventive or corrective) performed on this asset. Used to calculate maintenance intervals, identify overdue assets, and support compliance reporting for regulatory-mandated maintenance activities.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufactureDate rdf:type rdf:Property ;
    rdfs:label 'Manufacture Date' ;
    rdfs:comment 'Date the asset was manufactured by the OEM. May differ from installation date for assets stored in inventory before deployment. Used for age-based condition assessment and manufacturer warranty calculations.' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modelNum rdf:type rdf:Property ;
    rdfs:label 'Model Num' ;
    rdfs:comment 'Manufacturer\'s model or product number for the asset (e.g., \'LF 3196 STX\', \'NK 65-200\'). Used for spare parts identification, technical documentation retrieval, and procurement of replacement units. Sourced from IBM Maximo model field.' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Date' ;
    rdfs:comment 'Date on which the next scheduled preventive maintenance activity is due for this asset. Derived from the PM schedule and last maintenance date. Used for maintenance planning, resource scheduling, and compliance tracking in IBM Maximo.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current operational lifecycle state of the asset. \'in_service\' indicates the asset is active and performing its intended function. \'standby\' indicates the asset is available but not currently operating. \'out_of_service\' indicates the asset is temporarily removed from service for maintenance or repair. \'decommissioned\' indicates permanent retirement. Drives maintenance scheduling and regulatory reporting.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipeMaterial rdf:type rdf:Property ;
    rdfs:label 'Pipe Material' ;
    rdfs:comment 'Material composition of the asset (e.g., Ductile Iron, PVC, HDPE, Cast Iron, Concrete, Stainless Steel, Copper). Critical for corrosion risk assessment, Lead and Copper Rule Revisions (LCRR) compliance, Cured-in-Place Pipe (CIPP) rehabilitation planning, and remaining useful life estimation. Applicable primarily to pipe and fitting assets.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmScheduleId rdf:type rdf:Property ;
    rdfs:label 'Pm Schedule Id' ;
    rdfs:comment 'Reference to the preventive maintenance schedule record in IBM Maximo that governs recurring maintenance activities for this asset. Links the asset to its O&M (Operations and Maintenance) task plans, frequencies, and resource requirements.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PmSchedule .

ind:powerRatingKw rdf:type rdf:Property ;
    rdfs:label 'Power Rating Kw' ;
    rdfs:comment 'Nameplate power rating of the asset in kilowatts (kW). Applicable to pumps, blowers, motors, generators, and other electrical equipment. Used for energy consumption analysis, Variable Frequency Drive (VFD) sizing, electrical load planning, and OPEX budgeting.' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratedCapacity rdf:type rdf:Property ;
    rdfs:label 'Rated Capacity' ;
    rdfs:comment 'The manufacturer-rated operational capacity of the asset expressed in the appropriate unit of measure (see capacity_unit field). For pumps: Gallons per Minute (GPM); for treatment units: Million Gallons per Day (MGD); for tanks: gallons. Used for capacity planning, hydraulic modeling, and performance benchmarking.' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryAssetCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Asset Code' ;
    rdfs:comment 'Asset identifier assigned by a regulatory authority (e.g., state drinking water program, EPA) for compliance tracking and reporting purposes. Used in regulatory submissions such as the Consumer Confidence Report (CCR), Discharge Monitoring Report (DMR), and NPDES permit compliance documentation.' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementCost rdf:type rdf:Property ;
    rdfs:label 'Replacement Cost' ;
    rdfs:comment 'Current estimated cost to replace the asset with a new equivalent unit in US dollars. Updated periodically based on market pricing and engineering estimates. Used for Capital Improvement Program (CIP) budgeting, insurance valuation, and risk-based asset management decision-making.' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scadaTag rdf:type rdf:Property ;
    rdfs:label 'Scada Tag' ;
    rdfs:comment 'The Supervisory Control and Data Acquisition (SCADA) tag name used to identify this asset\'s data point(s) in the OSIsoft PI Historian system. Enables linkage between the physical asset registry and real-time operational data streams for performance monitoring, alarm management, and predictive maintenance analytics.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNum rdf:type rdf:Property ;
    rdfs:label 'Serial Num' ;
    rdfs:comment 'Unique serial number assigned by the manufacturer to this specific asset unit. Used for warranty claims, recall tracking, and precise asset identification when multiple identical units exist. Sourced from IBM Maximo serial number field.' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyId rdf:type rdf:Property ;
    rdfs:label 'Warranty Id' ;
    rdfs:comment 'Unique system-generated identifier for each asset warranty record in the enterprise asset management system. Primary key for the asset_warranty data product.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:constructionContractId rdf:type rdf:Property ;
    rdfs:label 'Construction Contract Id' ;
    rdfs:comment 'Foreign key linking to project.construction_contract. Business justification: Equipment warranties originate from construction contracts; warranty claim processing, vendor accountability, and performance bond claims require direct reference to the construction contract that spe' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConstructionContract .

ind:claimResponseDays rdf:type rdf:Property ;
    rdfs:label 'Claim Response Days' ;
    rdfs:comment 'Contractually committed number of calendar days within which the vendor must respond to a submitted warranty claim. Used for SLA monitoring and vendor performance management.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimSubmissionProcess rdf:type rdf:Property ;
    rdfs:label 'Claim Submission Process' ;
    rdfs:comment 'Description of the required process for submitting a warranty claim, including required documentation, submission channel (e.g., vendor portal URL, email, phone), and any pre-authorization requirements. Ensures maintenance staff follow correct procedures.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimedAmountToDate rdf:type rdf:Property ;
    rdfs:label 'Claimed Amount To Date' ;
    rdfs:comment 'Cumulative monetary value of all warranty claims submitted against this warranty record to date, expressed in USD. Used to track remaining claim capacity against the maximum claim value.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentCovered rdf:type rdf:Property ;
    rdfs:label 'Component Covered' ;
    rdfs:comment 'Specific sub-component or assembly of the asset covered by this warranty record (e.g., \'motor winding\', \'pump impeller\', \'control panel\', \'membrane module\'). A single asset may have multiple warranty records covering different components.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'The vendor-issued or internally-assigned contract number governing the warranty terms and conditions. Used for legal reference and claim dispute resolution.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageEndDate rdf:type rdf:Property ;
    rdfs:label 'Coverage End Date' ;
    rdfs:comment 'The date on which warranty coverage expires. Proactive monitoring of this date enables timely claim submission and maintenance routing through warranty channels before expiration, reducing OPEX.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageScope rdf:type rdf:Property ;
    rdfs:label 'Coverage Scope' ;
    rdfs:comment 'Narrative description of what is covered under this warranty, including specific components, failure modes, and exclusions. For example: \'Covers all mechanical and electrical components of the centrifugal pump excluding wear parts (seals, impellers) and damage caused by cavitation or improper operation.\'' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageStartDate rdf:type rdf:Property ;
    rdfs:label 'Coverage Start Date' ;
    rdfs:comment 'The date on which warranty coverage becomes effective. Typically aligned with the asset installation date, commissioning date, or purchase date depending on warranty terms.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:durationMonths rdf:type rdf:Property ;
    rdfs:label 'Duration Months' ;
    rdfs:comment 'Total length of the warranty coverage period expressed in months. Derived from the vendor contract terms and used for planning and renewal tracking.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exclusions rdf:type rdf:Property ;
    rdfs:label 'Exclusions' ;
    rdfs:comment 'Explicit list of conditions, components, or failure modes NOT covered by this warranty. Critical for maintenance routing decisions to avoid voiding coverage through excluded repair activities.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryAlertDays rdf:type rdf:Property ;
    rdfs:label 'Expiry Alert Days' ;
    rdfs:comment 'Number of calendar days before the coverage end date at which an automated alert should be triggered to notify asset managers and maintenance planners of impending warranty expiration. Enables proactive claim submission and maintenance routing.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:extendedWarrantyCost rdf:type rdf:Property ;
    rdfs:label 'Extended Warranty Cost' ;
    rdfs:comment 'The cost paid to purchase an extended warranty beyond the standard manufacturer warranty period, expressed in USD. Captured for CAPEX/OPEX planning and ROI analysis of extended warranty investments.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxClaimValue rdf:type rdf:Property ;
    rdfs:label 'Max Claim Value' ;
    rdfs:comment 'The maximum cumulative monetary value of claims that can be submitted under this warranty agreement, expressed in USD. Enables OPEX planning and ensures claims do not exceed contractual limits.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximoWarrantyCode rdf:type rdf:Property ;
    rdfs:label 'Maximo Warranty Code' ;
    rdfs:comment 'The native warranty record identifier from IBM Maximo Asset Management (CMMS). Retained as a cross-reference key to enable bidirectional traceability between the lakehouse silver layer and the operational CMMS source system.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceGuaranteeMetric rdf:type rdf:Property ;
    rdfs:label 'Performance Guarantee Metric' ;
    rdfs:comment 'For performance-type warranties, the specific operational metric that is guaranteed (e.g., \'pump flow rate >= 500 GPM\', \'motor efficiency >= 92%\', \'membrane rejection rate >= 99%\'). Null for parts/labor-only warranties.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceGuaranteeThreshold rdf:type rdf:Property ;
    rdfs:label 'Performance Guarantee Threshold' ;
    rdfs:comment 'The minimum or target numeric value of the performance guarantee metric that the asset must achieve under the warranty. For example, 500 (GPM) or 92 (%). Used to trigger performance warranty claims when asset output falls below the guaranteed level.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceGuaranteeUnit rdf:type rdf:Property ;
    rdfs:label 'Performance Guarantee Unit' ;
    rdfs:comment 'Unit of measure for the performance guarantee threshold value (e.g., GPM, MGD, PSI, %, NTU). Ensures correct interpretation of the numeric threshold in the context of the guaranteed metric.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseDate rdf:type rdf:Property ;
    rdfs:label 'Purchase Date' ;
    rdfs:comment 'The date the asset or component was purchased. Some warranties are triggered from purchase date rather than installation date; retained for accurate coverage period calculation.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'The SAP purchase order number associated with the original procurement of the asset or component. Links the warranty to the procurement transaction for audit and claim substantiation.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'The date the warranty was formally registered with the vendor or manufacturer. Some warranties require registration within a specified period post-purchase to be valid; failure to register may void coverage.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalOption rdf:type rdf:Property ;
    rdfs:label 'Renewal Option' ;
    rdfs:comment 'Indicates whether the warranty agreement includes an option to renew or extend coverage beyond the original expiration date. If True, renewal terms and pricing should be captured in the coverage_scope field.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresOemService rdf:type rdf:Property ;
    rdfs:label 'Requires Oem Service' ;
    rdfs:comment 'Indicates whether the warranty terms require that all maintenance and repair work be performed exclusively by the original equipment manufacturer (OEM) or an OEM-authorized service provider. If True, routing non-OEM technicians to this asset may void the warranty.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapPmOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Pm Order Number' ;
    rdfs:comment 'The SAP PM maintenance order number associated with warranty-covered repair or maintenance work. Links warranty coverage to the SAP PM work order for cost recovery and OPEX tracking.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferable rdf:type rdf:Property ;
    rdfs:label 'Transferable' ;
    rdfs:comment 'Indicates whether this warranty can be transferred to a new owner or operator in the event of asset sale, transfer, or organizational restructuring. Relevant for capital project asset handovers.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorContactEmail rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Email' ;
    rdfs:comment 'Email address for the designated warranty claims contact at the vendor or manufacturer. Used for formal claim submission and written correspondence.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContactName rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Name' ;
    rdfs:comment 'Name of the designated warranty claims contact person at the vendor or manufacturer organization. Used to initiate and follow up on warranty claims.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContactPhone rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Phone' ;
    rdfs:comment 'Phone number for the designated warranty claims contact at the vendor or manufacturer. Used to initiate and follow up on warranty claims.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyNumber rdf:type rdf:Property ;
    rdfs:label 'Warranty Number' ;
    rdfs:comment 'Externally-known warranty certificate or agreement number assigned by the vendor or manufacturer. Used for claim submission and correspondence with the warranty provider. Aligns with IBM Maximo warranty record identifier.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyStatus rdf:type rdf:Property ;
    rdfs:label 'Warranty Status' ;
    rdfs:comment 'Current lifecycle state of the warranty record. \'active\' indicates coverage is in force; \'expired\' indicates the coverage period has ended; \'claimed\' indicates a claim has been submitted and is under review; \'voided\' indicates the warranty was invalidated (e.g., unauthorized repair); \'pending_activation\' indicates the warranty has been registered but the coverage period has not yet started.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyType rdf:type rdf:Property ;
    rdfs:label 'Warranty Type' ;
    rdfs:comment 'Classification of the warranty coverage scope. \'parts\' covers replacement components only; \'labor\' covers repair labor costs; \'performance\' guarantees operational output levels (e.g., pump flow rate, motor efficiency); \'comprehensive\' covers both parts and labor; \'extended\' is a purchased extension beyond the original term; \'manufacturer\' is the standard OEM warranty.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Condition Assessment Id' ;
    rdfs:comment 'Unique identifier for the condition assessment record. Primary key.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConditionAssessment .

ind:analyticalResultId rdf:type rdf:Property ;
    rdfs:label 'Analytical Result Id' ;
    rdfs:comment 'Foreign key linking to quality.analytical_result. Business justification: Condition assessments for pipes, coatings, and linings often reference supporting lab analysis results (corrosion testing, material integrity tests). Real business need: linking physical asset conditi' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AnalyticalResult .

ind:approvedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approved By Employee Id' ;
    rdfs:comment 'Reference to the manager or authority who approved the assessment and recommended actions.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:billingRateScheduleId rdf:type rdf:Property ;
    rdfs:label 'Billing Rate Schedule Id' ;
    rdfs:comment 'Foreign key linking to billing.rate_schedule. Business justification: Asset condition assessments inform rate case filings and infrastructure replacement rate schedules. Required for rate case asset condition documentation, infrastructure surcharge justification (e.g., ' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingRateSchedule .

ind:employeeId rdf:type rdf:Property ;
    rdfs:label 'Employee Id' ;
    rdfs:comment 'Reference to the employee or contractor who performed the condition assessment.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:gisLocationId rdf:type rdf:Property ;
    rdfs:label 'Gis Location Id' ;
    rdfs:comment 'Reference to the asset location in the Geographic Information System (GIS), enabling spatial analysis and mapping of condition assessment results.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:labSampleId rdf:type rdf:Property ;
    rdfs:label 'Lab Sample Id' ;
    rdfs:comment 'Foreign key linking to laboratory.lab_sample. Business justification: Condition assessments routinely require laboratory analysis of pipe scale, corrosion products, coating degradation, and material samples. Essential for determining remaining useful life and failure ro' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabSample .

ind:primaryConditionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Condition Employee Id' ;
    rdfs:comment 'Reference to the employee or contractor who performed the condition assessment.' ;
    rdfs:domain ind:ConditionAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reviewedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reviewed By Employee Id' ;
    rdfs:comment 'Reference to the supervisor or engineer who reviewed and validated the assessment findings.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryConditionApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Condition Approved By Employee Id' ;
    rdfs:comment 'Reference to the manager or authority who approved the assessment and recommended actions.' ;
    rdfs:domain ind:ConditionAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:workOrderId rdf:type rdf:Property ;
    rdfs:label 'Work Order Id' ;
    rdfs:comment 'Reference to the work order under which this condition assessment was performed, if applicable.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'The date on which the condition assessment was performed in the field.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentIntervalMonths rdf:type rdf:Property ;
    rdfs:label 'Assessment Interval Months' ;
    rdfs:comment 'Standard inspection frequency interval in months for this asset type and condition grade.' ;
    rdfs:domain ind:ConditionAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assessment Method' ;
    rdfs:comment 'The inspection or testing method used to assess asset condition. Common methods include visual inspection, Closed-Circuit Television (CCTV) for pipes, acoustic leak detection, vibration analysis for rotating equipment, ultrasonic thickness measurement for corrosion, infrared thermography for electrical systems, and various hydraulic testing methods. [ENUM-REF-CANDIDATE: visual|cctv|acoustic|vibration_analysis|ultrasonic_thickness|infrared_thermography|dye_testing|smoke_testing|pressure_testing|flow_testing|electrical_testing|corrosion_survey — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Number' ;
    rdfs:comment 'Business identifier for the condition assessment, typically generated by the Computerized Maintenance Management System (CMMS) or inspection system.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assessment Status' ;
    rdfs:comment 'Current workflow status of the condition assessment record: scheduled, in progress, completed (field work done), reviewed (technical review complete), approved (management sign-off), or cancelled.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assessment Timestamp' ;
    rdfs:comment 'Precise date and time when the condition assessment was completed, including time zone information.' ;
    rdfs:domain ind:ConditionAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assessmentType rdf:type rdf:Property ;
    rdfs:label 'Assessment Type' ;
    rdfs:comment 'Classification of the assessment purpose: routine scheduled inspection, preventive maintenance assessment, reactive inspection following an incident, condition-based monitoring, regulatory compliance inspection, pre-failure investigation, post-repair verification, or new asset commissioning. [ENUM-REF-CANDIDATE: routine|preventive|reactive|condition_based|regulatory|pre_failure|post_repair|commissioning — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConditionAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalDefectCount rdf:type rdf:Property ;
    rdfs:label 'Critical Defect Count' ;
    rdfs:comment 'Number of critical or high-severity defects requiring immediate attention or corrective action.' ;
    rdfs:domain ind:ConditionAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectCount rdf:type rdf:Property ;
    rdfs:label 'Defect Count' ;
    rdfs:comment 'Total number of defects, anomalies, or non-conformances identified during the condition assessment.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectDescription rdf:type rdf:Property ;
    rdfs:label 'Defect Description' ;
    rdfs:comment 'Detailed narrative description of defects, damage, deterioration, or performance issues observed during the assessment.' ;
    rdfs:domain ind:ConditionAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedRepairCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Repair Cost' ;
    rdfs:comment 'Preliminary cost estimate for recommended repair or rehabilitation work, used for Capital Expenditure (CAPEX) and Operating Expenditure (OPEX) planning.' ;
    rdfs:domain ind:ConditionAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedReplacementCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Replacement Cost' ;
    rdfs:comment 'Estimated cost to fully replace the asset with equivalent new equipment or infrastructure.' ;
    rdfs:domain ind:ConditionAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failureProbability rdf:type rdf:Property ;
    rdfs:label 'Failure Probability' ;
    rdfs:comment 'Statistical probability (0.0000 to 1.0000) of asset failure within the next planning period, calculated from condition data, age, and historical failure rates.' ;
    rdfs:domain ind:ConditionAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionEquipmentUsed rdf:type rdf:Property ;
    rdfs:label 'Inspection Equipment Used' ;
    rdfs:comment 'Description of specialized equipment, instruments, or tools used during the assessment (e.g., CCTV crawler, ultrasonic thickness gauge, vibration analyzer, acoustic leak detector).' ;
    rdfs:domain ind:ConditionAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorCertification rdf:type rdf:Property ;
    rdfs:label 'Inspector Certification' ;
    rdfs:comment 'Professional certifications held by the inspector relevant to the assessment method (e.g., NASSCO PACP/MACP/LACP for pipeline inspection, ASNT Level II for ultrasonic testing, thermography certification).' ;
    rdfs:domain ind:ConditionAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorName rdf:type rdf:Property ;
    rdfs:label 'Inspector Name' ;
    rdfs:comment 'Full name of the inspector or technician who conducted the assessment.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'System timestamp when this condition assessment record was last updated.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nextAssessmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Assessment Due Date' ;
    rdfs:comment 'Scheduled date for the next condition assessment based on asset criticality, condition grade, and inspection frequency requirements.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceScore rdf:type rdf:Property ;
    rdfs:label 'Performance Score' ;
    rdfs:comment 'Quantitative score (0-100 scale) representing the operational performance and efficiency of the asset relative to design specifications.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedAction rdf:type rdf:Property ;
    rdfs:label 'Recommended Action' ;
    rdfs:comment 'Recommended intervention strategy based on assessment findings: continue monitoring, schedule repair, plan rehabilitation, schedule replacement, no action required, or emergency repair needed.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedActionPriority rdf:type rdf:Property ;
    rdfs:label 'Recommended Action Priority' ;
    rdfs:comment 'Priority level for the recommended intervention: immediate (0-30 days), urgent (1-6 months), high (6-12 months), medium (1-3 years), low (3+ years).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flag' ;
    rdfs:comment 'Indicates whether this assessment was performed to satisfy regulatory inspection requirements from Environmental Protection Agency (EPA), state primacy agencies, or other governing bodies.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remainingUsefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Remaining Useful Life Years' ;
    rdfs:comment 'Estimated number of years the asset can continue to operate before requiring major rehabilitation or replacement, based on current condition and deterioration rate.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Composite risk score calculated as the product of failure probability and consequence of failure, used to prioritize asset renewal and Capital Improvement Program (CIP) planning.' ;
    rdfs:domain ind:ConditionAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:structuralIntegrityScore rdf:type rdf:Property ;
    rdfs:label 'Structural Integrity Score' ;
    rdfs:comment 'Quantitative score (0-100 scale) representing the structural soundness of the asset based on inspection findings. Higher scores indicate better structural condition.' ;
    rdfs:domain ind:ConditionAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weatherConditions rdf:type rdf:Property ;
    rdfs:label 'Weather Conditions' ;
    rdfs:comment 'Weather conditions at the time of assessment, relevant for outdoor inspections and certain testing methods.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalityRatingId rdf:type rdf:Property ;
    rdfs:label 'Criticality Rating Id' ;
    rdfs:comment 'Unique identifier for the criticality rating record. Primary key for the criticality rating entity.' ;
    rdfs:domain ind:CriticalityRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentPerformedBy rdf:type rdf:Property ;
    rdfs:label 'Assessment Performed By' ;
    rdfs:comment 'Name or identifier of the person, team, or system that performed the criticality assessment. Supports audit trail and accountability for rating decisions.' ;
    rdfs:domain ind:CriticalityRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalRenewalPriorityRank rdf:type rdf:Property ;
    rdfs:label 'Capital Renewal Priority Rank' ;
    rdfs:comment 'Relative priority ranking for capital renewal or replacement within the asset portfolio. Lower numbers indicate higher priority. Derived from criticality tier and overall risk score.' ;
    rdfs:domain ind:CriticalityRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cipEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Cip Eligibility Flag' ;
    rdfs:comment 'Indicates whether this asset is eligible for inclusion in the Capital Improvement Program based on its criticality rating and condition. True if eligible for CIP funding consideration.' ;
    rdfs:domain ind:CriticalityRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consequenceOfFailureScore rdf:type rdf:Property ;
    rdfs:label 'Consequence Of Failure Score' ;
    rdfs:comment 'Quantitative score representing the business, operational, safety, environmental, and regulatory impact if the asset fails. Typically scaled 1-100 or 1-10 depending on methodology.' ;
    rdfs:domain ind:CriticalityRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerImpactCount rdf:type rdf:Property ;
    rdfs:label 'Customer Impact Count' ;
    rdfs:comment 'Estimated number of customers or service connections that would be affected by failure of this asset. Used to quantify consequence of failure for distribution and collection system assets.' ;
    rdfs:domain ind:CriticalityRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:environmentalImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Flag' ;
    rdfs:comment 'Indicates whether failure of this asset would result in environmental harm such as discharge of untreated wastewater, contamination of water sources, or SSO/CSO events. True if environmental impact is likely.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'Estimated financial consequence of asset failure including emergency repair costs, lost revenue, regulatory fines, and liability claims. Expressed in USD.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:likelihoodOfFailureScore rdf:type rdf:Property ;
    rdfs:label 'Likelihood Of Failure Score' ;
    rdfs:comment 'Quantitative score representing the probability of asset failure based on age, condition, maintenance history, and operating environment. Typically scaled 1-100 or 1-10 depending on methodology.' ;
    rdfs:domain ind:CriticalityRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:methodologyVersion rdf:type rdf:Property ;
    rdfs:label 'Methodology Version' ;
    rdfs:comment 'Version identifier of the criticality assessment methodology used to calculate this rating. Enables tracking of methodology changes over time and ensures consistent application across asset portfolio.' ;
    rdfs:domain ind:CriticalityRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next criticality reassessment. Critical assets typically require more frequent review cycles than low-criticality assets.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overallRiskScore rdf:type rdf:Property ;
    rdfs:label 'Overall Risk Score' ;
    rdfs:comment 'Composite risk score calculated from Consequence of Failure and Likelihood of Failure scores. Typically computed as CoF × LoF. Used to rank assets for maintenance and capital investment prioritization.' ;
    rdfs:domain ind:CriticalityRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preventiveMaintenanceFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Preventive Maintenance Frequency Days' ;
    rdfs:comment 'Recommended interval in days between preventive maintenance activities based on the criticality tier. Critical assets require more frequent PM than low-criticality assets.' ;
    rdfs:domain ind:CriticalityRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publicHealthImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Public Health Impact Flag' ;
    rdfs:comment 'Indicates whether failure of this asset would pose a direct threat to public health through loss of water supply, water quality degradation, or exposure to contaminants. True if public health risk exists.' ;
    rdfs:domain ind:CriticalityRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ratingEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Rating Effective Date' ;
    rdfs:comment 'The date from which this criticality rating becomes effective and is used for maintenance prioritization and capital planning decisions.' ;
    rdfs:domain ind:CriticalityRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratingExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Rating Expiration Date' ;
    rdfs:comment 'The date when this criticality rating expires and must be reassessed. Nullable for ratings without a defined review cycle.' ;
    rdfs:domain ind:CriticalityRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratingStatus rdf:type rdf:Property ;
    rdfs:label 'Rating Status' ;
    rdfs:comment 'Current lifecycle status of the criticality rating record. Active ratings are used for operational decisions; superseded ratings are retained for historical analysis.' ;
    rdfs:domain ind:CriticalityRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redundancyAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Redundancy Available Flag' ;
    rdfs:comment 'Indicates whether backup or redundant assets are available to maintain service if this asset fails. True if redundancy exists, False if asset is a single point of failure.' ;
    rdfs:domain ind:CriticalityRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryConsequenceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Consequence Flag' ;
    rdfs:comment 'Indicates whether failure of this asset would result in regulatory non-compliance, permit violations, or mandatory reporting under SDWA, CWA, or NPDES. True if regulatory consequences exist.' ;
    rdfs:domain ind:CriticalityRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Impact Flag' ;
    rdfs:comment 'Indicates whether failure of this asset would create safety hazards for employees, contractors, or the public (e.g., chemical release, electrical hazard, structural collapse). True if safety risk exists.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceDisruptionDurationHours rdf:type rdf:Property ;
    rdfs:label 'Service Disruption Duration Hours' ;
    rdfs:comment 'Estimated duration in hours that service would be disrupted if this asset fails, accounting for repair time, parts availability, and system restoration procedures.' ;
    rdfs:domain ind:CriticalityRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depreciationScheduleId rdf:type rdf:Property ;
    rdfs:label 'Depreciation Schedule Id' ;
    rdfs:comment 'Unique system-generated identifier for the depreciation schedule record. Primary key for this entity.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Fixed Asset Id' ;
    rdfs:comment 'Foreign key linking to finance.fixed_asset. Business justification: Depreciation schedules calculate periodic depreciation expense for fixed assets. Direct link supports automated depreciation posting, GASB 34 infrastructure reporting, and rate base calculations for u' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:annualDepreciationAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Depreciation Amount' ;
    rdfs:comment 'The total depreciation expense allocated for the full fiscal year for this asset. For straight-line method: depreciable_base / useful_life_years. Expressed in USD.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetClassCode rdf:type rdf:Property ;
    rdfs:label 'Asset Class Code' ;
    rdfs:comment 'SAP FI-AA asset class code categorizing the type of capital asset for depreciation area assignment and useful life defaults (e.g., \'PUMP\', \'PIPE\', \'BLDG\', \'VEHICLE\', \'ELEC\', \'METER\').' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Description' ;
    rdfs:comment 'Human-readable description of the capital asset being depreciated (e.g., \'WTP High-Service Pump Unit 3\', \'WWTP Aeration Blower\', \'12-inch Ductile Iron Main - Oak Street\').' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetLocationCode rdf:type rdf:Property ;
    rdfs:label 'Asset Location Code' ;
    rdfs:comment 'Functional location or facility code where the asset is installed (e.g., WTP facility code, WWTP unit, pump station ID, distribution zone). Aligns with IBM Maximo functional location hierarchy and Esri ArcGIS GIS asset registry.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'The externally-known fixed asset number as assigned in SAP FI/CO Fixed Asset Accounting (FI-AA) or IBM Maximo. Used for cross-system reconciliation and audit trails.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capexProjectNumber rdf:type rdf:Property ;
    rdfs:label 'Capex Project Number' ;
    rdfs:comment 'The Capital Improvement Program (CIP) project number associated with the asset\'s acquisition or construction. Links depreciation schedules to CAPEX planning and project close-out reporting.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationDate rdf:type rdf:Property ;
    rdfs:label 'Capitalization Date' ;
    rdfs:comment 'The date the asset was formally capitalized and transferred from construction-in-progress (CIP) to fixed assets in SAP FI-AA. May differ from depreciation start date for assets with a commissioning lag.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'SAP FI company code representing the legal entity or municipal utility enterprise to which this depreciation schedule belongs. Supports multi-entity financial reporting and GASB fund accounting.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'SAP CO cost center to which depreciation charges are posted, enabling OPEX/CAPEX allocation by operational unit (e.g., WTP operations, distribution, wastewater).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decliningBalanceRate rdf:type rdf:Property ;
    rdfs:label 'Declining Balance Rate' ;
    rdfs:comment 'The percentage rate applied per period for declining balance or double declining balance depreciation methods. Expressed as a decimal (e.g., 0.2000 = 20%). Null for straight-line method.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depreciableBase rdf:type rdf:Property ;
    rdfs:label 'Depreciable Base' ;
    rdfs:comment 'The amount subject to depreciation, calculated as acquisition cost minus salvage value. This is the total amount to be allocated over the asset\'s useful life. Expressed in USD.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depreciationAreaCode rdf:type rdf:Property ;
    rdfs:label 'Depreciation Area Code' ;
    rdfs:comment 'SAP FI-AA depreciation area identifier representing the valuation purpose (e.g., \'01\' for book depreciation per GAAP/GASB, \'15\' for tax depreciation, \'20\' for cost accounting). Supports parallel valuation for regulatory and tax reporting.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationConvention rdf:type rdf:Property ;
    rdfs:label 'Depreciation Convention' ;
    rdfs:comment 'The period convention applied to determine depreciation in the first and last year of the asset\'s life (e.g., full_month, half_year, pro_rata). Aligns with SAP FI-AA period control settings.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationEndDate rdf:type rdf:Property ;
    rdfs:label 'Depreciation End Date' ;
    rdfs:comment 'The projected or actual date on which depreciation ceases, corresponding to the end of the asset\'s useful life or full depreciation of the depreciable base.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depreciationKey rdf:type rdf:Property ;
    rdfs:label 'Depreciation Key' ;
    rdfs:comment 'SAP FI-AA depreciation key code that defines the calculation method, period control, and base value for depreciation posting (e.g., \'LINR\' for straight-line, \'0000\' for no depreciation). Enables direct reconciliation with SAP Fixed Asset Accounting.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationStartDate rdf:type rdf:Property ;
    rdfs:label 'Depreciation Start Date' ;
    rdfs:comment 'The date on which depreciation begins for the asset, typically the in-service date or acquisition date per GAAP/GASB capitalization policy.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalProceeds rdf:type rdf:Property ;
    rdfs:label 'Disposal Proceeds' ;
    rdfs:comment 'Cash or fair value received upon disposal or sale of the asset. Used to calculate gain or loss on disposal: disposal_proceeds minus net_book_value at disposal date. Expressed in USD.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'The accounting period (month 1–12) within the fiscal year for which this depreciation record applies. Enables monthly depreciation posting and period-end close reconciliation in SAP FI/CO.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'The fiscal year to which this depreciation schedule record applies. Supports annual depreciation posting, CAPEX/OPEX reporting, and GASB financial statement preparation.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fundCode rdf:type rdf:Property ;
    rdfs:label 'Fund Code' ;
    rdfs:comment 'Governmental fund code (e.g., Enterprise Fund, Capital Projects Fund) to which the asset and its depreciation are attributed, per GASB fund accounting requirements for municipal utilities.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impairmentLoss rdf:type rdf:Property ;
    rdfs:label 'Impairment Loss' ;
    rdfs:comment 'Cumulative impairment charges recognized against the asset when its carrying value exceeds its recoverable amount, per GAAP ASC 360 impairment testing. Reduces net book value beyond scheduled depreciation. Expressed in USD.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inServiceDate rdf:type rdf:Property ;
    rdfs:label 'In Service Date' ;
    rdfs:comment 'The date the asset was placed into operational service. This is the trigger date for depreciation commencement per GAAP/GASB policy and aligns with IBM Maximo asset activation.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'Date the depreciation schedule was last reviewed and validated by the asset accounting team, supporting annual audit requirements and GASB financial statement preparation.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netBookValue rdf:type rdf:Property ;
    rdfs:label 'Net Book Value' ;
    rdfs:comment 'Current carrying value of the asset on the balance sheet, calculated as acquisition cost minus accumulated depreciation. Key metric for CAPEX/OPEX planning and asset renewal decisions. Expressed in USD.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodDepreciationAmount rdf:type rdf:Property ;
    rdfs:label 'Period Depreciation Amount' ;
    rdfs:comment 'The depreciation expense allocated for the specific fiscal period (month). Used for monthly journal entry posting to the depreciation expense account in SAP FI/CO. Expressed in USD.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'The timestamp when this depreciation schedule record was first created in the system, supporting audit trail and data lineage requirements.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'The timestamp when this depreciation schedule record was last modified, supporting change tracking, audit trail, and period-end reconciliation.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the depreciation schedule record. \'active\' = depreciation ongoing; \'suspended\' = temporarily halted (e.g., asset taken out of service); \'fully_depreciated\' = net book value at or near salvage value; \'disposed\' = asset retired; \'impaired\' = impairment recognized; \'draft\' = pending approval.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitsOfProductionPeriod rdf:type rdf:Property ;
    rdfs:label 'Units Of Production Period' ;
    rdfs:comment 'Actual production units consumed during the current fiscal period, used to calculate period depreciation under the units-of-production method (e.g., gallons pumped, operating hours logged via SCADA/OSIsoft PI Historian).' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitsOfProductionTotal rdf:type rdf:Property ;
    rdfs:label 'Units Of Production Total' ;
    rdfs:comment 'Total estimated production units over the asset\'s useful life, used as the denominator for units-of-production depreciation method (e.g., total gallons pumped, total operating hours). Applicable only when depreciation_method = \'units_of_production\'.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usefulLifeRevisedYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Revised Years' ;
    rdfs:comment 'Updated estimated useful life in years following a formal engineering reassessment or condition assessment. Replaces original useful_life_years for prospective depreciation calculation.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usefulLifeRevisionDate rdf:type rdf:Property ;
    rdfs:label 'Useful Life Revision Date' ;
    rdfs:comment 'Date on which the asset\'s estimated useful life was last revised, triggering a prospective change in depreciation calculation per GAAP ASC 250 change in accounting estimate.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wbsElement rdf:type rdf:Property ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'SAP PS Work Breakdown Structure element linking the asset to its originating Capital Improvement Program (CIP) project for CAPEX tracking and project settlement.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureRecordId rdf:type rdf:Property ;
    rdfs:label 'Failure Record Id' ;
    rdfs:comment 'Unique identifier for the asset failure event record. Primary key.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FailureRecord .

ind:premiseId rdf:type rdf:Property ;
    rdfs:label 'Premise Id' ;
    rdfs:comment 'Foreign key linking to customer.premise. Business justification: Failures of customer-side assets (service line breaks, meter malfunctions, lateral collapses) must be tracked to premises for customer impact analysis, regulatory reporting (e.g., lead service line fa' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Premise .

ind:reportedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reported By Employee Id' ;
    rdfs:comment 'Reference to the employee who reported or documented the failure event.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:waterSampleId rdf:type rdf:Property ;
    rdfs:label 'Water Sample Id' ;
    rdfs:comment 'Foreign key linking to quality.water_sample. Business justification: Asset failures (main breaks, tank overflows, pressure loss events) trigger mandatory water quality sampling per regulatory requirements (e.g., bacteriological sampling after pressure loss per TCR/RTCR' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WaterSample .

ind:actualRepairCost rdf:type rdf:Property ;
    rdfs:label 'Actual Repair Cost' ;
    rdfs:comment 'Actual total cost incurred to repair or replace the failed asset after work completion.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affectedSystem rdf:type rdf:Property ;
    rdfs:label 'Affected System' ;
    rdfs:comment 'The operational system or process affected by the failure (e.g., high service pump station, chlorination system, SCADA network, distribution main).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionsRecommended rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Recommended' ;
    rdfs:comment 'List of recommended corrective and preventive actions to prevent recurrence of similar failures.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csoEventFlag rdf:type rdf:Property ;
    rdfs:label 'Cso Event Flag' ;
    rdfs:comment 'Boolean flag indicating whether the failure resulted in a Combined Sewer Overflow event requiring regulatory reporting.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customersAffectedCount rdf:type rdf:Property ;
    rdfs:label 'Customers Affected Count' ;
    rdfs:comment 'Count of customer accounts impacted by the failure event (service interruption, pressure loss, water quality issue).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'Method by which the failure was discovered (SCADA alarm, operator inspection, customer complaint, etc.). [ENUM-REF-CANDIDATE: scada_alarm|operator_inspection|customer_complaint|scheduled_inspection|predictive_maintenance|routine_testing|emergency_response — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeDurationHours rdf:type rdf:Property ;
    rdfs:label 'Downtime Duration Hours' ;
    rdfs:comment 'Total duration in hours that the asset was out of service due to the failure.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emergencyResponseActions rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Actions' ;
    rdfs:comment 'Detailed description of immediate emergency response actions taken to mitigate the failure (e.g., valve isolation, backup system activation, customer notification).' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalImpactDescription rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Description' ;
    rdfs:comment 'Description of any environmental impact resulting from the failure (e.g., water body contamination, soil contamination, habitat damage).' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureCause rdf:type rdf:Property ;
    rdfs:label 'Failure Cause' ;
    rdfs:comment 'Identified root cause of the failure (e.g., age-related deterioration, improper installation, inadequate maintenance, design deficiency, operational error, external damage).' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureCriticalityScore rdf:type rdf:Property ;
    rdfs:label 'Failure Criticality Score' ;
    rdfs:comment 'Calculated criticality score based on failure severity, service impact, and asset importance (typically 1-100 scale).' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failureDate rdf:type rdf:Property ;
    rdfs:label 'Failure Date' ;
    rdfs:comment 'Calendar date when the asset failure occurred.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:failureEffect rdf:type rdf:Property ;
    rdfs:label 'Failure Effect' ;
    rdfs:comment 'Description of the operational impact and consequences of the failure on system performance and service delivery.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureMode rdf:type rdf:Property ;
    rdfs:label 'Failure Mode' ;
    rdfs:comment 'Classification of how the asset failed (e.g., mechanical fracture, electrical short, corrosion perforation, seal leakage, bearing seizure, control malfunction).' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureNumber rdf:type rdf:Property ;
    rdfs:label 'Failure Number' ;
    rdfs:comment 'Business-readable unique identifier for the failure event, typically auto-generated by CMMS.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureSeverity rdf:type rdf:Property ;
    rdfs:label 'Failure Severity' ;
    rdfs:comment 'Severity classification of the failure based on service impact, safety risk, and regulatory implications.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureStatus rdf:type rdf:Property ;
    rdfs:label 'Failure Status' ;
    rdfs:comment 'Current lifecycle status of the failure record in the investigation and resolution workflow.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureTime rdf:type rdf:Property ;
    rdfs:label 'Failure Time' ;
    rdfs:comment 'Precise date and time when the asset failure was detected or occurred.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mtbfImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Mtbf Impact Flag' ;
    rdfs:comment 'Boolean flag indicating whether this failure event should be included in MTBF reliability calculations for the asset class.' ;
    rdfs:domain ind:FailureRecord ;
