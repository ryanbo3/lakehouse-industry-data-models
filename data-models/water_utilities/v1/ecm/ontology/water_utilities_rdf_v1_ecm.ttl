    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:specialContractId rdf:type rdf:Property ;
    rdfs:label 'Special Contract Id' ;
    rdfs:comment 'Foreign key linking to service.special_contract. Business justification: Large industrial users often have special contracts with negotiated discharge limits beyond standard IUP permits. Effluent monitoring results verify compliance with contract-specific limits, trigger p' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpecialContract .

ind:wwtpId rdf:type rdf:Property ;
    rdfs:label 'Wwtp Id' ;
    rdfs:comment 'Foreign key reference to the wastewater treatment plant where the effluent sample was collected.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Wwtp .

ind:ammoniaNitrogenMgL rdf:type rdf:Property ;
    rdfs:label 'Ammonia Nitrogen Mg L' ;
    rdfs:comment 'Ammonia nitrogen concentration in milligrams per liter, measuring un-ionized and ionized ammonia.' ;
