ind:tthmMclUgL rdf:type rdf:Property ;
    rdfs:label 'Tthm Mcl Ug L' ;
    rdfs:comment 'The applicable TTHM maximum contaminant level for this monitoring event, typically 80 µg/L under Stage 2 DBPR.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effluentQualityId rdf:type rdf:Property ;
    rdfs:label 'Effluent Quality Id' ;
    rdfs:comment 'Unique identifier for the effluent quality measurement record.' ;
    rdfs:domain ind:EffluentQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryEffluentSampledByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Effluent Sampled By Employee Id' ;
    rdfs:comment 'Foreign key reference to the employee who collected the effluent sample.' ;
