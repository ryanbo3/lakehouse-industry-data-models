ind:estimatedMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Material Cost' ;
    rdfs:comment 'Estimated total material and parts cost in USD required to execute this job plan, based on the materials list.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedToolCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Tool Cost' ;
