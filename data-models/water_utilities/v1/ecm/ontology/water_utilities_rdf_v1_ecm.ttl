ind:tocConcentrationMgL rdf:type rdf:Property ;
    rdfs:label 'Toc Concentration Mg L' ;
    rdfs:comment 'The total organic carbon concentration in milligrams per liter, a key precursor to DBP formation.' ;
    rdfs:domain ind:DbpMonitoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalChlorineResidualMgL rdf:type rdf:Property ;
    rdfs:label 'Total Chlorine Residual Mg L' ;
    rdfs:comment 'The total chlorine residual measured at the time of sample collection, in milligrams per liter.' ;
    rdfs:domain ind:DbpMonitoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trichloroaceticAcidConcentrationUgL rdf:type rdf:Property ;
    rdfs:label 'Trichloroacetic Acid Concentration Ug L' ;
