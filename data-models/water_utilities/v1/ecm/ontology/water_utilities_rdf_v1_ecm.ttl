    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceReference rdf:type rdf:Property ;
    rdfs:label 'Source Reference' ;
    rdfs:comment 'Reference to the source document or standard from which this job plan was derived (e.g., \'AWWA M11 Steel Pipe Manual\', \'Manufacturer Service Bulletin 2023-04\').' ;
    rdfs:domain ind:JobPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskSequence rdf:type rdf:Property ;
    rdfs:label 'Task Sequence' ;
    rdfs:comment 'Step-by-step instructions detailing the ordered sequence of tasks to be performed. Each step includes action description, safety notes, and quality checkpoints.' ;
    rdfs:domain ind:JobPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolsList rdf:type rdf:Property ;
    rdfs:label 'Tools List' ;
    rdfs:comment 'List of specialized tools, equipment, and instruments required to perform this job plan (e.g., \'Torque wrench, multimeter, pipe wrench set\').' ;
    rdfs:domain ind:JobPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirementId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_requirement. Business justification: Regulatory requirements drive PM schedules (monthly chlorine residual checks per permit, quarterly backwash inspections per state rules). Links maintenance planning to compliance obligations, ensures ' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryRequirement .

ind:assetCriticalityRating rdf:type rdf:Property ;
    rdfs:label 'Asset Criticality Rating' ;
    rdfs:comment 'Criticality classification of the asset to which this schedule applies, indicating the impact of asset failure on operations, safety, regulatory compliance, or customer service.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoGenerateWorkOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Generate Work Order Flag' ;
    rdfs:comment 'Indicates whether work orders should be automatically generated by the CMMS system when the schedule becomes due, or whether manual review and approval is required before work order creation.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedLaborHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Labor Hours' ;
    rdfs:comment 'Estimated number of labor hours required to complete the preventive maintenance task, used for workforce planning and scheduling.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frequencyInterval rdf:type rdf:Property ;
    rdfs:label 'Frequency Interval' ;
    rdfs:comment 'Numeric value representing the interval between preventive maintenance occurrences, interpreted based on the frequency unit (e.g., 30 for days, 500 for hours, 1000 for gallons).' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyUnit rdf:type rdf:Property ;
    rdfs:label 'Frequency Unit' ;
    rdfs:comment 'Unit of measure for the frequency interval, defining whether the schedule is based on time periods (days, weeks, months, years), operating hours, operational cycles, or volume processed (gallons, cubic meters). [ENUM-REF-CANDIDATE: days|weeks|months|years|hours|cycles|gallons|cubic_meters — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPerformedDate rdf:type rdf:Property ;
    rdfs:label 'Last Performed Date' ;
    rdfs:comment 'Date when the preventive maintenance task was last completed, used to calculate the next due date for calendar-based schedules.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'Number of days before the next due date that the work order should be generated to allow for planning, scheduling, and resource allocation.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenanceTaskDescription rdf:type rdf:Property ;
    rdfs:label 'Maintenance Task Description' ;
    rdfs:comment 'Detailed description of the preventive maintenance task to be performed, including specific procedures, inspections, or servicing activities required.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meterThreshold rdf:type rdf:Property ;
    rdfs:label 'Meter Threshold' ;
    rdfs:comment 'Threshold value for meter-based preventive maintenance triggers; when the asset meter reading reaches or exceeds this value, a work order is automatically generated.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Due Date' ;
    rdfs:comment 'Calculated date when the next preventive maintenance work order should be generated based on the schedule frequency and last performed date.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiredSkillCertifications rdf:type rdf:Property ;
    rdfs:label 'Required Skill Certifications' ;
    rdfs:comment 'Comma-separated list of required skill certifications or qualifications that technicians must possess to perform this preventive maintenance task safely and effectively (e.g., electrical license, confined space entry, SCADA operator certification).' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleName rdf:type rdf:Property ;
    rdfs:label 'Schedule Name' ;
    rdfs:comment 'Descriptive name of the preventive maintenance schedule for easy identification by operations and maintenance staff.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Number' ;
    rdfs:comment 'Business identifier for the preventive maintenance schedule, typically assigned by the CMMS system for tracking and reporting purposes.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalEndMonth rdf:type rdf:Property ;
    rdfs:label 'Seasonal End Month' ;
    rdfs:comment 'Month number (1-12) when seasonal preventive maintenance schedule becomes inactive, applicable only when seasonal_schedule_flag is true.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonalScheduleFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Schedule Flag' ;
    rdfs:comment 'Indicates whether this preventive maintenance schedule is seasonal in nature, applicable only during specific months or seasons (e.g., winterization of outdoor equipment, summer peak demand preparation).' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seasonalStartMonth rdf:type rdf:Property ;
    rdfs:label 'Seasonal Start Month' ;
    rdfs:comment 'Month number (1-12) when seasonal preventive maintenance schedule becomes active, applicable only when seasonal_schedule_flag is true.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:triggerType rdf:type rdf:Property ;
    rdfs:label 'Trigger Type' ;
    rdfs:comment 'Type of trigger mechanism that determines when preventive maintenance is due: calendar-based (time intervals), meter-based (usage thresholds), condition-based (sensor readings), runtime-based (operating hours), or cycle-based (number of operations).' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderType rdf:type rdf:Property ;
    rdfs:label 'Work Order Type' ;
    rdfs:comment 'Classification of the work order that will be generated from this schedule, indicating the nature of the maintenance activity (preventive maintenance, inspection, calibration, lubrication, cleaning).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workZone rdf:type rdf:Property ;
    rdfs:label 'Work Zone' ;
    rdfs:comment 'Specific work zone, area, or department within the facility where the preventive maintenance activity will take place, used for crew assignment and access control.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAccountId rdf:type rdf:Property ;
    rdfs:label 'Billing Account Id' ;
    rdfs:comment 'Foreign key linking to billing.billing_account. Business justification: Work orders performed for specific customer accounts (service calls, meter work, customer-requested repairs) require account linkage. Required for customer work history tracking, account-specific main' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingAccount .

ind:crewId rdf:type rdf:Property ;
    rdfs:label 'Crew Id' ;
    rdfs:comment 'Reference to the maintenance crew or work group assigned to perform the work.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Crew .

ind:enforcementActionId rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Id' ;
    rdfs:comment 'Foreign key linking to compliance.enforcement_action. Business justification: Enforcement actions (consent orders, administrative orders) mandate specific remediation work with deadlines. Work orders must reference enforcement actions to track compliance schedule milestones, re' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnforcementAction .

ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: Work orders for customer-requested services (meter replacement, service line repair, reconnection after disconnection) generate billable charges appearing on invoices. Required for billable work order' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to supply.purchase_order. Business justification: Capital work orders and major repairs have associated POs for materials/equipment procurement. Enables three-way match (work order-PO-invoice), project cost reconciliation, budget tracking, and financ' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'Total actual cost incurred for the work order, including labor, materials, contractor services, and overhead allocations.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualFinishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Finish Timestamp' ;
    rdfs:comment 'Actual date and time when work execution was completed in the field.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualLaborHours rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Hours' ;
    rdfs:comment 'Total labor hours actually expended on the work order, captured from time sheets and labor transactions.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Actual date and time when work execution began in the field.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignedTo rdf:type rdf:Property ;
    rdfs:label 'Assigned To' ;
    rdfs:comment 'Name or identifier of the technician, crew, or contractor assigned to execute the work order.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:causeCode rdf:type rdf:Property ;
    rdfs:label 'Cause Code' ;
    rdfs:comment 'Standardized code identifying the root cause of the failure (e.g., corrosion, age, improper operation, design defect).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Date and time when the work order was formally closed and moved to historical status.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:completionNotes rdf:type rdf:Property ;
    rdfs:label 'Completion Notes' ;
    rdfs:comment 'Detailed narrative entered by the technician upon work completion, documenting findings, actions taken, parts replaced, and any follow-up recommendations.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost' ;
    rdfs:comment 'Planned total cost for the work order including labor, materials, and services, used for budgeting and Capital Expenditure (CAPEX) / Operating Expenditure (OPEX) planning.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failureCode rdf:type rdf:Property ;
    rdfs:label 'Failure Code' ;
    rdfs:comment 'Standardized code identifying the type of failure or problem that triggered the work order (e.g., leak, blockage, electrical fault, mechanical wear).' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitRequired rdf:type rdf:Property ;
    rdfs:label 'Permit Required' ;
    rdfs:comment 'Indicates whether regulatory permits (confined space entry, hot work, excavation, discharge) are required before work can commence.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remedyCode rdf:type rdf:Property ;
    rdfs:label 'Remedy Code' ;
    rdfs:comment 'Standardized code identifying the corrective action taken to resolve the failure (e.g., repair, replace, adjust, clean).' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedDate rdf:type rdf:Property ;
    rdfs:label 'Reported Date' ;
    rdfs:comment 'Date when the work need was first reported or identified.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyPlanRequired rdf:type rdf:Property ;
    rdfs:label 'Safety Plan Required' ;
    rdfs:comment 'Indicates whether a formal safety plan, Job Safety Analysis (JSA), or Occupational Safety and Health Administration (OSHA) compliance documentation is required for this work order.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledFinishDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Finish Date' ;
    rdfs:comment 'Planned date when work is scheduled to be completed.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'Planned date when work is scheduled to begin.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supervisorApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Supervisor Approval Date' ;
    rdfs:comment 'Date when the work order was reviewed and approved by the maintenance supervisor or manager.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:warrantyClaim rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim' ;
    rdfs:comment 'Indicates whether this work order is associated with a warranty claim against a vendor or contractor for defective equipment or workmanship.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workOrderDescription rdf:type rdf:Property ;
    rdfs:label 'Work Order Description' ;
    rdfs:comment 'Detailed narrative description of the work to be performed, including scope, objectives, and any special instructions or safety considerations.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderSource rdf:type rdf:Property ;
    rdfs:label 'Work Order Source' ;
    rdfs:comment 'Origin or trigger that created the work order (preventive maintenance schedule, Supervisory Control and Data Acquisition (SCADA) alarm, customer complaint, inspection finding, operator observation, predictive analytics model, regulatory mandate). [ENUM-REF-CANDIDATE: pm_schedule|scada_alarm|customer_complaint|inspection|operator_round|predictive_analytics|regulatory_requirement — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Work Order Status' ;
    rdfs:comment 'Current lifecycle status of the work order in the maintenance workflow, from creation through completion and closure. [ENUM-REF-CANDIDATE: draft|approved|scheduled|in_progress|on_hold|completed|closed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Id' ;
    rdfs:comment 'Unique identifier for the billing adjustment record. Primary key.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Adjustment .

ind:adjustmentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Employee Id' ;
    rdfs:comment 'Reference to the supervisor or manager who approved this adjustment. Null if not yet approved or if auto-approved.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adjustmentInitiatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Initiated By User Employee Id' ;
    rdfs:comment 'Reference to the customer service representative or system user who initiated the adjustment request.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:customerAccountId rdf:type rdf:Property ;
    rdfs:label 'Customer Account Id' ;
    rdfs:comment 'Foreign key linking to customer.customer_account. Business justification: Adjustments must link to customer accounts for customer service inquiries, adjustment history tracking, and audit trails. Customer service representatives need to view all adjustments applied to a cus' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:initiatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Initiated By User Employee Id' ;
    rdfs:comment 'Reference to the customer service representative or system user who initiated the adjustment request.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.journal_entry. Business justification: Billing adjustments generate GL journal entries to record revenue impacts. Auditors and financial controllers need to trace adjustments to their accounting postings for financial statement preparation' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:mainBreakId rdf:type rdf:Property ;
    rdfs:label 'Main Break Id' ;
    rdfs:comment 'Foreign key linking to distribution.main_break. Business justification: Main break events trigger billing adjustments for affected customers (service interruption credits, water quality credits post-break). Adjustment records cite the main break event as justification for' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MainBreak .

ind:networkIsolationEventId rdf:type rdf:Property ;
    rdfs:label 'Network Isolation Event Id' ;
    rdfs:comment 'Foreign key linking to distribution.network_isolation_event. Business justification: Planned network isolation events (maintenance shutdowns) trigger service interruption credits for affected customers. Adjustment records must cite the isolation event for audit trails, regulatory repo' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkIsolationEvent .

ind:originalAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Original Adjustment Id' ;
    rdfs:comment 'Reference to the original adjustment record being reversed, if this is a reversal entry. Null if this is not a reversal.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Adjustment .

ind:paymentPlanId rdf:type rdf:Property ;
    rdfs:label 'Payment Plan Id' ;
    rdfs:comment 'Foreign key linking to billing.payment_plan. Business justification: Adjustments can be applied to payment plan balances (e.g., reducing the enrolled balance due to a billing error correction, or adjusting installment amounts). Each adjustment that affects a payment pl' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentPlan .

ind:serviceLineId rdf:type rdf:Property ;
    rdfs:label 'Service Line Id' ;
    rdfs:comment 'Foreign key linking to distribution.service_line. Business justification: Leak adjustments (leak_allowance_flag) require service line inspection records as justification, high-bill adjustments reference service line condition and age, and LCRR compliance adjustments tie to ' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceLine .

ind:adjustmentNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Number' ;
    rdfs:comment 'Externally visible unique adjustment reference number used for customer communication and audit trails.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentStatus rdf:type rdf:Property ;
    rdfs:label 'Adjustment Status' ;
    rdfs:comment 'Current lifecycle status of the adjustment: pending (awaiting approval), approved (authorized but not yet applied), rejected (denied), applied (posted to account), reversed (undone), cancelled (voided before application).' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Classification of the adjustment indicating the nature of the correction: credit (reduces balance), debit (increases balance), write-off (uncollectible), leak_adjustment (leak allowance), rate_correction (tariff error), estimated_to_actual (true-up from estimated to actual meter reading), courtesy_credit (goodwill), penalty_reversal (late fee removal). [ENUM-REF-CANDIDATE: credit|debit|write-off|leak_adjustment|rate_correction|estimated_to_actual|courtesy_credit|penalty_reversal — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'Monetary value of the adjustment in the billing currency. Positive values represent credits (reducing customer balance), negative values represent debits (increasing customer balance).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appliedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Applied Timestamp' ;
    rdfs:comment 'Date and time when the adjustment was actually posted to the customer account and reflected in the account balance. Null if not yet applied.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether supervisory approval is required for this adjustment based on amount thresholds or adjustment type. True if approval is required, False if auto-approved.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Approval Threshold Amount' ;
    rdfs:comment 'The monetary threshold above which supervisory approval is required for this adjustment type. Null if no threshold applies.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when the adjustment was approved by the supervisor. Null if not yet approved.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'End date of the billing period to which this adjustment applies. Used for period-specific corrections and true-ups.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'Start date of the billing period to which this adjustment applies. Used for period-specific corrections and true-ups.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chargeCategory rdf:type rdf:Property ;
    rdfs:label 'Charge Category' ;
    rdfs:comment 'The billing charge category being adjusted: consumption (usage-based charges), base_charge (fixed monthly fee), connection_fee (new service fees), late_fee (delinquency charges), penalty (violation fines), surcharge (special assessments), tax (sales or utility tax), other (miscellaneous). [ENUM-REF-CANDIDATE: consumption|base_charge|connection_fee|late_fee|penalty|surcharge|tax|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumptionUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Consumption Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the consumption volume adjusted: gallons, cubic_meters (m³), cubic_feet (ft³), liters, ccf (hundred cubic feet), kgal (thousand gallons).' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumptionVolumeAdjusted rdf:type rdf:Property ;
    rdfs:label 'Consumption Volume Adjusted' ;
    rdfs:comment 'The volume of water or wastewater consumption being adjusted, measured in the utility\'s standard unit (typically gallons or cubic meters). Null if adjustment is not consumption-related.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerNotificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Sent Flag' ;
    rdfs:comment 'Indicates whether the customer has been notified of this adjustment via bill message, email, or letter. True if notification sent, False otherwise.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Dispute Reference Number' ;
    rdfs:comment 'Reference number of the customer billing dispute or complaint that triggered this adjustment. Null if not dispute-related.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'External Reference Number' ;
    rdfs:comment 'External reference number from third-party systems (e.g., payment processor, collection agency, regulatory agency) related to this adjustment. Null if no external reference.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leakAllowanceFlag rdf:type rdf:Property ;
    rdfs:label 'Leak Allowance Flag' ;
    rdfs:comment 'Indicates whether this adjustment is a leak allowance credit granted to the customer for documented plumbing leaks. True if leak allowance, False otherwise.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leakVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Leak Verification Date' ;
    rdfs:comment 'Date when the plumbing leak was verified by utility staff or licensed plumber, supporting the leak allowance adjustment. Null if not a leak adjustment.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Timestamp' ;
    rdfs:comment 'Date and time when customer notification of the adjustment was sent. Null if notification not yet sent.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rateCaseReference rdf:type rdf:Property ;
    rdfs:label 'Rate Case Reference' ;
    rdfs:comment 'Reference number of the regulatory rate case or tariff filing that mandated this adjustment. Null if not rate-case-related.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Standardized code indicating the specific business reason for the adjustment (e.g., BILLING_ERROR, METER_MALFUNCTION, LEAK_ALLOWANCE, CUSTOMER_DISPUTE, RATE_CHANGE, GOODWILL, REGULATORY_COMPLIANCE). Maps to internal reason code table.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Detailed free-text explanation of the reason for the adjustment, providing context for audit and customer service purposes.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this adjustment is a reversal of a previous adjustment. True if this is a reversal entry, False otherwise.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'Free-text explanation of why the original adjustment was reversed. Null if this is not a reversal.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceType rdf:type rdf:Property ;
    rdfs:label 'Service Type' ;
    rdfs:comment 'The type of utility service to which this adjustment applies: water (potable water supply), wastewater (sewage collection and treatment), stormwater (drainage fees), reclaimed_water (recycled water), bulk_water (wholesale water sales), other (miscellaneous charges).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Flag' ;
    rdfs:comment 'Indicates whether this adjustment is exempt from sales tax or utility tax. True if tax-exempt, False if taxable.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingAssistanceEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Billing Assistance Enrollment Id' ;
    rdfs:comment 'Unique identifier for the assistance_enrollment data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:BillingAssistanceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approved By User Employee Id' ;
    rdfs:comment 'System user identifier of the staff member who approved the assistance program application. Supports audit trail and quality assurance review.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assistanceProgramId rdf:type rdf:Property ;
    rdfs:label 'Assistance Program Id' ;
    rdfs:comment 'Reference to the specific utility assistance or low-income rate program in which the customer is enrolled. Links to the program definition including eligibility criteria and benefit structure.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssistanceProgram .

ind:grantId rdf:type rdf:Property ;
    rdfs:label 'Grant Id' ;
    rdfs:comment 'Foreign key linking to finance.grant. Business justification: Customer assistance programs are often grant-funded (LIHEAP, state low-income programs). Grant compliance reporting requires tracking which enrollments and benefit amounts are funded by which grants f' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Grant .

ind:annualBenefitCap rdf:type rdf:Property ;
    rdfs:label 'Annual Benefit Cap' ;
    rdfs:comment 'Maximum dollar value of benefits the customer may receive in a single calendar year. Null if no annual cap applies. Expressed in USD. Benefits suspend when current_year_benefit_amount reaches this value.' ;
    rdfs:domain ind:BillingAssistanceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualHouseholdIncome rdf:type rdf:Property ;
    rdfs:label 'Annual Household Income' ;
    rdfs:comment 'Total annual gross income for the customer household in USD. Used to calculate percentage of Federal Poverty Level (FPL) for eligibility determination. Confidential financial information.' ;
    rdfs:domain ind:BillingAssistanceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicationDate rdf:type rdf:Property ;
    rdfs:label 'Application Date' ;
    rdfs:comment 'Date the customer submitted their initial assistance program application. May precede enrollment_date if application review and approval took time.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:arrearageForgivenessBalance rdf:type rdf:Property ;
    rdfs:label 'Arrearage Forgiveness Balance' ;
    rdfs:comment 'Remaining balance of past-due charges eligible for forgiveness under the assistance program. Decreases as customer makes on-time payments per arrearage management plan. Expressed in USD.' ;
    rdfs:domain ind:BillingAssistanceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arrearageForgivenessRate rdf:type rdf:Property ;
    rdfs:label 'Arrearage Forgiveness Rate' ;
    rdfs:comment 'Percentage of on-time payment amount that is applied to arrearage forgiveness (e.g., 1:1 match means 100.00). Used in arrearage management programs where consistent payment earns debt reduction.' ;
    rdfs:domain ind:BillingAssistanceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autoRecertificationEligible rdf:type rdf:Property ;
    rdfs:label 'Auto Recertification Eligible' ;
    rdfs:comment 'Indicates whether the customer is eligible for automatic recertification without submitting new documentation. True if categorical eligibility or data-sharing agreement allows automated reverification.' ;
    rdfs:domain ind:BillingAssistanceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:benefitType rdf:type rdf:Property ;
    rdfs:label 'Benefit Type' ;
    rdfs:comment 'Type of financial benefit provided by the assistance program. Percentage_discount applies a percentage reduction to charges; fixed_credit applies a monthly dollar credit; tiered_rate applies a reduced rate schedule; usage_allowance provides free baseline usage; arrearage_forgiveness reduces past-due balances; combined indicates multiple benefit types.' ;
    rdfs:domain ind:BillingAssistanceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoricalProgramName rdf:type rdf:Property ;
    rdfs:label 'Categorical Program Name' ;
    rdfs:comment 'Name of the external assistance program used for categorical eligibility verification (e.g., SNAP, Medicaid, SSI, LIHEAP, WIC). Populated when eligibility_basis is categorical_eligibility.' ;
    rdfs:domain ind:BillingAssistanceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Certification Period Months' ;
    rdfs:comment 'Duration in months for which the customer\'s eligibility certification is valid before recertification is required. Typically 12 months per regulatory requirements.' ;
    rdfs:domain ind:BillingAssistanceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cumulativeBenefitAmount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Benefit Amount' ;
    rdfs:comment 'Total dollar value of all assistance benefits applied to the customer account since enrollment_date. Expressed in USD. Used for program cost tracking and regulatory reporting.' ;
    rdfs:domain ind:BillingAssistanceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentYearBenefitAmount rdf:type rdf:Property ;
    rdfs:label 'Current Year Benefit Amount' ;
    rdfs:comment 'Total dollar value of assistance benefits applied during the current calendar year. Expressed in USD. Reset to zero on January 1st. Used for annual program cap enforcement and reporting.' ;
    rdfs:domain ind:BillingAssistanceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Percentage discount applied to eligible charges when benefit_type is percentage_discount. Expressed as a decimal (e.g., 15.00 for 15% discount). Null for other benefit types.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibilityBasis rdf:type rdf:Property ;
    rdfs:label 'Eligibility Basis' ;
    rdfs:comment 'Primary basis for program eligibility determination. Income_qualified indicates FPL-based qualification; categorical_eligibility indicates participation in other assistance programs (SNAP, Medicaid, SSI); other values indicate special eligibility categories per program rules. [ENUM-REF-CANDIDATE: income_qualified|categorical_eligibility|senior_citizen|disability|veteran|medical_baseline|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BillingAssistanceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentChannel rdf:type rdf:Property ;
    rdfs:label 'Enrollment Channel' ;
    rdfs:comment 'Channel through which the customer submitted their assistance program application. Used to track enrollment source effectiveness and optimize outreach strategies. [ENUM-REF-CANDIDATE: online_portal|phone|in_person|mail|community_partner|auto_enrollment|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Date the customer was officially enrolled in the assistance program and benefits became effective. Used as the start of the certification period.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentNotes rdf:type rdf:Property ;
    rdfs:label 'Enrollment Notes' ;
    rdfs:comment 'Free-text field for case-specific notes, special circumstances, or additional context related to the enrollment. Used by customer service representatives for case management.' ;
    rdfs:domain ind:BillingAssistanceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Number' ;
    rdfs:comment 'Business-facing unique enrollment identifier used for customer communication, case tracking, and external reporting. Format typically includes program prefix and sequential number.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrollment Status' ;
    rdfs:comment 'Current lifecycle status of the assistance enrollment. Active indicates benefits are being applied; pending indicates application under review; suspended indicates temporary hold; expired indicates certification period ended; terminated indicates voluntary or involuntary exit; pending_recertification indicates annual renewal in progress.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Enrollment Timestamp' ;
    rdfs:comment 'Precise date and time when the enrollment record was created in the system. Supports audit trail and regulatory reporting requirements.' ;
    rdfs:domain ind:BillingAssistanceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fplPercentage rdf:type rdf:Property ;
    rdfs:label 'Fpl Percentage' ;
    rdfs:comment 'Customer household income expressed as a percentage of the Federal Poverty Level (FPL) for their household size. Used to determine program tier eligibility (e.g., 0-50% FPL, 51-100% FPL, 101-200% FPL).' ;
    rdfs:domain ind:BillingAssistanceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:householdSize rdf:type rdf:Property ;
    rdfs:label 'Household Size' ;
    rdfs:comment 'Number of individuals in the customer household. Used in conjunction with household income to determine eligibility based on Federal Poverty Level (FPL) thresholds.' ;
    rdfs:domain ind:BillingAssistanceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incomeVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Income Verification Date' ;
    rdfs:comment 'Date on which income documentation was verified and approved. Used to determine when reverification is required per program rules.' ;
    rdfs:domain ind:BillingAssistanceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incomeVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Income Verification Status' ;
    rdfs:comment 'Status of income documentation verification for eligibility determination. Verified indicates documentation approved; pending indicates under review; not_required indicates categorical eligibility; failed indicates documentation rejected; expired indicates reverification needed.' ;
    rdfs:domain ind:BillingAssistanceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'Customer\'s preferred language for assistance program communications. Three-letter ISO 639-2 language code. Used to ensure culturally and linguistically appropriate outreach. [ENUM-REF-CANDIDATE: ENG|SPA|CHI|VIE|KOR|RUS|TGL|FRE|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRecertificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Recertification Date' ;
    rdfs:comment 'Date of the most recent successful recertification event. Null for initial enrollments that have not yet recertified. Used to track compliance with annual recertification requirements.' ;
    rdfs:domain ind:BillingAssistanceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifetimeBenefitCap rdf:type rdf:Property ;
    rdfs:label 'Lifetime Benefit Cap' ;
    rdfs:comment 'Maximum total dollar value of benefits the customer may receive over the lifetime of their enrollment. Null if no lifetime cap applies. Expressed in USD. Enrollment terminates when cumulative_benefit_amount reaches this value.' ;
    rdfs:domain ind:BillingAssistanceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monthlyCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Monthly Credit Amount' ;
    rdfs:comment 'Fixed dollar amount credited to the customer account each billing cycle when benefit_type is fixed_credit. Expressed in USD. Null for other benefit types.' ;
    rdfs:domain ind:BillingAssistanceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationSentDate rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Date' ;
    rdfs:comment 'Date the most recent enrollment-related notification was sent to the customer (e.g., recertification reminder, approval notice, termination notice). Used to track customer communication compliance.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationType rdf:type rdf:Property ;
    rdfs:label 'Notification Type' ;
    rdfs:comment 'Type of the most recent notification sent to the customer. Used in conjunction with notification_sent_date to track communication history.' ;
    rdfs:domain ind:BillingAssistanceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recertificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Recertification Due Date' ;
    rdfs:comment 'Date by which the customer must complete annual recertification to maintain enrollment. Calculated as enrollment_date plus certification_period_months. Triggers customer notification workflow.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specialNeedsIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Needs Indicator' ;
    rdfs:comment 'Indicates whether the customer has documented special needs (medical baseline, life support equipment, disability) that may qualify for enhanced program benefits or protections. Confidential information.' ;
    rdfs:domain ind:BillingAssistanceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Date the enrollment was terminated. Null for active enrollments. Populated when enrollment_status changes to terminated or expired.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Reason for enrollment termination. Used for program retention analysis and regulatory reporting. Null for active enrollments. [ENUM-REF-CANDIDATE: customer_request|income_ineligible|failed_recertification|moved_out_of_service_area|account_closed|program_ended|fraud|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementId rdf:type rdf:Property ;
    rdfs:label 'Agreement Id' ;
    rdfs:comment 'Reference to the service agreement that this billing account is associated with. Links the financial account to the service delivery contract.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:wtpFacilityId rdf:type rdf:Property ;
    rdfs:label 'Wtp Facility Id' ;
    rdfs:comment 'Foreign key linking to treatment.facility. Business justification: Accounts should reference primary supply facility for capital cost recovery tracking, facility-specific rate design, and cost allocation. Core requirement for multi-facility utilities managing separat' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'Externally-visible unique account number used for customer communication, billing statements, and payment processing. This is the business identifier displayed on bills and correspondence.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the billing account indicating whether it is actively billing, suspended due to non-payment, closed, or in another state within the revenue cycle.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the billing account based on customer segment and rate structure applicability. Determines which rate schedules and service classes apply.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aging30Days rdf:type rdf:Property ;
    rdfs:label 'Aging 30 Days' ;
    rdfs:comment 'Portion of the account balance that is 1-30 days past due. Used for delinquency tracking and collections workflow triggers.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aging60Days rdf:type rdf:Property ;
    rdfs:label 'Aging 60 Days' ;
    rdfs:comment 'Portion of the account balance that is 31-60 days past due. Indicates escalating delinquency requiring more aggressive collection actions.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aging90Days rdf:type rdf:Property ;
    rdfs:label 'Aging 90 Days' ;
    rdfs:comment 'Portion of the account balance that is 61-90 days past due. Typically triggers final notice and service disconnection warnings.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agingCurrent rdf:type rdf:Property ;
    rdfs:label 'Aging Current' ;
    rdfs:comment 'Portion of the account balance that is current and not yet past due. Part of the aging analysis for accounts receivable management.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agingOver90Days rdf:type rdf:Property ;
    rdfs:label 'Aging Over 90 Days' ;
    rdfs:comment 'Portion of the account balance that is more than 90 days past due. Highest risk category for write-off and may result in service termination or legal action.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autopayEnrolled rdf:type rdf:Property ;
    rdfs:label 'Autopay Enrolled' ;
    rdfs:comment 'Indicates whether the customer is enrolled in automatic payment processing where bills are automatically paid from a bank account or credit card on the due date.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autopayMethod rdf:type rdf:Property ;
    rdfs:label 'Autopay Method' ;
    rdfs:comment 'Payment instrument used for automatic payment processing if autopay is enabled. Specifies whether payments are drawn from bank account or charged to card.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceForward rdf:type rdf:Property ;
    rdfs:label 'Balance Forward' ;
    rdfs:comment 'Previous balance carried forward from the prior billing cycle before current period charges are applied. Used for aging analysis and delinquency tracking.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingCycleCode rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle Code' ;
    rdfs:comment 'Code identifying the billing cycle schedule for this account (e.g., monthly, bi-monthly, quarterly). Determines when meter reads are taken and bills are generated.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingFrequency rdf:type rdf:Property ;
    rdfs:label 'Billing Frequency' ;
    rdfs:comment 'Frequency at which bills are generated and issued for this account. Aligns with meter reading schedules and rate structure requirements.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetBillingAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Billing Amount' ;
    rdfs:comment 'Fixed monthly amount charged under budget billing program. Calculated based on historical consumption patterns and reconciled annually.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetBillingEnrolled rdf:type rdf:Property ;
    rdfs:label 'Budget Billing Enrolled' ;
    rdfs:comment 'Indicates whether the customer is enrolled in budget billing program where monthly bills are averaged to provide consistent payment amounts throughout the year.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date when the billing account was closed and final bill was issued. Null for active accounts.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:collectionStatus rdf:type rdf:Property ;
    rdfs:label 'Collection Status' ;
    rdfs:comment 'Current stage in the collections workflow for delinquent accounts. Indicates escalation level and next collection action required.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Maximum outstanding balance allowed before service restrictions or additional deposits are required. Based on credit rating and payment history.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'Internal credit assessment of the customer based on payment history, delinquency patterns, and account behavior. Influences deposit requirements and collection strategies.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentBalance rdf:type rdf:Property ;
    rdfs:label 'Current Balance' ;
    rdfs:comment 'Total outstanding balance on the billing account including all charges, fees, adjustments, and payments. Positive values indicate amounts owed by the customer; negative values indicate credit balances.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentCharges rdf:type rdf:Property ;
    rdfs:label 'Current Charges' ;
    rdfs:comment 'Total charges for the current billing period including water consumption, wastewater service, stormwater fees, and other utility charges before adjustments.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositOnFile rdf:type rdf:Property ;
    rdfs:label 'Deposit On File' ;
    rdfs:comment 'Security deposit amount held by the utility to mitigate credit risk. May be applied to final bill or returned to customer upon account closure with good payment history.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disconnectionDate rdf:type rdf:Property ;
    rdfs:label 'Disconnection Date' ;
    rdfs:comment 'Date when service was disconnected due to non-payment or other account issues. Null if service is currently active.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalBillIssued rdf:type rdf:Property ;
    rdfs:label 'Final Bill Issued' ;
    rdfs:comment 'Indicates whether a final bill has been generated for this account upon closure. Used to ensure proper account settlement and deposit refund processing.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastBillDate rdf:type rdf:Property ;
    rdfs:label 'Last Bill Date' ;
    rdfs:comment 'Date when the most recent bill was generated for this account. Used to calculate next billing cycle and track billing cadence.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Last Payment Amount' ;
    rdfs:comment 'Amount of the most recent payment received. Used for payment pattern analysis and customer service inquiries.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Payment Date' ;
    rdfs:comment 'Date when the most recent payment was received and posted to this account. Used for payment history analysis and delinquency assessment.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lateFeeAssessed rdf:type rdf:Property ;
    rdfs:label 'Late Fee Assessed' ;
    rdfs:comment 'Total late payment fees assessed on this account for the current billing period. Applied when payment is not received by due date.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextBillDate rdf:type rdf:Property ;
    rdfs:label 'Next Bill Date' ;
    rdfs:comment 'Scheduled date for the next bill generation based on billing cycle and frequency. Used for billing run planning and customer communication.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openedDate rdf:type rdf:Property ;
    rdfs:label 'Opened Date' ;
    rdfs:comment 'Date when the billing account was first established. Used for customer tenure analysis and lifecycle reporting.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paperlessBilling rdf:type rdf:Property ;
    rdfs:label 'Paperless Billing' ;
    rdfs:comment 'Indicates whether the customer has opted for electronic bill delivery instead of printed paper bills. Reduces mailing costs and supports environmental sustainability.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pastDueAmount rdf:type rdf:Property ;
    rdfs:label 'Past Due Amount' ;
    rdfs:comment 'Total amount that is overdue and unpaid beyond the payment due date. Used for collections prioritization and service restriction decisions.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentPlanActive rdf:type rdf:Property ;
    rdfs:label 'Payment Plan Active' ;
    rdfs:comment 'Indicates whether the customer is currently on a payment plan to pay down past due balances in installments. Used to prevent service disconnection during plan compliance.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentPlanBalance rdf:type rdf:Property ;
    rdfs:label 'Payment Plan Balance' ;
    rdfs:comment 'Remaining balance to be paid under the active payment plan. Tracks progress toward full payment of delinquent amounts.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Standard payment terms for this billing account specifying the number of days from invoice date until payment is due.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconnectionFee rdf:type rdf:Property ;
    rdfs:label 'Reconnection Fee' ;
    rdfs:comment 'Fee charged to restore service after disconnection. Must be paid along with outstanding balance before service is restored.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxExempt rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt' ;
    rdfs:comment 'Indicates whether this account is exempt from utility taxes and fees. Typically applies to government entities, non-profits, or other qualifying organizations.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxExemptCertificate rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Certificate' ;
    rdfs:comment 'Certificate or permit number documenting the tax exemption status. Required for audit compliance and revenue reporting.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeId rdf:type rdf:Property ;
    rdfs:label 'Dispute Id' ;
    rdfs:comment 'Unique identifier for the billing dispute record. Primary key.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dispute .

ind:assignedToUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned To User Employee Id' ;
    rdfs:comment 'Reference to the customer service representative or case worker assigned to investigate and resolve the dispute.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:collectionNoticeId rdf:type rdf:Property ;
    rdfs:label 'Collection Notice Id' ;
    rdfs:comment 'Foreign key linking to billing.collection_notice. Business justification: Disputes are often triggered by collection notices - customers receive a notice and contest the charges. Each dispute should optionally reference the collection notice that triggered it for workflow t' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CollectionNotice .

ind:contactPersonId rdf:type rdf:Property ;
    rdfs:label 'Contact Person Id' ;
    rdfs:comment 'Reference to the specific person associated with the account who initiated or is the primary contact for the dispute.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Person .

ind:investigationServiceOrderId rdf:type rdf:Property ;
    rdfs:label 'Investigation Service Order Id' ;
    rdfs:comment 'Foreign key linking to service.service_order. Business justification: Billing disputes often trigger investigation service orders (meter accuracy tests, leak inspections, pressure checks). Dispute resolution workflow requires linking the dispute case to the field servic' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:treatmentViolationId rdf:type rdf:Property ;
    rdfs:label 'Treatment Violation Id' ;
    rdfs:comment 'Foreign key linking to treatment.treatment_violation. Business justification: Customer disputes about water quality, taste, or odor issues must reference treatment violations when applicable for proper investigation, regulatory compliance tracking, and public notification coord' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TreatmentViolation .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'Communication channel through which the customer submitted the dispute. [ENUM-REF-CANDIDATE: phone|email|web_portal|mobile_app|in_person|mail|social_media — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditIssuedAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Issued Amount' ;
    rdfs:comment 'Dollar amount of credit or adjustment applied to the customer account as a result of the dispute resolution.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerSatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Rating' ;
    rdfs:comment 'Customer-provided satisfaction score for the dispute resolution process, typically on a scale of 1-5 or 1-10.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Date' ;
    rdfs:comment 'Date when the customer formally initiated the dispute or inquiry.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeNumber rdf:type rdf:Property ;
    rdfs:label 'Dispute Number' ;
    rdfs:comment 'Human-readable unique dispute case number assigned for tracking and customer reference. Format: DSP-YYYYNNNN.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current lifecycle status of the dispute case in the resolution workflow. [ENUM-REF-CANDIDATE: open|under_investigation|pending_customer_response|resolved|closed|escalated|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispute Timestamp' ;
    rdfs:comment 'Precise date and time when the dispute was logged in the system.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:disputeType rdf:type rdf:Property ;
    rdfs:label 'Dispute Type' ;
    rdfs:comment 'Classification of the dispute based on the nature of the customer complaint or inquiry. [ENUM-REF-CANDIDATE: high_bill_complaint|estimated_bill_dispute|rate_classification_dispute|leak_adjustment_request|meter_accuracy_dispute|billing_error|service_quality_complaint|unauthorized_charges — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedAmount rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount' ;
    rdfs:comment 'Total dollar amount being contested by the customer on the invoice.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'Date when the dispute was escalated to a higher authority or regulatory body.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Date' ;
    rdfs:comment 'Scheduled date for follow-up action or customer contact related to the dispute.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required Flag' ;
    rdfs:comment 'Indicator of whether additional follow-up action is required after initial resolution.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investigationNotes rdf:type rdf:Property ;
    rdfs:label 'Investigation Notes' ;
    rdfs:comment 'Internal notes and findings documented by the investigator during the dispute resolution process.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationStartDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Start Date' ;
    rdfs:comment 'Date when formal investigation of the dispute began.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leakAdjustmentApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Leak Adjustment Approved Flag' ;
    rdfs:comment 'Indicator of whether a leak adjustment was approved and applied to the customer account.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leakAdjustmentGallons rdf:type rdf:Property ;
    rdfs:label 'Leak Adjustment Gallons' ;
    rdfs:comment 'Volume of water in gallons for which a leak adjustment credit was applied.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meterTestRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Meter Test Requested Flag' ;
    rdfs:comment 'Indicator of whether the customer requested a meter accuracy test as part of the dispute investigation.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meterTestResult rdf:type rdf:Property ;
    rdfs:label 'Meter Test Result' ;
    rdfs:comment 'Outcome of the meter accuracy test if one was conducted as part of the dispute investigation.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Priority classification assigned to the dispute based on severity, customer segment, or regulatory requirements.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pucComplaintNumber rdf:type rdf:Property ;
    rdfs:label 'Puc Complaint Number' ;
    rdfs:comment 'Official complaint case number assigned by the Public Utilities Commission if the dispute was escalated to the regulatory authority.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reason rdf:type rdf:Property ;
    rdfs:label 'Reason' ;
    rdfs:comment 'Detailed explanation provided by the customer describing why they are disputing the charges.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryEscalationFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Escalation Flag' ;
    rdfs:comment 'Indicator of whether the dispute was escalated to a regulatory body such as the Public Utilities Commission (PUC).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Detailed explanation of how the dispute was resolved and the rationale for the decision.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Precise date and time when the dispute resolution was completed and recorded.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionType rdf:type rdf:Property ;
    rdfs:label 'Resolution Type' ;
    rdfs:comment 'Classification of the action taken to resolve the dispute. [ENUM-REF-CANDIDATE: credit_issued|bill_corrected|no_adjustment|payment_plan_offered|meter_test_scheduled|rate_reclassification|customer_education|partial_credit — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaActualResolutionHours rdf:type rdf:Property ;
    rdfs:label 'Sla Actual Resolution Hours' ;
    rdfs:comment 'Actual number of hours taken to resolve the dispute, measured from dispute initiation to resolution.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Indicator of whether the dispute resolution exceeded the SLA target timeframe.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetResolutionHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Resolution Hours' ;
    rdfs:comment 'Target number of hours within which the dispute should be resolved according to the applicable Service Level Agreement.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingCycleId rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle Id' ;
    rdfs:comment 'Foreign key linking to billing.billing_cycle. Business justification: Invoice belongs to a billing cycle; adding billing_cycle_id FK eliminates the redundant billing_cycle_code column and enables proper cycle lookup.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingCycle .

ind:fundId rdf:type rdf:Property ;
    rdfs:label 'Fund Id' ;
    rdfs:comment 'Foreign key linking to finance.fund. Business justification: Invoices are issued against specific funds (water enterprise fund, wastewater fund, stormwater fund). Fund accounting and GASB reporting require tracking invoice-to-fund attribution for revenue recogn' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fund .

ind:pointId rdf:type rdf:Property ;
    rdfs:label 'Point Id' ;
    rdfs:comment 'Reference to the physical service point (meter location) associated with this invoice. May be null for account-level charges not tied to a specific service point.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Point .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Net adjustment amount applied to the invoice, including credits for billing errors, leak adjustments, service quality issues, or promotional discounts. Positive values increase invoice total; negative values decrease it.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ccrIncluded rdf:type rdf:Property ;
    rdfs:label 'Ccr Included' ;
    rdfs:comment 'Boolean flag indicating whether the annual Consumer Confidence Report (water quality report) was included with this invoice mailing. Required annually under Safe Drinking Water Act (SDWA).' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conservationMessage rdf:type rdf:Property ;
    rdfs:label 'Conservation Message' ;
    rdfs:comment 'Optional water conservation message or tip printed on the invoice to encourage efficient water use. May vary seasonally or based on drought conditions.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'User ID or system process name that created this invoice record. For automated cycle billing, typically a batch process identifier; for manual invoices, the billing staff user ID.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'Method by which the invoice was delivered to the customer. Options include postal mail (paper bill), email (electronic bill), customer web portal, or SMS notification with portal link.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Boolean flag indicating whether the customer has formally disputed charges on this invoice. Triggers dispute resolution workflow and may suspend collection activities.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'Date by which payment must be received to avoid late fees or service disconnection. Calculated based on invoice date plus payment terms (typically 15-30 days).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:generationMethod rdf:type rdf:Property ;
    rdfs:label 'Generation Method' ;
    rdfs:comment 'Method by which the invoice was generated. Automated cycle invoices are produced by scheduled batch billing runs; manual invoices are created by billing staff; off-cycle invoices are generated outside normal schedules; estimated invoices use projected consumption; corrected invoices replace prior errors.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'Date the invoice was generated and issued to the customer. This is the official invoice date printed on the bill and used for aging calculations.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Externally visible, human-readable invoice number printed on customer bills and used for customer service inquiries. Must be unique across all invoices.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle state of the invoice. Draft invoices are pending finalization; issued invoices have been sent to customers; paid invoices are fully settled; partial_paid invoices have received some payment; overdue invoices are past due date; cancelled invoices are nullified before payment; void invoices are nullified after issuance. [ENUM-REF-CANDIDATE: draft|issued|paid|partial_paid|overdue|cancelled|void — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the invoice based on billing circumstances. Regular cycle invoices are standard periodic bills; final invoices are issued upon service termination; estimated invoices use projected consumption when actual reads are unavailable; corrected invoices replace erroneous prior bills; off-cycle invoices are generated outside normal billing cycles; adjustment invoices correct prior billing errors.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEstimated rdf:type rdf:Property ;
    rdfs:label 'Is Estimated' ;
    rdfs:comment 'Boolean flag indicating whether consumption values on this invoice are estimated rather than based on actual meter readings. True when meter is inaccessible or malfunctioning.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFinal rdf:type rdf:Property ;
    rdfs:label 'Is Final' ;
    rdfs:comment 'Boolean flag indicating whether this is a final invoice issued upon service termination or account closure. Final invoices settle all outstanding charges and close the billing relationship.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lateFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Late Fee Amount' ;
    rdfs:comment 'Late payment penalty assessed if payment is not received by due date. Calculated as a percentage of outstanding balance or flat fee per utility policy and regulatory limits.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'User ID or system process name that last modified this invoice record. Used for audit trail and accountability.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otherChargesAmount rdf:type rdf:Property ;
    rdfs:label 'Other Charges Amount' ;
    rdfs:comment 'Miscellaneous charges not categorized as water, wastewater, or stormwater services. May include meter reading fees, service connection charges, late fees, returned payment fees, or special assessments.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Number of days from invoice date until payment is due. Standard terms are typically 15, 21, or 30 days depending on utility policy and customer class.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Previous Balance Amount' ;
    rdfs:comment 'Outstanding balance carried forward from prior billing periods. Represents unpaid or partially paid amounts from previous invoices.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:printDate rdf:type rdf:Property ;
    rdfs:label 'Print Date' ;
    rdfs:comment 'Date the invoice was physically printed or electronically rendered for delivery to the customer. May differ from invoice date for batch processing.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateScheduleCode rdf:type rdf:Property ;
    rdfs:label 'Rate Schedule Code' ;
    rdfs:comment 'Code identifying the tariff rate schedule applied to calculate charges on this invoice. Rate schedules vary by customer class (residential, commercial, industrial) and service type.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stormwaterArea rdf:type rdf:Property ;
    rdfs:label 'Stormwater Area' ;
    rdfs:comment 'Total impervious surface area (in square feet or square meters) used to calculate stormwater management fees. Applicable for properties subject to stormwater utility charges.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stormwaterChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Stormwater Charge Amount' ;
    rdfs:comment 'Charges for stormwater management services, typically calculated based on impervious surface area. Supports stormwater infrastructure maintenance and regulatory compliance.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Total tax charges applied to the invoice, including sales tax, utility tax, franchise fees, or other regulatory taxes as required by jurisdiction.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAmountDue rdf:type rdf:Property ;
    rdfs:label 'Total Amount Due' ;
    rdfs:comment 'Total amount the customer must pay, calculated as sum of current period charges (water, wastewater, stormwater, other), taxes, adjustments, and previous balance. This is the headline amount printed on the invoice.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wastewaterChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Wastewater Charge Amount' ;
    rdfs:comment 'Total charges for wastewater collection and treatment services during the billing period. May include volumetric charges, fixed fees, and strength-of-waste surcharges for industrial users.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wastewaterVolume rdf:type rdf:Property ;
    rdfs:label 'Wastewater Volume' ;
    rdfs:comment 'Volume of wastewater discharged during the billing period, typically calculated as a percentage of water consumption or measured separately for industrial customers. Measured in same unit as water consumption.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Water Charge Amount' ;
    rdfs:comment 'Total charges for potable water service during the billing period, including volumetric consumption charges and fixed service fees. Calculated based on applicable rate schedule and tier structure.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterConsumptionUom rdf:type rdf:Property ;
    rdfs:label 'Water Consumption Uom' ;
    rdfs:comment 'Unit of measure for water consumption volume. Common units include gallons, cubic meters (m³), hundred cubic feet (CCF), or thousand gallons (kgal).' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterConsumptionVolume rdf:type rdf:Property ;
    rdfs:label 'Water Consumption Volume' ;
    rdfs:comment 'Total volume of potable water consumed during the billing period, measured in gallons or cubic meters depending on utility standard. Derived from meter readings or estimated when actual reads unavailable.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Id' ;
    rdfs:comment 'Unique identifier for the invoice line item. Primary key for the invoice line product.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvoiceLine .

ind:qualitySamplingPointId rdf:type rdf:Property ;
    rdfs:label 'Quality Sampling Point Id' ;
    rdfs:comment 'Foreign key linking to quality.sampling_point. Business justification: Industrial and commercial customers may have quality-based rate structures or surcharges tied to specific sampling points. Invoice lines need to reference the monitoring location for rate justificatio' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualitySamplingPoint .

ind:rateTierId rdf:type rdf:Property ;
    rdfs:label 'Rate Tier Id' ;
    rdfs:comment 'Reference to the specific rate tier applied for tiered or block rate structures. Identifies which consumption block or tier this charge falls into.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateTier .

ind:ratedConsumptionId rdf:type rdf:Property ;
    rdfs:label 'Rated Consumption Id' ;
    rdfs:comment 'Foreign key linking to billing.rated_consumption. Business justification: Invoice line items representing consumption charges should reference the authoritative rated_consumption record as their source data. This establishes traceability from billed charges back to the mete' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IntervalConsumption .

ind:adjustmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason Code' ;
    rdfs:comment 'Code indicating the reason for billing adjustments, credits, or special charges. Used for adjustment and dispute tracking. [ENUM-REF-CANDIDATE: BILLING_ERROR|METER_MALFUNCTION|LEAK_ADJUSTMENT|CUSTOMER_DISPUTE|RATE_CHANGE|PRORATION|CREDIT_MEMO|WRITE_OFF|GOODWILL|OTHER — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reference Number' ;
    rdfs:comment 'Reference number linking this line to an adjustment request, dispute case, or credit memo. Provides audit trail for non-standard charges.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingDeterminant rdf:type rdf:Property ;
    rdfs:label 'Billing Determinant' ;
    rdfs:comment 'The basis or method used to calculate this charge. Identifies whether charge is based on metered usage, property characteristics, flat rate, or other factors. [ENUM-REF-CANDIDATE: METERED_CONSUMPTION|ESTIMATED_CONSUMPTION|FLAT_RATE|METER_SIZE|PROPERTY_SIZE|IMPERVIOUS_AREA|FIXTURE_COUNT|CONNECTION_SIZE|CUSTOMER_CLASS|OTHER — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeDescription rdf:type rdf:Property ;
    rdfs:label 'Charge Description' ;
    rdfs:comment 'Detailed textual description of the charge as it appears on the customer invoice. Provides human-readable explanation of the line item.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeTypeCode rdf:type rdf:Property ;
    rdfs:label 'Charge Type Code' ;
    rdfs:comment 'Classification of the charge line item by billing component type. Distinguishes between consumption charges, fixed fees, taxes, adjustments, and other billing elements. [ENUM-REF-CANDIDATE: WATER_CONSUMPTION|WASTEWATER_SERVICE|STORMWATER_FEE|BASE_SERVICE|METER_CHARGE|CONNECTION_FEE|LATE_FEE|ADJUSTMENT|TAX|SURCHARGE|PENALTY|CREDIT|REBATE|DEPOSIT|OTHER — 15 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDisputed rdf:type rdf:Property ;
    rdfs:label 'Is Disputed' ;
    rdfs:comment 'Indicates whether this charge is currently under customer dispute. True if disputed, false otherwise. Used for dispute tracking and collections management.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isProrated rdf:type rdf:Property ;
    rdfs:label 'Is Prorated' ;
    rdfs:comment 'Indicates whether this charge has been prorated due to partial billing period, service start/stop, or rate change. True if prorated, false otherwise.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTaxable rdf:type rdf:Property ;
    rdfs:label 'Is Taxable' ;
    rdfs:comment 'Indicates whether this line item is subject to taxation. True if taxable, false if tax-exempt.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'User identifier or system process that last modified this invoice line record. Supports audit and accountability requirements.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineAmount rdf:type rdf:Property ;
    rdfs:label 'Line Amount' ;
    rdfs:comment 'Calculated charge amount for this line item before taxes and adjustments. Typically consumption_quantity multiplied by unit_rate for consumption charges, or fixed amount for service fees.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Line Sequence Number' ;
    rdfs:comment 'Sequential ordering of line items within the parent invoice. Determines display order on customer bill.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current status of the invoice line item in the billing lifecycle. Tracks whether the charge is active, has been adjusted, disputed, or reversed.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:printSequence rdf:type rdf:Property ;
    rdfs:label 'Print Sequence' ;
    rdfs:comment 'Display order for this line item on printed or electronic invoices. Controls the presentation sequence for customer-facing billing documents.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prorationFactor rdf:type rdf:Property ;
    rdfs:label 'Proration Factor' ;
    rdfs:comment 'Decimal factor applied for prorated charges. Represents the portion of the full billing period or rate being charged (e.g., 0.5000 for half period).' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueClass rdf:type rdf:Property ;
    rdfs:label 'Revenue Class' ;
    rdfs:comment 'Classification of revenue type for financial reporting and regulatory compliance. Distinguishes between operating revenue, capital contributions, and other revenue categories.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDays rdf:type rdf:Property ;
    rdfs:label 'Service Days' ;
    rdfs:comment 'Number of days in the billing period for this charge. Used for proration calculations and billing cycle analysis.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Percentage' ;
    rdfs:comment 'Tax rate percentage applied to calculate the tax amount. Expressed as decimal (e.g., 0.0825 for 8.25% tax rate).' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLineAmount rdf:type rdf:Property ;
    rdfs:label 'Total Line Amount' ;
    rdfs:comment 'Total amount for this line item including taxes and adjustments. Sum of line_amount and tax_amount. Contributes to invoice total.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitRate rdf:type rdf:Property ;
    rdfs:label 'Unit Rate' ;
    rdfs:comment 'Price per unit of consumption or service. The rate applied to calculate the line charge amount. Expressed in currency per consumption_unit_of_measure.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lienId rdf:type rdf:Property ;
    rdfs:label 'Lien Id' ;
    rdfs:comment 'Unique identifier for the property lien record. Primary key for the lien entity.' ;
    rdfs:domain ind:Lien ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:delinquencyNoticeId rdf:type rdf:Property ;
    rdfs:label 'Delinquency Notice Id' ;
    rdfs:comment 'Reference to the final delinquency notice or demand letter that preceded the lien filing. Links to the collections notice chain.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DelinquencyNotice .

ind:lienEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Lien Employee Id' ;
    rdfs:comment 'Identifier of the utility staff member or system user who initiated and filed the lien. Used for audit and accountability.' ;
    rdfs:domain ind:Lien ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:lienParcelPremiseId rdf:type rdf:Property ;
    rdfs:label 'Lien Parcel Premise Id' ;
    rdfs:comment 'County assessor parcel number or tax parcel identifier for the real property against which the lien is filed. Used for legal property identification.' ;
    rdfs:domain ind:Lien ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Premise .

ind:lienPremiseId rdf:type rdf:Property ;
    rdfs:label 'Lien Premise Id' ;
    rdfs:comment 'Reference to the property premise where utility service was provided and against which the lien is filed.' ;
    rdfs:domain ind:Lien ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Premise .

ind:lienReleasedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Lien Released By User Employee Id' ;
    rdfs:comment 'Identifier of the utility staff member or system user who processed the lien release. Null if lien remains active.' ;
    rdfs:domain ind:Lien ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:parcelId rdf:type rdf:Property ;
    rdfs:label 'Parcel Id' ;
    rdfs:comment 'County assessor parcel number or tax parcel identifier for the real property against which the lien is filed. Used for legal property identification.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Parcel .

ind:releasedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Released By User Employee Id' ;
    rdfs:comment 'Identifier of the utility staff member or system user who processed the lien release. Null if lien remains active.' ;
    rdfs:domain ind:Lien ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sewerServiceConnectionId rdf:type rdf:Property ;
    rdfs:label 'Sewer Service Connection Id' ;
    rdfs:comment 'Foreign key linking to wastewater.sewer_service_connection. Business justification: Liens filed for delinquent wastewater charges must reference the specific sewer service connection to establish legal basis for debt. Required for lien filing documentation, property title searches, l' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SewerServiceConnection .

ind:utilityAssetRegistryId rdf:type rdf:Property ;
    rdfs:label 'Utility Asset Registry Id' ;
    rdfs:comment 'Foreign key linking to asset.asset_registry. Business justification: Liens may be placed on utility-owned assets or reference infrastructure serving the property (distinct from premise_id for property). Required for utility asset encumbrance tracking, infrastructure li' ;
    rdfs:domain ind:Lien ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Registry .

ind:administrativeFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Administrative Fee Amount' ;
    rdfs:comment 'Administrative costs and filing fees associated with preparing and recording the lien, recoverable from the property owner.' ;
    rdfs:domain ind:Lien ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countyCode rdf:type rdf:Property ;
    rdfs:label 'County Code' ;
    rdfs:comment 'Code or identifier for the county where the lien was filed. Supports multi-county utility service territories.' ;
    rdfs:domain ind:Lien ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDate rdf:type rdf:Property ;
    rdfs:label 'Filing Date' ;
    rdfs:comment 'Date the lien was officially filed with the county recorder or appropriate legal authority. Establishes lien priority and legal enforceability.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:foreclosureCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Foreclosure Case Number' ;
    rdfs:comment 'Court case number or legal proceeding identifier for foreclosure action related to this lien. Null if no foreclosure filed.' ;
    rdfs:domain ind:Lien ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foreclosureDate rdf:type rdf:Property ;
    rdfs:label 'Foreclosure Date' ;
    rdfs:comment 'Date foreclosure proceedings were initiated or completed on the property to satisfy the lien. Null if no foreclosure action taken.' ;
    rdfs:domain ind:Lien ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interestAmount rdf:type rdf:Property ;
    rdfs:label 'Interest Amount' ;
    rdfs:comment 'Accrued interest on the delinquent balance calculated per statutory or ordinance-defined interest rate.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isSuperPriority rdf:type rdf:Property ;
    rdfs:label 'Is Super Priority' ;
    rdfs:comment 'Indicates whether this lien has super-priority status under state law, meaning it takes precedence over mortgage liens and other senior encumbrances. True if super-priority applies.' ;
    rdfs:domain ind:Lien ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Code' ;
    rdfs:comment 'Code identifying the legal jurisdiction or municipality under whose authority the lien was filed. Determines applicable statutes and procedures.' ;
    rdfs:domain ind:Lien ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalDescription rdf:type rdf:Property ;
    rdfs:label 'Legal Description' ;
    rdfs:comment 'Full legal description of the property as recorded in the deed, including lot, block, subdivision, metes and bounds, or other legal land description. Required for lien enforceability.' ;
    rdfs:domain ind:Lien ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lienNumber rdf:type rdf:Property ;
    rdfs:label 'Lien Number' ;
    rdfs:comment 'Externally-visible unique business identifier for the lien, used in legal filings and correspondence. May follow municipal or county recorder numbering conventions.' ;
    rdfs:domain ind:Lien ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lienStatus rdf:type rdf:Property ;
    rdfs:label 'Lien Status' ;
    rdfs:comment 'Current lifecycle status of the lien. Tracks progression from initial filing through resolution or foreclosure. [ENUM-REF-CANDIDATE: pending|filed|recorded|released|satisfied|foreclosed|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Lien ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lienType rdf:type rdf:Property ;
    rdfs:label 'Lien Type' ;
    rdfs:comment 'Classification of the lien based on the type of utility service charges that are unpaid. Determines legal authority and priority under state statute.' ;
    rdfs:domain ind:Lien ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeMethod rdf:type rdf:Property ;
    rdfs:label 'Notice Method' ;
    rdfs:comment 'Method by which the lien notice was delivered to the property owner. Must comply with statutory notice requirements.' ;
    rdfs:domain ind:Lien ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeSentDate rdf:type rdf:Property ;
    rdfs:label 'Notice Sent Date' ;
    rdfs:comment 'Date the notice of intent to file lien was sent to the property owner. Required pre-filing notice period per state statute.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'Late payment penalties and delinquency fees assessed on the unpaid balance prior to lien filing.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:principalAmount rdf:type rdf:Property ;
    rdfs:label 'Principal Amount' ;
    rdfs:comment 'Original unpaid utility charges amount excluding penalties, interest, and fees. Base delinquent balance that triggered the lien.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Legal priority ranking of this lien relative to other encumbrances on the property. Lower numbers indicate higher priority. Determined by state statute and recording date.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:propertyAddress rdf:type rdf:Property ;
    rdfs:label 'Property Address' ;
    rdfs:comment 'Full street address of the property subject to the lien. Used for legal notice and property identification.' ;
    rdfs:domain ind:Lien ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertyOwnerName rdf:type rdf:Property ;
    rdfs:label 'Property Owner Name' ;
    rdfs:comment 'Legal name of the property owner as recorded on the deed or county assessor records at the time of lien filing.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recorderBookNumber rdf:type rdf:Property ;
    rdfs:label 'Recorder Book Number' ;
    rdfs:comment 'Book number in the county recorders lien index where the lien is recorded. Legacy identifier in jurisdictions using book-and-page indexing.' ;
    rdfs:domain ind:Lien ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recorderPageNumber rdf:type rdf:Property ;
    rdfs:label 'Recorder Page Number' ;
    rdfs:comment 'Page number in the county recorders lien index where the lien is recorded. Legacy identifier in jurisdictions using book-and-page indexing.' ;
    rdfs:domain ind:Lien ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recorderReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Recorder Reference Number' ;
    rdfs:comment 'Official document number or instrument number assigned by the county recorder when the lien was recorded. Used for legal lookup and verification.' ;
    rdfs:domain ind:Lien ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordingDate rdf:type rdf:Property ;
    rdfs:label 'Recording Date' ;
    rdfs:comment 'Date the lien was officially recorded in the county land records system. May differ from filing date depending on recorder processing time.' ;
    rdfs:domain ind:Lien ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releaseAmount rdf:type rdf:Property ;
    rdfs:label 'Release Amount' ;
    rdfs:comment 'Total amount paid or settled to release the lien. May differ from original lien amount if partial settlement or additional interest accrued.' ;
    rdfs:domain ind:Lien ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date the lien was released or satisfied, typically after full payment of the delinquent balance. Null if lien remains active.' ;
    rdfs:domain ind:Lien ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releaseReasonCode rdf:type rdf:Property ;
    rdfs:label 'Release Reason Code' ;
    rdfs:comment 'Code indicating the reason the lien was released. Null if lien remains active.' ;
    rdfs:domain ind:Lien ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentId rdf:type rdf:Property ;
    rdfs:label 'Payment Id' ;
    rdfs:comment 'Unique identifier for the payment transaction. Primary key for the payment record.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payment .

ind:arTransactionId rdf:type rdf:Property ;
    rdfs:label 'Ar Transaction Id' ;
    rdfs:comment 'Unique transaction identifier from the payment gateway or processor, used for reconciliation and dispute resolution.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArTransaction .

ind:bankAccountId rdf:type rdf:Property ;
    rdfs:label 'Bank Account Id' ;
    rdfs:comment 'Foreign key linking to finance.bank_account. Business justification: Payments are deposited to specific bank accounts. Treasury operations, bank reconciliation, and cash management require tracking which bank account received each payment for daily cash positioning and' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:billInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Bill Invoice Id' ;
    rdfs:comment 'Reference to the specific bill or invoice that this payment is intended to satisfy. May be null for advance payments or account credits.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:receivedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Received By User Employee Id' ;
    rdfs:comment 'Identifier of the customer service representative or system user who received or processed the payment. Null for automated payments.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reversedByPaymentId rdf:type rdf:Property ;
    rdfs:label 'Reversed By Payment Id' ;
    rdfs:comment 'Reference to the reversal payment transaction that cancelled or reversed this payment. Null for non-reversed payments.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payment .

ind:appliedAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Amount' ;
    rdfs:comment 'The portion of the payment amount that has been applied to outstanding account balances. May differ from payment_amount if payment is partially applied or held as credit.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizationCode rdf:type rdf:Property ;
    rdfs:label 'Authorization Code' ;
    rdfs:comment 'Authorization or approval code returned by the payment processor for credit card or ACH transactions.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountLastFour rdf:type rdf:Property ;
    rdfs:label 'Bank Account Last Four' ;
    rdfs:comment 'Last four digits of the bank account number used for ACH or electronic payments. Used for customer verification without exposing full account number.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Identifier for the payment batch or deposit group in which this payment was processed, used for reconciliation and audit purposes.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardLastFour rdf:type rdf:Property ;
    rdfs:label 'Card Last Four' ;
    rdfs:comment 'Last four digits of the credit or debit card number used for card payments. Used for customer verification without exposing full card number.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardType rdf:type rdf:Property ;
    rdfs:label 'Card Type' ;
    rdfs:comment 'The credit or debit card brand for card payments (e.g., Visa, MasterCard, American Express, Discover). Null for non-card payments.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkNumber rdf:type rdf:Property ;
    rdfs:label 'Check Number' ;
    rdfs:comment 'The check number for check payments. Null for non-check payment methods.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearedDate rdf:type rdf:Property ;
    rdfs:label 'Cleared Date' ;
    rdfs:comment 'The date on which the payment cleared the bank or financial institution, confirming funds availability. Null for cash payments.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isAutoPay rdf:type rdf:Property ;
    rdfs:label 'Is Auto Pay' ;
    rdfs:comment 'Boolean flag indicating whether this payment was processed automatically through an auto-pay enrollment (True) or was a manual customer-initiated payment (False).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRecurring rdf:type rdf:Property ;
    rdfs:label 'Is Recurring' ;
    rdfs:comment 'Boolean flag indicating whether this payment is part of a recurring payment plan or schedule (True) or a one-time payment (False).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lockboxNumber rdf:type rdf:Property ;
    rdfs:label 'Lockbox Number' ;
    rdfs:comment 'Bank lockbox number or identifier for payments received through lockbox processing services. Null for non-lockbox payments.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nsfFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Nsf Fee Amount' ;
    rdfs:comment 'The fee charged to the customer account for a returned NSF payment. Null if no NSF occurred or no fee was assessed.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nsfIndicator rdf:type rdf:Property ;
    rdfs:label 'Nsf Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this payment was returned due to non-sufficient funds (True) or processed successfully (False).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The date on which the payment was received or processed by the utility. This is the business event date for revenue recognition.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'The financial instrument or tender type used to make the payment (e.g., check, ACH bank draft, credit card, debit card, cash, money order).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Number' ;
    rdfs:comment 'Business-facing unique reference number for the payment transaction, used for customer inquiries and reconciliation.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current lifecycle status of the payment transaction indicating whether it has been posted to the account, cleared by the bank, or reversed.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Payment Timestamp' ;
    rdfs:comment 'Precise date and time when the payment transaction was received or recorded in the system.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:paymentType rdf:type rdf:Property ;
    rdfs:label 'Payment Type' ;
    rdfs:comment 'Classification of the payment purpose (e.g., regular bill payment, advance payment, deposit, refund, billing adjustment).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The date on which the payment was posted to the customer account and applied against outstanding balances.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:processorName rdf:type rdf:Property ;
    rdfs:label 'Processor Name' ;
    rdfs:comment 'Name of the third-party payment processor or gateway that handled the electronic payment transaction (e.g., Stripe, PayPal, bank lockbox service).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'External reference number from the payment source (e.g., check number, ACH trace number, credit card authorization code, lockbox batch number).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unappliedAmount rdf:type rdf:Property ;
    rdfs:label 'Unapplied Amount' ;
    rdfs:comment 'The portion of the payment amount that remains unapplied and is held as account credit or pending allocation.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentApplicationId rdf:type rdf:Property ;
    rdfs:label 'Payment Application Id' ;
    rdfs:comment 'Unique identifier for the payment application record. Primary key.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appliedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Applied By User Employee Id' ;
    rdfs:comment 'Identifier of the system user or automated process that applied the payment. Supports audit trail and manual vs. automated application tracking.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:disputeCaseDisputeId rdf:type rdf:Property ;
    rdfs:label 'Dispute Case Dispute Id' ;
    rdfs:comment 'Reference to the dispute case record if this payment application is part of a dispute resolution process.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dispute .

ind:invoiceLineItemInvoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Item Invoice Line Id' ;
    rdfs:comment 'Reference to the specific invoice line item to which this payment is applied. Enables line-level payment allocation.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvoiceLine .

ind:adjustmentDate rdf:type rdf:Property ;
    rdfs:label 'Adjustment Date' ;
    rdfs:comment 'The date on which an adjustment was made to this payment application. Null if no adjustment occurred.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adjustmentIndicator rdf:type rdf:Property ;
    rdfs:label 'Adjustment Indicator' ;
    rdfs:comment 'Flag indicating whether this payment application was adjusted after initial processing due to billing correction or dispute resolution.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'The method or rule used to allocate the payment across outstanding charges (e.g., FIFO, oldest invoice first, pro-rata across all balances). [ENUM-REF-CANDIDATE: fifo|lifo|oldest_first|highest_balance|pro_rata|manual|system_default — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationNumber rdf:type rdf:Property ;
    rdfs:label 'Application Number' ;
    rdfs:comment 'Business-readable unique identifier for the payment application transaction, used for tracking and reconciliation.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationSequence rdf:type rdf:Property ;
    rdfs:label 'Application Sequence' ;
    rdfs:comment 'Sequential order in which this application was processed for a given payment. Supports scenarios where a single payment is split across multiple invoices.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicationSource rdf:type rdf:Property ;
    rdfs:label 'Application Source' ;
    rdfs:comment 'Source or channel through which the payment application was initiated (e.g., automated system rule, manual CSR entry, batch process, customer self-service portal). [ENUM-REF-CANDIDATE: automated|manual|batch|api|customer_portal|ivr|mobile_app — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationStatus rdf:type rdf:Property ;
    rdfs:label 'Application Status' ;
    rdfs:comment 'Current lifecycle status of the payment application indicating whether funds have been successfully applied, are pending, or have been reversed.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Application Timestamp' ;
    rdfs:comment 'The precise date and time when the payment application transaction was processed in the billing system.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:arReconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Ar Reconciliation Status' ;
    rdfs:comment 'Status indicating whether this payment application has been successfully reconciled in the accounts receivable ledger.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceBucketCode rdf:type rdf:Property ;
    rdfs:label 'Balance Bucket Code' ;
    rdfs:comment 'Code identifying the account balance bucket or aging category to which the payment was applied (e.g., current, 30-day, 60-day, 90-day past due).' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeType rdf:type rdf:Property ;
    rdfs:label 'Charge Type' ;
    rdfs:comment 'Category of charge to which the payment was applied, distinguishing between water, wastewater, stormwater, penalties, and other utility charges. [ENUM-REF-CANDIDATE: water|wastewater|stormwater|penalty|interest|reconnection|late_fee|service_charge|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeIndicator rdf:type rdf:Property ;
    rdfs:label 'Dispute Indicator' ;
    rdfs:comment 'Flag indicating whether this payment application is associated with a billing dispute or customer challenge.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOverpayment rdf:type rdf:Property ;
    rdfs:label 'Is Overpayment' ;
    rdfs:comment 'Flag indicating whether this payment application resulted in an overpayment or credit balance on the account.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrepayment rdf:type rdf:Property ;
    rdfs:label 'Is Prepayment' ;
    rdfs:comment 'Flag indicating whether this payment application represents a prepayment applied to future charges rather than outstanding invoices.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overpaymentHandling rdf:type rdf:Property ;
    rdfs:label 'Overpayment Handling' ;
    rdfs:comment 'Indicates how overpayment or excess credit is handled: refunded to customer, held as credit, transferred to another account, or held pending customer instruction.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'The date on which the applied payment amount is recognized as revenue in the general ledger, per GASB revenue recognition standards.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'The date on which this payment application was reversed. Null if not reversed.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Flag indicating whether this payment application has been reversed due to payment failure, dispute, or correction.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'Code indicating the reason for reversing the payment application (e.g., NSF, dispute, system error, customer request).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokenDate rdf:type rdf:Property ;
    rdfs:label 'Broken Date' ;
    rdfs:comment 'Date when the payment plan was marked as broken due to missed payment or violation of terms. Nullable if plan has never been broken.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:brokenReason rdf:type rdf:Property ;
    rdfs:label 'Broken Reason' ;
    rdfs:comment 'Reason the payment plan was marked as broken: missed installment (customer failed to pay on time), late payment (payment received after grace period), new charges unpaid (customer failed to pay current charges while on plan), customer request (customer asked to cancel), or administrative (utility-initiated termination).' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Free-text explanation of why the payment plan was cancelled, capturing business context for audit and reporting purposes.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledDate rdf:type rdf:Property ;
    rdfs:label 'Cancelled Date' ;
    rdfs:comment 'Date when the payment plan was cancelled by the utility or customer before completion. Nullable if plan was not cancelled.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completedDate rdf:type rdf:Property ;
    rdfs:label 'Completed Date' ;
    rdfs:comment 'Date when the payment plan was successfully completed with all installments paid in full. Nullable if plan is not yet completed.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completedInstallments rdf:type rdf:Property ;
    rdfs:label 'Completed Installments' ;
    rdfs:comment 'Number of installment payments successfully made by the customer to date.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Current Balance Amount' ;
    rdfs:comment 'Remaining balance amount still owed under the payment plan after applying all installment payments to date.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Down Payment Amount' ;
    rdfs:comment 'Initial down payment amount required to establish the payment plan, paid at enrollment. Nullable if no down payment was required.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downPaymentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Down Payment Received Date' ;
    rdfs:comment 'Date when the down payment was received and the payment plan was activated. Nullable if no down payment was required.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrolledBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Enrolled Balance Amount' ;
    rdfs:comment 'Total delinquent balance amount enrolled in the payment plan at the time of plan establishment. Represents the arrears being repaid through installments.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Grace Period Days' ;
    rdfs:comment 'Number of days after the installment due date during which a late payment is accepted without breaking the plan.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:installmentAmount rdf:type rdf:Property ;
    rdfs:label 'Installment Amount' ;
    rdfs:comment 'Fixed amount the customer is required to pay per installment period to satisfy the payment plan terms.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:installmentFrequency rdf:type rdf:Property ;
    rdfs:label 'Installment Frequency' ;
    rdfs:comment 'Frequency at which installment payments are due: weekly, biweekly, monthly, or quarterly.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liheapEligible rdf:type rdf:Property ;
    rdfs:label 'Liheap Eligible' ;
    rdfs:comment 'Indicates whether the customer on this payment plan is eligible for LIHEAP or similar low-income energy assistance coordination. True if eligible; false otherwise.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextInstallmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Installment Due Date' ;
    rdfs:comment 'Date when the next installment payment is due from the customer.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan End Date' ;
    rdfs:comment 'Scheduled date when the payment plan is expected to be completed if all installments are paid on time. Nullable for open-ended plans.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Number' ;
    rdfs:comment 'Externally visible unique business identifier for the payment plan, formatted as PP-XXXXXXXX.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Start Date' ;
    rdfs:comment 'Date when the payment plan becomes effective and the first installment is due.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle status of the payment plan: active (customer is making payments on schedule), broken (customer missed payment and violated terms), completed (all installments paid), cancelled (plan terminated by utility or customer), suspended (temporarily paused), or pending approval (awaiting credit review).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Classification of the payment plan arrangement: budget billing (level monthly payments), deferred payment agreement (short-term installment), low-income assistance (subsidized plan), arrearage management (long-term debt forgiveness plan), seasonal payment (adjusted for seasonal usage), or extended payment (custom extended terms).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresCurrentChargesPaid rdf:type rdf:Property ;
    rdfs:label 'Requires Current Charges Paid' ;
    rdfs:comment 'Indicates whether the customer must pay all new current charges in addition to installment payments to remain in good standing on the plan. True if current charges must be paid; false if only installments are required.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalInstallments rdf:type rdf:Property ;
    rdfs:label 'Total Installments' ;
    rdfs:comment 'Total number of scheduled installment payments required to complete the payment plan.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateComponentId rdf:type rdf:Property ;
    rdfs:label 'Rate Component Id' ;
    rdfs:comment 'Unique identifier for the rate component. Primary key for the rate component entity.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'Name of the regulatory body or internal authority that approved this rate component. Examples: State Public Utilities Commission, City Council, Utility Board of Directors.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billPrintLabel rdf:type rdf:Property ;
    rdfs:label 'Bill Print Label' ;
    rdfs:comment 'Customer-facing label text displayed on the bill for this component. Should be clear and understandable to customers. Examples: Monthly Service Charge, Water Usage - First 5 CCF, Stormwater Fee.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationFormula rdf:type rdf:Property ;
    rdfs:label 'Calculation Formula' ;
    rdfs:comment 'Custom calculation expression for formula-based components. Contains the algorithmic logic used to compute the charge amount, referencing other rate components, usage data, or account attributes. Null for standard calculation methods.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'Algorithm used to calculate the charge amount. Flat amount applies a fixed charge regardless of usage, per-unit multiplies usage by unit rate, tiered block applies different rates to usage ranges, percentage applies a rate to another charge, and formula uses a custom calculation expression.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentCode rdf:type rdf:Property ;
    rdfs:label 'Component Code' ;
    rdfs:comment 'Business identifier code for the rate component used in billing systems and rate books. Examples: BASE_CHG, TIER1_VOL, DEMAND_CHG, STORMWATER_FEE.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentName rdf:type rdf:Property ;
    rdfs:label 'Component Name' ;
    rdfs:comment 'Human-readable name of the rate component. Examples: Base Service Charge, First Tier Volumetric Charge, Peak Demand Charge, Stormwater Management Fee.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentType rdf:type rdf:Property ;
    rdfs:label 'Component Type' ;
    rdfs:comment 'Classification of the rate component defining its billing purpose. Base charges are fixed monthly fees, volumetric charges are consumption-based, demand charges are based on peak usage, tier charges apply to usage blocks, surcharges are additional fees, taxes are regulatory levies, fees are service-specific charges, adjustments modify base amounts, and credits reduce charges. [ENUM-REF-CANDIDATE: base_charge|volumetric_charge|demand_charge|tier_charge|surcharge|tax|fee|adjustment|credit — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conservationTierFlag rdf:type rdf:Property ;
    rdfs:label 'Conservation Tier Flag' ;
    rdfs:comment 'Indicates whether this component is part of a conservation-oriented inclining block rate structure designed to discourage excessive water use. True for higher-tier volumetric charges that increase with consumption.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flatAmount rdf:type rdf:Property ;
    rdfs:label 'Flat Amount' ;
    rdfs:comment 'Fixed charge amount for flat-rate components such as base service charges, connection fees, or fixed surcharges. Null for volumetric or percentage-based components.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isVolumetric rdf:type rdf:Property ;
    rdfs:label 'Is Volumetric' ;
    rdfs:comment 'Indicates whether the component is consumption-based (volumetric) or fixed. True for components that vary with usage (per-unit, tiered block). False for fixed charges (base charges, flat fees). Used to distinguish variable from fixed revenue components.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meterSizeApplicability rdf:type rdf:Property ;
    rdfs:label 'Meter Size Applicability' ;
    rdfs:comment 'Meter size or size range to which this component applies. Used for meter-size-based base charges. Examples: 5/8 inch, 1 inch, 2 inch, 3 inch and larger. Null if component applies to all meter sizes.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:percentageRate rdf:type rdf:Property ;
    rdfs:label 'Percentage Rate' ;
    rdfs:comment 'Percentage rate applied for percentage-based components such as taxes, surcharges, or adjustments. Expressed as a decimal (e.g., 0.0825 for 8.25% sales tax). Null for non-percentage components.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:printOnBillFlag rdf:type rdf:Property ;
    rdfs:label 'Print On Bill Flag' ;
    rdfs:comment 'Indicates whether this component should be displayed as a separate line item on customer bills. True for components that require transparency and customer visibility. False for internal calculation components.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Rate Case Number' ;
    rdfs:comment 'Regulatory rate case docket number or internal rate change request identifier associated with this component. Links the component to the formal rate approval process.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateComponentDescription rdf:type rdf:Property ;
    rdfs:label 'Rate Component Description' ;
    rdfs:comment 'Detailed business description of the rate component, its purpose, and how it is applied. Provides context for billing staff, customer service representatives, and customers reviewing their bills.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateComponentStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Component Status' ;
    rdfs:comment 'Current lifecycle status of the rate component. Active components are in use for billing. Inactive components are temporarily disabled. Pending approval components await regulatory approval. Superseded components have been replaced by newer versions. Retired components are no longer used and retained for historical reference only.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingCategory rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Category' ;
    rdfs:comment 'Classification code for regulatory financial reporting and rate case filings. Maps the component to standardized reporting categories required by state public utilities commissions.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalIndicator rdf:type rdf:Property ;
    rdfs:label 'Seasonal Indicator' ;
    rdfs:comment 'Seasonal applicability of the rate component. Supports seasonal rate structures for water conservation. Year-round applies all year, summer/winter/spring/fall apply to specific seasons, peak/off-peak apply to demand periods. [ENUM-REF-CANDIDATE: year_round|summer|winter|spring|fall|peak|off_peak — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Ordering sequence for component calculation and display within the rate schedule. Lower numbers are calculated and displayed first. Critical for components with dependencies (e.g., base charge calculated before percentage surcharge).' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierHighThreshold rdf:type rdf:Property ;
    rdfs:label 'Tier High Threshold' ;
    rdfs:comment 'Upper bound of the usage quantity range for tiered block rate components. Defines the maximum consumption level (inclusive) to which this tier rate applies. Measured in the component\'s unit of measure. Null indicates no upper limit (open-ended tier). Null for non-tiered components.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierLowThreshold rdf:type rdf:Property ;
    rdfs:label 'Tier Low Threshold' ;
    rdfs:comment 'Lower bound of the usage quantity range for tiered block rate components. Defines the minimum consumption level (inclusive) to which this tier rate applies. Measured in the component\'s unit of measure. Null for non-tiered components.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Unit of measure for volumetric or demand-based components. CCF (hundred cubic feet) is the standard water billing unit in North America. Gallons, kgal (thousand gallons), mgal (million gallons), and cubic meters are alternative volume units. Each applies to count-based charges. kWh and therm apply to energy-related charges. NA indicates non-volumetric components like flat fees. [ENUM-REF-CANDIDATE: CCF|gallon|kgal|mgal|cubic_meter|each|kWh|therm|NA — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financeRateCaseId rdf:type rdf:Property ;
    rdfs:label 'Finance Rate Case Id' ;
    rdfs:comment 'Foreign key reference to the rate case (regulatory proceeding) that established or modified this rate schedule. Links to the rate_case product.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinanceRateCase .

ind:offeringId rdf:type rdf:Property ;
    rdfs:label 'Offering Id' ;
    rdfs:comment 'Foreign key linking to service.offering. Business justification: Rate schedules implement the pricing structure for service offerings (residential water, commercial wastewater, irrigation). Tariff administration and rate case filings require linking approved rate s' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offering .

ind:supersededByRateScheduleBillingRateScheduleId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rate Schedule Billing Rate Schedule Id' ;
    rdfs:comment 'Foreign key reference to the rate schedule that supersedes this one. Nullable if this rate schedule is current or retired without replacement.' ;
    rdfs:domain ind:BillingRateSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingRateSchedule .

ind:baseChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Base Charge Amount' ;
    rdfs:comment 'Fixed monthly or periodic base charge (service charge) applied to customers under this rate schedule, regardless of consumption. Expressed in local currency.' ;
    rdfs:domain ind:BillingRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingRateScheduleDescription rdf:type rdf:Property ;
    rdfs:label 'Billing Rate Schedule Description' ;
    rdfs:comment 'Detailed description of the rate schedule, including its purpose, applicability, and any special conditions or notes.' ;
    rdfs:domain ind:BillingRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingRateScheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Billing Rate Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the rate schedule (draft, pending approval, active, superseded, retired). Lifecycle status of the tariff.' ;
    rdfs:domain ind:BillingRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conservationRateIndicator rdf:type rdf:Property ;
    rdfs:label 'Conservation Rate Indicator' ;
    rdfs:comment 'Indicates whether this rate schedule is designed to promote water conservation through inclining block or penalty pricing (true) or not (false).' ;
    rdfs:domain ind:BillingRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerClass rdf:type rdf:Property ;
    rdfs:label 'Customer Class' ;
    rdfs:comment 'Customer class or segment this rate schedule applies to (e.g., residential, commercial, industrial, irrigation, municipal, institutional). Classification of the tariff by customer segment.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:droughtSurchargeApplicable rdf:type rdf:Property ;
    rdfs:label 'Drought Surcharge Applicable' ;
    rdfs:comment 'Indicates whether a drought surcharge or emergency rate adjustment can be applied under this rate schedule (true) or not (false).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'Geographic or regulatory jurisdiction where this rate schedule applies (e.g., city, county, state, service territory name). Defines the geographic scope of the tariff.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Charge Amount' ;
    rdfs:comment 'Maximum total charge amount per billing period under this rate schedule (cap). Nullable if no maximum applies.' ;
    rdfs:domain ind:BillingRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Charge Amount' ;
    rdfs:comment 'Minimum total charge amount per billing period under this rate schedule, regardless of consumption. Nullable if no minimum applies.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateScheduleName rdf:type rdf:Property ;
    rdfs:label 'Rate Schedule Name' ;
    rdfs:comment 'Human-readable name of the rate schedule (e.g., \'Residential Tiered Water Rate\', \'Commercial Flat Wastewater Rate\'). Identity label for the tariff.' ;
    rdfs:domain ind:BillingRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateStructureType rdf:type rdf:Property ;
    rdfs:label 'Rate Structure Type' ;
    rdfs:comment 'Type of rate structure used for billing calculations (e.g., flat, tiered/inclining block, seasonal, time-of-use, budget-based, uniform, declining block). Defines the pricing methodology. [ENUM-REF-CANDIDATE: flat|tiered|seasonal|time_of_use|budget_based|uniform|declining_block — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Date' ;
    rdfs:comment 'Date when the regulatory body (e.g., Public Utilities Commission) approved this rate schedule.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryApprovalReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Reference' ;
    rdfs:comment 'Reference number or identifier for the regulatory approval (e.g., Public Utilities Commission (PUC) order number, resolution number) authorizing this rate schedule.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionEventId rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Event Id' ;
    rdfs:comment 'Unique identifier for the revenue recognition event record. Primary key.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalEventId rdf:type rdf:Property ;
    rdfs:label 'Original Event Id' ;
    rdfs:comment 'Reference to the original revenue recognition event that is being reversed, if this is a reversal event.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueRecognitionEvent .

ind:primaryRevenueEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Revenue Employee Id' ;
    rdfs:comment 'User ID of the person or system account that posted this revenue recognition event to the general ledger.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reversedEventId rdf:type rdf:Property ;
    rdfs:label 'Reversed Event Id' ;
    rdfs:comment 'Reference to the original revenue recognition event that this event reverses, if applicable.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueRecognitionEvent .

ind:writeOffId rdf:type rdf:Property ;
    rdfs:label 'Write Off Id' ;
    rdfs:comment 'Foreign key linking to billing.write_off. Business justification: Write-offs are revenue-impacting transactions that trigger revenue recognition events (bad debt expense recognition). Each revenue recognition event triggered by a write-off should reference the sourc' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WriteOff .

ind:accountingPeriod rdf:type rdf:Property ;
    rdfs:label 'Accounting Period' ;
    rdfs:comment 'Fiscal period to which this revenue recognition event is assigned, typically in YYYY-MM or YYYYPP format.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accruedRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Accrued Revenue Amount' ;
    rdfs:comment 'Amount of revenue accrued for services rendered but not yet invoiced or collected.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumptionUom rdf:type rdf:Property ;
    rdfs:label 'Consumption Uom' ;
    rdfs:comment 'Unit of measure for the consumption volume.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumptionVolume rdf:type rdf:Property ;
    rdfs:label 'Consumption Volume' ;
    rdfs:comment 'Volume of water or wastewater consumed during the service period for which revenue is recognized.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deferredRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Deferred Revenue Amount' ;
    rdfs:comment 'Amount of revenue deferred to future periods, representing unearned revenue at the recognition date.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventNumber rdf:type rdf:Property ;
    rdfs:label 'Event Number' ;
    rdfs:comment 'Business-readable unique identifier for the revenue recognition event, typically system-generated.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current lifecycle status of the revenue recognition event in the financial system.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Date and time when the revenue recognition event occurred in the source system (Oracle CC&B or payment processor).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Type of accounting event that triggered revenue recognition: invoice posted, payment received, adjustment applied, write-off recorded, reversal posted, or accrual recorded.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Date' ;
    rdfs:comment 'The date on which revenue is recognized for accounting purposes, following GASB revenue recognition principles.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionStatus rdf:type rdf:Property ;
    rdfs:label 'Recognition Status' ;
    rdfs:comment 'Current lifecycle status of the revenue recognition event in the accounting workflow.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recognition Timestamp' ;
    rdfs:comment 'Precise date and time when the revenue recognition event was recorded in the system.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recognizedRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Recognized Revenue Amount' ;
    rdfs:comment 'Actual revenue amount recognized in the general ledger for this event, after any allocations or adjustments.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'Date when the revenue recognition event was successfully reconciled between billing and financial systems.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Status of reconciliation between the billing system (Oracle CC&B) and the financial system (SAP/Munis) for this revenue event.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Amount' ;
    rdfs:comment 'Total amount of revenue recognized in this event before any adjustments or allocations.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:servicePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Service Period End Date' ;
    rdfs:comment 'Ending date of the service period for which revenue is being recognized.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:servicePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Service Period Start Date' ;
    rdfs:comment 'Beginning date of the service period for which revenue is being recognized.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'System of record that originated this revenue recognition event (Oracle CC&B, SAP FI/CO, Tyler Munis, or manual entry).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount' ;
    rdfs:comment 'Monetary amount of the revenue recognition event before any adjustments or allocations.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unbilledRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Unbilled Revenue Amount' ;
    rdfs:comment 'Amount of revenue recognized for services provided but not yet billed to the customer.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'Difference between expected and actual revenue amounts during reconciliation, if any variance exists.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By User Employee Id' ;
    rdfs:comment 'System user identifier of the person who initiated the write-off transaction.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryWriteEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Write Employee Id' ;
    rdfs:comment 'System user identifier of the person who approved the write-off transaction.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:collectionAgencyName rdf:type rdf:Property ;
    rdfs:label 'Collection Agency Name' ;
    rdfs:comment 'Name of the external collection agency to which the account was referred, if applicable.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionAgencyReferralIndicator rdf:type rdf:Property ;
    rdfs:label 'Collection Agency Referral Indicator' ;
    rdfs:comment 'Flag indicating whether the account was referred to an external collection agency prior to write-off. True indicates referral occurred, False indicates no external collection effort.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collectionReferralDate rdf:type rdf:Property ;
    rdfs:label 'Collection Referral Date' ;
    rdfs:comment 'Date on which the account was referred to external collections, if applicable.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:daysOutstanding rdf:type rdf:Property ;
    rdfs:label 'Days Outstanding' ;
    rdfs:comment 'Number of days between the original invoice date and the write-off date, indicating how long the balance remained uncollected.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feeChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Charge Amount' ;
    rdfs:comment 'Portion of the write-off amount attributable to service fees, connection fees, meter fees, and other non-consumption charges.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalInvoiceDate rdf:type rdf:Property ;
    rdfs:label 'Original Invoice Date' ;
    rdfs:comment 'Date of the oldest invoice included in the write-off amount, used to calculate aging and statute of limitations.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:otherChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Other Charge Amount' ;
    rdfs:comment 'Portion of the write-off amount attributable to miscellaneous charges not classified in standard categories.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveryAmount rdf:type rdf:Property ;
    rdfs:label 'Recovery Amount' ;
    rdfs:comment 'Dollar amount subsequently recovered after the write-off was posted. Applies when a previously written-off balance is collected through bankruptcy proceedings, estate settlement, or renewed collection efforts.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveryDate rdf:type rdf:Property ;
    rdfs:label 'Recovery Date' ;
    rdfs:comment 'Date on which a recovery payment was received for a previously written-off balance.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceAddress rdf:type rdf:Property ;
    rdfs:label 'Service Address' ;
    rdfs:comment 'Physical service address associated with the written-off account, used for geographic analysis of write-off patterns and collection effectiveness.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalWriteOffAmount rdf:type rdf:Property ;
    rdfs:label 'Total Write Off Amount' ;
    rdfs:comment 'Total dollar amount written off across all charge categories. Sum of water, wastewater, stormwater, fees, penalties, and other charges being removed from accounts receivable.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffDate rdf:type rdf:Property ;
    rdfs:label 'Write Off Date' ;
    rdfs:comment 'The date on which the uncollectible balance was officially written off from accounts receivable. This is the business event date for revenue recognition and bad debt expense reporting.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffNumber rdf:type rdf:Property ;
    rdfs:label 'Write Off Number' ;
    rdfs:comment 'Business-facing unique identifier for the write-off transaction, typically formatted as WO-YYYY-NNNNNN for external reference and audit trail.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffStatus rdf:type rdf:Property ;
    rdfs:label 'Write Off Status' ;
    rdfs:comment 'Current lifecycle status of the write-off transaction. Pending indicates awaiting approval, approved indicates authorized but not yet posted to GL, posted indicates completed and reflected in financial statements, reversed indicates subsequently recovered or corrected, cancelled indicates voided before posting.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Write Off Timestamp' ;
    rdfs:comment 'Precise timestamp when the write-off transaction was recorded in the system, including time zone information.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ccrId rdf:type rdf:Property ;
    rdfs:label 'Ccr Id' ;
    rdfs:comment 'Unique identifier for the Consumer Confidence Report record. Primary key.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ccr .

ind:preparedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Prepared By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Consumer Confidence Reports require designated preparer for regulatory compliance and quality assurance. Links to employee for training verification, workload tracking, and audit trail of who compiled' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:regulatorySubmissionId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_submission. Business justification: The Consumer Confidence Report (CCR) is an annual regulatory submission required by SDWA. The ccr table tracks certification_submitted_date, certification_method, and state_certification_number, which' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatorySubmission .

ind:samplingLocationId rdf:type rdf:Property ;
    rdfs:label 'Sampling Location Id' ;
    rdfs:comment 'Foreign key linking to laboratory.sampling_location. Business justification: Consumer Confidence Reports summarize monitoring data by location (source water, entry points, distribution system). Annual reporting requirement needs direct link to sampling locations for automated ' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SamplingLocation .

ind:additionalLanguages rdf:type rdf:Property ;
    rdfs:label 'Additional Languages' ;
    rdfs:comment 'List of additional languages in which CCR information or translations were provided to serve non-English speaking customers. Pipe-separated list (e.g., Spanish|Chinese|Vietnamese).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardMeetingInfo rdf:type rdf:Property ;
    rdfs:label 'Board Meeting Info' ;
    rdfs:comment 'Information about public meetings where customers can participate in decisions affecting drinking water quality, including meeting times, locations, and how to attend. Required CCR content for community water systems.' ;
    rdfs:domain ind:Ccr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Overall compliance status of this CCR with EPA and state requirements. Compliant indicates all requirements met. Non-compliant indicates violations. Pending review indicates state review in progress.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Email address for customer inquiries about the Consumer Confidence Report and water quality information.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactName rdf:type rdf:Property ;
    rdfs:label 'Contact Name' ;
    rdfs:comment 'Name of the water system contact person for customer questions about the CCR. Required CCR content per EPA rule.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Phone number for customer inquiries about the Consumer Confidence Report and water quality information. Required CCR content per EPA rule.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contaminantDetectionCount rdf:type rdf:Property ;
    rdfs:label 'Contaminant Detection Count' ;
    rdfs:comment 'Total number of regulated contaminants detected in the water system during the report year. All detected contaminants must be reported in the CCR regardless of whether they exceed Maximum Contaminant Levels (MCL).' ;
    rdfs:domain ind:Ccr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:copper90thPercentilePpm rdf:type rdf:Property ;
    rdfs:label 'Copper 90th Percentile Ppm' ;
    rdfs:comment '90th percentile value for copper in parts per million from tap water sampling. Action level is 1.3 PPM. Required reporting for systems that conducted lead and copper monitoring.' ;
    rdfs:domain ind:Ccr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disinfectionByproductMonitoringFlag rdf:type rdf:Property ;
    rdfs:label 'Disinfection Byproduct Monitoring Flag' ;
    rdfs:comment 'Indicates whether disinfection byproduct monitoring for Total Trihalomethanes (THM) and Haloacetic Acids (HAA5) was conducted during the report year. True if monitoring was performed.' ;
    rdfs:domain ind:Ccr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentFilePath rdf:type rdf:Property ;
    rdfs:label 'Document File Path' ;
    rdfs:comment 'File system path or document management system location where the published CCR PDF or document is stored for archival and retrieval purposes.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:educationalInformationIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Educational Information Included Flag' ;
    rdfs:comment 'Indicates whether mandatory educational information about contaminants and health effects was included in the CCR. Required content includes information about immunocompromised persons, sources of contamination, and EPA Safe Drinking Water Hotline.' ;
    rdfs:domain ind:Ccr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:electronicDeliveryCount rdf:type rdf:Property ;
    rdfs:label 'Electronic Delivery Count' ;
    rdfs:comment 'Number of customers who received the CCR electronically via email or online portal access. Systems must obtain customer consent for electronic delivery.' ;
    rdfs:domain ind:Ccr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:languageAccessibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Language Accessibility Flag' ;
    rdfs:comment 'Indicates whether the CCR includes information in languages other than English to serve non-English speaking populations. Systems must provide multilingual outreach when a significant portion of the population speaks another language.' ;
    rdfs:domain ind:Ccr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lead90thPercentilePpb rdf:type rdf:Property ;
    rdfs:label 'Lead 90th Percentile Ppb' ;
    rdfs:comment '90th percentile value for lead in parts per billion from tap water sampling. Action level is 15 PPB. Required reporting for systems that conducted lead and copper monitoring.' ;
    rdfs:domain ind:Ccr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadCopperMonitoringFlag rdf:type rdf:Property ;
    rdfs:label 'Lead Copper Monitoring Flag' ;
    rdfs:comment 'Indicates whether lead and copper monitoring was conducted during the report year per Lead and Copper Rule Revisions (LCRR) requirements. True if monitoring was performed.' ;
    rdfs:domain ind:Ccr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mailedCount rdf:type rdf:Property ;
    rdfs:label 'Mailed Count' ;
    rdfs:comment 'Number of physical CCR copies mailed to customers. Used to document delivery compliance and calculate distribution costs.' ;
    rdfs:domain ind:Ccr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mclExceedanceFlag rdf:type rdf:Property ;
    rdfs:label 'Mcl Exceedance Flag' ;
    rdfs:comment 'Indicates whether any detected contaminants exceeded their Maximum Contaminant Level during the report year. True if any MCL exceedances occurred.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'User ID or name of the person who last modified this CCR record. Part of audit trail for regulatory compliance tracking.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationServed rdf:type rdf:Property ;
    rdfs:label 'Population Served' ;
    rdfs:comment 'Total number of people served by this water system during the report year. Used to determine CCR delivery requirements and system classification.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'Date on which this Consumer Confidence Report was published and made available to customers. Must be by July 1 of the year following the report year.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pwsCode rdf:type rdf:Property ;
    rdfs:label 'Pws Code' ;
    rdfs:comment 'EPA-assigned Public Water System identification number. Format: two-letter state code followed by seven digits (e.g., CA1234567). Links this CCR to the specific water system.' ;
    rdfs:domain ind:Ccr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportYear rdf:type rdf:Property ;
    rdfs:label 'Report Year' ;
    rdfs:comment 'Calendar year for which this Consumer Confidence Report covers water quality data and compliance information. CCRs must be published annually by July 1 of the following year.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceAreaDescription rdf:type rdf:Property ;
    rdfs:label 'Service Area Description' ;
    rdfs:comment 'Geographic description of the area served by this water system, including municipalities, counties, or districts covered by this CCR.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceWaterDescription rdf:type rdf:Property ;
    rdfs:label 'Source Water Description' ;
    rdfs:comment 'Detailed description of the source water including specific water bodies, aquifers, wells, or treatment plant intake locations. Required CCR content per EPA rule.' ;
    rdfs:domain ind:Ccr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceWaterType rdf:type rdf:Property ;
    rdfs:label 'Source Water Type' ;
    rdfs:comment 'Classification of the primary source water for this system. Surface water includes rivers, lakes, and reservoirs. Groundwater includes wells and aquifers. GWUDI is groundwater under direct influence of surface water. Mixed indicates multiple source types.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialNoticeRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Special Notice Required Flag' ;
    rdfs:comment 'Indicates whether special public notice was required due to violations or other circumstances. Systems with certain violations must include additional notification language in the CCR.' ;
    rdfs:domain ind:Ccr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialNoticeText rdf:type rdf:Property ;
    rdfs:label 'Special Notice Text' ;
    rdfs:comment 'Text of any special public notice included in the CCR due to violations, variances, exemptions, or other circumstances requiring additional customer notification.' ;
    rdfs:domain ind:Ccr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemName rdf:type rdf:Property ;
    rdfs:label 'System Name' ;
    rdfs:comment 'Official name of the public water system issuing this Consumer Confidence Report.' ;
    rdfs:domain ind:Ccr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Violation Included Flag' ;
    rdfs:comment 'Indicates whether this CCR includes reporting of any Maximum Contaminant Level (MCL), Maximum Residual Disinfectant Level (MRDL), treatment technique, or monitoring violations during the report year. True if violations are reported.' ;
    rdfs:domain ind:Ccr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:violationSummary rdf:type rdf:Property ;
    rdfs:label 'Violation Summary' ;
    rdfs:comment 'Summary description of any water quality violations, treatment technique violations, or monitoring violations that occurred during the report year. Must include health effects language and corrective actions taken.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Web address where the Consumer Confidence Report is posted for public access. Required for systems serving more than 100,000 people.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationId rdf:type rdf:Property ;
    rdfs:label 'Obligation Id' ;
    rdfs:comment 'Unique identifier for the compliance obligation record. Primary key.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Obligation .

ind:assignedEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Compliance obligations (sampling, reporting, inspections) must be assigned to specific employees for accountability. Tracks who is responsible for completing each regulatory task and supports workload' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:compliancePermitId rdf:type rdf:Property ;
    rdfs:label 'Compliance Permit Id' ;
    rdfs:comment 'Reference to the specific permit (NPDES, IUP, state primacy agency permit) associated with this obligation, if applicable.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompliancePermit .

ind:financeBudgetId rdf:type rdf:Property ;
    rdfs:label 'Finance Budget Id' ;
    rdfs:comment 'Foreign key linking to finance.budget. Business justification: Compliance obligations require budget appropriations for monitoring, reporting, and capital improvements. Essential for compliance budget planning and tracking expenditures against regulatory deadline' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinanceBudget .

ind:samplingPlanId rdf:type rdf:Property ;
    rdfs:label 'Sampling Plan Id' ;
    rdfs:comment 'Foreign key linking to laboratory.sampling_plan. Business justification: Compliance obligations (e.g., consent order milestones) often require execution of specific sampling plans. Direct link tracks fulfillment mechanism and enables automated obligation status reporting b' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SamplingPlan .

ind:actualEffortHours rdf:type rdf:Property ;
    rdfs:label 'Actual Effort Hours' ;
    rdfs:comment 'Actual number of labor hours expended to complete this compliance obligation, captured for performance analysis and future estimation accuracy.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completedBy rdf:type rdf:Property ;
    rdfs:label 'Completed By' ;
    rdfs:comment 'Name or identifier of the individual who completed and documented the compliance obligation, for accountability and audit purposes.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'Precise date and time when the compliance obligation was marked as completed in the system, including time zone information for audit trail purposes.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contactPerson rdf:type rdf:Property ;
    rdfs:label 'Contact Person' ;
    rdfs:comment 'Name of the regulatory agency contact person or inspector associated with this obligation, for coordination and communication purposes.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRequired rdf:type rdf:Property ;
    rdfs:label 'Escalation Required' ;
    rdfs:comment 'Boolean flag indicating whether this obligation requires escalation to senior management or regulatory affairs due to complexity, risk, or overdue status.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedEffortHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Effort Hours' ;
    rdfs:comment 'Estimated number of labor hours required to complete this compliance obligation, used for resource planning and workload management.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evidenceOfFulfillment rdf:type rdf:Property ;
    rdfs:label 'Evidence Of Fulfillment' ;
    rdfs:comment 'Description or reference to documentation proving completion of the obligation (e.g., laboratory report number, DMR submission confirmation, training certificate number, inspection report ID).' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCriticalPath rdf:type rdf:Property ;
    rdfs:label 'Is Critical Path' ;
    rdfs:comment 'Boolean flag indicating whether this obligation is on the critical path for permit renewal, regulatory approval, or operational continuity. True if delay would have cascading regulatory or operational consequences.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:obligationDescription rdf:type rdf:Property ;
    rdfs:label 'Obligation Description' ;
    rdfs:comment 'Detailed description of the compliance obligation, including specific actions required, parameters to be monitored or reported, and any special conditions or instructions.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationNumber rdf:type rdf:Property ;
    rdfs:label 'Obligation Number' ;
    rdfs:comment 'Business-facing unique identifier or tracking number for the compliance obligation, used in operational communications and reporting.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationStatus rdf:type rdf:Property ;
    rdfs:label 'Obligation Status' ;
    rdfs:comment 'Current lifecycle status of the compliance obligation: pending (not yet started), in-progress (work underway), completed (fulfilled and documented), overdue (past due date without completion), waived (exempted by regulatory authority), or cancelled (no longer required).' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationType rdf:type rdf:Property ;
    rdfs:label 'Obligation Type' ;
    rdfs:comment 'Classification of the compliance obligation by activity type: monitoring (water quality testing, effluent sampling), reporting (MOR, DMR, CCR), operational (process control, treatment standards), training (operator certification, safety), inspection (regulatory site visits, internal audits), or maintenance (asset upkeep, preventive maintenance).' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceInterval rdf:type rdf:Property ;
    rdfs:label 'Recurrence Interval' ;
    rdfs:comment 'Numeric interval for recurring obligations (e.g., 1 for monthly, 3 for quarterly, 12 for annually). Used in conjunction with recurrence_pattern for scheduling.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recurrencePattern rdf:type rdf:Property ;
    rdfs:label 'Recurrence Pattern' ;
    rdfs:comment 'Frequency with which this obligation recurs: one-time (single event), daily, weekly, monthly (e.g., MOR submission), quarterly, annually (e.g., CCR publication), or as-needed (triggered by specific events). [ENUM-REF-CANDIDATE: one-time|daily|weekly|monthly|quarterly|annually|as-needed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority' ;
    rdfs:comment 'Name of the regulatory agency or authority to which this obligation must be reported or demonstrated (e.g., EPA Region 5, State Department of Environmental Quality, County Health Department).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCitation rdf:type rdf:Property ;
    rdfs:label 'Regulatory Citation' ;
    rdfs:comment 'Specific citation to the regulatory source (SDWA section, CWA section, CFR part, state regulation, permit condition number) that mandates this obligation.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleDepartment rdf:type rdf:Property ;
    rdfs:label 'Responsible Department' ;
    rdfs:comment 'Department or division within the organization accountable for fulfilling this obligation (e.g., Operations, Environmental Compliance, Laboratory, Maintenance).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleParty rdf:type rdf:Property ;
    rdfs:label 'Responsible Party' ;
    rdfs:comment 'Name or identifier of the individual, role, or organizational unit responsible for completing this compliance obligation (e.g., Chief Operator, Environmental Compliance Manager, Laboratory Director).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Category' ;
    rdfs:comment 'Primary risk domain associated with non-compliance: public-health (drinking water safety, MCL violations), environmental (discharge limits, ecosystem impact), financial (penalties, fines), operational (permit suspension, operational restrictions), or reputational (public trust, media exposure).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Submission Confirmation Number' ;
    rdfs:comment 'Confirmation or tracking number received from the regulatory authority upon successful submission of the compliance deliverable (e.g., NetDMR confirmation ID).' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'Method by which the compliance obligation deliverable was submitted to the regulatory authority: electronic (e.g., NetDMR, state portal), paper (mailed hard copy), in-person (hand-delivered), or not-applicable (internal obligation with no external submission).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceScheduleId rdf:type rdf:Property ;
    rdfs:label 'Compliance Schedule Id' ;
    rdfs:comment 'Unique identifier for the compliance schedule record. Primary key.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsibleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Compliance schedules require designated responsible party for milestone tracking and regulatory reporting. Links to employee for accountability, workload management, and contact information. Replaces ' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualTotalCost rdf:type rdf:Property ;
    rdfs:label 'Actual Total Cost' ;
    rdfs:comment 'Actual total cost incurred to date in executing the compliance schedule, including all capital and operating expenditures.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'URL or file path to the official compliance schedule document, consent order, or administrative order that formally establishes the schedule and its milestones.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedTotalCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Cost' ;
    rdfs:comment 'Estimated total cost to complete all milestones and achieve full compliance under this schedule, including capital expenditures (CAPEX) and operating expenditures (OPEX).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extensionApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Extension Approval Date' ;
    rdfs:comment 'Date on which the regulatory authority formally approved the extension request.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extensionApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Extension Approved Flag' ;
    rdfs:comment 'Indicates whether the regulatory authority approved the requested extension to the compliance schedule.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extensionJustification rdf:type rdf:Property ;
    rdfs:label 'Extension Justification' ;
    rdfs:comment 'Detailed explanation or justification provided by the utility for requesting an extension to the compliance schedule, including any unforeseen circumstances, technical challenges, or resource constraints.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extensionRequestDate rdf:type rdf:Property ;
    rdfs:label 'Extension Request Date' ;
    rdfs:comment 'Date on which the utility submitted a formal request to extend the compliance schedule deadlines.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extensionRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Extension Requested Flag' ;
    rdfs:comment 'Indicates whether the utility has requested an extension to the compliance schedule deadlines.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:finalComplianceDeadline rdf:type rdf:Property ;
    rdfs:label 'Final Compliance Deadline' ;
    rdfs:comment 'The ultimate deadline by which the utility must achieve full compliance with the regulatory requirement or permit condition. This is the final milestone in the schedule.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'Name of the regulatory agency or authority that issued or approved the compliance schedule (e.g., EPA Region, State Primacy Agency, local environmental department).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastStatusUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Status Update Date' ;
    rdfs:comment 'Date of the most recent status update or progress report submitted to the regulatory authority regarding the compliance schedule.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:milestoneCount rdf:type rdf:Property ;
    rdfs:label 'Milestone Count' ;
    rdfs:comment 'Total number of milestones defined within this compliance schedule. Milestones are typically tracked in a separate related table.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milestonesCompletedCount rdf:type rdf:Property ;
    rdfs:label 'Milestones Completed Count' ;
    rdfs:comment 'Number of milestones that have been completed as of the current date. Used to track progress toward full compliance.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milestonesOverdueCount rdf:type rdf:Property ;
    rdfs:label 'Milestones Overdue Count' ;
    rdfs:comment 'Number of milestones that are past their due date and have not been completed. Indicates potential non-compliance with the schedule.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextStatusUpdateDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Status Update Due Date' ;
    rdfs:comment 'Date by which the next status update or progress report is due to be submitted to the regulatory authority.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onScheduleFlag rdf:type rdf:Property ;
    rdfs:label 'On Schedule Flag' ;
    rdfs:comment 'Indicates whether the compliance schedule is currently on track to meet all milestone deadlines and the final compliance deadline. False if any milestones are overdue or at risk.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalFinalDeadline rdf:type rdf:Property ;
    rdfs:label 'Original Final Deadline' ;
    rdfs:comment 'The original final compliance deadline as initially agreed upon, preserved for audit and tracking purposes even if the schedule is later extended.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overallCompletionPercentage rdf:type rdf:Property ;
    rdfs:label 'Overall Completion Percentage' ;
    rdfs:comment 'Percentage of the compliance schedule that has been completed, calculated as (milestones_completed_count / milestone_count) * 100. Provides a high-level progress indicator.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publicNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Public Notification Date' ;
    rdfs:comment 'Date on which the utility provided public notification regarding the compliance schedule, if required.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Public Notification Required Flag' ;
    rdfs:comment 'Indicates whether the utility is required to provide public notification regarding the compliance schedule, such as inclusion in the Consumer Confidence Report (CCR) or public notices.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryCorrespondenceCount rdf:type rdf:Property ;
    rdfs:label 'Regulatory Correspondence Count' ;
    rdfs:comment 'Number of formal correspondence items (letters, emails, reports) exchanged between the utility and the regulatory authority regarding this compliance schedule.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduleDescription rdf:type rdf:Property ;
    rdfs:label 'Schedule Description' ;
    rdfs:comment 'Detailed description of the compliance schedule, including the nature of the non-compliance, the corrective actions required, and the overall scope of work to achieve compliance.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleType rdf:type rdf:Property ;
    rdfs:label 'Schedule Type' ;
    rdfs:comment 'Classification of the compliance schedule based on its legal or regulatory origin (e.g., consent order, administrative order, permit condition, settlement agreement, voluntary schedule).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCorrectiveActionId rdf:type rdf:Property ;
    rdfs:label 'Compliance Corrective Action Id' ;
    rdfs:comment 'Unique identifier for the corrective action record. Primary key.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceCorrectiveAction .

ind:encumbranceId rdf:type rdf:Property ;
    rdfs:label 'Encumbrance Id' ;
    rdfs:comment 'Foreign key linking to finance.encumbrance. Business justification: Corrective action contracts create encumbrances against budgets when purchase orders or contracts are issued. Standard governmental accounting practice for commitment tracking.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Encumbrance .

ind:inspectionFindingId rdf:type rdf:Property ;
    rdfs:label 'Inspection Finding Id' ;
    rdfs:comment 'Reference to the inspection finding that identified the compliance gap requiring corrective action.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionFinding .

ind:overflowEventId rdf:type rdf:Property ;
    rdfs:label 'Overflow Event Id' ;
    rdfs:comment 'Foreign key linking to compliance.overflow_event. Business justification: Corrective actions can be triggered by SSO/CSO overflow events. The overflow_event table has text fields for corrective_action_taken and preventive_action_planned, but no structured link to the correc' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OverflowEvent .

ind:actionDescription rdf:type rdf:Property ;
    rdfs:label 'Action Description' ;
    rdfs:comment 'Detailed description of the corrective action to be taken, including specific tasks, procedures, and deliverables required to address the compliance gap.' ;
    rdfs:domain ind:ComplianceCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionNumber rdf:type rdf:Property ;
    rdfs:label 'Action Number' ;
    rdfs:comment 'Business identifier for the corrective action, typically formatted as a human-readable reference number for tracking and reporting.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionStatus rdf:type rdf:Property ;
    rdfs:label 'Action Status' ;
    rdfs:comment 'Current lifecycle status of the corrective action, tracking progress from planning through completion and verification.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionTitle rdf:type rdf:Property ;
    rdfs:label 'Action Title' ;
    rdfs:comment 'Brief descriptive title summarizing the corrective action for quick identification and reporting.' ;
    rdfs:domain ind:ComplianceCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'Actual date when the corrective action was fully implemented and completed, used to track compliance with regulatory deadlines.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'Actual date when implementation of the corrective action commenced.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agencyNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Agency Notification Date' ;
    rdfs:comment 'Date when the regulatory agency was formally notified of the corrective action plan or completion, fulfilling reporting requirements.' ;
    rdfs:domain ind:ComplianceCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agencyNotificationMethod rdf:type rdf:Property ;
    rdfs:label 'Agency Notification Method' ;
    rdfs:comment 'Method used to notify the regulatory agency of the corrective action, such as formal letter, email, portal submission, phone, or in-person meeting.' ;
    rdfs:domain ind:ComplianceCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyResponse rdf:type rdf:Property ;
    rdfs:label 'Agency Response' ;
    rdfs:comment 'Summary of the regulatory agencys response to the corrective action notification, including any feedback, approval, or additional requirements.' ;
    rdfs:domain ind:ComplianceCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureNotes rdf:type rdf:Property ;
    rdfs:label 'Closure Notes' ;
    rdfs:comment 'Final notes documenting the closure of the corrective action, including lessons learned and recommendations for future compliance management.' ;
    rdfs:domain ind:ComplianceCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessReviewDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Review Date' ;
    rdfs:comment 'Scheduled date for follow-up review to assess the long-term effectiveness of the corrective action and any preventive measures.' ;
    rdfs:domain ind:ComplianceCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivenessReviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Review Outcome' ;
    rdfs:comment 'Summary of the effectiveness review findings, documenting whether the corrective action achieved sustained compliance improvement.' ;
    rdfs:domain ind:ComplianceCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Completion Date' ;
    rdfs:comment 'Target date by which the corrective action must be fully implemented and completed, often driven by regulatory deadlines or consent decree requirements.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'Scheduled date when implementation of the corrective action is planned to begin.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preventiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Description' ;
    rdfs:comment 'Description of preventive measures implemented to address systemic issues and prevent future occurrences of similar compliance gaps.' ;
    rdfs:domain ind:ComplianceCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveActionImplemented rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Implemented' ;
    rdfs:comment 'Indicates whether preventive actions were implemented to prevent recurrence of the compliance gap or violation.' ;
    rdfs:domain ind:ComplianceCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryAgencyNotified rdf:type rdf:Property ;
    rdfs:label 'Regulatory Agency Notified' ;
    rdfs:comment 'Indicates whether the relevant regulatory agency (EPA, state primacy agency, etc.) was notified of the corrective action as required by enforcement orders or consent decrees.' ;
    rdfs:domain ind:ComplianceCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleIndividual rdf:type rdf:Property ;
    rdfs:label 'Responsible Individual' ;
    rdfs:comment 'Name of the individual assigned accountability for ensuring the corrective action is completed on time and meets all requirements.' ;
    rdfs:domain ind:ComplianceCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysis rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis' ;
    rdfs:comment 'Documented analysis identifying the underlying root cause(s) of the compliance gap or violation, supporting effective corrective action design.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingEvidenceLocation rdf:type rdf:Property ;
    rdfs:label 'Supporting Evidence Location' ;
    rdfs:comment 'File path, document management system reference, or physical location where supporting evidence and documentation for the corrective action is stored for audit trail purposes.' ;
    rdfs:domain ind:ComplianceCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringEventDescription rdf:type rdf:Property ;
    rdfs:label 'Triggering Event Description' ;
    rdfs:comment 'Narrative description of the specific event or condition that triggered the need for corrective action, providing context for the compliance response.' ;
    rdfs:domain ind:ComplianceCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringEventType rdf:type rdf:Property ;
    rdfs:label 'Triggering Event Type' ;
    rdfs:comment 'Classification of the event that initiated this corrective action, such as regulatory violation, enforcement action, inspection finding, internal audit, self-disclosure, or customer complaint.' ;
    rdfs:domain ind:ComplianceCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'Date when the corrective action was verified as complete and effective through the specified verification method.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used to verify that the corrective action was implemented effectively and achieved the intended compliance outcome, such as internal audit, third-party audit, regulatory inspection, documentation review, testing, or monitoring.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationNotes rdf:type rdf:Property ;
    rdfs:label 'Verification Notes' ;
    rdfs:comment 'Detailed notes documenting the verification process, findings, and any additional observations regarding the effectiveness of the corrective action.' ;
    rdfs:domain ind:ComplianceCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Status of the verification process indicating whether the corrective action has been confirmed as effective in addressing the compliance gap.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmrId rdf:type rdf:Property ;
    rdfs:label 'Dmr Id' ;
    rdfs:comment 'Unique identifier for the discharge monitoring report record.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dmr .

ind:originalDmrId rdf:type rdf:Property ;
    rdfs:label 'Original Dmr Id' ;
    rdfs:comment 'Reference to the original discharge monitoring report record if this is a resubmission or correction.' ;
    rdfs:domain ind:Dmr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dmr .

ind:outfallId rdf:type rdf:Property ;
    rdfs:label 'Outfall Id' ;
    rdfs:comment 'Reference to the specific discharge outfall or monitoring point where effluent samples were collected for this report.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Outfall .

ind:acknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Date' ;
    rdfs:comment 'The date on which the regulatory authority acknowledged receipt of this discharge monitoring report.' ;
    rdfs:domain ind:Dmr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Date' ;
    rdfs:comment 'The date on which the certifying official signed and certified this discharge monitoring report, attesting to its accuracy under penalty of law.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationStatement rdf:type rdf:Property ;
    rdfs:label 'Certification Statement' ;
    rdfs:comment 'The full text of the legal certification statement signed by the certifying official, typically stating that the report was prepared under their direction and supervision and that the information is true, accurate, and complete to the best of their knowledge.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingOfficialName rdf:type rdf:Property ;
    rdfs:label 'Certifying Official Name' ;
    rdfs:comment 'The full name of the authorized signatory who certified the accuracy and completeness of this discharge monitoring report (typically a principal executive officer or ranking elected official).' ;
    rdfs:domain ind:Dmr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingOfficialTitle rdf:type rdf:Property ;
    rdfs:label 'Certifying Official Title' ;
    rdfs:comment 'The job title or position of the authorized signatory who certified this discharge monitoring report (e.g., General Manager, Mayor, Director of Public Works).' ;
    rdfs:domain ind:Dmr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Additional comments, explanations, or notes provided by the facility regarding this discharge monitoring report, including explanations for exceedances, operational issues, or data quality concerns.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmrNumber rdf:type rdf:Property ;
    rdfs:label 'Dmr Number' ;
    rdfs:comment 'Externally-known unique identifier or tracking number for this discharge monitoring report, often assigned by the regulatory authority or internal tracking system.' ;
    rdfs:domain ind:Dmr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceedanceCount rdf:type rdf:Property ;
    rdfs:label 'Exceedance Count' ;
    rdfs:comment 'The total number of individual parameter measurements within this discharge monitoring report that exceeded their respective permit limits.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lateSubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Late Submission Flag' ;
    rdfs:comment 'Indicates whether this discharge monitoring report was submitted after the regulatory deadline (True if late, False if on time).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monitoringLocationCode rdf:type rdf:Property ;
    rdfs:label 'Monitoring Location Code' ;
    rdfs:comment 'The alphanumeric code identifying the specific monitoring location or sampling point as designated in the NPDES permit (e.g., 001, 002, EFF-1).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noDischargeFlag rdf:type rdf:Property ;
    rdfs:label 'No Discharge Flag' ;
    rdfs:comment 'Indicates whether there was no discharge from the outfall during the reporting period (True if no discharge occurred, False if discharge occurred).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noDischargeReason rdf:type rdf:Property ;
    rdfs:label 'No Discharge Reason' ;
    rdfs:comment 'Explanation for why no discharge occurred during the reporting period (e.g., facility shutdown, seasonal operations, maintenance outage).' ;
    rdfs:domain ind:Dmr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noncomplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Noncompliance Flag' ;
    rdfs:comment 'Indicates whether this discharge monitoring report contains any parameter measurements that exceeded permitted limits, triggering a noncompliance event (True if noncompliance detected, False if all parameters within limits).' ;
    rdfs:domain ind:Dmr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preparerEmail rdf:type rdf:Property ;
    rdfs:label 'Preparer Email' ;
    rdfs:comment 'The email address of the individual who prepared this discharge monitoring report.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparerName rdf:type rdf:Property ;
    rdfs:label 'Preparer Name' ;
    rdfs:comment 'The full name of the individual who prepared and compiled this discharge monitoring report.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparerPhone rdf:type rdf:Property ;
    rdfs:label 'Preparer Phone' ;
    rdfs:comment 'The contact phone number for the individual who prepared this discharge monitoring report.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparerTitle rdf:type rdf:Property ;
    rdfs:label 'Preparer Title' ;
    rdfs:comment 'The job title or position of the individual who prepared this discharge monitoring report (e.g., Environmental Compliance Manager, Laboratory Supervisor).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Explanation provided by the regulatory authority if this discharge monitoring report was rejected, including specific deficiencies or errors that must be corrected.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'The frequency at which this discharge monitoring report must be submitted as specified in the NPDES permit (monthly, quarterly, annual, semi-annual, or weekly).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End Date' ;
    rdfs:comment 'The last day of the monitoring period covered by this discharge monitoring report (typically the last day of the month or quarter).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start Date' ;
    rdfs:comment 'The first day of the monitoring period covered by this discharge monitoring report (typically the first day of the month or quarter).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Resubmission Flag' ;
    rdfs:comment 'Indicates whether this discharge monitoring report is a resubmission of a previously rejected or corrected report (True if resubmission, False if original submission).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateAgencyName rdf:type rdf:Property ;
    rdfs:label 'State Agency Name' ;
    rdfs:comment 'The name of the state environmental or water quality agency that received this discharge monitoring report if submitted under a state-delegated NPDES program.' ;
    rdfs:domain ind:Dmr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'The date on which this discharge monitoring report was submitted to the EPA or state NPDES authority.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionDueDate rdf:type rdf:Property ;
    rdfs:label 'Submission Due Date' ;
    rdfs:comment 'The regulatory deadline by which this discharge monitoring report must be submitted (typically the 28th day of the month following the reporting period).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionStatus rdf:type rdf:Property ;
    rdfs:label 'Submission Status' ;
    rdfs:comment 'The current status of this discharge monitoring report in the submission and review workflow (draft, submitted, accepted by authority, rejected, under review, or resubmitted after corrections).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmrResultId rdf:type rdf:Property ;
    rdfs:label 'Dmr Result Id' ;
    rdfs:comment 'Unique identifier for the individual parameter measurement result recorded on a Discharge Monitoring Report. Primary key for granular compliance tracking at the parameter level.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DmrResult .

ind:dmrSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Dmr Submission Id' ;
    rdfs:comment 'Reference to the parent DMR submission that contains this parameter result. Links the individual measurement to the overall monthly or quarterly discharge report.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DmrSubmission .

ind:finishedWaterProductionId rdf:type rdf:Property ;
    rdfs:label 'Finished Water Production Id' ;
    rdfs:comment 'Foreign key linking to treatment.finished_water_production. Business justification: DMR results report finished water quality parameters from treatment production records. Business process: NPDES discharge monitoring where finished water quality data (turbidity, chlorine residual, pH' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinishedWaterProduction .

ind:laboratoryId rdf:type rdf:Property ;
    rdfs:label 'Laboratory Id' ;
    rdfs:comment 'Reference to the certified laboratory that performed the analysis. Required for audit trails and quality assurance verification.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Laboratory .

ind:modifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this record. Required for regulatory audit trails and accountability in compliance reporting.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:treatmentChemicalMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Treatment Chemical Material Master Id' ;
    rdfs:comment 'Foreign key linking to supply.material_master. Business justification: DMR results must trace back to specific treatment chemicals (coagulants, disinfectants) used to achieve reported parameters. Essential for regulatory audits and compliance verification.' ;
    rdfs:domain ind:DmrResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:analysisDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Date' ;
    rdfs:comment 'The date on which the laboratory analysis was performed. Used to verify compliance with holding time requirements for various parameters.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:analyticalMethod rdf:type rdf:Property ;
    rdfs:label 'Analytical Method' ;
    rdfs:comment 'The EPA-approved analytical method used to measure this parameter (e.g., SM 5210B for BOD, EPA 410.4 for COD, SM 2540D for TSS, EPA 300.0 for nitrate). Ensures measurement accuracy and regulatory acceptance.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Flag' ;
    rdfs:comment 'Internal quality assurance flag indicating the reliability of this measurement result (valid, suspect, invalid, pending review). Used for data validation workflows before regulatory submission.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionLimit rdf:type rdf:Property ;
    rdfs:label 'Detection Limit' ;
    rdfs:comment 'The minimum concentration that can be reliably detected by the analytical method used. Important for interpreting results below detection limits and assessing method adequacy.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enforcementActionRequired rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Required' ;
    rdfs:comment 'Boolean indicator of whether this result triggers a mandatory enforcement action under the permit or regulatory framework. True initiates enforcement workflows.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceedanceFlag rdf:type rdf:Property ;
    rdfs:label 'Exceedance Flag' ;
    rdfs:comment 'Boolean indicator of whether the measured value exceeded the permit limit. True indicates a violation requiring reporting and potential enforcement action.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceedancePercentage rdf:type rdf:Property ;
    rdfs:label 'Exceedance Percentage' ;
    rdfs:comment 'The percentage by which the measured value exceeded the permit limit, calculated as ((measured_value - permit_limit) / permit_limit) * 100. Quantifies the severity of violations.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementFrequency rdf:type rdf:Property ;
    rdfs:label 'Measurement Frequency' ;
    rdfs:comment 'The frequency at which this parameter is required to be monitored under the permit (daily, weekly, monthly, quarterly, annual, continuous). Determines sampling schedule and compliance evaluation periods.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementValue rdf:type rdf:Property ;
    rdfs:label 'Measurement Value' ;
    rdfs:comment 'The actual numeric value measured for this parameter during the monitoring period. Precision supports a wide range of parameter types from trace contaminants to high-volume flow measurements.' ;
    rdfs:domain ind:DmrResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nodiCode rdf:type rdf:Property ;
    rdfs:label 'Nodi Code' ;
    rdfs:comment 'EPA code indicating why no measurement data is reported for a required parameter (e.g., 9 for no discharge, C for facility not operational, Q for quality assurance issue). Used when measurement_value is null.' ;
    rdfs:domain ind:DmrResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfExceedances rdf:type rdf:Property ;
    rdfs:label 'Number Of Exceedances' ;
    rdfs:comment 'The count of individual samples that exceeded the permit limit during the reporting period. Used for compliance tracking and violation severity assessment.' ;
    rdfs:domain ind:DmrResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfSamples rdf:type rdf:Property ;
    rdfs:label 'Number Of Samples' ;
    rdfs:comment 'The total number of individual samples collected and analyzed during the reporting period for this parameter. Used to calculate statistical bases like monthly averages.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parameterCode rdf:type rdf:Property ;
    rdfs:label 'Parameter Code' ;
    rdfs:comment 'Standardized code identifying the specific effluent parameter being measured (e.g., 00310 for BOD, 00340 for COD, 00530 for TSS, 00600 for TDS, 00400 for pH, 50050 for flow, 31616 for fecal coliform, 00620 for nitrate, 00665 for phosphorus). Uses EPA parameter codes from the STORET database.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterName rdf:type rdf:Property ;
    rdfs:label 'Parameter Name' ;
    rdfs:comment 'Human-readable name of the effluent parameter being measured (e.g., Biochemical Oxygen Demand, Chemical Oxygen Demand, Total Suspended Solids, Total Dissolved Solids, pH, Flow, Fecal Coliform, Nitrate, Phosphorus).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitLimitType rdf:type rdf:Property ;
    rdfs:label 'Permit Limit Type' ;
    rdfs:comment 'The type of limit specified in the permit (maximum concentration, minimum value, acceptable range, or narrative standard). Determines how compliance is evaluated.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitLimitValue rdf:type rdf:Property ;
    rdfs:label 'Permit Limit Value' ;
    rdfs:comment 'The numeric limit specified in the NPDES permit for this parameter and statistical base. Used for direct comparison with the measured value to determine compliance status.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qaQcNotes rdf:type rdf:Property ;
    rdfs:label 'Qa Qc Notes' ;
    rdfs:comment 'Free-text notes documenting quality assurance or quality control issues, corrective actions, or special circumstances affecting this measurement. Supports audit trails and regulatory inquiries.' ;
    rdfs:domain ind:DmrResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifierCode rdf:type rdf:Property ;
    rdfs:label 'Qualifier Code' ;
    rdfs:comment 'Code indicating special conditions affecting the measurement (e.g., < for below detection limit, > for above quantification limit, E for estimated value, J for value below reporting limit but above detection limit).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantificationLimit rdf:type rdf:Property ;
    rdfs:label 'Quantification Limit' ;
    rdfs:comment 'The minimum concentration that can be reliably quantified by the analytical method. Typically higher than the detection limit and used for regulatory compliance evaluation.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleCollectionDate rdf:type rdf:Property ;
    rdfs:label 'Sample Collection Date' ;
    rdfs:comment 'The date on which the sample was collected from the outfall for laboratory analysis or field measurement. Critical for tracking temporal compliance patterns.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleCollectionTime rdf:type rdf:Property ;
    rdfs:label 'Sample Collection Time' ;
    rdfs:comment 'The precise timestamp when the sample was collected. Important for grab samples and instantaneous measurements where timing affects results.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sampleType rdf:type rdf:Property ;
    rdfs:label 'Sample Type' ;
    rdfs:comment 'The type of sample collected for this measurement (grab sample, composite sample, or continuous monitoring). Affects data interpretation and compliance evaluation.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalBase rdf:type rdf:Property ;
    rdfs:label 'Statistical Base' ;
    rdfs:comment 'The statistical qualifier or basis for the reported value (e.g., daily maximum, monthly average, weekly average, annual average, instantaneous, geometric mean). Determines how the measurement is compared against permit limits. [ENUM-REF-CANDIDATE: daily_maximum|daily_minimum|monthly_average|weekly_average|annual_average|instantaneous|geometric_mean — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DmrResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'The date and time when this result was submitted to the regulatory agency through NetDMR or other electronic reporting system. Establishes the official compliance record timestamp.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:submittedToRegulatorFlag rdf:type rdf:Property ;
    rdfs:label 'Submitted To Regulator Flag' ;
    rdfs:comment 'Boolean indicator of whether this result has been officially submitted to the regulatory agency as part of the DMR. True indicates the data is part of the official compliance record.' ;
    rdfs:domain ind:DmrResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:violationCategory rdf:type rdf:Property ;
    rdfs:label 'Violation Category' ;
    rdfs:comment 'Classification of the type of violation if non-compliant (effluent limit exceedance, monitoring frequency violation, reporting violation, or none). Used for enforcement prioritization and trend analysis.' ;
    rdfs:domain ind:DmrResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceViolationId rdf:type rdf:Property ;
    rdfs:label 'Compliance Violation Id' ;
    rdfs:comment 'Reference to the primary violation record that triggered this enforcement action. Links to the violation tracking system.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceViolation .

ind:remediationVendorId rdf:type rdf:Property ;
    rdfs:label 'Remediation Vendor Id' ;
    rdfs:comment 'Foreign key linking to supply.vendor. Business justification: Enforcement actions often require specialized vendor services (engineering studies, equipment upgrades, environmental consulting) to achieve compliance. Tracks vendor responsible for remediation work.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:responsibleManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Enforcement actions require designated management oversight for response coordination, legal liaison, and board reporting. Links to employee for accountability tracking and workload management. Replac' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionSummary rdf:type rdf:Property ;
    rdfs:label 'Action Summary' ;
    rdfs:comment 'Brief summary of the enforcement action, including the nature of the violation, regulatory basis, and key requirements. Provides context for reporting and management review.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionType rdf:type rdf:Property ;
    rdfs:label 'Action Type' ;
    rdfs:comment 'Type of formal enforcement action initiated by the regulatory agency. Includes Notice of Violation (NOV), Administrative Order (AO), Consent Order, Compliance Schedule, civil penalty assessment, or criminal referral.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Flag' ;
    rdfs:comment 'Indicates whether the utility filed a formal appeal or contested the enforcement action through administrative or judicial proceedings.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appealFilingDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Filing Date' ;
    rdfs:comment 'Date the utility filed its appeal or petition for review. Null if no appeal was filed.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:boardNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Board Notification Date' ;
    rdfs:comment 'Date the utility\'s Board of Directors or governing body was notified of the enforcement action. Tracks governance and executive oversight requirements.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:civilPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Civil Penalty Amount' ;
    rdfs:comment 'Monetary penalty amount assessed by the regulatory agency in U.S. dollars. Null if no civil penalty was imposed.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceScheduleFinalDeadline rdf:type rdf:Property ;
    rdfs:label 'Compliance Schedule Final Deadline' ;
    rdfs:comment 'Final deadline by which all corrective actions and compliance milestones must be completed. Null if no compliance schedule is required.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceScheduleRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Schedule Required Flag' ;
    rdfs:comment 'Indicates whether the enforcement action includes a formal compliance schedule with milestones and deadlines for corrective actions.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required' ;
    rdfs:comment 'Description of the corrective actions required by the enforcement action. May include operational changes, infrastructure upgrades, process improvements, or enhanced monitoring.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Document Reference Number' ;
    rdfs:comment 'Internal document management system reference number for the enforcement action file. Links to stored correspondence, legal documents, and supporting materials.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAgency rdf:type rdf:Property ;
    rdfs:label 'Issuing Agency' ;
    rdfs:comment 'Name of the regulatory agency that issued the enforcement action (e.g., U.S. Environmental Protection Agency, State Department of Environmental Quality, Regional Water Quality Control Board).' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAgencyRegion rdf:type rdf:Property ;
    rdfs:label 'Issuing Agency Region' ;
    rdfs:comment 'Regional office, district, or jurisdiction of the issuing agency (e.g., EPA Region 5, Northwest Regional Office). Identifies the specific regulatory authority within the agency structure.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalCounselAssigned rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Assigned' ;
    rdfs:comment 'Name of the internal or external legal counsel assigned to manage the utility\'s response to the enforcement action. Business-confidential information.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalFirmName rdf:type rdf:Property ;
    rdfs:label 'Legal Firm Name' ;
    rdfs:comment 'Name of the external law firm representing the utility, if external counsel is engaged. Null if handled internally.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyPaidAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Paid Amount' ;
    rdfs:comment 'Actual amount paid by the utility toward the civil penalty. May differ from assessed amount due to negotiated settlements or payment plans.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Penalty Payment Date' ;
    rdfs:comment 'Date the civil penalty payment was made to the regulatory agency. Tracks compliance with payment deadlines.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicNoticeDate rdf:type rdf:Property ;
    rdfs:label 'Public Notice Date' ;
    rdfs:comment 'Date public notice of the enforcement action was issued. Null if public notice is not required.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicNoticeRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Public Notice Required Flag' ;
    rdfs:comment 'Indicates whether the enforcement action requires public notification under regulatory or consent order terms. Drives public communication and transparency obligations.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'Date the utility officially received the enforcement action notice. Used to calculate response deadlines and compliance timelines.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionOutcome rdf:type rdf:Property ;
    rdfs:label 'Resolution Outcome' ;
    rdfs:comment 'Final outcome of the enforcement action. Indicates how the action was resolved (compliance achieved, consent order executed, penalty paid, dismissed, or under appeal).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'Deadline by which the utility must submit a formal response to the enforcement action. Typically specified in the enforcement notice or calculated based on regulatory timelines.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Response Submitted Date' ;
    rdfs:comment 'Date the utility submitted its formal response to the enforcement action. Tracks compliance with response deadlines.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sepDescription rdf:type rdf:Property ;
    rdfs:label 'Sep Description' ;
    rdfs:comment 'Description of the Supplemental Environmental Project (SEP) agreed to as part of the enforcement settlement. Null if no SEP is included.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sepEstimatedCost rdf:type rdf:Property ;
    rdfs:label 'Sep Estimated Cost' ;
    rdfs:comment 'Estimated cost of the Supplemental Environmental Project (SEP) in U.S. dollars. Used to calculate penalty offsets and track SEP investment.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplementalEnvironmentalProjectFlag rdf:type rdf:Property ;
    rdfs:label 'Supplemental Environmental Project Flag' ;
    rdfs:comment 'Indicates whether the enforcement action includes a Supplemental Environmental Project (SEP) as part of the settlement. SEPs are environmentally beneficial projects that go beyond compliance requirements and may offset civil penalties.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:industrialUserId rdf:type rdf:Property ;
    rdfs:label 'Industrial User Id' ;
    rdfs:comment 'Unique identifier for the industrial user record in the pretreatment program registry. Primary key.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IndustrialUser .

ind:approvedServiceVendorId rdf:type rdf:Property ;
    rdfs:label 'Approved Service Vendor Id' ;
    rdfs:comment 'Foreign key linking to supply.vendor. Business justification: Industrial users have approved vendors for pretreatment system maintenance, monitoring, and sampling. Tracks vendor qualifications and service agreements for pretreatment program compliance.' ;
    rdfs:domain ind:IndustrialUser ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:coordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Coordinator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Each industrial user requires assigned pretreatment coordinator for compliance monitoring, sampling coordination, and regulatory reporting. Links to employee for workload management and certification ' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:annualCertificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Annual Certification Due Date' ;
    rdfs:comment 'Due date for the industrial user\'s annual certification of compliance with applicable pretreatment standards.' ;
    rdfs:domain ind:IndustrialUser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselineMonitoringReportDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Monitoring Report Date' ;
    rdfs:comment 'Date the Baseline Monitoring Report (BMR) was submitted by the industrial user.' ;
    rdfs:domain ind:IndustrialUser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselineMonitoringReportSubmitted rdf:type rdf:Property ;
    rdfs:label 'Baseline Monitoring Report Submitted' ;
    rdfs:comment 'Indicates whether the industrial user has submitted the required Baseline Monitoring Report (BMR) for categorical users.' ;
    rdfs:domain ind:IndustrialUser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:categoricalStandardApplicable rdf:type rdf:Property ;
    rdfs:label 'Categorical Standard Applicable' ;
    rdfs:comment 'Indicates whether the industrial user is subject to EPA categorical pretreatment standards for a specific industry category.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:categoricalStandardReference rdf:type rdf:Property ;
    rdfs:label 'Categorical Standard Reference' ;
    rdfs:comment 'Citation of the specific EPA categorical pretreatment standard applicable to this industrial user (e.g., 40 CFR Part 433 for Metal Finishing).' ;
    rdfs:domain ind:IndustrialUser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classification rdf:type rdf:Property ;
    rdfs:label 'Classification' ;
    rdfs:comment 'Classification of the industrial user under the pretreatment program: Significant Industrial User (SIU), Categorical Industrial User (CIU), Non-Significant Industrial User, or Exempt.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPersonEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Person Email' ;
    rdfs:comment 'Email address of the primary contact person for pretreatment program correspondence and reporting.' ;
    rdfs:domain ind:IndustrialUser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPersonName rdf:type rdf:Property ;
    rdfs:label 'Contact Person Name' ;
    rdfs:comment 'Full name of the primary contact person at the industrial facility responsible for pretreatment program compliance.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPersonPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Person Phone' ;
    rdfs:comment 'Primary phone number of the contact person at the industrial facility.' ;
    rdfs:domain ind:IndustrialUser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPersonTitle rdf:type rdf:Property ;
    rdfs:label 'Contact Person Title' ;
    rdfs:comment 'Job title or role of the primary contact person at the industrial facility.' ;
    rdfs:domain ind:IndustrialUser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dischargeConnectionPoint rdf:type rdf:Property ;
    rdfs:label 'Discharge Connection Point' ;
    rdfs:comment 'Identifier or description of the physical connection point where the industrial user discharges wastewater into the utility\'s collection system (e.g., manhole ID, GPS coordinates).' ;
    rdfs:domain ind:IndustrialUser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementActionPending rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Pending' ;
    rdfs:comment 'Indicates whether an enforcement action (administrative order, civil penalty, consent decree) is currently pending against this industrial user.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedDischargeVolumeGpd rdf:type rdf:Property ;
    rdfs:label 'Estimated Discharge Volume Gpd' ;
    rdfs:comment 'Estimated average daily wastewater discharge volume from the industrial facility in gallons per day (GPD).' ;
    rdfs:domain ind:IndustrialUser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Facility Address Line1' ;
    rdfs:comment 'Primary street address of the industrial facility discharging to the wastewater collection system.' ;
    rdfs:domain ind:IndustrialUser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Facility Address Line2' ;
    rdfs:comment 'Secondary address information (suite, building, floor) for the industrial facility.' ;
    rdfs:domain ind:IndustrialUser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityName rdf:type rdf:Property ;
    rdfs:label 'Facility Name' ;
    rdfs:comment 'Legal or trade name of the industrial or commercial facility subject to pretreatment requirements.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionFrequency rdf:type rdf:Property ;
    rdfs:label 'Inspection Frequency' ;
    rdfs:comment 'Required frequency of compliance inspections for this industrial user as specified in the IUP or local pretreatment ordinance.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether the industrial user is currently active in the pretreatment program registry. False if the facility has closed or is no longer discharging.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'Date of the most recent compliance inspection conducted at the industrial facility.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastSamplingDate rdf:type rdf:Property ;
    rdfs:label 'Last Sampling Date' ;
    rdfs:comment 'Date of the most recent wastewater discharge sampling event for this industrial user.' ;
    rdfs:domain ind:IndustrialUser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastViolationDate rdf:type rdf:Property ;
    rdfs:label 'Last Violation Date' ;
    rdfs:comment 'Date of the most recent documented violation of pretreatment standards or permit limits by this industrial user.' ;
    rdfs:domain ind:IndustrialUser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:naicsCode rdf:type rdf:Property ;
    rdfs:label 'Naics Code' ;
    rdfs:comment 'Six-digit NAICS code identifying the primary industrial activity of the facility, replacing SIC in modern classifications.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pollutantsOfConcern rdf:type rdf:Property ;
    rdfs:label 'Pollutants Of Concern' ;
    rdfs:comment 'Comma-separated list of key pollutants of concern discharged by this industrial user (e.g., Fats Oils and Grease (FOG), heavy metals, Biochemical Oxygen Demand (BOD), Total Suspended Solids (TSS), pH).' ;
    rdfs:domain ind:IndustrialUser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pretreatmentSystemDescription rdf:type rdf:Property ;
    rdfs:label 'Pretreatment System Description' ;
    rdfs:comment 'Description of the on-site pretreatment system, including technology type (e.g., oil-water separator, pH adjustment, metals precipitation).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pretreatmentSystemInstalled rdf:type rdf:Property ;
    rdfs:label 'Pretreatment System Installed' ;
    rdfs:comment 'Indicates whether the industrial user has installed on-site pretreatment equipment to reduce pollutant concentrations before discharge.' ;
    rdfs:domain ind:IndustrialUser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:samplingFrequency rdf:type rdf:Property ;
    rdfs:label 'Sampling Frequency' ;
    rdfs:comment 'Required frequency of wastewater discharge sampling for this industrial user as specified in the IUP.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sicCode rdf:type rdf:Property ;
    rdfs:label 'Sic Code' ;
    rdfs:comment 'Four-digit Standard Industrial Classification code identifying the primary industrial activity of the facility.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slugDischargeNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Slug Discharge Notification Required' ;
    rdfs:comment 'Indicates whether the industrial user is required to notify the utility immediately of any slug discharge or accidental spill that could cause interference or pass-through.' ;
    rdfs:domain ind:IndustrialUser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:state rdf:type rdf:Property ;
    rdfs:label 'State' ;
    rdfs:comment 'State or province where the industrial facility is located.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationCountLast12Months rdf:type rdf:Property ;
    rdfs:label 'Violation Count Last 12 Months' ;
    rdfs:comment 'Total number of documented violations by this industrial user in the past 12 months.' ;
    rdfs:domain ind:IndustrialUser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:zeroDischargeCertification rdf:type rdf:Property ;
    rdfs:label 'Zero Discharge Certification' ;
    rdfs:comment 'Indicates whether the industrial user has certified that they have no process wastewater discharge (zero discharge facility).' ;
    rdfs:domain ind:IndustrialUser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:affectedAssetRegistryId rdf:type rdf:Property ;
    rdfs:label 'Affected Asset Registry Id' ;
    rdfs:comment 'Reference to the specific asset, equipment, or infrastructure component directly related to this finding, if applicable.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Registry .

ind:previousFindingInspectionFindingId rdf:type rdf:Property ;
    rdfs:label 'Previous Finding Inspection Finding Id' ;
    rdfs:comment 'Reference to the prior inspection finding record if this is a recurrence of a previously documented deficiency.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionFinding .

ind:processUnitId rdf:type rdf:Property ;
    rdfs:label 'Process Unit Id' ;
    rdfs:comment 'Foreign key linking to treatment.process_unit. Business justification: Inspection findings identify deficiencies in specific treatment processes requiring corrective action. Business process: inspection follow-up where findings (inadequate baffling, insufficient contact ' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessUnit .

ind:regulatoryInspectionId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Inspection Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_inspection. Business justification: Inspection findings can originate from two types of inspections: asset inspections (tracked in asset.inspection_event) and regulatory compliance inspections (tracked in compliance.regulatory_inspectio' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryInspection .

ind:testMethodId rdf:type rdf:Property ;
    rdfs:label 'Test Method Id' ;
    rdfs:comment 'Foreign key linking to laboratory.test_method. Business justification: Inspection findings often cite method compliance issues (e.g., unapproved method, expired accreditation). Direct link to test method enables targeted corrective actions and tracks method-specific comp' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestMethod .

ind:correctiveActionDeadline rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Deadline' ;
    rdfs:comment 'Regulatory deadline or target date by which the corrective action must be completed to achieve compliance.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correspondenceReference rdf:type rdf:Property ;
    rdfs:label 'Correspondence Reference' ;
    rdfs:comment 'Reference number or identifier for official regulatory correspondence, letters, or communications related to this finding (e.g., EPA Notice of Violation (NOV) number, State Agency Letter Reference).' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingCategory rdf:type rdf:Property ;
    rdfs:label 'Finding Category' ;
    rdfs:comment 'Classification of the finding severity and regulatory significance. Significant deficiency indicates a failure or deficiency in treatment, distribution, or monitoring that could adversely affect water quality or public health.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingNumber rdf:type rdf:Property ;
    rdfs:label 'Finding Number' ;
    rdfs:comment 'Sequential or structured identifier assigned to this finding within the inspection event (e.g., F-001, 2023-INS-12-F03).' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingType rdf:type rdf:Property ;
    rdfs:label 'Finding Type' ;
    rdfs:comment 'Specific type or nature of the finding (e.g., treatment process deficiency, monitoring inadequacy, recordkeeping failure, operational practice issue, infrastructure condition).' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identified Date' ;
    rdfs:comment 'Date on which the finding was identified during the inspection or sanitary survey.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionFindingDescription rdf:type rdf:Property ;
    rdfs:label 'Inspection Finding Description' ;
    rdfs:comment 'Detailed narrative description of the non-conformance, deficiency, or observation identified during the inspection, including specific conditions observed and context.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorAgency rdf:type rdf:Property ;
    rdfs:label 'Inspector Agency' ;
    rdfs:comment 'Regulatory agency or organization that conducted the inspection (e.g., U.S. Environmental Protection Agency (EPA), State Department of Environmental Quality, County Health Department).' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicHealthImpact rdf:type rdf:Property ;
    rdfs:label 'Public Health Impact' ;
    rdfs:comment 'Assessment of the actual or potential impact of this finding on public health and drinking water safety.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceFlag rdf:type rdf:Property ;
    rdfs:label 'Recurrence Flag' ;
    rdfs:comment 'Indicates whether this finding is a recurrence of a previously identified and supposedly corrected deficiency, suggesting systemic or persistent compliance issues.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredCorrectiveAction rdf:type rdf:Property ;
    rdfs:label 'Required Corrective Action' ;
    rdfs:comment 'Detailed description of the corrective action, remediation, or improvement required to address and resolve the finding, as specified by the inspector or regulatory authority.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDescription rdf:type rdf:Property ;
    rdfs:label 'Resolution Description' ;
    rdfs:comment 'Detailed narrative describing the corrective actions taken, remediation steps implemented, and evidence demonstrating resolution of the finding.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Current status of the finding in the corrective action lifecycle, tracking progress from identification through closure.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Assessment of the potential risk to public health, environmental quality, or regulatory compliance posed by this finding if not corrected.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'Name or title of the individual or agency that verified the corrective action and confirmed resolution of the finding.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:morId rdf:type rdf:Property ;
    rdfs:label 'Mor Id' ;
    rdfs:comment 'Unique identifier for the Monthly Operating Report record.' ;
    rdfs:domain ind:Mor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coagulantMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Coagulant Material Master Id' ;
    rdfs:comment 'Foreign key linking to supply.material_master. Business justification: Monthly Operating Reports document specific coagulant products used (alum, ferric chloride) which must link to material master for regulatory traceability and NSF/ANSI 60 compliance verification.' ;
    rdfs:domain ind:Mor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:preparerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Preparer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Monthly Operating Reports must be prepared by licensed operators. Links MOR to specific employee for license verification, training tracking, and regulatory audit trail. Replaces denormalized preparer' ;
    rdfs:domain ind:Mor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:agencyResponseDate rdf:type rdf:Property ;
    rdfs:label 'Agency Response Date' ;
    rdfs:comment 'Date on which the state primacy agency responded to or acknowledged the submitted MOR.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agencyResponseReceived rdf:type rdf:Property ;
    rdfs:label 'Agency Response Received' ;
    rdfs:comment 'Indicates whether a response or acknowledgment was received from the state primacy agency after submission.' ;
    rdfs:domain ind:Mor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alkalinityAvgMgL rdf:type rdf:Property ;
    rdfs:label 'Alkalinity Avg Mg L' ;
    rdfs:comment 'Average alkalinity of finished water during the reporting month.' ;
    rdfs:domain ind:Mor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageDailyFlowMgd rdf:type rdf:Property ;
    rdfs:label 'Average Daily Flow Mgd' ;
    rdfs:comment 'Average daily flow rate of treated water produced during the reporting month.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Current status of the MOR in the certification and submission workflow.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifierLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Certifier License Number' ;
    rdfs:comment 'State-issued water treatment operator license number of the certifying operator.' ;
    rdfs:domain ind:Mor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifierName rdf:type rdf:Property ;
    rdfs:label 'Certifier Name' ;
    rdfs:comment 'Full name of the certified operator who reviewed and certified the accuracy of the MOR.' ;
    rdfs:domain ind:Mor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coagulantDosageAvgMgL rdf:type rdf:Property ;
    rdfs:label 'Coagulant Dosage Avg Mg L' ;
    rdfs:comment 'Average coagulant dosage applied during the reporting month.' ;
    rdfs:domain ind:Mor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Ct Compliance Status' ;
    rdfs:comment 'Indicates whether the achieved CT value met or exceeded the required CT value for the reporting month.' ;
    rdfs:domain ind:Mor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctValueAchieved rdf:type rdf:Property ;
    rdfs:label 'Ct Value Achieved' ;
    rdfs:comment 'Calculated CT value (disinfectant concentration multiplied by contact time) achieved for pathogen inactivation during the reporting month.' ;
    rdfs:domain ind:Mor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctValueRequired rdf:type rdf:Property ;
    rdfs:label 'Ct Value Required' ;
    rdfs:comment 'Regulatory CT value required for adequate pathogen inactivation based on water temperature and pH.' ;
    rdfs:domain ind:Mor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disinfectantResidualAvgMgL rdf:type rdf:Property ;
    rdfs:label 'Disinfectant Residual Avg Mg L' ;
    rdfs:comment 'Average disinfectant residual concentration in the distribution system during the reporting month.' ;
    rdfs:domain ind:Mor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disinfectantResidualMinMgL rdf:type rdf:Property ;
    rdfs:label 'Disinfectant Residual Min Mg L' ;
    rdfs:comment 'Minimum disinfectant residual concentration recorded in the distribution system during the reporting month.' ;
    rdfs:domain ind:Mor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disinfectantType rdf:type rdf:Property ;
    rdfs:label 'Disinfectant Type' ;
    rdfs:comment 'Primary disinfection method used at the treatment plant during the reporting month.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finishedWaterTurbidityAvgNtu rdf:type rdf:Property ;
    rdfs:label 'Finished Water Turbidity Avg Ntu' ;
    rdfs:comment 'Average turbidity of finished treated water leaving the plant during the reporting month.' ;
    rdfs:domain ind:Mor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finishedWaterTurbidityMaxNtu rdf:type rdf:Property ;
    rdfs:label 'Finished Water Turbidity Max Ntu' ;
    rdfs:comment 'Maximum turbidity of finished treated water recorded during the reporting month.' ;
    rdfs:domain ind:Mor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fluorideAvgMgL rdf:type rdf:Property ;
    rdfs:label 'Fluoride Avg Mg L' ;
    rdfs:comment 'Average fluoride concentration in finished water during the reporting month.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationalEventsCount rdf:type rdf:Property ;
    rdfs:label 'Operational Events Count' ;
    rdfs:comment 'Number of significant operational events (equipment failures, process upsets, maintenance shutdowns) recorded during the reporting month.' ;
    rdfs:domain ind:Mor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationalEventsDescription rdf:type rdf:Property ;
    rdfs:label 'Operational Events Description' ;
    rdfs:comment 'Narrative description of significant operational events that occurred during the reporting month.' ;
    rdfs:domain ind:Mor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peakDailyFlowMgd rdf:type rdf:Property ;
    rdfs:label 'Peak Daily Flow Mgd' ;
    rdfs:comment 'Maximum daily flow rate of treated water produced during the reporting month.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phAvg rdf:type rdf:Property ;
    rdfs:label 'Ph Avg' ;
    rdfs:comment 'Average pH level of finished water during the reporting month.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preparerLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Preparer License Number' ;
    rdfs:comment 'State-issued water treatment operator license number of the preparer.' ;
    rdfs:domain ind:Mor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rawWaterTurbidityAvgNtu rdf:type rdf:Property ;
    rdfs:label 'Raw Water Turbidity Avg Ntu' ;
    rdfs:comment 'Average turbidity of raw source water entering the treatment plant during the reporting month.' ;
    rdfs:domain ind:Mor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rawWaterTurbidityMaxNtu rdf:type rdf:Property ;
    rdfs:label 'Raw Water Turbidity Max Ntu' ;
    rdfs:comment 'Maximum turbidity of raw source water recorded during the reporting month.' ;
    rdfs:domain ind:Mor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportNumber rdf:type rdf:Property ;
    rdfs:label 'Report Number' ;
    rdfs:comment 'Externally-known unique report number assigned by the state primacy agency or internal tracking system.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingMonth rdf:type rdf:Property ;
    rdfs:label 'Reporting Month' ;
    rdfs:comment 'The calendar month for which this MOR documents water treatment plant operations.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingYear rdf:type rdf:Property ;
    rdfs:label 'Reporting Year' ;
    rdfs:comment 'The calendar year for which this MOR is submitted.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalWaterProducedMgd rdf:type rdf:Property ;
    rdfs:label 'Total Water Produced Mgd' ;
    rdfs:comment 'Total volume of treated water produced by the WTP during the reporting month, measured in million gallons per day.' ;
    rdfs:domain ind:Mor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:turbidityComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Turbidity Compliance Status' ;
    rdfs:comment 'Indicates whether turbidity levels met regulatory Maximum Contaminant Level (MCL) requirements during the reporting month.' ;
    rdfs:domain ind:Mor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationsCount rdf:type rdf:Property ;
    rdfs:label 'Violations Count' ;
    rdfs:comment 'Number of regulatory violations (MCL exceedances, monitoring failures, reporting failures) recorded during the reporting month.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:violationsDescription rdf:type rdf:Property ;
    rdfs:label 'Violations Description' ;
    rdfs:comment 'Narrative description of regulatory violations that occurred during the reporting month.' ;
    rdfs:domain ind:Mor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitConditionId rdf:type rdf:Property ;
    rdfs:label 'Permit Condition Id' ;
    rdfs:comment 'Unique identifier for the permit condition record. Primary key.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PermitCondition .

ind:analyteId rdf:type rdf:Property ;
    rdfs:label 'Analyte Id' ;
    rdfs:comment 'Foreign key linking to laboratory.analyte. Business justification: Permit conditions regulate specific contaminants. Direct link to analyte master enables automated compliance limit evaluation, eliminates denormalized parameter_name, and ensures consistent contaminan' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Analyte .

ind:treatmentPermitId rdf:type rdf:Property ;
    rdfs:label 'Treatment Permit Id' ;
    rdfs:comment 'Foreign key linking to treatment.treatment_permit. Business justification: Permit conditions define operational limits enforced at treatment facilities. Business process: permit compliance tracking where specific numeric limits (turbidity <0.3 NTU, CT >15 mg-min/L, flow <10 ' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TreatmentPermit .

ind:complianceEvaluationMethod rdf:type rdf:Property ;
    rdfs:label 'Compliance Evaluation Method' ;
    rdfs:comment 'The method used to determine compliance with this condition: single value comparison (each result compared to limit), rolling average (moving average over specified period), statistical analysis (percentile or confidence interval), narrative assessment (qualitative evaluation), or best professional judgment (case-by-case determination).' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceScheduleFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Schedule Flag' ;
    rdfs:comment 'Indicates whether this condition is subject to a compliance schedule (phased implementation plan) that allows the permittee additional time to achieve full compliance. True if a compliance schedule is in effect, False otherwise.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceScheduleMilestone rdf:type rdf:Property ;
    rdfs:label 'Compliance Schedule Milestone' ;
    rdfs:comment 'Description of the compliance schedule milestone associated with this condition (e.g., \'Submit engineering plans by 2024-06-30\', \'Complete construction by 2025-12-31\', \'Achieve interim limit of 30 mg/L BOD by 2024-12-31\'). Null if no compliance schedule applies.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionNumber rdf:type rdf:Property ;
    rdfs:label 'Condition Number' ;
    rdfs:comment 'The official condition number or identifier as stated in the permit document (e.g., \'I.A.1\', \'II.B.3\', \'Condition 5\').' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionStatus rdf:type rdf:Property ;
    rdfs:label 'Condition Status' ;
    rdfs:comment 'Current lifecycle status of the permit condition: active (currently enforceable), suspended (temporarily not enforced due to variance or stay), superseded (replaced by modified condition), expired (no longer in effect), or under appeal (contested by permittee).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionText rdf:type rdf:Property ;
    rdfs:label 'Condition Text' ;
    rdfs:comment 'The full verbatim text of the permit condition as written in the permit document. Includes all narrative requirements, qualifications, and regulatory language.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionType rdf:type rdf:Property ;
    rdfs:label 'Condition Type' ;
    rdfs:comment 'Classification of the permit condition: effluent limit (numeric discharge limit), monitoring requirement (sampling frequency and method), reporting requirement (MOR/DMR submission), technology-based standard (treatment technology mandate), narrative condition (qualitative requirement), or best management practice (operational control).' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionLimitRequirement rdf:type rdf:Property ;
    rdfs:label 'Detection Limit Requirement' ;
    rdfs:comment 'The minimum detection limit (MDL) or practical quantitation limit (PQL) required for the analytical method. Ensures that the laboratory can measure the parameter at levels sufficiently below the permit limit to demonstrate compliance. Null if no specific detection limit is mandated.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enforcementPriority rdf:type rdf:Property ;
    rdfs:label 'Enforcement Priority' ;
    rdfs:comment 'The priority level assigned by the regulatory agency for enforcement of this condition. Critical conditions (e.g., public health parameters like coliform, lead, PFAS) trigger immediate enforcement action upon violation. High priority conditions (e.g., BOD, TSS, pH) require prompt corrective action. Medium and low priority conditions may allow for compliance schedules.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitType rdf:type rdf:Property ;
    rdfs:label 'Limit Type' ;
    rdfs:comment 'The statistical basis for the effluent limit: daily maximum (highest single-day value), monthly average (arithmetic mean over calendar month), weekly average (arithmetic mean over 7-day period), instantaneous maximum (single grab sample), annual average, or minimum (for parameters like dissolved oxygen).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mixingZoneAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Mixing Zone Allowed Flag' ;
    rdfs:comment 'Indicates whether a mixing zone (limited area where discharge is allowed to exceed water quality standards before achieving full dilution and compliance) is authorized for this condition. True if mixing zone is allowed, False if end-of-pipe compliance is required.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mixingZoneDescription rdf:type rdf:Property ;
    rdfs:label 'Mixing Zone Description' ;
    rdfs:comment 'Description of the authorized mixing zone including dimensions, boundaries, and compliance monitoring points (e.g., \'100 meters downstream of Outfall 001\', \'Within 50-foot radius of discharge point\', \'Compliance measured at edge of mixing zone\'). Null if no mixing zone is allowed.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modificationDate rdf:type rdf:Property ;
    rdfs:label 'Modification Date' ;
    rdfs:comment 'The date on which this permit condition was last modified through permit amendment, administrative order, or consent decree. Null if the condition has never been modified since the original permit issuance.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modificationReason rdf:type rdf:Property ;
    rdfs:label 'Modification Reason' ;
    rdfs:comment 'The reason for the most recent modification to this condition (e.g., \'Updated water quality standards\', \'New analytical method approved\', \'Compliance schedule adjustment\', \'Facility upgrade completed\', \'Enforcement action settlement\', \'Anti-backsliding provision waiver\'). Null if never modified.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Monitoring Frequency' ;
    rdfs:comment 'The required frequency for monitoring or sampling this parameter: continuous (real-time SCADA monitoring), daily, weekly, monthly, quarterly, annually, or as needed (event-driven). [ENUM-REF-CANDIDATE: continuous|daily|weekly|monthly|quarterly|annually|as_needed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringLocation rdf:type rdf:Property ;
    rdfs:label 'Monitoring Location' ;
    rdfs:comment 'The specific location where monitoring or sampling must occur (e.g., \'Outfall 001\', \'Effluent Discharge Point A\', \'Influent to Primary Treatment\', \'Final Effluent\'). May reference a specific outfall, sampling point, or monitoring station.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numericLimit rdf:type rdf:Property ;
    rdfs:label 'Numeric Limit' ;
    rdfs:comment 'The numeric threshold value for the effluent limit or monitoring requirement. Null for narrative conditions or qualitative requirements.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityAssuranceRequirement rdf:type rdf:Property ;
    rdfs:label 'Quality Assurance Requirement' ;
    rdfs:comment 'Specific quality assurance and quality control (QA/QC) requirements for monitoring and sampling (e.g., \'EPA Method 1664A for FOG\', \'Standard Methods 5210B for BOD\', \'EPA Method 200.8 for metals\', \'Chain of custody required\', \'Laboratory must be state-certified\', \'Duplicate samples required quarterly\').' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingWaterBody rdf:type rdf:Property ;
    rdfs:label 'Receiving Water Body' ;
    rdfs:comment 'The name of the receiving water body (river, stream, lake, estuary, ocean, groundwater) into which the discharge occurs and for which this condition is designed to protect water quality (e.g., \'Mississippi River\', \'Lake Michigan\', \'Chesapeake Bay\', \'Atlantic Ocean\', \'Groundwater Aquifer Zone IIA\').' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordRetentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Record Retention Period Days' ;
    rdfs:comment 'The number of days that monitoring records, laboratory results, and compliance documentation for this condition must be retained by the permittee. Typically 3 years (1095 days) for NPDES permits, but may be longer for certain parameters or enforcement actions.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryBasis rdf:type rdf:Property ;
    rdfs:label 'Regulatory Basis' ;
    rdfs:comment 'The legal or regulatory authority for this condition (e.g., \'Clean Water Act Section 301\', \'SDWA Section 1412\', \'40 CFR 122.44\', \'State Water Quality Standard Chapter 62-302\', \'Technology-Based Effluent Limitation\', \'Water Quality-Based Effluent Limitation\', \'Best Available Technology (BAT)\', \'Best Conventional Pollutant Control Technology (BCT)\').' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalPeriod rdf:type rdf:Property ;
    rdfs:label 'Seasonal Period' ;
    rdfs:comment 'The time period during which seasonal variations apply (e.g., \'May 1 - September 30\', \'Winter: November 1 - March 31\', \'Low Flow Season: June - August\'). Null if no seasonal variation applies.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalVariationFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Variation Flag' ;
    rdfs:comment 'Indicates whether this condition has seasonal variations in limits or monitoring requirements (e.g., more stringent limits during low-flow summer months, reduced monitoring during winter). True if seasonal variations apply, False otherwise.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technologyRequirement rdf:type rdf:Property ;
    rdfs:label 'Technology Requirement' ;
    rdfs:comment 'Specific treatment technology or operational practice mandated by this condition (e.g., \'Secondary Treatment\', \'Ultraviolet (UV) Disinfection\', \'Granular Activated Carbon (GAC) Filtration\', \'Reverse Osmosis (RO)\', \'Microfiltration (MF)\', \'Ultrafiltration (UF)\', \'Fats Oils and Grease (FOG) Pretreatment\', \'Best Management Practice (BMP) for Stormwater\'). Null for non-technology-based conditions.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationThreshold rdf:type rdf:Property ;
    rdfs:label 'Violation Threshold' ;
    rdfs:comment 'The numeric value at which a violation is triggered. May differ from the numeric limit if the permit allows for measurement uncertainty, rounding conventions, or compliance margins. Null for narrative conditions.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterQualityStandardBasis rdf:type rdf:Property ;
    rdfs:label 'Water Quality Standard Basis' ;
    rdfs:comment 'The specific water quality standard or criterion that this condition is designed to protect (e.g., \'Aquatic Life Chronic Criterion\', \'Human Health - Fish Consumption\', \'Drinking Water Maximum Contaminant Level (MCL)\', \'Recreational Water Quality Standard\', \'Anti-Degradation Policy Tier II\'). Null for technology-based conditions.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pretreatmentIupId rdf:type rdf:Property ;
    rdfs:label 'Pretreatment Iup Id' ;
    rdfs:comment 'Unique identifier for the Industrial User Permit record in the pretreatment program.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PretreatmentIup .

ind:pretreatmentEquipmentVendorId rdf:type rdf:Property ;
    rdfs:label 'Pretreatment Equipment Vendor Id' ;
    rdfs:comment 'Foreign key linking to supply.vendor. Business justification: Industrial user permits reference vendors providing pretreatment equipment or monitoring services. Essential for tracking approved vendors and equipment compliance with categorical standards.' ;
    rdfs:domain ind:PretreatmentIup ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:bmpRequirements rdf:type rdf:Property ;
    rdfs:label 'Bmp Requirements' ;
    rdfs:comment 'Description of the Best Management Practices (BMPs) the industrial user must implement to minimize pollutant discharge and ensure compliance.' ;
    rdfs:domain ind:PretreatmentIup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dischargePointLatitude rdf:type rdf:Property ;
    rdfs:label 'Discharge Point Latitude' ;
    rdfs:comment 'The geographic latitude coordinate of the industrial users discharge point to the sewer system.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dischargePointLongitude rdf:type rdf:Property ;
    rdfs:label 'Discharge Point Longitude' ;
    rdfs:comment 'The geographic longitude coordinate of the industrial users discharge point to the sewer system.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityAddress rdf:type rdf:Property ;
    rdfs:label 'Facility Address' ;
    rdfs:comment 'The physical street address of the industrial facility discharging to the municipal sewer system.' ;
    rdfs:domain ind:PretreatmentIup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityCity rdf:type rdf:Property ;
    rdfs:label 'Facility City' ;
    rdfs:comment 'The city where the industrial facility is located.' ;
    rdfs:domain ind:PretreatmentIup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityPostalCode rdf:type rdf:Property ;
    rdfs:label 'Facility Postal Code' ;
    rdfs:comment 'The postal or ZIP code of the industrial facility location.' ;
    rdfs:domain ind:PretreatmentIup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityState rdf:type rdf:Property ;
    rdfs:label 'Facility State' ;
    rdfs:comment 'The state or province where the industrial facility is located.' ;
    rdfs:domain ind:PretreatmentIup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuanceDate rdf:type rdf:Property ;
    rdfs:label 'Issuance Date' ;
    rdfs:comment 'The date on which the permit was officially issued by the utility to the industrial user.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastComplianceAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Assessment Date' ;
    rdfs:comment 'The date of the most recent compliance assessment or evaluation conducted by the utility for this industrial user.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Last Renewal Date' ;
    rdfs:comment 'The date of the most recent permit renewal or modification.' ;
    rdfs:domain ind:PretreatmentIup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumDailyFlowMgd rdf:type rdf:Property ;
    rdfs:label 'Maximum Daily Flow Mgd' ;
    rdfs:comment 'The maximum permitted daily wastewater discharge flow rate from the industrial user to the municipal sewer system, measured in Million Gallons per Day (MGD).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Report Due Date' ;
    rdfs:comment 'The date by which the industrial user must submit the next compliance monitoring report to the utility.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permitConditions rdf:type rdf:Property ;
    rdfs:label 'Permit Conditions' ;
    rdfs:comment 'Detailed text of special conditions, requirements, or restrictions imposed on the industrial user as part of this permit.' ;
    rdfs:domain ind:PretreatmentIup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitStatus rdf:type rdf:Property ;
    rdfs:label 'Permit Status' ;
    rdfs:comment 'Current lifecycle status of the Industrial User Permit: Active, Expired, Suspended, Revoked, Pending Renewal, or Terminated.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitType rdf:type rdf:Property ;
    rdfs:label 'Permit Type' ;
    rdfs:comment 'Type of Industrial User Permit: Individual (facility-specific), General (standard conditions for a category), or Conditional (temporary or limited scope).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pretreatmentRequired rdf:type rdf:Property ;
    rdfs:label 'Pretreatment Required' ;
    rdfs:comment 'Indicates whether the industrial user is required to pretreat wastewater before discharge to the municipal sewer system.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pretreatmentTechnologyDescription rdf:type rdf:Property ;
    rdfs:label 'Pretreatment Technology Description' ;
    rdfs:comment 'Description of the pretreatment technologies and processes the industrial user must employ to meet discharge limits (e.g., pH adjustment, oil-water separation, metals precipitation).' ;
    rdfs:domain ind:PretreatmentIup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siuClassification rdf:type rdf:Property ;
    rdfs:label 'Siu Classification' ;
    rdfs:comment 'Classification of the industrial user under the pretreatment program: Significant Industrial User (SIU), Categorical Industrial User (CIU), Non-Significant Categorical User (NSCIU), or Non-Categorical User.' ;
    rdfs:domain ind:PretreatmentIup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slugControlPlanApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Slug Control Plan Approval Date' ;
    rdfs:comment 'The date on which the utilitys pretreatment coordinator approved the industrial users slug discharge control plan.' ;
    rdfs:domain ind:PretreatmentIup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slugControlPlanRequired rdf:type rdf:Property ;
    rdfs:label 'Slug Control Plan Required' ;
    rdfs:comment 'Indicates whether the industrial user is required to develop and maintain a slug discharge control plan to prevent accidental or intentional spills.' ;
    rdfs:domain ind:PretreatmentIup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compliancePublicNotificationId rdf:type rdf:Property ;
    rdfs:label 'Compliance Public Notification Id' ;
    rdfs:comment 'Unique identifier for the public notification record. Primary key.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompliancePublicNotification .

ind:primaryComplianceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Compliance Employee Id' ;
    rdfs:comment 'Identifier of the utility staff member who prepared the public notification content and documentation.' ;
    rdfs:domain ind:CompliancePublicNotification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedCustomerCount rdf:type rdf:Property ;
    rdfs:label 'Affected Customer Count' ;
    rdfs:comment 'Total number of customer accounts or service connections in the affected service area that must receive the public notification.' ;
    rdfs:domain ind:CompliancePublicNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedServiceArea rdf:type rdf:Property ;
    rdfs:label 'Affected Service Area' ;
    rdfs:comment 'Geographic description or identifier of the service area, distribution zone, or District Metered Area (DMA) affected by the violation and subject to the public notification.' ;
    rdfs:domain ind:CompliancePublicNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'Tracking number or reference identifier assigned by the primacy agency upon receipt of the public notification certification submission.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Certification Submitted Date' ;
    rdfs:comment 'Date on which the certification of public notification completion was submitted to the state primacy agency, as required by SDWA regulations.' ;
    rdfs:domain ind:CompliancePublicNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contactEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Contact Email Address' ;
    rdfs:comment 'Email address provided in the public notification for customers to contact the utility for additional information.' ;
    rdfs:domain ind:CompliancePublicNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Contact Phone Number' ;
    rdfs:comment 'Phone number provided in the public notification for customers to contact the utility for additional information.' ;
    rdfs:domain ind:CompliancePublicNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contaminantName rdf:type rdf:Property ;
    rdfs:label 'Contaminant Name' ;
    rdfs:comment 'Name of the specific contaminant or parameter that exceeded regulatory limits or was subject to the violation (e.g., Total Coliform, Lead, Copper, Trihalomethanes (THM), Haloacetic Acids (HAA5), Nitrate, PFAS).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Description of the corrective actions being taken by the water utility to address the violation and prevent recurrence, as required to be included in the public notification.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deadlineMetFlag rdf:type rdf:Property ;
    rdfs:label 'Deadline Met Flag' ;
    rdfs:comment 'Boolean indicator of whether the public notification was completed within the regulatory deadline. True if deadline was met, False if deadline was missed.' ;
    rdfs:domain ind:CompliancePublicNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distributionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Distribution Completion Date' ;
    rdfs:comment 'Date on which the public notification distribution was completed to all affected customers and required public channels.' ;
    rdfs:domain ind:CompliancePublicNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distributionCostAmount rdf:type rdf:Property ;
    rdfs:label 'Distribution Cost Amount' ;
    rdfs:comment 'Total cost incurred for distributing the public notification, including printing, postage, media advertising, and other distribution expenses.' ;
    rdfs:domain ind:CompliancePublicNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionStartDate rdf:type rdf:Property ;
    rdfs:label 'Distribution Start Date' ;
    rdfs:comment 'Date on which the public notification distribution began to affected customers and the public.' ;
    rdfs:domain ind:CompliancePublicNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:healthEffectsLanguage rdf:type rdf:Property ;
    rdfs:label 'Health Effects Language' ;
    rdfs:comment 'Mandatory health effects language as prescribed by EPA for the specific contaminant or violation type, describing potential health risks to consumers.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mclValue rdf:type rdf:Property ;
    rdfs:label 'Mcl Value' ;
    rdfs:comment 'The regulatory Maximum Contaminant Level (MCL) threshold that was exceeded, expressed in the appropriate unit of measure (mg/L, ug/L, pCi/L, NTU, etc.).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measuredValue rdf:type rdf:Property ;
    rdfs:label 'Measured Value' ;
    rdfs:comment 'The actual measured value of the contaminant that triggered the violation, expressed in the same unit of measure as the MCL.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mediaOutletList rdf:type rdf:Property ;
    rdfs:label 'Media Outlet List' ;
    rdfs:comment 'List of media outlets (newspapers, radio stations, television stations) to which the public notification was distributed for broadcast or publication, as required for Tier 1 notifications.' ;
    rdfs:domain ind:CompliancePublicNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationContent rdf:type rdf:Property ;
    rdfs:label 'Notification Content' ;
    rdfs:comment 'Full text of the public notification message as distributed to customers, including mandatory elements: description of violation, potential health effects, population at risk, corrective actions, and contact information.' ;
    rdfs:domain ind:CompliancePublicNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationLanguage rdf:type rdf:Property ;
    rdfs:label 'Notification Language' ;
    rdfs:comment 'Primary language(s) in which the notification was issued to ensure accessibility for the affected population. May include multiple languages based on community demographics.' ;
    rdfs:domain ind:CompliancePublicNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationMethod rdf:type rdf:Property ;
    rdfs:label 'Notification Method' ;
    rdfs:comment 'Method(s) used to deliver the public notification to affected customers and the public. May include multiple methods such as bill insert, direct mail, hand delivery, posting, newspaper publication, broadcast media (radio/TV), website posting, social media, or email. [ENUM-REF-CANDIDATE: Bill Insert|Direct Mail|Hand Delivery|Posted Notice|Newspaper|Radio|Television|Website|Social Media|Email|Press Release — promote to reference product]' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationNumber rdf:type rdf:Property ;
    rdfs:label 'Notification Number' ;
    rdfs:comment 'Business identifier for the public notification, typically formatted as PN-YYYY-NNNNNN for tracking and regulatory submission purposes.' ;
    rdfs:domain ind:CompliancePublicNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationStatus rdf:type rdf:Property ;
    rdfs:label 'Notification Status' ;
    rdfs:comment 'Current lifecycle status of the public notification: Draft (being prepared), Pending Approval (awaiting management review), Approved (ready for distribution), Distributed (sent to customers), Certified (submitted to primacy agency), or Closed (violation resolved and notification cycle complete).' ;
    rdfs:domain ind:CompliancePublicNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationTier rdf:type rdf:Property ;
    rdfs:label 'Notification Tier' ;
    rdfs:comment 'Classification of notification urgency and timeline as defined by EPA: Tier 1 (immediate, within 24 hours for acute health risks), Tier 2 (within 30 days for less urgent violations), Tier 3 (annual notice via Consumer Confidence Report for monitoring or reporting violations).' ;
    rdfs:domain ind:CompliancePublicNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primacyAgencyAcknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Primacy Agency Acknowledgment Date' ;
    rdfs:comment 'Date on which the state primacy agency acknowledged receipt and acceptance of the public notification certification.' ;
    rdfs:domain ind:CompliancePublicNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primacyAgencyName rdf:type rdf:Property ;
    rdfs:label 'Primacy Agency Name' ;
    rdfs:comment 'Name of the state or tribal primacy agency to which the public notification certification and documentation must be submitted (e.g., State Department of Environmental Quality, State Health Department).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Public Meeting Date' ;
    rdfs:comment 'Date on which the public meeting was held to discuss the violation with affected customers and community stakeholders.' ;
    rdfs:domain ind:CompliancePublicNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicMeetingHeldFlag rdf:type rdf:Property ;
    rdfs:label 'Public Meeting Held Flag' ;
    rdfs:comment 'Boolean indicator of whether a public meeting was held to discuss the violation and corrective actions with affected customers and community stakeholders. True if meeting was held.' ;
    rdfs:domain ind:CompliancePublicNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Deadline Date' ;
    rdfs:comment 'The regulatory deadline by which the public notification must be completed based on the notification tier: 24 hours for Tier 1, 30 days for Tier 2, or annual CCR publication for Tier 3.' ;
    rdfs:domain ind:CompliancePublicNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:repeatNotificationFrequency rdf:type rdf:Property ;
    rdfs:label 'Repeat Notification Frequency' ;
    rdfs:comment 'Frequency at which repeat public notifications must be issued for ongoing violations, as specified by the notification tier and primacy agency requirements.' ;
    rdfs:domain ind:CompliancePublicNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Notification Required Flag' ;
    rdfs:comment 'Boolean indicator of whether repeat public notifications are required for ongoing violations. True if repeat notifications must be issued at specified intervals until the violation is resolved.' ;
    rdfs:domain ind:CompliancePublicNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:violationDate rdf:type rdf:Property ;
    rdfs:label 'Violation Date' ;
    rdfs:comment 'The date on which the violation occurred or was first identified through water quality testing or monitoring.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:violationType rdf:type rdf:Property ;
    rdfs:label 'Violation Type' ;
    rdfs:comment 'Category of the violation that triggered the notification: Maximum Contaminant Level (MCL) exceedance, Maximum Contaminant Level Goal (MCLG) exceedance, Treatment Technique violation, Monitoring violation, or Reporting violation.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websitePostingUrl rdf:type rdf:Property ;
    rdfs:label 'Website Posting Url' ;
    rdfs:comment 'URL of the utility website page where the public notification was posted for public access and transparency.' ;
    rdfs:domain ind:CompliancePublicNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAgencyId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Agency Id' ;
    rdfs:comment 'Unique identifier for the regulatory agency record. Primary key.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryAgency .

ind:parentAgencyId rdf:type rdf:Property ;
    rdfs:label 'Parent Agency Id' ;
