    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportedToStateFlag rdf:type rdf:Property ;
    rdfs:label 'Reported To State Flag' ;
    rdfs:comment 'Indicates whether this monitoring event result has been reported to the state primacy agency.' ;
    rdfs:domain ind:DbpMonitoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleCollectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sample Collection Timestamp' ;
    rdfs:comment 'The precise date and time when the DBP water sample was collected from the monitoring point.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
