ind:tthmConcentrationUgL rdf:type rdf:Property ;
    rdfs:label 'Tthm Concentration Ug L' ;
    rdfs:comment 'Sum of the four trihalomethane species (chloroform, bromodichloromethane, dibromochloromethane, bromoform) in micrograms per liter.' ;
