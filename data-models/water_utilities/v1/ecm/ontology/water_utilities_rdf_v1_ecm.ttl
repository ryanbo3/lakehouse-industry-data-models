ind:workCenterOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Work Center Org Unit Id' ;
    rdfs:comment 'Reference to the maintenance work center or crew responsible for executing this job plan.' ;
    rdfs:domain ind:JobPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Date and time when this job plan was approved and activated for use in work orders and preventive maintenance schedules.' ;
