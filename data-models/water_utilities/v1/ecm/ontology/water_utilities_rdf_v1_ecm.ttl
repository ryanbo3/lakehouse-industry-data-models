    rdfs:range xsd:boolean .

ind:correspondenceDate rdf:type rdf:Property ;
    rdfs:label 'Correspondence Date' ;
    rdfs:comment 'Date the correspondence was sent (for outgoing) or received (for incoming). This is the principal business event timestamp for the correspondence.' ;
    rdfs:domain ind:RegulatoryCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correspondenceNumber rdf:type rdf:Property ;
    rdfs:label 'Correspondence Number' ;
    rdfs:comment 'Business identifier or reference number assigned to the correspondence for tracking and filing purposes. May follow agency or internal numbering conventions.' ;
    rdfs:domain ind:RegulatoryCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondenceStatus rdf:type rdf:Property ;
    rdfs:label 'Correspondence Status' ;
    rdfs:comment 'Current lifecycle status of the correspondence record (e.g., active, closed, archived, under review).' ;
    rdfs:domain ind:RegulatoryCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondenceType rdf:type rdf:Property ;
    rdfs:label 'Correspondence Type' ;
    rdfs:comment 'Classification of the correspondence document type (e.g., letter, notice, response to Notice of Violation (NOV), request for information, variance application, waiver request, extension request, agency response, inspection report, technical memorandum). [ENUM-REF-CANDIDATE: letter|notice|response|request_for_information|variance_application|waiver_request|extension_request|nov_response|agency_response|inspection_report|technical_memorandum — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:direction rdf:type rdf:Property ;
    rdfs:label 'Direction' ;
    rdfs:comment 'Indicates whether the correspondence is incoming (received from regulatory agency) or outgoing (sent by the utility to regulatory agency).' ;
    rdfs:domain ind:RegulatoryCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionDate rdf:type rdf:Property ;
    rdfs:label 'Disposition Date' ;
    rdfs:comment 'Date on which the correspondence record is eligible for disposition (archival or destruction) per records retention policy. Null if not yet determined.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentFormat rdf:type rdf:Property ;
    rdfs:label 'Document Format' ;
    rdfs:comment 'Format of the correspondence document (e.g., PDF, DOCX, email, paper, other).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReference rdf:type rdf:Property ;
    rdfs:label 'Document Reference' ;
    rdfs:comment 'Reference identifier, file path, or URL to the stored correspondence document (e.g., document management system reference, SharePoint path, network drive location).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementActionFlag rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Flag' ;
    rdfs:comment 'Indicates whether the correspondence is related to a regulatory enforcement action (e.g., Notice of Violation (NOV), consent decree, administrative order) (True/False).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publicDisclosureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Required Flag' ;
    rdfs:comment 'Indicates whether the correspondence or its content must be disclosed to the public (e.g., as part of Consumer Confidence Report (CCR), public notice, or Freedom of Information Act (FOIA) request) (True/False).' ;
    rdfs:domain ind:RegulatoryCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Response Deadline Date' ;
    rdfs:comment 'Date by which the utility must submit a response to the regulatory agency, if a response is required. Null if no response deadline applies.' ;
    rdfs:domain ind:RegulatoryCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Response Required Flag' ;
    rdfs:comment 'Indicates whether a formal response from the utility is required for this correspondence (True/False).' ;
    rdfs:domain ind:RegulatoryCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseStatus rdf:type rdf:Property ;
    rdfs:label 'Response Status' ;
    rdfs:comment 'Current status of the utility\'s response to the correspondence (e.g., not required, pending, in progress, submitted, accepted by agency, rejected by agency, overdue). [ENUM-REF-CANDIDATE: not_required|pending|in_progress|submitted|accepted|rejected|overdue — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentDate rdf:type rdf:Property ;
    rdfs:label 'Sent Date' ;
    rdfs:comment 'Date the outgoing correspondence was officially sent or transmitted by the utility. Null for incoming correspondence.' ;
    rdfs:domain ind:RegulatoryCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Subject line or title of the correspondence describing the primary topic or purpose.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:summary rdf:type rdf:Property ;
    rdfs:label 'Summary' ;
    rdfs:comment 'Brief summary or abstract of the correspondence content, key points, and any actions requested or required.' ;
    rdfs:domain ind:RegulatoryCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilityContactTitle rdf:type rdf:Property ;
    rdfs:label 'Utility Contact Title' ;
    rdfs:comment 'Job title or position of the utility contact person (e.g., Compliance Manager, Director of Operations, Environmental Manager).' ;
    rdfs:domain ind:RegulatoryCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionReportDocumentId rdf:type rdf:Property ;
    rdfs:label 'Inspection Report Document Id' ;
    rdfs:comment 'Identifier linking to the stored inspection report document in the document management system.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:labAccreditationId rdf:type rdf:Property ;
    rdfs:label 'Lab Accreditation Id' ;
    rdfs:comment 'Foreign key linking to laboratory.lab_accreditation. Business justification: Regulatory inspections verify laboratory accreditation status and scope. Direct link enables inspectors to validate that laboratory is accredited for methods used in compliance monitoring, supports re' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabAccreditation .

ind:utilityRepresentativeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Utility Representative Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Regulatory inspections require utility representative present during site visit. Links to employee for scheduling, certification verification, and follow-up coordination. Replaces denormalized utility' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:correctiveActionSummary rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Summary' ;
    rdfs:comment 'Summary of the corrective actions required to address deficiencies and achieve compliance.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deficiencyCount rdf:type rdf:Property ;
    rdfs:label 'Deficiency Count' ;
    rdfs:comment 'Total number of deficiencies or non-compliance items identified during the inspection.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:findingsSummary rdf:type rdf:Property ;
    rdfs:label 'Findings Summary' ;
    rdfs:comment 'High-level summary of the inspection findings, deficiencies identified, and overall compliance status.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Inspection Required Flag' ;
    rdfs:comment 'Indicates whether a follow-up inspection by the regulatory agency is required to verify corrective action completion.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpInspectionScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Inspection Scheduled Date' ;
    rdfs:comment 'Scheduled date for the follow-up inspection if required.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectingAgency rdf:type rdf:Property ;
    rdfs:label 'Inspecting Agency' ;
    rdfs:comment 'Name of the regulatory body or agency that conducted the inspection (EPA, state primacy agency, local health department, etc.).' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Number' ;
    rdfs:comment 'Externally-known unique identifier or reference number assigned by the regulatory agency for this inspection.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionReportReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Report Received Date' ;
    rdfs:comment 'Date on which the utility received the official inspection report from the regulatory agency.' ;
    rdfs:domain ind:RegulatoryInspection ;
