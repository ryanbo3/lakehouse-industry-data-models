ind:systemWideHaa5RaaUgL rdf:type rdf:Property ;
    rdfs:label 'System Wide Haa5 Raa Ug L' ;
    rdfs:comment 'The system-wide running annual average of HAA5 concentrations across all monitoring points, used for overall system compliance assessment.' ;
