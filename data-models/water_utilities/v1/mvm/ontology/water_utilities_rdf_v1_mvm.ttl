    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'Minimum quantity that must be ordered from this vendor for this material per purchase order, as negotiated in the sourcing agreement.' ;
    rdfs:domain ind:ApprovedSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredVendorFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Flag' ;
    rdfs:comment 'Indicates whether this vendor is the preferred (primary) source for this material among all approved sources. Supports vendor ranking when multiple approved sources exist.' ;
    rdfs:domain ind:ApprovedSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractLineItemId rdf:type rdf:Property ;
    rdfs:label 'Contract Line Item Id' ;
    rdfs:comment 'Primary key for the contract_line_item association' ;
    rdfs:domain ind:ContractLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Line Item Number' ;
    rdfs:comment 'The sequential line number identifying this item within the contract (e.g., 00010, 00020). Corresponds to SAP MM EKPO-EBELP. Used for reference in purchase order releases and vendor communications.' ;
    rdfs:domain ind:ContractLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemStatus rdf:type rdf:Property ;
    rdfs:label 'Line Item Status' ;
    rdfs:comment 'Current status of this contract line item. Active items are available for release. Closed items have reached target quantity or expiry. Blocked items are temporarily suspended. Cancelled items are voided.' ;
    rdfs:domain ind:ContractLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricePerUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Price Per Unit Of Measure' ;
    rdfs:comment 'The unit of measure basis for the unit price (e.g., price per KG, per L, per EA). Defines how unit_price is interpreted for this contract line item.' ;
    rdfs:domain ind:ContractLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseQuantity rdf:type rdf:Property ;
    rdfs:label 'Release Quantity' ;
    rdfs:comment 'Cumulative quantity of this material that has been called off (released) against this contract line item via purchase orders or scheduling agreements. Tracks consumption of the target quantity commitment.' ;
    rdfs:domain ind:ContractLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releaseValue rdf:type rdf:Property ;
    rdfs:label 'Release Value' ;
    rdfs:comment 'Cumulative monetary value released against this contract line item. Used for budget tracking and contract utilization reporting at the material level.' ;
    rdfs:domain ind:ContractLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetQuantity rdf:type rdf:Property ;
    rdfs:label 'Target Quantity' ;
    rdfs:comment 'The total quantity of the material committed under this contract line item. Represents the maximum or agreed volume the utility intends to procure for this material under this contract. Belongs to the contract-material combination, not to either entity alone.' ;
    rdfs:domain ind:ContractLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleOfValuesLineId rdf:type rdf:Property ;
    rdfs:label 'Schedule Of Values Line Id' ;
    rdfs:comment 'Primary key for the schedule_of_values_line association' ;
    rdfs:domain ind:ScheduleOfValuesLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amountBilledThisPeriod rdf:type rdf:Property ;
    rdfs:label 'Amount Billed This Period' ;
    rdfs:comment 'The dollar amount billed against this change order line item in the current pay application billing period. Belongs to the intersection of pay application and change order, not to either entity alone. Sourced from detection phase relationship data.' ;
    rdfs:domain ind:ScheduleOfValuesLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedChangeOrdersAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Change Orders Amount' ;
    rdfs:comment 'Net total of all approved change orders that modify the contract sum. [Moved from pay_application: This is a rolled-up aggregate of all change order SOV lines and belongs as a derived/summary value, not a stored attribute on pay_application. The granular per-change-order billing data now lives in schedule_of_values_line, making this a computable total. However, it may be retained on pay_application as a denormalized summary for AIA G702 reporting convenience — flagged for review rather than mandatory removal.]' ;
    rdfs:domain ind:ScheduleOfValuesLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeAmountBilled rdf:type rdf:Property ;
    rdfs:label 'Cumulative Amount Billed' ;
    rdfs:comment 'Total amount billed against this change order line item across all pay applications to date, including the current period. Tracks running billing progress for this specific change order. Sourced from detection phase relationship data.' ;
    rdfs:domain ind:ScheduleOfValuesLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentCompleteThisPeriod rdf:type rdf:Property ;
    rdfs:label 'Percent Complete This Period' ;
    rdfs:comment 'Percentage of this change order\'s scope of work completed as of this billing period. Belongs to the specific pay application and change order combination. Sourced from detection phase relationship data.' ;
    rdfs:domain ind:ScheduleOfValuesLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledValue rdf:type rdf:Property ;
    rdfs:label 'Scheduled Value' ;
    rdfs:comment 'The approved contract value of this change order as established on the Schedule of Values. Represents the total value allocated to this SOV line item. Sourced from detection phase relationship data.' ;
    rdfs:domain ind:ScheduleOfValuesLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Program Enrollment Id' ;
    rdfs:comment 'Primary key for the program_enrollment association' ;
    rdfs:domain ind:ProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incentiveAmountApplied rdf:type rdf:Property ;
    rdfs:label 'Incentive Amount Applied' ;
    rdfs:comment 'Actual monetary incentive amount applied or credited to this specific agreement under this enrollment. May differ from the program\'s standard incentive_amount due to customer-specific calculations or caps. Sourced from detection phase relationship_data.' ;
    rdfs:domain ind:ProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programEnrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Program Enrollment Status' ;
    rdfs:comment 'Current lifecycle status of this specific enrollment. Tracks the progression from application through active participation to expiration or withdrawal. Sourced from detection phase relationship_data (enrollment_status).' ;
    rdfs:domain ind:ProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .
