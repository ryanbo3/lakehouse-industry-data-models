    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastBalanceUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Balance Update Date' ;
    rdfs:comment 'The most recent date when this character\'s stats, abilities, or mechanics were adjusted for game balance purposes.' ;
    rdfs:domain ind:PlayableCharacter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licensingStatus rdf:type rdf:Property ;
    rdfs:label 'Licensing Status' ;
    rdfs:comment 'The legal licensing arrangement for this character\'s intellectual property.' ;
    rdfs:domain ind:PlayableCharacter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loreBiography rdf:type rdf:Property ;
    rdfs:label 'Lore Biography' ;
    rdfs:comment 'Extended lore and backstory text for the character, providing deep narrative context for engaged players.' ;
    rdfs:domain ind:PlayableCharacter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxLevel rdf:type rdf:Property ;
    rdfs:label 'Max Level' ;
    rdfs:comment 'The highest level or rank this character can achieve through player progression.' ;
    rdfs:domain ind:PlayableCharacter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playableCharacterStatus rdf:type rdf:Property ;
    rdfs:label 'Playable Character Status' ;
    rdfs:comment 'The current lifecycle status of the character in the game\'s live environment.' ;
    rdfs:domain ind:PlayableCharacter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:popularityScore rdf:type rdf:Property ;
    rdfs:label 'Popularity Score' ;
    rdfs:comment 'A calculated score representing the character\'s popularity among players, based on pick rate, win rate, and community engagement metrics.' ;
    rdfs:domain ind:PlayableCharacter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryWeaponType rdf:type rdf:Property ;
    rdfs:label 'Primary Weapon Type' ;
    rdfs:comment 'The default or signature weapon type used by this character (e.g., sword, bow, staff, gun, fists).' ;
    rdfs:domain ind:PlayableCharacter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialAbilityDescription rdf:type rdf:Property ;
    rdfs:label 'Special Ability Description' ;
    rdfs:comment 'Detailed description of what the character\'s special ability does, including mechanics and effects.' ;
    rdfs:domain ind:PlayableCharacter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialAbilityName rdf:type rdf:Property ;
    rdfs:label 'Special Ability Name' ;
    rdfs:comment 'The name of the character\'s signature or ultimate special ability.' ;
    rdfs:domain ind:PlayableCharacter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:species rdf:type rdf:Property ;
    rdfs:label 'Species' ;
    rdfs:comment 'The species, race, or creature type of the character (e.g., human, elf, orc, robot, alien) as defined in the game universe.' ;
    rdfs:domain ind:PlayableCharacter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unlockMethod rdf:type rdf:Property ;
    rdfs:label 'Unlock Method' ;
    rdfs:comment 'The primary method by which players can unlock or acquire this character.' ;
    rdfs:domain ind:PlayableCharacter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voiceActorName rdf:type rdf:Property ;
    rdfs:label 'Voice Actor Name' ;
    rdfs:comment 'The name of the voice actor who provides the character\'s voice performance, used for credits and marketing.' ;
    rdfs:domain ind:PlayableCharacter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAdUnitId rdf:type rdf:Property ;
    rdfs:label 'Parent Ad Unit Id' ;
    rdfs:comment 'Self-referencing FK on ad_unit (parent_ad_unit_id)' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdUnit .

ind:adUnitCode rdf:type rdf:Property ;
    rdfs:label 'Ad Unit Code' ;
    rdfs:comment 'Externally-known unique business identifier for the ad unit, used for ad server integration and campaign targeting.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adUnitStatus rdf:type rdf:Property ;
    rdfs:label 'Ad Unit Status' ;
    rdfs:comment 'Current lifecycle status of the ad unit determining whether it can serve advertisements.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adUnitType rdf:type rdf:Property ;
    rdfs:label 'Ad Unit Type' ;
    rdfs:comment 'Classification of the ad unit format determining how the advertisement is displayed to the player.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advertiserExclusions rdf:type rdf:Property ;
    rdfs:label 'Advertiser Exclusions' ;
    rdfs:comment 'Comma-separated list of advertiser identifiers that are blocked from serving ads through this unit due to competitive or content conflicts.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRefreshEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Refresh Enabled' ;
    rdfs:comment 'Indicates whether the ad unit automatically refreshes to serve new ads at the defined refresh rate interval.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:categoryExclusions rdf:type rdf:Property ;
    rdfs:label 'Category Exclusions' ;
    rdfs:comment 'Comma-separated list of IAB content categories that are blocked from serving ads through this unit to maintain brand safety.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorPriceUsd rdf:type rdf:Property ;
    rdfs:label 'Floor Price Usd' ;
    rdfs:comment 'Minimum cost per mille (CPM) bid price in USD required for an ad to be served through this unit, protecting revenue quality.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frequencyCapCount rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap Count' ;
    rdfs:comment 'Maximum number of times the same ad can be shown to a single user within the frequency cap period, preventing ad fatigue.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyCapPeriodHours rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap Period Hours' ;
    rdfs:comment 'Time window in hours over which the frequency cap count is enforced.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mediationPriority rdf:type rdf:Property ;
    rdfs:label 'Mediation Priority' ;
    rdfs:comment 'Priority ranking for this ad unit within the mediation waterfall, determining the order in which ad networks are queried.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:placementLocation rdf:type rdf:Property ;
    rdfs:label 'Placement Location' ;
    rdfs:comment 'In-game location or screen where the ad unit is displayed, critical for user experience and monetization optimization.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refreshRateSeconds rdf:type rdf:Property ;
    rdfs:label 'Refresh Rate Seconds' ;
    rdfs:comment 'Time interval in seconds between automatic ad refreshes for this unit, impacting impression volume and user experience.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rewardedAdFlag rdf:type rdf:Property ;
    rdfs:label 'Rewarded Ad Flag' ;
    rdfs:comment 'Indicates whether this ad unit provides in-game rewards (virtual currency, extra lives, power-ups) to players who complete the ad view.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:skipOffsetSeconds rdf:type rdf:Property ;
    rdfs:label 'Skip Offset Seconds' ;
    rdfs:comment 'Number of seconds that must elapse before the skip button becomes available to the player for skippable ads.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:skippableFlag rdf:type rdf:Property ;
    rdfs:label 'Skippable Flag' ;
    rdfs:comment 'Indicates whether players can skip the ad before completion, impacting user experience and advertiser value.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetAudienceAgeMax rdf:type rdf:Property ;
    rdfs:label 'Target Audience Age Max' ;
    rdfs:comment 'Maximum age of the intended audience for this ad unit, enabling demographic targeting optimization.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetAudienceAgeMin rdf:type rdf:Property ;
    rdfs:label 'Target Audience Age Min' ;
    rdfs:comment 'Minimum age of the intended audience for this ad unit, ensuring compliance with age-appropriate advertising regulations.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testModeFlag rdf:type rdf:Property ;
    rdfs:label 'Test Mode Flag' ;
    rdfs:comment 'Indicates whether this ad unit is operating in test mode, serving test ads for quality assurance without generating revenue.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:videoDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Video Duration Seconds' ;
    rdfs:comment 'Standard duration in seconds for video ads served through this unit, applicable to video and rewarded video ad types.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalStorefrontTransactionId rdf:type rdf:Property ;
    rdfs:label 'Original Storefront Transaction Id' ;
    rdfs:comment 'Self-referencing FK on storefront_transaction (original_storefront_transaction_id)' ;
    rdfs:domain ind:StorefrontTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorefrontTransaction .

ind:isWhaleTransaction rdf:type rdf:Property ;
    rdfs:label 'Is Whale Transaction' ;
    rdfs:comment 'Flag indicating whether this transaction qualifies as a high-value whale purchase based on business-defined thresholds.' ;
    rdfs:domain ind:StorefrontTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemQuantity rdf:type rdf:Property ;
    rdfs:label 'Item Quantity' ;
    rdfs:comment 'Number of units of the storefront item purchased in this transaction.' ;
    rdfs:domain ind:StorefrontTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storefrontLocation rdf:type rdf:Property ;
    rdfs:label 'Storefront Location' ;
    rdfs:comment 'Specific in-game location or menu where the storefront item was displayed and purchased (e.g., main menu, post-match screen, battle pass tab).' ;
    rdfs:domain ind:StorefrontTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'Externally-visible unique transaction number displayed to players and used in customer service interactions.' ;
    rdfs:domain ind:StorefrontTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Category of monetization transaction: in-app purchase (IAP), microtransaction (MTX), downloadable content (DLC), battle pass, subscription, virtual currency purchase, loot box, or season pass.' ;
    rdfs:domain ind:StorefrontTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentAssetId rdf:type rdf:Property ;
    rdfs:label 'Content Asset Id' ;
    rdfs:comment 'Foreign key linking to content.asset. Business justification: Storefront items (skins, cosmetics, icons) are rendered using a specific content asset. Merchandising and live-ops teams must link each storefront item to its display asset for store rendering, asset ' ;
    rdfs:domain ind:StorefrontItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:parentStorefrontItemId rdf:type rdf:Property ;
    rdfs:label 'Parent Storefront Item Id' ;
    rdfs:comment 'Self-referencing FK on storefront_item (parent_storefront_item_id)' ;
    rdfs:domain ind:StorefrontItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorefrontItem .

ind:bundleItemCount rdf:type rdf:Property ;
    rdfs:label 'Bundle Item Count' ;
    rdfs:comment 'Number of distinct items or rewards included in the bundle (null for non-bundle items).' ;
    rdfs:domain ind:StorefrontItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discountedPrice rdf:type rdf:Property ;
    rdfs:label 'Discounted Price' ;
    rdfs:comment 'Final price after applying discount percentage, used for player-facing display and transaction processing.' ;
    rdfs:domain ind:StorefrontItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:imageUrl rdf:type rdf:Property ;
    rdfs:label 'Image Url' ;
    rdfs:comment 'URL path to the primary promotional image or icon asset for the storefront item.' ;
    rdfs:domain ind:StorefrontItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBundle rdf:type rdf:Property ;
    rdfs:label 'Is Bundle' ;
    rdfs:comment 'Indicates whether this storefront item is a bundle containing multiple sub-items or rewards.' ;
    rdfs:domain ind:StorefrontItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemCategory rdf:type rdf:Property ;
    rdfs:label 'Item Category' ;
    rdfs:comment 'Business category of the storefront item by player value proposition: cosmetic (appearance), gameplay (mechanics), progression (advancement), social (interaction), utility (convenience), or bundle (multi-item package).' ;
    rdfs:domain ind:StorefrontItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemCode rdf:type rdf:Property ;
    rdfs:label 'Item Code' ;
    rdfs:comment 'Externally-known unique business identifier for the storefront item, used in catalogs, APIs, and player-facing interfaces.' ;
    rdfs:domain ind:StorefrontItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemRarity rdf:type rdf:Property ;
    rdfs:label 'Item Rarity' ;
    rdfs:comment 'Rarity tier of the storefront item, used for perceived value signaling and collection mechanics.' ;
    rdfs:domain ind:StorefrontItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerLevelRequirement rdf:type rdf:Property ;
    rdfs:label 'Player Level Requirement' ;
    rdfs:comment 'Minimum player level required to view or purchase this storefront item (null if no level gate).' ;
    rdfs:domain ind:StorefrontItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:purchaseLimitPerPlayer rdf:type rdf:Property ;
    rdfs:label 'Purchase Limit Per Player' ;
    rdfs:comment 'Maximum number of times a single player can purchase this item (null for unlimited purchases).' ;
    rdfs:domain ind:StorefrontItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stockQuantity rdf:type rdf:Property ;
    rdfs:label 'Stock Quantity' ;
    rdfs:comment 'Total available inventory quantity for limited-edition items (null for unlimited digital goods).' ;
    rdfs:domain ind:StorefrontItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSalesCount rdf:type rdf:Property ;
    rdfs:label 'Total Sales Count' ;
    rdfs:comment 'Cumulative number of times this storefront item has been purchased across all players and platforms.' ;
    rdfs:domain ind:StorefrontItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:videoPreviewUrl rdf:type rdf:Property ;
    rdfs:label 'Video Preview Url' ;
    rdfs:comment 'URL path to the video preview or trailer showcasing the storefront item (null if no video available).' ;
    rdfs:domain ind:StorefrontItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:virtualCurrencyPrice rdf:type rdf:Property ;
    rdfs:label 'Virtual Currency Price' ;
    rdfs:comment 'Price of the storefront item in the game\'s virtual currency (e.g., V-Bucks, Riot Points, Apex Coins) if purchasable with in-game currency.' ;
    rdfs:domain ind:StorefrontItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campaignItemId rdf:type rdf:Property ;
    rdfs:label 'Campaign Item Id' ;
    rdfs:comment 'Unique surrogate identifier for each campaign-item pairing. Primary key.' ;
    rdfs:domain ind:CampaignItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campaignDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Campaign Discount Pct' ;
    rdfs:comment 'Percentage discount applied to this specific catalog item within this campaign, expressed as a decimal (e.g., 25.00 for 25% off). Overrides base catalog pricing for campaign duration.' ;
    rdfs:domain ind:CampaignItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignSpecificPrice rdf:type rdf:Property ;
    rdfs:label 'Campaign Specific Price' ;
    rdfs:comment 'Absolute override price for this catalog item within this campaign, denominated in the campaign\'s currency_code. If set, this price supersedes both base_price_usd and campaign_discount_pct calculations.' ;
    rdfs:domain ind:CampaignItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:displayOrderInCampaign rdf:type rdf:Property ;
    rdfs:label 'Display Order In Campaign' ;
    rdfs:comment 'Integer sort order controlling the presentation sequence of this item within the campaign\'s storefront UI. Lower values appear first. Used for merchandising and promotional emphasis.' ;
    rdfs:domain ind:CampaignItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Eligibility Flag' ;
    rdfs:comment 'Boolean indicating whether this catalog item is currently eligible for purchase within this campaign. Allows dynamic inclusion/exclusion without removing the campaign_item record (e.g., inventory depletion, compliance hold).' ;
    rdfs:domain ind:CampaignItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:featuredFlag rdf:type rdf:Property ;
    rdfs:label 'Featured Flag' ;
    rdfs:comment 'Boolean indicating whether this item receives featured/hero placement within the campaign UI (e.g., banner image, top carousel slot). Used for merchandising strategy.' ;
    rdfs:domain ind:CampaignItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impressionCount rdf:type rdf:Property ;
    rdfs:label 'Impression Count' ;
    rdfs:comment 'Number of times this specific catalog item was displayed to players within this campaign context. Used for item-level conversion rate analysis and A/B testing.' ;
    rdfs:domain ind:CampaignItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:itemAddedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Item Added Timestamp' ;
    rdfs:comment 'Date and time when this catalog item was added to the campaign. Supports audit trail and dynamic campaign composition tracking.' ;
    rdfs:domain ind:CampaignItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:itemRemovedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Item Removed Timestamp' ;
    rdfs:comment 'Date and time when this catalog item was removed from the campaign (if applicable). Null if item is still active in campaign. Supports historical analysis of campaign composition changes.' ;
    rdfs:domain ind:CampaignItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:redemptionCount rdf:type rdf:Property ;
    rdfs:label 'Redemption Count' ;
    rdfs:comment 'Number of times this specific catalog item was purchased/redeemed within this campaign. Used for item-level performance tracking and inventory management.' ;
    rdfs:domain ind:CampaignItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redemptionLimitPerItem rdf:type rdf:Property ;
    rdfs:label 'Redemption Limit Per Item' ;
    rdfs:comment 'Maximum number of times a single player account can redeem this specific catalog item within this campaign. Null indicates no per-item limit (campaign-level cap still applies). Used for flash sale scarcity and whale retention offers.' ;
    rdfs:domain ind:CampaignItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planContentInclusionId rdf:type rdf:Property ;
    rdfs:label 'Plan Content Inclusion Id' ;
    rdfs:comment 'Primary key for the plan content inclusion association record' ;
    rdfs:domain ind:PlanContentInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessLevel rdf:type rdf:Property ;
    rdfs:label 'Access Level' ;
    rdfs:comment 'Level of access granted to subscribers for this DLC content (FULL = complete access, TRIAL = limited time trial, PREVIEW = demo mode, TIMED = time-limited sessions). Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:PlanContentInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentUnlockSequence rdf:type rdf:Property ;
    rdfs:label 'Content Unlock Sequence' ;
    rdfs:comment 'Ordinal position in which this DLC content unlocks for subscribers (e.g., episodic content released over subscription tenure). Null if all content available immediately. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:PlanContentInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exclusionDate rdf:type rdf:Property ;
    rdfs:label 'Exclusion Date' ;
    rdfs:comment 'Date when this DLC content will be or was removed from the subscription plan library. Null if content is permanent. Used for content rotation management and subscriber notifications.' ;
    rdfs:domain ind:PlanContentInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:includedSinceDate rdf:type rdf:Property ;
    rdfs:label 'Included Since Date' ;
    rdfs:comment 'Date when this DLC content was added to the subscription plan library. Used for content lifecycle tracking and subscriber communication. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:PlanContentInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inclusionStatus rdf:type rdf:Property ;
    rdfs:label 'Inclusion Status' ;
    rdfs:comment 'Current lifecycle status of this content inclusion (ACTIVE = currently available, SCHEDULED = future inclusion, EXPIRED = removed from library, SUSPENDED = temporarily unavailable). Used for access enforcement and content catalog display.' ;
    rdfs:domain ind:PlanContentInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExclusiveToPlan rdf:type rdf:Property ;
    rdfs:label 'Is Exclusive To Plan' ;
    rdfs:comment 'Indicates whether this DLC content is exclusive to this subscription plan tier (not available in lower tiers or standalone purchase). Used for marketing differentiation and access control. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:PlanContentInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bundleManifestEntryId rdf:type rdf:Property ;
    rdfs:label 'Bundle Manifest Entry Id' ;
    rdfs:comment 'Primary key for the bundle_manifest_entry association' ;
    rdfs:domain ind:BundleManifestEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetOrderInBundle rdf:type rdf:Property ;
    rdfs:label 'Asset Order In Bundle' ;
    rdfs:comment 'Sequential position of the asset within the bundle manifest, used for load order optimization and dependency resolution' ;
    rdfs:domain ind:BundleManifestEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetRoleInBundle rdf:type rdf:Property ;
    rdfs:label 'Asset Role In Bundle' ;
    rdfs:comment 'Functional role of the asset within this specific bundle: primary (core content), dependency (required by other assets), optional (can be lazy-loaded), fallback (used if primary fails), locale_variant (language-specific version)' ;
    rdfs:domain ind:BundleManifestEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compressionOverride rdf:type rdf:Property ;
    rdfs:label 'Compression Override' ;
    rdfs:comment 'Bundle-specific compression setting that overrides the asset\'s default compression format for this particular packaging context' ;
    rdfs:domain ind:BundleManifestEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusion Flag' ;
    rdfs:comment 'Boolean flag indicating whether this asset should be excluded from the bundle in the next build (soft delete for manifest management)' ;
    rdfs:domain ind:BundleManifestEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inclusionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inclusion Timestamp' ;
    rdfs:comment 'Timestamp when the asset was added to this bundle manifest, used for version control and audit trail' ;
    rdfs:domain ind:BundleManifestEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isPrimaryAsset rdf:type rdf:Property ;
    rdfs:label 'Is Primary Asset' ;
    rdfs:comment 'Boolean flag indicating whether this asset is a primary deliverable of the bundle (true) or a supporting dependency (false)' ;
    rdfs:domain ind:BundleManifestEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loadPriority rdf:type rdf:Property ;
    rdfs:label 'Load Priority' ;
    rdfs:comment 'Priority value for asset loading within the bundle (lower numbers load first), used by the game engine\'s streaming system' ;
    rdfs:domain ind:BundleManifestEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lodTierOverride rdf:type rdf:Property ;
    rdfs:label 'Lod Tier Override' ;
    rdfs:comment 'Level of Detail tier override for this asset in this specific bundle, allowing the same asset to be packaged at different quality levels for different bundles (e.g., mobile vs console builds)' ;
    rdfs:domain ind:BundleManifestEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npcSpawnConfigurationId rdf:type rdf:Property ;
    rdfs:label 'Npc Spawn Configuration Id' ;
    rdfs:comment 'Unique identifier for this NPC spawn configuration record. Primary key.' ;
    rdfs:domain ind:NpcSpawnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isBossVariant rdf:type rdf:Property ;
    rdfs:label 'Is Boss Variant' ;
    rdfs:comment 'Indicates whether this spawn configuration represents a boss encounter variant with modified stats or behavior for this specific level.' ;
    rdfs:domain ind:NpcSpawnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:levelSpecificLootOverride rdf:type rdf:Property ;
    rdfs:label 'Level Specific Loot Override' ;
    rdfs:comment 'Reference to a level-specific loot table that overrides the NPC definition\'s default loot table for this particular level. Used for level-specific rewards.' ;
    rdfs:domain ind:NpcSpawnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spawnCountMax rdf:type rdf:Property ;
    rdfs:label 'Spawn Count Max' ;
    rdfs:comment 'Maximum number of instances of this NPC archetype that can spawn simultaneously in this level. Used for encounter balancing and performance budgeting.' ;
    rdfs:domain ind:NpcSpawnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spawnCountMin rdf:type rdf:Property ;
    rdfs:label 'Spawn Count Min' ;
    rdfs:comment 'Minimum number of instances of this NPC archetype that can spawn simultaneously in this level. Used for encounter balancing and performance budgeting.' ;
    rdfs:domain ind:NpcSpawnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spawnWeight rdf:type rdf:Property ;
    rdfs:label 'Spawn Weight' ;
    rdfs:comment 'Relative probability weight for this NPC archetype spawning in this level compared to other configured NPCs. Used for randomized encounter variety.' ;
    rdfs:domain ind:NpcSpawnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spawnZoneCode rdf:type rdf:Property ;
    rdfs:label 'Spawn Zone Code' ;
    rdfs:comment 'Identifier for the specific spawn zone or region within the level where this NPC archetype is configured to appear. References level geometry zones.' ;
    rdfs:domain ind:NpcSpawnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:editionContentInclusionId rdf:type rdf:Property ;
    rdfs:label 'Edition Content Inclusion Id' ;
    rdfs:comment 'Unique identifier for this edition-DLC inclusion record. Primary key.' ;
    rdfs:domain ind:EditionContentInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:includedInEdition rdf:type rdf:Property ;
    rdfs:label 'Included In Edition' ;
    rdfs:comment 'Comma-separated list of game editions (Deluxe, Ultimate, Gold) that include this DLC bundle at no additional cost. Used for bundling and upsell strategies. [Moved from dlc_bundle: This STRING attribute on dlc_bundle is a denormalized representation of the M:N relationship. It stores a comma-separated list of edition names, which is a classic anti-pattern indicating an underlying many-to-many relationship that should be properly modeled in the association table. The association table replaces this denormalized field with proper relational structure.]' ;
    rdfs:domain ind:EditionContentInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inclusionType rdf:type rdf:Property ;
    rdfs:label 'Inclusion Type' ;
    rdfs:comment 'Classification of how this DLC is included in the edition (bundled at launch, pre-order bonus, season pass entitlement, early access window, timed exclusive). Drives entitlement logic and marketing messaging.' ;
    rdfs:domain ind:EditionContentInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryContent rdf:type rdf:Property ;
    rdfs:label 'Is Primary Content' ;
    rdfs:comment 'Indicates whether this DLC bundle is a primary selling point for this edition tier (featured in marketing) versus secondary/bonus content.' ;
    rdfs:domain ind:EditionContentInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceContributionUsd rdf:type rdf:Property ;
    rdfs:label 'Price Contribution Usd' ;
    rdfs:comment 'The estimated value contribution of this DLC bundle to the edition\'s total MSRP in USD. Used for pricing analysis and value proposition calculations.' ;
    rdfs:domain ind:EditionContentInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modeCharacterRosterId rdf:type rdf:Property ;
    rdfs:label 'Mode Character Roster Id' ;
    rdfs:comment 'Unique identifier for this mode-character roster configuration record. Primary key.' ;
    rdfs:domain ind:ModeCharacterRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Availability Status' ;
    rdfs:comment 'Current availability status of this character in this mode. Values: available (playable), disabled (temporarily unavailable), banned (prohibited for competitive integrity), restricted (requires unlock).' ;
    rdfs:domain ind:ModeCharacterRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceOverrideVersion rdf:type rdf:Property ;
    rdfs:label 'Balance Override Version' ;
    rdfs:comment 'Version identifier for mode-specific balance adjustments applied to this character in this mode. References a balance patch or configuration version that modifies character stats for this mode only.' ;
    rdfs:domain ind:ModeCharacterRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:banRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Ban Rate Percentage' ;
    rdfs:comment 'Calculated percentage representing how often this character is banned in this mode (for modes with draft/ban mechanics). Used for competitive balance analysis.' ;
    rdfs:domain ind:ModeCharacterRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDefaultAvailable rdf:type rdf:Property ;
    rdfs:label 'Is Default Available' ;
    rdfs:comment 'Indicates whether this character is available by default in this mode (true) or requires unlock/purchase (false). Used for free-to-play roster management.' ;
    rdfs:domain ind:ModeCharacterRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Pick Rate Percentage' ;
    rdfs:comment 'Calculated percentage representing how often this character is selected in this mode. Used for balance analysis and esports meta tracking.' ;
    rdfs:domain ind:ModeCharacterRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unlockRequirementOverride rdf:type rdf:Property ;
    rdfs:label 'Unlock Requirement Override' ;
    rdfs:comment 'Mode-specific unlock requirement for this character if it differs from the base game unlock. Examples: \'ranked_level_10\', \'battle_pass_tier_25\', \'premium_purchase\'. Null if base unlock applies.' ;
    rdfs:domain ind:ModeCharacterRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Win Rate Percentage' ;
    rdfs:comment 'Calculated win rate for this character in this mode. Used for balance monitoring and identifying overpowered/underpowered characters per mode.' ;
    rdfs:domain ind:ModeCharacterRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .
