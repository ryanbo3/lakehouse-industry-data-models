ind:evolvedFromPlayableCharacterId rdf:type rdf:Property ;
    rdfs:label 'Evolved From Playable Character Id' ;
    rdfs:comment 'Self-referencing FK on playable_character (evolved_from_playable_character_id)' ;
    rdfs:domain ind:PlayableCharacter ;
