    rdfs:comment 'Status of notifications sent to third-party data processors or recipients regarding this data subject request.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentVenueId rdf:type rdf:Property ;
