    rdfs:comment 'Number of teams that executed at least one roster change during this transfer window.' ;
    rdfs:domain ind:TransferWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalTransfersExecuted rdf:type rdf:Property ;
    rdfs:label 'Total Transfers Executed' ;
    rdfs:comment 'Total number of player transfers successfully completed across all teams during this window.' ;
    rdfs:domain ind:TransferWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transferFeeRequired rdf:type rdf:Property ;
