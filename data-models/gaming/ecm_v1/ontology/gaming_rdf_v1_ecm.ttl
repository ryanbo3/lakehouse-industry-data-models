    rdfs:range ind:CostCenter .

ind:studioId rdf:type rdf:Property ;
    rdfs:label 'Studio Id' ;
    rdfs:comment 'The game development studio associated with this allocation cycle, if applicable to studio-level cost allocations.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GameStudio .

ind:allocationBasis rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis' ;
    rdfs:comment 'The driver or basis used to calculate allocation proportions (e.g., headcount, revenue, square footage, usage hours).' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationRuleSet rdf:type rdf:Property ;
    rdfs:label 'Allocation Rule Set' ;
    rdfs:comment 'The named set of business rules and logic governing how allocations are calculated and distributed in this cycle.' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionCount rdf:type rdf:Property ;
    rdfs:label 'Execution Count' ;
    rdfs:comment 'The total number of times this allocation cycle has been executed since creation.' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'The recurring schedule on which this allocation cycle is executed.' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Last Execution Date' ;
    rdfs:comment 'The date of the most recent execution of this allocation cycle.' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Next Execution Date' ;
    rdfs:comment 'The scheduled date for the next execution of this recurring allocation cycle. Null for non-recurring cycles.' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'The date on which this allocation cycle was reversed. Null if not reversed.' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalAmountAllocated rdf:type rdf:Property ;
    rdfs:label 'Total Amount Allocated' ;
    rdfs:comment 'The total monetary amount distributed through this allocation cycle in the base currency.' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:suppressionRuleId rdf:type rdf:Property ;
    rdfs:label 'Suppression Rule Id' ;
    rdfs:comment 'The identifier of the alert suppression or maintenance window rule that muted this alert, if applicable. Used during planned maintenance or known issue periods.' ;
    rdfs:domain ind:MonitoringAlert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AlertSuppressionRule .

ind:acknowledgedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledged Timestamp' ;
    rdfs:comment 'The date and time when the alert was acknowledged by an on-call engineer or automated system, indicating response has begun.' ;
    rdfs:domain ind:MonitoringAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:alertCode rdf:type rdf:Property ;
    rdfs:label 'Alert Code' ;
    rdfs:comment 'Externally-known unique code identifying the alert type and category. Format: three-letter category prefix followed by four-digit sequence number (e.g., SRV-0001, NET-0042).' ;
    rdfs:domain ind:MonitoringAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertDescription rdf:type rdf:Property ;
    rdfs:label 'Alert Description' ;
    rdfs:comment 'Detailed description of the alert condition, including business impact, affected services, and recommended actions for responders.' ;
    rdfs:domain ind:MonitoringAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertMessage rdf:type rdf:Property ;
    rdfs:label 'Alert Message' ;
    rdfs:comment 'The specific alert message generated at trigger time, including dynamic values and context (e.g., \'CPU utilization 95% on server game-srv-042 exceeds threshold 80%\').' ;
    rdfs:domain ind:MonitoringAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertName rdf:type rdf:Property ;
    rdfs:label 'Alert Name' ;
    rdfs:comment 'Human-readable name of the monitoring alert, describing the condition being monitored.' ;
    rdfs:domain ind:MonitoringAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertType rdf:type rdf:Property ;
    rdfs:label 'Alert Type' ;
    rdfs:comment 'Classification of the alert based on the monitoring condition: threshold (metric exceeds limit), anomaly (unusual pattern detected), availability (service up/down), performance (latency/throughput degradation), security (threat detected), capacity (resource exhaustion).' ;
    rdfs:domain ind:MonitoringAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedEngineer rdf:type rdf:Property ;
    rdfs:label 'Assigned Engineer' ;
    rdfs:comment 'The name or identifier of the specific engineer or responder currently assigned to investigate and resolve the alert.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedTeam rdf:type rdf:Property ;
    rdfs:label 'Assigned Team' ;
    rdfs:comment 'The name of the engineering or operations team assigned to respond to the alert (e.g., game-server-ops, network-engineering, platform-reliability, security-response).' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoResolvedFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Resolved Flag' ;
    rdfs:comment 'Boolean indicator of whether the alert was automatically resolved by the monitoring system (true) or required manual intervention (false). Used to measure self-healing infrastructure effectiveness.' ;
    rdfs:domain ind:MonitoringAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evaluationWindowSeconds rdf:type rdf:Property ;
    rdfs:label 'Evaluation Window Seconds' ;
    rdfs:comment 'The time window in seconds over which the metric is evaluated before triggering the alert. Prevents false positives from transient spikes.' ;
    rdfs:domain ind:MonitoringAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gameTitle rdf:type rdf:Property ;
    rdfs:label 'Game Title' ;
    rdfs:comment 'The specific game title or franchise affected by the alert. Critical for prioritizing alerts based on player base and revenue impact.' ;
    rdfs:domain ind:MonitoringAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricName rdf:type rdf:Property ;
    rdfs:label 'Metric Name' ;
    rdfs:comment 'The name of the performance or health metric being monitored (e.g., cpu_utilization_percent, network_latency_ms, active_player_count, server_response_time_ms).' ;
    rdfs:domain ind:MonitoringAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricUnit rdf:type rdf:Property ;
    rdfs:label 'Metric Unit' ;
    rdfs:comment 'The unit of measurement for the metric value (e.g., percent, milliseconds, requests_per_second, concurrent_users, gigabytes).' ;
    rdfs:domain ind:MonitoringAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationChannels rdf:type rdf:Property ;
    rdfs:label 'Notification Channels' ;
    rdfs:comment 'Comma-separated list of notification channels used to alert responders (e.g., pagerduty, slack, email, sms, webhook). Tracks how the alert was communicated.' ;
    rdfs:domain ind:MonitoringAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdOperator rdf:type rdf:Property ;
    rdfs:label 'Threshold Operator' ;
    rdfs:comment 'The comparison operator used to evaluate the metric against the threshold (e.g., greater_than for high-water marks, less_than for low-water marks).' ;
    rdfs:domain ind:MonitoringAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedToUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned To User Employee Id' ;
    rdfs:comment 'Identifier of the user or team member responsible for implementing the change request.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:configurationItemId rdf:type rdf:Property ;
    rdfs:label 'Configuration Item Id' ;
    rdfs:comment 'Identifier of the primary configuration item or infrastructure component being modified by this change.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConfigurationItem .

ind:relatedIncidentInfrastructureIncidentId rdf:type rdf:Property ;
    rdfs:label 'Related Incident Infrastructure Incident Id' ;
    rdfs:comment 'Identifier of the incident that triggered this change request, if the change is remedial in nature.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InfrastructureIncident .

ind:relatedProblemId rdf:type rdf:Property ;
    rdfs:label 'Related Problem Id' ;
    rdfs:comment 'Identifier of the problem record that this change request addresses as a permanent fix.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Problem .

ind:affectedRegions rdf:type rdf:Property ;
    rdfs:label 'Affected Regions' ;
    rdfs:comment 'Geographic regions or data center locations where the change will be deployed, relevant for global game infrastructure.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedServices rdf:type rdf:Property ;
    rdfs:label 'Affected Services' ;
    rdfs:comment 'List of game services, platforms, or infrastructure components that will be impacted by the change implementation.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cabApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Cab Approval Required' ;
    rdfs:comment 'Indicates whether the change requires formal review and approval by the Change Advisory Board based on risk and impact.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedDowntimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Downtime Minutes' ;
    rdfs:comment 'Expected duration of service downtime or degradation during change implementation, measured in minutes.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:impactAssessment rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment' ;
    rdfs:comment 'Analysis of potential impact on game services, infrastructure components, player experience, and business operations if the change is implemented.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationNotes rdf:type rdf:Property ;
    rdfs:label 'Implementation Notes' ;
    rdfs:comment 'Technical notes and observations recorded during change implementation, including any deviations from the plan.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationSuccessful rdf:type rdf:Property ;
    rdfs:label 'Implementation Successful' ;
    rdfs:comment 'Indicates whether the change implementation met success criteria without requiring rollback.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:justification rdf:type rdf:Property ;
    rdfs:label 'Justification' ;
    rdfs:comment 'Business rationale and expected benefits for implementing the change, including impact on player experience, operational efficiency, or revenue.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceWindowRequired rdf:type rdf:Property ;
    rdfs:label 'Maintenance Window Required' ;
    rdfs:comment 'Indicates whether the change requires a scheduled maintenance window with player notification and service downtime.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:playerNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Player Notification Required' ;
    rdfs:comment 'Indicates whether advance notification to players is required due to expected service impact or downtime.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postImplementationReview rdf:type rdf:Property ;
    rdfs:label 'Post Implementation Review' ;
    rdfs:comment 'Assessment of change success, lessons learned, and recommendations for future similar changes.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rollbackExecuted rdf:type rdf:Property ;
    rdfs:label 'Rollback Executed' ;
    rdfs:comment 'Indicates whether the rollback plan was executed due to implementation failure or unexpected issues.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rollbackPlan rdf:type rdf:Property ;
    rdfs:label 'Rollback Plan' ;
    rdfs:comment 'Documented procedure for reverting the change if implementation fails or causes unexpected issues, ensuring service continuity.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successCriteria rdf:type rdf:Property ;
    rdfs:label 'Success Criteria' ;
    rdfs:comment 'Measurable criteria that define successful completion of the change, used for post-implementation validation.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:algorithmType rdf:type rdf:Property ;
    rdfs:label 'Algorithm Type' ;
    rdfs:comment 'The matchmaking algorithm used to pair players (skill-based matchmaking, connection-based, hybrid, Elo rating, Glicko, TrueSkill, etc.).' ;
    rdfs:domain ind:MatchmakingService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Api Endpoint Url' ;
    rdfs:comment 'URL of the API endpoint that clients use to interact with this matchmaking service.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avgMatchTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Avg Match Time Seconds' ;
    rdfs:comment 'Average time in seconds for a typical match session facilitated by this matchmaking service.' ;
    rdfs:domain ind:MatchmakingService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:avgQueueTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Avg Queue Time Seconds' ;
    rdfs:comment 'Average time in seconds players spend waiting in the matchmaking queue before being matched.' ;
    rdfs:domain ind:MatchmakingService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backfillEnabled rdf:type rdf:Property ;
    rdfs:label 'Backfill Enabled' ;
    rdfs:comment 'Indicates whether this matchmaking service supports backfilling players into in-progress matches when slots become available.' ;
    rdfs:domain ind:MatchmakingService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:healthCheckIntervalSeconds rdf:type rdf:Property ;
    rdfs:label 'Health Check Interval Seconds' ;
    rdfs:comment 'Frequency in seconds at which the matchmaking service health status is monitored and reported.' ;
    rdfs:domain ind:MatchmakingService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incidentCountLast30Days rdf:type rdf:Property ;
    rdfs:label 'Incident Count Last 30 Days' ;
    rdfs:comment 'Number of incidents reported for this matchmaking service in the last 30 days.' ;
    rdfs:domain ind:MatchmakingService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastDeploymentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Deployment Timestamp' ;
    rdfs:comment 'Timestamp when this matchmaking service version was last deployed to the environment.' ;
    rdfs:domain ind:MatchmakingService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:latencyThresholdMs rdf:type rdf:Property ;
    rdfs:label 'Latency Threshold Ms' ;
    rdfs:comment 'Maximum acceptable network latency in milliseconds for players matched through this service to ensure quality gameplay experience.' ;
    rdfs:domain ind:MatchmakingService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxPartySize rdf:type rdf:Property ;
    rdfs:label 'Max Party Size' ;
    rdfs:comment 'Maximum number of players allowed in a single party when entering this matchmaking service queue.' ;
    rdfs:domain ind:MatchmakingService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxPlayers rdf:type rdf:Property ;
    rdfs:label 'Max Players' ;
    rdfs:comment 'Maximum number of players allowed in a match created by this service.' ;
    rdfs:domain ind:MatchmakingService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxQueueTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Max Queue Time Seconds' ;
    rdfs:comment 'Maximum allowed queue time in seconds before the matchmaking service relaxes matching criteria or times out.' ;
    rdfs:domain ind:MatchmakingService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minPlayers rdf:type rdf:Property ;
    rdfs:label 'Min Players' ;
    rdfs:comment 'Minimum number of players required to start a match through this service.' ;
    rdfs:domain ind:MatchmakingService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partySupportEnabled rdf:type rdf:Property ;
    rdfs:label 'Party Support Enabled' ;
    rdfs:comment 'Indicates whether this matchmaking service supports pre-formed player parties or groups entering the queue together.' ;
    rdfs:domain ind:MatchmakingService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pcuPeakCapacity rdf:type rdf:Property ;
    rdfs:label 'Pcu Peak Capacity' ;
    rdfs:comment 'Peak concurrent user capacity this matchmaking service can scale to during high-demand periods.' ;
    rdfs:domain ind:MatchmakingService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorityWeight rdf:type rdf:Property ;
    rdfs:label 'Priority Weight' ;
    rdfs:comment 'Weighting factor used to prioritize this matchmaking service in resource allocation and queue processing (higher values = higher priority).' ;
    rdfs:domain ind:MatchmakingService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceCode rdf:type rdf:Property ;
    rdfs:label 'Service Code' ;
    rdfs:comment 'Unique business identifier code for the matchmaking service used in operational systems and APIs.' ;
    rdfs:domain ind:MatchmakingService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceType rdf:type rdf:Property ;
    rdfs:label 'Service Type' ;
    rdfs:comment 'Classification of the matchmaking service by gameplay mode and competitive structure.' ;
    rdfs:domain ind:MatchmakingService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillRangeTolerance rdf:type rdf:Property ;
    rdfs:label 'Skill Range Tolerance' ;
    rdfs:comment 'Percentage tolerance for skill rating variance allowed when matching players (e.g., 10.00 means +/- 10% skill rating).' ;
    rdfs:domain ind:MatchmakingService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ageMax rdf:type rdf:Property ;
    rdfs:label 'Age Max' ;
    rdfs:comment 'Maximum age of the target audience for this ad set.' ;
    rdfs:domain ind:AdSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageMin rdf:type rdf:Property ;
    rdfs:label 'Age Min' ;
    rdfs:comment 'Minimum age of the target audience for this ad set.' ;
    rdfs:domain ind:AdSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appStoreUrl rdf:type rdf:Property ;
    rdfs:label 'App Store Url' ;
    rdfs:comment 'Direct URL to the game or app in the app store (Apple App Store, Google Play Store) being promoted by this ad set.' ;
    rdfs:domain ind:AdSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionWindowClick rdf:type rdf:Property ;
    rdfs:label 'Attribution Window Click' ;
    rdfs:comment 'Number of days after a click during which conversions are attributed to this ad set.' ;
    rdfs:domain ind:AdSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attributionWindowView rdf:type rdf:Property ;
    rdfs:label 'Attribution Window View' ;
    rdfs:comment 'Number of days after a view (impression) during which conversions are attributed to this ad set.' ;
    rdfs:domain ind:AdSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bidAmount rdf:type rdf:Property ;
    rdfs:label 'Bid Amount' ;
    rdfs:comment 'Maximum bid amount or target cost per optimization event in the ad set\'s currency.' ;
    rdfs:domain ind:AdSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidStrategy rdf:type rdf:Property ;
    rdfs:label 'Bid Strategy' ;
    rdfs:comment 'Bidding strategy used for ad delivery and auction participation (e.g., lowest cost, cost cap, bid cap, target cost).' ;
    rdfs:domain ind:AdSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeRotation rdf:type rdf:Property ;
    rdfs:label 'Creative Rotation' ;
    rdfs:comment 'Strategy for rotating multiple ad creatives within the ad set (optimize for best performers or rotate evenly).' ;
    rdfs:domain ind:AdSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailyBudget rdf:type rdf:Property ;
    rdfs:label 'Daily Budget' ;
    rdfs:comment 'Maximum amount allocated to be spent per day for this ad set in the campaign currency.' ;
    rdfs:domain ind:AdSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deepLinkUrl rdf:type rdf:Property ;
    rdfs:label 'Deep Link Url' ;
    rdfs:comment 'Deep link URL that directs users to a specific location within the app after install or click.' ;
    rdfs:domain ind:AdSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:devicePlatforms rdf:type rdf:Property ;
    rdfs:label 'Device Platforms' ;
    rdfs:comment 'Comma-separated list of device platforms targeted (e.g., mobile, desktop, tablet, iOS, Android).' ;
    rdfs:domain ind:AdSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyCap rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap' ;
    rdfs:comment 'Maximum number of times an individual user should see ads from this ad set within a specified time period.' ;
    rdfs:domain ind:AdSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyCapPeriodHours rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap Period Hours' ;
    rdfs:comment 'Time period in hours over which the frequency cap is applied.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geoLocations rdf:type rdf:Property ;
    rdfs:label 'Geo Locations' ;
    rdfs:comment 'Comma-separated list or JSON array of geographic locations (countries, regions, cities, postal codes) targeted by this ad set.' ;
    rdfs:domain ind:AdSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAutobid rdf:type rdf:Property ;
    rdfs:label 'Is Autobid' ;
    rdfs:comment 'Indicates whether automatic bidding is enabled for this ad set (true) or manual bidding is used (false).' ;
    rdfs:domain ind:AdSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lifetimeBudget rdf:type rdf:Property ;
    rdfs:label 'Lifetime Budget' ;
    rdfs:comment 'Total maximum amount allocated to be spent over the entire lifetime of this ad set in the campaign currency.' ;
    rdfs:domain ind:AdSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optimizationGoal rdf:type rdf:Property ;
    rdfs:label 'Optimization Goal' ;
    rdfs:comment 'Specific metric or event that the ad delivery algorithm is optimizing for (e.g., install, click, impression, ROAS, value).' ;
    rdfs:domain ind:AdSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pacingType rdf:type rdf:Property ;
    rdfs:label 'Pacing Type' ;
    rdfs:comment 'Strategy for how the ad set budget is spent over time (standard pacing spreads budget evenly, accelerated spends as quickly as possible).' ;
    rdfs:domain ind:AdSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementType rdf:type rdf:Property ;
    rdfs:label 'Placement Type' ;
    rdfs:comment 'Indicates whether ad placements are automatically optimized by the platform or manually selected.' ;
    rdfs:domain ind:AdSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placements rdf:type rdf:Property ;
    rdfs:label 'Placements' ;
    rdfs:comment 'Comma-separated list or JSON array of specific ad placement positions (e.g., feed, stories, in-stream, audience network, rewarded video).' ;
    rdfs:domain ind:AdSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotedObjectReference rdf:type rdf:Property ;
    rdfs:label 'Promoted Object Reference' ;
    rdfs:comment 'External identifier of the specific object being promoted (e.g., app store ID, Facebook page ID, event ID).' ;
    rdfs:domain ind:AdSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotedObjectType rdf:type rdf:Property ;
    rdfs:label 'Promoted Object Type' ;
    rdfs:comment 'Type of object being promoted by this ad set (e.g., app, page, event, product catalog, offer).' ;
    rdfs:domain ind:AdSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetingSpec rdf:type rdf:Property ;
    rdfs:label 'Targeting Spec' ;
    rdfs:comment 'JSON or structured text representation of audience targeting criteria including demographics, interests, behaviors, and custom audiences.' ;
    rdfs:domain ind:AdSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingUrlTemplate rdf:type rdf:Property ;
    rdfs:label 'Tracking Url Template' ;
    rdfs:comment 'Template URL with macros for third-party tracking and attribution (e.g., AppsFlyer, Adjust, Branch) to measure campaign performance.' ;
    rdfs:domain ind:AdSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callToActionText rdf:type rdf:Property ;
    rdfs:label 'Call To Action Text' ;
    rdfs:comment 'Text displayed on the primary call-to-action button or link within the message template.' ;
    rdfs:domain ind:MessageTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callToActionUrl rdf:type rdf:Property ;
    rdfs:label 'Call To Action Url' ;
    rdfs:comment 'Target URL or deep link for the primary call-to-action, directing players to specific game features, store pages, or promotional content.' ;
    rdfs:domain ind:MessageTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Date' ;
    rdfs:comment 'Date when the template was last reviewed for compliance with applicable regulations and marketing standards.' ;
    rdfs:domain ind:MessageTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceReviewed rdf:type rdf:Property ;
    rdfs:label 'Compliance Reviewed' ;
    rdfs:comment 'Indicates whether the template has been reviewed and approved by legal/compliance teams for regulatory adherence (GDPR, COPPA, CAN-SPAM).' ;
    rdfs:domain ind:MessageTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:frequencyCapHours rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap Hours' ;
    rdfs:comment 'Minimum number of hours that must elapse between sending this template to the same player to prevent message fatigue.' ;
    rdfs:domain ind:MessageTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:personalizationTokens rdf:type rdf:Property ;
    rdfs:label 'Personalization Tokens' ;
    rdfs:comment 'Comma-separated list of personalization tokens used in the template (e.g., player_name, level, currency_balance) for dynamic content insertion.' ;
    rdfs:domain ind:MessageTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preheaderText rdf:type rdf:Property ;
    rdfs:label 'Preheader Text' ;
    rdfs:comment 'Preview text displayed in email clients before the message is opened, used to increase open rates.' ;
    rdfs:domain ind:MessageTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replyToEmail rdf:type rdf:Property ;
    rdfs:label 'Reply To Email' ;
    rdfs:comment 'Email address where player replies will be directed. May differ from sender email for support routing.' ;
    rdfs:domain ind:MessageTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendTimeOptimizationEnabled rdf:type rdf:Property ;
    rdfs:label 'Send Time Optimization Enabled' ;
    rdfs:comment 'Indicates whether send-time optimization is enabled for this template to deliver messages at optimal engagement times per player.' ;
    rdfs:domain ind:MessageTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:senderEmail rdf:type rdf:Property ;
    rdfs:label 'Sender Email' ;
    rdfs:comment 'Email address used as the from address for email templates. Must be a verified sending domain.' ;
    rdfs:domain ind:MessageTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderName rdf:type rdf:Property ;
    rdfs:label 'Sender Name' ;
    rdfs:comment 'Display name shown as the sender of the message (e.g., game title, studio name, or character name).' ;
    rdfs:domain ind:MessageTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectLine rdf:type rdf:Property ;
    rdfs:label 'Subject Line' ;
    rdfs:comment 'Subject line text for email templates or title text for push notifications. May contain personalization tokens.' ;
    rdfs:domain ind:MessageTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateCategory rdf:type rdf:Property ;
    rdfs:label 'Template Category' ;
    rdfs:comment 'Marketing category classification indicating the primary business purpose of the template (acquisition, retention, reactivation, monetization, engagement, transactional).' ;
    rdfs:domain ind:MessageTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateCode rdf:type rdf:Property ;
    rdfs:label 'Template Code' ;
    rdfs:comment 'Unique business identifier code for the message template, used for external references and API integrations.' ;
    rdfs:domain ind:MessageTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateName rdf:type rdf:Property ;
    rdfs:label 'Template Name' ;
    rdfs:comment 'Human-readable name of the message template used for identification and selection in campaign management systems.' ;
    rdfs:domain ind:MessageTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateType rdf:type rdf:Property ;
    rdfs:label 'Template Type' ;
    rdfs:comment 'Classification of the message template by delivery channel (email, push notification, in-app message, SMS, web push, direct mail).' ;
    rdfs:domain ind:MessageTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Tracking Enabled' ;
    rdfs:comment 'Indicates whether open tracking, click tracking, and conversion tracking are enabled for messages sent using this template.' ;
    rdfs:domain ind:MessageTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unsubscribeLinkRequired rdf:type rdf:Property ;
    rdfs:label 'Unsubscribe Link Required' ;
    rdfs:comment 'Indicates whether an unsubscribe link must be included in messages sent using this template for regulatory compliance.' ;
    rdfs:domain ind:MessageTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastContactAttemptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Contact Attempt Timestamp' ;
    rdfs:comment 'Timestamp of the last marketing contact attempt before suppression was applied.' ;
    rdfs:domain ind:SuppressionList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:listCode rdf:type rdf:Property ;
    rdfs:label 'List Code' ;
    rdfs:comment 'Externally-known unique code or identifier for this suppression list, used for integration with marketing automation platforms (AppsFlyer, Adjust, Salesforce).' ;
    rdfs:domain ind:SuppressionList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listName rdf:type rdf:Property ;
    rdfs:label 'List Name' ;
    rdfs:comment 'Human-readable name or label for this suppression list (e.g., \'Unsubscribed Users\', \'GDPR Opt-Out\', \'High-Value VIP Exclusion\').' ;
    rdfs:domain ind:SuppressionList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listType rdf:type rdf:Property ;
    rdfs:label 'List Type' ;
    rdfs:comment 'Categorical classification of the suppression list purpose (opt-out, unsubscribe, regulatory compliance, internal exclusion, VIP exclusion, fraud prevention, test account).' ;
    rdfs:domain ind:SuppressionList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilePhone rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone' ;
    rdfs:comment 'Mobile phone number to be suppressed from SMS and push notification campaigns.' ;
    rdfs:domain ind:SuppressionList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reactivationEligibleDate rdf:type rdf:Property ;
    rdfs:label 'Reactivation Eligible Date' ;
    rdfs:comment 'Date when the player becomes eligible for re-engagement or reactivation campaigns, if applicable. Nullable for permanent suppressions.' ;
    rdfs:domain ind:SuppressionList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suppressionPriority rdf:type rdf:Property ;
    rdfs:label 'Suppression Priority' ;
    rdfs:comment 'Priority level for this suppression rule when multiple rules conflict (higher number = higher priority). Used for rule resolution in marketing automation systems.' ;
    rdfs:domain ind:SuppressionList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:suppressionReason rdf:type rdf:Property ;
    rdfs:label 'Suppression Reason' ;
    rdfs:comment 'Primary reason for adding this entry to the suppression list (user request, regulatory compliance, fraud prevention, internal policy, VIP exclusion, test account, data quality issue).' ;
    rdfs:domain ind:SuppressionList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suppressionScope rdf:type rdf:Property ;
    rdfs:label 'Suppression Scope' ;
    rdfs:comment 'Scope of the suppression rule (global across all marketing, game-specific, campaign-specific, or channel-specific).' ;
    rdfs:domain ind:SuppressionList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suppressionSource rdf:type rdf:Property ;
    rdfs:label 'Suppression Source' ;
    rdfs:comment 'System or channel through which the suppression request originated (Salesforce CRM, AppsFlyer, Adjust, manual entry, API, batch import, player self-service portal).' ;
    rdfs:domain ind:SuppressionList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adUnitCode rdf:type rdf:Property ;
    rdfs:label 'Ad Unit Code' ;
    rdfs:comment 'Externally-known unique business identifier for the ad unit, used for ad server integration and campaign targeting.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adUnitName rdf:type rdf:Property ;
    rdfs:label 'Ad Unit Name' ;
    rdfs:comment 'Human-readable name of the ad unit for identification and reporting purposes.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adUnitType rdf:type rdf:Property ;
    rdfs:label 'Ad Unit Type' ;
    rdfs:comment 'Classification of the ad unit format determining how the advertisement is displayed to the player.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advertiserExclusions rdf:type rdf:Property ;
    rdfs:label 'Advertiser Exclusions' ;
    rdfs:comment 'Comma-separated list of advertiser identifiers that are blocked from serving ads through this unit due to competitive or content conflicts.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRefreshEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Refresh Enabled' ;
    rdfs:comment 'Indicates whether the ad unit automatically refreshes to serve new ads at the defined refresh rate interval.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:categoryExclusions rdf:type rdf:Property ;
    rdfs:label 'Category Exclusions' ;
    rdfs:comment 'Comma-separated list of IAB content categories that are blocked from serving ads through this unit to maintain brand safety.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorPriceUsd rdf:type rdf:Property ;
    rdfs:label 'Floor Price Usd' ;
    rdfs:comment 'Minimum cost per mille (CPM) bid price in USD required for an ad to be served through this unit, protecting revenue quality.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frequencyCapCount rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap Count' ;
    rdfs:comment 'Maximum number of times the same ad can be shown to a single user within the frequency cap period, preventing ad fatigue.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mediationPriority rdf:type rdf:Property ;
    rdfs:label 'Mediation Priority' ;
    rdfs:comment 'Priority ranking for this ad unit within the mediation waterfall, determining the order in which ad networks are queried.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:refreshRateSeconds rdf:type rdf:Property ;
    rdfs:label 'Refresh Rate Seconds' ;
    rdfs:comment 'Time interval in seconds between automatic ad refreshes for this unit, impacting impression volume and user experience.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rewardedAdFlag rdf:type rdf:Property ;
    rdfs:label 'Rewarded Ad Flag' ;
    rdfs:comment 'Indicates whether this ad unit provides in-game rewards (virtual currency, extra lives, power-ups) to players who complete the ad view.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:skipOffsetSeconds rdf:type rdf:Property ;
    rdfs:label 'Skip Offset Seconds' ;
    rdfs:comment 'Number of seconds that must elapse before the skip button becomes available to the player for skippable ads.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:skippableFlag rdf:type rdf:Property ;
    rdfs:label 'Skippable Flag' ;
    rdfs:comment 'Indicates whether players can skip the ad before completion, impacting user experience and advertiser value.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetAudienceAgeMax rdf:type rdf:Property ;
    rdfs:label 'Target Audience Age Max' ;
    rdfs:comment 'Maximum age of the intended audience for this ad unit, enabling demographic targeting optimization.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetAudienceAgeMin rdf:type rdf:Property ;
    rdfs:label 'Target Audience Age Min' ;
    rdfs:comment 'Minimum age of the intended audience for this ad unit, ensuring compliance with age-appropriate advertising regulations.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testModeFlag rdf:type rdf:Property ;
    rdfs:label 'Test Mode Flag' ;
    rdfs:comment 'Indicates whether this ad unit is operating in test mode, serving test ads for quality assurance without generating revenue.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:videoDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Video Duration Seconds' ;
    rdfs:comment 'Standard duration in seconds for video ads served through this unit, applicable to video and rewarded video ad types.' ;
    rdfs:domain ind:AdUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storefrontItemId rdf:type rdf:Property ;
    rdfs:label 'Storefront Item Id' ;
    rdfs:comment 'Identifier of the specific item, bundle, or offer purchased from the in-game storefront.' ;
    rdfs:domain ind:Monetization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorefrontItem .

ind:isWhaleTransaction rdf:type rdf:Property ;
    rdfs:label 'Is Whale Transaction' ;
    rdfs:comment 'Flag indicating whether this transaction qualifies as a high-value whale purchase based on business-defined thresholds.' ;
    rdfs:domain ind:StorefrontTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemQuantity rdf:type rdf:Property ;
    rdfs:label 'Item Quantity' ;
    rdfs:comment 'Number of units of the storefront item purchased in this transaction.' ;
    rdfs:domain ind:StorefrontTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storefrontLocation rdf:type rdf:Property ;
    rdfs:label 'Storefront Location' ;
    rdfs:comment 'Specific in-game location or menu where the storefront item was displayed and purchased (e.g., main menu, post-match screen, battle pass tab).' ;
    rdfs:domain ind:StorefrontTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateType rdf:type rdf:Property ;
    rdfs:label 'Certificate Type' ;
    rdfs:comment 'Type of certification certificate: Technical Requirements Checklist (TRC), Technical Certification Requirements (TCR), age rating, content rating, technical compliance, or security audit.' ;
    rdfs:domain ind:CertificationCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationRegion rdf:type rdf:Property ;
    rdfs:label 'Certification Region' ;
    rdfs:comment 'Geographic region or market for which this certification is valid (ISO 3166-1 alpha-3 country code).' ;
    rdfs:domain ind:CertificationCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmEntitlementEnabled rdf:type rdf:Property ;
    rdfs:label 'Drm Entitlement Enabled' ;
    rdfs:comment 'Indicates whether DRM entitlement systems are enabled for this certified build.' ;
    rdfs:domain ind:CertificationCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalNotes rdf:type rdf:Property ;
    rdfs:label 'External Notes' ;
    rdfs:comment 'Notes and feedback provided by the platform holder or certification authority regarding this submission.' ;
    rdfs:domain ind:CertificationCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failedTestCases rdf:type rdf:Property ;
    rdfs:label 'Failed Test Cases' ;
    rdfs:comment 'Number of test cases that failed during the certification process.' ;
    rdfs:domain ind:CertificationCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'Name of the platform holder, certification body, or regulatory authority that issued the certificate (e.g., Sony Interactive Entertainment, Microsoft Xbox, Nintendo, ESRB, PEGI).' ;
    rdfs:domain ind:CertificationCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthorityContactEmail rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Contact Email' ;
    rdfs:comment 'Primary email address of the issuing authority for correspondence regarding this certification.' ;
    rdfs:domain ind:CertificationCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorIssuesCount rdf:type rdf:Property ;
    rdfs:label 'Major Issues Count' ;
    rdfs:comment 'Number of major issues identified during certification that should be resolved before approval.' ;
    rdfs:domain ind:CertificationCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorIssuesCount rdf:type rdf:Property ;
    rdfs:label 'Minor Issues Count' ;
    rdfs:comment 'Number of minor issues identified during certification that may be addressed in future updates.' ;
    rdfs:domain ind:CertificationCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passedTestCases rdf:type rdf:Property ;
    rdfs:label 'Passed Test Cases' ;
    rdfs:comment 'Number of test cases that passed during the certification process.' ;
    rdfs:domain ind:CertificationCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resubmissionRequired rdf:type rdf:Property ;
    rdfs:label 'Resubmission Required' ;
    rdfs:comment 'Indicates whether a resubmission is required after addressing identified issues.' ;
    rdfs:domain ind:CertificationCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewerEmail rdf:type rdf:Property ;
    rdfs:label 'Reviewer Email' ;
    rdfs:comment 'Email address of the primary reviewer or certification analyst assigned to this submission.' ;
    rdfs:domain ind:CertificationCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerName rdf:type rdf:Property ;
    rdfs:label 'Reviewer Name' ;
    rdfs:comment 'Name of the primary reviewer or certification analyst assigned to this submission.' ;
    rdfs:domain ind:CertificationCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waivedTestCases rdf:type rdf:Property ;
    rdfs:label 'Waived Test Cases' ;
    rdfs:comment 'Number of test cases that were waived or exempted by the certification authority.' ;
    rdfs:domain ind:CertificationCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageRatingRequirement rdf:type rdf:Property ;
    rdfs:label 'Age Rating Requirement' ;
    rdfs:comment 'Minimum age rating classification required for users to access this entitlement, based on ESRB or PEGI standards.' ;
    rdfs:domain ind:EntitlementRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Required' ;
    rdfs:comment 'Indicates whether this entitlement rule requires platform-specific compliance certification (TRC/TCR) before activation.' ;
    rdfs:domain ind:EntitlementRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entitlementScope rdf:type rdf:Property ;
    rdfs:label 'Entitlement Scope' ;
    rdfs:comment 'The scope of content or features this entitlement rule grants: full game, downloadable content (DLC), season pass, cosmetic items, in-game currency, subscription tier, or beta access.' ;
    rdfs:domain ind:EntitlementRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productSku rdf:type rdf:Property ;
    rdfs:label 'Product Sku' ;
    rdfs:comment 'The product SKU or catalog identifier this entitlement rule governs access to.' ;
    rdfs:domain ind:EntitlementRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleDescription rdf:type rdf:Property ;
    rdfs:label 'Rule Description' ;
    rdfs:comment 'Detailed description of the entitlement rule, including business logic, conditions, and intended use cases.' ;
    rdfs:domain ind:EntitlementRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current lifecycle status of the entitlement rule indicating whether it is actively enforced, inactive, deprecated, pending approval, or suspended.' ;
    rdfs:domain ind:EntitlementRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialDurationDays rdf:type rdf:Property ;
    rdfs:label 'Trial Duration Days' ;
    rdfs:comment 'Number of days for which this entitlement is granted as a trial before requiring purchase or subscription. Null indicates no trial period.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checkpointId rdf:type rdf:Property ;
    rdfs:label 'Checkpoint Id' ;
    rdfs:comment 'Primary key for checkpoint' ;
    rdfs:domain ind:Checkpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:missionId rdf:type rdf:Property ;
    rdfs:label 'Mission Id' ;
    rdfs:comment 'Reference to the mission or quest associated with this checkpoint, if applicable.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Mission .

ind:achievementLinked rdf:type rdf:Property ;
    rdfs:label 'Achievement Linked' ;
    rdfs:comment 'Indicates whether reaching this checkpoint unlocks or contributes to a game achievement or trophy.' ;
    rdfs:domain ind:Checkpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:audioCueCode rdf:type rdf:Property ;
    rdfs:label 'Audio Cue Code' ;
    rdfs:comment 'Reference to the audio asset played when the checkpoint is activated.' ;
    rdfs:domain ind:Checkpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageCompletionTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Average Completion Time Seconds' ;
    rdfs:comment 'Average time in seconds players take to reach this checkpoint from the previous checkpoint or level start, based on telemetry data.' ;
    rdfs:domain ind:Checkpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:buildVersionDeprecated rdf:type rdf:Property ;
    rdfs:label 'Build Version Deprecated' ;
    rdfs:comment 'Game build version number when this checkpoint was deprecated or removed, if applicable.' ;
    rdfs:domain ind:Checkpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkpointCode rdf:type rdf:Property ;
    rdfs:label 'Checkpoint Code' ;
    rdfs:comment 'Unique business identifier code for the checkpoint, used for external reference and integration.' ;
    rdfs:domain ind:Checkpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkpointName rdf:type rdf:Property ;
    rdfs:label 'Checkpoint Name' ;
    rdfs:comment 'Human-readable name of the checkpoint as displayed to players and developers.' ;
    rdfs:domain ind:Checkpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkpointStatus rdf:type rdf:Property ;
    rdfs:label 'Checkpoint Status' ;
    rdfs:comment 'Current lifecycle status of the checkpoint in the game build.' ;
    rdfs:domain ind:Checkpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkpointType rdf:type rdf:Property ;
    rdfs:label 'Checkpoint Type' ;
    rdfs:comment 'Classification of the checkpoint mechanism: manual (player-triggered), automatic (system-triggered), story (narrative milestone), mission (objective completion), level (stage transition), autosave (periodic system save), or quicksave (player quick-save).' ;
    rdfs:domain ind:Checkpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:narrativeDescription rdf:type rdf:Property ;
    rdfs:label 'Narrative Description' ;
    rdfs:comment 'Story or narrative context associated with this checkpoint for design and documentation purposes.' ;
    rdfs:domain ind:Checkpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerReachRatePercent rdf:type rdf:Property ;
    rdfs:label 'Player Reach Rate Percent' ;
    rdfs:comment 'Percentage of players who reach this checkpoint out of those who started the level or mission, based on telemetry data.' ;
    rdfs:domain ind:Checkpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:respawnCoordinatesX rdf:type rdf:Property ;
    rdfs:label 'Respawn Coordinates X' ;
    rdfs:comment 'X-axis coordinate where the player respawns when using this checkpoint.' ;
    rdfs:domain ind:Checkpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:respawnCoordinatesY rdf:type rdf:Property ;
    rdfs:label 'Respawn Coordinates Y' ;
    rdfs:comment 'Y-axis coordinate where the player respawns when using this checkpoint.' ;
    rdfs:domain ind:Checkpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:respawnCoordinatesZ rdf:type rdf:Property ;
    rdfs:label 'Respawn Coordinates Z' ;
    rdfs:comment 'Z-axis coordinate where the player respawns when using this checkpoint.' ;
    rdfs:domain ind:Checkpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:saveStateIncluded rdf:type rdf:Property ;
    rdfs:label 'Save State Included' ;
    rdfs:comment 'Indicates whether this checkpoint triggers a full game state save (inventory, progress, stats).' ;
    rdfs:domain ind:Checkpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Ordinal position of this checkpoint within the level or mission progression sequence.' ;
    rdfs:domain ind:Checkpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:triggerCondition rdf:type rdf:Property ;
    rdfs:label 'Trigger Condition' ;
    rdfs:comment 'Game logic condition or event that activates this checkpoint (e.g., player proximity, objective completion, time elapsed).' ;
    rdfs:domain ind:Checkpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visualIndicatorType rdf:type rdf:Property ;
    rdfs:label 'Visual Indicator Type' ;
    rdfs:comment 'Type of visual marker or indicator used to represent this checkpoint in the game world.' ;
    rdfs:domain ind:Checkpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:worldCoordinatesX rdf:type rdf:Property ;
    rdfs:label 'World Coordinates X' ;
    rdfs:comment 'X-axis coordinate of the checkpoint location in the game world coordinate system.' ;
    rdfs:domain ind:Checkpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:worldCoordinatesY rdf:type rdf:Property ;
    rdfs:label 'World Coordinates Y' ;
    rdfs:comment 'Y-axis coordinate of the checkpoint location in the game world coordinate system.' ;
    rdfs:domain ind:Checkpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:worldCoordinatesZ rdf:type rdf:Property ;
    rdfs:label 'World Coordinates Z' ;
    rdfs:comment 'Z-axis coordinate of the checkpoint location in the game world coordinate system.' ;
    rdfs:domain ind:Checkpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coinsurancePercentage rdf:type rdf:Property ;
    rdfs:label 'Coinsurance Percentage' ;
    rdfs:comment 'Percentage of costs the employee pays after meeting the deductible under this benefit plan.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:copayAmount rdf:type rdf:Property ;
    rdfs:label 'Copay Amount' ;
    rdfs:comment 'Fixed amount the employee pays for covered services under this benefit plan, typically for medical visits.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageAmount rdf:type rdf:Property ;
    rdfs:label 'Coverage Amount' ;
    rdfs:comment 'Maximum benefit amount or coverage limit provided by this benefit plan, applicable to life insurance and disability plans.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageLevel rdf:type rdf:Property ;
    rdfs:label 'Coverage Level' ;
    rdfs:comment 'Scope of coverage indicating who is eligible under the benefit plan.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductibleAmount rdf:type rdf:Property ;
    rdfs:label 'Deductible Amount' ;
    rdfs:comment 'Annual deductible amount the employee must pay before the benefit plan coverage begins, applicable to insurance plans.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPortable rdf:type rdf:Property ;
    rdfs:label 'Is Portable' ;
    rdfs:comment 'Indicates whether the benefit plan can be continued by the employee after termination of employment.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outOfPocketMaximum rdf:type rdf:Property ;
    rdfs:label 'Out Of Pocket Maximum' ;
    rdfs:comment 'Maximum amount the employee will pay out-of-pocket in a plan year before the benefit plan covers 100% of costs.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planCategory rdf:type rdf:Property ;
    rdfs:label 'Plan Category' ;
    rdfs:comment 'High-level grouping of the benefit plan for organizational and reporting purposes.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planDescription rdf:type rdf:Property ;
    rdfs:label 'Plan Description' ;
    rdfs:comment 'Detailed textual description of the benefit plan features, coverage, and terms for employee reference.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Plan Document Url' ;
    rdfs:comment 'Web address linking to the official benefit plan document, summary plan description, or policy details.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerCode rdf:type rdf:Property ;
    rdfs:label 'Provider Code' ;
    rdfs:comment 'Reference to the external vendor or insurance carrier administering this benefit plan.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxTreatment rdf:type rdf:Property ;
    rdfs:label 'Tax Treatment' ;
    rdfs:comment 'Tax status of employee contributions to this benefit plan for payroll and tax reporting purposes.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waitingPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Waiting Period Days' ;
    rdfs:comment 'Number of days an employee must wait after hire date before becoming eligible for this benefit plan.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hiringManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Hiring Manager Employee Id' ;
    rdfs:comment 'Reference to the hiring manager or studio lead responsible for the final hiring decision for this position.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:jobRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Job Requisition Id' ;
    rdfs:comment 'Reference to the job requisition or job posting that this application is responding to.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecruitmentRequisition .

ind:referralEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Referral Employee Id' ;
    rdfs:comment 'Reference to the current employee who referred this candidate, if the application came through an employee referral program.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicationNumber rdf:type rdf:Property ;
    rdfs:label 'Application Number' ;
    rdfs:comment 'Human-readable unique application reference number assigned to each job application for tracking and communication purposes.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationType rdf:type rdf:Property ;
    rdfs:label 'Application Type' ;
    rdfs:comment 'Classification of the application based on the source and nature of the candidate (external new hire, internal transfer, employee referral, returning employee, or contractor-to-employee conversion).' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentCompleted rdf:type rdf:Property ;
    rdfs:label 'Assessment Completed' ;
    rdfs:comment 'Indicates whether the candidate has completed required technical assessments, skill tests, or portfolio reviews for this application.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:backgroundCheckDate rdf:type rdf:Property ;
    rdfs:label 'Background Check Date' ;
    rdfs:comment 'Date when the background check process was completed.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Disability Status' ;
    rdfs:comment 'Indicates whether the candidate self-identified as having a disability, tracked for compliance and accommodation planning.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:diversityHireFlag rdf:type rdf:Property ;
    rdfs:label 'Diversity Hire Flag' ;
    rdfs:comment 'Indicates whether this application is part of a diversity and inclusion hiring initiative or program.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offerResponseDeadline rdf:type rdf:Property ;
    rdfs:label 'Offer Response Deadline' ;
    rdfs:comment 'Date by which the candidate must accept or decline the job offer.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proposedStartDate rdf:type rdf:Property ;
    rdfs:label 'Proposed Start Date' ;
    rdfs:comment 'Anticipated or agreed-upon date when the candidate would begin employment if hired.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referralBonusEligible rdf:type rdf:Property ;
    rdfs:label 'Referral Bonus Eligible' ;
    rdfs:comment 'Indicates whether the referring employee is eligible for a referral bonus if this candidate is hired and meets retention criteria.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:screeningScore rdf:type rdf:Property ;
    rdfs:label 'Screening Score' ;
    rdfs:comment 'Numerical score assigned during initial resume screening or automated applicant tracking system (ATS) evaluation, typically on a 0-100 scale.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:veteranStatus rdf:type rdf:Property ;
    rdfs:label 'Veteran Status' ;
    rdfs:comment 'Indicates whether the candidate self-identified as a military veteran, tracked for compliance and diversity reporting.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationOffered rdf:type rdf:Property ;
    rdfs:label 'Certification Offered' ;
    rdfs:comment 'Indicates whether successful completion of the course results in a formal certification or credential.' ;
    rdfs:domain ind:Course ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceRequired rdf:type rdf:Property ;
    rdfs:label 'Compliance Required' ;
    rdfs:comment 'Indicates whether the course is mandatory for compliance with regulatory, legal, or organizational policy requirements.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentOwner rdf:type rdf:Property ;
    rdfs:label 'Content Owner' ;
    rdfs:comment 'Name or identifier of the individual or team responsible for maintaining and updating the course content.' ;
    rdfs:domain ind:Course ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerLearner rdf:type rdf:Property ;
    rdfs:label 'Cost Per Learner' ;
    rdfs:comment 'The monetary cost incurred per individual learner enrolled in the course, including materials and instructor fees.' ;
    rdfs:domain ind:Course ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:courseCode rdf:type rdf:Property ;
    rdfs:label 'Course Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code for the course, used in catalogs and registration systems.' ;
    rdfs:domain ind:Course ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseType rdf:type rdf:Property ;
    rdfs:label 'Course Type' ;
    rdfs:comment 'Categorical classification of the course based on its primary focus area (e.g., technical skills, leadership development, compliance training).' ;
    rdfs:domain ind:Course ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMode rdf:type rdf:Property ;
    rdfs:label 'Delivery Mode' ;
    rdfs:comment 'The method by which the course is delivered to learners (e.g., in-person classroom, virtual instructor-led, self-paced online).' ;
    rdfs:domain ind:Course ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentOpen rdf:type rdf:Property ;
    rdfs:label 'Enrollment Open' ;
    rdfs:comment 'Indicates whether the course is currently accepting new enrollments.' ;
    rdfs:domain ind:Course ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:instructorEmail rdf:type rdf:Property ;
    rdfs:label 'Instructor Email' ;
    rdfs:comment 'Email address of the primary instructor for learner inquiries and course coordination.' ;
    rdfs:domain ind:Course ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialsUrl rdf:type rdf:Property ;
    rdfs:label 'Materials Url' ;
    rdfs:comment 'Web address or file path where course materials, resources, and supplementary content are stored and accessible.' ;
    rdfs:domain ind:Course ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxEnrollment rdf:type rdf:Property ;
    rdfs:label 'Max Enrollment' ;
    rdfs:comment 'The maximum number of participants that can be enrolled in a single offering of the course.' ;
    rdfs:domain ind:Course ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recertificationPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Recertification Period Months' ;
    rdfs:comment 'The number of months after which learners must retake or renew the course to maintain certification or compliance status.' ;
    rdfs:domain ind:Course ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:studioApplicable rdf:type rdf:Property ;
    rdfs:label 'Studio Applicable' ;
    rdfs:comment 'Comma-separated list of studio names or identifiers for which this course is relevant, supporting studio-specific capacity planning.' ;
    rdfs:domain ind:Course ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalDeadlineDays rdf:type rdf:Property ;
    rdfs:label 'Approval Deadline Days' ;
    rdfs:comment 'Number of days before pay date that all time entries and payroll adjustments must be approved by managers.' ;
    rdfs:domain ind:PayrollCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarCode rdf:type rdf:Property ;
    rdfs:label 'Calendar Code' ;
    rdfs:comment 'Business identifier code for the payroll calendar, used for external reference and integration with SAP S/4HANA HR module.' ;
    rdfs:domain ind:PayrollCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarName rdf:type rdf:Property ;
    rdfs:label 'Calendar Name' ;
    rdfs:comment 'Human-readable name of the payroll calendar (e.g., \'US Biweekly Salaried\', \'UK Monthly Contractors\').' ;
    rdfs:domain ind:PayrollCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarType rdf:type rdf:Property ;
    rdfs:label 'Calendar Type' ;
    rdfs:comment 'Classification of the payroll calendar frequency determining pay period intervals.' ;
    rdfs:domain ind:PayrollCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crunchPeriodOverrideAllowed rdf:type rdf:Property ;
    rdfs:label 'Crunch Period Override Allowed' ;
    rdfs:comment 'Indicates whether this calendar permits temporary schedule overrides during game development crunch periods.' ;
    rdfs:domain ind:PayrollCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeeGroup rdf:type rdf:Property ;
    rdfs:label 'Employee Group' ;
    rdfs:comment 'Classification of employee population covered by this calendar (e.g., \'Full-Time Developers\', \'Contractors\', \'QA Testers\', \'Esports Athletes\').' ;
    rdfs:domain ind:PayrollCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstPayPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'First Pay Period Start Date' ;
    rdfs:comment 'Start date of the first pay period in this calendar, used as the anchor for calculating all subsequent periods.' ;
    rdfs:domain ind:PayrollCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holidayCalendarCode rdf:type rdf:Property ;
    rdfs:label 'Holiday Calendar Code' ;
    rdfs:comment 'Reference to the holiday calendar used to adjust pay dates when they fall on non-working days.' ;
    rdfs:domain ind:PayrollCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:igdaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Igda Compliance Flag' ;
    rdfs:comment 'Indicates whether this payroll calendar adheres to IGDA workforce standards for game development labor practices.' ;
    rdfs:domain ind:PayrollCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefaultCalendar rdf:type rdf:Property ;
    rdfs:label 'Is Default Calendar' ;
    rdfs:comment 'Indicates whether this is the default payroll calendar for the associated studio or employee group.' ;
    rdfs:domain ind:PayrollCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payDateAdjustmentRule rdf:type rdf:Property ;
    rdfs:label 'Pay Date Adjustment Rule' ;
    rdfs:comment 'Rule for adjusting pay dates when they fall on holidays or weekends.' ;
    rdfs:domain ind:PayrollCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payDayOfWeek rdf:type rdf:Property ;
    rdfs:label 'Pay Day Of Week' ;
    rdfs:comment 'Standard day of the week on which payroll is disbursed (e.g., \'friday\' for weekly payrolls).' ;
    rdfs:domain ind:PayrollCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payDayOffsetDays rdf:type rdf:Property ;
    rdfs:label 'Pay Day Offset Days' ;
    rdfs:comment 'Number of days after the pay period end date that payment is issued to employees.' ;
    rdfs:domain ind:PayrollCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payFrequencyPerYear rdf:type rdf:Property ;
    rdfs:label 'Pay Frequency Per Year' ;
    rdfs:comment 'Number of pay periods in a standard calendar year (e.g., 52 for weekly, 26 for biweekly, 24 for semi-monthly, 12 for monthly).' ;
    rdfs:domain ind:PayrollCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sapPayrollControlRecord rdf:type rdf:Property ;
    rdfs:label 'Sap Payroll Control Record' ;
    rdfs:comment 'SAP-specific control record identifier linking this calendar to SAP S/4HANA HR payroll processing configuration.' ;
    rdfs:domain ind:PayrollCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportsOffCyclePayments rdf:type rdf:Property ;
    rdfs:label 'Supports Off Cycle Payments' ;
    rdfs:comment 'Indicates whether this calendar allows for off-cycle or ad-hoc payroll runs outside the standard schedule.' ;
    rdfs:domain ind:PayrollCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxYearStartMonth rdf:type rdf:Property ;
    rdfs:label 'Tax Year Start Month' ;
    rdfs:comment 'Month number (1-12) when the tax year begins for this jurisdiction, used for year-to-date calculations.' ;
    rdfs:domain ind:PayrollCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timeEntryCutoffDays rdf:type rdf:Property ;
    rdfs:label 'Time Entry Cutoff Days' ;
    rdfs:comment 'Number of days before pay period end that time entry submissions must be completed for payroll processing.' ;
    rdfs:domain ind:PayrollCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calibrationEndDate rdf:type rdf:Property ;
    rdfs:label 'Calibration End Date' ;
    rdfs:comment 'The date by which all calibration sessions must be completed and final ratings approved by senior leadership.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calibrationStartDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Start Date' ;
    rdfs:comment 'The date when leadership calibration sessions begin to normalize performance ratings across teams and ensure fairness and consistency.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:communicationPlan rdf:type rdf:Property ;
    rdfs:label 'Communication Plan' ;
    rdfs:comment 'Summary of the communication strategy for this review cycle, including key messages, channels, and stakeholder engagement approach.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationReviewLinked rdf:type rdf:Property ;
    rdfs:label 'Compensation Review Linked' ;
    rdfs:comment 'Indicates whether this review cycle is directly linked to compensation decisions (salary increases, bonuses, equity grants). True means performance ratings will influence compensation outcomes; false means this is a developmental review only.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibleEmployeeCount rdf:type rdf:Property ;
    rdfs:label 'Eligible Employee Count' ;
    rdfs:comment 'The total number of employees eligible to participate in this review cycle at the time of cycle creation. Excludes employees on leave, contractors, and ineligible employment types.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:employmentTypeScope rdf:type rdf:Property ;
    rdfs:label 'Employment Type Scope' ;
    rdfs:comment 'Pipe-separated list of employment types included in this review cycle (e.g., \'full_time|part_time|contractor\'). Defines which employee categories are eligible for review. [ENUM-REF-CANDIDATE: full_time|part_time|contractor|temporary|intern|seasonal|freelance — promote to reference product]' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackDeliveryDueDate rdf:type rdf:Property ;
    rdfs:label 'Feedback Delivery Due Date' ;
    rdfs:comment 'The deadline by which all managers must complete feedback delivery sessions with their direct reports. Required for cycle closure.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feedbackDeliveryStartDate rdf:type rdf:Property ;
    rdfs:label 'Feedback Delivery Start Date' ;
    rdfs:comment 'The date when managers can begin scheduling and conducting one-on-one feedback sessions with employees to discuss review results.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forcedDistributionEnabled rdf:type rdf:Property ;
    rdfs:label 'Forced Distribution Enabled' ;
    rdfs:comment 'Indicates whether forced ranking or distribution curves are applied during calibration. True means a percentage of employees must be rated in each performance tier; false means ratings are not constrained by distribution requirements.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goalSettingEnabled rdf:type rdf:Property ;
    rdfs:label 'Goal Setting Enabled' ;
    rdfs:comment 'Indicates whether goal-setting functionality is enabled for this review cycle. True means employees and managers can set performance goals; false means this cycle focuses only on retrospective evaluation.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobLevelScope rdf:type rdf:Property ;
    rdfs:label 'Job Level Scope' ;
    rdfs:comment 'Defines which job levels or career bands are included in this review cycle (e.g., \'individual_contributor\', \'manager\', \'senior_leader\'). Used to segment review processes by organizational hierarchy.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Manager Review Due Date' ;
    rdfs:comment 'The deadline by which managers must complete all performance reviews for their direct reports. Required for calibration session scheduling.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:managerReviewStartDate rdf:type rdf:Property ;
    rdfs:label 'Manager Review Start Date' ;
    rdfs:comment 'The date when managers can begin conducting performance reviews and providing ratings for their direct reports.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:peerFeedbackEnabled rdf:type rdf:Property ;
    rdfs:label 'Peer Feedback Enabled' ;
    rdfs:comment 'Indicates whether peer feedback collection is enabled for this review cycle. True means employees can nominate peers and receive 360-degree feedback; false means reviews are manager-only.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionEligible rdf:type rdf:Property ;
    rdfs:label 'Promotion Eligible' ;
    rdfs:comment 'Indicates whether employees can be nominated for promotion during this review cycle. True means promotion recommendations are accepted; false means this cycle does not include promotion decisions.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ratingScaleType rdf:type rdf:Property ;
    rdfs:label 'Rating Scale Type' ;
    rdfs:comment 'The performance rating scale used for this review cycle. Five-point scales typically range from \'Does Not Meet\' to \'Exceptional\'; four-point scales eliminate the middle option; three-point scales use \'Below/Meets/Exceeds\'; narrative-only cycles do not use numeric ratings; meets-expectations scales use binary pass/fail assessment.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewTemplateCode rdf:type rdf:Property ;
    rdfs:label 'Review Template Code' ;
    rdfs:comment 'Reference to the review form template used for this cycle, defining the questions, competencies, and rating criteria employees and managers will use.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:selfAssessmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Self Assessment Due Date' ;
    rdfs:comment 'The deadline by which employees must complete and submit their self-assessment forms. Late submissions may require manager approval.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:selfAssessmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Self Assessment Start Date' ;
    rdfs:comment 'The date when employees can begin submitting their self-assessment forms for this review cycle.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:studioScope rdf:type rdf:Property ;
    rdfs:label 'Studio Scope' ;
    rdfs:comment 'Defines the organizational scope of the review cycle. Global cycles apply to all studios and locations; regional cycles target specific geographic regions; studio-specific cycles apply to individual game development studios; project-team cycles focus on specific game title development teams.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetParticipationRate rdf:type rdf:Property ;
    rdfs:label 'Target Participation Rate' ;
    rdfs:comment 'The target percentage of eligible employees who should complete the review cycle (e.g., 95.00 means 95% participation target). Used for compliance tracking and HR analytics.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upwardFeedbackEnabled rdf:type rdf:Property ;
    rdfs:label 'Upward Feedback Enabled' ;
    rdfs:comment 'Indicates whether upward feedback (employee feedback on managers) is enabled for this review cycle. True means direct reports can provide anonymous feedback on their managers; false means no upward feedback is collected.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:datasetId rdf:type rdf:Property ;
    rdfs:label 'Dataset Id' ;
    rdfs:comment 'Primary key for dataset' ;
    rdfs:domain ind:Dataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessLevel rdf:type rdf:Property ;
    rdfs:label 'Access Level' ;
    rdfs:comment 'Data classification level determining who can access and use the dataset.' ;
    rdfs:domain ind:Dataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataDomain rdf:type rdf:Property ;
    rdfs:label 'Data Domain' ;
    rdfs:comment 'Business domain or subject area that the dataset belongs to within the analytics ecosystem.' ;
    rdfs:domain ind:Dataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAnonymized rdf:type rdf:Property ;
    rdfs:label 'Is Anonymized' ;
    rdfs:comment 'Indicates whether the dataset has undergone anonymization or de-identification processes to protect player privacy.' ;
    rdfs:domain ind:Dataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCertified rdf:type rdf:Property ;
    rdfs:label 'Is Certified' ;
    rdfs:comment 'Indicates whether the dataset has been certified by data governance as meeting quality, compliance, and documentation standards.' ;
    rdfs:domain ind:Dataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPiiPresent rdf:type rdf:Property ;
    rdfs:label 'Is Pii Present' ;
    rdfs:comment 'Indicates whether the dataset contains personally identifiable information requiring special handling and compliance measures.' ;
    rdfs:domain ind:Dataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineageSource rdf:type rdf:Property ;
    rdfs:label 'Lineage Source' ;
    rdfs:comment 'Upstream data source or parent dataset from which this dataset was derived or transformed.' ;
    rdfs:domain ind:Dataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelRegistryId rdf:type rdf:Property ;
    rdfs:label 'Model Registry Id' ;
    rdfs:comment 'Reference identifier linking the dataset to machine learning models in the model registry that were trained or validated using this dataset.' ;
    rdfs:domain ind:Dataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partitionStrategy rdf:type rdf:Property ;
    rdfs:label 'Partition Strategy' ;
    rdfs:comment 'Partitioning scheme applied to the dataset for optimized query performance and data organization.' ;
    rdfs:domain ind:Dataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCount rdf:type rdf:Property ;
    rdfs:label 'Record Count' ;
    rdfs:comment 'Total number of records or observations contained in the dataset.' ;
    rdfs:domain ind:Dataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sizeBytes rdf:type rdf:Property ;
    rdfs:label 'Size Bytes' ;
    rdfs:comment 'Physical storage size of the dataset measured in bytes.' ;
    rdfs:domain ind:Dataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stewardName rdf:type rdf:Property ;
    rdfs:label 'Steward Name' ;
    rdfs:comment 'Name of the individual responsible for data quality, governance, and compliance for this dataset.' ;
    rdfs:domain ind:Dataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Physical or logical path where the dataset is stored in the lakehouse architecture.' ;
    rdfs:domain ind:Dataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temporalCoverageEndDate rdf:type rdf:Property ;
    rdfs:label 'Temporal Coverage End Date' ;
    rdfs:comment 'Latest date of data contained within the dataset, defining the end of its temporal range.' ;
    rdfs:domain ind:Dataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:temporalCoverageStartDate rdf:type rdf:Property ;
    rdfs:label 'Temporal Coverage Start Date' ;
    rdfs:comment 'Earliest date of data contained within the dataset, defining the beginning of its temporal range.' ;
    rdfs:domain ind:Dataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:funnelStepId rdf:type rdf:Property ;
    rdfs:label 'Funnel Step Id' ;
    rdfs:comment 'Primary key for funnel_step' ;
    rdfs:domain ind:FunnelStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessOwner rdf:type rdf:Property ;
    rdfs:label 'Business Owner' ;
    rdfs:comment 'Name or identifier of the business stakeholder responsible for defining and maintaining this funnel step.' ;
    rdfs:domain ind:FunnelStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataScienceModelId rdf:type rdf:Property ;
    rdfs:label 'Data Science Model Id' ;
    rdfs:comment 'Reference to the machine learning model in the model registry used for predicting completion of this step.' ;
    rdfs:domain ind:FunnelStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventParameters rdf:type rdf:Property ;
    rdfs:label 'Event Parameters' ;
    rdfs:comment 'JSON string or key-value pairs defining additional event parameters required to qualify this step completion.' ;
    rdfs:domain ind:FunnelStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:funnelId rdf:type rdf:Property ;
    rdfs:label 'Funnel Id' ;
    rdfs:comment 'Reference to the parent funnel definition that this step belongs to.' ;
    rdfs:domain ind:FunnelStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gameModeFilter rdf:type rdf:Property ;
    rdfs:label 'Game Mode Filter' ;
    rdfs:comment 'Comma-separated list of game modes this step applies to (e.g., \'single_player\', \'multiplayer\', \'competitive\').' ;
    rdfs:domain ind:FunnelStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRequired rdf:type rdf:Property ;
    rdfs:label 'Is Required' ;
    rdfs:comment 'Indicates whether this step is mandatory in the funnel sequence or optional.' ;
    rdfs:domain ind:FunnelStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTerminal rdf:type rdf:Property ;
    rdfs:label 'Is Terminal' ;
    rdfs:comment 'Indicates whether this step represents a terminal conversion event (end of funnel).' ;
    rdfs:domain ind:FunnelStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kpiMetricId rdf:type rdf:Property ;
    rdfs:label 'Kpi Metric Id' ;
    rdfs:comment 'Reference to the KPI metric catalog entry associated with this funnel step.' ;
    rdfs:domain ind:FunnelStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Revenue Impact Flag' ;
    rdfs:comment 'Indicates whether this funnel step has direct revenue implications (e.g., purchase, subscription).' ;
    rdfs:domain ind:FunnelStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stepCategory rdf:type rdf:Property ;
    rdfs:label 'Step Category' ;
    rdfs:comment 'High-level category aligning the step to the AARRR (Pirate Metrics) framework for player lifecycle analysis.' ;
    rdfs:domain ind:FunnelStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepCode rdf:type rdf:Property ;
    rdfs:label 'Step Code' ;
    rdfs:comment 'Standardized code identifier for the funnel step used in telemetry and event tracking systems.' ;
    rdfs:domain ind:FunnelStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepDescription rdf:type rdf:Property ;
    rdfs:label 'Step Description' ;
    rdfs:comment 'Detailed business description of what player action or milestone this step represents.' ;
    rdfs:domain ind:FunnelStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepName rdf:type rdf:Property ;
    rdfs:label 'Step Name' ;
    rdfs:comment 'Human-readable name of the funnel step (e.g., \'Tutorial Start\', \'First Purchase\', \'Level 10 Reached\').' ;
    rdfs:domain ind:FunnelStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepSequence rdf:type rdf:Property ;
    rdfs:label 'Step Sequence' ;
    rdfs:comment 'Ordinal position of this step within its parent funnel, used for sequential analysis and drop-off calculation.' ;
    rdfs:domain ind:FunnelStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetCompletionRate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Rate' ;
    rdfs:comment 'Expected or target completion rate for this step as a decimal (e.g., 0.7500 for 75%).' ;
    rdfs:domain ind:FunnelStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetTimeToCompleteSeconds rdf:type rdf:Property ;
    rdfs:label 'Target Time To Complete Seconds' ;
    rdfs:comment 'Expected time in seconds for a player to complete this step from the previous step.' ;
    rdfs:domain ind:FunnelStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:achievementsSystemName rdf:type rdf:Property ;
    rdfs:label 'Achievements System Name' ;
    rdfs:comment 'Name of the platform holder\'s proprietary achievements or trophies system (e.g., PlayStation Trophies, Xbox Achievements, Steam Achievements, Google Play Games Achievements).' ;
    rdfs:domain ind:PlatformHolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analyticsSdkAvailable rdf:type rdf:Property ;
    rdfs:label 'Analytics Sdk Available' ;
    rdfs:comment 'Indicates whether the platform holder provides an analytics SDK for tracking player behavior, engagement metrics, and performance data.' ;
    rdfs:domain ind:PlatformHolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:backwardCompatibilitySupported rdf:type rdf:Property ;
    rdfs:label 'Backward Compatibility Supported' ;
    rdfs:comment 'Indicates whether the platform holder supports running games from previous platform generations on current hardware.' ;
    rdfs:domain ind:PlatformHolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessDevelopmentContact rdf:type rdf:Property ;
    rdfs:label 'Business Development Contact' ;
    rdfs:comment 'Email address or contact identifier for business development, partnership negotiations, and commercial discussions with the platform holder.' ;
    rdfs:domain ind:PlatformHolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationProcessType rdf:type rdf:Property ;
    rdfs:label 'Certification Process Type' ;
    rdfs:comment 'Type of technical certification or compliance review process required by the platform holder. TRC (Technical Requirements Checklist) for PlayStation, TCR (Technical Certification Requirements) for Xbox, Lotcheck for Nintendo, Steamworks Review for Steam, App Review for Apple, Play Review for Google.' ;
    rdfs:domain ind:PlatformHolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cloudSaveSupported rdf:type rdf:Property ;
    rdfs:label 'Cloud Save Supported' ;
    rdfs:comment 'Indicates whether the platform holder provides cloud-based game save storage and synchronization services.' ;
    rdfs:domain ind:PlatformHolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmSystemName rdf:type rdf:Property ;
    rdfs:label 'Drm System Name' ;
    rdfs:comment 'Name of the proprietary DRM and entitlement system used by the platform holder to manage game licenses and access control.' ;
    rdfs:domain ind:PlatformHolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnershipTier rdf:type rdf:Property ;
    rdfs:label 'Partnership Tier' ;
    rdfs:comment 'Classification of the business relationship strength and priority level with the platform holder.' ;
    rdfs:domain ind:PlatformHolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patchApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Patch Approval Required' ;
    rdfs:comment 'Indicates whether game updates and patches require formal approval from the platform holder before deployment.' ;
    rdfs:domain ind:PlatformHolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentProcessingSystem rdf:type rdf:Property ;
    rdfs:label 'Payment Processing System' ;
    rdfs:comment 'Name of the payment processing and transaction system used by the platform holder for in-game purchases and game sales.' ;
    rdfs:domain ind:PlatformHolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdkIntegrationRequired rdf:type rdf:Property ;
    rdfs:label 'Sdk Integration Required' ;
    rdfs:comment 'Indicates whether games must integrate the platform holder\'s proprietary SDK for distribution on their platform.' ;
    rdfs:domain ind:PlatformHolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:socialFeaturesSupported rdf:type rdf:Property ;
    rdfs:label 'Social Features Supported' ;
    rdfs:comment 'Indicates whether the platform holder provides integrated social networking features such as friends lists, messaging, and activity feeds.' ;
    rdfs:domain ind:PlatformHolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Submission Lead Time Days' ;
    rdfs:comment 'Typical number of business days required for the platform holder to complete certification review and approve a game submission.' ;
    rdfs:domain ind:PlatformHolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supportsCrossPlatformPlay rdf:type rdf:Property ;
    rdfs:label 'Supports Cross Platform Play' ;
    rdfs:comment 'Indicates whether the platform holder allows and supports cross-platform multiplayer functionality with other platforms.' ;
    rdfs:domain ind:PlatformHolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsCrossPlatformProgression rdf:type rdf:Property ;
    rdfs:label 'Supports Cross Platform Progression' ;
    rdfs:comment 'Indicates whether the platform holder supports cross-platform save data and player progression synchronization.' ;
    rdfs:domain ind:PlatformHolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsInGamePurchases rdf:type rdf:Property ;
    rdfs:label 'Supports In Game Purchases' ;
    rdfs:comment 'Indicates whether the platform holder provides infrastructure and APIs for in-game microtransactions and virtual goods.' ;
    rdfs:domain ind:PlatformHolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsSubscriptionModel rdf:type rdf:Property ;
    rdfs:label 'Supports Subscription Model' ;
    rdfs:comment 'Indicates whether the platform holder offers a subscription service that includes game access (e.g., PlayStation Plus, Xbox Game Pass, Apple Arcade).' ;
    rdfs:domain ind:PlatformHolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technicalSupportContact rdf:type rdf:Property ;
    rdfs:label 'Technical Support Contact' ;
    rdfs:comment 'Email address or contact identifier for technical support and SDK integration assistance from the platform holder.' ;
    rdfs:domain ind:PlatformHolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageAuthorizationTimeMs rdf:type rdf:Property ;
    rdfs:label 'Average Authorization Time Ms' ;
    rdfs:comment 'Average time in milliseconds for the payment provider to authorize a transaction. Key performance indicator for checkout experience optimization.' ;
    rdfs:domain ind:PaymentProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chargebackFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Chargeback Fee Amount' ;
    rdfs:comment 'Fixed fee charged by the payment provider per chargeback dispute (e.g., 15.00 USD). Critical for chargeback cost tracking and fraud prevention ROI analysis.' ;
    rdfs:domain ind:PaymentProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:merchantAccountId rdf:type rdf:Property ;
    rdfs:label 'Merchant Account Id' ;
    rdfs:comment 'The merchant account identifier or merchant ID assigned by the payment provider to the gaming company. Used for reconciliation and settlement tracking.' ;
    rdfs:domain ind:PaymentProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pciCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Pci Certification Date' ;
    rdfs:comment 'Date of the most recent PCI DSS compliance certification for this payment provider. Must be renewed annually per PCI DSS requirements.' ;
    rdfs:domain ind:PaymentProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pciCertificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Pci Certification Expiry Date' ;
    rdfs:comment 'Expiration date of the current PCI DSS compliance certification. Providers must be recertified before this date to maintain active status.' ;
    rdfs:domain ind:PaymentProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:providerType rdf:type rdf:Property ;
    rdfs:label 'Provider Type' ;
    rdfs:comment 'Classification of the payment provider based on service model: payment gateway (Stripe, Adyen), payment processor (Worldpay), digital wallet (PayPal, Apple Pay), bank transfer (ACH, SEPA), mobile payment (Google Pay, Samsung Pay), or console first-party (PlayStation Network, Xbox Live, Nintendo eShop).' ;
    rdfs:domain ind:PaymentProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Fee Amount' ;
    rdfs:comment 'Fee charged by the payment provider for processing refunds. Some providers refund the original transaction fee, others charge a separate refund fee.' ;
    rdfs:domain ind:PaymentProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Settlement Period Days' ;
    rdfs:comment 'Number of days between transaction authorization and funds settlement to the merchant account (e.g., 2 for T+2 settlement). Critical for cash flow forecasting and working capital management.' ;
    rdfs:domain ind:PaymentProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supportedCurrencies rdf:type rdf:Property ;
    rdfs:label 'Supported Currencies' ;
    rdfs:comment 'Comma-separated list of ISO 4217 three-letter currency codes that this payment provider supports (e.g., USD,EUR,GBP,JPY,KRW). Used to route transactions to appropriate providers based on player currency.' ;
    rdfs:domain ind:PaymentProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedRegions rdf:type rdf:Property ;
    rdfs:label 'Supported Regions' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes or region codes where this payment provider is available (e.g., USA,CAN,GBR,DEU,JPN,KOR,BRA). Used for geographic routing of payment transactions.' ;
    rdfs:domain ind:PaymentProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supports3ds rdf:type rdf:Property ;
    rdfs:label 'Supports 3ds' ;
    rdfs:comment 'Indicates whether the payment provider supports 3D Secure authentication (3DS 1.0 or 3DS 2.0) for fraud prevention and liability shift. Required in many European markets under PSD2 Strong Customer Authentication.' ;
    rdfs:domain ind:PaymentProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsRecurringBilling rdf:type rdf:Property ;
    rdfs:label 'Supports Recurring Billing' ;
    rdfs:comment 'Indicates whether the payment provider supports recurring billing for subscriptions (e.g., monthly game pass, season pass auto-renewal). True if supported, False otherwise.' ;
    rdfs:domain ind:PaymentProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsTokenization rdf:type rdf:Property ;
    rdfs:label 'Supports Tokenization' ;
    rdfs:comment 'Indicates whether the payment provider supports tokenization of payment instruments for secure storage and reuse. Critical for PCI DSS compliance and one-click checkout.' ;
    rdfs:domain ind:PaymentProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:threeDsVersion rdf:type rdf:Property ;
    rdfs:label 'Three Ds Version' ;
    rdfs:comment 'Version of 3D Secure protocol supported by the payment provider. 3DS 2.x provides better mobile experience and lower friction than 1.0.' ;
    rdfs:domain ind:PaymentProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Transaction Fee Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the fixed transaction fee (e.g., USD, EUR). Used for multi-currency fee reconciliation.' ;
    rdfs:domain ind:PaymentProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionFeeFixedAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Fee Fixed Amount' ;
    rdfs:comment 'Fixed per-transaction fee charged by the payment provider in the provider\'s base currency (e.g., 0.30 USD). Combined with percentage fee for total cost calculation.' ;
    rdfs:domain ind:PaymentProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionFeePercentage rdf:type rdf:Property ;
    rdfs:label 'Transaction Fee Percentage' ;
    rdfs:comment 'Percentage-based transaction fee charged by the payment provider (e.g., 0.0290 for 2.90%). Used for revenue recognition and cost allocation calculations.' ;
    rdfs:domain ind:PaymentProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'Number of formal amendments or addendums executed against this contract since its original signature.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chargebackLiabilityParty rdf:type rdf:Property ;
    rdfs:label 'Chargeback Liability Party' ;
    rdfs:comment 'Specifies which party bears financial responsibility for payment chargebacks and disputes under this contract.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Period Years' ;
    rdfs:comment 'Number of years after contract termination during which confidentiality obligations remain in effect.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractValueEstimate rdf:type rdf:Property ;
    rdfs:label 'Contract Value Estimate' ;
    rdfs:comment 'Estimated total monetary value of the contract over its full term, used for financial planning and forecasting. Nullable for open-ended or variable contracts.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:excludedTerritories rdf:type rdf:Property ;
    rdfs:label 'Excluded Territories' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes explicitly excluded from this contract. Used for regional licensing restrictions.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:includedTerritories rdf:type rdf:Property ;
    rdfs:label 'Included Territories' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where this contract is valid. Nullable if territory_scope is global.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'Date of the most recent amendment to the contract. Nullable if no amendments have been executed.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publisherId rdf:type rdf:Property ;
    rdfs:label 'Publisher Id' ;
    rdfs:comment 'Reference to the game publisher entity that is party to this contract.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:refundPolicyType rdf:type rdf:Property ;
    rdfs:label 'Refund Policy Type' ;
    rdfs:comment 'Classification of the refund policy governing transactions under this contract.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundWindowDays rdf:type rdf:Property ;
    rdfs:label 'Refund Window Days' ;
    rdfs:comment 'Number of days after purchase during which customers may request a refund under the contract terms. Nullable if refund_policy_type is no_refunds.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signatureDate rdf:type rdf:Property ;
    rdfs:label 'Signature Date' ;
    rdfs:comment 'Date when all parties executed the contract, establishing legal agreement. May differ from effective_start_date.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signedByPlatform rdf:type rdf:Property ;
    rdfs:label 'Signed By Platform' ;
    rdfs:comment 'Name and title of the authorized signatory who executed the contract on behalf of the platform holder.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signedByPublisher rdf:type rdf:Property ;
    rdfs:label 'Signed By Publisher' ;
    rdfs:comment 'Name and title of the authorized signatory who executed the contract on behalf of the publisher.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleFlag rdf:type rdf:Property ;
    rdfs:label 'Bundle Flag' ;
    rdfs:comment 'Indicates whether this product is a bundle containing multiple sub-products sold as a single SKU.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentDescriptor rdf:type rdf:Property ;
    rdfs:label 'Content Descriptor' ;
    rdfs:comment 'Comma-separated list of ESRB content descriptors (e.g., Violence, Blood, Strong Language) that describe content elements in the product.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developerId rdf:type rdf:Property ;
    rdfs:label 'Developer Id' ;
    rdfs:comment 'Reference to the development studio that created this product.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:genre rdf:type rdf:Property ;
    rdfs:label 'Genre' ;
    rdfs:comment 'Primary game genre classification (e.g., Action, RPG, Strategy, Sports, Simulation).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentProductId rdf:type rdf:Property ;
    rdfs:label 'Parent Product Id' ;
    rdfs:comment 'Reference to the parent base game product for DLC, expansions, and season passes. Null for standalone products.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pciDssScope rdf:type rdf:Property ;
    rdfs:label 'Pci Dss Scope' ;
    rdfs:comment 'Indicates whether transactions for this product involve payment card data and fall under PCI DSS compliance scope.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preOrderAvailable rdf:type rdf:Property ;
    rdfs:label 'Pre Order Available' ;
    rdfs:comment 'Indicates whether this product is available for pre-order purchase before the official release date.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preOrderBonusDescription rdf:type rdf:Property ;
    rdfs:label 'Pre Order Bonus Description' ;
    rdfs:comment 'Description of exclusive content or bonuses provided to customers who pre-order this product. Null if no pre-order bonus exists.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionalRestrictions rdf:type rdf:Property ;
    rdfs:label 'Regional Restrictions' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where this product is explicitly blocked or restricted from sale due to regulatory or licensing constraints.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionModel rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Model' ;
    rdfs:comment 'Accounting treatment model for revenue recognition per ASC 606 / IFRS 15 standards.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionBillingCycle rdf:type rdf:Property ;
    rdfs:label 'Subscription Billing Cycle' ;
    rdfs:comment 'Recurring billing frequency for subscription products. Null for non-subscription products.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialAvailable rdf:type rdf:Property ;
    rdfs:label 'Trial Available' ;
    rdfs:comment 'Indicates whether a free trial or demo version is available for this product.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Authorization Timestamp' ;
    rdfs:comment 'The date and time when the payment was authorized by the payment processor or issuing bank.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:chargebackReasonCode rdf:type rdf:Property ;
    rdfs:label 'Chargeback Reason Code' ;
    rdfs:comment 'The reason code provided by the card network or issuing bank for a chargeback dispute.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declineReason rdf:type rdf:Property ;
    rdfs:label 'Decline Reason' ;
    rdfs:comment 'The reason provided by the payment processor or issuing bank if the transaction was declined or failed.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderId rdf:type rdf:Property ;
    rdfs:label 'Order Id' ;
    rdfs:comment 'Identifier of the order that generated this transaction.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentMethodId rdf:type rdf:Property ;
    rdfs:label 'Payment Method Id' ;
    rdfs:comment 'Identifier of the payment instrument used for this transaction (credit card, PayPal, digital wallet, platform wallet).' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentProcessingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Processing Fee Amount' ;
    rdfs:comment 'The fee charged by the payment processor or gateway for processing the transaction.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentProcessorTransactionId rdf:type rdf:Property ;
    rdfs:label 'Payment Processor Transaction Id' ;
    rdfs:comment 'The unique transaction identifier assigned by the external payment processor or gateway for reconciliation purposes.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payoutBatchId rdf:type rdf:Property ;
    rdfs:label 'Payout Batch Id' ;
    rdfs:comment 'Identifier of the payout batch in which this transaction was settled with the platform holder or payment processor.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playerId rdf:type rdf:Property ;
    rdfs:label 'Player Id' ;
    rdfs:comment 'Identifier of the player who initiated or is associated with this transaction.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:settlementCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the currency in which funds were settled to the merchant account.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageAnnualEvents rdf:type rdf:Property ;
    rdfs:label 'Average Annual Events' ;
    rdfs:comment 'Average number of esports events or tournaments organized per year, used for capacity and performance assessment.' ;
    rdfs:domain ind:Organizer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Status' ;
    rdfs:comment 'Status of the organizer\'s compliance with industry standards, regulatory requirements, or internal certification programs.' ;
    rdfs:domain ind:Organizer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverage rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage' ;
    rdfs:comment 'Geographic scope of the organizer\'s tournament and event operations.' ;
    rdfs:domain ind:Organizer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCoverageAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Amount Usd' ;
    rdfs:comment 'Total insurance coverage amount in USD that the organizer maintains for event liability, cancellation, and other risks.' ;
    rdfs:domain ind:Organizer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Expiry Date' ;
    rdfs:comment 'Expiration date of the organizer\'s current insurance policy coverage.' ;
    rdfs:domain ind:Organizer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Due Date' ;
    rdfs:comment 'Scheduled date for the next compliance, financial, or operational audit of the organizer.' ;
    rdfs:domain ind:Organizer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:organizerCode rdf:type rdf:Property ;
    rdfs:label 'Organizer Code' ;
    rdfs:comment 'Unique business identifier or code assigned to the organizer for external reference and integration purposes.' ;
    rdfs:domain ind:Organizer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialMediaFollowersCount rdf:type rdf:Property ;
    rdfs:label 'Social Media Followers Count' ;
    rdfs:comment 'Total number of followers across the organizer\'s primary social media platforms, used as a measure of reach and influence.' ;
    rdfs:domain ind:Organizer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:socialMediaTwitterHandle rdf:type rdf:Property ;
    rdfs:label 'Social Media Twitter Handle' ;
    rdfs:comment 'Official Twitter/X handle of the organizer for social media engagement and communication.' ;
    rdfs:domain ind:Organizer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorshipManagement rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Management' ;
    rdfs:comment 'Indicates whether the organizer manages sponsorship agreements and activations for their events (true) or if sponsorships are managed by the business (false).' ;
    rdfs:domain ind:Organizer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalPrizePoolDistributedUsd rdf:type rdf:Property ;
    rdfs:label 'Total Prize Pool Distributed Usd' ;
    rdfs:comment 'Cumulative total prize pool amount in USD that the organizer has distributed across all tournaments and events to date.' ;
    rdfs:domain ind:Organizer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessUnitType rdf:type rdf:Property ;
    rdfs:label 'Business Unit Type' ;
    rdfs:comment 'Classification of the business unit by its primary function within the gaming enterprise (studio for game development, publishing for distribution, platform for online services, esports for competitive gaming, technology for engine/tools, corporate for headquarters, shared services for support functions).' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationUnitCode rdf:type rdf:Property ;
    rdfs:label 'Consolidation Unit Code' ;
    rdfs:comment 'Code identifying the financial consolidation unit or reporting segment to which this business unit rolls up for statutory and management reporting.' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishmentDate rdf:type rdf:Property ;
    rdfs:label 'Establishment Date' ;
    rdfs:comment 'Date when the business unit was formally established or incorporated, used for historical tracking and anniversary reporting.' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalReportingSegment rdf:type rdf:Property ;
    rdfs:label 'External Reporting Segment' ;
    rdfs:comment 'Segment classification for external financial reporting and investor disclosures per IFRS 8 or ASC 280 operating segment requirements.' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financeContactEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Finance Contact Employee Id' ;
    rdfs:comment 'Reference to the finance business partner or controller responsible for financial reporting and analysis for this business unit.' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headcountPlanned rdf:type rdf:Property ;
    rdfs:label 'Headcount Planned' ;
    rdfs:comment 'Approved full-time equivalent (FTE) headcount allocation for the business unit, used for workforce planning and cost modeling.' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:intercompanyBillingEnabled rdf:type rdf:Property ;
    rdfs:label 'Intercompany Billing Enabled' ;
    rdfs:comment 'Flag indicating whether the business unit participates in intercompany billing and transfer pricing arrangements with other business units.' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCostCenterOnly rdf:type rdf:Property ;
    rdfs:label 'Is Cost Center Only' ;
    rdfs:comment 'Flag indicating whether the business unit operates purely as a cost center without profit/loss accountability (true for support functions, false for P&L-responsible units).' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRevenueGenerating rdf:type rdf:Property ;
    rdfs:label 'Is Revenue Generating' ;
    rdfs:comment 'Flag indicating whether the business unit directly generates external revenue (true for studios, publishing, platforms; false for corporate, shared services).' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedByUserId rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User Id' ;
    rdfs:comment 'User identifier of the person who last modified the business unit record, supporting audit and governance requirements.' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentBusinessUnitId rdf:type rdf:Property ;
    rdfs:label 'Parent Business Unit Id' ;
    rdfs:comment 'Reference to the parent business unit in the organizational hierarchy, enabling multi-level business unit structures (e.g., regional studio reporting to global studio division). Null for top-level units.' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:royaltyAccrualRequired rdf:type rdf:Property ;
    rdfs:label 'Royalty Accrual Required' ;
    rdfs:comment 'Flag indicating whether the business unit must accrue royalty expenses for third-party IP, talent, or platform fees in its financial reporting.' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:problemId rdf:type rdf:Property ;
    rdfs:label 'Problem Id' ;
    rdfs:comment 'Primary key for problem' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedRegion rdf:type rdf:Property ;
    rdfs:label 'Affected Region' ;
    rdfs:comment 'Geographic region or data center location affected by the problem. Uses 3-letter region codes (e.g., USE, EUW, APS).' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedService rdf:type rdf:Property ;
    rdfs:label 'Affected Service' ;
    rdfs:comment 'Name of the game service or infrastructure component affected by this problem. Examples: matchmaking, authentication, CDN, game servers.' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detected Timestamp' ;
    rdfs:comment 'Date and time when the problem was first detected or identified. Used for timeline analysis and response time measurement.' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downtimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Downtime Minutes' ;
    rdfs:comment 'Total service downtime in minutes caused by this problem. Used for SLA tracking and availability reporting.' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:investigationStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Investigation Started Timestamp' ;
    rdfs:comment 'Date and time when formal investigation of the problem began. Used to track time-to-investigation metrics.' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isKnownError rdf:type rdf:Property ;
    rdfs:label 'Is Known Error' ;
    rdfs:comment 'Flag indicating whether this problem has been classified as a known error with documented workaround. True when root cause is identified but permanent fix is pending.' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permanentSolution rdf:type rdf:Property ;
    rdfs:label 'Permanent Solution' ;
    rdfs:comment 'Description of the permanent fix or solution implemented to resolve the problem. Documents the final resolution approach.' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerImpactCount rdf:type rdf:Property ;
    rdfs:label 'Player Impact Count' ;
    rdfs:comment 'Estimated number of players affected by this problem. Critical metric for prioritization and business impact assessment.' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:problemNumber rdf:type rdf:Property ;
    rdfs:label 'Problem Number' ;
    rdfs:comment 'Human-readable unique problem ticket number used for external reference and tracking. Format: PRB-YYYYMMDD.' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:problemType rdf:type rdf:Property ;
    rdfs:label 'Problem Type' ;
    rdfs:comment 'Classification of the problem by technical domain. Used for routing to appropriate engineering teams and trend analysis.' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Identified root cause of the problem after investigation. Documents the underlying technical or process issue causing incidents.' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseIdentifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Root Cause Identified Timestamp' ;
    rdfs:comment 'Date and time when the root cause was successfully identified. Used to measure investigation effectiveness and time-to-diagnosis.' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:workaround rdf:type rdf:Property ;
    rdfs:label 'Workaround' ;
    rdfs:comment 'Temporary workaround or mitigation steps to reduce impact while permanent fix is developed. Used for known error management.' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bandwidthMbps rdf:type rdf:Property ;
    rdfs:label 'Bandwidth Mbps' ;
    rdfs:comment 'Network bandwidth capacity allocated to the configuration item, measured in megabits per second.' ;
    rdfs:domain ind:ConfigurationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityCcu rdf:type rdf:Property ;
    rdfs:label 'Capacity Ccu' ;
    rdfs:comment 'Maximum number of concurrent users (CCU) that the configuration item can support simultaneously.' ;
    rdfs:domain ind:ConfigurationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityPcu rdf:type rdf:Property ;
    rdfs:label 'Capacity Pcu' ;
    rdfs:comment 'Peak concurrent users (PCU) capacity threshold for the configuration item, representing maximum load handling capability.' ;
    rdfs:domain ind:ConfigurationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ciCategory rdf:type rdf:Property ;
    rdfs:label 'Ci Category' ;
    rdfs:comment 'High-level category grouping for the configuration item (hardware, software, network, service, virtual, cloud).' ;
    rdfs:domain ind:ConfigurationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ciCode rdf:type rdf:Property ;
    rdfs:label 'Ci Code' ;
    rdfs:comment 'Externally-known unique code or identifier for the configuration item, used for cross-system reference and asset tracking.' ;
    rdfs:domain ind:ConfigurationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ciName rdf:type rdf:Property ;
    rdfs:label 'Ci Name' ;
    rdfs:comment 'Human-readable name or label for the configuration item, used for identification and display purposes.' ;
    rdfs:domain ind:ConfigurationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ciStatus rdf:type rdf:Property ;
    rdfs:label 'Ci Status' ;
    rdfs:comment 'Current lifecycle status of the configuration item indicating its operational state (active, inactive, maintenance, decommissioned, provisioning, failed).' ;
    rdfs:domain ind:ConfigurationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ciType rdf:type rdf:Property ;
    rdfs:label 'Ci Type' ;
    rdfs:comment 'Classification of the configuration item by its functional role in the infrastructure (e.g., game server, matchmaking service, CDN node, load balancer, database instance, cache cluster, message queue). [ENUM-REF-CANDIDATE: game_server|matchmaking_service|cdn_node|load_balancer|database_instance|cache_cluster|message_queue|api_gateway|authentication_service|storage_service|monitoring_agent|backup_service|firewall|network_switch|container_orchestrator — promote to reference product]' ;
    rdfs:domain ind:ConfigurationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerHourUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Per Hour Usd' ;
    rdfs:comment 'Hourly operational cost for running this configuration item, measured in US dollars.' ;
    rdfs:domain ind:ConfigurationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:highAvailabilityEnabled rdf:type rdf:Property ;
    rdfs:label 'High Availability Enabled' ;
    rdfs:comment 'Indicates whether high availability configuration is enabled for this configuration item to ensure redundancy and failover capability.' ;
    rdfs:domain ind:ConfigurationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMaintenanceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Timestamp' ;
    rdfs:comment 'Timestamp of the most recent maintenance activity performed on the configuration item.' ;
    rdfs:domain ind:ConfigurationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:patchLevel rdf:type rdf:Property ;
    rdfs:label 'Patch Level' ;
    rdfs:comment 'Current patch level or update version applied to the configuration item for security and maintenance.' ;
    rdfs:domain ind:ConfigurationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaFpsTarget rdf:type rdf:Property ;
    rdfs:label 'Sla Fps Target' ;
    rdfs:comment 'Target frames per second (FPS) performance metric defined in the service level agreement for game server configuration items.' ;
    rdfs:domain ind:ConfigurationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaLatencyTargetMs rdf:type rdf:Property ;
    rdfs:label 'Sla Latency Target Ms' ;
    rdfs:comment 'Target maximum latency in milliseconds defined in the service level agreement for this configuration item.' ;
    rdfs:domain ind:ConfigurationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaUptimeTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Sla Uptime Target Percent' ;
    rdfs:comment 'Target uptime percentage defined in the service level agreement for this configuration item (e.g., 99.95%).' ;
    rdfs:domain ind:ConfigurationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:softwareVersion rdf:type rdf:Property ;
    rdfs:label 'Software Version' ;
    rdfs:comment 'Version number of the primary software or application running on the configuration item.' ;
    rdfs:domain ind:ConfigurationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportTier rdf:type rdf:Property ;
    rdfs:label 'Support Tier' ;
    rdfs:comment 'Support tier level assigned to the configuration item indicating priority and escalation path (tier 1, tier 2, tier 3, critical, standard).' ;
    rdfs:domain ind:ConfigurationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertSuppressionRuleId rdf:type rdf:Property ;
    rdfs:label 'Alert Suppression Rule Id' ;
    rdfs:comment 'Primary key for alert_suppression_rule' ;
    rdfs:domain ind:AlertSuppressionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activationCount rdf:type rdf:Property ;
    rdfs:label 'Activation Count' ;
    rdfs:comment 'Number of times this suppression rule has been triggered and activated since creation.' ;
    rdfs:domain ind:AlertSuppressionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alertCategory rdf:type rdf:Property ;
    rdfs:label 'Alert Category' ;
    rdfs:comment 'Category of alerts targeted by this suppression rule, such as performance, availability, security, or capacity alerts.' ;
    rdfs:domain ind:AlertSuppressionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertSeverityFilter rdf:type rdf:Property ;
    rdfs:label 'Alert Severity Filter' ;
    rdfs:comment 'Minimum severity level of alerts that this suppression rule will affect. Alerts below this severity are not suppressed.' ;
    rdfs:domain ind:AlertSuppressionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByUserId rdf:type rdf:Property ;
    rdfs:label 'Approved By User Id' ;
    rdfs:comment 'Identifier of the user who approved this suppression rule for activation, if approval workflow is required.' ;
    rdfs:domain ind:AlertSuppressionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Flag' ;
    rdfs:comment 'Indicates whether suppressed alerts are logged for audit and compliance purposes even when not displayed.' ;
    rdfs:domain ind:AlertSuppressionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoExpireFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Expire Flag' ;
    rdfs:comment 'Indicates whether the suppression rule automatically expires after its effective end timestamp or requires manual deactivation.' ;
    rdfs:domain ind:AlertSuppressionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conditionExpression rdf:type rdf:Property ;
    rdfs:label 'Condition Expression' ;
    rdfs:comment 'Logical expression or criteria that must be met for the suppression rule to activate and suppress matching alerts.' ;
    rdfs:domain ind:AlertSuppressionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUserId rdf:type rdf:Property ;
    rdfs:label 'Created By User Id' ;
    rdfs:comment 'Identifier of the user or system account that created this suppression rule.' ;
    rdfs:domain ind:AlertSuppressionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective End Timestamp' ;
    rdfs:comment 'Date and time when this suppression rule expires and stops suppressing alerts. Null indicates indefinite duration.' ;
    rdfs:domain ind:AlertSuppressionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:effectiveStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Start Timestamp' ;
    rdfs:comment 'Date and time when this suppression rule becomes active and begins suppressing alerts.' ;
    rdfs:domain ind:AlertSuppressionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:escalationBypassFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Bypass Flag' ;
    rdfs:comment 'Indicates whether suppressed alerts bypass normal escalation workflows and incident management processes.' ;
    rdfs:domain ind:AlertSuppressionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incidentReferenceId rdf:type rdf:Property ;
    rdfs:label 'Incident Reference Id' ;
    rdfs:comment 'Reference identifier to the incident or change request that prompted the creation of this suppression rule.' ;
    rdfs:domain ind:AlertSuppressionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastActivationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Activation Timestamp' ;
    rdfs:comment 'Date and time when this suppression rule was most recently triggered and activated.' ;
    rdfs:domain ind:AlertSuppressionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:modifiedByUserId rdf:type rdf:Property ;
    rdfs:label 'Modified By User Id' ;
    rdfs:comment 'Identifier of the user or system account that last modified this suppression rule.' ;
    rdfs:domain ind:AlertSuppressionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Override Flag' ;
    rdfs:comment 'Indicates whether this suppression rule also prevents notification delivery or only suppresses alert visibility.' ;
    rdfs:domain ind:AlertSuppressionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suppressedAlertCount rdf:type rdf:Property ;
    rdfs:label 'Suppressed Alert Count' ;
    rdfs:comment 'Total number of alerts that have been suppressed by this rule since creation.' ;
    rdfs:domain ind:AlertSuppressionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:suppressionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Suppression Duration Minutes' ;
    rdfs:comment 'Duration in minutes for which alerts will be suppressed once the rule is triggered.' ;
    rdfs:domain ind:AlertSuppressionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetRegionCode rdf:type rdf:Property ;
    rdfs:label 'Target Region Code' ;
    rdfs:comment 'Geographic region or datacenter location code where the suppression rule applies.' ;
    rdfs:domain ind:AlertSuppressionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetServiceName rdf:type rdf:Property ;
    rdfs:label 'Target Service Name' ;
    rdfs:comment 'Name of the specific game service or infrastructure component to which this suppression rule applies.' ;
    rdfs:domain ind:AlertSuppressionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleItemCount rdf:type rdf:Property ;
    rdfs:label 'Bundle Item Count' ;
    rdfs:comment 'Number of distinct items or rewards included in the bundle (null for non-bundle items).' ;
