    rdfs:comment 'Indicates whether teams are permitted to sign free agent players (not currently under contract) during this window.' ;
    rdfs:domain ind:TransferWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allowsLoans rdf:type rdf:Property ;
    rdfs:label 'Allows Loans' ;
    rdfs:comment 'Indicates whether teams are permitted to loan players to other teams temporarily during this window.' ;
    rdfs:domain ind:TransferWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allowsReleases rdf:type rdf:Property ;
    rdfs:label 'Allows Releases' ;
    rdfs:comment 'Indicates whether teams are permitted to release players from their contracts during this window.' ;
    rdfs:domain ind:TransferWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allowsTrades rdf:type rdf:Property ;
    rdfs:label 'Allows Trades' ;
    rdfs:comment 'Indicates whether teams are permitted to trade players with other teams during this window.' ;
    rdfs:domain ind:TransferWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalDeadlineHours rdf:type rdf:Property ;
    rdfs:label 'Approval Deadline Hours' ;
    rdfs:comment 'Number of hours before window close by which transfer requests must be submitted for league approval consideration.' ;
    rdfs:domain ind:TransferWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closeDate rdf:type rdf:Property ;
    rdfs:label 'Close Date' ;
    rdfs:comment 'Date when the transfer window officially closes and no further roster changes are permitted.' ;
    rdfs:domain ind:TransferWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Close Timestamp' ;
    rdfs:comment 'Precise timestamp when the transfer window closes, including time zone information for global coordination.' ;
    rdfs:domain ind:TransferWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:emergencyExtensionAllowed rdf:type rdf:Property ;
    rdfs:label 'Emergency Extension Allowed' ;
    rdfs:comment 'Indicates whether the league commissioner can grant emergency extensions to the window close time under exceptional circumstances.' ;
    rdfs:domain ind:TransferWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxRosterSize rdf:type rdf:Property ;
    rdfs:label 'Max Roster Size' ;
    rdfs:comment 'Maximum number of players each team is allowed to have on their roster after transfers are completed.' ;
    rdfs:domain ind:TransferWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxTransfersPerTeam rdf:type rdf:Property ;
    rdfs:label 'Max Transfers Per Team' ;
    rdfs:comment 'Maximum number of player transfers a single team is permitted to execute during this window.' ;
    rdfs:domain ind:TransferWindow ;
    rdf:type owl:DatatypeProperty ;
