    rdfs:comment 'Indicates whether teams must pay transfer fees to acquire players from other teams during this window.' ;
    rdfs:domain ind:TransferWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:windowType rdf:type rdf:Property ;
    rdfs:label 'Window Type' ;
