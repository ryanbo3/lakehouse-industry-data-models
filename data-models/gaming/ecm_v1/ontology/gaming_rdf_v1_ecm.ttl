    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventId rdf:type rdf:Property ;
    rdfs:label 'Event Id' ;
    rdfs:comment 'Identifier of the special in-game event associated with this item (e.g., Halloween_2024, Winter_Festival).' ;
    rdfs:domain ind:StorefrontItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imageUrl rdf:type rdf:Property ;
    rdfs:label 'Image Url' ;
    rdfs:comment 'URL path to the primary promotional image or icon asset for the storefront item.' ;
    rdfs:domain ind:StorefrontItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBundle rdf:type rdf:Property ;
