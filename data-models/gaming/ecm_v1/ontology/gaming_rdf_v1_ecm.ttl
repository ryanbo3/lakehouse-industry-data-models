# --- Attribute Properties ---
ind:abExperimentId rdf:type rdf:Property ;
    rdfs:label 'Ab Experiment Id' ;
    rdfs:comment 'Unique identifier for the A/B or multivariate experiment. Primary key for the experiment record.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AbExperiment .

ind:devProjectId rdf:type rdf:Property ;
    rdfs:label 'Dev Project Id' ;
    rdfs:comment 'Foreign key linking to studio.dev_project. Business justification: A/B experiments are planned, resourced, and tracked as part of development projects, especially for GaaS titles. Links experiment design to project roadmaps, sprint planning, and milestone delivery. E' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DevProject .

ind:forumId rdf:type rdf:Property ;
    rdfs:label 'Forum Id' ;
    rdfs:comment 'Foreign key linking to community.forum. Business justification: A/B tests frequently target specific forums for UI changes, feature rollouts, or moderation policy tests. Real experimentation pattern for community feature optimization and engagement improvement ini' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Forum .

ind:gameModeId rdf:type rdf:Property ;
    rdfs:label 'Game Mode Id' ;
    rdfs:comment 'Foreign key linking to title.game_mode. Business justification: Experiments frequently target specific game modes (matchmaking algorithm changes in ranked, weapon balance in battle royale, tutorial flow in campaign). Mode-scoped experiments are standard practice f' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GameMode .

ind:gameTitleId rdf:type rdf:Property ;
    rdfs:label 'Game Title Id' ;
    rdfs:comment 'Reference to the game title for which this experiment is being conducted. Links to the game title master data.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GameTitle .

ind:leagueId rdf:type rdf:Property ;
    rdfs:label 'League Id' ;
    rdfs:comment 'Foreign key linking to esports.league. Business justification: Gaming studios run A/B experiments during major esports leagues to test new features with highly-engaged competitive audiences. Product teams need to track which league context an experiment ran in fo' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:League .

ind:licenseeId rdf:type rdf:Property ;
    rdfs:label 'Licensee Id' ;
    rdfs:comment 'Foreign key linking to licensing.licensee. Business justification: Experiments may be run by or for specific licensees (e.g., platform-exclusive features, licensee-specific content tests). Tracks which licensee\'s content is being tested for performance reporting and ' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Licensee .

ind:ownerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Experiments are owned by product managers, game designers, or data scientists for approval workflow, results review, and rollout decisions. Business process: experiment governance, performance account' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:platformSkuId rdf:type rdf:Property ;
    rdfs:label 'Platform Sku Id' ;
    rdfs:comment 'Foreign key linking to platform.platform_sku. Business justification: Experiments often target specific SKUs/editions (e.g., testing premium features only for Deluxe Edition owners, or measuring Standard-to-Deluxe upgrade conversion). Essential for edition-specific feat' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlatformSku .

ind:policyId rdf:type rdf:Property ;
    rdfs:label 'Policy Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_policy. Business justification: Experiments must comply with internal policies (e.g., \'no A/B testing loot box odds without disclosure\', \'no targeting minors with monetization\'). Experiment review board checks policy adherence befor' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:primaryKpiDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Primary Kpi Definition Id' ;
    rdfs:comment 'Foreign key linking to analytics.kpi_definition. Business justification: ab_experiment defines one primary success metric for statistical analysis. Each experiment has one primary KPI. Adding primary_kpi_definition_id FK normalizes the primary metric reference, ensuring ex' ;
    rdfs:domain ind:AbExperiment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KpiDefinition .

ind:privacyImpactAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Privacy Impact Assessment Id' ;
    rdfs:comment 'Foreign key linking to compliance.privacy_impact_assessment. Business justification: Experiments involving new data collection, profiling, or targeting require PIAs under GDPR Article 35 for high-risk processing. Experiment approval workflow includes PIA review by DPO before launch, e' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrivacyImpactAssessment .

ind:regulatoryObligationId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_obligation. Business justification: Experiments testing monetization mechanics (loot boxes, pricing) must document compliance with applicable regulations (e.g., loot box disclosure laws, consumer protection). Required for experiment app' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryObligation .

ind:seasonalEventId rdf:type rdf:Property ;
    rdfs:label 'Seasonal Event Id' ;
    rdfs:comment 'Foreign key linking to content.seasonal_event. Business justification: Experiments run during seasonal events to test event mechanics, reward structures, participation incentives, and event-specific content. Links experiment results to event performance analysis and futu' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SeasonalEvent .

ind:testedAssetId rdf:type rdf:Property ;
    rdfs:label 'Tested Asset Id' ;
    rdfs:comment 'Foreign key linking to content.asset. Business justification: Experiments test asset variants (weapon balance changes, cosmetic appeal, map layout iterations). Experiment definitions must reference the asset being tested for results attribution and variant track' ;
    rdfs:domain ind:AbExperiment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'The actual date when the experiment concluded or was terminated, which may differ from the planned end date.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualSampleSize rdf:type rdf:Property ;
    rdfs:label 'Actual Sample Size' ;
    rdfs:comment 'Actual number of players who participated in the experiment, used to compare against the required sample size.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessObjective rdf:type rdf:Property ;
    rdfs:label 'Business Objective' ;
    rdfs:comment 'High-level business goal the experiment aims to achieve, such as increasing player retention, improving monetization, or enhancing player engagement.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceLevelPct rdf:type rdf:Property ;
    rdfs:label 'Confidence Level Pct' ;
    rdfs:comment 'Statistical confidence level for the experiment, typically 90%, 95%, or 99%, representing the probability that results are not due to chance.' ;
    rdfs:domain ind:AbExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlGroupDefinition rdf:type rdf:Property ;
    rdfs:label 'Control Group Definition' ;
    rdfs:comment 'Description of the control group configuration, including the baseline experience or default settings against which treatment arms are compared.' ;
    rdfs:domain ind:AbExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Timestamp when the experiment record was first created in the system.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:effectSize rdf:type rdf:Property ;
    rdfs:label 'Effect Size' ;
    rdfs:comment 'Measured effect size of the winning variant compared to control, expressed as a percentage lift or absolute difference in the primary success metric.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:experimentCode rdf:type rdf:Property ;
    rdfs:label 'Experiment Code' ;
    rdfs:comment 'Unique business identifier or code for the experiment, often used in technical implementations and SDK integrations.' ;
    rdfs:domain ind:AbExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentName rdf:type rdf:Property ;
    rdfs:label 'Experiment Name' ;
    rdfs:comment 'Human-readable name of the experiment, used for identification and reporting purposes.' ;
    rdfs:domain ind:AbExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentStatus rdf:type rdf:Property ;
    rdfs:label 'Experiment Status' ;
    rdfs:comment 'Current lifecycle status of the experiment: draft (being designed), running (actively collecting data), paused (temporarily stopped), concluded (completed with results), or cancelled (terminated without completion).' ;
    rdfs:domain ind:AbExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentType rdf:type rdf:Property ;
    rdfs:label 'Experiment Type' ;
    rdfs:comment 'Category of experiment being conducted, such as feature flag, game balance adjustment, monetization offer, UI variant, matchmaking parameter tuning, or content test.' ;
    rdfs:domain ind:AbExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardrailMetrics rdf:type rdf:Property ;
    rdfs:label 'Guardrail Metrics' ;
    rdfs:comment 'List of secondary metrics monitored to ensure the experiment does not negatively impact other important KPIs, such as churn rate, session crashes, or player satisfaction.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hypothesis rdf:type rdf:Property ;
    rdfs:label 'Hypothesis' ;
    rdfs:comment 'The hypothesis being tested by this experiment, describing the expected outcome and rationale.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isStatisticallySignificant rdf:type rdf:Property ;
    rdfs:label 'Is Statistically Significant' ;
    rdfs:comment 'Boolean flag indicating whether the experiment results achieved statistical significance at the defined confidence level.' ;
    rdfs:domain ind:AbExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumDetectableEffect rdf:type rdf:Property ;
    rdfs:label 'Minimum Detectable Effect' ;
    rdfs:comment 'The smallest effect size that the experiment is designed to detect with statistical significance, expressed as a percentage or absolute value.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Timestamp when the experiment record was last modified or updated.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Additional notes, observations, or context about the experiment, including any anomalies, external factors, or lessons learned.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pValue rdf:type rdf:Property ;
    rdfs:label 'P Value' ;
    rdfs:comment 'Statistical p-value from the hypothesis test, indicating the probability of observing the results if the null hypothesis is true.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:comment 'The originally planned date for experiment conclusion, based on required sample size and traffic allocation.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:platformFilter rdf:type rdf:Property ;
    rdfs:label 'Platform Filter' ;
    rdfs:comment 'Platforms on which the experiment is running, such as iOS, Android, PC, console, or cross-platform. May be a comma-separated list.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:randomizationUnit rdf:type rdf:Property ;
    rdfs:label 'Randomization Unit' ;
    rdfs:comment 'The unit of randomization for experiment assignment, such as player, session, device, or account.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredSampleSize rdf:type rdf:Property ;
    rdfs:label 'Required Sample Size' ;
    rdfs:comment 'Calculated minimum number of players required in the experiment to achieve statistical power and detect the minimum detectable effect.' ;
    rdfs:domain ind:AbExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resultSummary rdf:type rdf:Property ;
    rdfs:label 'Result Summary' ;
    rdfs:comment 'Summary of experiment results, including key findings, statistical significance, and business impact.' ;
    rdfs:domain ind:AbExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rolloutDecision rdf:type rdf:Property ;
    rdfs:label 'Rollout Decision' ;
    rdfs:comment 'Decision on whether to roll out the winning variant to all players: full rollout (100% traffic), partial rollout (gradual increase), no rollout (revert to control), or pending (decision not yet made).' ;
    rdfs:domain ind:AbExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'The date when the experiment began collecting data and exposing players to treatment arms.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statisticalPower rdf:type rdf:Property ;
    rdfs:label 'Statistical Power' ;
    rdfs:comment 'The probability that the experiment will detect an effect if one truly exists, typically set at 80% or higher.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statisticalTestType rdf:type rdf:Property ;
    rdfs:label 'Statistical Test Type' ;
    rdfs:comment 'Type of statistical test used for experiment analysis, such as t-test, Mann-Whitney U test, chi-square test, CUPED (Controlled-experiment Using Pre-Experiment Data), or Bayesian analysis.' ;
    rdfs:domain ind:AbExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSegment rdf:type rdf:Property ;
    rdfs:label 'Target Segment' ;
    rdfs:comment 'Definition of the player segment targeted for this experiment, such as new players, high-value players, specific geographic regions, or behavioral cohorts.' ;
    rdfs:domain ind:AbExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficAllocationPct rdf:type rdf:Property ;
    rdfs:label 'Traffic Allocation Pct' ;
    rdfs:comment 'Percentage of eligible players allocated to this experiment, ranging from 0.00 to 100.00.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentArmCount rdf:type rdf:Property ;
    rdfs:label 'Treatment Arm Count' ;
    rdfs:comment 'Number of treatment arms (variants) in the experiment, excluding the control group.' ;
    rdfs:domain ind:AbExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:treatmentArmsDefinition rdf:type rdf:Property ;
    rdfs:label 'Treatment Arms Definition' ;
    rdfs:comment 'Description of all treatment arm configurations, including the variations being tested and their respective settings or parameters.' ;
    rdfs:domain ind:AbExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winningVariant rdf:type rdf:Property ;
    rdfs:label 'Winning Variant' ;
    rdfs:comment 'Identifier of the treatment arm or control group that was determined to be the winner based on the primary success metric, if the experiment has concluded.' ;
    rdfs:domain ind:AbExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:behaviorSegmentMembershipId rdf:type rdf:Property ;
    rdfs:label 'Behavior Segment Membership Id' ;
    rdfs:comment 'Unique identifier for the behavior segment membership record. Primary key for tracking player-to-segment associations over time.' ;
    rdfs:domain ind:BehaviorSegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:guildId rdf:type rdf:Property ;
    rdfs:label 'Guild Id' ;
    rdfs:comment 'Foreign key linking to community.guild. Business justification: Guild membership influences behavioral segmentation (guild-focused players vs solo). Real segmentation dimension for retention modeling and social feature targeting in multiplayer games.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Guild .

ind:playerAccountId rdf:type rdf:Property ;
    rdfs:label 'Player Account Id' ;
    rdfs:comment 'Reference to the player who is assigned to this behavioral segment. Links to the player master entity.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerAccount .

ind:primaryPlayerBehaviorSegmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Player Behavior Segment Id' ;
    rdfs:comment 'Reference to the behavioral segment definition that this player is assigned to. Links to the segment taxonomy maintained by analytics.' ;
    rdfs:domain ind:BehaviorSegmentMembership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerBehaviorSegment .

ind:storefrontId rdf:type rdf:Property ;
    rdfs:label 'Storefront Id' ;
    rdfs:comment 'Reference to the gaming platform (console, PC, mobile) where this behavioral segment membership was observed. Enables platform-specific segmentation and cross-platform behavior tracking.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Storefront .

ind:subscriptionId rdf:type rdf:Property ;
    rdfs:label 'Subscription Id' ;
    rdfs:comment 'Foreign key linking to billing.subscription. Business justification: Subscription tier and engagement segments need direct links to subscription records for targeted retention campaigns, upgrade offers, and churn prevention interventions.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subscription .

ind:assignmentBatchCode rdf:type rdf:Property ;
    rdfs:label 'Assignment Batch Code' ;
    rdfs:comment 'Identifier for the batch or job run that created this segment assignment. Enables grouping of assignments from the same processing cycle for quality control and rollback scenarios.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assignment Method' ;
    rdfs:comment 'The mechanism used to assign the player to this segment. Rule-based uses predefined business logic, ML model uses machine learning predictions, manual is analyst-driven, hybrid combines multiple methods, cohort import is bulk assignment, and API is external system integration.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentReason rdf:type rdf:Property ;
    rdfs:label 'Assignment Reason' ;
    rdfs:comment 'Human-readable explanation or business justification for why the player was assigned to this segment. May include rule criteria met, model features that triggered assignment, or analyst notes for manual assignments.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Assignment Source System' ;
    rdfs:comment 'The system or platform that generated this segment assignment. Examples include GameAnalytics, Amplitude, internal ML pipeline, or manual analyst tools. Used for data lineage and troubleshooting.' ;
    rdfs:domain ind:BehaviorSegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Timestamp' ;
    rdfs:comment 'The precise date and time when the player was assigned to this behavioral segment. Represents the business event time of segment assignment.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confidenceValue rdf:type rdf:Property ;
    rdfs:label 'Confidence Value' ;
    rdfs:comment 'Statistical confidence level of the segment assignment, typically expressed as a probability between 0.0 and 1.0. Used for quality control and filtering low-confidence assignments in downstream analytics.' ;
    rdfs:domain ind:BehaviorSegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Flag' ;
    rdfs:comment 'Indicator of the data quality or reliability of this segment assignment. Valid means high confidence, suspect indicates potential issues, incomplete means missing input data, stale means outdated, anomaly indicates statistical outlier.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiry Timestamp' ;
    rdfs:comment 'The date and time when this segment membership expires or is superseded by a new assignment. Null indicates the membership is currently active. Used for temporal segment analysis and cohort tracking.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:featureVectorHash rdf:type rdf:Property ;
    rdfs:label 'Feature Vector Hash' ;
    rdfs:comment 'Hash of the feature vector or input data used to generate this segment assignment. Enables reproducibility checks and detection of data drift in ML-based segmentation.' ;
    rdfs:domain ind:BehaviorSegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Flag indicating whether this segment membership is currently active. True means the player is currently in this segment, False means the membership has expired or been superseded.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimarySegment rdf:type rdf:Property ;
    rdfs:label 'Is Primary Segment' ;
    rdfs:comment 'Flag indicating whether this is the players primary behavioral segment when they belong to multiple segments. True for the highest-priority or most relevant segment, False for secondary segments.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRecalculationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Recalculation Timestamp' ;
    rdfs:comment 'The most recent date and time when this segment membership was re-evaluated, regardless of whether the assignment changed. Used to track data freshness and identify stale assignments.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:migrationCount rdf:type rdf:Property ;
    rdfs:label 'Migration Count' ;
    rdfs:comment 'The number of times this player has moved between behavioral segments. Used to identify players with unstable or evolving behavior patterns and to measure segment churn.' ;
    rdfs:domain ind:BehaviorSegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modelVersion rdf:type rdf:Property ;
    rdfs:label 'Model Version' ;
    rdfs:comment 'The version identifier of the machine learning model or rule set used to generate this segment assignment. Enables tracking of model performance and segment drift over time. Null for manual assignments.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRecalculationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Next Recalculation Timestamp' ;
    rdfs:comment 'The scheduled date and time for the next re-evaluation of this segment membership. Used for planning refresh cycles and ensuring timely segment updates.' ;
    rdfs:domain ind:BehaviorSegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:overrideByUser rdf:type rdf:Property ;
    rdfs:label 'Override By User' ;
    rdfs:comment 'Username or identifier of the analyst or business user who performed the manual override. Null if override_flag is False. Used for accountability and audit purposes.' ;
    rdfs:domain ind:BehaviorSegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideFlag rdf:type rdf:Property ;
    rdfs:label 'Override Flag' ;
    rdfs:comment 'Indicates whether this segment assignment was manually overridden by an analyst or business user, superseding the automated assignment logic. Used for audit trails and understanding manual interventions.' ;
    rdfs:domain ind:BehaviorSegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideReason rdf:type rdf:Property ;
    rdfs:label 'Override Reason' ;
    rdfs:comment 'Business justification for why this segment assignment was manually overridden. Null if override_flag is False. Provides context for understanding exceptions to automated segmentation.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recalculationFrequency rdf:type rdf:Property ;
    rdfs:label 'Recalculation Frequency' ;
    rdfs:comment 'The cadence at which this segment membership is re-evaluated and potentially updated. Indicates how fresh the segment assignment is and when the next refresh is expected.' ;
    rdfs:domain ind:BehaviorSegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Geographic region code where the player was located when assigned to this segment. Enables regional behavioral analysis and localized segment strategies. Uses ISO 3166-1 alpha-3 country codes or custom regional groupings.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentEntryDate rdf:type rdf:Property ;
    rdfs:label 'Segment Entry Date' ;
    rdfs:comment 'The calendar date when the player first entered this behavioral segment, used for day-level cohort analysis and retention tracking. Complements assignment_timestamp for date-grain reporting.' ;
    rdfs:domain ind:BehaviorSegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:segmentExitDate rdf:type rdf:Property ;
    rdfs:label 'Segment Exit Date' ;
    rdfs:comment 'The calendar date when the player exited this behavioral segment, either by moving to another segment or becoming inactive. Null for currently active memberships. Used for segment tenure and churn analysis.' ;
    rdfs:domain ind:BehaviorSegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:segmentPriority rdf:type rdf:Property ;
    rdfs:label 'Segment Priority' ;
    rdfs:comment 'Priority ranking when a player qualifies for multiple behavioral segments simultaneously. Lower numbers indicate higher priority. Used to resolve segment conflicts and determine primary segment assignment.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentScore rdf:type rdf:Property ;
    rdfs:label 'Segment Score' ;
    rdfs:comment 'The confidence score or probability value indicating how strongly the player matches this segment profile. Range typically 0.0 to 1.0 for ML models, or custom scoring for rule-based assignments. Higher values indicate stronger segment affinity.' ;
    rdfs:domain ind:BehaviorSegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:segmentStabilityScore rdf:type rdf:Property ;
    rdfs:label 'Segment Stability Score' ;
    rdfs:comment 'Metric indicating how stable or volatile this players segment membership has been over time. Higher scores indicate consistent segment membership, lower scores indicate frequent segment changes. Used for behavioral drift detection.' ;
    rdfs:domain ind:BehaviorSegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenureDays rdf:type rdf:Property ;
    rdfs:label 'Tenure Days' ;
    rdfs:comment 'The number of days the player has been or was a member of this behavioral segment. Calculated as the difference between entry and exit dates, or entry date and current date for active memberships.' ;
    rdfs:domain ind:BehaviorSegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:treatmentVariant rdf:type rdf:Property ;
    rdfs:label 'Treatment Variant' ;
    rdfs:comment 'The specific experiment treatment or variant the player was exposed to that may have influenced their behavioral segment. Null if not part of an experiment. Used for causal analysis of segment drivers.' ;
    rdfs:domain ind:BehaviorSegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'The date and time when this segment membership record was last modified. Used for tracking changes and ensuring data freshness in downstream analytics.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventSchemaId rdf:type rdf:Property ;
    rdfs:label 'Event Schema Id' ;
    rdfs:comment 'Unique identifier for the event schema definition. Primary key for the event schema registry.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EventSchema .

ind:parentSchemaEventSchemaId rdf:type rdf:Property ;
    rdfs:label 'Parent Schema Event Schema Id' ;
    rdfs:comment 'Reference to the previous version of this event schema. Null for the initial version. Enables schema lineage tracking and rollback.' ;
    rdfs:domain ind:EventSchema ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EventSchema .

ind:referenceAssetId rdf:type rdf:Property ;
    rdfs:label 'Reference Asset Id' ;
    rdfs:comment 'Foreign key linking to content.asset. Business justification: Event schemas reference specific assets when defining payload validation rules (e.g., item_equipped schema validates against item asset catalog, map_loaded validates map IDs). Role-prefixed to disting' ;
    rdfs:domain ind:EventSchema ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Timestamp when this event schema was approved for production use. Null for draft schemas. Part of the schema governance workflow.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Username of the data architect or lead engineer who approved this event schema for production deployment. Required for governance compliance.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backwardCompatibleFlag rdf:type rdf:Property ;
    rdfs:label 'Backward Compatible Flag' ;
    rdfs:comment 'Indicates whether this schema version is backward-compatible with the previous version. False indicates breaking changes that require coordinated deployment.' ;
    rdfs:domain ind:EventSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeNotes rdf:type rdf:Property ;
    rdfs:label 'Change Notes' ;
    rdfs:comment 'Free-text description of changes made in this schema version. Documents breaking changes, new fields, deprecated fields, and migration guidance.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compressionEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Compression Enabled Flag' ;
    rdfs:comment 'Indicates whether event payloads of this schema type are compressed during transmission. True reduces bandwidth but increases processing overhead.' ;
    rdfs:domain ind:EventSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deprecationDate rdf:type rdf:Property ;
    rdfs:label 'Deprecation Date' ;
    rdfs:comment 'The date when this event schema was marked as deprecated. After this date, new implementations should not use this schema, but existing usage is still supported.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentationUrl rdf:type rdf:Property ;
    rdfs:label 'Documentation Url' ;
    rdfs:comment 'Link to detailed documentation for this event schema, including field definitions, usage examples, and integration guidelines. Supports self-service analytics.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Encryption Required Flag' ;
    rdfs:comment 'Indicates whether events of this schema type must be encrypted in transit and at rest. True for schemas containing sensitive player data.' ;
    rdfs:domain ind:EventSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:errorRateLast7d rdf:type rdf:Property ;
    rdfs:label 'Error Rate Last 7d' ;
    rdfs:comment 'Decimal fraction (0.0000 to 1.0000) representing the percentage of events of this schema type that failed validation in the last 7 days. High error rates indicate schema or implementation issues.' ;
    rdfs:domain ind:EventSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventCategory rdf:type rdf:Property ;
    rdfs:label 'Event Category' ;
    rdfs:comment 'High-level business classification of the event type. Used for organizing events into analytical domains and routing to specialized processing pipelines. [ENUM-REF-CANDIDATE: player_behavior|monetization|progression|social|technical|performance|engagement|retention — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EventSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventPriority rdf:type rdf:Property ;
    rdfs:label 'Event Priority' ;
    rdfs:comment 'Processing priority level for events of this schema type. Critical events are processed in real-time; low priority events may be batched.' ;
    rdfs:domain ind:EventSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTypeName rdf:type rdf:Property ;
    rdfs:label 'Event Type Name' ;
    rdfs:comment 'The canonical name of the telemetry event type (e.g., player_login, item_purchased, level_completed). Used as the primary identifier for event classification in the analytics pipeline.' ;
    rdfs:domain ind:EventSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examplePayload rdf:type rdf:Property ;
    rdfs:label 'Example Payload' ;
    rdfs:comment 'Sample JSON payload demonstrating a valid event instance of this schema type. Used for developer onboarding and testing.' ;
    rdfs:domain ind:EventSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forwardCompatibleFlag rdf:type rdf:Property ;
    rdfs:label 'Forward Compatible Flag' ;
    rdfs:comment 'Indicates whether older consumers can safely ignore new fields added in this schema version. True enables gradual rollout of schema changes.' ;
    rdfs:domain ind:EventSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ingestionTopic rdf:type rdf:Property ;
    rdfs:label 'Ingestion Topic' ;
    rdfs:comment 'The Kafka topic or message queue name where events of this schema type are published and consumed. Maps schema to the physical ingestion pipeline.' ;
    rdfs:domain ind:EventSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'Username or service account that last modified this event schema record. Used for audit trail and change tracking.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionalFields rdf:type rdf:Property ;
    rdfs:label 'Optional Fields' ;
    rdfs:comment 'Comma-separated list of field names that are optional in event payloads of this type. Provides flexibility for context-specific data capture.' ;
    rdfs:domain ind:EventSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owningTeam rdf:type rdf:Property ;
    rdfs:label 'Owning Team' ;
    rdfs:comment 'Name of the engineering or analytics team responsible for this event schema. Used for accountability and change management routing.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payloadSchemaJson rdf:type rdf:Property ;
    rdfs:label 'Payload Schema Json' ;
    rdfs:comment 'JSON Schema definition of the event payload structure. Defines all fields, data types, constraints, and nested objects for this event type. Used for validation and documentation.' ;
    rdfs:domain ind:EventSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piiFlag rdf:type rdf:Property ;
    rdfs:label 'Pii Flag' ;
    rdfs:comment 'Indicates whether events of this schema type contain personally identifiable information. True triggers additional privacy controls and compliance workflows.' ;
    rdfs:domain ind:EventSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformCompatibility rdf:type rdf:Property ;
    rdfs:label 'Platform Compatibility' ;
    rdfs:comment 'Comma-separated list of platforms where this event schema is supported (e.g., iOS, Android, PC, PlayStation, Xbox, Switch). Enables platform-specific analytics.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredFields rdf:type rdf:Property ;
    rdfs:label 'Required Fields' ;
    rdfs:comment 'Comma-separated list of field names that are mandatory in every event payload of this type. Used for validation and quality checks in the ingestion pipeline.' ;
    rdfs:domain ind:EventSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionDays rdf:type rdf:Property ;
    rdfs:label 'Retention Days' ;
    rdfs:comment 'Number of days that raw events of this schema type are retained in hot storage before archival or deletion. Driven by analytics needs and compliance requirements.' ;
    rdfs:domain ind:EventSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'The date when this event schema will be or was retired from production. After this date, events of this type are no longer processed by the analytics pipeline.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:samplingRate rdf:type rdf:Property ;
    rdfs:label 'Sampling Rate' ;
    rdfs:comment 'Decimal fraction (0.0000 to 1.0000) representing the percentage of events of this type that are captured. 1.0000 means all events are captured; 0.0100 means 1% sampling.' ;
    rdfs:domain ind:EventSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:schemaHash rdf:type rdf:Property ;
    rdfs:label 'Schema Hash' ;
    rdfs:comment 'SHA-256 hash of the payload_schema_json field. Used for fast schema comparison and change detection without parsing full JSON.' ;
    rdfs:domain ind:EventSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemaStatus rdf:type rdf:Property ;
    rdfs:label 'Schema Status' ;
    rdfs:comment 'Current lifecycle status of the event schema. Active schemas are in production use; deprecated schemas are supported but discouraged; retired schemas are no longer processed.' ;
    rdfs:domain ind:EventSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemaVersion rdf:type rdf:Property ;
    rdfs:label 'Schema Version' ;
    rdfs:comment 'Semantic version number of the event schema following semver format (major.minor.patch). Enables schema evolution tracking and backward-compatibility validation.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdkVersionMax rdf:type rdf:Property ;
    rdfs:label 'Sdk Version Max' ;
    rdfs:comment 'Maximum version of the game analytics SDK that supports this event schema type. Null indicates no upper bound. Used for managing schema sunset.' ;
    rdfs:domain ind:EventSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdkVersionMin rdf:type rdf:Property ;
    rdfs:label 'Sdk Version Min' ;
    rdfs:comment 'Minimum version of the game analytics SDK required to emit events of this schema type. Ensures client-side compatibility.' ;
    rdfs:domain ind:EventSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tags rdf:type rdf:Property ;
    rdfs:label 'Tags' ;
    rdfs:comment 'Comma-separated list of custom tags for categorizing and filtering event schemas (e.g., experiment, core_kpi, gdpr_relevant). Supports flexible schema organization.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageCountLast30d rdf:type rdf:Property ;
    rdfs:label 'Usage Count Last 30d' ;
    rdfs:comment 'Total number of events of this schema type received in the last 30 days. Used to identify unused schemas for deprecation and to monitor adoption of new schemas.' ;
    rdfs:domain ind:EventSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationRules rdf:type rdf:Property ;
    rdfs:label 'Validation Rules' ;
    rdfs:comment 'Additional business logic validation rules beyond JSON Schema constraints (e.g., cross-field dependencies, range checks, referential integrity). Applied during ingestion.' ;
    rdfs:domain ind:EventSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'Username or service account that registered this event schema. Used for audit trail and accountability.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Experiment Assignment Id' ;
    rdfs:comment 'Unique identifier for each experiment assignment record. Primary key for the experiment assignment entity.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExperimentAssignment .

ind:drmEntitlementId rdf:type rdf:Property ;
    rdfs:label 'Drm Entitlement Id' ;
    rdfs:comment 'Foreign key linking to platform.drm_entitlement. Business justification: Experiment eligibility depends on entitlement status; assignments must verify player has required DLC/content entitlements before exposing experimental features. Critical for preventing feature leakag' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrmEntitlement .

ind:employeeId rdf:type rdf:Property ;
    rdfs:label 'Employee Id' ;
    rdfs:comment 'Identifier of the internal user who performed the manual override. Null if is_override is false. Used for accountability and audit purposes.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:paymentId rdf:type rdf:Property ;
    rdfs:label 'Payment Id' ;
    rdfs:comment 'Foreign key linking to billing.payment. Business justification: Payment flow experiments (checkout UX, payment method presentation) need direct links to payment outcomes for conversion rate and payment success rate analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payment .

ind:treatmentArmId rdf:type rdf:Property ;
    rdfs:label 'Treatment Arm Id' ;
    rdfs:comment 'Identifier of the specific treatment variant assigned to the player (e.g., CONTROL, VARIANT_A, VARIANT_B). Used to segment cohorts for analysis.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TreatmentArm .

ind:assignmentContext rdf:type rdf:Property ;
    rdfs:label 'Assignment Context' ;
    rdfs:comment 'JSON string capturing additional context at assignment time (e.g., player level, session number, geographic region, device type). Used for stratification analysis and debugging.' ;
    rdfs:domain ind:ExperimentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentHashSeed rdf:type rdf:Property ;
    rdfs:label 'Assignment Hash Seed' ;
    rdfs:comment 'Seed value used in deterministic hash assignment algorithm. Enables reproducibility and validation of assignment logic. Null for non-hash assignment methods.' ;
    rdfs:domain ind:ExperimentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentPriority rdf:type rdf:Property ;
    rdfs:label 'Assignment Priority' ;
    rdfs:comment 'Priority level of this experiment assignment when multiple experiments overlap. Higher values indicate higher priority. Used to resolve experiment conflicts and ensure treatment integrity.' ;
    rdfs:domain ind:ExperimentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentSource rdf:type rdf:Property ;
    rdfs:label 'Assignment Source' ;
    rdfs:comment 'System component that performed the assignment. Client SDK for real-time in-game assignment; server API for backend assignment; batch backfill for historical assignment; manual override for QA testing.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle status of the assignment. Active indicates the player is currently in the experiment; completed indicates the experiment ended; invalidated indicates the assignment was retroactively invalidated; excluded indicates the player was removed from analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bucketingKey rdf:type rdf:Property ;
    rdfs:label 'Bucketing Key' ;
    rdfs:comment 'Identifier used for consistent bucketing across related experiments. Typically player_id but may be device_id or household_id for specific experiment designs.' ;
    rdfs:domain ind:ExperimentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildNumberAtAssignment rdf:type rdf:Property ;
    rdfs:label 'Build Number At Assignment' ;
    rdfs:comment 'Internal build number of the game client at assignment time. Used for precise version tracking and troubleshooting assignment issues.' ;
    rdfs:domain ind:ExperimentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBySystem rdf:type rdf:Property ;
    rdfs:label 'Created By System' ;
    rdfs:comment 'Name of the system or service that created this assignment record (e.g., experiment-service, analytics-pipeline). Used for troubleshooting and data lineage tracking.' ;
    rdfs:domain ind:ExperimentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceTypeAtAssignment rdf:type rdf:Property ;
    rdfs:label 'Device Type At Assignment' ;
    rdfs:comment 'Category of device the player was using at assignment time. Used for device-specific performance analysis and cross-device experiment validation.' ;
    rdfs:domain ind:ExperimentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentLayer rdf:type rdf:Property ;
    rdfs:label 'Experiment Layer' ;
    rdfs:comment 'Logical layer or namespace of the experiment to enable orthogonal experiment execution. Players can be in one experiment per layer simultaneously without interaction effects.' ;
    rdfs:domain ind:ExperimentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureCount rdf:type rdf:Property ;
    rdfs:label 'Exposure Count' ;
    rdfs:comment 'Number of times the player encountered the treatment during the experiment period. Used for dose-response analysis and engagement measurement.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firstExposureTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Exposure Timestamp' ;
    rdfs:comment 'Date and time when the player first encountered the treatment in-game. Null if is_exposed is false. Used to calculate time-to-exposure and actual treatment duration.' ;
    rdfs:domain ind:ExperimentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gameVersionAtAssignment rdf:type rdf:Property ;
    rdfs:label 'Game Version At Assignment' ;
    rdfs:comment 'Semantic version of the game client at the time of assignment (e.g., 2.5.1). Critical for validating that players received the correct treatment implementation.' ;
    rdfs:domain ind:ExperimentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegionAtAssignment rdf:type rdf:Property ;
    rdfs:label 'Geographic Region At Assignment' ;
    rdfs:comment 'Three-letter ISO country code representing the players geographic location at assignment time. Used for region-specific analysis and regulatory compliance validation.' ;
    rdfs:domain ind:ExperimentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ineligibilityReason rdf:type rdf:Property ;
    rdfs:label 'Ineligibility Reason' ;
    rdfs:comment 'Reason code or description explaining why a player was marked ineligible. Null if is_eligible is true. Used for quality control and Sample Ratio Mismatch (SRM) investigation.' ;
    rdfs:domain ind:ExperimentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invalidationReason rdf:type rdf:Property ;
    rdfs:label 'Invalidation Reason' ;
    rdfs:comment 'Explanation for why the assignment was invalidated (e.g., bot detected, data quality issue, implementation bug). Null if not invalidated. Critical for experiment result validity.' ;
    rdfs:domain ind:ExperimentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invalidationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Invalidation Timestamp' ;
    rdfs:comment 'Date and time when the assignment was invalidated. Null if assignment_status is not invalidated. Used for data quality tracking and Sample Ratio Mismatch (SRM) investigation.' ;
    rdfs:domain ind:ExperimentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isEligible rdf:type rdf:Property ;
    rdfs:label 'Is Eligible' ;
    rdfs:comment 'Boolean flag indicating whether the player met all eligibility criteria for the experiment at assignment time. False indicates the player was assigned but later found ineligible (e.g., bot detection, policy violation).' ;
    rdfs:domain ind:ExperimentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isExposed rdf:type rdf:Property ;
    rdfs:label 'Is Exposed' ;
    rdfs:comment 'Boolean flag indicating whether the player actually encountered the treatment (true) or was assigned but never reached the experiment trigger point (false). Critical for intent-to-treat vs per-protocol analysis.' ;
    rdfs:domain ind:ExperimentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHoldout rdf:type rdf:Property ;
    rdfs:label 'Is Holdout' ;
    rdfs:comment 'Boolean flag indicating whether this player is part of a global holdout group excluded from all experiments. Used for long-term cumulative impact measurement.' ;
    rdfs:domain ind:ExperimentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOverride rdf:type rdf:Property ;
    rdfs:label 'Is Override' ;
    rdfs:comment 'Boolean flag indicating whether this assignment was manually overridden (true) or followed standard assignment logic (false). Used to identify QA testing and special case assignments.' ;
    rdfs:domain ind:ExperimentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformAtAssignment rdf:type rdf:Property ;
    rdfs:label 'Platform At Assignment' ;
    rdfs:comment 'Gaming platform the player was using when assigned to the experiment. Critical for platform-specific analysis and cross-platform experiment validation. [ENUM-REF-CANDIDATE: ios|android|windows|macos|playstation|xbox|nintendo_switch|web — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ExperimentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerSegmentAtAssignment rdf:type rdf:Property ;
    rdfs:label 'Player Segment At Assignment' ;
    rdfs:comment 'Player segment classification at the time of assignment (e.g., new_player, returning_player, whale, casual). Used for segment-specific experiment analysis and Sample Ratio Mismatch (SRM) checks.' ;
    rdfs:domain ind:ExperimentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionIdAtAssignment rdf:type rdf:Property ;
    rdfs:label 'Session Id At Assignment' ;
    rdfs:comment 'Unique identifier of the game session during which the assignment occurred. Links to session telemetry for detailed behavioral analysis.' ;
    rdfs:domain ind:ExperimentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Traffic Allocation Percentage' ;
    rdfs:comment 'Percentage of total eligible traffic allocated to this treatment arm at the time of assignment. Used for power analysis and Sample Ratio Mismatch (SRM) validation.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentArmName rdf:type rdf:Property ;
    rdfs:label 'Treatment Arm Name' ;
    rdfs:comment 'Human-readable name of the treatment variant for reporting and analysis (e.g., Increased Reward Rate, New Onboarding Flow).' ;
    rdfs:domain ind:ExperimentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentResultId rdf:type rdf:Property ;
    rdfs:label 'Experiment Result Id' ;
    rdfs:comment 'Unique identifier for the experiment result record. Primary key.' ;
    rdfs:domain ind:ExperimentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approver Employee Id' ;
    rdfs:comment 'Reference to the manager or stakeholder who approved or rejected the analyst decision.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assetId rdf:type rdf:Property ;
    rdfs:label 'Asset Id' ;
    rdfs:comment 'Foreign key linking to content.asset. Business justification: Experiment results track performance metrics for specific asset variants tested (weapon win rate deltas, cosmetic purchase lift, map engagement changes). Essential for asset balance decisions and cont' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:kpiDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Kpi Definition Id' ;
    rdfs:comment 'Foreign key linking to analytics.kpi_definition. Business justification: experiment_result captures statistical outcomes for specific metrics. Each result measures one defined KPI. Adding kpi_definition_id FK normalizes metric definitions, ensuring experiment results refer' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KpiDefinition .

ind:primaryExperimentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Experiment Employee Id' ;
    rdfs:comment 'Reference to the data analyst or data scientist who performed this analysis and made the decision.' ;
    rdfs:domain ind:ExperimentResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:revenueRecognitionId rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Id' ;
    rdfs:comment 'Foreign key linking to billing.revenue_recognition. Business justification: Revenue-focused experiment results must link to revenue recognition events for accurate financial impact measurement, especially for subscription and deferred revenue experiments requiring GAAP-compli' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueRecognition .

ind:absoluteDelta rdf:type rdf:Property ;
    rdfs:label 'Absolute Delta' ;
    rdfs:comment 'The absolute difference between treatment and control arm means (treatment_mean - control_mean).' ;
    rdfs:domain ind:ExperimentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:analysisRunTimestamp rdf:type rdf:Property ;
    rdfs:label 'Analysis Run Timestamp' ;
    rdfs:comment 'The timestamp when this statistical analysis was executed. Represents the principal business event time for this result record.' ;
    rdfs:domain ind:ExperimentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:analysisType rdf:type rdf:Property ;
    rdfs:label 'Analysis Type' ;
    rdfs:comment 'The type of statistical analysis performed: interim (mid-experiment check), final (experiment concluded), or post-hoc (retrospective analysis after conclusion).' ;
    rdfs:domain ind:ExperimentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisWindowEndDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Window End Date' ;
    rdfs:comment 'The end date of the data window used for this analysis.' ;
    rdfs:domain ind:ExperimentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:analysisWindowStartDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Window Start Date' ;
    rdfs:comment 'The start date of the data window used for this analysis.' ;
    rdfs:domain ind:ExperimentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:analystDecision rdf:type rdf:Property ;
    rdfs:label 'Analyst Decision' ;
    rdfs:comment 'The decision made by the analyst based on this result: ship (deploy treatment to all users), rollback (revert to control), iterate (modify and re-test), inconclusive (insufficient evidence), or monitor (continue observation).' ;
    rdfs:domain ind:ExperimentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'The approval status of the analyst decision: pending (awaiting review), approved (decision confirmed), rejected (decision overturned), or escalated (sent to higher authority).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceIntervalLower rdf:type rdf:Property ;
    rdfs:label 'Confidence Interval Lower' ;
    rdfs:comment 'The lower bound of the confidence interval for the treatment effect estimate.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceIntervalUpper rdf:type rdf:Property ;
    rdfs:label 'Confidence Interval Upper' ;
    rdfs:comment 'The upper bound of the confidence interval for the treatment effect estimate.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Confidence Level' ;
    rdfs:comment 'The confidence level used for the confidence interval calculation, typically expressed as a percentage (e.g., 95.00, 99.00).' ;
    rdfs:domain ind:ExperimentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlArmMean rdf:type rdf:Property ;
    rdfs:label 'Control Arm Mean' ;
    rdfs:comment 'The computed mean value of the metric for the control (baseline) arm of the experiment.' ;
    rdfs:domain ind:ExperimentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlSampleSize rdf:type rdf:Property ;
    rdfs:label 'Control Sample Size' ;
    rdfs:comment 'The number of observations (players, sessions, or events) in the control arm for this metric analysis.' ;
    rdfs:domain ind:ExperimentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:controlStandardDeviation rdf:type rdf:Property ;
    rdfs:label 'Control Standard Deviation' ;
    rdfs:comment 'The standard deviation of the metric in the control arm, indicating variability.' ;
    rdfs:domain ind:ExperimentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:decisionRationale rdf:type rdf:Property ;
    rdfs:label 'Decision Rationale' ;
    rdfs:comment 'Free-text explanation of the reasoning behind the analyst decision, including business context and trade-offs considered.' ;
    rdfs:domain ind:ExperimentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryMetric rdf:type rdf:Property ;
    rdfs:label 'Is Primary Metric' ;
    rdfs:comment 'Boolean flag indicating whether this metric is the primary (decision-making) metric for the experiment, as opposed to a secondary or guardrail metric.' ;
    rdfs:domain ind:ExperimentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:metricCategory rdf:type rdf:Property ;
    rdfs:label 'Metric Category' ;
    rdfs:comment 'The business category of the metric: engagement (DAU, session length), monetization (ARPU, IAP), retention (D1/D7/D30), acquisition (CPI, installs), performance (FPS, load time), or quality (crash rate, bug reports).' ;
    rdfs:domain ind:ExperimentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multipleTestingCorrection rdf:type rdf:Property ;
    rdfs:label 'Multiple Testing Correction' ;
    rdfs:comment 'The method used to correct for multiple comparisons, if any (e.g., Bonferroni, Holm, Benjamini-Hochberg FDR). None if no correction applied.' ;
    rdfs:domain ind:ExperimentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relativeLiftPercentage rdf:type rdf:Property ;
    rdfs:label 'Relative Lift Percentage' ;
    rdfs:comment 'The percentage change of the treatment arm relative to the control arm. Calculated as ((treatment_mean - control_mean) / control_mean) * 100.' ;
    rdfs:domain ind:ExperimentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:srmFlag rdf:type rdf:Property ;
    rdfs:label 'Srm Flag' ;
    rdfs:comment 'Boolean flag indicating whether a Sample Ratio Mismatch was detected, which suggests potential bias in the experiment randomization or data collection.' ;
    rdfs:domain ind:ExperimentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:srmPValue rdf:type rdf:Property ;
    rdfs:label 'Srm P Value' ;
    rdfs:comment 'The p-value from the chi-square test for Sample Ratio Mismatch detection. Low values indicate significant deviation from expected sample ratios.' ;
    rdfs:domain ind:ExperimentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statisticalTestMethod rdf:type rdf:Property ;
    rdfs:label 'Statistical Test Method' ;
    rdfs:comment 'The statistical test method used to compute this result (e.g., t-test, z-test, Mann-Whitney U, chi-square, Bayesian analysis, bootstrap).' ;
    rdfs:domain ind:ExperimentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentArmMean rdf:type rdf:Property ;
    rdfs:label 'Treatment Arm Mean' ;
    rdfs:comment 'The computed mean value of the metric for the treatment (variant) arm of the experiment.' ;
    rdfs:domain ind:ExperimentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentSampleSize rdf:type rdf:Property ;
    rdfs:label 'Treatment Sample Size' ;
    rdfs:comment 'The number of observations (players, sessions, or events) in the treatment arm for this metric analysis.' ;
    rdfs:domain ind:ExperimentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:treatmentStandardDeviation rdf:type rdf:Property ;
    rdfs:label 'Treatment Standard Deviation' ;
    rdfs:comment 'The standard deviation of the metric in the treatment arm, indicating variability.' ;
    rdfs:domain ind:ExperimentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:featureStoreDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Feature Store Definition Id' ;
    rdfs:comment 'Unique identifier for the feature store definition record. Primary key for the feature registry catalog.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processingActivityId rdf:type rdf:Property ;
    rdfs:label 'Processing Activity Id' ;
    rdfs:comment 'Foreign key linking to compliance.processing_activity. Business justification: Feature engineering creates derived personal data (aggregations, embeddings). Each feature group is a processing activity requiring documented legal basis and purpose limitation. DPO audits feature pi' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessingActivity .

ind:aggregationWindow rdf:type rdf:Property ;
    rdfs:label 'Aggregation Window' ;
    rdfs:comment 'Time window over which the feature is aggregated (e.g., 1d, 7d, 30d, 90d, lifetime, session). Defines the temporal scope of the feature calculation.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backfillAvailableFromDate rdf:type rdf:Property ;
    rdfs:label 'Backfill Available From Date' ;
    rdfs:comment 'Earliest date for which historical feature values are available for backfill and training dataset generation. Defines the temporal coverage of the feature.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:computationCostTier rdf:type rdf:Property ;
    rdfs:label 'Computation Cost Tier' ;
    rdfs:comment 'Relative computational cost tier for calculating this feature. Used for resource planning and optimization prioritization.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:computationLogicDescription rdf:type rdf:Property ;
    rdfs:label 'Computation Logic Description' ;
    rdfs:comment 'Human-readable description of how the feature is calculated, including source tables, aggregation functions, filters, and business rules. Provides transparency for feature interpretation and debugging.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataType rdf:type rdf:Property ;
    rdfs:label 'Data Type' ;
    rdfs:comment 'Spark SQL data type of the feature value. Defines the schema for feature storage and serving. [ENUM-REF-CANDIDATE: BIGINT|INT|DECIMAL|DOUBLE|STRING|BOOLEAN|TIMESTAMP|DATE|ARRAY<STRING>|ARRAY<DOUBLE> — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependentFeatures rdf:type rdf:Property ;
    rdfs:label 'Dependent Features' ;
    rdfs:comment 'Comma-separated list of other feature names that depend on this feature. Tracks feature dependencies for impact analysis and change management.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Feature Approval Status' ;
    rdfs:comment 'Governance approval status for the feature definition. Controls promotion to production and usage in regulated models.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureApprovedByEmail rdf:type rdf:Property ;
    rdfs:label 'Feature Approved By Email' ;
    rdfs:comment 'Email address of the data governance lead or ML platform owner who approved this feature for production use. Nullable if not yet approved.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureApprovedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Feature Approved Timestamp' ;
    rdfs:comment 'Timestamp when the feature definition was approved for production use. Nullable if not yet approved. Audit field for governance compliance.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:featureCardinality rdf:type rdf:Property ;
    rdfs:label 'Feature Cardinality' ;
    rdfs:comment 'Number of distinct values observed for categorical features. Nullable for continuous numeric features. Used for feature encoding strategy selection.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:featureCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Feature Created Timestamp' ;
    rdfs:comment 'Timestamp when the feature definition was first registered in the feature store. Audit field for feature lifecycle tracking.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:featureDeprecatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Feature Deprecated Timestamp' ;
    rdfs:comment 'Timestamp when the feature was marked as deprecated. Nullable field used for lifecycle management and migration planning.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:featureDocumentationUrl rdf:type rdf:Property ;
    rdfs:label 'Feature Documentation Url' ;
    rdfs:comment 'URL to detailed technical documentation for the feature, including computation logic, dependencies, known issues, and usage examples.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureDriftMonitoringEnabled rdf:type rdf:Property ;
    rdfs:label 'Feature Drift Monitoring Enabled' ;
    rdfs:comment 'Indicates whether automated drift detection and monitoring is enabled for this feature. Tracks distribution shifts between training and serving data.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:featureGroup rdf:type rdf:Property ;
    rdfs:label 'Feature Group' ;
    rdfs:comment 'Logical grouping or namespace for related features. Organizes features by domain, entity type, or business function (e.g., player_engagement, monetization_signals, session_behavior).' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureImportanceScore rdf:type rdf:Property ;
    rdfs:label 'Feature Importance Score' ;
    rdfs:comment 'Statistical importance score of the feature in production models (0.0000 to 1.0000). Derived from SHAP values or model-specific feature importance metrics. Helps prioritize feature maintenance and optimization.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:featureMaxValue rdf:type rdf:Property ;
    rdfs:label 'Feature Max Value' ;
    rdfs:comment 'Maximum observed value for numeric features. Used for data validation, outlier detection, and feature scaling. Nullable for non-numeric features.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:featureMeanValue rdf:type rdf:Property ;
    rdfs:label 'Feature Mean Value' ;
    rdfs:comment 'Mean (average) value for numeric features. Used for imputation, normalization, and drift detection. Nullable for non-numeric features.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:featureMinValue rdf:type rdf:Property ;
    rdfs:label 'Feature Min Value' ;
    rdfs:comment 'Minimum observed value for numeric features. Used for data validation, outlier detection, and feature scaling. Nullable for non-numeric features.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:featureModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Feature Modified Timestamp' ;
    rdfs:comment 'Timestamp when the feature definition was last modified. Tracks updates to computation logic, metadata, or configuration.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:featureName rdf:type rdf:Property ;
    rdfs:label 'Feature Name' ;
    rdfs:comment 'Unique name of the machine learning feature as registered in the feature store. Must be unique within the feature store namespace. Used for feature lookup and serving.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureNullPercentage rdf:type rdf:Property ;
    rdfs:label 'Feature Null Percentage' ;
    rdfs:comment 'Percentage of null or missing values in the feature (0.00 to 100.00). Used for data quality monitoring and feature selection.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:featureOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'Feature Owner Email' ;
    rdfs:comment 'Email address of the data scientist or ML engineer responsible for maintaining this feature definition. Primary contact for feature-related questions and issues.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureRetiredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Feature Retired Timestamp' ;
    rdfs:comment 'Timestamp when the feature was permanently retired and removed from active serving. Nullable field for historical tracking.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:featureStatus rdf:type rdf:Property ;
    rdfs:label 'Feature Status' ;
    rdfs:comment 'Current lifecycle status of the feature definition. Controls feature availability for model training and serving.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureTags rdf:type rdf:Property ;
    rdfs:label 'Feature Tags' ;
    rdfs:comment 'Comma-separated list of metadata tags for feature discovery and categorization (e.g., engagement, monetization, behavioral, demographic, real-time).' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureTeam rdf:type rdf:Property ;
    rdfs:label 'Feature Team' ;
    rdfs:comment 'Data science or analytics team responsible for the feature definition (e.g., Player Analytics, Monetization Science, Game Balance Team).' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Feature Unit Of Measure' ;
    rdfs:comment 'Unit of measurement for numeric features (e.g., USD, seconds, count, percentage, ratio). Provides semantic context for feature interpretation.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureVersion rdf:type rdf:Property ;
    rdfs:label 'Feature Version' ;
    rdfs:comment 'Semantic version identifier for the feature definition (e.g., 1.0.0, 2.1.3). Tracks breaking changes, enhancements, and bug fixes to feature computation logic.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freshnessSlaHours rdf:type rdf:Property ;
    rdfs:label 'Freshness Sla Hours' ;
    rdfs:comment 'Maximum allowed age of the feature value in hours before it is considered stale. Defines the refresh frequency requirement for feature pipelines.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isPiiFeature rdf:type rdf:Property ;
    rdfs:label 'Is Pii Feature' ;
    rdfs:comment 'Indicates whether the feature contains or is derived from personally identifiable information. Used for privacy compliance and data governance controls.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:joinKeyColumn rdf:type rdf:Property ;
    rdfs:label 'Join Key Column' ;
    rdfs:comment 'Name of the column used as the join key for feature lookup (e.g., player_id, session_id, match_id). Defines how features are joined to training datasets and inference requests.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nullValueHandlingStrategy rdf:type rdf:Property ;
    rdfs:label 'Null Value Handling Strategy' ;
    rdfs:comment 'Strategy for handling null or missing values in the feature. Defines the imputation or filtering logic applied during feature computation.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offlineStoreTablePath rdf:type rdf:Property ;
    rdfs:label 'Offline Store Table Path' ;
    rdfs:comment 'Fully qualified Delta Lake table path where offline feature values are stored for batch training and historical analysis.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onlineStoreEnabled rdf:type rdf:Property ;
    rdfs:label 'Online Store Enabled' ;
    rdfs:comment 'Indicates whether the feature is materialized in the online feature store for low-latency real-time serving. Required for production inference endpoints.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onlineStoreKeyValueStore rdf:type rdf:Property ;
    rdfs:label 'Online Store Key Value Store' ;
    rdfs:comment 'Name of the online key-value store (e.g., Redis, DynamoDB, Cosmos DB) used for real-time feature serving. Nullable if online serving is not enabled.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owningUseCase rdf:type rdf:Property ;
    rdfs:label 'Owning Use Case' ;
    rdfs:comment 'Primary machine learning use case or model that owns and maintains this feature definition (e.g., churn_prediction, LTV_forecasting, player_segmentation, match_balancing).' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servingMode rdf:type rdf:Property ;
    rdfs:label 'Serving Mode' ;
    rdfs:comment 'Deployment mode for feature serving. Online: low-latency real-time serving for inference. Offline: batch serving for training. Both: dual-mode serving for training and inference.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceEntityType rdf:type rdf:Property ;
    rdfs:label 'Source Entity Type' ;
    rdfs:comment 'The primary business entity type that this feature is computed from. Defines the grain and join key for feature serving. [ENUM-REF-CANDIDATE: player|session|title|match|transaction|event|guild|tournament — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceTableName rdf:type rdf:Property ;
    rdfs:label 'Source Table Name' ;
    rdfs:comment 'Fully qualified name of the primary source table or view used to compute this feature (e.g., silver.player_sessions, gold.player_daily_aggregates).' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upstreamDependencies rdf:type rdf:Property ;
    rdfs:label 'Upstream Dependencies' ;
    rdfs:comment 'Comma-separated list of upstream features or data sources that this feature depends on. Used for lineage tracking and pipeline orchestration.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:funnelDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Funnel Definition Id' ;
    rdfs:comment 'Unique identifier for the funnel definition record. Primary key.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FunnelDefinition .

ind:contentReleaseId rdf:type rdf:Property ;
    rdfs:label 'Content Release Id' ;
    rdfs:comment 'Foreign key linking to content.content_release. Business justification: Funnels measure content drop adoption (download → install → first play → D7 retention). Funnel definitions scope to specific releases for launch performance tracking and content strategy optimization.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContentRelease .

ind:ipAgreementId rdf:type rdf:Property ;
    rdfs:label 'Ip Agreement Id' ;
    rdfs:comment 'Foreign key linking to licensing.ip_agreement. Business justification: Funnels track licensed content conversion (e.g., "IP character trial → purchase"). Agreement context needed for royalty attribution on funnel conversions and IP monetization analysis. Real business pr' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IpAgreement .

ind:licensedIpId rdf:type rdf:Property ;
    rdfs:label 'Licensed Ip Id' ;
    rdfs:comment 'Foreign key linking to licensing.licensed_ip. Business justification: Funnels measure IP-specific conversion paths (awareness → trial → purchase). Links IP catalog to funnel analytics for IP performance measurement and licensing value assessment.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LicensedIp .

ind:parentFunnelDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Parent Funnel Definition Id' ;
    rdfs:comment 'Reference to the previous version of this funnel definition. Null for version 1. Used to trace funnel evolution and compare conversion rates across versions.' ;
    rdfs:domain ind:FunnelDefinition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FunnelDefinition .

ind:storefrontListingId rdf:type rdf:Property ;
    rdfs:label 'Storefront Listing Id' ;
    rdfs:comment 'Foreign key linking to platform.storefront_listing. Business justification: Conversion funnels track storefront listing views → add-to-cart → purchase. Funnel definitions must reference the specific listing being analyzed for ASO optimization, listing A/B tests, and cross-sto' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorefrontListing .

ind:supportTicketId rdf:type rdf:Property ;
    rdfs:label 'Support Ticket Id' ;
    rdfs:comment 'Foreign key linking to community.support_ticket. Business justification: Support resolution funnels track ticket lifecycle stages (opened → first response → resolved → closed). Standard customer service analytics for SLA monitoring and support efficiency measurement.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupportTicket .

ind:abTestVariant rdf:type rdf:Property ;
    rdfs:label 'Ab Test Variant' ;
    rdfs:comment 'Identifier for the A/B test variant this funnel measures (e.g., \'control\', \'treatment_a\', \'treatment_b\'). Null if is_ab_test_funnel is False. Used to segment funnel analysis by experiment arm.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionWindowHours rdf:type rdf:Property ;
    rdfs:label 'Attribution Window Hours' ;
    rdfs:comment 'Time window in hours within which all funnel steps must be completed for a player to be counted as a conversion. For example, a 24-hour window means all steps must occur within 24 hours of the first step. Used to define conversion time constraints.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benchmarkConversionRate rdf:type rdf:Property ;
    rdfs:label 'Benchmark Conversion Rate' ;
    rdfs:comment 'Industry or historical benchmark conversion rate percentage for this funnel type, expressed as a decimal. Used for comparative analysis and goal setting. May be sourced from industry reports or historical game performance.' ;
    rdfs:domain ind:FunnelDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataRetentionDays rdf:type rdf:Property ;
    rdfs:label 'Data Retention Days' ;
    rdfs:comment 'Number of days that funnel analysis results should be retained before archival or deletion. Aligns with data retention policies and regulatory requirements such as General Data Protection Regulation (GDPR) and Children\'s Online Privacy Protection Act (COPPA).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date when this funnel definition version was superseded or deactivated. Null for currently active versions. Format: yyyy-MM-dd. Used to support historical funnel analysis and version comparison.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date when this funnel definition version became active and started being used for player behavior analysis. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:funnelCode rdf:type rdf:Property ;
    rdfs:label 'Funnel Code' ;
    rdfs:comment 'Unique business identifier code for the funnel definition. Used in analytics queries and reporting systems to reference the funnel programmatically.' ;
    rdfs:domain ind:FunnelDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:funnelDefinitionDescription rdf:type rdf:Property ;
    rdfs:label 'Funnel Definition Description' ;
    rdfs:comment 'Detailed description of the funnel definition, including its purpose, key steps, and how it should be interpreted. Provides context for analysts and product managers using this funnel for conversion analysis.' ;
    rdfs:domain ind:FunnelDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:funnelName rdf:type rdf:Property ;
    rdfs:label 'Funnel Name' ;
    rdfs:comment 'Human-readable name of the funnel definition. Used by product managers and analysts to identify the funnel (e.g., \'New Player Onboarding\', \'Battle Pass Purchase Flow\', \'PvP First Match\').' ;
    rdfs:domain ind:FunnelDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:funnelStatus rdf:type rdf:Property ;
    rdfs:label 'Funnel Status' ;
    rdfs:comment 'Current lifecycle status of the funnel definition. Active funnels are used in production analytics. Draft funnels are under development. Inactive funnels are temporarily disabled. Deprecated funnels are replaced by newer versions. Archived funnels are retained for historical analysis only.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:funnelSteps rdf:type rdf:Property ;
    rdfs:label 'Funnel Steps' ;
    rdfs:comment 'Ordered list of funnel steps stored as JSON array of event type references. Each step represents a player behavior event that must occur in sequence. Example: [\'player_registered\', \'tutorial_started\', \'tutorial_completed\', \'first_match_entered\', \'first_match_completed\']. The order defines the conversion path.' ;
    rdfs:domain ind:FunnelDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:funnelType rdf:type rdf:Property ;
    rdfs:label 'Funnel Type' ;
    rdfs:comment 'Classification of the funnel by its primary business purpose. Onboarding tracks new player progression through First-Time User Experience (FTUE). Monetization tracks conversion to paying users and In-App Purchase (IAP) flows. Feature adoption tracks engagement with new game features. PvP engagement tracks Player versus Player mode entry. Battle pass progression tracks seasonal content completion. Retention tracks Day 1/Day 7/Day 30 (D1/D7/D30) return behavior.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAbTestFunnel rdf:type rdf:Property ;
    rdfs:label 'Is Ab Test Funnel' ;
    rdfs:comment 'Boolean flag indicating whether this funnel is part of an A/B experimentation framework. True if the funnel is used to measure treatment vs control group conversion. False for standard production funnels.' ;
    rdfs:domain ind:FunnelDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCurrentVersion rdf:type rdf:Property ;
    rdfs:label 'Is Current Version' ;
    rdfs:comment 'Boolean flag indicating whether this is the current active version of the funnel. True for the latest version, False for historical versions. Only one version per funnel_code should be current at any time.' ;
    rdfs:domain ind:FunnelDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastExecutedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Executed Timestamp' ;
    rdfs:comment 'Timestamp when this funnel definition was last executed in an analytics query. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. Used to identify stale or unused funnels for archival.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxPlayerLevel rdf:type rdf:Property ;
    rdfs:label 'Max Player Level' ;
    rdfs:comment 'Maximum player level for inclusion in this funnel analysis. Null if no upper level restriction applies. Used to create level-specific funnel segments (e.g., new player vs veteran player funnels).' ;
    rdfs:domain ind:FunnelDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minPlayerLevel rdf:type rdf:Property ;
    rdfs:label 'Min Player Level' ;
    rdfs:comment 'Minimum player level required for inclusion in this funnel analysis. Null if no level restriction applies. Used to create level-gated funnel definitions (e.g., endgame content funnels).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monetizationModelFilter rdf:type rdf:Property ;
    rdfs:label 'Monetization Model Filter' ;
    rdfs:comment 'Monetization model scope for this funnel. Free-to-Play (F2P) for games with In-App Purchases (IAP). Premium for paid upfront games. Subscription for recurring payment models. Game-as-a-Service (GaaS) for live operations models. All for cross-model funnels.' ;
    rdfs:domain ind:FunnelDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerPopulationFilter rdf:type rdf:Property ;
    rdfs:label 'Player Population Filter' ;
    rdfs:comment 'JSON-encoded filter criteria defining which player population this funnel applies to. May include filters by player segment, acquisition channel, geographic region, platform, or cohort. Example: {\'platform\': \'mobile\', \'region\': \'NA\', \'install_date_after\': \'2024-01-01\'}. Empty string means all players.' ;
    rdfs:domain ind:FunnelDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionFilter rdf:type rdf:Property ;
    rdfs:label 'Region Filter' ;
    rdfs:comment 'Geographic region filter for this funnel, using 3-letter ISO country codes or region groupings. Examples: \'USA\', \'GBR\', \'JPN\', or \'all\' for global. Used to create region-specific conversion analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepCount rdf:type rdf:Property ;
    rdfs:label 'Step Count' ;
    rdfs:comment 'Total number of steps in the funnel. Derived from the funnel_steps array length. Used for quick filtering and funnel complexity classification.' ;
    rdfs:domain ind:FunnelDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetConversionRate rdf:type rdf:Property ;
    rdfs:label 'Target Conversion Rate' ;
    rdfs:comment 'Target conversion rate percentage for this funnel, expressed as a decimal (e.g., 35.50 for 35.5%). Represents the business goal for end-to-end funnel completion. Used to evaluate funnel performance against objectives.' ;
    rdfs:domain ind:FunnelDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'Number of times this funnel definition has been used in analytics queries or reports. Incremented each time the funnel is executed. Used to identify popular funnels and prioritize maintenance.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Version number of this funnel definition. Funnels are versioned to support historical comparison and A/B testing. Version 1 is the initial definition. Incremented when funnel steps, attribution window, or filters are modified.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:funnelStepEventId rdf:type rdf:Property ;
    rdfs:label 'Funnel Step Event Id' ;
    rdfs:comment 'Unique identifier for each individual funnel step completion event. Primary key for the funnel step event entity.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FunnelStepEvent .

ind:abTestVariantId rdf:type rdf:Property ;
    rdfs:label 'Ab Test Variant Id' ;
    rdfs:comment 'Reference to the A/B test variant the player was assigned to when completing this step. Enables experimentation analysis and variant-specific funnel performance comparison.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AbTestVariant .

ind:achievementId rdf:type rdf:Property ;
    rdfs:label 'Achievement Id' ;
    rdfs:comment 'Foreign key linking to title.achievement. Business justification: Achievement unlocks are common funnel steps for progression analysis (first achievement → 10 achievements → platinum trophy). Essential for measuring engagement milestones and identifying drop-off poi' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Achievement .

ind:forumThreadId rdf:type rdf:Property ;
    rdfs:label 'Forum Thread Id' ;
    rdfs:comment 'Foreign key linking to community.forum_thread. Business justification: Community engagement funnels track progression through forum interactions (view → read → reply → subscribe). Core analytics for community activation and measuring content stickiness.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ForumThread .

ind:marketingCampaignId rdf:type rdf:Property ;
    rdfs:label 'Marketing Campaign Id' ;
    rdfs:comment 'Reference to the marketing campaign that drove the player into this funnel. Enables campaign-specific funnel ROI analysis and attribution.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketingCampaign .

ind:pricingId rdf:type rdf:Property ;
    rdfs:label 'Pricing Id' ;
    rdfs:comment 'Foreign key linking to platform.pricing. Business justification: Funnel events must capture exact pricing tier and promotional status at time of conversion for price elasticity analysis, promotional effectiveness measurement, and regional pricing optimization. Esse' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pricing .

ind:retentionCohortId rdf:type rdf:Property ;
    rdfs:label 'Retention Cohort Id' ;
    rdfs:comment 'Reference to the player cohort (e.g., install date cohort, acquisition channel cohort) for cohort-based funnel analysis and retention tracking.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetentionCohort .

ind:sessionId rdf:type rdf:Property ;
    rdfs:label 'Session Id' ;
    rdfs:comment 'Reference to the player session during which this funnel step was completed. Enables session-level funnel analysis and multi-step session tracking.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Session .

ind:storefrontOrderId rdf:type rdf:Property ;
    rdfs:label 'Storefront Order Id' ;
    rdfs:comment 'Foreign key linking to billing.storefront_order. Business justification: Purchase funnel steps must link to completed orders for conversion rate calculation, funnel drop-off analysis, and revenue attribution—core e-commerce analytics in gaming.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorefrontOrder .

ind:ugcSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Ugc Submission Id' ;
    rdfs:comment 'Foreign key linking to community.ugc_submission. Business justification: Creator funnels track UGC journey (browse → download → rate → create own). Core creator economy analytics for measuring conversion to active creators and content ecosystem health.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UgcSubmission .

ind:appVersion rdf:type rdf:Property ;
    rdfs:label 'App Version' ;
    rdfs:comment 'Version of the game application in which this funnel step was completed. Enables version-specific funnel performance tracking and regression detection.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completedNextStepFlag rdf:type rdf:Property ;
    rdfs:label 'Completed Next Step Flag' ;
    rdfs:comment 'Lookahead indicator showing whether the player subsequently completed the next step in the funnel. Pre-computed for pipeline efficiency to enable fast drop-off rate calculations without self-joins.' ;
    rdfs:domain ind:FunnelStepEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'Three-letter ISO country code representing the players geographic location when completing this step. Enables geo-specific funnel analysis and localization optimization.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysSinceInstall rdf:type rdf:Property ;
    rdfs:label 'Days Since Install' ;
    rdfs:comment 'Number of days elapsed between the players initial game install and the completion of this funnel step. Used for lifecycle-based funnel analysis and retention correlation.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'Category of device used to complete this funnel step. Enables device-specific funnel optimization and cross-device journey analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:funnelInstanceId rdf:type rdf:Property ;
    rdfs:label 'Funnel Instance Id' ;
    rdfs:comment 'Unique identifier for a single players journey through a specific funnel. Groups all step events for one player in one funnel attempt, enabling instance-level analysis and abandoned funnel recovery.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:funnelStepOrdinal rdf:type rdf:Property ;
    rdfs:label 'Funnel Step Ordinal' ;
    rdfs:comment 'Sequential position of this step within the funnel (1 for first step, 2 for second, etc.). Used to order steps and calculate drop-off rates between consecutive steps.' ;
    rdfs:domain ind:FunnelStepEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isFirstTimeCompletion rdf:type rdf:Property ;
    rdfs:label 'Is First Time Completion' ;
    rdfs:comment 'Indicates whether this is the first time this player has ever completed this specific funnel step across all funnel instances. Used to distinguish new vs. repeat step completions.' ;
    rdfs:domain ind:FunnelStepEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platform rdf:type rdf:Property ;
    rdfs:label 'Platform' ;
    rdfs:comment 'Gaming platform on which the player completed this funnel step. Enables platform-specific funnel performance analysis and optimization. [ENUM-REF-CANDIDATE: ios|android|windows|macos|playstation|xbox|nintendo_switch|web — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerLevelAtStep rdf:type rdf:Property ;
    rdfs:label 'Player Level At Step' ;
    rdfs:comment 'The players in-game level or progression tier at the time of completing this funnel step. Enables analysis of how player progression correlates with funnel conversion.' ;
    rdfs:domain ind:FunnelStepEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playerLifetimeSpendAtStep rdf:type rdf:Property ;
    rdfs:label 'Player Lifetime Spend At Step' ;
    rdfs:comment 'Cumulative amount the player has spent in the game up to the point of completing this funnel step. Enables monetization-based funnel segmentation and high-value player tracking.' ;
    rdfs:domain ind:FunnelStepEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referrerUrl rdf:type rdf:Property ;
    rdfs:label 'Referrer Url' ;
    rdfs:comment 'URL of the page or source that referred the player to this funnel step. Enables attribution analysis and traffic source funnel performance tracking.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Step Completion Timestamp' ;
    rdfs:comment 'Precise date and time when the player completed this specific funnel step. Primary business event timestamp for funnel progression analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stepEventName rdf:type rdf:Property ;
    rdfs:label 'Step Event Name' ;
    rdfs:comment 'Name of the specific event that triggered this funnel step completion (e.g., tutorial_started, first_purchase_completed, level_10_reached). Provides semantic context for what action the player took.' ;
    rdfs:domain ind:FunnelStepEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepMetadataJson rdf:type rdf:Property ;
    rdfs:label 'Step Metadata Json' ;
    rdfs:comment 'JSON string containing additional step-specific contextual data (e.g., item purchased, level reached, tutorial section). Provides flexible schema for step-specific attributes without schema changes.' ;
    rdfs:domain ind:FunnelStepEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeSinceFunnelEntrySeconds rdf:type rdf:Property ;
    rdfs:label 'Time Since Funnel Entry Seconds' ;
    rdfs:comment 'Elapsed time in seconds from when the player first entered the funnel (completed step 1) to when they completed this step. Used to measure overall funnel velocity and identify slow progression patterns.' ;
    rdfs:domain ind:FunnelStepEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timeSincePreviousStepSeconds rdf:type rdf:Property ;
    rdfs:label 'Time Since Previous Step Seconds' ;
    rdfs:comment 'Elapsed time in seconds from the completion of the immediately preceding funnel step to this step. Used to identify bottlenecks and friction points between consecutive steps.' ;
    rdfs:domain ind:FunnelStepEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:userAgent rdf:type rdf:Property ;
    rdfs:label 'User Agent' ;
    rdfs:comment 'Browser or client user agent string captured at the time of step completion. Provides detailed device and browser context for web-based funnels.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gameBalanceSnapshotId rdf:type rdf:Property ;
    rdfs:label 'Game Balance Snapshot Id' ;
    rdfs:comment 'Unique identifier for the game balance snapshot record. Primary key for this transactional snapshot entity.' ;
    rdfs:domain ind:GameBalanceSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compatibilityProfileId rdf:type rdf:Property ;
    rdfs:label 'Compatibility Profile Id' ;
    rdfs:comment 'Foreign key linking to platform.compatibility_profile. Business justification: Balance snapshots must segment by hardware capability (high-end vs low-end, ray tracing on/off) to detect performance-dependent balance issues. Links to compatibility profiles for hardware-stratified ' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompatibilityProfile .

ind:levelMapId rdf:type rdf:Property ;
    rdfs:label 'Level Map Id' ;
    rdfs:comment 'Foreign key linking to content.level_map. Business justification: Balance snapshots track map-specific metrics (win rates by side, spawn balance, objective completion rates, map-specific character performance). Essential for map balance patches and competitive map p' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LevelMap .

ind:aggregationPeriod rdf:type rdf:Property ;
    rdfs:label 'Aggregation Period' ;
    rdfs:comment 'The time period over which raw telemetry was aggregated to produce this snapshot (e.g., hourly, daily, weekly). Defines the temporal granularity of the balance signal.' ;
    rdfs:domain ind:GameBalanceSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:anomalyScore rdf:type rdf:Property ;
    rdfs:label 'Anomaly Score' ;
    rdfs:comment 'A machine learning-generated anomaly score (0.0000 to 1.0000) indicating the likelihood that this snapshot represents an anomalous balance state. Higher scores indicate greater deviation from expected patterns.' ;
    rdfs:domain ind:GameBalanceSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balanceStatus rdf:type rdf:Property ;
    rdfs:label 'Balance Status' ;
    rdfs:comment 'The assessed balance status of this metric based on thresholds and game design targets (e.g., balanced, overpowered, underpowered, monitoring, flagged). Used by game designers to prioritize balance adjustments.' ;
    rdfs:domain ind:GameBalanceSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeFromPrevious rdf:type rdf:Property ;
    rdfs:label 'Change From Previous' ;
    rdfs:comment 'The absolute change in metric value from the previous snapshot (metric_value - previous_snapshot_value). Quantifies the magnitude of balance shift.' ;
    rdfs:domain ind:GameBalanceSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changePercentage rdf:type rdf:Property ;
    rdfs:label 'Change Percentage' ;
    rdfs:comment 'The percentage change from the previous snapshot ((metric_value - previous_snapshot_value) / previous_snapshot_value * 100). Provides a normalized measure of period-over-period change.' ;
    rdfs:domain ind:GameBalanceSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceScore rdf:type rdf:Property ;
    rdfs:label 'Confidence Score' ;
    rdfs:comment 'A statistical confidence score (0.0000 to 1.0000) indicating the reliability of this balance metric based on sample size and variance. Used by data scientists to filter high-confidence signals.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviationFromTarget rdf:type rdf:Property ;
    rdfs:label 'Deviation From Target' ;
    rdfs:comment 'The calculated deviation of the metric value from the target value (metric_value - target_value). Positive values indicate above-target performance, negative values indicate below-target.' ;
    rdfs:domain ind:GameBalanceSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviationPercentage rdf:type rdf:Property ;
    rdfs:label 'Deviation Percentage' ;
    rdfs:comment 'The percentage deviation from the target value ((metric_value - target_value) / target_value * 100). Provides a normalized measure of balance drift.' ;
    rdfs:domain ind:GameBalanceSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metricValue rdf:type rdf:Property ;
    rdfs:label 'Metric Value' ;
    rdfs:comment 'The numeric value of the balance metric for this snapshot. Represents the aggregated or calculated balance signal (e.g., 0.523 for win rate, 1250.75 for average gold earned).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentile25 rdf:type rdf:Property ;
    rdfs:label 'Percentile 25' ;
    rdfs:comment 'The 25th percentile (first quartile) value of the metric distribution. Used for understanding the lower range of player performance or behavior.' ;
    rdfs:domain ind:GameBalanceSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentile50 rdf:type rdf:Property ;
    rdfs:label 'Percentile 50' ;
    rdfs:comment 'The 50th percentile (median) value of the metric distribution. Represents the typical player experience for this balance metric.' ;
    rdfs:domain ind:GameBalanceSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentile75 rdf:type rdf:Property ;
    rdfs:label 'Percentile 75' ;
    rdfs:comment 'The 75th percentile (third quartile) value of the metric distribution. Used for understanding the upper range of player performance or behavior.' ;
    rdfs:domain ind:GameBalanceSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentile95 rdf:type rdf:Property ;
    rdfs:label 'Percentile 95' ;
    rdfs:comment 'The 95th percentile value of the metric distribution. Identifies outlier or elite player performance levels.' ;
    rdfs:domain ind:GameBalanceSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:playerPopulationSize rdf:type rdf:Property ;
    rdfs:label 'Player Population Size' ;
    rdfs:comment 'The number of players included in the aggregation that produced this balance snapshot. Represents the sample size for statistical validity assessment.' ;
    rdfs:domain ind:GameBalanceSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousSnapshotValue rdf:type rdf:Property ;
    rdfs:label 'Previous Snapshot Value' ;
    rdfs:comment 'The metric value from the immediately preceding snapshot for the same game title, mode, and metric. Enables period-over-period comparison.' ;
    rdfs:domain ind:GameBalanceSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:segmentDimension rdf:type rdf:Property ;
    rdfs:label 'Segment Dimension' ;
    rdfs:comment 'The dimension by which the balance metric is segmented (e.g., character_class, weapon_type, player_tier, region). Identifies the categorical breakdown applied to the metric.' ;
    rdfs:domain ind:GameBalanceSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentValue rdf:type rdf:Property ;
    rdfs:label 'Segment Value' ;
    rdfs:comment 'The specific value of the segment dimension for this snapshot (e.g., warrior, assault_rifle, platinum, north_america). Provides the categorical context for the metric.' ;
    rdfs:domain ind:GameBalanceSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sessionCount rdf:type rdf:Property ;
    rdfs:label 'Session Count' ;
    rdfs:comment 'The total number of game sessions aggregated to produce this balance snapshot. Provides additional context on data volume and statistical confidence.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:snapshotDate rdf:type rdf:Property ;
    rdfs:label 'Snapshot Date' ;
    rdfs:comment 'The calendar date on which this balance snapshot was captured. Represents the business event timestamp for the aggregated balance telemetry.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:snapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Snapshot Timestamp' ;
    rdfs:comment 'The precise timestamp when this balance snapshot was generated, including time-of-day. Provides granular event timing for intraday snapshots.' ;
    rdfs:domain ind:GameBalanceSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:standardDeviation rdf:type rdf:Property ;
    rdfs:label 'Standard Deviation' ;
    rdfs:comment 'The standard deviation of the metric value. Provides a normalized measure of variability for the balance signal.' ;
    rdfs:domain ind:GameBalanceSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'The target or ideal value for this balance metric as defined by game designers. Used to calculate deviation and identify balance issues.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trendDirection rdf:type rdf:Property ;
    rdfs:label 'Trend Direction' ;
    rdfs:comment 'The directional trend of this metric compared to previous snapshots (e.g., improving, declining, stable, volatile). Indicates whether balance is moving toward or away from target.' ;
    rdfs:domain ind:GameBalanceSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variance rdf:type rdf:Property ;
    rdfs:label 'Variance' ;
    rdfs:comment 'The statistical variance of the metric value across the player population. Indicates the spread or dispersion of the balance signal.' ;
    rdfs:domain ind:GameBalanceSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replacementKpiDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Replacement Kpi Definition Id' ;
    rdfs:comment 'Foreign key reference to the KPI definition that replaces this deprecated KPI. Enables continuity tracking when KPIs evolve or are redefined.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KpiDefinition .

ind:aggregationGrain rdf:type rdf:Property ;
    rdfs:label 'Aggregation Grain' ;
    rdfs:comment 'The time granularity at which this KPI is calculated and reported: daily, weekly, monthly, quarterly, annual, or real-time (streaming).' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertEnabled rdf:type rdf:Property ;
    rdfs:label 'Alert Enabled' ;
    rdfs:comment 'Boolean flag indicating whether automated alerts are enabled for this KPI when values breach red or amber thresholds.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alertRecipientList rdf:type rdf:Property ;
    rdfs:label 'Alert Recipient List' ;
    rdfs:comment 'Comma-separated list of email addresses or distribution list names that receive automated alerts when this KPI breaches thresholds.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amberThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Amber Threshold Value' ;
    rdfs:comment 'The mid-range threshold value below which the KPI is considered at-risk (amber status) but above red. Used for traffic-light reporting and early warning.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchmarkSource rdf:type rdf:Property ;
    rdfs:label 'Benchmark Source' ;
    rdfs:comment 'The external industry benchmark or competitive intelligence source used to set target values for this KPI (e.g., \'Newzoo Industry Report 2024\', \'Internal historical average\', \'Competitor analysis\').' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessDefinition rdf:type rdf:Property ;
    rdfs:label 'Business Definition' ;
    rdfs:comment 'Comprehensive business definition of what this KPI measures, why it matters to the business, and how it should be interpreted by stakeholders. Serves as the authoritative business glossary entry.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationFormulaDescription rdf:type rdf:Property ;
    rdfs:label 'Calculation Formula Description' ;
    rdfs:comment 'Human-readable description of how the KPI is calculated, including the mathematical formula, business logic, and any filters or conditions applied (e.g., \'Count of unique player_ids with at least one session event in the calendar day\').' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationLogicVersion rdf:type rdf:Property ;
    rdfs:label 'Calculation Logic Version' ;
    rdfs:comment 'Version identifier for the calculation logic or formula used to compute this KPI. Enables tracking of changes to KPI definitions over time and ensures historical comparability.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataFreshnessSlaMinutes rdf:type rdf:Property ;
    rdfs:label 'Data Freshness Sla Minutes' ;
    rdfs:comment 'The maximum acceptable delay in minutes between the source event occurring and the KPI value being available for reporting. Defines the data freshness commitment for this KPI.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'The name of the operational system or analytics platform that provides the source data for this KPI (e.g., GameAnalytics, Amplitude, Unity Analytics, custom telemetry pipeline).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denominatorEventType rdf:type rdf:Property ;
    rdfs:label 'Denominator Event Type' ;
    rdfs:comment 'The event type or population that forms the denominator of the KPI calculation (e.g., \'active_players\', \'paying_users\', \'installs\'). Null for count-based KPIs.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deprecationReason rdf:type rdf:Property ;
    rdfs:label 'Deprecation Reason' ;
    rdfs:comment 'Explanation of why this KPI was deprecated (e.g., \'Replaced by more granular cohort-based retention metric\', \'Business priority shifted\', \'Data source no longer available\').' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:greenThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Green Threshold Value' ;
    rdfs:comment 'The threshold value at or above which the KPI is considered on-target or exceeding expectations (green status). Used for traffic-light reporting.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:kpiCategory rdf:type rdf:Property ;
    rdfs:label 'Kpi Category' ;
    rdfs:comment 'The primary business category this KPI belongs to: engagement (player activity metrics), monetization (revenue and spending metrics), retention (player return behavior), acquisition (new player metrics), performance (technical performance metrics), or balance (game economy and fairness metrics).' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiCode rdf:type rdf:Property ;
    rdfs:label 'Kpi Code' ;
    rdfs:comment 'Short alphanumeric code or abbreviation for the KPI used in reports and dashboards (e.g., DAU, ARPU, D7RET).' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiName rdf:type rdf:Property ;
    rdfs:label 'Kpi Name' ;
    rdfs:comment 'The canonical business name of the KPI metric (e.g., Daily Active Users, Average Revenue Per User, Day 7 Retention Rate).' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'The username or identifier of the person who last modified this KPI definition record.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'The timestamp when this KPI definition record was last updated or modified.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:measurementUnit rdf:type rdf:Property ;
    rdfs:label 'Measurement Unit' ;
    rdfs:comment 'The unit of measure for the KPI value (e.g., \'count\', \'USD\', \'percentage\', \'minutes\', \'ratio\', \'score\'). Provides context for interpreting the KPI value.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numeratorEventType rdf:type rdf:Property ;
    rdfs:label 'Numerator Event Type' ;
    rdfs:comment 'The event type or metric that forms the numerator of the KPI calculation (e.g., \'purchase_completed\', \'session_start\', \'level_completed\'). Null for KPIs that are not ratio-based.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owningAnalyticsTeam rdf:type rdf:Property ;
    rdfs:label 'Owning Analytics Team' ;
    rdfs:comment 'The name of the analytics team or business intelligence unit responsible for maintaining this KPI definition, ensuring data quality, and supporting business users.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Red Threshold Value' ;
    rdfs:comment 'The lower bound threshold value below which the KPI is considered critically underperforming (red status). Used for traffic-light reporting and alerting.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relatedOkr rdf:type rdf:Property ;
    rdfs:label 'Related Okr' ;
    rdfs:comment 'Reference to the company or team OKR (Objectives and Key Results) that this KPI supports or measures progress against.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingDashboardUrl rdf:type rdf:Property ;
    rdfs:label 'Reporting Dashboard Url' ;
    rdfs:comment 'The URL link to the primary business intelligence dashboard or report where this KPI is visualized (e.g., Tableau, Looker, Amplitude dashboard).' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeType rdf:type rdf:Property ;
    rdfs:label 'Scope Type' ;
    rdfs:comment 'The organizational scope at which this KPI is measured: platform-level (across all games), title-specific (single game), studio-level (development team), region-specific (geographic market), segment-specific (player cohort), or global (enterprise-wide).' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdDirection rdf:type rdf:Property ;
    rdfs:label 'Threshold Direction' ;
    rdfs:comment 'Indicates whether higher values are better (e.g., revenue, retention), lower values are better (e.g., churn, cost per install), or the target value is optimal (e.g., game balance metrics).' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiTargetId rdf:type rdf:Property ;
    rdfs:label 'Kpi Target Id' ;
    rdfs:comment 'Unique identifier for the KPI target record. Primary key for the kpi_target product.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:platformStorefrontId rdf:type rdf:Property ;
    rdfs:label 'Platform Storefront Id' ;
    rdfs:comment 'Reference to the gaming platform (console, PC, mobile) for which this target is set. Enables platform-specific performance tracking when targets vary by platform.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Storefront .

ind:previousTargetKpiTargetId rdf:type rdf:Property ;
    rdfs:label 'Previous Target Kpi Target Id' ;
    rdfs:comment 'Reference to the prior version of this target if it has been revised. Supports target history and change tracking.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KpiTarget .

ind:targetOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Target Owner Employee Id' ;
    rdfs:comment 'Reference to the specific organizational entity (studio, team, business unit) that owns accountability for achieving this target.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'The date on which this KPI target was formally approved. Marks the official commitment to the target value.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselinePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Period End Date' ;
    rdfs:comment 'The end date of the period used to calculate the baseline value. Completes the historical comparison window definition.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselinePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Period Start Date' ;
    rdfs:comment 'The start date of the period used to calculate the baseline value. Defines the historical comparison window.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselineValue rdf:type rdf:Property ;
    rdfs:label 'Baseline Value' ;
    rdfs:comment 'The historical or current baseline performance value from which improvement is measured. Provides context for target ambition and growth expectations.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:floorValue rdf:type rdf:Property ;
    rdfs:label 'Floor Value' ;
    rdfs:comment 'The minimum acceptable value or threshold below which performance is considered unsatisfactory. Defines the lower bound for acceptable performance.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPublicCommitment rdf:type rdf:Property ;
    rdfs:label 'Is Public Commitment' ;
    rdfs:comment 'Indicates whether this target has been publicly communicated to investors, partners, or external stakeholders. Flags targets with external accountability.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:linkedOkrReference rdf:type rdf:Property ;
    rdfs:label 'Linked Okr Reference' ;
    rdfs:comment 'Reference to the OKR (Objectives and Key Results) framework objective that this KPI target supports. Aligns operational targets with strategic objectives.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningCycle rdf:type rdf:Property ;
    rdfs:label 'Planning Cycle' ;
    rdfs:comment 'The business planning cycle or period identifier during which this target was established (e.g., FY2024, Q1-2024, Season-3). Links targets to strategic planning windows.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stretchTargetValue rdf:type rdf:Property ;
    rdfs:label 'Stretch Target Value' ;
    rdfs:comment 'The aspirational or stretch target value that represents exceptional performance beyond the committed target. Used for incentive planning and goal-setting.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetConfidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Target Confidence Level' ;
    rdfs:comment 'The level of confidence or certainty that the target can be achieved based on current conditions and assumptions. Supports risk assessment and scenario planning.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetNotes rdf:type rdf:Property ;
    rdfs:label 'Target Notes' ;
    rdfs:comment 'Additional notes, comments, or context about this target. Captures supplementary information for planning and review discussions.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetOwnerType rdf:type rdf:Property ;
    rdfs:label 'Target Owner Type' ;
    rdfs:comment 'The type of organizational entity responsible for achieving this KPI target. Categorizes ownership by functional area.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Target Period End Date' ;
    rdfs:comment 'The end date of the period for which this KPI target applies. Defines the conclusion of the measurement window.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Target Period Start Date' ;
    rdfs:comment 'The start date of the period for which this KPI target applies. Defines the beginning of the measurement window.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetPeriodType rdf:type rdf:Property ;
    rdfs:label 'Target Period Type' ;
    rdfs:comment 'The type of time period for which this target is set. Supports fiscal quarters, calendar periods, game seasons, and custom planning cycles. [ENUM-REF-CANDIDATE: fiscal_quarter|calendar_quarter|fiscal_month|calendar_month|season|annual|custom — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRationale rdf:type rdf:Property ;
    rdfs:label 'Target Rationale' ;
    rdfs:comment 'Business justification and reasoning for setting this target value. Captures strategic context, market conditions, and planning assumptions.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStatus rdf:type rdf:Property ;
    rdfs:label 'Target Status' ;
    rdfs:comment 'Current lifecycle status of the KPI target. Tracks the target through planning, approval, activation, and retirement stages. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|suspended|archived|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Target Unit Of Measure' ;
    rdfs:comment 'The unit of measurement for the target values (e.g., count, percentage, currency, ratio, minutes, sessions). Provides context for interpreting target values.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetVersion rdf:type rdf:Property ;
    rdfs:label 'Target Version' ;
    rdfs:comment 'Version number for this target record. Enables tracking of target revisions and changes over planning cycles.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:liveOpsSignalId rdf:type rdf:Property ;
    rdfs:label 'Live Ops Signal Id' ;
    rdfs:comment 'Unique identifier for the live operations signal record. Primary key.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LiveOpsSignal .

ind:cohortId rdf:type rdf:Property ;
    rdfs:label 'Cohort Id' ;
    rdfs:comment 'Player cohort or segment identifier used for grouping players with similar characteristics or install dates. Enables cohort-based signal analysis.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetentionCohort .

ind:gaasLiveOpsCycleId rdf:type rdf:Property ;
    rdfs:label 'Gaas Live Ops Cycle Id' ;
    rdfs:comment 'Foreign key linking to studio.live_ops_cycle. Business justification: Live ops signals (churn risk, engagement drops, monetization opportunities) trigger actions within specific live ops cycles. Links analytics detection to studio execution, enabling cycle teams to resp' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LiveOpsCycle .

ind:playerPredictionRecordId rdf:type rdf:Property ;
    rdfs:label 'Player Prediction Record Id' ;
    rdfs:comment 'Foreign key linking to analytics.player_prediction_record. Business justification: live_ops_signal can be triggered by ML model predictions (e.g., churn risk signal triggers retention campaign). One signal references one prediction record. Adding player_prediction_record_id FK allow' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerPredictionRecord .

ind:titleSeasonId rdf:type rdf:Property ;
    rdfs:label 'Title Season Id' ;
    rdfs:comment 'Foreign key linking to title.title_season. Business justification: Live ops signals (churn risk, engagement drop, monetization opportunity) are often season-specific for targeted interventions during active seasons. Season context enables personalized offers, re-enga' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TitleSeason .

ind:actionOutcome rdf:type rdf:Property ;
    rdfs:label 'Action Outcome' ;
    rdfs:comment 'Result of the live-ops intervention triggered by this signal. Tracks effectiveness of actions for closed-loop optimization.' ;
    rdfs:domain ind:LiveOpsSignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionTakenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Action Taken Timestamp' ;
    rdfs:comment 'Timestamp when a live-ops action was executed in response to this signal. Null if no action has been taken yet.' ;
    rdfs:domain ind:LiveOpsSignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consumedByLiveOpsFlag rdf:type rdf:Property ;
    rdfs:label 'Consumed By Live Ops Flag' ;
    rdfs:comment 'Indicates whether this signal has been consumed and acted upon by a downstream live-ops system. True when the signal has been processed and an intervention has been triggered.' ;
    rdfs:domain ind:LiveOpsSignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'Technique or algorithm used to identify and generate this signal. Indicates whether the signal was produced by rule-based logic, machine learning models, or other analytical methods.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detection Timestamp' ;
    rdfs:comment 'Timestamp when the analytics system detected and generated this signal. Represents the real-world event time of signal creation.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:experimentVariant rdf:type rdf:Property ;
    rdfs:label 'Experiment Variant' ;
    rdfs:comment 'Specific treatment arm or variant identifier within the A/B experiment. Enables analysis of signal patterns across different experimental conditions.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expirationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiration Timestamp' ;
    rdfs:comment 'Timestamp after which this signal is no longer valid or actionable. Signals past expiration should not trigger new interventions.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isPayingUser rdf:type rdf:Property ;
    rdfs:label 'Is Paying User' ;
    rdfs:comment 'Indicates whether the player has made at least one purchase. Distinguishes between free-to-play (F2P) and paying users for targeted interventions.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformCode rdf:type rdf:Property ;
    rdfs:label 'Platform Code' ;
    rdfs:comment 'Gaming platform on which the signal was detected. Enables platform-specific live-ops strategies and cross-platform behavior analysis. [ENUM-REF-CANDIDATE: PC|PS5|PS4|XBOX_SERIES|XBOX_ONE|SWITCH|IOS|ANDROID|WEB — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerLevel rdf:type rdf:Property ;
    rdfs:label 'Player Level' ;
    rdfs:comment 'In-game progression level of the player at the time of signal detection. Used to contextualize signals within player journey stages.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playerLifetimeDays rdf:type rdf:Property ;
    rdfs:label 'Player Lifetime Days' ;
    rdfs:comment 'Number of days since the player first installed or registered for the game. Provides player tenure context for signal interpretation.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playerLifetimeSpend rdf:type rdf:Property ;
    rdfs:label 'Player Lifetime Spend' ;
    rdfs:comment 'Total cumulative spending by the player across all in-game purchases at the time of signal detection. Used to assess monetization context and player value.' ;
    rdfs:domain ind:LiveOpsSignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:populationScope rdf:type rdf:Property ;
    rdfs:label 'Population Scope' ;
    rdfs:comment 'Defines the player population segment this signal applies to when not targeting an individual player. Examples include cohort identifiers, geographic regions, or player level ranges.' ;
    rdfs:domain ind:LiveOpsSignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedActionType rdf:type rdf:Property ;
    rdfs:label 'Recommended Action Type' ;
    rdfs:comment 'Suggested live-ops intervention or action to address the detected signal. Provides guidance to live-ops systems on how to respond to the player behavior or game state.' ;
    rdfs:domain ind:LiveOpsSignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalMetadataJson rdf:type rdf:Property ;
    rdfs:label 'Signal Metadata Json' ;
    rdfs:comment 'Additional contextual data and parameters specific to the signal type, stored as JSON. Contains signal-specific attributes such as threshold values, feature names, or economy metrics.' ;
    rdfs:domain ind:LiveOpsSignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalOwnerTeam rdf:type rdf:Property ;
    rdfs:label 'Signal Owner Team' ;
    rdfs:comment 'Name of the team or business unit responsible for monitoring and acting on this signal type. Supports operational accountability and routing.' ;
    rdfs:domain ind:LiveOpsSignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalPriority rdf:type rdf:Property ;
    rdfs:label 'Signal Priority' ;
    rdfs:comment 'Business priority level assigned to this signal for live-ops processing. Critical signals require immediate intervention while low priority signals may be batched or deferred.' ;
    rdfs:domain ind:LiveOpsSignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalStatus rdf:type rdf:Property ;
    rdfs:label 'Signal Status' ;
    rdfs:comment 'Current lifecycle state of the signal in the live-ops workflow. Tracks whether the signal is awaiting action, being processed, has been acted upon, or has been dismissed.' ;
    rdfs:domain ind:LiveOpsSignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalStrength rdf:type rdf:Property ;
    rdfs:label 'Signal Strength' ;
    rdfs:comment 'Numeric measure of signal intensity or confidence score, typically ranging from 0.00 to 100.00. Higher values indicate stronger or more urgent signals requiring live-ops intervention.' ;
    rdfs:domain ind:LiveOpsSignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:signalType rdf:type rdf:Property ;
    rdfs:label 'Signal Type' ;
    rdfs:comment 'Category of behavioral signal detected by the analytics system. Indicates the nature of the player behavior pattern or game state anomaly that triggered the signal.' ;
    rdfs:domain ind:LiveOpsSignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceEventCount rdf:type rdf:Property ;
    rdfs:label 'Source Event Count' ;
    rdfs:comment 'Number of underlying telemetry events or data points that contributed to this signal generation. Indicates signal robustness and data volume.' ;
    rdfs:domain ind:LiveOpsSignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mlModelRegistryId rdf:type rdf:Property ;
    rdfs:label 'Ml Model Registry Id' ;
    rdfs:comment 'Unique identifier for the machine learning model registry entry. Primary key.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MlModelRegistry .

ind:businessImpactDescription rdf:type rdf:Property ;
    rdfs:label 'Business Impact Description' ;
    rdfs:comment 'Description of the measured or expected business impact of deploying this model (e.g., 5% reduction in churn, 10% increase in LTV).' ;
    rdfs:domain ind:MlModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Notes on compliance considerations for this model, including GDPR, COPPA, fairness, bias mitigation, and explainability requirements.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentEnvironment rdf:type rdf:Property ;
    rdfs:label 'Deployment Environment' ;
    rdfs:comment 'Current deployment environment where the model is running (development, staging, production, archived).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deployment Timestamp' ;
    rdfs:comment 'Timestamp when the model was deployed to the current environment. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:evaluationMetricName rdf:type rdf:Property ;
    rdfs:label 'Evaluation Metric Name' ;
    rdfs:comment 'Name of the primary evaluation metric used to assess model performance (e.g., AUC-ROC, RMSE, F1-score, precision, recall, MAE).' ;
    rdfs:domain ind:MlModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationMetricValue rdf:type rdf:Property ;
    rdfs:label 'Evaluation Metric Value' ;
    rdfs:comment 'Numeric value of the primary evaluation metric achieved by the model on the validation dataset.' ;
    rdfs:domain ind:MlModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:featureSetDescription rdf:type rdf:Property ;
    rdfs:label 'Feature Set Description' ;
    rdfs:comment 'Description of the feature set used by the model, including key features and their business meaning.' ;
    rdfs:domain ind:MlModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:framework rdf:type rdf:Property ;
    rdfs:label 'Framework' ;
    rdfs:comment 'Machine learning framework used to develop the model (TensorFlow, PyTorch, XGBoost, Spark MLlib, scikit-learn, Keras).' ;
    rdfs:domain ind:MlModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hyperparameters rdf:type rdf:Property ;
    rdfs:label 'Hyperparameters' ;
    rdfs:comment 'JSON or text representation of the hyperparameters used during model training (e.g., learning rate, number of trees, depth).' ;
    rdfs:domain ind:MlModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isChampionModel rdf:type rdf:Property ;
    rdfs:label 'Is Champion Model' ;
    rdfs:comment 'Flag indicating whether this model is the current champion (best-performing) model for its use case. True if champion, False otherwise.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRetrainedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Retrained Timestamp' ;
    rdfs:comment 'Timestamp when the model was last retrained. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:MlModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mlflowRunReference rdf:type rdf:Property ;
    rdfs:label 'Mlflow Run Reference' ;
    rdfs:comment 'Unique identifier for the MLflow experiment run that produced this model version. Links to MLflow tracking server.' ;
    rdfs:domain ind:MlModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelArtifactPath rdf:type rdf:Property ;
    rdfs:label 'Model Artifact Path' ;
    rdfs:comment 'Storage path or URI where the serialized model artifact is stored (e.g., S3 bucket path, Azure Blob Storage URI).' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelDescription rdf:type rdf:Property ;
    rdfs:label 'Model Description' ;
    rdfs:comment 'Detailed business description of the model, its purpose, and expected business impact.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelName rdf:type rdf:Property ;
    rdfs:label 'Model Name' ;
    rdfs:comment 'Human-readable name of the machine learning model (e.g., Player Churn Predictor v3, LTV Forecaster).' ;
    rdfs:domain ind:MlModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelSizeMb rdf:type rdf:Property ;
    rdfs:label 'Model Size Mb' ;
    rdfs:comment 'Size of the serialized model artifact in megabytes. Important for deployment and resource planning.' ;
    rdfs:domain ind:MlModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelStatus rdf:type rdf:Property ;
    rdfs:label 'Model Status' ;
    rdfs:comment 'Current lifecycle status of the model (active, inactive, deprecated, experimental, retired).' ;
    rdfs:domain ind:MlModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelTags rdf:type rdf:Property ;
    rdfs:label 'Model Tags' ;
    rdfs:comment 'Comma-separated list of tags for model categorization and discovery (e.g., churn, monetization, player-behavior, experimental).' ;
    rdfs:domain ind:MlModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelType rdf:type rdf:Property ;
    rdfs:label 'Model Type' ;
    rdfs:comment 'Type of machine learning model algorithm used (classification, regression, ranking, clustering, reinforcement learning, time series).' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predictionLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Prediction Latency Ms' ;
    rdfs:comment 'Average prediction latency in milliseconds for real-time inference. Key performance indicator for production models.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retrainingFrequency rdf:type rdf:Property ;
    rdfs:label 'Retraining Frequency' ;
    rdfs:comment 'Planned frequency for retraining the model to maintain performance (daily, weekly, monthly, quarterly, on-demand, never).' ;
    rdfs:domain ind:MlModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetVariable rdf:type rdf:Property ;
    rdfs:label 'Target Variable' ;
    rdfs:comment 'Name of the target variable or label that the model predicts (e.g., churn_flag, ltv_30_day, match_quality_score).' ;
    rdfs:domain ind:MlModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testSampleCount rdf:type rdf:Property ;
    rdfs:label 'Test Sample Count' ;
    rdfs:comment 'Number of test samples (rows) used for final model evaluation before deployment.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingDatasetReference rdf:type rdf:Property ;
    rdfs:label 'Training Dataset Reference' ;
    rdfs:comment 'Reference path or identifier to the training dataset used to train this model (e.g., S3 path, Delta table name, dataset ID).' ;
    rdfs:domain ind:MlModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Training Duration Minutes' ;
    rdfs:comment 'Total duration of model training in minutes. Used for resource planning and cost optimization.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Training End Timestamp' ;
    rdfs:comment 'Timestamp when model training completed. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:trainingSampleCount rdf:type rdf:Property ;
    rdfs:label 'Training Sample Count' ;
    rdfs:comment 'Number of training samples (rows) used to train the model. Indicator of model robustness.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Training Start Timestamp' ;
    rdfs:comment 'Timestamp when model training began. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:useCase rdf:type rdf:Property ;
    rdfs:label 'Use Case' ;
    rdfs:comment 'Business use case the model addresses (e.g., player churn prediction, LTV forecasting, matchmaking optimization, game balance tuning, content recommendation).' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationSampleCount rdf:type rdf:Property ;
    rdfs:label 'Validation Sample Count' ;
    rdfs:comment 'Number of validation samples (rows) used to evaluate the model during training.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modelServingEventId rdf:type rdf:Property ;
    rdfs:label 'Model Serving Event Id' ;
    rdfs:comment 'Unique identifier for each model inference event. Primary key for the model serving event record.' ;
    rdfs:domain ind:ModelServingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gameSessionId rdf:type rdf:Property ;
    rdfs:label 'Game Session Id' ;
    rdfs:comment 'Reference to the game session during which this inference was executed. Links predictions to player gameplay context.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Session .

ind:modelDeploymentId rdf:type rdf:Property ;
    rdfs:label 'Model Deployment Id' ;
    rdfs:comment 'Reference to the specific deployment instance of the model. Enables tracking of deployment-specific performance issues.' ;
    rdfs:domain ind:ModelServingEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MlModelDeployment .

ind:modelVersionId rdf:type rdf:Property ;
    rdfs:label 'Model Version Id' ;
    rdfs:comment 'Reference to the specific version of the ML model used for this inference. Enables A/B testing and version comparison.' ;
    rdfs:domain ind:ModelServingEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MlModelVersion .

ind:actionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Action Timestamp' ;
    rdfs:comment 'The timestamp when the downstream action was executed based on this prediction. Nullable if no action taken.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actionType rdf:type rdf:Property ;
    rdfs:label 'Action Type' ;
    rdfs:comment 'The type of action triggered by this prediction (e.g., push notification, in-game offer, content recommendation, matchmaking adjustment). Nullable if no action taken.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchJobReference rdf:type rdf:Property ;
    rdfs:label 'Batch Job Reference' ;
    rdfs:comment 'Identifier for the batch job if this inference was part of a batch scoring run. Nullable for real-time inferences.' ;
    rdfs:domain ind:ModelServingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataDriftScore rdf:type rdf:Property ;
    rdfs:label 'Data Drift Score' ;
    rdfs:comment 'Calculated drift score comparing input feature distribution to training data distribution. Used for model retraining triggers.' ;
    rdfs:domain ind:ModelServingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:errorCode rdf:type rdf:Property ;
    rdfs:label 'Error Code' ;
    rdfs:comment 'The error code if the inference failed (e.g., feature_missing, timeout, model_unavailable). Nullable if no error occurred.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorMessage rdf:type rdf:Property ;
    rdfs:label 'Error Message' ;
    rdfs:comment 'Detailed error message if the inference failed. Nullable if no error occurred.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureExtractionLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Feature Extraction Latency Ms' ;
    rdfs:comment 'Time spent extracting and preparing input features before model inference. Helps identify preprocessing bottlenecks.' ;
    rdfs:domain ind:ModelServingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:featureStoreVersion rdf:type rdf:Property ;
    rdfs:label 'Feature Store Version' ;
    rdfs:comment 'Version of the feature store schema used to retrieve input features. Tracks feature engineering pipeline changes.' ;
    rdfs:domain ind:ModelServingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inferenceMode rdf:type rdf:Property ;
    rdfs:label 'Inference Mode' ;
    rdfs:comment 'The execution mode of the inference: real-time API call, scheduled batch job, streaming pipeline, or edge device inference.' ;
    rdfs:domain ind:ModelServingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inferenceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inference Timestamp' ;
    rdfs:comment 'The exact date and time when the model inference was executed. Critical for latency analysis and temporal drift detection.' ;
    rdfs:domain ind:ModelServingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inputFeatureVectorHash rdf:type rdf:Property ;
    rdfs:label 'Input Feature Vector Hash' ;
    rdfs:comment 'Hash of the input feature vector used for the prediction. Enables detection of duplicate requests and feature drift analysis without storing full feature vectors.' ;
    rdfs:domain ind:ModelServingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelComputeCostUsd rdf:type rdf:Property ;
    rdfs:label 'Model Compute Cost Usd' ;
    rdfs:comment 'Estimated compute cost in USD for executing this inference. Enables cost-per-prediction analysis and ROI calculation.' ;
    rdfs:domain ind:ModelServingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelFramework rdf:type rdf:Property ;
    rdfs:label 'Model Framework' ;
    rdfs:comment 'The machine learning framework used for this model (e.g., TensorFlow, PyTorch, Scikit-learn, XGBoost). Supports framework-specific performance analysis.' ;
    rdfs:domain ind:ModelServingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelInferenceLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Model Inference Latency Ms' ;
    rdfs:comment 'Time spent in the actual model inference computation, excluding feature preparation and post-processing.' ;
    rdfs:domain ind:ModelServingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modelInputFeatureCount rdf:type rdf:Property ;
    rdfs:label 'Model Input Feature Count' ;
    rdfs:comment 'The number of features in the input vector for this inference. Helps detect feature schema drift.' ;
    rdfs:domain ind:ModelServingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:predictionActedUponFlag rdf:type rdf:Property ;
    rdfs:label 'Prediction Acted Upon Flag' ;
    rdfs:comment 'Indicates whether the prediction triggered a downstream action (e.g., live-ops intervention, personalized offer, content recommendation displayed).' ;
    rdfs:domain ind:ModelServingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:predictionCacheHitFlag rdf:type rdf:Property ;
    rdfs:label 'Prediction Cache Hit Flag' ;
    rdfs:comment 'Indicates whether this prediction was served from cache rather than computed. Affects latency and cost metrics.' ;
    rdfs:domain ind:ModelServingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:predictionClass rdf:type rdf:Property ;
    rdfs:label 'Prediction Class' ;
    rdfs:comment 'The predicted class label for classification models (e.g., churn risk tier, player segment, content recommendation category). Nullable for regression models.' ;
    rdfs:domain ind:ModelServingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predictionConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Prediction Confidence Score' ;
    rdfs:comment 'The model\'s confidence score for the prediction, typically ranging from 0.0 to 1.0. Used for threshold-based decision making and model quality monitoring.' ;
    rdfs:domain ind:ModelServingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:predictionErrorFlag rdf:type rdf:Property ;
    rdfs:label 'Prediction Error Flag' ;
    rdfs:comment 'Indicates whether the inference encountered an error during execution. Used for model reliability monitoring.' ;
    rdfs:domain ind:ModelServingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:predictionOutputValue rdf:type rdf:Property ;
    rdfs:label 'Prediction Output Value' ;
    rdfs:comment 'The primary prediction output from the model. May be a numeric value, class label, or JSON-encoded complex output depending on model type.' ;
    rdfs:domain ind:ModelServingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:predictionProbabilityDistribution rdf:type rdf:Property ;
    rdfs:label 'Prediction Probability Distribution' ;
    rdfs:comment 'JSON-encoded probability distribution across all possible classes for classification models. Enables detailed analysis of model uncertainty.' ;
    rdfs:domain ind:ModelServingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predictionShapValues rdf:type rdf:Property ;
    rdfs:label 'Prediction Shap Values' ;
    rdfs:comment 'JSON-encoded SHAP values explaining feature contributions to the prediction. Enables model interpretability and explainability analysis.' ;
    rdfs:domain ind:ModelServingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predictionUseCase rdf:type rdf:Property ;
    rdfs:label 'Prediction Use Case' ;
    rdfs:comment 'The business use case for this prediction (e.g., churn_prediction, ltv_forecast, content_recommendation, matchmaking, game_balance). Enables use-case-specific ROI analysis.' ;
    rdfs:domain ind:ModelServingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestTraceCode rdf:type rdf:Property ;
    rdfs:label 'Request Trace Code' ;
    rdfs:comment 'Unique identifier for the inference request. Enables end-to-end tracing across distributed systems.' ;
    rdfs:domain ind:ModelServingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servingEndpoint rdf:type rdf:Property ;
    rdfs:label 'Serving Endpoint' ;
    rdfs:comment 'The infrastructure endpoint or service that executed the inference (e.g., API gateway URL, batch job name, edge node identifier).' ;
    rdfs:domain ind:ModelServingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servingLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Serving Latency Ms' ;
    rdfs:comment 'The total time in milliseconds from inference request to response delivery. Critical KPI for real-time serving performance monitoring.' ;
    rdfs:domain ind:ModelServingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playerBehaviorSegmentId rdf:type rdf:Property ;
    rdfs:label 'Player Behavior Segment Id' ;
    rdfs:comment 'Unique identifier for the player behavior segment record. Primary key.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerBehaviorSegment .

ind:billingAccountId rdf:type rdf:Property ;
    rdfs:label 'Billing Account Id' ;
    rdfs:comment 'Foreign key linking to billing.account. Business justification: Monetization segments (whales, dolphins, minnows, non-payers) are defined by billing behavior patterns. Segments must link to billing accounts for targeted offers and retention campaigns.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingAccount .

ind:avgArpu rdf:type rdf:Property ;
    rdfs:label 'Avg Arpu' ;
    rdfs:comment 'Average revenue per user for players in this segment over a standard period (typically 30 days), in USD.' ;
    rdfs:domain ind:PlayerBehaviorSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgLtv rdf:type rdf:Property ;
    rdfs:label 'Avg Ltv' ;
    rdfs:comment 'Average predicted or observed lifetime value of players in this segment, in USD. Key metric for monetization-focused segments.' ;
    rdfs:domain ind:PlayerBehaviorSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgSessionLengthMinutes rdf:type rdf:Property ;
    rdfs:label 'Avg Session Length Minutes' ;
    rdfs:comment 'Mean session duration in minutes for players in this segment. Key engagement metric.' ;
    rdfs:domain ind:PlayerBehaviorSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:churnRiskScore rdf:type rdf:Property ;
    rdfs:label 'Churn Risk Score' ;
    rdfs:comment 'Predicted churn probability for players in this segment, expressed as a percentage (0.00 to 100.00). Higher scores indicate higher risk of player attrition.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:d30RetentionRate rdf:type rdf:Property ;
    rdfs:label 'D30 Retention Rate' ;
    rdfs:comment 'Percentage of players in this segment who return on day 30 after first session (0.00 to 100.00). Long-term retention metric.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:d7RetentionRate rdf:type rdf:Property ;
    rdfs:label 'D7 Retention Rate' ;
    rdfs:comment 'Percentage of players in this segment who return on day 7 after first session (0.00 to 100.00). Standard retention metric.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSourceSystems rdf:type rdf:Property ;
    rdfs:label 'Data Source Systems' ;
    rdfs:comment 'Comma-separated list of source systems providing telemetry and behavioral data for this segment (e.g., \'GameAnalytics, Amplitude, Unity Analytics\'). Documents data lineage.' ;
    rdfs:domain ind:PlayerBehaviorSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureSetUsed rdf:type rdf:Property ;
    rdfs:label 'Feature Set Used' ;
    rdfs:comment 'Comma-separated list or description of behavioral features used as input to the segmentation model (e.g., \'avg_session_length, d7_retention, mtx_spend, pvp_participation, guild_membership, login_frequency\'). Documents the data foundation of the segment.' ;
    rdfs:domain ind:PlayerBehaviorSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Refresh Timestamp' ;
    rdfs:comment 'Timestamp when player assignments to this segment were last recalculated. Used to track data currency and trigger refresh workflows.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:modelAccuracyScore rdf:type rdf:Property ;
    rdfs:label 'Model Accuracy Score' ;
    rdfs:comment 'Validation accuracy or performance metric of the segmentation model, expressed as a percentage (0.00 to 100.00). Used for model quality monitoring.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Model Algorithm' ;
    rdfs:comment 'Name of the machine learning or statistical algorithm used for segmentation (e.g., \'K-Means Clustering\', \'Random Forest\', \'RFM Analysis\', \'Hierarchical Clustering\', \'Neural Network\').' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelTrainingDate rdf:type rdf:Property ;
    rdfs:label 'Model Training Date' ;
    rdfs:comment 'Date when the segmentation model was last trained or calibrated. Used to assess model staleness and trigger retraining.' ;
    rdfs:domain ind:PlayerBehaviorSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monetizationWeight rdf:type rdf:Property ;
    rdfs:label 'Monetization Weight' ;
    rdfs:comment 'Relative weight of monetization and spending behavior features in the segmentation model, expressed as a percentage (0.00 to 100.00).' ;
    rdfs:domain ind:PlayerBehaviorSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Next Refresh Timestamp' ;
    rdfs:comment 'Scheduled timestamp for the next segment refresh. Used for pipeline orchestration and data freshness monitoring.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:playerCount rdf:type rdf:Property ;
    rdfs:label 'Player Count' ;
    rdfs:comment 'Number of players currently assigned to this behavioral segment as of the last refresh. Used for segment size tracking and population distribution analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playerCountPercentage rdf:type rdf:Property ;
    rdfs:label 'Player Count Percentage' ;
    rdfs:comment 'Percentage of the total player base in this game title that belongs to this segment (0.00 to 100.00). Provides relative segment size context.' ;
    rdfs:domain ind:PlayerBehaviorSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:playtimeWeight rdf:type rdf:Property ;
    rdfs:label 'Playtime Weight' ;
    rdfs:comment 'Relative weight or importance of playtime-related features in the segmentation model, expressed as a percentage (0.00 to 100.00). Used for model interpretability.' ;
    rdfs:domain ind:PlayerBehaviorSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refreshCadence rdf:type rdf:Property ;
    rdfs:label 'Refresh Cadence' ;
    rdfs:comment 'Frequency at which player assignments to this segment are recalculated and updated. Determines data freshness for targeting and analytics.' ;
    rdfs:domain ind:PlayerBehaviorSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentBoundaryCriteria rdf:type rdf:Property ;
    rdfs:label 'Segment Boundary Criteria' ;
    rdfs:comment 'Technical definition of the thresholds, ranges, or clustering boundaries that define membership in this segment (e.g., \'avg_daily_playtime > 120 min AND mtx_spend_30d > 50 USD\'). Used for segment assignment logic.' ;
    rdfs:domain ind:PlayerBehaviorSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Short alphanumeric code for the segment used in technical systems and data pipelines (e.g., \'HG01\', \'SB02\', \'WW03\').' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Detailed description of the behavioral characteristics, play patterns, and defining traits of players in this segment.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable name of the behavioral segment (e.g., \'Hardcore Grinders\', \'Social Butterflies\', \'Weekend Warriors\', \'Whales\', \'Casual Explorers\'). Used for reporting and targeting.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle status of the segment. Active segments are used for targeting and analytics; deprecated segments are retained for historical analysis only.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Primary categorization of the segment based on the dominant behavioral dimension: engagement (activity level), monetization (spending behavior), retention (churn risk), playstyle (gameplay preferences), social (community interaction), or hybrid (multi-dimensional).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentationModelVersion rdf:type rdf:Property ;
    rdfs:label 'Segmentation Model Version' ;
    rdfs:comment 'Version identifier of the data science model or algorithm used to generate this segment (e.g., \'v2.3.1\', \'kmeans_v5\'). Enables tracking of model evolution and A/B testing of segmentation approaches.' ;
    rdfs:domain ind:PlayerBehaviorSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionFrequencyWeight rdf:type rdf:Property ;
    rdfs:label 'Session Frequency Weight' ;
    rdfs:comment 'Relative weight of session frequency features in the segmentation model, expressed as a percentage (0.00 to 100.00).' ;
    rdfs:domain ind:PlayerBehaviorSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialWeight rdf:type rdf:Property ;
    rdfs:label 'Social Weight' ;
    rdfs:comment 'Relative weight of social interaction and community engagement features in the segmentation model, expressed as a percentage (0.00 to 100.00).' ;
    rdfs:domain ind:PlayerBehaviorSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetAudience rdf:type rdf:Property ;
    rdfs:label 'Target Audience' ;
    rdfs:comment 'Intended business audience or team that consumes this segment (e.g., \'Game Design Team\', \'LiveOps Team\', \'Data Science Team\', \'Product Management\').' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predictedAssetId rdf:type rdf:Property ;
    rdfs:label 'Predicted Asset Id' ;
    rdfs:comment 'Foreign key linking to content.asset. Business justification: Predictions for asset-specific player behavior (will purchase this cosmetic, will use this weapon, will play this map). Powers personalized content recommendations, dynamic pricing, and targeted conte' ;
    rdfs:domain ind:PlayerPredictionRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:actionTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Action Triggered Flag' ;
    rdfs:comment 'Indicates whether this prediction triggered a downstream live-ops, CRM (Customer Relationship Management), or marketing action. True if action was initiated, False otherwise.' ;
    rdfs:domain ind:PlayerPredictionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualOutcomeFlag rdf:type rdf:Property ;
    rdfs:label 'Actual Outcome Flag' ;
    rdfs:comment 'Indicates whether the actual outcome has been observed and recorded for this prediction. Used for model performance evaluation and retraining. True if outcome is known, False if still pending.' ;
    rdfs:domain ind:PlayerPredictionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualOutcomeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Outcome Timestamp' ;
    rdfs:comment 'The date and time when the actual outcome was observed and recorded. Null until outcome is known.' ;
    rdfs:domain ind:PlayerPredictionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualOutcomeValue rdf:type rdf:Property ;
    rdfs:label 'Actual Outcome Value' ;
    rdfs:comment 'The actual observed outcome value corresponding to this prediction. Used to calculate prediction accuracy, error metrics, and model performance. Null until outcome is observed.' ;
    rdfs:domain ind:PlayerPredictionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchRunCode rdf:type rdf:Property ;
    rdfs:label 'Batch Run Code' ;
    rdfs:comment 'Identifier for the batch prediction run that generated this record. Groups predictions generated in the same model execution cycle.' ;
    rdfs:domain ind:PlayerPredictionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureCount rdf:type rdf:Property ;
    rdfs:label 'Feature Count' ;
    rdfs:comment 'The number of input features used by the model to generate this prediction. Tracks model complexity and feature engineering scope.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:featureSnapshotDate rdf:type rdf:Property ;
    rdfs:label 'Feature Snapshot Date' ;
    rdfs:comment 'The date representing the point-in-time snapshot of player features used as input to the ML model. Ensures reproducibility and tracks data freshness.' ;
    rdfs:domain ind:PlayerPredictionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modelDriftFlag rdf:type rdf:Property ;
    rdfs:label 'Model Drift Flag' ;
    rdfs:comment 'Indicates whether this prediction was flagged as potentially affected by model drift or data distribution shift. True if drift detected, False otherwise.' ;
    rdfs:domain ind:PlayerPredictionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:playerSegment rdf:type rdf:Property ;
    rdfs:label 'Player Segment' ;
    rdfs:comment 'The player segment or cohort this prediction applies to (e.g., \'new_player\', \'veteran\', \'whale\', \'casual\'). Enables segment-specific model performance tracking.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predictionConfidence rdf:type rdf:Property ;
    rdfs:label 'Prediction Confidence' ;
    rdfs:comment 'Confidence score or probability indicating the model\'s certainty in this prediction. Typically ranges from 0.0 to 1.0.' ;
    rdfs:domain ind:PlayerPredictionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:predictionError rdf:type rdf:Property ;
    rdfs:label 'Prediction Error' ;
    rdfs:comment 'The calculated error between the predicted value and the actual outcome value. Used for model performance monitoring and retraining triggers. Null until actual outcome is observed.' ;
    rdfs:domain ind:PlayerPredictionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:predictionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Prediction Expiry Date' ;
    rdfs:comment 'The date after which this prediction is considered stale and should no longer be used for decision-making. Calculated as prediction_timestamp + prediction_horizon_days.' ;
    rdfs:domain ind:PlayerPredictionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:predictionHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Prediction Horizon Days' ;
    rdfs:comment 'The forward-looking time window in days for which this prediction is valid. For example, 7-day churn risk or 30-day LTV (Lifetime Value) prediction.' ;
    rdfs:domain ind:PlayerPredictionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:predictionLabel rdf:type rdf:Property ;
    rdfs:label 'Prediction Label' ;
    rdfs:comment 'Human-readable categorical label or classification output from the model (e.g., \'High Risk\', \'Tier 3\', \'Likely Whale\'). Complements the numeric prediction_value.' ;
    rdfs:domain ind:PlayerPredictionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predictionStatus rdf:type rdf:Property ;
    rdfs:label 'Prediction Status' ;
    rdfs:comment 'The current lifecycle status of this prediction record. Tracks whether the prediction is active, has been acted upon, or has been replaced by a newer prediction.' ;
    rdfs:domain ind:PlayerPredictionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predictionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Prediction Timestamp' ;
    rdfs:comment 'The date and time when this prediction was generated by the ML model. Represents the business event time of prediction execution.' ;
    rdfs:domain ind:PlayerPredictionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:predictionType rdf:type rdf:Property ;
    rdfs:label 'Prediction Type' ;
    rdfs:comment 'The type of prediction generated by the ML model. Indicates what player behavior or outcome is being predicted.' ;
    rdfs:domain ind:PlayerPredictionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predictionValue rdf:type rdf:Property ;
    rdfs:label 'Prediction Value' ;
    rdfs:comment 'The raw numeric output value from the ML model. Interpretation depends on prediction_type (e.g., probability score 0-1, tier classification 1-5, recommendation score).' ;
    rdfs:domain ind:PlayerPredictionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:topFeature1Importance rdf:type rdf:Property ;
    rdfs:label 'Top Feature 1 Importance' ;
    rdfs:comment 'The importance score or contribution weight of the top feature to this prediction. Enables model explainability and interpretability.' ;
    rdfs:domain ind:PlayerPredictionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:topFeature1Name rdf:type rdf:Property ;
    rdfs:label 'Top Feature 1 Name' ;
    rdfs:comment 'The name of the most important feature contributing to this prediction, based on feature importance or SHAP (SHapley Additive exPlanations) values.' ;
    rdfs:domain ind:PlayerPredictionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:topFeature2Importance rdf:type rdf:Property ;
    rdfs:label 'Top Feature 2 Importance' ;
    rdfs:comment 'The importance score or contribution weight of the second top feature to this prediction.' ;
    rdfs:domain ind:PlayerPredictionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:topFeature2Name rdf:type rdf:Property ;
    rdfs:label 'Top Feature 2 Name' ;
    rdfs:comment 'The name of the second most important feature contributing to this prediction.' ;
    rdfs:domain ind:PlayerPredictionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:topFeature3Importance rdf:type rdf:Property ;
    rdfs:label 'Top Feature 3 Importance' ;
    rdfs:comment 'The importance score or contribution weight of the third top feature to this prediction.' ;
    rdfs:domain ind:PlayerPredictionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:topFeature3Name rdf:type rdf:Property ;
    rdfs:label 'Top Feature 3 Name' ;
    rdfs:comment 'The name of the third most important feature contributing to this prediction.' ;
    rdfs:domain ind:PlayerPredictionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionCohortAnalysisId rdf:type rdf:Property ;
    rdfs:label 'Retention Cohort Analysis Id' ;
    rdfs:comment 'Unique identifier for the retention cohort analysis record. Primary key.' ;
    rdfs:domain ind:RetentionCohortAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageSessionLengthMinutes rdf:type rdf:Property ;
    rdfs:label 'Average Session Length Minutes' ;
    rdfs:comment 'Mean session duration in minutes for players in this cohort across the measurement period. Indicates engagement depth.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageSessionsPerPlayer rdf:type rdf:Property ;
    rdfs:label 'Average Sessions Per Player' ;
    rdfs:comment 'Mean number of sessions per player in this cohort across the measurement period. Indicates engagement frequency.' ;
    rdfs:domain ind:RetentionCohortAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cohortArppu rdf:type rdf:Property ;
    rdfs:label 'Cohort Arppu' ;
    rdfs:comment 'Average revenue per paying user in this cohort during the measurement period, excluding non-payers.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cohortArpu rdf:type rdf:Property ;
    rdfs:label 'Cohort Arpu' ;
    rdfs:comment 'Average revenue per user across all players in this cohort during the measurement period, including non-payers.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cohortCode rdf:type rdf:Property ;
    rdfs:label 'Cohort Code' ;
    rdfs:comment 'Unique business identifier code for the cohort used in reporting and analytics systems.' ;
    rdfs:domain ind:RetentionCohortAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cohortEntryEndDate rdf:type rdf:Property ;
    rdfs:label 'Cohort Entry End Date' ;
    rdfs:comment 'The last date on which players could enter this cohort. Defines the end of the cohort entry window. Null for open-ended cohorts.' ;
    rdfs:domain ind:RetentionCohortAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cohortEntryEventType rdf:type rdf:Property ;
    rdfs:label 'Cohort Entry Event Type' ;
    rdfs:comment 'The specific player behavior event that defines entry into this cohort (e.g., \'first_install\', \'first_session_after_30d_absence\', \'feature_x_first_use\', \'season_5_login\').' ;
    rdfs:domain ind:RetentionCohortAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cohortEntryStartDate rdf:type rdf:Property ;
    rdfs:label 'Cohort Entry Start Date' ;
    rdfs:comment 'The first date on which players could enter this cohort. Defines the beginning of the cohort entry window.' ;
    rdfs:domain ind:RetentionCohortAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cohortLtvEstimate rdf:type rdf:Property ;
    rdfs:label 'Cohort Ltv Estimate' ;
    rdfs:comment 'Estimated average lifetime value per player for this cohort based on observed monetization patterns. Used for ROI and acquisition cost analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cohortName rdf:type rdf:Property ;
    rdfs:label 'Cohort Name' ;
    rdfs:comment 'Human-readable name for the retention cohort (e.g., \'Q1 2024 Install Cohort\', \'Season 5 Launch Cohort\').' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cohortStatus rdf:type rdf:Property ;
    rdfs:label 'Cohort Status' ;
    rdfs:comment 'Current lifecycle status of the cohort analysis: active (ongoing measurement), completed (all intervals measured), archived (historical reference), or cancelled (discontinued).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cohortType rdf:type rdf:Property ;
    rdfs:label 'Cohort Type' ;
    rdfs:comment 'Classification of the cohort based on the entry trigger: install cohort (new player acquisition), reactivation cohort (lapsed player return), feature-adoption cohort (new feature engagement), season-start cohort (seasonal content launch), event cohort (special event participation), or segment cohort (custom player segment).' ;
    rdfs:domain ind:RetentionCohortAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionRatePct rdf:type rdf:Property ;
    rdfs:label 'Conversion Rate Pct' ;
    rdfs:comment 'Percentage of cohort players who made at least one in-app purchase (IAP) or microtransaction (MTX) during the measurement period.' ;
    rdfs:domain ind:RetentionCohortAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:d1RetentionRatePct rdf:type rdf:Property ;
    rdfs:label 'D1 Retention Rate Pct' ;
    rdfs:comment 'Percentage of cohort players who returned on Day 1 after entry. Key early engagement metric.' ;
    rdfs:domain ind:RetentionCohortAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:d30RetentionRatePct rdf:type rdf:Property ;
    rdfs:label 'D30 Retention Rate Pct' ;
    rdfs:comment 'Percentage of cohort players who returned on Day 30 after entry. Standard medium-term retention metric.' ;
    rdfs:domain ind:RetentionCohortAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:d7RetentionRatePct rdf:type rdf:Property ;
    rdfs:label 'D7 Retention Rate Pct' ;
    rdfs:comment 'Percentage of cohort players who returned on Day 7 after entry. Critical short-term retention metric.' ;
    rdfs:domain ind:RetentionCohortAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:d90RetentionRatePct rdf:type rdf:Property ;
    rdfs:label 'D90 Retention Rate Pct' ;
    rdfs:comment 'Percentage of cohort players who returned on Day 90 after entry. Long-term engagement and loyalty metric.' ;
    rdfs:domain ind:RetentionCohortAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicFilter rdf:type rdf:Property ;
    rdfs:label 'Geographic Filter' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes this cohort is filtered to (e.g., \'USA,CAN,GBR\'). Empty if cohort includes all geographies.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerCountAtEntry rdf:type rdf:Property ;
    rdfs:label 'Player Count At Entry' ;
    rdfs:comment 'Total number of unique players who entered this cohort during the entry window. Represents the cohort size (denominator for retention rate calculations).' ;
    rdfs:domain ind:RetentionCohortAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retentionMeasurementIntervals rdf:type rdf:Property ;
    rdfs:label 'Retention Measurement Intervals' ;
    rdfs:comment 'Comma-separated list of day offsets from cohort entry at which retention is measured (e.g., \'1,7,14,30,60,90\' for D1/D7/D14/D30/D60/D90 retention). Defines the retention curve measurement points.' ;
    rdfs:domain ind:RetentionCohortAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentFilter rdf:type rdf:Property ;
    rdfs:label 'Segment Filter' ;
    rdfs:comment 'Player segment or audience definition applied to this cohort (e.g., \'high_spenders\', \'casual_players\', \'competitive_pvp\'). Empty if no segment filter applied.' ;
    rdfs:domain ind:RetentionCohortAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionEventSummaryId rdf:type rdf:Property ;
    rdfs:label 'Session Event Summary Id' ;
    rdfs:comment 'Unique identifier for the session event summary record. Primary key for this silver-layer aggregated view.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SessionEventSummary .

ind:buildArtifactId rdf:type rdf:Property ;
    rdfs:label 'Build Artifact Id' ;
    rdfs:comment 'Foreign key linking to title.build_artifact. Business justification: Session summaries require build context for crash rate analysis, performance regression detection (FPS drops in specific builds), and version-specific behavior tracking. Critical for correlating sessi' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BuildArtifact .

ind:buildId rdf:type rdf:Property ;
    rdfs:label 'Build Id' ;
    rdfs:comment 'Specific build identifier of the game client. Provides granular version tracking for Quality Assurance (QA) and release management.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Build .

ind:buildSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Build Submission Id' ;
    rdfs:comment 'Foreign key linking to platform.build_submission. Business justification: Session summaries must track which build generated the session for build quality scoring, crash rate tracking, performance regression detection, and correlating player experience metrics with specific' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BuildSubmission .

ind:aggregationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Aggregation Timestamp' ;
    rdfs:comment 'Timestamp when the raw telemetry events were aggregated into this session summary record. Tracks data processing latency and pipeline performance.' ;
    rdfs:domain ind:SessionEventSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:attributionSource rdf:type rdf:Property ;
    rdfs:label 'Attribution Source' ;
    rdfs:comment 'Marketing attribution source or channel that brought the player to the game (e.g., Facebook Ads, Google UAC, organic). Used for user acquisition analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageFps rdf:type rdf:Property ;
    rdfs:label 'Average Fps' ;
    rdfs:comment 'Average frames per second (FPS) during this session. Key performance indicator for client-side rendering and player experience quality.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clientVersion rdf:type rdf:Property ;
    rdfs:label 'Client Version' ;
    rdfs:comment 'Version number of the game client used during this session. Enables version-specific bug tracking and feature adoption analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:combatEventsCount rdf:type rdf:Property ;
    rdfs:label 'Combat Events Count' ;
    rdfs:comment 'Count of combat-related events (attacks, kills, deaths, damage dealt) during this session. Measures engagement with core gameplay mechanics.' ;
    rdfs:domain ind:SessionEventSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'Data quality score (0-100) indicating completeness and validity of telemetry data for this session. Used for pipeline monitoring and data governance.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distinctEventTypesCount rdf:type rdf:Property ;
    rdfs:label 'Distinct Event Types Count' ;
    rdfs:comment 'Number of unique event types observed in this session. Measures breadth of player interaction with game features.' ;
    rdfs:domain ind:SessionEventSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:economyEventsCount rdf:type rdf:Property ;
    rdfs:label 'Economy Events Count' ;
    rdfs:comment 'Count of in-game economy events (currency earned, items acquired, resources spent) during this session. Tracks virtual economy engagement.' ;
    rdfs:domain ind:SessionEventSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:errorEventsCount rdf:type rdf:Property ;
    rdfs:label 'Error Events Count' ;
    rdfs:comment 'Count of error or exception events logged during this session. Indicates technical issues or bugs encountered by the player.' ;
    rdfs:domain ind:SessionEventSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isFirstSession rdf:type rdf:Property ;
    rdfs:label 'Is First Session' ;
    rdfs:comment 'Boolean flag indicating whether this was the players first gameplay session. Critical for First-Time User Experience (FTUE) and onboarding funnel analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSynthetic rdf:type rdf:Property ;
    rdfs:label 'Is Synthetic' ;
    rdfs:comment 'Boolean flag indicating whether this session was generated by automated testing or bots rather than real players. Used to filter test data from production analytics.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monetizationEventsCount rdf:type rdf:Property ;
    rdfs:label 'Monetization Events Count' ;
    rdfs:comment 'Count of monetization events (In-App Purchases (IAP), microtransactions (MTX), store views, purchase attempts) during this session. Key revenue indicator.' ;
    rdfs:domain ind:SessionEventSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:networkType rdf:type rdf:Property ;
    rdfs:label 'Network Type' ;
    rdfs:comment 'Type of network connection used during the session. Helps diagnose connectivity issues and optimize for different network conditions.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peakActionsPerMinute rdf:type rdf:Property ;
    rdfs:label 'Peak Actions Per Minute' ;
    rdfs:comment 'Maximum number of player actions recorded in any single minute during the session. Indicates peak engagement intensity and skill level.' ;
    rdfs:domain ind:SessionEventSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pipelineIngestionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pipeline Ingestion Timestamp' ;
    rdfs:comment 'Timestamp when this session summary record was ingested into the silver layer by the data pipeline. Used for data freshness monitoring and Extract Transform Load (ETL) auditing.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:progressionEventsCount rdf:type rdf:Property ;
    rdfs:label 'Progression Events Count' ;
    rdfs:comment 'Count of player progression events (level ups, quest completions, achievements unlocked, skill upgrades) during this session. Tracks advancement through game content.' ;
    rdfs:domain ind:SessionEventSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serverRegion rdf:type rdf:Property ;
    rdfs:label 'Server Region' ;
    rdfs:comment 'Geographic region of the game server that hosted this session. Used for latency analysis and infrastructure capacity planning.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionDate rdf:type rdf:Property ;
    rdfs:label 'Session Date' ;
    rdfs:comment 'Calendar date on which the session occurred (derived from session start timestamp). Partitioning key for efficient time-series queries.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sessionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session End Timestamp' ;
    rdfs:comment 'Timestamp of the last event fired in this session. Represents the moment the player ended or exited gameplay.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionQualityScore rdf:type rdf:Property ;
    rdfs:label 'Session Quality Score' ;
    rdfs:comment 'Composite quality score (0-100) for this session based on technical performance metrics (FPS, latency, error rate). Used for experience quality monitoring.' ;
    rdfs:domain ind:SessionEventSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sessionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session Start Timestamp' ;
    rdfs:comment 'Timestamp of the first event fired in this session. Represents the moment the player began gameplay.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:socialEventsCount rdf:type rdf:Property ;
    rdfs:label 'Social Events Count' ;
    rdfs:comment 'Count of social interaction events (chat messages, friend requests, guild actions, party invites) during this session. Tracks community engagement.' ;
    rdfs:domain ind:SessionEventSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalEventsFired rdf:type rdf:Property ;
    rdfs:label 'Total Events Fired' ;
    rdfs:comment 'Total count of telemetry events emitted during this session. Indicates player activity intensity and data volume.' ;
    rdfs:domain ind:SessionEventSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPlaytimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Total Playtime Seconds' ;
    rdfs:comment 'Total duration of the session in seconds, calculated as the difference between session end and start timestamps. Key metric for engagement analysis.' ;
    rdfs:domain ind:SessionEventSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:telemetryEventId rdf:type rdf:Property ;
    rdfs:label 'Telemetry Event Id' ;
    rdfs:comment 'Unique identifier for the telemetry event record. Primary key for the immutable event stream. Inferred role: EVENT_LOG.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TelemetryEvent .

ind:billingPromoCodeId rdf:type rdf:Property ;
    rdfs:label 'Billing Promo Code Id' ;
    rdfs:comment 'Foreign key linking to billing.promo_code. Business justification: Promo code impression and click events must link to promo codes for campaign effectiveness measurement, attribution analysis, and ROI calculation—essential for marketing analytics.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromoCode .

ind:crossplayFeatureId rdf:type rdf:Property ;
    rdfs:label 'Crossplay Feature Id' ;
    rdfs:comment 'Foreign key linking to platform.crossplay_feature. Business justification: Crossplay events must tag which crossplay feature configuration was active for cross-platform balance analysis, input method fairness validation, and measuring crossplay adoption impact on matchmaking' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CrossplayFeature .

ind:deviceId rdf:type rdf:Property ;
    rdfs:label 'Device Id' ;
    rdfs:comment 'Unique identifier for the device. Platform-specific (IDFA for iOS, GAID for Android, console hardware ID). Used for device-level attribution, fraud detection, and multi-device player tracking. Subject to GDPR, COPPA, and platform privacy policies.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Device .

ind:gameServerId rdf:type rdf:Property ;
    rdfs:label 'Game Server Id' ;
    rdfs:comment 'Identifier of the specific game server instance that processed the event. Used for server-level performance troubleshooting, load balancing analysis, and incident correlation.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GameServer .

ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: In-game purchase events (IAP, DLC) generate invoices. Real-time revenue attribution and conversion funnel analysis require linking telemetry events to resulting invoices for accurate monetization trac' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:matchId rdf:type rdf:Property ;
    rdfs:label 'Match Id' ;
    rdfs:comment 'Foreign key linking to esports.match. Business justification: Telemetry events during esports matches should reference the match for competitive analytics, replay analysis, and tournament statistics. This enables detailed performance analysis of competitive game' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Match .

ind:moderationActionId rdf:type rdf:Property ;
    rdfs:label 'Moderation Action Id' ;
    rdfs:comment 'Foreign key linking to community.moderation_action. Business justification: Moderation events (bans, warnings, appeals, content removals) tracked in telemetry for trust & safety analytics, policy effectiveness measurement, and regulatory compliance reporting in community mode' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ModerationAction .

ind:patchReleaseId rdf:type rdf:Property ;
    rdfs:label 'Patch Release Id' ;
    rdfs:comment 'Foreign key linking to platform.patch_release. Business justification: Telemetry must track which patch version generated each event for patch impact analysis, measuring patch effectiveness, identifying patch-introduced regressions, and making rollback decisions. Critica' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PatchRelease .

ind:platformCertSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Platform Cert Submission Id' ;
    rdfs:comment 'Foreign key linking to platform.cert_submission. Business justification: Post-certification telemetry links events to the certified submission for production quality monitoring, TRC/TCR compliance verification, and identifying issues that passed cert but fail in production' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlatformCertSubmission .

ind:telemetryPipelineId rdf:type rdf:Property ;
    rdfs:label 'Telemetry Pipeline Id' ;
    rdfs:comment 'Foreign key linking to analytics.telemetry_pipeline. Business justification: telemetry_event records are ingested through specific telemetry pipelines. Each event is processed by one pipeline. Adding telemetry_pipeline_id FK allows tracking which pipeline ingested each event, ' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TelemetryPipeline .

ind:eventPayload rdf:type rdf:Property ;
    rdfs:label 'Event Payload' ;
    rdfs:comment 'JSON-serialized payload containing event-specific attributes and context. Structure varies by event_type and event_name. Contains game-specific data such as coordinates, item IDs, damage values, currency amounts, UI element identifiers, etc.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventProcessingStatus rdf:type rdf:Property ;
    rdfs:label 'Event Processing Status' ;
    rdfs:comment 'Current processing state of the event in the telemetry pipeline. Raw: just ingested. Validated: schema-validated. Enriched: joined with dimension data. Failed: validation or enrichment error. Used for pipeline monitoring and data quality tracking.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSchemaVersion rdf:type rdf:Property ;
    rdfs:label 'Event Schema Version' ;
    rdfs:comment 'Semantic version of the event payload schema. Enables backward-compatible evolution of event structures and payload parsing logic. Format: major.minor.patch (e.g., 1.2.0).' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Event Size Bytes' ;
    rdfs:comment 'Size of the event payload in bytes. Used for bandwidth analysis, cost optimization, and payload compression effectiveness tracking.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Client-side timestamp when the event was generated by the game client or server. Represents the real-world moment of the in-game action or state change. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'IP address of the client at the time of event generation. Used for geolocation enrichment, fraud detection, and regional latency analysis. May be considered PII under GDPR in certain jurisdictions.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serverIngestionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Server Ingestion Timestamp' ;
    rdfs:comment 'Server-side timestamp when the event was received and ingested by the telemetry pipeline. Used for latency analysis and event ordering reconciliation. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Session Sequence Number' ;
    rdfs:comment 'Ordinal position of this event within the session. Used for event ordering, funnel step sequencing, and session replay reconstruction.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceEventId rdf:type rdf:Property ;
    rdfs:label 'Compliance Event Id' ;
    rdfs:comment 'Foreign key linking to platform.compliance_event. Business justification: Compliance violations often trigger pipeline audits and data quality investigations. Pipelines must link to compliance events that surfaced violations for root cause analysis, remediation tracking, an' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceEvent .

ind:complianceObligationId rdf:type rdf:Property ;
    rdfs:label 'Compliance Obligation Id' ;
    rdfs:comment 'Foreign key linking to licensing.compliance_obligation. Business justification: Compliance requirements (COPPA, GDPR, rating board restrictions) dictate pipeline data handling. Pipelines must enforce obligation-specific filtering, retention, and anonymization. Real business proce' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceObligation .

ind:developerAccountId rdf:type rdf:Property ;
    rdfs:label 'Developer Account Id' ;
    rdfs:comment 'Foreign key linking to platform.developer_account. Business justification: Pipelines are provisioned per developer account for access control, cost allocation, and data isolation. Required for multi-studio publishers managing separate analytics infrastructure per studio and ' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeveloperAccount .

ind:sdkIntegrationId rdf:type rdf:Property ;
    rdfs:label 'Sdk Integration Id' ;
    rdfs:comment 'Foreign key linking to platform.sdk_integration. Business justification: Pipelines ingest data from specific SDK integrations; each pipeline is configured for SDK version-specific telemetry schemas, event formats, and platform capabilities. Required for pipeline schema val' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SdkIntegration .

ind:activeFromDate rdf:type rdf:Property ;
    rdfs:label 'Active From Date' ;
    rdfs:comment 'Date when this pipeline was first activated and began processing telemetry data. Marks the start of the pipeline\'s operational lifecycle.' ;
    rdfs:domain ind:TelemetryPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activeUntilDate rdf:type rdf:Property ;
    rdfs:label 'Active Until Date' ;
    rdfs:comment 'Date when this pipeline is scheduled to be decommissioned or deprecated. Null for pipelines with no planned end date.' ;
    rdfs:domain ind:TelemetryPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:alertingChannel rdf:type rdf:Property ;
    rdfs:label 'Alerting Channel' ;
    rdfs:comment 'Slack channel, PagerDuty service, or email distribution list for pipeline failure alerts. Used for incident notification routing.' ;
    rdfs:domain ind:TelemetryPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageLatencySeconds rdf:type rdf:Property ;
    rdfs:label 'Average Latency Seconds' ;
    rdfs:comment 'Rolling average end-to-end latency in seconds over the last 24 hours. Used to track performance against SLA targets.' ;
    rdfs:domain ind:TelemetryPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coppaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Coppa Compliant Flag' ;
    rdfs:comment 'Indicates whether the pipeline implements COPPA-required controls for games with users under 13 years old, including parental consent verification.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'Financial cost center code for chargeback of pipeline compute and storage costs. Used for budget tracking and cost allocation.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'Username or identifier of the person who created this pipeline record. Used for audit trail and accountability.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalityLevel rdf:type rdf:Property ;
    rdfs:label 'Criticality Level' ;
    rdfs:comment 'Business criticality classification of the pipeline. Critical pipelines require 24/7 monitoring and immediate incident response.' ;
    rdfs:domain ind:TelemetryPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataEngineeringTeam rdf:type rdf:Property ;
    rdfs:label 'Data Engineering Team' ;
    rdfs:comment 'Name of the data engineering team responsible for maintaining and operating this pipeline. Used for incident routing and ownership tracking.' ;
    rdfs:domain ind:TelemetryPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataVolumeTier rdf:type rdf:Property ;
    rdfs:label 'Data Volume Tier' ;
    rdfs:comment 'Classification of expected data volume throughput for capacity planning and resource allocation. Low: <1M events/day, Medium: 1M-10M, High: 10M-100M, Very High: >100M.' ;
    rdfs:domain ind:TelemetryPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Encryption Enabled Flag' ;
    rdfs:comment 'Indicates whether data-at-rest encryption is enabled for the target Silver Layer table. Required for pipelines processing sensitive data.' ;
    rdfs:domain ind:TelemetryPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eventsPerDayEstimate rdf:type rdf:Property ;
    rdfs:label 'Events Per Day Estimate' ;
    rdfs:comment 'Estimated number of telemetry events processed by this pipeline per day. Used for capacity planning and cost forecasting.' ;
    rdfs:domain ind:TelemetryPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failureCountLast24h rdf:type rdf:Property ;
    rdfs:label 'Failure Count Last 24h' ;
    rdfs:comment 'Number of pipeline execution failures in the last 24 hours. Used for alerting and health monitoring.' ;
    rdfs:domain ind:TelemetryPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gdprCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliant Flag' ;
    rdfs:comment 'Indicates whether the pipeline implements GDPR-required controls such as data minimization, pseudonymization, and right-to-erasure support.' ;
    rdfs:domain ind:TelemetryPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ingestionMode rdf:type rdf:Property ;
    rdfs:label 'Ingestion Mode' ;
    rdfs:comment 'Data ingestion pattern used by the pipeline. Streaming for real-time continuous processing, micro-batch for near-real-time windowed processing, batch for scheduled bulk loads.' ;
    rdfs:domain ind:TelemetryPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastFailureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Failure Timestamp' ;
    rdfs:comment 'Timestamp of the most recent pipeline failure. Used for failure pattern analysis and mean time to recovery (MTTR) calculation.' ;
    rdfs:domain ind:TelemetryPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastSuccessfulRunTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Successful Run Timestamp' ;
    rdfs:comment 'Timestamp of the most recent successful pipeline execution. Used to detect stale pipelines and calculate uptime metrics.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'Username or identifier of the person who last modified this pipeline record. Used for audit trail and change tracking.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringDashboardUrl rdf:type rdf:Property ;
    rdfs:label 'Monitoring Dashboard Url' ;
    rdfs:comment 'URL to the operational monitoring dashboard for this pipeline. Provides real-time visibility into pipeline health, throughput, and latency metrics.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peakEventsPerSecond rdf:type rdf:Property ;
    rdfs:label 'Peak Events Per Second' ;
    rdfs:comment 'Maximum observed event throughput in events per second. Used for capacity planning and infrastructure scaling decisions.' ;
    rdfs:domain ind:TelemetryPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:piiDataFlag rdf:type rdf:Property ;
    rdfs:label 'Pii Data Flag' ;
    rdfs:comment 'Indicates whether this pipeline processes telemetry events containing PII. True if PII is present, requiring additional compliance controls.' ;
    rdfs:domain ind:TelemetryPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pipelineCode rdf:type rdf:Property ;
    rdfs:label 'Pipeline Code' ;
    rdfs:comment 'Unique business identifier code for the pipeline. Used in configuration files, monitoring systems, and operational runbooks.' ;
    rdfs:domain ind:TelemetryPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineDescription rdf:type rdf:Property ;
    rdfs:label 'Pipeline Description' ;
    rdfs:comment 'Detailed business description of the pipeline\'s purpose, data sources, and use cases. Used for documentation and knowledge transfer.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineName rdf:type rdf:Property ;
    rdfs:label 'Pipeline Name' ;
    rdfs:comment 'Human-readable name of the telemetry pipeline. Used for operational identification and monitoring dashboards.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineStatus rdf:type rdf:Property ;
    rdfs:label 'Pipeline Status' ;
    rdfs:comment 'Current operational status of the telemetry pipeline. Indicates whether the pipeline is actively processing data or in a non-operational state.' ;
    rdfs:domain ind:TelemetryPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineType rdf:type rdf:Property ;
    rdfs:label 'Pipeline Type' ;
    rdfs:comment 'Classification of the telemetry pipeline based on the nature of data it processes. Determines processing patterns and SLA requirements.' ;
    rdfs:domain ind:TelemetryPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformRegion rdf:type rdf:Property ;
    rdfs:label 'Platform Region' ;
    rdfs:comment 'Geographic region or cloud availability zone where the pipeline infrastructure is deployed. Three-letter uppercase code (e.g., USE for US East, EUR for Europe).' ;
    rdfs:domain ind:TelemetryPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaLatencyTargetSeconds rdf:type rdf:Property ;
    rdfs:label 'Sla Latency Target Seconds' ;
    rdfs:comment 'Maximum acceptable end-to-end latency in seconds from event generation to Silver Layer availability. Used for SLA monitoring and alerting.' ;
    rdfs:domain ind:TelemetryPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceEventTopic rdf:type rdf:Property ;
    rdfs:label 'Source Event Topic' ;
    rdfs:comment 'Kafka or Kinesis topic name from which the pipeline ingests raw telemetry events. Primary source identifier for event streaming.' ;
    rdfs:domain ind:TelemetryPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSilverTable rdf:type rdf:Property ;
    rdfs:label 'Target Silver Table' ;
    rdfs:comment 'Fully qualified name of the target Silver Layer table in the lakehouse where processed telemetry data is written. Format: schema.table_name.' ;
    rdfs:domain ind:TelemetryPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transformationLogicVersion rdf:type rdf:Property ;
    rdfs:label 'Transformation Logic Version' ;
    rdfs:comment 'Version identifier of the data transformation logic applied by this pipeline. Links to code repository tags or release versions.' ;
    rdfs:domain ind:TelemetryPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uptimePercentageLast30d rdf:type rdf:Property ;
    rdfs:label 'Uptime Percentage Last 30d' ;
    rdfs:comment 'Calculated uptime percentage for the pipeline over the last 30 days. Used for SLA compliance reporting and operational health tracking.' ;
    rdfs:domain ind:TelemetryPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'Externally visible unique account number for customer service and billing correspondence. Format: BA followed by 10 digits.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the billing account. Active accounts can transact; suspended accounts are temporarily blocked; closed accounts are permanently terminated; under-review accounts are flagged for fraud investigation; pending-activation accounts await verification; delinquent accounts have overdue payments.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountTier rdf:type rdf:Property ;
    rdfs:label 'Account Tier' ;
    rdfs:comment 'Segmentation tier based on lifetime spend and engagement. Standard represents typical players; premium represents moderate spenders; VIP represents high-value players; whale represents top-tier spenders with dedicated account management.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activated Timestamp' ;
    rdfs:comment 'Timestamp when the billing account was activated and became eligible for transactions. May differ from creation timestamp if verification was required.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:autoRenewEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Renew Enabled' ;
    rdfs:comment 'Boolean indicator whether automatic renewal is enabled for recurring subscriptions on this account. False requires manual renewal by player.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:balance rdf:type rdf:Property ;
    rdfs:label 'Balance' ;
    rdfs:comment 'Current store credit or wallet balance available for purchases. Positive balance represents prepaid funds; negative balance represents outstanding debt. Denominated in preferred currency.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line1' ;
    rdfs:comment 'Primary street address line for billing correspondence and tax jurisdiction determination.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line2' ;
    rdfs:comment 'Secondary address line for apartment, suite, or unit number.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCity rdf:type rdf:Property ;
    rdfs:label 'Billing City' ;
    rdfs:comment 'City name for billing address.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Billing Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for billing address. Determines applicable tax rules, payment methods, and regulatory requirements.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Postal Code' ;
    rdfs:comment 'Postal or ZIP code for billing address. Critical for tax jurisdiction and fraud detection.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Billing State Province' ;
    rdfs:comment 'State, province, or region code for billing address. Used for sales tax calculation.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackCount rdf:type rdf:Property ;
    rdfs:label 'Chargeback Count' ;
    rdfs:comment 'Total number of chargebacks filed against this account. High chargeback rates may result in account suspension and increased fraud scrutiny.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Timestamp when the billing account was permanently closed. Null for active accounts.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataRetentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Data Retention Expiry Date' ;
    rdfs:comment 'Date when billing account data must be purged or anonymized per GDPR right-to-erasure or internal data retention policies. Null for active accounts with ongoing retention requirements.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dunningCycleCount rdf:type rdf:Property ;
    rdfs:label 'Dunning Cycle Count' ;
    rdfs:comment 'Number of dunning cycles (payment retry attempts) executed for the current outstanding balance. Resets to zero when balance is cleared.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dunningStatus rdf:type rdf:Property ;
    rdfs:label 'Dunning Status' ;
    rdfs:comment 'Current stage in the payment recovery process for failed recurring charges. None indicates no outstanding issues; soft-dunning represents initial retry attempts; hard-dunning indicates escalated recovery; final-notice is last warning before suspension; collections indicates account sent to external recovery.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failedTransactionCount rdf:type rdf:Property ;
    rdfs:label 'Failed Transaction Count' ;
    rdfs:comment 'Cumulative count of failed payment transactions on this account. High failure rates trigger fraud alerts and dunning workflows.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fraudFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Flag' ;
    rdfs:comment 'Boolean indicator whether the account has been flagged for suspected fraudulent activity. True triggers additional verification steps for transactions.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fraudRiskScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Risk Score' ;
    rdfs:comment 'Calculated fraud risk score ranging from 0.00 (lowest risk) to 100.00 (highest risk). Generated by fraud detection algorithms based on transaction patterns, device fingerprints, and behavioral analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gdprConsentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Timestamp' ;
    rdfs:comment 'Timestamp when the player provided explicit consent for processing billing and payment data under GDPR Article 6. Required for EU players.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastFailedTransactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Failed Transaction Timestamp' ;
    rdfs:comment 'Timestamp of the most recent failed payment transaction. Used to trigger dunning workflows and fraud alerts.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastSuccessfulTransactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Successful Transaction Timestamp' ;
    rdfs:comment 'Timestamp of the most recent successful payment transaction on this account. Used for account activity monitoring and churn prediction.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lifetimeSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Lifetime Spend Amount' ;
    rdfs:comment 'Total cumulative amount spent by this billing account across all transactions since account creation. Denominated in the accounts preferred currency. Used for player segmentation and LTV (Lifetime Value) analysis.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketingOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In Flag' ;
    rdfs:comment 'Boolean indicator whether the player has consented to receive promotional offers and marketing communications related to billing and monetization. Required for GDPR and CAN-SPAM compliance.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentalConsentVerified rdf:type rdf:Property ;
    rdfs:label 'Parental Consent Verified' ;
    rdfs:comment 'Boolean indicator whether parental consent has been verified for accounts subject to COPPA or similar child protection regulations. Required before processing payments for minors.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pciComplianceScope rdf:type rdf:Property ;
    rdfs:label 'Pci Compliance Scope' ;
    rdfs:comment 'Indicates whether this account stores payment card data subject to PCI DSS requirements. In-scope accounts require full compliance controls; out-of-scope accounts do not handle card data; tokenized-only accounts use vault tokens exclusively.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the players preferred currency for pricing display and billing. Transactions may still settle in platform currency.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundCount rdf:type rdf:Property ;
    rdfs:label 'Refund Count' ;
    rdfs:comment 'Total number of refunds issued to this account. Used for customer satisfaction analysis and fraud pattern detection.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subscriptionActiveFlag rdf:type rdf:Property ;
    rdfs:label 'Subscription Active Flag' ;
    rdfs:comment 'Boolean indicator whether the account has at least one active recurring subscription (e.g., battle pass, premium membership). Used for churn analysis and retention campaigns.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:successfulTransactionCount rdf:type rdf:Property ;
    rdfs:label 'Successful Transaction Count' ;
    rdfs:comment 'Cumulative count of successful payment transactions on this account. Used to calculate transaction success rate.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxExemptionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Certificate Number' ;
    rdfs:comment 'Government-issued certificate number supporting tax exemption claim. Required for audit trail when tax_exemption_status is exempt or partial.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Expiry Date' ;
    rdfs:comment 'Date when the tax exemption certificate expires and must be renewed. Null for permanent exemptions or non-exempt accounts.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxExemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Status' ;
    rdfs:comment 'Indicates whether the account qualifies for sales tax exemption. Exempt accounts bypass tax calculation; partial exemptions apply reduced rates; pending-verification accounts await documentation review.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalTransactionCount rdf:type rdf:Property ;
    rdfs:label 'Total Transaction Count' ;
    rdfs:comment 'Cumulative count of all payment transactions (successful and failed) processed on this account since creation. Used for engagement and fraud analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingTaxRecordId rdf:type rdf:Property ;
    rdfs:label 'Billing Tax Record Id' ;
    rdfs:comment 'Unique identifier for the billing tax record. Primary key for this entity.' ;
    rdfs:domain ind:BillingTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:legalEntityId rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to finance.legal_entity. Business justification: Tax records must tie to the legal entity responsible for tax remittance and filing. Gaming companies file VAT/sales tax returns by legal entity; this link enables tax compliance reporting and audit de' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:reviewedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reviewed By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Complex tax jurisdictions (VAT MOSS, digital services tax, nexus determinations) require manual review by finance/tax team before filing. Reviewer tracking is mandatory for compliance audit trails, ta' ;
    rdfs:domain ind:BillingTaxRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Reference identifier linking this tax record to detailed audit logs, supporting documentation, or compliance evidence. Used for tax authority audits and internal compliance reviews.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Billing Transaction Reference' ;
    rdfs:comment 'Reference to the parent billing transaction for which this tax was calculated and collected. Links this tax record to the underlying purchase, refund, or chargeback event.' ;
    rdfs:domain ind:BillingTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the taxable_amount and tax_amount (e.g., USD, EUR, GBP, JPY).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerBusinessFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Business Flag' ;
    rdfs:comment 'Indicates whether the customer is a business entity (True) or a consumer (False). Affects tax treatment (e.g., B2B reverse charge vs B2C standard VAT).' ;
    rdfs:domain ind:BillingTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerTaxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Customer Tax Identifier' ;
    rdfs:comment 'The customers tax identification number (e.g., VAT number for B2B transactions, EIN, TIN) if provided and relevant for tax reporting. Nullable for B2C transactions. Confidential business data.' ;
    rdfs:domain ind:BillingTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Filing Period End Date' ;
    rdfs:comment 'The end date of the tax filing period (month, quarter, or year) to which this tax record belongs. Used for aggregating tax liability for periodic filings.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingPeriodReference rdf:type rdf:Property ;
    rdfs:label 'Filing Period Reference' ;
    rdfs:comment 'Human-readable reference for the filing period (e.g., 2024-Q1, 2024-03, 2024-Annual). Used for reporting and reconciliation.' ;
    rdfs:domain ind:BillingTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Filing Period Start Date' ;
    rdfs:comment 'The start date of the tax filing period (month, quarter, or year) to which this tax record belongs. Used for aggregating tax liability for periodic filings.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nexusDeterminationBasis rdf:type rdf:Property ;
    rdfs:label 'Nexus Determination Basis' ;
    rdfs:comment 'The legal or business basis for establishing tax nexus in this jurisdiction (e.g., physical presence, economic nexus threshold, marketplace facilitator law, customer location). Critical for US state sales tax compliance.' ;
    rdfs:domain ind:BillingTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformHolder rdf:type rdf:Property ;
    rdfs:label 'Platform Holder' ;
    rdfs:comment 'The digital storefront or platform through which the transaction was processed. Determines tax collection responsibility under platform-specific agreements (e.g., Steam collects VAT in EU, Apple collects sales tax in US). [ENUM-REF-CANDIDATE: steam|epic|playstation|xbox|nintendo|apple|google — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BillingTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformTaxCollectionFlag rdf:type rdf:Property ;
    rdfs:label 'Platform Tax Collection Flag' ;
    rdfs:comment 'Indicates whether the platform holder (e.g., Steam, Apple) collected and will remit the tax on behalf of the publisher (True), or whether the publisher is responsible for collection and remittance (False).' ;
    rdfs:domain ind:BillingTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productTaxabilityCategory rdf:type rdf:Property ;
    rdfs:label 'Product Taxability Category' ;
    rdfs:comment 'Classification of the product or service for tax purposes (e.g., electronically supplied services, digital content, tangible personal property, software-as-a-service). Determines applicable tax rules.' ;
    rdfs:domain ind:BillingTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reverseChargeFlag rdf:type rdf:Property ;
    rdfs:label 'Reverse Charge Flag' ;
    rdfs:comment 'Indicates whether the reverse charge mechanism applies (True) or not (False). Under reverse charge, the customer (not the seller) is responsible for remitting VAT. Common in B2B cross-border EU transactions.' ;
    rdfs:domain ind:BillingTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'The actual tax amount calculated and collected from the player, in the transaction currency. Equals taxable_amount multiplied by tax_rate, subject to rounding rules.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Tax Authority Name' ;
    rdfs:comment 'Name of the government tax authority to which the tax is owed (e.g., HM Revenue & Customs, IRS, California Department of Tax and Fee Administration, Bundeszentralamt für Steuern).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAuthorityReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Authority Reference Number' ;
    rdfs:comment 'Reference number or transaction identifier assigned by the tax authority for this remittance or filing. Nullable if not yet assigned.' ;
    rdfs:domain ind:BillingTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCalculationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Tax Calculation Timestamp' ;
    rdfs:comment 'The date and time when the tax was calculated for this transaction. Captures the moment the tax engine determined the applicable rate and amount.' ;
    rdfs:domain ind:BillingTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'Internal or external tax code representing the tax treatment category for this transaction (e.g., digital goods, software license, in-game currency). Maps to tax engine product taxability rules.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxEngineName rdf:type rdf:Property ;
    rdfs:label 'Tax Engine Name' ;
    rdfs:comment 'Name or identifier of the tax calculation engine or service used to determine the tax (e.g., Avalara, Vertex, TaxJar, internal tax engine). Supports audit and troubleshooting.' ;
    rdfs:domain ind:BillingTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxEngineVersion rdf:type rdf:Property ;
    rdfs:label 'Tax Engine Version' ;
    rdfs:comment 'Version number of the tax calculation engine or tax rate database used at the time of calculation. Supports reproducibility and audit.' ;
    rdfs:domain ind:BillingTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionCertificateReference rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Certificate Reference' ;
    rdfs:comment 'Reference number or identifier of the tax exemption certificate on file, if the exemption was granted based on a certificate provided by the customer. Nullable if no certificate applies.' ;
    rdfs:domain ind:BillingTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Flag' ;
    rdfs:comment 'Indicates whether this transaction qualified for a tax exemption. True if exempt, False if tax was applied normally.' ;
    rdfs:domain ind:BillingTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxExemptionReason rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Reason' ;
    rdfs:comment 'Business reason or regulatory basis for the tax exemption, if applicable (e.g., educational institution, government entity, below de minimis threshold, reverse charge mechanism). Nullable if no exemption applies.' ;
    rdfs:domain ind:BillingTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Invoice Number' ;
    rdfs:comment 'The invoice number on which this tax was reported to the customer. Links the tax record to the customer-facing invoice document. Nullable if no formal invoice was issued.' ;
    rdfs:domain ind:BillingTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCountry rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the country-level tax jurisdiction where the tax obligation arises (e.g., USA, GBR, DEU, JPN).' ;
    rdfs:domain ind:BillingTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionMunicipality rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Municipality' ;
    rdfs:comment 'City, county, or local municipality name where the tax obligation arises. Nullable for jurisdictions without municipal-level tax.' ;
    rdfs:domain ind:BillingTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionStateProvince rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction State Province' ;
    rdfs:comment 'State, province, or first-level administrative subdivision code where the tax obligation arises (e.g., CA for California, ON for Ontario). Nullable for countries without state-level tax.' ;
    rdfs:domain ind:BillingTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate' ;
    rdfs:comment 'The tax rate applied to the taxable amount, expressed as a decimal (e.g., 0.200000 for 20% VAT, 0.0875 for 8.75% sales tax). Supports up to six decimal places for precision in complex jurisdictions.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxRemittanceDate rdf:type rdf:Property ;
    rdfs:label 'Tax Remittance Date' ;
    rdfs:comment 'The date on which the collected tax was (or will be) remitted to the tax authority. Nullable if remittance has not yet occurred.' ;
    rdfs:domain ind:BillingTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxRemittanceStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Remittance Status' ;
    rdfs:comment 'Current status of tax remittance to the tax authority. Pending: collected but not yet remitted; Remitted: paid to authority; Deferred: scheduled for future remittance; Disputed: under audit or dispute; Refunded: returned to customer.' ;
    rdfs:domain ind:BillingTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxType rdf:type rdf:Property ;
    rdfs:label 'Tax Type' ;
    rdfs:comment 'Type of tax applied to the transaction. VAT (Value-Added Tax) for EU and other jurisdictions, GST (Goods and Services Tax) for Canada/Australia/India, sales_tax for US state/local, digital_services_tax for DST regimes, withholding_tax for cross-border payments, consumption_tax for Japan.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxableAmount rdf:type rdf:Property ;
    rdfs:label 'Taxable Amount' ;
    rdfs:comment 'The base amount subject to tax, in the transaction currency. This is the pre-tax subtotal on which the tax rate is applied. For VAT, this is the net amount; for sales tax, this is the gross sale amount.' ;
    rdfs:domain ind:BillingTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vatMossSchemeFlag rdf:type rdf:Property ;
    rdfs:label 'Vat Moss Scheme Flag' ;
    rdfs:comment 'Indicates whether this transaction was reported under the EU VAT Mini One Stop Shop scheme (True) or through standard VAT registration in each member state (False). MOSS simplifies VAT compliance for digital services sold to EU consumers.' ;
    rdfs:domain ind:BillingTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vatRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Vat Registration Number' ;
    rdfs:comment 'The VAT registration number of the entity responsible for remitting the tax (either the publisher or the platform holder). Format varies by jurisdiction (e.g., GB123456789, DE123456789). Nullable if not applicable.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackId rdf:type rdf:Property ;
    rdfs:label 'Chargeback Id' ;
    rdfs:comment 'Unique identifier for the chargeback record. Primary key.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Chargeback .

ind:complianceIncidentId rdf:type rdf:Property ;
    rdfs:label 'Compliance Incident Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_incident. Business justification: High-value chargebacks or patterns trigger compliance incidents for fraud investigation and AML reporting. Gaming companies must link chargebacks to incidents for regulatory filings (FinCEN, card netw' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceIncident .

ind:defectId rdf:type rdf:Property ;
    rdfs:label 'Defect Id' ;
    rdfs:comment 'Foreign key linking to quality.defect. Business justification: Chargebacks often result from game-breaking bugs preventing content delivery. Finance teams link chargeback cases to defects for dispute evidence, quality accountability reporting, and to quantify qua' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Defect .

ind:iapTransactionId rdf:type rdf:Property ;
    rdfs:label 'Iap Transaction Id' ;
    rdfs:comment 'Foreign key linking to monetization.iap_transaction. Business justification: Chargebacks on IAP transactions drive fraud analysis, entitlement revocation, and dispute resolution. Financial operations require linking chargebacks to originating IAP transactions for evidence subm' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IapTransaction .

ind:acquiringBank rdf:type rdf:Property ;
    rdfs:label 'Acquiring Bank' ;
    rdfs:comment 'Merchant\'s bank or payment processor that acquired the original transaction and is handling the chargeback response.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'Monetary value of the disputed transaction being charged back to the merchant.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arbitrationFee rdf:type rdf:Property ;
    rdfs:label 'Arbitration Fee' ;
    rdfs:comment 'Additional fee charged by the card network for arbitration proceedings if the dispute is escalated beyond standard chargeback resolution.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arbitrationRequested rdf:type rdf:Property ;
    rdfs:label 'Arbitration Requested' ;
    rdfs:comment 'Flag indicating whether the merchant has escalated the dispute to card network arbitration after losing the initial chargeback.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assignedTo rdf:type rdf:Property ;
    rdfs:label 'Assigned To' ;
    rdfs:comment 'Name or identifier of the billing operations team member or fraud analyst assigned to handle this chargeback case.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardLastFour rdf:type rdf:Property ;
    rdfs:label 'Card Last Four' ;
    rdfs:comment 'Last four digits of the payment card involved in the disputed transaction, used for identification while maintaining PCI DSS compliance.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardNetwork rdf:type rdf:Property ;
    rdfs:label 'Card Network' ;
    rdfs:comment 'Payment card network that processed the original transaction and is handling the chargeback (Visa, Mastercard, American Express, Discover, JCB, UnionPay).' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardholderName rdf:type rdf:Property ;
    rdfs:label 'Cardholder Name' ;
    rdfs:comment 'Name of the cardholder as it appears on the payment card used for the disputed transaction.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Internal case tracking number assigned by the billing or fraud team for dispute management.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackNumber rdf:type rdf:Property ;
    rdfs:label 'Chargeback Number' ;
    rdfs:comment 'Externally-known unique identifier for the chargeback case, typically provided by the card network or payment processor.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackStatus rdf:type rdf:Property ;
    rdfs:label 'Chargeback Status' ;
    rdfs:comment 'Current lifecycle status of the chargeback dispute. Tracks progression from initial receipt through final resolution.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceFingerprint rdf:type rdf:Property ;
    rdfs:label 'Device Fingerprint' ;
    rdfs:comment 'Unique identifier for the device used to make the original purchase, used for fraud detection and pattern analysis.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeCategory rdf:type rdf:Property ;
    rdfs:label 'Dispute Category' ;
    rdfs:comment 'High-level categorization of the chargeback type for reporting and analysis purposes. [ENUM-REF-CANDIDATE: fraud|authorization|processing-error|consumer-dispute|not-as-described|duplicate|service-not-rendered — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason Code' ;
    rdfs:comment 'Standardized reason code provided by the card network indicating the basis for the chargeback (e.g., fraud, not-as-described, duplicate charge, service not rendered). Codes vary by card network (Visa, Mastercard, Amex, Discover).' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason Description' ;
    rdfs:comment 'Human-readable description of the dispute reason, providing additional context beyond the reason code.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceDocuments rdf:type rdf:Property ;
    rdfs:label 'Evidence Documents' ;
    rdfs:comment 'References or identifiers for supporting documentation submitted to contest the chargeback (receipts, terms of service, delivery confirmation, player activity logs).' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Evidence Submission Date' ;
    rdfs:comment 'Date when supporting evidence and documentation were submitted to contest the chargeback.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fee rdf:type rdf:Property ;
    rdfs:label 'Fee' ;
    rdfs:comment 'Administrative fee charged by the payment processor or card network for handling the chargeback, separate from the disputed amount.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fraudIndicator rdf:type rdf:Property ;
    rdfs:label 'Fraud Indicator' ;
    rdfs:comment 'Flag indicating whether the chargeback was categorized as fraudulent activity (true) or a legitimate customer dispute (false).' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fraudScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Score' ;
    rdfs:comment 'Risk score assigned by fraud detection systems at the time of the original transaction, ranging from 0.00 (low risk) to 100.00 (high risk).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Notes' ;
    rdfs:comment 'Free-text field for internal team notes, investigation findings, and case management details related to the chargeback dispute.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBank rdf:type rdf:Property ;
    rdfs:label 'Issuing Bank' ;
    rdfs:comment 'Financial institution that issued the payment card and initiated the chargeback on behalf of the cardholder.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalTransactionDate rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Date' ;
    rdfs:comment 'Date when the original payment transaction that is being disputed was processed.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Type of payment instrument used for the original transaction (credit card, debit card, prepaid card, digital wallet).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformStorefront rdf:type rdf:Property ;
    rdfs:label 'Platform Storefront' ;
    rdfs:comment 'Digital storefront or platform where the original transaction occurred (Steam, Epic Games Store, PlayStation Store, Xbox Store, Nintendo eShop, Apple App Store, Google Play). [ENUM-REF-CANDIDATE: steam|epic|playstation|xbox|nintendo|apple-app-store|google-play — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseType rdf:type rdf:Property ;
    rdfs:label 'Purchase Type' ;
    rdfs:comment 'Type of gaming purchase that was disputed (full game purchase, DLC, microtransaction, subscription, season pass, in-game currency).' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'Date and time when the chargeback notification was received from the payment processor or card network.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'Date when the chargeback dispute was finalized with a won or lost outcome.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionOutcome rdf:type rdf:Property ;
    rdfs:label 'Resolution Outcome' ;
    rdfs:comment 'Final outcome of the chargeback dispute indicating whether the merchant successfully defended against the chargeback or lost the dispute.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Response Deadline Date' ;
    rdfs:comment 'Final date by which the merchant must submit evidence and response to contest the chargeback, as mandated by card network rules.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalAmount rdf:type rdf:Property ;
    rdfs:label 'Reversal Amount' ;
    rdfs:comment 'Amount returned to the merchant if the chargeback was won or partially won. Null if the dispute was lost.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFinancialImpact rdf:type rdf:Property ;
    rdfs:label 'Total Financial Impact' ;
    rdfs:comment 'Total financial loss to the business including the chargeback amount plus any associated fees.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditMemoId rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Id' ;
    rdfs:comment 'Unique identifier for the credit memo. Primary key.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.journal_entry. Business justification: Credit memos generate GL journal entries for revenue reversals and customer credits; audit trail requirement. Gaming companies must link credit memos to GL for financial statement accuracy and revenue' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:originatingInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Originating Invoice Id' ;
    rdfs:comment 'Reference to the invoice that this credit memo is correcting or crediting against. Null if the credit is not tied to a specific invoice (e.g., goodwill credit).' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:primaryCreditEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Credit Employee Id' ;
    rdfs:comment 'Reference to the customer service agent, finance team member, or automated system process that authorized and issued this credit memo.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryCreditVoidedByAgentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Credit Voided By Agent Employee Id' ;
    rdfs:comment 'Reference to the agent who voided or cancelled this credit memo. Null if not voided.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:appliedAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Amount' ;
    rdfs:comment 'Total monetary value of the credit that has been consumed (applied to purchases). Zero if not yet used.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'Total monetary value of the credit issued, in the specified currency. This is the gross credit before any application or expiry.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Number' ;
    rdfs:comment 'Externally-visible unique business identifier for the credit memo, typically formatted as CM-XXXXXXXXXX for customer and platform partner reference.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditMemoStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Status' ;
    rdfs:comment 'Current lifecycle state of the credit memo: issued (active and available for use), applied (fully consumed against purchases), partially_applied (some balance remaining), expired (past expiry date and no longer usable), voided (cancelled by issuing agent), pending (awaiting approval or system processing).' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditMemoType rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Type' ;
    rdfs:comment 'Classification of the credit memo indicating the business reason category: goodwill (customer service gesture), billing_error_correction (invoice mistake), partial_refund (store credit instead of cash refund), promotional (marketing campaign credit), chargeback_reversal (chargeback won and credit issued), platform_adjustment (platform partner settlement correction).' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditReasonCode rdf:type rdf:Property ;
    rdfs:label 'Credit Reason Code' ;
    rdfs:comment 'Standardized internal code representing the specific reason for issuing the credit (e.g., BILLING_ERROR, GOODWILL_GESTURE, PROMO_CAMPAIGN, CHARGEBACK_WON). Used for reporting and analytics.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Credit Reason Description' ;
    rdfs:comment 'Free-text explanation of why the credit memo was issued, providing business context and details for audit and customer service reference.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Date on which the credit memo expires and any remaining balance becomes unusable. Null if the credit has no expiration.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'External system identifier or reference number from the platform partner or payment processor related to this credit memo (e.g., Steam transaction ID, Epic order ID). Used for reconciliation.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullyAppliedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fully Applied Timestamp' ;
    rdfs:comment 'Timestamp when the credit memo balance was fully consumed (remaining_balance reached zero). Null if not yet fully applied.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'General ledger account code to which this credit memo is posted for financial reporting and reconciliation.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'Date on which the credit memo was officially issued and became available for use by the player or platform partner.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:platformPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Platform Partner Code' ;
    rdfs:comment 'Reference to the platform partner (Steam, Epic, console first-party, mobile app store) to which this credit memo is issued. Null if issued to a player account instead.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remainingBalance rdf:type rdf:Property ;
    rdfs:label 'Remaining Balance' ;
    rdfs:comment 'Current available credit balance (credit_amount minus applied_amount). This is the amount still available for future purchases.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueReversalFlag rdf:type rdf:Property ;
    rdfs:label 'Revenue Reversal Flag' ;
    rdfs:comment 'Boolean flag indicating whether this credit memo triggers a revenue reversal in the general ledger (True) or is treated as a marketing expense (False).' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storefrontCode rdf:type rdf:Property ;
    rdfs:label 'Storefront Code' ;
    rdfs:comment 'Code identifying the digital storefront or platform where the original transaction occurred and where this credit will be applied (Steam, Epic Games Store, PlayStation Network, Xbox Live, Nintendo eShop, Apple App Store, Google Play, Direct Web Store). [ENUM-REF-CANDIDATE: STEAM|EPIC|PSN|XBOX|NINTENDO|APPLE|GOOGLE|DIRECT — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Code identifying the tax jurisdiction applicable to this credit memo (e.g., US-CA for California, GB for United Kingdom, EU-VAT for EU VAT area).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxTreatmentCode rdf:type rdf:Property ;
    rdfs:label 'Tax Treatment Code' ;
    rdfs:comment 'Code indicating how this credit memo is treated for tax purposes: TAXABLE (credit includes tax component), NON_TAXABLE (credit is pre-tax), TAX_EXEMPT (recipient is tax-exempt), REVERSE_CHARGE (VAT reverse charge applies).' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Voided Timestamp' ;
    rdfs:comment 'Timestamp when this credit memo was voided or cancelled. Null if not voided.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dunningEventId rdf:type rdf:Property ;
    rdfs:label 'Dunning Event Id' ;
    rdfs:comment 'Unique identifier for the dunning event record. Primary key.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Dunning and retention costs are tracked by cost center for customer lifetime value analysis and subscription economics. Gaming finance allocates dunning campaign costs to title cost centers to measure' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:dunningCycleId rdf:type rdf:Property ;
    rdfs:label 'Dunning Cycle Id' ;
    rdfs:comment 'Identifier grouping all dunning attempts for a single payment failure incident, allowing tracking of the complete recovery workflow.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DunningCycle .

ind:paymentInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Payment Instrument Id' ;
    rdfs:comment 'Reference to the payment instrument that failed during the billing attempt.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentInstrument .

ind:recoveryOfferId rdf:type rdf:Property ;
    rdfs:label 'Recovery Offer Id' ;
    rdfs:comment 'Identifier of the retention offer presented to the player. Null if no offer was made.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogOffer .

ind:resolvedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Resolved By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: When automated dunning fails and escalates to manual intervention, the CS rep who resolved the payment issue (updated card, applied credit, negotiated payment plan) must be tracked for performance met' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:subscriptionCycleId rdf:type rdf:Property ;
    rdfs:label 'Subscription Cycle Id' ;
    rdfs:comment 'Foreign key linking to billing.subscription_cycle. Business justification: Dunning events are triggered by failed billing cycles. While dunning_event already links to subscription (the parent), linking to the specific subscription_cycle that failed provides granular tracking' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SubscriptionCycle .

ind:accessRevokedFlag rdf:type rdf:Property ;
    rdfs:label 'Access Revoked Flag' ;
    rdfs:comment 'Flag indicating whether subscription access has been revoked due to unresolved payment failure.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accessRevokedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Access Revoked Timestamp' ;
    rdfs:comment 'Date and time when subscription access was revoked. Null if access has not been revoked.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:attemptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Attempt Timestamp' ;
    rdfs:comment 'Date and time when this dunning attempt was executed.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:attemptedAmount rdf:type rdf:Property ;
    rdfs:label 'Attempted Amount' ;
    rdfs:comment 'Monetary amount that was attempted to be charged during this dunning event.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dunningAttemptNumber rdf:type rdf:Property ;
    rdfs:label 'Dunning Attempt Number' ;
    rdfs:comment 'Sequential number of this dunning attempt within the dunning cycle (1 for first attempt, 2 for second, etc.).' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalation Timestamp' ;
    rdfs:comment 'Date and time when this dunning case was escalated to manual collection or customer support. Null if not escalated.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:failureReasonCode rdf:type rdf:Property ;
    rdfs:label 'Failure Reason Code' ;
    rdfs:comment 'Standardized code indicating why the payment failed (insufficient funds, card expired, card declined, bank block, invalid card, fraud suspected).' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Failure Reason Description' ;
    rdfs:comment 'Detailed human-readable description of the payment failure reason provided by the payment processor.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatewayResponseCode rdf:type rdf:Property ;
    rdfs:label 'Gateway Response Code' ;
    rdfs:comment 'Raw response code returned by the payment gateway for this dunning attempt.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Grace Period Days' ;
    rdfs:comment 'Total number of days in the grace period granted to the player for this dunning cycle.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gracePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Grace Period End Date' ;
    rdfs:comment 'Date when the grace period expires and subscription access will be revoked if payment is not resolved.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gracePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Grace Period Start Date' ;
    rdfs:comment 'Date when the grace period began, allowing the player continued access despite payment failure.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isVoluntaryCancellation rdf:type rdf:Property ;
    rdfs:label 'Is Voluntary Cancellation' ;
    rdfs:comment 'Flag indicating whether the subscription was voluntarily cancelled by the player (true) or involuntarily cancelled due to dunning failure (false).' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ltvAtDunning rdf:type rdf:Property ;
    rdfs:label 'Ltv At Dunning' ;
    rdfs:comment 'Player\'s lifetime value at the time of this dunning event, used to prioritize recovery efforts.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxRetryAttempts rdf:type rdf:Property ;
    rdfs:label 'Max Retry Attempts' ;
    rdfs:comment 'Maximum number of automated retry attempts configured for this dunning cycle before escalation or cancellation.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextRetryDate rdf:type rdf:Property ;
    rdfs:label 'Next Retry Date' ;
    rdfs:comment 'Scheduled date for the next automated payment retry attempt. Null if no further retries are scheduled.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationChannel rdf:type rdf:Property ;
    rdfs:label 'Notification Channel' ;
    rdfs:comment 'Communication channel used to notify the player about the payment failure (email, push notification, in-game message, SMS, or none if no notification sent).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Timestamp' ;
    rdfs:comment 'Date and time when the dunning notification was sent to the player. Null if no notification was sent.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notificationTemplateCode rdf:type rdf:Property ;
    rdfs:label 'Notification Template Code' ;
    rdfs:comment 'Identifier of the message template used for player communication during this dunning attempt.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentProcessor rdf:type rdf:Property ;
    rdfs:label 'Payment Processor' ;
    rdfs:comment 'Name of the payment processor or gateway that handled this transaction attempt (Stripe, Braintree, Adyen, etc.).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerResponseAction rdf:type rdf:Property ;
    rdfs:label 'Player Response Action' ;
    rdfs:comment 'Action taken by the player in response to the dunning notification (updated payment method, contacted support, ignored notification, cancelled subscription, or no action).' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processorTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Processor Transaction Reference' ;
    rdfs:comment 'Unique transaction identifier assigned by the payment processor for this dunning attempt.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryOfferPresented rdf:type rdf:Property ;
    rdfs:label 'Recovery Offer Presented' ;
    rdfs:comment 'Flag indicating whether a special retention offer (discount, free period) was presented to the player during this dunning event.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Resolution Method' ;
    rdfs:comment 'Method by which the dunning event was resolved (automatic retry succeeded, manual payment by player, player updated payment method, subscription cancelled, or written off as uncollectible).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Date and time when the dunning event was resolved (payment succeeded or subscription cancelled). Null if still active.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:retryIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Retry Interval Days' ;
    rdfs:comment 'Number of days between this attempt and the next scheduled retry.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Manual invoice creation (credits, adjustments, enterprise billing) requires audit trail of the billing operations employee who created it for SOX compliance, dispute resolution, and internal controls.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:jurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Id' ;
    rdfs:comment 'Foreign key linking to compliance.jurisdiction. Business justification: Invoices must track tax jurisdiction for VAT/sales tax filing and audit compliance. Gaming platforms operate globally with complex tax nexus rules. Replaces denormalized tax_jurisdiction_code with pro' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'End date of the billing period covered by this invoice. Defines the close of the billing cycle for subscription and recurring charges.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'Start date of the billing period covered by this invoice. Used for subscription billing cycles and recurring revenue recognition.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chargebackFlag rdf:type rdf:Property ;
    rdfs:label 'Chargeback Flag' ;
    rdfs:comment 'Indicates whether this invoice was subject to a payment chargeback initiated by the cardholder or payment processor. True if chargeback occurred; false otherwise. Critical for fraud detection and payment risk management.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Total discount amount applied to this invoice, including promotional discounts, volume discounts, early payment discounts, or platform-specific adjustments. Reduces the net amount due.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'Date by which payment is expected per the agreed payment terms. Used for accounts receivable aging and overdue invoice identification.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'Date the invoice was formally issued to the customer or platform partner. Serves as the baseline for payment terms and aging calculations.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Externally-visible unique invoice number issued to the player or platform partner. Human-readable business identifier used for customer service, accounting reconciliation, and dispute resolution.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle status of the invoice. Tracks progression from draft through issuance, payment, or dispute resolution. Critical for accounts receivable aging and revenue recognition workflows.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of invoice document type. Standard invoices represent normal sales; credit memos represent refunds or adjustments; debit memos represent additional charges; proforma invoices are estimates; recurring invoices are for subscription billing cycles.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paidDate rdf:type rdf:Property ;
    rdfs:label 'Paid Date' ;
    rdfs:comment 'Date the invoice was fully paid. Null if invoice is unpaid or partially paid. Used for cash flow analysis and Days Sales Outstanding (DSO) calculations.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentChannel rdf:type rdf:Property ;
    rdfs:label 'Payment Channel' ;
    rdfs:comment 'Interface or channel through which the payment was initiated. Distinct from payment method; tracks the user experience touchpoint for conversion funnel analysis and channel-specific revenue attribution.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Contractual payment terms defining the period within which payment is due. Immediate means payment on receipt; net_X means payment due X days after invoice date.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Platform Fee Amount' ;
    rdfs:comment 'Total platform commission or distribution fee charged by the storefront (e.g., 30% Apple App Store fee, 12% Epic Games Store fee). Deducted from gross revenue to calculate net payout to the studio.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Amount' ;
    rdfs:comment 'Total amount refunded to the customer if this invoice was partially or fully refunded. Zero if no refund issued. Tracked separately from credit memos for chargeback and dispute analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Category' ;
    rdfs:comment 'Accounting classification determining when and how revenue from this invoice is recognized per ASC 606 / IFRS 15 standards. Immediate for one-time purchases; deferred for DLC (Downloadable Content) or season passes; subscription for recurring GaaS (Game as a Service) revenue; usage-based for consumption models; milestone for performance-based contracts.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Subtotal Amount' ;
    rdfs:comment 'Sum of all line item amounts before taxes, fees, and discounts. Base amount for revenue recognition calculations.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxExemptionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Code' ;
    rdfs:comment 'Code indicating tax exemption status if applicable (e.g., non-profit organization, educational institution, tax-exempt jurisdiction). Null if no exemption applies.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Percentage' ;
    rdfs:comment 'Effective tax rate percentage applied to this invoice. Composite rate if multiple tax types apply (e.g., state + local sales tax, or VAT).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'Final invoice total after applying subtotal, taxes, discounts, and fees. This is the net amount due from the customer or platform partner. Used for payment reconciliation and revenue recognition.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voidedReason rdf:type rdf:Property ;
    rdfs:label 'Voided Reason' ;
    rdfs:comment 'Explanation for why this invoice was voided (e.g., billing error, duplicate invoice, customer cancellation, fraud). Null if invoice has not been voided. Required for financial audit and compliance reporting.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Id' ;
    rdfs:comment 'Unique identifier for the invoice line item. Primary key for this entity.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvoiceLine .

ind:gameStudioId rdf:type rdf:Property ;
    rdfs:label 'Game Studio Id' ;
    rdfs:comment 'Reference to the development studio responsible for the product sold on this line. Used for studio-level revenue attribution and royalty calculations.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GameStudio .

ind:chargebackAmount rdf:type rdf:Property ;
    rdfs:label 'Chargeback Amount' ;
    rdfs:comment 'Amount reversed due to chargeback initiated by the payment card issuer. Zero if no chargeback has occurred. Expressed in the invoice currency.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargebackDate rdf:type rdf:Property ;
    rdfs:label 'Chargeback Date' ;
    rdfs:comment 'Date when the chargeback was processed against this line item. Null if no chargeback has occurred.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discountCode rdf:type rdf:Property ;
    rdfs:label 'Discount Code' ;
    rdfs:comment 'Promotional code, coupon identifier, or campaign code applied to this line item. Null if no discount code was used.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line number within the invoice, used for ordering and referencing individual line items on the invoice document.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current status of this invoice line item: active (valid charge), refunded (fully refunded), partially_refunded (partial refund issued), disputed (under dispute), or chargeback (payment reversed by card issuer).' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineTotal rdf:type rdf:Property ;
    rdfs:label 'Line Total' ;
    rdfs:comment 'Final total for this line item including all discounts and taxes: subtotal + tax_amount. This is the amount recognized for this line. Expressed in the invoice currency.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:listPrice rdf:type rdf:Property ;
    rdfs:label 'List Price' ;
    rdfs:comment 'Original catalog or storefront list price per unit before promotional discounts. Used to calculate discount percentage and promotional effectiveness.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netRevenue rdf:type rdf:Property ;
    rdfs:label 'Net Revenue' ;
    rdfs:comment 'Net revenue after platform fees: line_total - platform_fee_amount. This is the amount the studio receives after platform revenue share. Expressed in the invoice currency.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformFeeRate rdf:type rdf:Property ;
    rdfs:label 'Platform Fee Rate' ;
    rdfs:comment 'Platform fee rate expressed as a decimal (e.g., 0.3000 for 30% platform fee). Used for financial modeling and payout reconciliation.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'Human-readable name of the product or service sold on this line: game title, expansion pack name, subscription plan name, or virtual item bundle name.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productType rdf:type rdf:Property ;
    rdfs:label 'Product Type' ;
    rdfs:comment 'Category of the product sold: base game purchase, Downloadable Content (DLC), season pass, subscription period, In-App Purchase (IAP), virtual currency, cosmetic item, or battle pass. [ENUM-REF-CANDIDATE: base_game|dlc|season_pass|subscription|iap|virtual_currency|cosmetic|battle_pass — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Number of units of this Stock Keeping Unit (SKU) purchased on this line. Typically 1 for digital goods; may be greater than 1 for virtual currency bundles or multi-license purchases.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:refundDate rdf:type rdf:Property ;
    rdfs:label 'Refund Date' ;
    rdfs:comment 'Date when the refund was processed for this line item. Null if no refund has been issued.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refundEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Refund Eligible Flag' ;
    rdfs:comment 'Indicates whether this line item is eligible for refund based on platform policies (e.g., Steam 2-hour/14-day policy, Apple/Google refund windows). True if refundable, False if non-refundable.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refundWindowEndDate rdf:type rdf:Property ;
    rdfs:label 'Refund Window End Date' ;
    rdfs:comment 'Last date on which a refund can be requested for this line item per platform policy. Null if item is non-refundable or refund window has no expiration.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueRecognitionEndDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition End Date' ;
    rdfs:comment 'Date when revenue recognition ends for this line item. Null for immediate recognition. For subscriptions or deferred items, marks the end of the recognition period.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueRecognitionStartDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Start Date' ;
    rdfs:comment 'Date when revenue recognition begins for this line item. For immediate recognition, equals the invoice date. For deferred or subscription items, marks the start of the recognition period.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sku rdf:type rdf:Property ;
    rdfs:label 'Sku' ;
    rdfs:comment 'Product identifier representing the specific item sold: game title, Downloadable Content (DLC) pack, season pass, subscription tier, In-App Purchase (IAP) bundle, or virtual currency package.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Subscription Period End Date' ;
    rdfs:comment 'End date of the subscription billing period for subscription line items. Null for non-subscription purchases.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subscriptionPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Subscription Period Start Date' ;
    rdfs:comment 'Start date of the subscription billing period for subscription line items. Null for non-subscription purchases.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subtotal rdf:type rdf:Property ;
    rdfs:label 'Subtotal' ;
    rdfs:comment 'Line total after discounts but before taxes: (quantity × unit_price) - discount_amount. Expressed in the invoice currency.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction' ;
    rdfs:comment 'Geographic tax jurisdiction code or name where the tax was assessed (e.g., state, province, country). Required for multi-jurisdiction tax reporting.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'Price per single unit of the Stock Keeping Unit (SKU) before any discounts or taxes. Expressed in the invoice currency.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizationCode rdf:type rdf:Property ;
    rdfs:label 'Authorization Code' ;
    rdfs:comment 'The authorization code returned by the payment gateway or issuing bank confirming that the payment was approved. Used for reconciliation and dispute resolution.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardBrand rdf:type rdf:Property ;
    rdfs:label 'Card Brand' ;
    rdfs:comment 'The brand of the payment card used (e.g., Visa, Mastercard, American Express). Applicable only when payment method type is credit or debit card. [ENUM-REF-CANDIDATE: visa|mastercard|amex|discover|jcb|diners_club|unionpay — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardExpiryMonth rdf:type rdf:Property ;
    rdfs:label 'Card Expiry Month' ;
    rdfs:comment 'The expiration month of the payment card (1-12). Used for subscription renewal validation and payment method expiry alerts.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cardExpiryYear rdf:type rdf:Property ;
    rdfs:label 'Card Expiry Year' ;
    rdfs:comment 'The expiration year of the payment card (four-digit year). Used for subscription renewal validation and payment method expiry alerts.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cardLastFourDigits rdf:type rdf:Property ;
    rdfs:label 'Card Last Four Digits' ;
    rdfs:comment 'The last four digits of the payment card used for the transaction. PCI DSS-compliant - no full card number stored. Used for player reference and support.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The distribution channel or storefront through which the payment was processed. Distinct from payment method - this identifies the platform interface. [ENUM-REF-CANDIDATE: web|mobile_app|console|in_game|steam|epic_games_store|apple_app_store|google_play_store|playstation_store|xbox_store|nintendo_eshop — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Fraud Review Status' ;
    rdfs:comment 'The status of manual or automated fraud review for this payment. Indicates whether the payment has been cleared, flagged, or is pending investigation.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatewayFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Gateway Fee Amount' ;
    rdfs:comment 'The fee charged by the payment gateway or payment processor (e.g., Stripe, PayPal, Adyen) for processing the payment. Separate from platform fees.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gatewayProvider rdf:type rdf:Property ;
    rdfs:label 'Gateway Provider' ;
    rdfs:comment 'The name of the payment gateway or payment processor that handled the transaction (e.g., Stripe, PayPal, Adyen, Braintree, platform-native processor).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatewayTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Gateway Transaction Reference' ;
    rdfs:comment 'The unique transaction identifier assigned by the payment gateway. Used for tracking, reconciliation, and support inquiries with the gateway provider.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTestTransaction rdf:type rdf:Property ;
    rdfs:label 'Is Test Transaction' ;
    rdfs:comment 'Flag indicating whether this payment is a test transaction used for QA, UAT, or sandbox testing. Test transactions are excluded from revenue reporting.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:methodType rdf:type rdf:Property ;
    rdfs:label 'Method Type' ;
    rdfs:comment 'The type of payment instrument used by the player to complete the transaction (e.g., credit card, PayPal, platform wallet, gift card). [ENUM-REF-CANDIDATE: credit_card|debit_card|paypal|platform_wallet|gift_card|bank_transfer|mobile_payment|cryptocurrency — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Net Revenue Amount' ;
    rdfs:comment 'The net revenue amount received by the business after deducting platform fees, payment gateway fees, and taxes from the gross payment amount. This is the recognized revenue for financial reporting.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payerEmail rdf:type rdf:Property ;
    rdfs:label 'Payer Email' ;
    rdfs:comment 'The email address of the payer as provided during the payment transaction. May differ from the player account email for gift purchases or third-party payments.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDescription rdf:type rdf:Property ;
    rdfs:label 'Payment Description' ;
    rdfs:comment 'A human-readable description of the payment transaction, typically including the product name and purchase details. Used for player receipts and support inquiries.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current lifecycle status of the payment transaction. Tracks the payment from authorization through settlement or failure. [ENUM-REF-CANDIDATE: pending|authorized|captured|settled|failed|declined|refunded|partially_refunded|chargeback — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Payment Timestamp' ;
    rdfs:comment 'The exact date and time when the payment transaction was initiated by the player. This is the business event timestamp for revenue recognition and analytics.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:refundReasonCode rdf:type rdf:Property ;
    rdfs:label 'Refund Reason Code' ;
    rdfs:comment 'The reason code for refund or chargeback if the payment status is refunded, partially refunded, or chargeback. Nullable for successful payments. [ENUM-REF-CANDIDATE: customer_request|duplicate_charge|fraud|technical_issue|policy_violation|chargeback|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundTimestamp rdf:type rdf:Property ;
    rdfs:label 'Refund Timestamp' ;
    rdfs:comment 'The date and time when the refund was processed. Nullable for non-refunded payments.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:settlementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Settlement Timestamp' ;
    rdfs:comment 'The date and time when the payment was settled and funds were transferred to the merchant account. Nullable for pending or failed payments.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:threeDsAuthenticationStatus rdf:type rdf:Property ;
    rdfs:label 'Three Ds Authentication Status' ;
    rdfs:comment 'The status of 3D Secure authentication for this payment. Indicates whether the cardholder was successfully authenticated using 3DS protocol.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Reference Number' ;
    rdfs:comment 'Externally-known unique reference number for this payment transaction, provided by the payment gateway or platform. Used for reconciliation and customer support inquiries.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentHoldId rdf:type rdf:Property ;
    rdfs:label 'Payment Hold Id' ;
    rdfs:comment 'Unique identifier for the payment hold record. Primary key.' ;
    rdfs:domain ind:PaymentHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fraudRuleId rdf:type rdf:Property ;
    rdfs:label 'Fraud Rule Id' ;
    rdfs:comment 'Identifier of the specific fraud prevention rule or model that triggered the hold. Enables rule performance analysis and optimization.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FraudRule .

ind:sanctionsScreeningResultId rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Result Id' ;
    rdfs:comment 'Foreign key linking to compliance.sanctions_screening_result. Business justification: Payment holds often result from sanctions screening hits (OFAC, export control). Gaming companies must link holds to screening results for AML compliance and hold resolution workflows. Critical for re' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SanctionsScreeningResult .

ind:captureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Capture Timestamp' ;
    rdfs:comment 'Date and time when the held payment authorization was captured and settled. Null if the hold was declined, voided, or expired.' ;
    rdfs:domain ind:PaymentHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:declineReasonCode rdf:type rdf:Property ;
    rdfs:label 'Decline Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason the payment hold was declined and voided. Used for fraud pattern analysis and player communication.' ;
    rdfs:domain ind:PaymentHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declineReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Decline Reason Description' ;
    rdfs:comment 'Detailed explanation of why the payment hold was declined. Provides context for player support and dispute resolution.' ;
    rdfs:domain ind:PaymentHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicates whether the payment hold was escalated to senior fraud analysts or management for additional review. True if escalated.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Explanation of why the payment hold required escalation beyond standard fraud review procedures.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudRuleVersion rdf:type rdf:Property ;
    rdfs:label 'Fraud Rule Version' ;
    rdfs:comment 'Version number of the fraud rule or model that was active when the hold was triggered. Critical for audit trails and rule effectiveness analysis.' ;
    rdfs:domain ind:PaymentHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudScoreThreshold rdf:type rdf:Property ;
    rdfs:label 'Fraud Score Threshold' ;
    rdfs:comment 'The fraud score threshold that was exceeded, triggering the payment hold. Used to evaluate and tune fraud prevention rules.' ;
    rdfs:domain ind:PaymentHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdAmount rdf:type rdf:Property ;
    rdfs:label 'Hold Amount' ;
    rdfs:comment 'The monetary amount of the payment authorization that is being held pending fraud review. Represents the value at risk.' ;
    rdfs:domain ind:PaymentHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Created Timestamp' ;
    rdfs:comment 'Date and time when the payment hold was initially placed. Marks the start of the authorization hold period.' ;
    rdfs:domain ind:PaymentHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdExpiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Expiry Timestamp' ;
    rdfs:comment 'Date and time when the payment authorization hold will expire if not captured or voided. Typically 7-30 days from creation depending on card network rules.' ;
    rdfs:domain ind:PaymentHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdNumber rdf:type rdf:Property ;
    rdfs:label 'Hold Number' ;
    rdfs:comment 'Human-readable unique identifier for the payment hold, used for tracking and reference in fraud review workflows and customer support interactions.' ;
    rdfs:domain ind:PaymentHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReasonCode rdf:type rdf:Property ;
    rdfs:label 'Hold Reason Code' ;
    rdfs:comment 'Standardized code indicating the primary reason the payment was placed on hold. Used for categorization and reporting of fraud prevention triggers.' ;
    rdfs:domain ind:PaymentHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Hold Reason Description' ;
    rdfs:comment 'Detailed human-readable explanation of why the payment was placed on hold. Provides context for fraud analysts and support agents reviewing the case.' ;
    rdfs:domain ind:PaymentHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdStatus rdf:type rdf:Property ;
    rdfs:label 'Hold Status' ;
    rdfs:comment 'Current status of the payment hold in the fraud review and settlement workflow. Tracks progression from initial hold through final resolution. [ENUM-REF-CANDIDATE: pending_review|approved_for_capture|declined|expired|escalated|cancelled|captured|voided — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PaymentHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdTriggerType rdf:type rdf:Property ;
    rdfs:label 'Hold Trigger Type' ;
    rdfs:comment 'Classification of the fraud prevention mechanism that triggered the hold. Distinguishes between automated rules, ML models, and manual interventions. [ENUM-REF-CANDIDATE: fraud_score_threshold|velocity_check|geo_mismatch|first_purchase|high_value|card_verification_failure|suspicious_device|manual_review|rule_engine|machine_learning_model — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PaymentHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerContactAttemptedFlag rdf:type rdf:Property ;
    rdfs:label 'Player Contact Attempted Flag' ;
    rdfs:comment 'Indicates whether the fraud team attempted to contact the player to verify the transaction. True if contact was attempted.' ;
    rdfs:domain ind:PaymentHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:playerContactTimestamp rdf:type rdf:Property ;
    rdfs:label 'Player Contact Timestamp' ;
    rdfs:comment 'Date and time when the fraud team attempted to contact the player for transaction verification. Null if no contact attempted.' ;
    rdfs:domain ind:PaymentHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:playerVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Player Verification Status' ;
    rdfs:comment 'Outcome of player identity and transaction verification attempts during fraud review. Indicates whether the player confirmed the purchase.' ;
    rdfs:domain ind:PaymentHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewNotes rdf:type rdf:Property ;
    rdfs:label 'Review Notes' ;
    rdfs:comment 'Free-text notes entered by fraud analysts during the review process. Documents investigation findings and decision rationale.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewPriority rdf:type rdf:Property ;
    rdfs:label 'Review Priority' ;
    rdfs:comment 'Priority level assigned to the hold review based on fraud risk, transaction value, and player history. Determines review queue ordering.' ;
    rdfs:domain ind:PaymentHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Started Timestamp' ;
    rdfs:comment 'Date and time when fraud review of the held payment began. Used to measure review queue wait times and SLA compliance.' ;
    rdfs:domain ind:PaymentHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transactionCountryCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Country Code' ;
    rdfs:comment 'Three-letter ISO 3166 country code derived from the IP address or device location at transaction time. Used for geo-mismatch analysis.' ;
    rdfs:domain ind:PaymentHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidTimestamp rdf:type rdf:Property ;
    rdfs:label 'Void Timestamp' ;
    rdfs:comment 'Date and time when the held payment authorization was voided and released. Null if the hold was captured or expired.' ;
    rdfs:domain ind:PaymentHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:verifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Verified By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Payment instruments flagged for fraud or requiring manual verification (high-value accounts, suspicious patterns) are assigned to fraud analysts for verification. Tracking the verifying employee is re' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:virtualCurrencyAccountId rdf:type rdf:Property ;
    rdfs:label 'Virtual Currency Account Id' ;
    rdfs:comment 'The identifier for platform-specific wallet payment methods (PlayStation Network Wallet, Xbox Wallet, Steam Wallet). Null for non-platform wallets.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VirtualCurrencyAccount .

ind:addedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Added Timestamp' ;
    rdfs:comment 'The date and time when the payment instrument was first added to the players account.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deleted Timestamp' ;
    rdfs:comment 'The date and time when the payment instrument was soft-deleted or removed from the players account. Null if still active.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expiryMonth rdf:type rdf:Property ;
    rdfs:label 'Expiry Month' ;
    rdfs:comment 'The expiration month of the payment instrument (1-12). Used to validate instrument validity.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expiryNotificationSent rdf:type rdf:Property ;
    rdfs:label 'Expiry Notification Sent' ;
    rdfs:comment 'Indicates whether an expiration notification has been sent to the player for this payment instrument.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expiryYear rdf:type rdf:Property ;
    rdfs:label 'Expiry Year' ;
    rdfs:comment 'The expiration year of the payment instrument (four-digit year). Used to validate instrument validity.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:instrumentStatus rdf:type rdf:Property ;
    rdfs:label 'Instrument Status' ;
    rdfs:comment 'Current lifecycle status of the payment instrument. Determines whether the instrument can be used for transactions.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefault rdf:type rdf:Property ;
    rdfs:label 'Is Default' ;
    rdfs:comment 'Indicates whether this payment instrument is the players default payment method for transactions.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVerified rdf:type rdf:Property ;
    rdfs:label 'Is Verified' ;
    rdfs:comment 'Indicates whether the payment instrument has been successfully verified through AVS or other verification methods.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingBankBin rdf:type rdf:Property ;
    rdfs:label 'Issuing Bank Bin' ;
    rdfs:comment 'The Bank Identification Number (BIN) or Issuer Identification Number (IIN) identifying the issuing financial institution. First 6-8 digits of the card number.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBankName rdf:type rdf:Property ;
    rdfs:label 'Issuing Bank Name' ;
    rdfs:comment 'The name of the financial institution that issued the payment instrument. Derived from BIN lookup.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the payment instrument was issued. Used for fraud detection and regional compliance.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastFourDigits rdf:type rdf:Property ;
    rdfs:label 'Last Four Digits' ;
    rdfs:comment 'The last four digits of the card number for display and player identification purposes. Safe to store per PCI DSS.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUsedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Used Timestamp' ;
    rdfs:comment 'The date and time when this payment instrument was last used for a successful transaction.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:paymentMethodType rdf:type rdf:Property ;
    rdfs:label 'Payment Method Type' ;
    rdfs:comment 'The type of payment instrument (e.g., credit card, PayPal, digital wallet). Represents the payment instrument category. [ENUM-REF-CANDIDATE: credit_card|debit_card|paypal|apple_pay|google_pay|psn_wallet|xbox_wallet|steam_wallet — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurringBillingEnabled rdf:type rdf:Property ;
    rdfs:label 'Recurring Billing Enabled' ;
    rdfs:comment 'Indicates whether this payment instrument is authorized for recurring subscription billing.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:threeDSecureEnrolled rdf:type rdf:Property ;
    rdfs:label 'Three D Secure Enrolled' ;
    rdfs:comment 'Indicates whether the payment instrument is enrolled in 3D Secure authentication (Verified by Visa, Mastercard SecureCode, etc.).' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tokenizedReference rdf:type rdf:Property ;
    rdfs:label 'Tokenized Reference' ;
    rdfs:comment 'PCI DSS-compliant tokenized reference to the payment instrument stored in the vault provider. Does not contain raw Primary Account Number (PAN).' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vaultCustomerReference rdf:type rdf:Property ;
    rdfs:label 'Vault Customer Reference' ;
    rdfs:comment 'The customer identifier in the vault providers system. Used to retrieve payment instruments from the vault.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vaultProvider rdf:type rdf:Property ;
    rdfs:label 'Vault Provider' ;
    rdfs:comment 'The third-party payment vault provider that securely stores the tokenized payment instrument (e.g., Braintree, Stripe, Adyen).' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'The method used to verify the payment instrument (Address Verification Service, CVV check, 3D Secure, etc.).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verification Timestamp' ;
    rdfs:comment 'The date and time when the payment instrument was successfully verified.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:payoutLineId rdf:type rdf:Property ;
    rdfs:label 'Payout Line Id' ;
    rdfs:comment 'Unique identifier for the payout line item. Primary key for this entity.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayoutLine .

ind:platformPayoutId rdf:type rdf:Property ;
    rdfs:label 'Platform Payout Id' ;
    rdfs:comment 'Reference to the parent payout settlement batch that this line item belongs to. Links to the payout header entity.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlatformPayout .

ind:titleSkuId rdf:type rdf:Property ;
    rdfs:label 'Title Sku Id' ;
    rdfs:comment 'Reference to the specific SKU or product variant that contributed to this payout line (e.g., base game, DLC, season pass, in-game currency pack).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TitleSku .

ind:adjustmentsAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustments Amount' ;
    rdfs:comment 'Other revenue adjustments applied by the platform holder (e.g., promotional credits, pricing corrections, currency adjustments).' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargebacksAmount rdf:type rdf:Property ;
    rdfs:label 'Chargebacks Amount' ;
    rdfs:comment 'Total value of payment chargebacks for this SKU during the payout period, deducted from gross revenue.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Reason for dispute if reconciliation status is disputed (e.g., unit count mismatch, fee rate discrepancy, missing transactions, incorrect SKU mapping).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Revenue Amount' ;
    rdfs:comment 'Total gross revenue generated by this SKU before any deductions (returns, refunds, chargebacks, platform fees). Reported in the payout currency.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPayoutAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payout Amount' ;
    rdfs:comment 'Final net payout amount for this line item after all deductions and platform fees. This is the amount remitted to the publisher.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformName rdf:type rdf:Property ;
    rdfs:label 'Platform Name' ;
    rdfs:comment 'Name of the distribution platform, denormalized for reporting convenience.' ;
    rdfs:domain ind:PayoutLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformStatementReference rdf:type rdf:Property ;
    rdfs:label 'Platform Statement Reference' ;
    rdfs:comment 'Reference number or identifier from the platform holders settlement statement that corresponds to this payout line, used for audit trail and reconciliation.' ;
    rdfs:domain ind:PayoutLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Current reconciliation status of this payout line against internal sales records: pending initial review, reconciled and matched, disputed with platform, adjusted after dispute resolution, or approved for revenue recognition.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundsAmount rdf:type rdf:Property ;
    rdfs:label 'Refunds Amount' ;
    rdfs:comment 'Total value of refunds issued for this SKU during the payout period, deducted from gross revenue.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnsAmount rdf:type rdf:Property ;
    rdfs:label 'Returns Amount' ;
    rdfs:comment 'Total value of product returns for this SKU during the payout period, deducted from gross revenue.' ;
    rdfs:domain ind:PayoutLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'Date when revenue from this payout line was recognized in the general ledger for financial reporting purposes, per ASC 606 / IFRS 15 guidance.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Sales Period End Date' ;
    rdfs:comment 'End date of the sales period covered by this payout line item.' ;
    rdfs:domain ind:PayoutLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Sales Period Start Date' ;
    rdfs:comment 'Start date of the sales period covered by this payout line item.' ;
    rdfs:domain ind:PayoutLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:skuCode rdf:type rdf:Property ;
    rdfs:label 'Sku Code' ;
    rdfs:comment 'Platform-specific SKU code or product identifier as reported by the platform holder (Steam, Epic, PlayStation, Xbox, App Store, Google Play).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuType rdf:type rdf:Property ;
    rdfs:label 'Sku Type' ;
    rdfs:comment 'Category of the SKU: base game, downloadable content (DLC), season pass, expansion, microtransaction (MTX), in-app purchase (IAP), or subscription. [ENUM-REF-CANDIDATE: base_game|dlc|season_pass|expansion|mtx|iap|subscription — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PayoutLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitsSold rdf:type rdf:Property ;
    rdfs:label 'Units Sold' ;
    rdfs:comment 'Number of units sold for this SKU during the payout period. For consumable MTX or IAP, represents transaction count.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bankAccountId rdf:type rdf:Property ;
    rdfs:label 'Bank Account Id' ;
    rdfs:comment 'Identifier of the bank account that received this payout settlement.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Timestamp when this payout settlement was approved by the finance team.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'Exchange rate applied by the platform holder for currency conversion, if applicable.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'Fiscal quarter to which this payout settlement is attributed for financial reporting purposes.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'Fiscal year to which this payout settlement is attributed for financial reporting purposes.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'Date when this payout settlement was posted to the general ledger in the ERP system.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:glPostingStatus rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Status' ;
    rdfs:comment 'Status of the general ledger posting for this payout settlement in the ERP system.' ;
    rdfs:domain ind:PlatformPayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemCount rdf:type rdf:Property ;
    rdfs:label 'Line Item Count' ;
    rdfs:comment 'Number of per-title or per-SKU line items included in this payout settlement breakdown.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payoutDate rdf:type rdf:Property ;
    rdfs:label 'Payout Date' ;
    rdfs:comment 'Date when the platform holder transferred the settlement funds to the gaming business.' ;
    rdfs:domain ind:PlatformPayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payoutPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Payout Period End Date' ;
    rdfs:comment 'End date of the sales period covered by this payout settlement.' ;
    rdfs:domain ind:PlatformPayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payoutPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Payout Period Start Date' ;
    rdfs:comment 'Start date of the sales period covered by this payout settlement.' ;
    rdfs:domain ind:PlatformPayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:platformFeePercentage rdf:type rdf:Property ;
    rdfs:label 'Platform Fee Percentage' ;
    rdfs:comment 'Platform revenue share percentage applied to gross revenue (e.g., 30.00 for 30% platform fee).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'Date when this payout settlement was reconciled and approved by the finance team.' ;
    rdfs:domain ind:PlatformPayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationNotes rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Notes' ;
    rdfs:comment 'Notes and comments from the finance team regarding reconciliation findings, discrepancies, or resolutions.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnsRefundsAmount rdf:type rdf:Property ;
    rdfs:label 'Returns Refunds Amount' ;
    rdfs:comment 'Total amount deducted for returns, refunds, and chargebacks during the payout period.' ;
    rdfs:domain ind:PlatformPayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Settlement Reference Number' ;
    rdfs:comment 'External reference number or identifier provided by the platform holder for this payout settlement, used for reconciliation and audit trail.' ;
    rdfs:domain ind:PlatformPayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementUrl rdf:type rdf:Property ;
    rdfs:label 'Statement Url' ;
    rdfs:comment 'URL or file path to the detailed payout statement document provided by the platform holder.' ;
    rdfs:domain ind:PlatformPayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxWithheldAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Withheld Amount' ;
    rdfs:comment 'Total tax amount withheld by the platform holder for jurisdictional tax compliance (e.g., VAT, sales tax, withholding tax).' ;
    rdfs:domain ind:PlatformPayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitsSoldTotal rdf:type rdf:Property ;
    rdfs:label 'Units Sold Total' ;
    rdfs:comment 'Total number of units (game copies, DLC, MTX, subscriptions) sold across all titles during the payout period.' ;
    rdfs:domain ind:PlatformPayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promoCodeId rdf:type rdf:Property ;
    rdfs:label 'Promo Code Id' ;
    rdfs:comment 'Primary key for promo_code' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromoCode .

ind:primaryPromoEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Promo Employee Id' ;
    rdfs:comment 'Reference to the internal user or system account that created this promo code record.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicableSkuScope rdf:type rdf:Property ;
    rdfs:label 'Applicable Sku Scope' ;
    rdfs:comment 'Defines the scope of products to which this promo code applies: all (any purchase), specific_skus (listed SKUs only), category (product category), platform (specific platform purchases).' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionChannel rdf:type rdf:Property ;
    rdfs:label 'Attribution Channel' ;
    rdfs:comment 'The marketing channel through which this promo code was distributed, used for campaign performance attribution and ROAS (Return on Ad Spend) analysis. [ENUM-REF-CANDIDATE: email|social_media|paid_search|organic|affiliate|in_game|customer_support — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoApplyFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Apply Flag' ;
    rdfs:comment 'Indicates whether this promo code is automatically applied at checkout for eligible players without requiring manual entry. True if auto-applied, False if manual entry required.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:codeType rdf:type rdf:Property ;
    rdfs:label 'Code Type' ;
    rdfs:comment 'Classification of the promotional code based on redemption limits: single_use (one redemption total), multi_use (limited redemptions), unlimited (no cap).' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentRedemptionCount rdf:type rdf:Property ;
    rdfs:label 'Current Redemption Count' ;
    rdfs:comment 'The current total number of times this promo code has been successfully redeemed. Incremented with each successful redemption.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deactivatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deactivated Timestamp' ;
    rdfs:comment 'The date and time when this promo code was manually deactivated or suspended. Null if never deactivated.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deactivationReason rdf:type rdf:Property ;
    rdfs:label 'Deactivation Reason' ;
    rdfs:comment 'The reason why this promo code was deactivated: fraud (fraudulent use detected), abuse (terms violation), campaign_ended (promotional period concluded), business_decision (strategic change), error_correction (code issued in error).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountType rdf:type rdf:Property ;
    rdfs:label 'Discount Type' ;
    rdfs:comment 'The mechanism by which the discount is applied: percentage (e.g., 20% off), fixed_amount (e.g., $5 off), free_trial (e.g., 30 days free), bundle_discount (special bundle pricing).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountValue rdf:type rdf:Property ;
    rdfs:label 'Discount Value' ;
    rdfs:comment 'The numeric value of the discount. For percentage discounts, this is the percentage (e.g., 20.00 for 20%). For fixed_amount, this is the currency amount. For free_trial, this is the number of days.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstTimePurchaserOnlyFlag rdf:type rdf:Property ;
    rdfs:label 'First Time Purchaser Only Flag' ;
    rdfs:comment 'Indicates whether this promo code is restricted to players making their first real-money purchase. True if restricted to first-time buyers, False otherwise.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingSource rdf:type rdf:Property ;
    rdfs:label 'Issuing Source' ;
    rdfs:comment 'The origin or channel through which this promo code was issued: marketing_campaign, partner_promotion, influencer, customer_support (service recovery), loyalty_program, event_giveaway.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxRedemptionCount rdf:type rdf:Property ;
    rdfs:label 'Max Redemption Count' ;
    rdfs:comment 'The total number of times this promo code can be redeemed across all players. Null for unlimited redemption codes.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maximumDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Discount Amount' ;
    rdfs:comment 'The maximum discount amount that can be applied when using this code, used to cap percentage-based discounts. Null if no cap applies.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumPurchaseAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Purchase Amount' ;
    rdfs:comment 'The minimum order subtotal required for this promo code to be applicable. Null if no minimum is required.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerName rdf:type rdf:Property ;
    rdfs:label 'Partner Name' ;
    rdfs:comment 'Name of the external partner or influencer associated with this promo code, if applicable. Used for co-marketing and attribution tracking.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perPlayerRedemptionLimit rdf:type rdf:Property ;
    rdfs:label 'Per Player Redemption Limit' ;
    rdfs:comment 'The maximum number of times a single player can redeem this promo code. Typically 1 for single-use-per-player codes.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:platformScope rdf:type rdf:Property ;
    rdfs:label 'Platform Scope' ;
    rdfs:comment 'The gaming platform(s) on which this promo code is valid. Restricts redemption to specific storefronts or first-party platforms. [ENUM-REF-CANDIDATE: all|steam|epic|playstation|xbox|nintendo|mobile_ios|mobile_android — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoCodeCode rdf:type rdf:Property ;
    rdfs:label 'Promo Code Code' ;
    rdfs:comment 'The alphanumeric promotional code string that players enter at checkout to receive the discount. Must be unique across all active codes.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoCodeStatus rdf:type rdf:Property ;
    rdfs:label 'Promo Code Status' ;
    rdfs:comment 'Current lifecycle status of the promo code: active (available for redemption), inactive (not yet active or manually disabled), expired (past valid_until_date), depleted (max_redemption_count reached), suspended (temporarily disabled by admin).' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicDescription rdf:type rdf:Property ;
    rdfs:label 'Public Description' ;
    rdfs:comment 'Player-facing description of the promotional offer associated with this code, displayed in marketing materials and at checkout. Example: \'Get 20% off your next purchase!\'' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuFilterList rdf:type rdf:Property ;
    rdfs:label 'Sku Filter List' ;
    rdfs:comment 'Comma-separated list of SKU identifiers or category codes to which this promo code is restricted. Null if applicable_sku_scope is \'all\'.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stackableFlag rdf:type rdf:Property ;
    rdfs:label 'Stackable Flag' ;
    rdfs:comment 'Indicates whether this promo code can be combined with other promotional codes in a single transaction. True if stackable, False if exclusive.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termsAndConditionsUrl rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions Url' ;
    rdfs:comment 'URL link to the full terms and conditions governing the use of this promo code, ensuring compliance with consumer protection regulations.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDiscountAmountApplied rdf:type rdf:Property ;
    rdfs:label 'Total Discount Amount Applied' ;
    rdfs:comment 'The cumulative total discount amount (in the promo code\'s currency) that has been applied across all redemptions of this code. Used for financial reconciliation and ROI (Return on Investment) analysis.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRevenueAttributed rdf:type rdf:Property ;
    rdfs:label 'Total Revenue Attributed' ;
    rdfs:comment 'The cumulative gross revenue (before discount) from all orders that used this promo code. Used to measure the revenue-driving impact of the promotion.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'The date from which this promo code becomes active and can be redeemed. Part of the promotional window.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validUntilDate rdf:type rdf:Property ;
    rdfs:label 'Valid Until Date' ;
    rdfs:comment 'The date after which this promo code expires and can no longer be redeemed. Null for codes with no expiration.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promoRedemptionId rdf:type rdf:Property ;
    rdfs:label 'Promo Redemption Id' ;
    rdfs:comment 'Unique identifier for the promotional code redemption transaction. Primary key.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromoRedemption .

ind:promotionId rdf:type rdf:Property ;
    rdfs:label 'Promotion Id' ;
    rdfs:comment 'Foreign key linking to monetization.promotion. Business justification: Billing promo redemptions tied to monetization promotions enable campaign attribution, discount validation, and ROI analysis. Marketing operations require linking redemptions to promotions for perform' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Promotion .

ind:transactionStorefrontOrderId rdf:type rdf:Property ;
    rdfs:label 'Transaction Storefront Order Id' ;
    rdfs:comment 'The external transaction identifier from the payment processor or platform SDK, used for reconciliation and dispute resolution.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorefrontOrder .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'The percentage discount applied if the promo code is percentage-based (e.g., 10.00 for 10% off). Null for fixed-amount discounts.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'The expiration date of the promotional code at the time of redemption, captured for historical tracking and compliance.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalOrderAmount rdf:type rdf:Property ;
    rdfs:label 'Final Order Amount' ;
    rdfs:comment 'The total order amount after the promotional discount was applied.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isFirstPurchase rdf:type rdf:Property ;
    rdfs:label 'Is First Purchase' ;
    rdfs:comment 'Boolean flag indicating whether this redemption was associated with the players first-ever purchase (true) or a repeat purchase (false).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStackable rdf:type rdf:Property ;
    rdfs:label 'Is Stackable' ;
    rdfs:comment 'Boolean flag indicating whether this promotional code was allowed to be combined with other promotions on the same order.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalOrderAmount rdf:type rdf:Property ;
    rdfs:label 'Original Order Amount' ;
    rdfs:comment 'The total order amount before the promotional discount was applied.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerCode rdf:type rdf:Property ;
    rdfs:label 'Partner Code' ;
    rdfs:comment 'Reference to the external partner or affiliate who distributed the promotional code, enabling partner payout tracking.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redemptionChannel rdf:type rdf:Property ;
    rdfs:label 'Redemption Channel' ;
    rdfs:comment 'The storefront or platform where the promotional code was redeemed (e.g., Steam, Epic Games Store, console first-party stores, mobile app stores, in-game store, web store). [ENUM-REF-CANDIDATE: steam|epic_games_store|playstation_store|xbox_store|nintendo_eshop|mobile_app_store|in_game_store|web_store|retail_partner — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionCode rdf:type rdf:Property ;
    rdfs:label 'Redemption Code' ;
    rdfs:comment 'The actual promotional code string entered or applied by the player (e.g., SUMMER2024, WELCOME10).' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionCountryCode rdf:type rdf:Property ;
    rdfs:label 'Redemption Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code indicating the geographic location where the redemption occurred.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionDeviceType rdf:type rdf:Property ;
    rdfs:label 'Redemption Device Type' ;
    rdfs:comment 'The type of device used to redeem the promotional code (PC, console, mobile, tablet, web browser).' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionIpAddress rdf:type rdf:Property ;
    rdfs:label 'Redemption Ip Address' ;
    rdfs:comment 'The IP address from which the promotional code redemption was initiated, used for fraud detection and geographic analysis.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionPlatform rdf:type rdf:Property ;
    rdfs:label 'Redemption Platform' ;
    rdfs:comment 'The operating system or gaming platform on which the promotional code was redeemed. [ENUM-REF-CANDIDATE: windows|macos|linux|playstation|xbox|nintendo_switch|ios|android|web|unknown — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionRegion rdf:type rdf:Property ;
    rdfs:label 'Redemption Region' ;
    rdfs:comment 'The geographic region or market where the promotional code was redeemed (e.g., North America, Europe, Asia-Pacific).' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Redemption Status' ;
    rdfs:comment 'Current lifecycle status of the promotional redemption indicating whether the discount was successfully applied, reversed due to refund, or failed validation.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Redemption Timestamp' ;
    rdfs:comment 'The exact date and time when the promotional code was successfully redeemed by the player.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:referralCode rdf:type rdf:Property ;
    rdfs:label 'Referral Code' ;
    rdfs:comment 'The referral or affiliate code associated with this promotional redemption, if the promo was distributed through a referral program.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'The business reason why the promotional discount was reversed (e.g., order refund, chargeback, fraud detection, policy violation). Null if not reversed.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reversal Timestamp' ;
    rdfs:comment 'The date and time when the promotional discount was reversed. Null if the redemption has not been reversed.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'The name of the operational system that originated this promotional redemption record (e.g., Steamworks, Epic Games Store SDK, SAP S/4HANA, proprietary billing platform).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termsAcceptedFlag rdf:type rdf:Property ;
    rdfs:label 'Terms Accepted Flag' ;
    rdfs:comment 'Boolean flag indicating whether the player explicitly accepted the promotional terms and conditions at redemption time.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usageSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Usage Sequence Number' ;
    rdfs:comment 'The sequential usage count for this promotional code by this player (e.g., 1 for first use, 2 for second use), enabling multi-use promo tracking.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationErrorCode rdf:type rdf:Property ;
    rdfs:label 'Validation Error Code' ;
    rdfs:comment 'The system error code returned if the promotional code failed validation (e.g., EXPIRED, INVALID_CODE, USAGE_LIMIT_EXCEEDED, REGION_RESTRICTED). Null if validation succeeded.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationErrorMessage rdf:type rdf:Property ;
    rdfs:label 'Validation Error Message' ;
    rdfs:comment 'Human-readable error message explaining why the promotional code redemption failed validation. Null if validation succeeded.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundId rdf:type rdf:Property ;
    rdfs:label 'Refund Id' ;
    rdfs:comment 'Unique identifier for the refund or credit memo transaction. Primary key for the refund product.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Refund .

ind:settlementBatchId rdf:type rdf:Property ;
    rdfs:label 'Settlement Batch Id' ;
    rdfs:comment 'Identifier of the settlement batch in which this refund was included for platform payout reconciliation or payment processor settlement.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SettlementBatch .

ind:creditAppliedAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Applied Amount' ;
    rdfs:comment 'The cumulative amount of store credit that has been applied or redeemed by the player against subsequent purchases.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditBalanceRemaining rdf:type rdf:Property ;
    rdfs:label 'Credit Balance Remaining' ;
    rdfs:comment 'The remaining unused balance of store credit available for future player purchases.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Credit Expiry Date' ;
    rdfs:comment 'Expiration date for store credit or platform wallet credit, after which the credit becomes invalid and cannot be applied.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isAutomatedRefund rdf:type rdf:Property ;
    rdfs:label 'Is Automated Refund' ;
    rdfs:comment 'Flag indicating whether the refund was processed automatically by policy engine (true) or required manual approval (false).' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPartialRefund rdf:type rdf:Property ;
    rdfs:label 'Is Partial Refund' ;
    rdfs:comment 'Flag indicating whether this is a partial refund (true) or a full refund (false) of the original transaction amount.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Code' ;
    rdfs:comment 'Two or three-letter code representing the legal jurisdiction governing this refund transaction, relevant for consumer protection compliance (e.g., US, EU, UK, AU, CA).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Original Payment Amount' ;
    rdfs:comment 'The original payment amount from the transaction being refunded, for reconciliation and partial refund tracking.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformFeeRefundAmount rdf:type rdf:Property ;
    rdfs:label 'Platform Fee Refund Amount' ;
    rdfs:comment 'Portion of the refund representing platform holder fees (Steam, Epic, Apple, Google) being reversed or reclaimed.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:policyVersion rdf:type rdf:Property ;
    rdfs:label 'Policy Version' ;
    rdfs:comment 'Version identifier of the refund policy rules applied to this transaction, for audit and compliance tracking.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processed Timestamp' ;
    rdfs:comment 'The date and time when the refund was successfully processed and funds were returned to the player or credit was issued.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processorRefundReference rdf:type rdf:Property ;
    rdfs:label 'Processor Refund Reference' ;
    rdfs:comment 'External refund transaction identifier from the payment processor or gateway, used for reconciliation and dispute resolution.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for the refund: player_request, fraud, technical_failure, platform_policy, goodwill, billing_error, duplicate_charge, unauthorized_purchase, game_defect, service_outage, regulatory_compliance, chargeback. [ENUM-REF-CANDIDATE: player_request|fraud|technical_failure|platform_policy|goodwill|billing_error|duplicate_charge|unauthorized_purchase|game_defect|service_outage|regulatory_compliance|chargeback — promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Free-text detailed explanation of the refund reason, capturing context from player support tickets or internal investigation notes.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundNumber rdf:type rdf:Property ;
    rdfs:label 'Refund Number' ;
    rdfs:comment 'Externally visible unique business identifier for the refund transaction, used in player communications and support tickets.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundStatus rdf:type rdf:Property ;
    rdfs:label 'Refund Status' ;
    rdfs:comment 'Current lifecycle status of the refund: pending approval, approved, processed (funds returned), rejected, applied (credit used), expired (credit unused past expiry), or cancelled. [ENUM-REF-CANDIDATE: pending|approved|processed|rejected|applied|expired|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundType rdf:type rdf:Property ;
    rdfs:label 'Refund Type' ;
    rdfs:comment 'Classification of the refund mechanism: cash refund to original payment method, store credit (credit memo), platform wallet credit, chargeback reversal, or goodwill credit.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flag' ;
    rdfs:comment 'Flag indicating whether this refund was issued to comply with regulatory requirements (GDPR right to refund, consumer protection laws, platform policy mandates).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rejected Timestamp' ;
    rdfs:comment 'The date and time when the refund request was rejected or denied.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Requested Timestamp' ;
    rdfs:comment 'The date and time when the player or system initiated the refund request.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:returnMethod rdf:type rdf:Property ;
    rdfs:label 'Return Method' ;
    rdfs:comment 'The mechanism by which the refund value is returned to the player: original payment method (credit card, PayPal), store credit, platform wallet, bank transfer, or physical check.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRefundAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Refund Amount' ;
    rdfs:comment 'Portion of the refund amount representing tax reversal (VAT, sales tax, GST) being returned to the player.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalRecognitionEventRevenueRecognitionId rdf:type rdf:Property ;
    rdfs:label 'Original Recognition Event Revenue Recognition Id' ;
    rdfs:comment 'Reference to the original revenue recognition event being reversed, if reversal_flag is True. Null for non-reversal events.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueRecognition .

ind:performanceObligationId rdf:type rdf:Property ;
    rdfs:label 'Performance Obligation Id' ;
    rdfs:comment 'Identifier for the specific performance obligation being satisfied. Relevant for contracts with multiple deliverables (e.g., game + season pass + in-game currency).' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformanceObligation .

ind:primaryRevenueEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Revenue Employee Id' ;
    rdfs:comment 'Identifier of the user or system process that created this revenue recognition record. Supports audit and compliance requirements.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:profitCenterId rdf:type rdf:Property ;
    rdfs:label 'Profit Center Id' ;
    rdfs:comment 'Foreign key linking to finance.profit_center. Business justification: Revenue recognition drives profit center reporting for title performance analysis and portfolio management. Gaming companies use profit centers to track title-level profitability and make investment d' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:accountingPeriod rdf:type rdf:Property ;
    rdfs:label 'Accounting Period' ;
    rdfs:comment 'The fiscal period (YYYY-MM or YYYY-QX) to which this revenue recognition is allocated. Used for period-end close and financial reporting.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'Method used to allocate transaction price to multiple performance obligations. Standalone_selling_price for observable prices; residual for unobservable prices; adjusted_market_assessment for market-based estimates.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractModificationDate rdf:type rdf:Property ;
    rdfs:label 'Contract Modification Date' ;
    rdfs:comment 'Date the contract was modified, if contract_modification_flag is True. Null for unmodified contracts.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractModificationFlag rdf:type rdf:Property ;
    rdfs:label 'Contract Modification Flag' ;
    rdfs:comment 'Indicates whether this recognition event resulted from a contract modification (e.g., subscription upgrade, refund, chargeback, price adjustment). True if modified; False if original contract terms.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractModificationReason rdf:type rdf:Property ;
    rdfs:label 'Contract Modification Reason' ;
    rdfs:comment 'Reason for contract modification (e.g., \'Player upgraded subscription tier\', \'Refund issued\', \'Chargeback processed\', \'Price adjustment applied\').' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferredAmount rdf:type rdf:Property ;
    rdfs:label 'Deferred Amount' ;
    rdfs:comment 'The amount of revenue deferred to future periods. Represents unearned revenue for services not yet delivered (e.g., remaining months of a subscription, unreleased DLC in a season pass).' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceObligationDescription rdf:type rdf:Property ;
    rdfs:label 'Performance Obligation Description' ;
    rdfs:comment 'Textual description of the performance obligation being satisfied (e.g., \'Deliver base game\', \'Provide 12 months of live service\', \'Grant access to DLC content\').' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Date' ;
    rdfs:comment 'The date on which revenue was recognized in the general ledger. The principal business event timestamp for this transaction.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionEventNumber rdf:type rdf:Property ;
    rdfs:label 'Recognition Event Number' ;
    rdfs:comment 'Externally-visible unique business identifier for this revenue recognition event. Format: RRE-XXXXXXXXXX.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Recognition Method' ;
    rdfs:comment 'The method used to recognize revenue per ASC 606. Point-in-time for one-time purchases (game sales, DLC); over-time for subscriptions and GaaS; proportional for bundled offerings; milestone for performance-based contracts; usage-based for consumption models.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionPercentage rdf:type rdf:Property ;
    rdfs:label 'Recognition Percentage' ;
    rdfs:comment 'Percentage of total transaction amount recognized in this event. Used for proportional and milestone-based recognition. Range: 0.00 to 100.00.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recognitionStatus rdf:type rdf:Property ;
    rdfs:label 'Recognition Status' ;
    rdfs:comment 'Current lifecycle status of the revenue recognition event. Tracks whether revenue has been recognized, is still deferred, or has been adjusted.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognizedAmount rdf:type rdf:Property ;
    rdfs:label 'Recognized Amount' ;
    rdfs:comment 'The amount of revenue recognized in this event. For point-in-time recognition, equals total_transaction_amount. For over-time, represents the portion recognized in this period.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingDeferredBalance rdf:type rdf:Property ;
    rdfs:label 'Remaining Deferred Balance' ;
    rdfs:comment 'The cumulative deferred revenue balance remaining after this recognition event. Tracks the liability for unearned revenue.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Category' ;
    rdfs:comment 'High-level categorization of revenue. Product for one-time sales; service for ongoing subscriptions/GaaS; hybrid for bundled offerings.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueType rdf:type rdf:Property ;
    rdfs:label 'Revenue Type' ;
    rdfs:comment 'Classification of the revenue stream. Game_sale for base game purchases; DLC for downloadable content; season_pass for bundled future content; subscription for recurring GaaS fees; MTX/IAP for in-game microtransactions; licensing for engine/IP licensing; advertising for ad-supported F2P models. [ENUM-REF-CANDIDATE: game_sale|dlc|season_pass|subscription|mtx|iap|licensing|advertising — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this event reverses previously recognized revenue (e.g., due to refund, chargeback, or accounting correction). True if reversal; False if original recognition.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:servicePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Service Period End Date' ;
    rdfs:comment 'End date of the service period for over-time revenue recognition (e.g., subscription end date, GaaS service period end). Null for point-in-time recognition.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:servicePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Service Period Start Date' ;
    rdfs:comment 'Start date of the service period for over-time revenue recognition (e.g., subscription start date, GaaS service period start). Null for point-in-time recognition.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalTransactionAmount rdf:type rdf:Property ;
    rdfs:label 'Total Transaction Amount' ;
    rdfs:comment 'The total transaction price allocated to this performance obligation. Gross amount before recognition adjustments.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionDate rdf:type rdf:Property ;
    rdfs:label 'Transaction Date' ;
    rdfs:comment 'The date the underlying transaction (purchase, subscription charge) occurred. May differ from recognition_date for deferred revenue scenarios.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'Date and time when the order was cancelled, either by the player or by the system due to payment failure.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:chargebackTimestamp rdf:type rdf:Property ;
    rdfs:label 'Chargeback Timestamp' ;
    rdfs:comment 'Date and time when the chargeback was filed by the players payment provider.' ;
    rdfs:domain ind:StorefrontOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:completedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completed Timestamp' ;
    rdfs:comment 'Date and time when the order was marked as completed and all entitlements were delivered to the player.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:entitlementDeliveredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Entitlement Delivered Timestamp' ;
    rdfs:comment 'Date and time when all purchased entitlements were successfully delivered to the players account.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:entitlementDeliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Entitlement Delivery Status' ;
    rdfs:comment 'Status of digital entitlement delivery to the players account (e.g., game license, DLC unlock, virtual currency). Drives customer support escalation.' ;
    rdfs:domain ind:StorefrontOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSubscription rdf:type rdf:Property ;
    rdfs:label 'Is Subscription' ;
    rdfs:comment 'Indicates whether this order is part of a recurring subscription billing cycle (e.g., monthly game pass, season pass auto-renewal).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Externally-visible unique order number assigned by the storefront platform. Used for customer service, refunds, and reconciliation.' ;
    rdfs:domain ind:StorefrontOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the order. Drives revenue recognition, entitlement delivery, and customer support workflows.' ;
    rdfs:domain ind:StorefrontOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Timestamp' ;
    rdfs:comment 'Date and time when the player placed the order. Principal business event timestamp for this transaction.' ;
    rdfs:domain ind:StorefrontOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:paymentAuthorizedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Payment Authorized Timestamp' ;
    rdfs:comment 'Date and time when payment authorization was received from the payment processor or platform holder.' ;
    rdfs:domain ind:StorefrontOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:playerRegion rdf:type rdf:Property ;
    rdfs:label 'Player Region' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the players billing region. Determines tax jurisdiction, content ratings, and regional pricing.' ;
    rdfs:domain ind:StorefrontOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalCode rdf:type rdf:Property ;
    rdfs:label 'Promotional Code' ;
    rdfs:comment 'Promotional or discount code applied by the player at checkout. Used for marketing attribution and discount tracking.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundProcessedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Refund Processed Timestamp' ;
    rdfs:comment 'Date and time when the refund was processed and funds were returned to the players payment method.' ;
    rdfs:domain ind:StorefrontOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:refundReason rdf:type rdf:Property ;
    rdfs:label 'Refund Reason' ;
    rdfs:comment 'Reason provided for the refund request (e.g., accidental purchase, technical issue, player dissatisfaction). Used for quality analysis and fraud detection.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundRequestedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Refund Requested Timestamp' ;
    rdfs:comment 'Date and time when the player or customer support initiated the refund request.' ;
    rdfs:domain ind:StorefrontOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:storefrontPlatform rdf:type rdf:Property ;
    rdfs:label 'Storefront Platform' ;
    rdfs:comment 'Digital distribution platform where the order was placed. Determines revenue share, settlement terms, and certification requirements. [ENUM-REF-CANDIDATE: steam|epic_games_store|playstation_store|xbox_marketplace|nintendo_eshop|apple_app_store|google_play — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionReference rdf:type rdf:Property ;
    rdfs:label 'Transaction Reference' ;
    rdfs:comment 'External transaction identifier provided by the payment processor or platform holder. Used for reconciliation and dispute resolution.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storefrontOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Storefront Order Line Id' ;
    rdfs:comment 'Unique identifier for the storefront order line item. Primary key for this entity representing a single SKU within a purchase order.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorefrontOrderLine .

ind:assetBundleId rdf:type rdf:Property ;
    rdfs:label 'Asset Bundle Id' ;
    rdfs:comment 'Foreign key linking to content.asset_bundle. Business justification: Order lines reference specific asset bundles purchased (map packs, skin bundles, content packs). Essential for bundle sales analytics, bundle pricing optimization, and understanding which content pack' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetBundle .

ind:bundleParentLineId rdf:type rdf:Property ;
    rdfs:label 'Bundle Parent Line Id' ;
    rdfs:comment 'Reference to the parent line item if this line is part of a bundle purchase. Enables bundle component tracking and revenue allocation.' ;
    rdfs:domain ind:StorefrontOrderLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorefrontOrderLine .

ind:entitlementId rdf:type rdf:Property ;
    rdfs:label 'Entitlement Id' ;
    rdfs:comment 'Unique identifier for the digital entitlement granted to the player. Used to track ownership and prevent duplicate grants.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Entitlement .

ind:matchmakingPoolId rdf:type rdf:Property ;
    rdfs:label 'Matchmaking Pool Id' ;
    rdfs:comment 'Foreign key linking to infrastructure.matchmaking_pool. Business justification: Competitive games monetize ranked/premium matchmaking access via season passes or priority queue purchases. Line items track which pool the entitlement grants access to. Business process: feature-base' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MatchmakingPool .

ind:mtxCatalogId rdf:type rdf:Property ;
    rdfs:label 'Mtx Catalog Id' ;
    rdfs:comment 'Foreign key linking to monetization.mtx_catalog. Business justification: Storefront orders for MTX items reference catalog for pricing validation, entitlement delivery, and revenue recognition. Order fulfillment workflows require linking order lines to MTX catalog entries ' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MtxCatalog .

ind:promotionalOfferId rdf:type rdf:Property ;
    rdfs:label 'Promotional Offer Id' ;
    rdfs:comment 'Reference to the promotional campaign or offer that provided the discount. Links to marketing campaign master data for attribution analysis.' ;
    rdfs:domain ind:StorefrontOrderLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogOffer .

ind:couponCode rdf:type rdf:Property ;
    rdfs:label 'Coupon Code' ;
    rdfs:comment 'Player-entered coupon or promotional code applied to this line item. Captured for campaign tracking and fraud detection.' ;
    rdfs:domain ind:StorefrontOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementStatus rdf:type rdf:Property ;
    rdfs:label 'Entitlement Status' ;
    rdfs:comment 'Current fulfillment status of the digital entitlement for this line item. Tracks whether the player has received access to the purchased content.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBundleComponent rdf:type rdf:Property ;
    rdfs:label 'Is Bundle Component' ;
    rdfs:comment 'Indicates whether this line item is a component of a larger bundle purchase. Used to distinguish standalone purchases from bundle components.' ;
    rdfs:domain ind:StorefrontOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineSubtotal rdf:type rdf:Property ;
    rdfs:label 'Line Subtotal' ;
    rdfs:comment 'Total amount for this line before taxes. Calculated as quantity multiplied by unit price minus discount amount.' ;
    rdfs:domain ind:StorefrontOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionStatus rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Status' ;
    rdfs:comment 'Current status of revenue recognition for this line item. Tracks whether revenue has been recognized immediately or is being deferred over time.' ;
    rdfs:domain ind:StorefrontOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:virtualCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Virtual Currency Amount' ;
    rdfs:comment 'Quantity of virtual currency granted if this line item is a virtual currency pack. Null for non-currency SKUs.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Cancelled By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Customer service reps cancel subscriptions on behalf of players (refund requests, account issues). Tracking which employee processed the cancellation is critical for churn analysis, training needs ass' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:consentPolicyId rdf:type rdf:Property ;
    rdfs:label 'Consent Policy Id' ;
    rdfs:comment 'Foreign key linking to compliance.consent_policy. Business justification: Subscriptions require explicit consent tracking under GDPR/CCPA for recurring billing. Gaming companies must prove which policy version player accepted at subscription start. Critical for regulatory a' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsentPolicy .

ind:subscriptionGiftedByPlayerPlayerAccountId rdf:type rdf:Property ;
    rdfs:label 'Subscription Gifted By Player Player Account Id' ;
    rdfs:comment 'Identifier of the player who purchased this subscription as a gift. Null if not a gift subscription.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerAccount .

ind:subscriptionPlanId rdf:type rdf:Property ;
    rdfs:label 'Subscription Plan Id' ;
    rdfs:comment 'Identifier of the subscription plan tier that defines pricing, features, and billing frequency for this subscription.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SubscriptionPlan .

ind:subscriptionPlayerAccountId rdf:type rdf:Property ;
    rdfs:label 'Subscription Player Account Id' ;
    rdfs:comment 'Identifier of the player who owns this subscription.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerAccount .

ind:acquisitionChannel rdf:type rdf:Property ;
    rdfs:label 'Acquisition Channel' ;
    rdfs:comment 'Marketing channel through which the player discovered and subscribed (organic, paid search, social media, email, referral, in-game promotion, web, mobile app). [ENUM-REF-CANDIDATE: organic|paid_search|social_media|email|referral|in_game|web|mobile_app — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingFrequency rdf:type rdf:Property ;
    rdfs:label 'Billing Frequency' ;
    rdfs:comment 'Recurring billing cycle interval for the subscription (monthly, quarterly, annual, lifetime one-time payment).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'Date when the player cancelled the subscription. Null if subscription has not been cancelled.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationFeedback rdf:type rdf:Property ;
    rdfs:label 'Cancellation Feedback' ;
    rdfs:comment 'Free-text feedback provided by the player at cancellation explaining their decision. Used for qualitative churn analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Player-provided reason for cancelling the subscription. Used for churn analysis and retention strategy.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Timestamp' ;
    rdfs:comment 'Timestamp when the player provided explicit consent to the subscription terms and recurring billing authorization. Required for GDPR and payment processor compliance.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currentPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Current Period End Date' ;
    rdfs:comment 'End date of the current billing period. Next renewal or expiration occurs on this date.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Current Period Start Date' ;
    rdfs:comment 'Start date of the current billing period for which the player has paid or will be charged.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discountEndDate rdf:type rdf:Property ;
    rdfs:label 'Discount End Date' ;
    rdfs:comment 'Date when the promotional discount expires and full price billing resumes. Null if discount is permanent or no discount applied.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalSubscriptionReference rdf:type rdf:Property ;
    rdfs:label 'External Subscription Reference' ;
    rdfs:comment 'Subscription identifier from the external payment processor or platform (e.g., Stripe subscription ID, Apple subscription ID). Used for reconciliation and support.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failedPaymentCount rdf:type rdf:Property ;
    rdfs:label 'Failed Payment Count' ;
    rdfs:comment 'Total number of failed billing attempts for this subscription. Used to identify at-risk subscriptions and trigger dunning workflows.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isGiftSubscription rdf:type rdf:Property ;
    rdfs:label 'Is Gift Subscription' ;
    rdfs:comment 'Indicates whether this subscription was purchased as a gift by another player (True) or self-purchased (False).' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTrialActive rdf:type rdf:Property ;
    rdfs:label 'Is Trial Active' ;
    rdfs:comment 'Indicates whether the subscription is currently in its free trial period (True) or has converted to paid billing (False).' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Last Payment Amount' ;
    rdfs:comment 'Amount charged in the most recent successful payment in the subscription currency.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Payment Date' ;
    rdfs:comment 'Date of the most recent successful payment for this subscription.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextBillingDate rdf:type rdf:Property ;
    rdfs:label 'Next Billing Date' ;
    rdfs:comment 'Date when the next recurring payment will be charged if auto-renew is enabled. Null if subscription is cancelled or expired.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:platformSubscriptionStatus rdf:type rdf:Property ;
    rdfs:label 'Platform Subscription Status' ;
    rdfs:comment 'Raw subscription status value from the external platform or payment processor. Used for reconciliation and debugging platform-specific subscription states.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:price rdf:type rdf:Property ;
    rdfs:label 'Price' ;
    rdfs:comment 'Recurring price charged per billing cycle for this subscription in the subscription currency.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalCount rdf:type rdf:Property ;
    rdfs:label 'Renewal Count' ;
    rdfs:comment 'Total number of successful billing renewals since subscription start. Used to calculate subscription tenure and LTV (Lifetime Value).' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subscriptionNumber rdf:type rdf:Property ;
    rdfs:label 'Subscription Number' ;
    rdfs:comment 'Human-readable external subscription identifier displayed to players and used in customer support interactions.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionStatus rdf:type rdf:Property ;
    rdfs:label 'Subscription Status' ;
    rdfs:comment 'Current lifecycle state of the subscription. Active: subscription is live and billing. Paused: temporarily suspended by player. Cancelled: player terminated, no future billing. Expired: ended due to non-payment or term completion. Pending: awaiting payment confirmation. Trial: in free trial period.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionTier rdf:type rdf:Property ;
    rdfs:label 'Subscription Tier' ;
    rdfs:comment 'Service tier level of the subscription plan defining feature access and benefits (basic, standard, premium, ultimate).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialEndDate rdf:type rdf:Property ;
    rdfs:label 'Trial End Date' ;
    rdfs:comment 'Date when the free trial period ends and first billing occurs. Null if no trial period.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trialPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Trial Period Days' ;
    rdfs:comment 'Number of days in the free trial period before first billing occurs. Null if no trial offered.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billedAmount rdf:type rdf:Property ;
    rdfs:label 'Billed Amount' ;
    rdfs:comment 'The gross amount charged to the player for this billing cycle before any adjustments or taxes.' ;
    rdfs:domain ind:SubscriptionCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingAttemptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Billing Attempt Timestamp' ;
    rdfs:comment 'The exact timestamp when the billing system attempted to charge the player for this cycle. Primary business event timestamp for the billing execution.' ;
    rdfs:domain ind:SubscriptionCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billingPeriodType rdf:type rdf:Property ;
    rdfs:label 'Billing Period Type' ;
    rdfs:comment 'The frequency or type of billing period for this cycle (e.g., monthly, quarterly, annual). Defines the subscription billing cadence.' ;
    rdfs:domain ind:SubscriptionCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleEndDate rdf:type rdf:Property ;
    rdfs:label 'Cycle End Date' ;
    rdfs:comment 'The date when this billing cycle period ended. Defines the end of the service period being billed.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cycleNumber rdf:type rdf:Property ;
    rdfs:label 'Cycle Number' ;
    rdfs:comment 'Sequential cycle number within the subscription lifecycle. First cycle is 1, increments with each billing period.' ;
    rdfs:domain ind:SubscriptionCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cycleStartDate rdf:type rdf:Property ;
    rdfs:label 'Cycle Start Date' ;
    rdfs:comment 'The date when this billing cycle period began. Defines the start of the service period being billed.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cycleStatus rdf:type rdf:Property ;
    rdfs:label 'Cycle Status' ;
    rdfs:comment 'Current status of the billing cycle execution. Tracks the lifecycle state of the billing attempt and settlement. [ENUM-REF-CANDIDATE: pending|billed|failed|retried|skipped|cancelled|refunded — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'The dunning stage or level for this billing cycle if payment failed. Indicates progression through automated retry and notification sequence (0=no dunning, 1-5=escalating stages).' ;
    rdfs:domain ind:SubscriptionCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'The final net amount charged to the player after applying taxes and discounts. This is the actual amount settled.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentGateway rdf:type rdf:Property ;
    rdfs:label 'Payment Gateway' ;
    rdfs:comment 'The payment gateway or processor used to execute this billing cycle charge (e.g., Stripe, PayPal, Braintree).' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prorationAmount rdf:type rdf:Property ;
    rdfs:label 'Proration Amount' ;
    rdfs:comment 'The prorated adjustment amount applied to this billing cycle. Positive for credits, negative for additional charges. Null if no proration applied.' ;
    rdfs:domain ind:SubscriptionCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prorationApplied rdf:type rdf:Property ;
    rdfs:label 'Proration Applied' ;
    rdfs:comment 'Indicates whether proration was applied to this billing cycle due to mid-cycle subscription changes, upgrades, or downgrades.' ;
    rdfs:domain ind:SubscriptionCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retryAttemptCount rdf:type rdf:Property ;
    rdfs:label 'Retry Attempt Count' ;
    rdfs:comment 'Number of retry attempts made for this billing cycle if the initial charge failed. Zero indicates first attempt was successful.' ;
    rdfs:domain ind:SubscriptionCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'The date when the funds from this billing cycle were settled and transferred to the company account. Null if not yet settled.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementReference rdf:type rdf:Property ;
    rdfs:label 'Settlement Reference' ;
    rdfs:comment 'Reference identifier for the financial settlement batch or payout that includes this billing cycle. Used for reconciliation with platform holders and payment processors.' ;
    rdfs:domain ind:SubscriptionCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chatSessionId rdf:type rdf:Property ;
    rdfs:label 'Chat Session Id' ;
    rdfs:comment 'Unique surrogate identifier for each live chat support session record in the Zendesk Chat platform. Primary key for the chat_session data product.' ;
    rdfs:domain ind:ChatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageVerificationEventId rdf:type rdf:Property ;
    rdfs:label 'Age Verification Event Id' ;
    rdfs:comment 'Foreign key linking to compliance.age_verification_event. Business justification: Live chat support agents verify player age when discussing age-restricted content, purchases, or COPPA-protected data. Links support interaction to formal age verification audit trail required for reg' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AgeVerificationEvent .

ind:playerSubscriptionId rdf:type rdf:Property ;
    rdfs:label 'Player Subscription Id' ;
    rdfs:comment 'Foreign key linking to monetization.player_subscription. Business justification: Subscription billing inquiries handled via live chat (cancellation requests, payment method updates, billing cycle questions). Chat sessions need subscription context to verify status, process cancell' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerSubscription .

ind:agentTeam rdf:type rdf:Property ;
    rdfs:label 'Agent Team' ;
    rdfs:comment 'The support team or group to which the handling agent belongs (e.g., \'Tier 1 General\', \'Tier 2 Technical\', \'VIP Concierge\', \'Esports Player Support\'). Enables team-level performance benchmarking and workload distribution analysis.' ;
    rdfs:domain ind:ChatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coppaMinorFlag rdf:type rdf:Property ;
    rdfs:label 'Coppa Minor Flag' ;
    rdfs:comment 'Indicates whether the player associated with this chat session is identified as a minor (under 13 in the US, under 16 in the EU) subject to Children\'s Online Privacy Protection Act (COPPA) or GDPR child data protections. True = minor player; False = adult player. Triggers special handling protocols for transcript retention, data access, and parental consent verification.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:csatComment rdf:type rdf:Property ;
    rdfs:label 'Csat Comment' ;
    rdfs:comment 'Free-text qualitative feedback provided by the player alongside the CSAT score in the post-chat survey. Contains player sentiment and specific feedback about the support experience. Classified confidential due to potentially sensitive player-expressed content.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csatScore rdf:type rdf:Property ;
    rdfs:label 'Csat Score' ;
    rdfs:comment 'The Customer Satisfaction (CSAT) score provided by the player following the chat session, typically on a 1–5 scale (or binary Good/Bad mapped to 1/0). Null if the player did not respond to the post-chat survey. Core KPI for player support quality measurement.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csatSurveySent rdf:type rdf:Property ;
    rdfs:label 'Csat Survey Sent' ;
    rdfs:comment 'Indicates whether a post-chat CSAT survey was sent to the player after session close. True = survey dispatched; False = survey not sent (e.g., session abandoned, player opted out, bot-only session below threshold). Enables accurate CSAT response rate calculation.' ;
    rdfs:domain ind:ChatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstResponseTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'First Response Time Seconds' ;
    rdfs:comment 'The number of seconds elapsed from when the session was assigned to an agent or bot until the first message was sent to the player. Distinct from wait_time_seconds which measures queue time; this measures agent responsiveness after assignment.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gdprDataSubjectRequest rdf:type rdf:Property ;
    rdfs:label 'Gdpr Data Subject Request' ;
    rdfs:comment 'Indicates whether this chat session is associated with or triggered by a GDPR data subject request (e.g., right of access, right to erasure, data portability). True = session is linked to a DSR; False = standard support session. Enables compliance workflow tracking and audit trail for GDPR supervisory authority reporting.' ;
    rdfs:domain ind:ChatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:handleTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Handle Time Seconds' ;
    rdfs:comment 'The total number of seconds from first agent/bot response to session close. Represents the active engagement duration and is a primary operational efficiency KPI for the player support team.' ;
    rdfs:domain ind:ChatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isBotHandled rdf:type rdf:Property ;
    rdfs:label 'Is Bot Handled' ;
    rdfs:comment 'Indicates whether the chat session was fully handled by an automated bot (chatbot/virtual agent) without any human agent involvement. True = bot-only session; False = human agent was involved at some point. Key metric for bot deflection rate reporting.' ;
    rdfs:domain ind:ChatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEscalatedToHuman rdf:type rdf:Property ;
    rdfs:label 'Is Escalated To Human' ;
    rdfs:comment 'Indicates whether the chat session was escalated from a bot or initial automated routing to a live human support agent. True = escalation occurred; False = no escalation. Used to measure bot containment rate and escalation triggers.' ;
    rdfs:domain ind:ChatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFirstContact rdf:type rdf:Property ;
    rdfs:label 'Is First Contact' ;
    rdfs:comment 'Indicates whether this chat session represents the player\'s first-ever contact with player support. True = first contact; False = returning contact. Used to measure First-Time User Experience (FTUE) support rates and new player onboarding friction.' ;
    rdfs:domain ind:ChatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRepeatContact rdf:type rdf:Property ;
    rdfs:label 'Is Repeat Contact' ;
    rdfs:comment 'Indicates whether the player contacted support again for the same issue within a defined lookback window (typically 7 days), signaling an unresolved prior interaction. True = repeat contact on same issue; False = new or unrelated contact. Key metric for First Contact Resolution (FCR) quality measurement.' ;
    rdfs:domain ind:ChatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueCategory rdf:type rdf:Property ;
    rdfs:label 'Issue Category' ;
    rdfs:comment 'The primary category of the player\'s support issue as classified by the agent or automated tagging system. Examples include account_access, billing, gameplay_bug, in_game_purchase, ban_appeal, technical_performance. [ENUM-REF-CANDIDATE: account_access|billing|gameplay_bug|in_game_purchase|ban_appeal|technical_performance|content_report|other — promote to reference product]' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueSubcategory rdf:type rdf:Property ;
    rdfs:label 'Issue Subcategory' ;
    rdfs:comment 'The secondary classification of the player\'s support issue, providing granular detail beneath issue_category. For example, under \'billing\': refund_request, charge_dispute, subscription_cancellation. Enables detailed support trend analysis and knowledge base optimization.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageCount rdf:type rdf:Property ;
    rdfs:label 'Message Count' ;
    rdfs:comment 'Total number of messages exchanged (both player and agent/bot) during the chat session. Indicates session complexity and engagement depth; used in workload analysis and bot deflection effectiveness measurement.' ;
    rdfs:domain ind:ChatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pciSensitiveDataShared rdf:type rdf:Property ;
    rdfs:label 'Pci Sensitive Data Shared' ;
    rdfs:comment 'Indicates whether the player shared or attempted to share payment card or PCI-sensitive data during the chat session. True = PCI-sensitive data detected in transcript; False = no PCI data detected. Triggers mandatory transcript masking, security review, and PCI DSS compliance escalation procedures.' ;
    rdfs:domain ind:ChatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:playerAccountAgeDays rdf:type rdf:Property ;
    rdfs:label 'Player Account Age Days' ;
    rdfs:comment 'The age of the player\'s account in days at the time the chat session was initiated. Enables segmentation of support contacts by player tenure (e.g., new player FTUE issues vs. veteran player issues) and informs retention risk analysis.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playerLocale rdf:type rdf:Property ;
    rdfs:label 'Player Locale' ;
    rdfs:comment 'The locale code (IETF BCP 47 format, e.g., en_US, fr_FR, de_DE, ja_JP) of the player at the time of the chat session. Drives language routing, localization of support responses, and regional support volume analysis.' ;
    rdfs:domain ind:ChatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queueName rdf:type rdf:Property ;
    rdfs:label 'Queue Name' ;
    rdfs:comment 'The name of the Zendesk Chat department or routing queue to which the session was assigned. Examples: \'Billing Support\', \'Technical Support\', \'VIP Player Care\', \'Ban Appeals\'. Enables queue-level performance analysis and staffing optimization.' ;
    rdfs:domain ind:ChatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'The outcome resolution state of the chat session at close. \'resolved\' = issue addressed to completion; \'unresolved\' = issue not resolved during session; \'follow_up_required\' = agent flagged need for further action; \'transferred\' = session handed off to another channel or team.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:satisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Satisfaction Rating' ;
    rdfs:comment 'The binary satisfaction rating as recorded in Zendesk\'s native Good/Bad CSAT system, distinct from the numeric csat_score. \'good\' = positive rating; \'bad\' = negative rating; \'unoffered\' = survey not offered. Aligns with Zendesk\'s native satisfaction_rating field for source system reconciliation.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionKey rdf:type rdf:Property ;
    rdfs:label 'Session Key' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the chat session as assigned by Zendesk Chat. Used for cross-system referencing, audit trails, and player-facing session references.' ;
    rdfs:domain ind:ChatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionStatus rdf:type rdf:Property ;
    rdfs:label 'Session Status' ;
    rdfs:comment 'Current lifecycle state of the chat session. \'open\' = session initiated and in queue; \'active\' = agent/bot engaged; \'waiting\' = awaiting player response; \'resolved\' = session closed with resolution; \'abandoned\' = player left before resolution; \'missed\' = no agent available.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transcriptReference rdf:type rdf:Property ;
    rdfs:label 'Transcript Reference' ;
    rdfs:comment 'Reference key or storage path pointing to the full chat transcript stored in the secure transcript repository (e.g., cloud object storage path or Zendesk transcript ID). The transcript itself is not stored inline; this field enables retrieval for QA, compliance, and dispute resolution.' ;
    rdfs:domain ind:ChatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waitTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Wait Time Seconds' ;
    rdfs:comment 'The number of seconds the player waited in the support queue from session initiation until an agent or bot first responded. Key metric for queue performance, staffing adequacy, and player experience benchmarking.' ;
    rdfs:domain ind:ChatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:banId rdf:type rdf:Property ;
    rdfs:label 'Ban Id' ;
    rdfs:comment 'Unique surrogate identifier for each community ban or suspension record. Primary key for the community_ban entity in the Silver Layer lakehouse.' ;
    rdfs:domain ind:Ban ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:banAppealReviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Ban Appeal Reviewer Employee Id' ;
    rdfs:comment 'Reference to the moderator or senior staff member who reviewed and resolved the appeal. Supports accountability and separation of duties between ban issuance and appeal review.' ;
    rdfs:domain ind:Ban ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:banEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Ban Employee Id' ;
    rdfs:comment 'Reference to the moderator or staff member who issued this ban. Used for accountability, audit trails, and moderator performance tracking.' ;
    rdfs:domain ind:Ban ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:playerReportId rdf:type rdf:Property ;
    rdfs:label 'Player Report Id' ;
    rdfs:comment 'Reference to the player report that initiated or contributed to this ban, if applicable. Enables traceability from community report through to enforcement outcome.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerReport .

ind:appealNotes rdf:type rdf:Property ;
    rdfs:label 'Appeal Notes' ;
    rdfs:comment 'Free-text notes recorded by the appeal reviewer documenting the rationale for the appeal outcome. Supports audit trails and policy consistency reviews.' ;
    rdfs:domain ind:Ban ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealOutcome rdf:type rdf:Property ;
    rdfs:label 'Appeal Outcome' ;
    rdfs:comment 'Final decision on the player\'s appeal. \'upheld\' means the original ban stands; \'overturned\' means the ban is reversed; \'modified\' means the ban terms were changed (e.g., duration reduced); \'withdrawn\' means the player withdrew the appeal before resolution.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealResolvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Appeal Resolved Timestamp' ;
    rdfs:comment 'Date and time when the appeal review was completed and a final outcome was recorded. Null if appeal is still pending or not submitted. Used to measure appeal resolution time and SLA adherence.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:appealStatus rdf:type rdf:Property ;
    rdfs:label 'Appeal Status' ;
    rdfs:comment 'Current status of the player\'s appeal against this ban. \'not_appealed\' means no appeal has been submitted; \'pending\' means appeal submitted but not yet reviewed; \'under_review\' means actively being reviewed; \'upheld\' means ban confirmed; \'overturned\' means ban reversed; \'withdrawn\' means player withdrew the appeal.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealSubmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Appeal Submitted Timestamp' ;
    rdfs:comment 'Date and time when the player submitted their appeal against this ban. Null if no appeal has been filed. Used to track appeal SLA compliance.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:autoModerationScore rdf:type rdf:Property ;
    rdfs:label 'Auto Moderation Score' ;
    rdfs:comment 'Confidence score (0.0000–1.0000) assigned by the automated moderation system that triggered or contributed to this ban. Populated only when is_automated is True. Used to calibrate and audit automated enforcement thresholds.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:banNumber rdf:type rdf:Property ;
    rdfs:label 'Ban Number' ;
    rdfs:comment 'Human-readable, externally referenceable identifier for this ban (e.g., BAN-202400012345). Used in player communications, appeal correspondence, and support tickets.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:banScope rdf:type rdf:Property ;
    rdfs:label 'Ban Scope' ;
    rdfs:comment 'The community feature area(s) to which this ban applies. \'forum\' restricts forum posting; \'chat\' restricts in-game and community chat; \'ugc\' restricts User-Generated Content (UGC) submissions; \'all_community\' applies a full community ban across all features.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:banStatus rdf:type rdf:Property ;
    rdfs:label 'Ban Status' ;
    rdfs:comment 'Current lifecycle state of the community ban. \'active\' means the ban is currently enforced; \'expired\' means the ban end date has passed; \'lifted\' means the ban was manually removed; \'appealed\' means an appeal is in progress; \'pending_review\' means the ban is under internal review.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:banType rdf:type rdf:Property ;
    rdfs:label 'Ban Type' ;
    rdfs:comment 'Classification of the ban duration model. \'temporary\' bans have a defined end date; \'permanent\' bans have no end date (null ban_end_timestamp); \'shadow\' bans restrict visibility without notifying the player, used for spam and bot suppression.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRatingConcern rdf:type rdf:Property ;
    rdfs:label 'Content Rating Concern' ;
    rdfs:comment 'Indicates whether the violation underlying this ban involved content that may affect the game\'s content rating classification (e.g., extreme violence, sexual content, hate speech). Flags for escalation to the content compliance team for ESRB/PEGI review.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationHours rdf:type rdf:Property ;
    rdfs:label 'Duration Hours' ;
    rdfs:comment 'The originally assigned duration of the ban in hours at the time of issuance. Null for permanent bans. Enables duration-based analytics and policy benchmarking independent of actual start/end timestamps.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'The date and time when this ban is scheduled to expire. Null for permanent bans (ban_type = \'permanent\'). When the current timestamp exceeds this value, ban_status transitions to \'expired\'.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:evidenceAttachmentCount rdf:type rdf:Property ;
    rdfs:label 'Evidence Attachment Count' ;
    rdfs:comment 'Number of evidence files (screenshots, chat logs, video clips) attached to this ban record to substantiate the violation. Supports audit completeness checks and appeal review.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gdprConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Flag' ;
    rdfs:comment 'Indicates whether the player has provided valid GDPR consent for processing of their personal data in connection with this ban record. Relevant for EU-jurisdiction players and required for lawful processing under GDPR Article 6.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAutomated rdf:type rdf:Property ;
    rdfs:label 'Is Automated' ;
    rdfs:comment 'Indicates whether this ban was issued automatically by an automated moderation system (e.g., anti-cheat engine, spam detection, toxicity classifier) rather than by a human moderator. Supports audit of automated enforcement accuracy.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMinorInvolved rdf:type rdf:Property ;
    rdfs:label 'Is Minor Involved' ;
    rdfs:comment 'Indicates whether the banned player is identified as a minor (under 18, or under 13 for COPPA purposes). Triggers enhanced data handling, parental notification workflows, and stricter enforcement protocols.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPermanent rdf:type rdf:Property ;
    rdfs:label 'Is Permanent' ;
    rdfs:comment 'Indicates whether this ban is permanent with no scheduled end date. True when ban_type is \'permanent\' and ban_end_timestamp is null. Provides a direct boolean filter for permanent ban analytics and enforcement dashboards.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRepeatOffender rdf:type rdf:Property ;
    rdfs:label 'Is Repeat Offender' ;
    rdfs:comment 'Indicates whether the player was classified as a repeat offender at the time of ban issuance (prior_ban_count > 0 or per policy threshold). Drives escalated enforcement actions and permanent ban eligibility.' ;
    rdfs:domain ind:Ban ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationSent rdf:type rdf:Property ;
    rdfs:label 'Notification Sent' ;
    rdfs:comment 'Indicates whether the player was notified of this ban via the standard communication channel (in-game notification, email, or support ticket). Supports compliance with consumer protection notification requirements.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Timestamp' ;
    rdfs:comment 'Date and time when the ban notification was sent to the player. Null if notification_sent is False. Used to measure notification SLA compliance and support regulatory audit.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priorBanCount rdf:type rdf:Property ;
    rdfs:label 'Prior Ban Count' ;
    rdfs:comment 'Number of previous community bans on record for this player at the time this ban was issued. Supports repeat offender escalation policies and ban duration calibration.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reason rdf:type rdf:Property ;
    rdfs:label 'Reason' ;
    rdfs:comment 'Free-text description of the specific reason for issuing this ban, as documented by the moderator. Provides context beyond the structured violation category for audit and appeal review purposes.' ;
    rdfs:domain ind:Ban ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code or regional code indicating the regulatory jurisdiction applicable to this ban record (e.g., \'DEU\' for Germany under USK/GDPR, \'KOR\' for South Korea under GRAC). Supports jurisdiction-specific compliance reporting.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinstatementReason rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Reason' ;
    rdfs:comment 'Reason code explaining why the player was reinstated. \'appeal_overturned\' means a successful appeal; \'ban_expired\' means the ban duration elapsed; \'manual_lift\' means a moderator manually removed the ban; \'policy_change\' means a policy update retroactively affected the ban; \'error_correction\' means the ban was issued in error.' ;
    rdfs:domain ind:Ban ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinstatementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Timestamp' ;
    rdfs:comment 'Date and time when the player\'s community access was reinstated following a ban lift, expiry, or successful appeal. Null if the ban is still active or the player has not been reinstated.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Assessed severity of the violation that triggered this ban. Drives escalation workflows, ban duration recommendations, and repeat offender policies.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'The exact date and time (ISO 8601 with timezone) when this ban became effective and enforcement began. Principal business event timestamp for the ban lifecycle.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:violationCategory rdf:type rdf:Property ;
    rdfs:label 'Violation Category' ;
    rdfs:comment 'Primary category of the community guideline violation that led to this ban (e.g., harassment, hate_speech, cheating, spam, inappropriate_content, impersonation, exploitation). [ENUM-REF-CANDIDATE: harassment|hate_speech|cheating|spam|inappropriate_content|impersonation|exploitation|other — promote to reference product]' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationSubcategory rdf:type rdf:Property ;
    rdfs:label 'Violation Subcategory' ;
    rdfs:comment 'Secondary classification providing more granular detail on the violation type within the primary violation_category (e.g., within \'harassment\': targeted_harassment, doxxing, sexual_harassment). Supports detailed moderation analytics and policy refinement.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communityEventId rdf:type rdf:Property ;
    rdfs:label 'Community Event Id' ;
    rdfs:comment 'Unique surrogate identifier for the community event record. Primary key for the community_event data product in the Silver Layer lakehouse.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommunityEvent .

ind:ageRatingCertId rdf:type rdf:Property ;
    rdfs:label 'Age Rating Cert Id' ;
    rdfs:comment 'Foreign key linking to compliance.age_rating_cert. Business justification: Community events with prizes, monetization, or user-generated content require age rating certification to comply with platform policies and rating authority requirements. Ensures event eligibility ali' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AgeRatingCert .

ind:battlePassId rdf:type rdf:Property ;
    rdfs:label 'Battle Pass Id' ;
    rdfs:comment 'Foreign key linking to monetization.battle_pass. Business justification: Community events promote battle pass engagement (season launch events, tier unlock challenges, reward showcases). Events tied to passes for cross-promotion tracking, participation measurement, and con' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BattlePass .

ind:brandPartnershipId rdf:type rdf:Property ;
    rdfs:label 'Brand Partnership Id' ;
    rdfs:comment 'Foreign key linking to licensing.brand_partnership. Business justification: Community events (tournaments, creator contests, live streams) with brand sponsors require linking to brand partnership for co-marketing obligation tracking, brand usage approval workflows, and revenu' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BrandPartnership .

ind:financeBudgetId rdf:type rdf:Property ;
    rdfs:label 'Finance Budget Id' ;
    rdfs:comment 'Foreign key linking to finance.budget. Business justification: Community events are planned marketing activities with allocated budgets. Direct link to budget enables real-time budget vs. actual tracking, variance analysis, and spend control for community marketi' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinanceBudget .

ind:influencerId rdf:type rdf:Property ;
    rdfs:label 'Influencer Id' ;
    rdfs:comment 'Foreign key linking to marketing.influencer. Business justification: Influencers host or participate in community events (tournaments, creator showcases, charity streams). Direct link enables influencer campaign ROI tracking, engagement measurement, and contractual del' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Influencer .

ind:parentEventCommunityEventId rdf:type rdf:Property ;
    rdfs:label 'Parent Event Community Event Id' ;
    rdfs:comment 'Self-referencing identifier linking this event to its parent event in a series or campaign hierarchy (e.g., a weekly challenge belonging to a seasonal campaign). Null for top-level events.' ;
    rdfs:domain ind:CommunityEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommunityEvent .

ind:parentSeasonalEventId rdf:type rdf:Property ;
    rdfs:label 'Parent Seasonal Event Id' ;
    rdfs:comment 'Foreign key linking to content.seasonal_event. Business justification: Event planning and execution requires linking community-driven activities (fan art contests, cosplay competitions) to seasonal event calendar for coordination and unified reporting. Enables nested eve' ;
    rdfs:domain ind:CommunityEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SeasonalEvent .

ind:releaseScheduleId rdf:type rdf:Property ;
    rdfs:label 'Release Schedule Id' ;
    rdfs:comment 'Foreign key linking to platform.release_schedule. Business justification: Launch events, tournaments, and content drops are coordinated with release schedules. Marketing and community teams need to sync event timing with platform approval dates, embargo lifts, and preorder ' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReleaseSchedule .

ind:eligibilityCriteria rdf:type rdf:Property ;
    rdfs:label 'Eligibility Criteria' ;
    rdfs:comment 'Textual description of the requirements a player must meet to participate in the event (e.g., minimum account level, geographic restrictions, age requirements, game ownership). Supports COPPA and GDPR compliance for age-gated events.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventCode rdf:type rdf:Property ;
    rdfs:label 'Event Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the community event, used in marketing materials, URLs, and cross-system references (e.g., \'CE-SUMFAN24\').' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDescription rdf:type rdf:Property ;
    rdfs:label 'Event Description' ;
    rdfs:comment 'Full narrative description of the community event including objectives, rules, theme, and any special instructions for participants. Displayed on community portals and in-game event hubs.' ;
    rdfs:domain ind:CommunityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventName rdf:type rdf:Property ;
    rdfs:label 'Event Name' ;
    rdfs:comment 'Official display name of the community event as shown to players and community members (e.g., \'Summer Fan Art Contest 2024\', \'Developer AMA — Season 5 Launch\').' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current lifecycle state of the community event. Controls visibility, registration availability, and operational workflows. Values: upcoming (scheduled, not yet started), active (currently running), completed (ended successfully), cancelled (terminated before completion), postponed (rescheduled), draft (not yet published).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Classification of the community event by its format and purpose. Drives eligibility rules, prize structures, and reporting segmentation. [ENUM-REF-CANDIDATE: in_game_challenge|fan_tournament|developer_ama|community_contest|seasonal_campaign|community_challenge|ugc_submission|charity_stream — promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalUrl rdf:type rdf:Property ;
    rdfs:label 'External Url' ;
    rdfs:comment 'The public-facing URL for the community event landing page, registration portal, or official announcement. Used in marketing campaigns, in-game notifications, and community portal links.' ;
    rdfs:domain ind:CommunityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRestriction rdf:type rdf:Property ;
    rdfs:label 'Geographic Restriction' ;
    rdfs:comment 'Pipe-separated list of ISO 3166-1 alpha-3 country codes where participation is permitted or restricted. Null indicates globally open. Used for regulatory compliance and prize distribution legality (e.g., \'USA|CAN|GBR\').' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAgeRestricted rdf:type rdf:Property ;
    rdfs:label 'Is Age Restricted' ;
    rdfs:comment 'Indicates whether this community event has age-based eligibility restrictions (e.g., 18+ for prize-bearing contests). Triggers additional COPPA/GDPR compliance workflows when True.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFeatured rdf:type rdf:Property ;
    rdfs:label 'Is Featured' ;
    rdfs:comment 'Indicates whether this community event is designated as a featured or promoted event, receiving elevated visibility on community portals, in-game hubs, and marketing channels.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRecurring rdf:type rdf:Property ;
    rdfs:label 'Is Recurring' ;
    rdfs:comment 'Indicates whether this community event is part of a recurring series (e.g., weekly community challenges, annual seasonal campaigns). When True, recurrence_pattern provides scheduling details.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kFactorTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'K Factor Tracking Enabled' ;
    rdfs:comment 'Indicates whether viral referral and K-Factor (Viral Coefficient) tracking is enabled for this community event. When True, referral attribution data is captured to measure the event\'s organic growth and word-of-mouth amplification.' ;
    rdfs:domain ind:CommunityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxRegistrations rdf:type rdf:Property ;
    rdfs:label 'Max Registrations' ;
    rdfs:comment 'The maximum number of players or teams allowed to register for this community event. Null indicates unlimited registrations. Used for capacity planning and waitlist management.' ;
    rdfs:domain ind:CommunityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:moderationRequired rdf:type rdf:Property ;
    rdfs:label 'Moderation Required' ;
    rdfs:comment 'Indicates whether player submissions or participation in this event requires human or automated content moderation review before being published or counted. Critical for UGC events and community contests.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npsScore rdf:type rdf:Property ;
    rdfs:label 'Nps Score' ;
    rdfs:comment 'The Net Promoter Score (NPS) collected from participants after the community event concludes, ranging from -100 to 100. Measures player satisfaction and likelihood to recommend the event. Sourced from post-event surveys.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizerType rdf:type rdf:Property ;
    rdfs:label 'Organizer Type' ;
    rdfs:comment 'Classification of the entity organizing the event. Distinguishes first-party developer-run events from community-led or third-party organized events, which affects moderation requirements and prize liability.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantCount rdf:type rdf:Property ;
    rdfs:label 'Participant Count' ;
    rdfs:comment 'The total number of players or teams that actively participated in the community event (distinct from registrations, which may include no-shows). Key metric for community engagement reporting.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prizeDescription rdf:type rdf:Property ;
    rdfs:label 'Prize Description' ;
    rdfs:comment 'Narrative description of prizes, rewards, or incentives offered to participants or winners of the community event (e.g., \'Exclusive in-game cosmetic skin, 1000 virtual currency, and a physical trophy for top 3 finishers\').' ;
    rdfs:domain ind:CommunityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prizeType rdf:type rdf:Property ;
    rdfs:label 'Prize Type' ;
    rdfs:comment 'Classification of the primary prize category offered in this community event. Drives tax reporting obligations and prize fulfillment workflows. Virtual prizes (MTX items, virtual currency) are distinguished from physical or cash prizes for regulatory purposes.' ;
    rdfs:domain ind:CommunityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prizeValueUsd rdf:type rdf:Property ;
    rdfs:label 'Prize Value Usd' ;
    rdfs:comment 'The total declared monetary value of all prizes for this community event in US Dollars. Required for tax reporting, legal compliance, and prize pool disclosures. Applies to both cash and fair-market-value of physical/virtual prizes.' ;
    rdfs:domain ind:CommunityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recurrencePattern rdf:type rdf:Property ;
    rdfs:label 'Recurrence Pattern' ;
    rdfs:comment 'The frequency pattern for recurring community events. Null for one-time events. Used for automated event scheduling and community calendar management. [ENUM-REF-CANDIDATE: daily|weekly|biweekly|monthly|quarterly|annually|seasonal — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralCount rdf:type rdf:Property ;
    rdfs:label 'Referral Count' ;
    rdfs:comment 'The total number of new player registrations attributed to referrals from existing participants in this community event. Used to calculate the K-Factor (Viral Coefficient) and measure organic community growth.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:registrationCloseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Registration Close Timestamp' ;
    rdfs:comment 'The date and time when player registration for the community event closes. After this point, no new registrations are accepted.' ;
    rdfs:domain ind:CommunityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:registrationCount rdf:type rdf:Property ;
    rdfs:label 'Registration Count' ;
    rdfs:comment 'The current total number of players or teams that have registered for this community event. Updated in near-real-time from the registration system.' ;
    rdfs:domain ind:CommunityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:registrationOpenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Registration Open Timestamp' ;
    rdfs:comment 'The date and time when player registration for the community event opens. May precede the event start timestamp to allow advance sign-ups.' ;
    rdfs:domain ind:CommunityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shortDescription rdf:type rdf:Property ;
    rdfs:label 'Short Description' ;
    rdfs:comment 'Concise summary of the community event (max 280 characters) used in promotional banners, push notifications, and social media previews.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionType rdf:type rdf:Property ;
    rdfs:label 'Submission Type' ;
    rdfs:comment 'The type of submission or participation action required from players in this community event. Determines the UGC (User-Generated Content) moderation workflow and submission portal configuration. [ENUM-REF-CANDIDATE: ugc_artwork|ugc_video|ugc_screenshot|gameplay_score|leaderboard|vote|registration_only|written_entry — promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyResponseCount rdf:type rdf:Property ;
    rdfs:label 'Survey Response Count' ;
    rdfs:comment 'The total number of post-event survey responses received from participants. Provides the denominator context for interpreting NPS and CSAT scores.' ;
    rdfs:domain ind:CommunityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:votingEnabled rdf:type rdf:Property ;
    rdfs:label 'Voting Enabled' ;
    rdfs:comment 'Indicates whether community members can vote on submissions or outcomes in this event (e.g., fan art contests with community voting). Drives the voting module configuration.' ;
    rdfs:domain ind:CommunityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentForumId rdf:type rdf:Property ;
    rdfs:label 'Parent Forum Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent forum when this record represents a sub-forum. Null for top-level forums. Supports hierarchical forum structures.' ;
    rdfs:domain ind:Forum ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Forum .

ind:allowsAttachments rdf:type rdf:Property ;
    rdfs:label 'Allows Attachments' ;
    rdfs:comment 'Indicates whether players are permitted to attach files, images, or media to posts in this forum. Relevant for UGC (User-Generated Content) forums and bug report forums requiring screenshots.' ;
    rdfs:domain ind:Forum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allowsUgcSubmissions rdf:type rdf:Property ;
    rdfs:label 'Allows Ugc Submissions' ;
    rdfs:comment 'Indicates whether this forum accepts formal User-Generated Content (UGC) submissions such as mods, maps, or fan art. Distinct from general attachments; triggers UGC review workflows.' ;
    rdfs:domain ind:Forum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:archivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Archived Timestamp' ;
    rdfs:comment 'Timestamp when this forum was transitioned to \'archived\' status. Null if the forum has never been archived. Supports community lifecycle management and data retention compliance.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:autoLockDaysInactive rdf:type rdf:Property ;
    rdfs:label 'Auto Lock Days Inactive' ;
    rdfs:comment 'Number of days of inactivity after which threads in this forum are automatically locked. Null means threads never auto-lock. Supports community hygiene and moderation efficiency.' ;
    rdfs:domain ind:Forum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bannerImageUrl rdf:type rdf:Property ;
    rdfs:label 'Banner Image Url' ;
    rdfs:comment 'URL to the forum\'s banner or header image asset hosted on the CDN (Content Delivery Network). Used for visual branding of the forum on the community portal.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRating rdf:type rdf:Property ;
    rdfs:label 'Content Rating' ;
    rdfs:comment 'Content rating assigned to this forum based on the nature of discussions permitted, aligned with ESRB and PEGI rating systems. Determines age-gating and parental control enforcement. [ENUM-REF-CANDIDATE: E|E10+|T|M|AO|RP|PEGI_3|PEGI_7|PEGI_12|PEGI_16|PEGI_18 — promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dau rdf:type rdf:Property ;
    rdfs:label 'Dau' ;
    rdfs:comment 'Count of unique players who engaged with this forum (viewed, posted, or reacted) on the most recent calendar day. Key community health KPI (Key Performance Indicator) aligned with platform-wide DAU tracking.' ;
    rdfs:domain ind:Forum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:depthLevel rdf:type rdf:Property ;
    rdfs:label 'Depth Level' ;
    rdfs:comment 'Integer indicating the nesting depth of this forum in the hierarchy. Level 0 is a top-level forum; level 1 is a direct sub-forum; higher values indicate deeper nesting.' ;
    rdfs:domain ind:Forum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forumCategory rdf:type rdf:Property ;
    rdfs:label 'Forum Category' ;
    rdfs:comment 'Logical grouping category for the forum used to organize forums in the community portal (e.g., \'Game Discussion\', \'Technical Support\', \'Esports\', \'Off-Topic\', \'Announcements\', \'UGC Showcase\'). [ENUM-REF-CANDIDATE: game_discussion|technical_support|esports|announcements|ugc_showcase|off_topic|bug_reports|feedback — promote to reference product]' ;
    rdfs:domain ind:Forum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forumDescription rdf:type rdf:Property ;
    rdfs:label 'Forum Description' ;
    rdfs:comment 'Short descriptive text explaining the purpose, scope, and posting guidelines of the forum. Displayed to players on the forum landing page.' ;
    rdfs:domain ind:Forum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forumName rdf:type rdf:Property ;
    rdfs:label 'Forum Name' ;
    rdfs:comment 'Human-readable display name of the forum or sub-forum as shown to players on the community platform (e.g., \'General Discussion\', \'Bug Reports\', \'Esports Strategy\').' ;
    rdfs:domain ind:Forum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forumStatus rdf:type rdf:Property ;
    rdfs:label 'Forum Status' ;
    rdfs:comment 'Current lifecycle state of the forum. \'active\' is open for posting; \'inactive\' is temporarily disabled; \'archived\' is read-only historical forum; \'locked\' prevents new posts but remains visible; \'pending_review\' is awaiting moderation approval before going live.' ;
    rdfs:domain ind:Forum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forumType rdf:type rdf:Property ;
    rdfs:label 'Forum Type' ;
    rdfs:comment 'Classifies the operational purpose of the forum. \'standard\' is general discussion; \'announcement\' is read-heavy official news; \'support\' maps to Zendesk-integrated player support; \'esports\' is for competitive community; \'ugc\' is for User-Generated Content (UGC) sharing; \'guild\' is for guild/clan community spaces.' ;
    rdfs:domain ind:Forum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iconImageUrl rdf:type rdf:Property ;
    rdfs:label 'Icon Image Url' ;
    rdfs:comment 'URL to the forum\'s icon or thumbnail image asset hosted on the CDN (Content Delivery Network). Used in forum listings and navigation menus.' ;
    rdfs:domain ind:Forum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPinned rdf:type rdf:Property ;
    rdfs:label 'Is Pinned' ;
    rdfs:comment 'Indicates whether this forum is pinned to the top of its category listing. Pinned forums are prioritized in navigation to drive player engagement with key community spaces.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPostTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Post Timestamp' ;
    rdfs:comment 'Timestamp of the most recent post made in this forum. Used to determine forum activity recency, drive auto-lock logic, and surface active forums in community portal rankings.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:localeCode rdf:type rdf:Property ;
    rdfs:label 'Locale Code' ;
    rdfs:comment 'IETF BCP 47 language-region code specifying the primary language and locale of the forum (e.g., \'en-US\', \'fr-FR\', \'ja-JP\', \'ko-KR\'). Supports multi-language community segmentation and localization.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mau rdf:type rdf:Property ;
    rdfs:label 'Mau' ;
    rdfs:comment 'Count of unique players who engaged with this forum in the most recent 30-day rolling window. Used alongside DAU for community stickiness and engagement ratio analysis.' ;
    rdfs:domain ind:Forum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxPostLengthChars rdf:type rdf:Property ;
    rdfs:label 'Max Post Length Chars' ;
    rdfs:comment 'Maximum character count allowed per post in this forum. Enforces posting rules and prevents spam. Null means no character limit is enforced.' ;
    rdfs:domain ind:Forum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumAgeYears rdf:type rdf:Property ;
    rdfs:label 'Minimum Age Years' ;
    rdfs:comment 'Minimum player age in years required to access this forum. Enforced for age-restricted forums per ESRB, PEGI, COPPA, and regional rating body requirements. Null if no age restriction applies.' ;
    rdfs:domain ind:Forum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:moderationMode rdf:type rdf:Property ;
    rdfs:label 'Moderation Mode' ;
    rdfs:comment 'Defines the content moderation approach for this forum. \'pre_moderated\' requires approval before posts are visible; \'post_moderated\' reviews after publishing; \'auto_moderated\' uses automated tools; \'unmoderated\' has no active moderation.' ;
    rdfs:domain ind:Forum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postCount rdf:type rdf:Property ;
    rdfs:label 'Post Count' ;
    rdfs:comment 'Total cumulative number of posts ever created in this forum. Used as a community health and engagement metric. Updated by the platform\'s community analytics pipeline.' ;
    rdfs:domain ind:Forum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postingPermission rdf:type rdf:Property ;
    rdfs:label 'Posting Permission' ;
    rdfs:comment 'Defines which player segments are permitted to create new posts in this forum. \'verified_only\' requires email-verified accounts; \'moderators_only\' restricts to community moderators; \'staff_only\' is for official announcements.' ;
    rdfs:domain ind:Forum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresAccountVerification rdf:type rdf:Property ;
    rdfs:label 'Requires Account Verification' ;
    rdfs:comment 'Indicates whether players must have a verified account (email or identity verified) to post in this forum. Supports anti-spam and COPPA compliance for age-gated communities.' ;
    rdfs:domain ind:Forum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rulesUrl rdf:type rdf:Property ;
    rdfs:label 'Rules Url' ;
    rdfs:comment 'URL linking to the official posting rules and community guidelines document for this forum. Displayed to players before posting to ensure compliance with community standards.' ;
    rdfs:domain ind:Forum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slug rdf:type rdf:Property ;
    rdfs:label 'Slug' ;
    rdfs:comment 'URL-safe, lowercase hyphenated identifier used in the forum\'s web address. Ensures stable, human-readable permalinks for SEO and deep-linking purposes.' ;
    rdfs:domain ind:Forum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortOrder rdf:type rdf:Property ;
    rdfs:label 'Sort Order' ;
    rdfs:comment 'Numeric display ordering position of the forum within its parent category or parent forum. Lower values appear first in the community portal navigation.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriberCount rdf:type rdf:Property ;
    rdfs:label 'Subscriber Count' ;
    rdfs:comment 'Total number of players who have subscribed to receive notifications from this forum. Indicates community reach and is used in player retention and K-Factor (Viral Coefficient) analysis.' ;
    rdfs:domain ind:Forum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:threadCount rdf:type rdf:Property ;
    rdfs:label 'Thread Count' ;
    rdfs:comment 'Total cumulative number of discussion threads created in this forum. Distinct from post count; a thread is the parent topic while posts are replies. Key community engagement indicator.' ;
    rdfs:domain ind:Forum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visibility rdf:type rdf:Property ;
    rdfs:label 'Visibility' ;
    rdfs:comment 'Controls who can view the forum. \'public\' is visible to all including unauthenticated visitors; \'private\' is hidden from non-members; \'members_only\' requires platform account; \'staff_only\' is restricted to internal community team.' ;
    rdfs:domain ind:Forum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zendeskGroupCode rdf:type rdf:Property ;
    rdfs:label 'Zendesk Group Code' ;
    rdfs:comment 'External identifier linking this forum to its corresponding Zendesk support group for player support ticket routing. Enables seamless escalation from community forum posts to Zendesk tickets.' ;
    rdfs:domain ind:Forum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forumPostId rdf:type rdf:Property ;
    rdfs:label 'Forum Post Id' ;
    rdfs:comment 'Unique system-generated identifier for each individual forum post or reply within the gaming community platform. Primary key for this entity.' ;
    rdfs:domain ind:ForumPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forumCategoryId rdf:type rdf:Property ;
    rdfs:label 'Forum Category Id' ;
    rdfs:comment 'Reference to the forum category or subforum this post belongs to (e.g., Bug Reports, General Discussion, Esports, Patch Notes). Used for community analytics segmentation and moderation routing.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ForumCategory .

ind:parentPostForumPostId rdf:type rdf:Property ;
    rdfs:label 'Parent Post Forum Post Id' ;
    rdfs:comment 'Reference to the post being directly replied to, enabling nested/threaded conversation structures. Null if this is a top-level post within the thread.' ;
    rdfs:domain ind:ForumPost ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ForumPost .

ind:authorDisplayName rdf:type rdf:Property ;
    rdfs:label 'Author Display Name' ;
    rdfs:comment 'The in-game or community display name (gamertag/username) of the post author at the time of posting. Denormalized from the player record for historical accuracy in case the player later changes their display name.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:charCount rdf:type rdf:Property ;
    rdfs:label 'Char Count' ;
    rdfs:comment 'Total character length of the post body at the time of last save. Used for content quality analytics, spam detection heuristics, and enforcing platform post length limits.' ;
    rdfs:domain ind:ForumPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containsSpoiler rdf:type rdf:Property ;
    rdfs:label 'Contains Spoiler' ;
    rdfs:comment 'Indicates whether the post has been tagged as containing game story or content spoilers. Enables spoiler-blur rendering in the community UI and supports community content policy enforcement.' ;
    rdfs:domain ind:ForumPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentWarningFlag rdf:type rdf:Property ;
    rdfs:label 'Content Warning Flag' ;
    rdfs:comment 'Indicates whether this post has been tagged with a content warning by the author or a moderator. Relevant for ESRB/PEGI compliance and age-gating in community spaces associated with mature-rated titles.' ;
    rdfs:domain ind:ForumPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:downvoteCount rdf:type rdf:Property ;
    rdfs:label 'Downvote Count' ;
    rdfs:comment 'Total number of negative community votes (downvotes/dislikes) received by this post. Used alongside upvote_count to compute net community sentiment and identify potentially problematic content.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:editCount rdf:type rdf:Property ;
    rdfs:label 'Edit Count' ;
    rdfs:comment 'Total number of times this post has been edited by the author or a moderator. Used in moderation analytics to identify posts with unusual edit patterns.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isAnonymous rdf:type rdf:Property ;
    rdfs:label 'Is Anonymous' ;
    rdfs:comment 'Indicates whether the post was submitted anonymously, hiding the author\'s identity from other community members. Relevant for player feedback channels and GDPR data minimization compliance.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEdited rdf:type rdf:Property ;
    rdfs:label 'Is Edited' ;
    rdfs:comment 'Indicates whether the post body has been modified after initial submission. Triggers display of an edit indicator in the community UI and flags the post for audit trail review.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReported rdf:type rdf:Property ;
    rdfs:label 'Is Reported' ;
    rdfs:comment 'Indicates whether this post has been reported by one or more community members for violating community guidelines. Triggers moderation queue entry when set to true.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSolution rdf:type rdf:Property ;
    rdfs:label 'Is Solution' ;
    rdfs:comment 'Indicates whether this post has been marked as the accepted solution to the thread\'s question by the original poster or a moderator. Used in player support knowledge base analytics and CSAT (Customer Satisfaction Score) tracking.' ;
    rdfs:domain ind:ForumPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStaffPost rdf:type rdf:Property ;
    rdfs:label 'Is Staff Post' ;
    rdfs:comment 'Indicates whether this post was authored by a Gaming staff member, community manager, or official representative. Used to distinguish official communications from player-generated content in community analytics.' ;
    rdfs:domain ind:ForumPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'ISO 639-1 two-letter language code (optionally with ISO 3166-1 region subtag) of the post content, either author-declared or auto-detected. Used for multilingual community moderation routing and localization analytics.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastEditedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Edited Timestamp' ;
    rdfs:comment 'Date and time when the post body was most recently modified. Null if the post has never been edited. Stored in ISO 8601 format with timezone offset.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:moderationReason rdf:type rdf:Property ;
    rdfs:label 'Moderation Reason' ;
    rdfs:comment 'Categorical reason code assigned by the moderation team when a moderation action is taken. Used for moderation analytics, policy enforcement reporting, and regulatory compliance. [ENUM-REF-CANDIDATE: hate_speech|harassment|spam|cheating_discussion|spoiler|off_topic|misinformation|explicit_content|other — promote to reference product]' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moderationStatus rdf:type rdf:Property ;
    rdfs:label 'Moderation Status' ;
    rdfs:comment 'Current state of the moderation workflow for this post. \'not_reviewed\' = no moderation activity; \'under_review\' = assigned to a moderator; \'approved\' = reviewed and cleared; \'actioned\' = moderation action taken; \'escalated\' = referred to senior moderation or legal team.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsSurveyTriggered rdf:type rdf:Property ;
    rdfs:label 'Nps Survey Triggered' ;
    rdfs:comment 'Indicates whether this post interaction triggered an NPS (Net Promoter Score) or CSAT (Customer Satisfaction Score) survey prompt to the author. Used in player satisfaction measurement and community feedback channel analytics.' ;
    rdfs:domain ind:ForumPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformSource rdf:type rdf:Property ;
    rdfs:label 'Platform Source' ;
    rdfs:comment 'The platform or client interface from which the post was submitted. Used for community engagement analytics segmented by platform and for identifying platform-specific UX issues.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postBody rdf:type rdf:Property ;
    rdfs:label 'Post Body' ;
    rdfs:comment 'Full text content of the forum post as authored by the player. May include game-related discussion, bug reports, feedback, or community conversation. Subject to content moderation policies and GDPR right-to-erasure obligations.' ;
    rdfs:domain ind:ForumPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postFormat rdf:type rdf:Property ;
    rdfs:label 'Post Format' ;
    rdfs:comment 'Markup or formatting type used in the post body. Determines how the content is rendered in the community UI and how it is processed during content moderation and indexing.' ;
    rdfs:domain ind:ForumPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postNumber rdf:type rdf:Property ;
    rdfs:label 'Post Number' ;
    rdfs:comment 'Sequential position of this post within its parent thread, used for ordering and display. Assigned at post creation time and reflects chronological order within the thread.' ;
    rdfs:domain ind:ForumPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postStatus rdf:type rdf:Property ;
    rdfs:label 'Post Status' ;
    rdfs:comment 'Current lifecycle state of the forum post. \'active\' = visible to community; \'hidden\' = temporarily concealed pending review; \'removed\' = taken down by moderation; \'pending_review\' = flagged and awaiting moderator decision; \'locked\' = no further replies allowed; \'deleted\' = soft-deleted by author or admin.' ;
    rdfs:domain ind:ForumPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postType rdf:type rdf:Property ;
    rdfs:label 'Post Type' ;
    rdfs:comment 'Classification of the post within the thread structure. \'original_post\' = first post opening the thread; \'reply\' = standard response; \'quote_reply\' = reply quoting another post; \'announcement\' = official staff post; \'pinned\' = elevated visibility post.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replyCount rdf:type rdf:Property ;
    rdfs:label 'Reply Count' ;
    rdfs:comment 'Number of direct replies to this specific post. Denormalized count maintained for performance in community engagement dashboards and thread activity metrics.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportCount rdf:type rdf:Property ;
    rdfs:label 'Report Count' ;
    rdfs:comment 'Total number of distinct player reports submitted against this post. Higher counts may trigger automated moderation escalation thresholds.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sentimentScore rdf:type rdf:Property ;
    rdfs:label 'Sentiment Score' ;
    rdfs:comment 'Automated NLP-derived sentiment score for the post body, ranging from -1.0 (most negative) to 1.0 (most positive). Used in community health dashboards, NPS (Net Promoter Score) proxy analytics, and early toxicity detection pipelines.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toxicityScore rdf:type rdf:Property ;
    rdfs:label 'Toxicity Score' ;
    rdfs:comment 'Automated ML-derived toxicity probability score for the post body, ranging from 0.0 (non-toxic) to 1.0 (highly toxic). Used to prioritize moderation queue items and support community health KPI (Key Performance Indicator) reporting.' ;
    rdfs:domain ind:ForumPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ugcAttachmentCount rdf:type rdf:Property ;
    rdfs:label 'Ugc Attachment Count' ;
    rdfs:comment 'Number of media attachments (screenshots, videos, UGC assets) included in this post. Used for content moderation workload estimation and UGC (User-Generated Content) volume analytics.' ;
    rdfs:domain ind:ForumPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:upvoteCount rdf:type rdf:Property ;
    rdfs:label 'Upvote Count' ;
    rdfs:comment 'Total number of positive community votes (upvotes/likes) received by this post. Used in community health scoring, content surfacing algorithms, and player engagement analytics.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backlogItemId rdf:type rdf:Property ;
    rdfs:label 'Backlog Item Id' ;
    rdfs:comment 'Foreign key linking to studio.backlog_item. Business justification: Community-driven backlog prioritization: high-visibility threads discussing bugs or feature requests spawn backlog items. Community managers link threads to track player sentiment and prioritize work.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BacklogItem .

ind:gachaPoolId rdf:type rdf:Property ;
    rdfs:label 'Gacha Pool Id' ;
    rdfs:comment 'Foreign key linking to monetization.gacha_pool. Business justification: Gacha pools generate extensive forum discussion (drop rate analysis, pull strategy, complaints about pity system). Community managers track pool-specific sentiment for monetization feedback and to ide' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GachaPool .

ind:offerCampaignId rdf:type rdf:Property ;
    rdfs:label 'Offer Campaign Id' ;
    rdfs:comment 'Foreign key linking to monetization.offer_campaign. Business justification: Players create forum threads discussing promotional offers (value analysis, eligibility questions, bugs). Community managers track campaign-related discussions for sentiment analysis and to identify o' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OfferCampaign .

ind:primaryForumPlayerAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Forum Player Account Id' ;
    rdfs:comment 'Reference to the player who authored this thread or post. Links to the player master record for identity, account standing, and community reputation context.' ;
    rdfs:domain ind:ForumThread ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerAccount .

ind:threadRootForumThreadId rdf:type rdf:Property ;
    rdfs:label 'Thread Root Forum Thread Id' ;
    rdfs:comment 'Reference to the originating thread-starter post (depth level 0) for all replies within the same conversation. Equals forum_thread_id for root posts. Enables efficient retrieval of all posts within a thread without recursive traversal.' ;
    rdfs:domain ind:ForumThread ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ForumThread .

ind:authorPostCountAtTime rdf:type rdf:Property ;
    rdfs:label 'Author Post Count At Time' ;
    rdfs:comment 'Snapshot of the author\'s total forum post count at the time this post was submitted. Provides community seniority context for moderation decisions and trust-scoring models without requiring a join to current player stats.' ;
    rdfs:domain ind:ForumThread ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bodyContent rdf:type rdf:Property ;
    rdfs:label 'Body Content' ;
    rdfs:comment 'Full text body of the forum post or reply, stored as plain text or lightweight markup (BBCode/Markdown). Primary content payload for community discourse, moderation review, and NLP-based sentiment analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Content Language Code' ;
    rdfs:comment 'ISO 639-1 language code (optionally with ISO 3166-1 region subtag) of the post body content (e.g., en, en-US, fr, de, ja, ko). Supports multilingual community moderation routing, localization analytics, and GDPR jurisdiction determination.' ;
    rdfs:domain ind:ForumThread ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRatingCategory rdf:type rdf:Property ;
    rdfs:label 'Content Rating Category' ;
    rdfs:comment 'Community content maturity classification applied to this post, aligned with ESRB/PEGI rating vocabulary. Supports age-gating of forum content, COPPA compliance for underage players, and platform certification requirements.' ;
    rdfs:domain ind:ForumThread ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flairLabel rdf:type rdf:Property ;
    rdfs:label 'Flair Label' ;
    rdfs:comment 'Community-assigned or author-selected flair tag categorizing the thread topic (e.g., Bug Report, Feedback, Guide, Lore, Patch Discussion). Supports forum navigation, filtering, and content taxonomy analytics.' ;
    rdfs:domain ind:ForumThread ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDeleted rdf:type rdf:Property ;
    rdfs:label 'Is Deleted' ;
    rdfs:comment 'Soft-delete flag indicating the post has been removed from public view by the author or a moderator. Retains the record for audit, compliance, and potential restoration. Supports GDPR right-to-erasure workflows.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLocked rdf:type rdf:Property ;
    rdfs:label 'Is Locked' ;
    rdfs:comment 'Indicates whether this thread has been locked by a moderator, preventing further replies. Locked threads remain visible but are closed to new community contributions. Common for resolved issues or policy-violating discussions.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUgcSubmission rdf:type rdf:Property ;
    rdfs:label 'Is Ugc Submission' ;
    rdfs:comment 'Indicates whether this post has been formally tagged as a User-Generated Content (UGC) submission (e.g., fan art showcase, mod announcement, community guide). Enables UGC pipeline routing and IP compliance review workflows.' ;
    rdfs:domain ind:ForumThread ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReplyTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Reply Timestamp' ;
    rdfs:comment 'Date and time of the most recent reply posted within this thread. Applicable to thread-root posts. Used for thread sorting by recent activity, stale thread detection, and community engagement recency metrics.' ;
    rdfs:domain ind:ForumThread ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:moderationActionType rdf:type rdf:Property ;
    rdfs:label 'Moderation Action Type' ;
    rdfs:comment 'Type of moderation action applied to this post by a community moderator or automated trust-and-safety system. Supports moderation audit trails, compliance reporting under DSA, and moderator performance analytics.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moderationNote rdf:type rdf:Property ;
    rdfs:label 'Moderation Note' ;
    rdfs:comment 'Internal moderator-authored note documenting the rationale for a moderation action. Not visible to community members. Supports moderation audit trails, appeals processes, and DSA compliance documentation.' ;
    rdfs:domain ind:ForumThread ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moderationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Moderation Timestamp' ;
    rdfs:comment 'Date and time when the most recent moderation action was applied to this post. Supports SLA tracking for moderation response times and DSA compliance reporting on content removal timelines.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:parentPostId rdf:type rdf:Property ;
    rdfs:label 'Parent Post Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediate parent post in a threaded reply chain. NULL for thread-starting posts (depth level 0). Enables nested conversation tree traversal.' ;
    rdfs:domain ind:ForumThread ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postDepthLevel rdf:type rdf:Property ;
    rdfs:label 'Post Depth Level' ;
    rdfs:comment 'Integer indicating the nesting depth of this post within the thread hierarchy. Value 0 = thread root post; 1 = direct reply to root; 2+ = nested reply. Supports both flat and threaded conversation rendering models.' ;
    rdfs:domain ind:ForumThread ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postTimestamp rdf:type rdf:Property ;
    rdfs:label 'Post Timestamp' ;
    rdfs:comment 'Date and time when this post or thread was originally submitted by the author. The principal business event timestamp representing when the community discourse event occurred. Distinct from system audit created_timestamp.' ;
    rdfs:domain ind:ForumThread ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Human-readable subject line of the thread, populated only for thread-starting posts (post_type = thread or announcement). NULL for reply posts. Displayed in forum index listings and search results.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewCount rdf:type rdf:Property ;
    rdfs:label 'View Count' ;
    rdfs:comment 'Cumulative number of times this thread has been viewed by community members. Applicable primarily to thread-root posts. Key engagement metric for community health dashboards and content popularity analysis.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageRestricted rdf:type rdf:Property ;
    rdfs:label 'Age Restricted' ;
    rdfs:comment 'Indicates whether this guild enforces an age restriction on membership, requiring members to be 18+ or meet a minimum age threshold. Supports COPPA and GDPR compliance for minor protection.' ;
    rdfs:domain ind:Guild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bannerAssetRef rdf:type rdf:Property ;
    rdfs:label 'Banner Asset Ref' ;
    rdfs:comment 'Reference path or URI to the guild\'s banner or header image asset stored in the digital asset management system. Displayed on the guild\'s community profile page.' ;
    rdfs:domain ind:Guild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbandedDate rdf:type rdf:Property ;
    rdfs:label 'Disbanded Date' ;
    rdfs:comment 'Date on which the guild was officially disbanded or dissolved. Null for active guilds. Used for historical reporting and community lifecycle analytics.' ;
    rdfs:domain ind:Guild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discordServerCode rdf:type rdf:Property ;
    rdfs:label 'Discord Server Code' ;
    rdfs:comment 'External Discord server identifier linked to this guild\'s community communication channel. Used for cross-platform community integration and player support routing.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emblemAssetRef rdf:type rdf:Property ;
    rdfs:label 'Emblem Asset Ref' ;
    rdfs:comment 'Reference path or URI to the guild\'s emblem or badge image asset stored in the digital asset management system (Perforce Helix Core / CDN). Used for rendering the guild icon in-game and on community portals.' ;
    rdfs:domain ind:Guild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalWebsiteUrl rdf:type rdf:Property ;
    rdfs:label 'External Website Url' ;
    rdfs:comment 'URL of the guild\'s external website or community page, if maintained outside the game platform. Used for community discovery and marketing.' ;
    rdfs:domain ind:Guild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foundedDate rdf:type rdf:Property ;
    rdfs:label 'Founded Date' ;
    rdfs:comment 'Calendar date on which the guild was officially created and founded by the founding player. Used for guild anniversary tracking and tenure-based analytics.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guildDescription rdf:type rdf:Property ;
    rdfs:label 'Guild Description' ;
    rdfs:comment 'Free-text description of the guild written by the guild leader, outlining the guild\'s goals, rules, play style, and membership expectations. Displayed on the guild profile page.' ;
    rdfs:domain ind:Guild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildName rdf:type rdf:Property ;
    rdfs:label 'Guild Name' ;
    rdfs:comment 'The full display name of the guild or clan as chosen by the founder and visible to all players in-game and on community platforms.' ;
    rdfs:domain ind:Guild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildStatus rdf:type rdf:Property ;
    rdfs:label 'Guild Status' ;
    rdfs:comment 'Current lifecycle status of the guild. Active guilds are operational; disbanded guilds have been dissolved; suspended guilds are under moderation review; pending guilds are awaiting approval.' ;
    rdfs:domain ind:Guild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildType rdf:type rdf:Property ;
    rdfs:label 'Guild Type' ;
    rdfs:comment 'Categorical classification of the guild\'s primary play style and purpose. [ENUM-REF-CANDIDATE: casual|competitive|roleplay|social|esports|pve — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:Guild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEsportsOrg rdf:type rdf:Property ;
    rdfs:label 'Is Esports Org' ;
    rdfs:comment 'Indicates whether this guild is formally affiliated with or operates as an esports organization participating in sanctioned leagues or tournaments.' ;
    rdfs:domain ind:Guild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the most recent recorded activity within the guild (e.g., member login, guild event, chat message). Used to identify inactive or dormant guilds for lifecycle management.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:memberCapacity rdf:type rdf:Property ;
    rdfs:label 'Member Capacity' ;
    rdfs:comment 'Maximum number of players allowed to be members of this guild simultaneously, as configured by the guild leader or constrained by game design rules.' ;
    rdfs:domain ind:Guild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:memberCount rdf:type rdf:Property ;
    rdfs:label 'Member Count' ;
    rdfs:comment 'Current number of active members in the guild at the time of the last record update. Used for capacity management and community health reporting.' ;
    rdfs:domain ind:Guild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:moderationFlag rdf:type rdf:Property ;
    rdfs:label 'Moderation Flag' ;
    rdfs:comment 'Indicates whether this guild is currently flagged for active moderation review due to reported violations of community guidelines, toxic behavior, or policy breaches.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prestigeLevel rdf:type rdf:Property ;
    rdfs:label 'Prestige Level' ;
    rdfs:comment 'Current prestige or rank level of the guild derived from accumulated XP and achievements. Determines access to exclusive guild perks, rewards, and in-game content.' ;
    rdfs:domain ind:Guild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:privacyLevel rdf:type rdf:Property ;
    rdfs:label 'Privacy Level' ;
    rdfs:comment 'Visibility setting for the guild profile. Public guilds are discoverable by all players; private guilds are hidden from search; unlisted guilds are accessible only via direct link.' ;
    rdfs:domain ind:Guild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pveFocus rdf:type rdf:Property ;
    rdfs:label 'Pve Focus' ;
    rdfs:comment 'Indicates whether the guild\'s primary activity focus is Player versus Environment (PvE) content such as raids, dungeons, and cooperative missions.' ;
    rdfs:domain ind:Guild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pvpFocus rdf:type rdf:Property ;
    rdfs:label 'Pvp Focus' ;
    rdfs:comment 'Indicates whether the guild\'s primary activity focus is Player versus Player (PvP) content, as opposed to Player versus Environment (PvE) or social/roleplay activities.' ;
    rdfs:domain ind:Guild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recruitmentStatus rdf:type rdf:Property ;
    rdfs:label 'Recruitment Status' ;
    rdfs:comment 'Current recruitment posture of the guild indicating whether new members may join freely (open), by invitation only (invite_only), via application (application), or not at all (closed).' ;
    rdfs:domain ind:Guild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Geographic region the guild primarily operates in, used for matchmaking, server routing, and community segmentation (e.g., NA = North America, EU = Europe, APAC = Asia-Pacific).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tag rdf:type rdf:Property ;
    rdfs:label 'Tag' ;
    rdfs:comment 'Short alphanumeric abbreviation or clan tag (2–6 characters) displayed alongside player names in-game to identify guild membership (e.g., [APEX]).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weeklyActiveMembers rdf:type rdf:Property ;
    rdfs:label 'Weekly Active Members' ;
    rdfs:comment 'Count of guild members who were active in-game during the most recent 7-day period. Key community health metric analogous to Weekly Active Users (WAU) at the guild level.' ;
    rdfs:domain ind:Guild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:xpTotal rdf:type rdf:Property ;
    rdfs:label 'Xp Total' ;
    rdfs:comment 'Cumulative experience points (XP) earned by the guild through collective member activity, guild quests, and in-game events. Drives guild level progression and prestige rankings.' ;
    rdfs:domain ind:Guild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:guildMembershipId rdf:type rdf:Property ;
    rdfs:label 'Guild Membership Id' ;
    rdfs:comment 'Unique surrogate identifier for each guild membership record. Serves as the primary key for the guild_membership association entity, tracking the full lifecycle of a player\'s participation within a guild or clan.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activityStatus rdf:type rdf:Property ;
    rdfs:label 'Activity Status' ;
    rdfs:comment 'Derived classification of the member\'s recent engagement level within the guild context, based on login frequency and guild-specific interactions. Distinct from membership_status; used by guild leaders and community managers to identify at-risk members for retention outreach.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributionScore rdf:type rdf:Property ;
    rdfs:label 'Contribution Score' ;
    rdfs:comment 'Numeric score representing the player\'s cumulative contributions to the guild, such as donated resources, completed guild quests, or participation in guild events. Used by guild leaders to assess member value and inform promotion or removal decisions.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentRoleSinceDate rdf:type rdf:Property ;
    rdfs:label 'Current Role Since Date' ;
    rdfs:comment 'The date on which the player was assigned their current membership_role. Enables tenure-in-role calculations and supports promotion eligibility logic distinct from overall guild tenure.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataProcessingConsent rdf:type rdf:Property ;
    rdfs:label 'Data Processing Consent' ;
    rdfs:comment 'Indicates whether the player has provided explicit consent for processing of their guild membership and community interaction data. Required for GDPR compliance for players in EU jurisdictions. True when valid consent is on record.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:departureDate rdf:type rdf:Property ;
    rdfs:label 'Departure Date' ;
    rdfs:comment 'The calendar date on which the player left or was removed from the guild. Null when the membership is still active. Used for churn analysis and guild stability reporting.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:departureReason rdf:type rdf:Property ;
    rdfs:label 'Departure Reason' ;
    rdfs:comment 'Categorical reason explaining why the player\'s membership ended. Supports community health analysis and guild churn root-cause reporting. Null when membership is still active.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildChatMessagesSent rdf:type rdf:Property ;
    rdfs:label 'Guild Chat Messages Sent' ;
    rdfs:comment 'Cumulative count of messages sent by the player in the guild chat channel since joining. A key social engagement indicator used by community managers to assess member communication activity and guild cohesion.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:guildEventsParticipated rdf:type rdf:Property ;
    rdfs:label 'Guild Events Participated' ;
    rdfs:comment 'Cumulative count of guild-organized events (raids, tournaments, guild quests, PvP battles) in which the player has participated since joining. Used to measure event engagement and identify high-value community contributors.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hasPromotionHistory rdf:type rdf:Property ;
    rdfs:label 'Has Promotion History' ;
    rdfs:comment 'Indicates whether the player has ever been promoted to a higher role within this guild. True when at least one role promotion event exists in the membership history. Used as a quick filter for identifying experienced, trusted members.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inviteSource rdf:type rdf:Property ;
    rdfs:label 'Invite Source' ;
    rdfs:comment 'The channel or mechanism through which the player was recruited into the guild. Supports K-Factor viral coefficient analysis and community growth attribution. Examples include direct officer invite, public recruitment post, player referral, automated matchmaking, social platform import, or in-game guild search.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAgeVerified rdf:type rdf:Property ;
    rdfs:label 'Is Age Verified' ;
    rdfs:comment 'Indicates whether the player\'s age has been verified as meeting the minimum age requirement for guild participation, particularly relevant for guilds with mature content ratings. Supports COPPA compliance for guilds accessible to younger audiences.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFounder rdf:type rdf:Property ;
    rdfs:label 'Is Founder' ;
    rdfs:comment 'Indicates whether this player was one of the founding members who created the guild. Founders may retain special privileges or recognition even if their current role has changed. Used for community heritage and loyalty analytics.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMuted rdf:type rdf:Property ;
    rdfs:label 'Is Muted' ;
    rdfs:comment 'Indicates whether the player\'s guild chat privileges have been temporarily muted by a guild officer or leader. True when the player is currently restricted from sending messages in guild channels. Used for community moderation tracking.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:joinDate rdf:type rdf:Property ;
    rdfs:label 'Join Date' ;
    rdfs:comment 'The calendar date on which the player officially joined the guild. Used for tenure calculations, retention analysis, and D1/D7/D30 guild engagement cohort reporting.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:joinTimestamp rdf:type rdf:Property ;
    rdfs:label 'Join Timestamp' ;
    rdfs:comment 'Precise date and time at which the player\'s guild membership was activated. Provides sub-day precision for event sequencing, funnel analysis, and audit trails beyond what join_date alone provides.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastActiveDate rdf:type rdf:Property ;
    rdfs:label 'Last Active Date' ;
    rdfs:comment 'The most recent calendar date on which the player performed any guild-related activity. Used to identify dormant members, trigger re-engagement campaigns, and support inactivity-based removal workflows.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:membershipRole rdf:type rdf:Property ;
    rdfs:label 'Membership Role' ;
    rdfs:comment 'The functional role held by the player within the guild hierarchy. Determines permissions, responsibilities, and visibility within guild operations. Common roles include leader (guild owner), officer (elevated permissions), veteran (trusted long-term member), member (standard participant), and recruit (probationary new member).' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipStatus rdf:type rdf:Property ;
    rdfs:label 'Membership Status' ;
    rdfs:comment 'Current lifecycle state of the player\'s guild membership. Active indicates full participation; inactive indicates the player has not engaged recently; suspended indicates a temporary restriction imposed by guild leadership; departed indicates the player has left or been removed; pending indicates an invitation or application awaiting acceptance.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipTier rdf:type rdf:Property ;
    rdfs:label 'Membership Tier' ;
    rdfs:comment 'Prestige or progression tier assigned to the player\'s membership within the guild, reflecting cumulative achievement and standing. Used for tiered reward distribution, exclusive content access, and community recognition programs.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:muteExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Mute Expiry Date' ;
    rdfs:comment 'The date on which a temporary guild chat mute restriction is scheduled to expire. Null when is_muted is false or when the mute is permanent pending manual review. Used by community moderation workflows.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:previousRole rdf:type rdf:Property ;
    rdfs:label 'Previous Role' ;
    rdfs:comment 'The membership role held by the player immediately before their current role assignment. Provides a single-step promotion/demotion audit trail without requiring a full history table query for the most recent transition.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pvpWinsForGuild rdf:type rdf:Property ;
    rdfs:label 'Pvp Wins For Guild' ;
    rdfs:comment 'Cumulative count of PvP (Player versus Player) match victories the player has contributed to guild-ranked competitions since joining. Used to assess competitive contribution and inform officer promotion decisions.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'The timestamp at which this guild membership record was first created in the data platform. Serves as the audit creation timestamp for data lineage and Silver Layer ingestion tracking.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'The timestamp at which this guild membership record was most recently modified in the data platform. Used for incremental ETL processing, change data capture, and audit trail maintenance in the Databricks Silver Layer.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:referralsMade rdf:type rdf:Property ;
    rdfs:label 'Referrals Made' ;
    rdfs:comment 'Count of other players this member has successfully referred or invited into the guild. Supports K-Factor (viral coefficient) analysis at the guild level and identifies high-influence community members.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportsReceived rdf:type rdf:Property ;
    rdfs:label 'Reports Received' ;
    rdfs:comment 'Cumulative count of conduct or content reports filed against this player by other community members during their guild membership. Elevated counts may trigger moderation review or membership suspension.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportsSubmitted rdf:type rdf:Property ;
    rdfs:label 'Reports Submitted' ;
    rdfs:comment 'Cumulative count of player-reported content or conduct reports submitted by this member against other guild members or community participants. Used by community moderation teams to assess reporting behavior and identify potential abuse patterns.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resourcesDonated rdf:type rdf:Property ;
    rdfs:label 'Resources Donated' ;
    rdfs:comment 'Cumulative count of in-game resource units donated by the player to the guild treasury or shared pool since joining. Contributes to contribution_score and is used to evaluate member generosity and guild economy participation.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Identifies the operational system of record from which this guild membership record originated or was last updated. Supports data lineage tracking in the Databricks Silver Layer and ETL audit processes.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportTicketsRaised rdf:type rdf:Property ;
    rdfs:label 'Support Tickets Raised' ;
    rdfs:comment 'Count of Zendesk support tickets raised by this player that are related to guild or community issues (e.g., harassment reports, guild dispute escalations) during their membership tenure. Used by player support teams to identify high-friction community interactions.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalGuildSessions rdf:type rdf:Property ;
    rdfs:label 'Total Guild Sessions' ;
    rdfs:comment 'Cumulative count of play sessions during which the player engaged in at least one guild-specific activity since joining. Supports session length and engagement depth analysis for community health reporting.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weeklyActiveDays rdf:type rdf:Property ;
    rdfs:label 'Weekly Active Days' ;
    rdfs:comment 'Number of distinct days in the most recently completed calendar week on which the player was active within the guild context (e.g., participated in guild chat, guild quests, or guild events). Serves as a WAU (Weekly Active Users) proxy at the membership level for community health dashboards.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kbArticleId rdf:type rdf:Property ;
    rdfs:label 'Kb Article Id' ;
    rdfs:comment 'Unique surrogate identifier for a knowledge base article in the player support portal. Primary key for this entity. MASTER_RESOURCE role — serves as the SSOT for self-service support content published via Zendesk Knowledge Base.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KbArticle .

ind:categoryId rdf:type rdf:Property ;
    rdfs:label 'Category Id' ;
    rdfs:comment 'Reference to the Zendesk Help Center category under which this article is organized (e.g., Account & Billing, Gameplay, Technical Issues, In-Game Purchases). Drives portal navigation and article discoverability.' ;
    rdfs:domain ind:KbArticle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KbCategory .

ind:certificationChecklistId rdf:type rdf:Property ;
    rdfs:label 'Certification Checklist Id' ;
    rdfs:comment 'Foreign key linking to platform.certification_checklist. Business justification: Knowledge base articles document certification requirements, TRC/TCR guidance, and compliance best practices. Developer portal KB must reference specific checklist versions for accuracy. Essential for' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CertificationChecklist .

ind:primaryKbEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Kb Employee Id' ;
    rdfs:comment 'Reference to the Zendesk support agent or community manager who authored or owns this article. Used for content accountability, quality review workflows, and agent performance tracking.' ;
    rdfs:domain ind:KbArticle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reviewerAgentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reviewer Agent Employee Id' ;
    rdfs:comment 'Reference to the Zendesk agent or team lead who last reviewed and approved this article for publication. Supports content governance, accountability, and audit trail requirements.' ;
    rdfs:domain ind:KbArticle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:archivedAt rdf:type rdf:Property ;
    rdfs:label 'Archived At' ;
    rdfs:comment 'Timestamp when the article was transitioned to \'archived\' status and removed from public view. Null if the article has never been archived. Supports content lifecycle audit trails and compliance record retention.' ;
    rdfs:domain ind:KbArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:articleType rdf:type rdf:Property ;
    rdfs:label 'Article Type' ;
    rdfs:comment 'Classification of the article by its content purpose. \'how_to\' = step-by-step guide; \'faq\' = frequently asked question; \'troubleshooting\' = diagnostic resolution guide; \'policy\' = terms, rules, or compliance content; \'release_notes\' = patch or update notes; \'known_issue\' = documented active bug or service disruption.' ;
    rdfs:domain ind:KbArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commentCount rdf:type rdf:Property ;
    rdfs:label 'Comment Count' ;
    rdfs:comment 'Total number of player comments submitted on this article. Indicates community engagement level and may surface unresolved issues or content gaps requiring article updates.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentBody rdf:type rdf:Property ;
    rdfs:label 'Content Body' ;
    rdfs:comment 'Full HTML or plain-text body content of the knowledge base article as rendered in the player support portal. Contains step-by-step instructions, troubleshooting guidance, FAQs, or policy explanations. Sourced from Zendesk Articles API \'body\' field.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentFormat rdf:type rdf:Property ;
    rdfs:label 'Content Format' ;
    rdfs:comment 'Format of the article content body. \'html\' = rich HTML markup as rendered in Zendesk; \'markdown\' = Markdown-formatted text; \'plain_text\' = unformatted text. Determines how the content_body field is parsed and rendered by the support portal.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentVersion rdf:type rdf:Property ;
    rdfs:label 'Content Version' ;
    rdfs:comment 'Monotonically incrementing version number of the article content, incremented each time the article body or title is materially updated. Supports content audit trails and rollback identification. Corresponds to Zendesk article revision tracking.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coppaRestricted rdf:type rdf:Property ;
    rdfs:label 'Coppa Restricted' ;
    rdfs:comment 'Indicates whether this article is restricted from display to players under 13 years of age in compliance with COPPA regulations. Applies to articles referencing data collection, in-app purchases (IAP), or social features for child-directed games.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:createdAt rdf:type rdf:Property ;
    rdfs:label 'Created At' ;
    rdfs:comment 'Timestamp when this knowledge base article record was first created in the system (draft creation). Corresponds to the Zendesk article creation timestamp. Distinct from published_at, which reflects when the article became publicly visible.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deflectionRate rdf:type rdf:Property ;
    rdfs:label 'Deflection Rate' ;
    rdfs:comment 'Proportion of article views that resulted in the player NOT submitting a support ticket, expressed as a decimal between 0 and 1 (e.g., 0.7500 = 75% deflection). Core KPI for measuring the effectiveness of self-service support content in reducing agent workload.' ;
    rdfs:domain ind:KbArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:esrbContentFlag rdf:type rdf:Property ;
    rdfs:label 'Esrb Content Flag' ;
    rdfs:comment 'Indicates whether this article contains content that references mature or age-restricted game content subject to ESRB rating guidelines (e.g., articles about M-rated game features). When true, the article may be restricted from display to players under the applicable age threshold.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprDataFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Data Flag' ;
    rdfs:comment 'Indicates whether this article references player personal data handling procedures (e.g., data deletion requests, account privacy settings). When true, the article is subject to GDPR supervisory authority review and must align with current privacy policy.' ;
    rdfs:domain ind:KbArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:helpfulVoteCount rdf:type rdf:Property ;
    rdfs:label 'Helpful Vote Count' ;
    rdfs:comment 'Total number of player votes indicating the article was helpful (thumbs up / \'Yes\' response to the \'Was this article helpful?\' prompt). Used to measure content quality and player satisfaction with self-service support.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isCommentsEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Comments Enabled' ;
    rdfs:comment 'Indicates whether player comments are enabled on this article. When true, players can submit feedback comments directly on the article page. Community managers may disable comments on policy or legal articles.' ;
    rdfs:domain ind:KbArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPromoted rdf:type rdf:Property ;
    rdfs:label 'Is Promoted' ;
    rdfs:comment 'Indicates whether this article has been promoted to appear at the top of search results or in featured content sections of the support portal. Promoted articles are typically high-traffic or high-deflection content prioritized by the community team.' ;
    rdfs:domain ind:KbArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelNames rdf:type rdf:Property ;
    rdfs:label 'Label Names' ;
    rdfs:comment 'Comma-separated list of Zendesk content labels or tags applied to this article for search and filtering purposes (e.g., \'account,billing,refund\'). Supports faceted search and related-article recommendations in the support portal.' ;
    rdfs:domain ind:KbArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAccuracyReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Accuracy Review Date' ;
    rdfs:comment 'Date on which the article content was last reviewed for factual accuracy and relevance by the content team. Articles not reviewed within a defined SLA window (e.g., 90 days) are flagged for mandatory review to prevent outdated guidance from reaching players.' ;
    rdfs:domain ind:KbArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastUpdatedAt rdf:type rdf:Property ;
    rdfs:label 'Last Updated At' ;
    rdfs:comment 'Timestamp of the most recent material update to the article content, title, or metadata. Corresponds to the Zendesk \'updated_at\' field. Displayed to players as \'Last Updated\' to indicate content freshness.' ;
    rdfs:domain ind:KbArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:locale rdf:type rdf:Property ;
    rdfs:label 'Locale' ;
    rdfs:comment 'IETF BCP 47 language-region locale code for the article (e.g., en-US, fr-FR, de-DE, ja-JP, ko-KR). Supports multi-language player support portals across global markets. Aligns with PEGI, USK, CERO, and GRAC regional compliance requirements.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date by which this article must next be reviewed for accuracy and relevance. Set by the content governance workflow based on article type, game patch cadence, or regulatory change events. Drives automated review reminders for the community team.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permissionGroup rdf:type rdf:Property ;
    rdfs:label 'Permission Group' ;
    rdfs:comment 'Access control group determining which audience can view this article. \'everyone\' = publicly accessible without login; \'signed_in\' = requires player account authentication; \'agents_only\' = internal support agent reference content not visible to players. Aligns with Zendesk user segment permissions.' ;
    rdfs:domain ind:KbArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationStatus rdf:type rdf:Property ;
    rdfs:label 'Publication Status' ;
    rdfs:comment 'Current lifecycle state of the knowledge base article within the Zendesk content workflow. \'draft\' = authored but not yet visible to players; \'published\' = live and searchable in the support portal; \'archived\' = retired from public view but retained for historical reference.' ;
    rdfs:domain ind:KbArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishedAt rdf:type rdf:Property ;
    rdfs:label 'Published At' ;
    rdfs:comment 'Timestamp when the article was first published and made visible to players in the support portal. Corresponds to the Zendesk \'created_at\' field for published articles. Used for content age analysis and SLA reporting.' ;
    rdfs:domain ind:KbArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:readingTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Reading Time Minutes' ;
    rdfs:comment 'Estimated time in minutes for a player to read the article, calculated from word_count using a standard reading speed baseline. Displayed in the support portal to set player expectations and improve user experience.' ;
    rdfs:domain ind:KbArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:relatedArticleIds rdf:type rdf:Property ;
    rdfs:label 'Related Article Ids' ;
    rdfs:comment 'Comma-separated list of kb_article_id values for articles editorially linked as related content. Drives \'Related Articles\' recommendations in the support portal to improve player self-service navigation and reduce ticket submission.' ;
    rdfs:domain ind:KbArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Editorial review state of the article within the content governance workflow. \'pending_review\' = awaiting QA or editorial sign-off; \'approved\' = cleared for publication; \'needs_update\' = flagged for content refresh; \'flagged\' = escalated for compliance or accuracy concerns.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchRankScore rdf:type rdf:Property ;
    rdfs:label 'Search Rank Score' ;
    rdfs:comment 'Relevance score assigned by the Zendesk search engine or internal ranking algorithm to determine article ordering in search results. Higher scores indicate greater relevance for common player queries. Used to optimize content discoverability.' ;
    rdfs:domain ind:KbArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sectionId rdf:type rdf:Property ;
    rdfs:label 'Section Id' ;
    rdfs:comment 'Reference to the Zendesk Help Center section (sub-category) under which this article is nested. Sections provide a second level of hierarchy beneath categories for finer-grained content organization.' ;
    rdfs:domain ind:KbArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seoSlug rdf:type rdf:Property ;
    rdfs:label 'Seo Slug' ;
    rdfs:comment 'URL-friendly slug derived from the article title, used in the canonical URL of the support portal article page. Supports App Store Optimization (ASO) and organic search discoverability. Must be lowercase alphanumeric with hyphens.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unhelpfulVoteCount rdf:type rdf:Property ;
    rdfs:label 'Unhelpful Vote Count' ;
    rdfs:comment 'Total number of player votes indicating the article was not helpful (thumbs down / \'No\' response). Used alongside helpful_vote_count to compute article satisfaction ratio and identify content requiring revision.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:voteSum rdf:type rdf:Property ;
    rdfs:label 'Vote Sum' ;
    rdfs:comment 'Net vote score for the article, calculated as helpful_vote_count minus unhelpful_vote_count. Provides a single signed integer representing overall player sentiment toward the article. Used for content quality ranking and surfacing top-rated support articles.' ;
    rdfs:domain ind:KbArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wordCount rdf:type rdf:Property ;
    rdfs:label 'Word Count' ;
    rdfs:comment 'Total word count of the article content body (excluding HTML markup). Used by content teams to assess article depth, readability, and SEO quality. Articles below a minimum threshold may be flagged for expansion.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:zendeskArticleCode rdf:type rdf:Property ;
    rdfs:label 'Zendesk Article Code' ;
    rdfs:comment 'External article identifier assigned by Zendesk Knowledge Base, used to cross-reference the article in the source system of record. Enables reconciliation between the lakehouse silver layer and the operational Zendesk platform.' ;
    rdfs:domain ind:KbArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adCreativeId rdf:type rdf:Property ;
    rdfs:label 'Ad Creative Id' ;
    rdfs:comment 'Foreign key linking to marketing.ad_creative. Business justification: Moderation flags ad creative violations in UGC or forums (copyright infringement, misleading claims). Direct link enables compliance tracking, ad creative quality monitoring, and regulatory reporting ' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdCreative .

ind:auditFindingId rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Id' ;
    rdfs:comment 'Foreign key linking to compliance.audit_finding. Business justification: Compliance audits analyze moderation action patterns to identify control gaps (inadequate age verification, inconsistent content enforcement). Links moderation evidence to formal audit findings requir' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditFinding .

ind:primaryModerationPlayerAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Moderation Player Account Id' ;
    rdfs:comment 'Reference to the player account against whom this moderation action is applied. The subject of the enforcement action.' ;
    rdfs:domain ind:ModerationAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerAccount .

ind:violatingAssetId rdf:type rdf:Property ;
    rdfs:label 'Violating Asset Id' ;
    rdfs:comment 'Foreign key linking to content.asset. Business justification: Content policy enforcement requires linking moderation decisions to asset catalog for CDN removal and audit trail. Regulatory compliance (ESRB, PEGI, COPPA) mandates tracking which assets were flagged' ;
    rdfs:domain ind:ModerationAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:actionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Action Reference Number' ;
    rdfs:comment 'Externally visible, human-readable reference number for this moderation action. Used in player-facing communications, appeals correspondence, and audit trails. Format: MOD- followed by 8–12 digits.' ;
    rdfs:domain ind:ModerationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionStatus rdf:type rdf:Property ;
    rdfs:label 'Action Status' ;
    rdfs:comment 'Current lifecycle state of the moderation action. active = enforcement currently in effect; expired = time-limited ban has naturally elapsed; reinstated = ban re-applied after appeal overturn; overturned = action reversed via appeal; pending = action queued for review or delayed enforcement.' ;
    rdfs:domain ind:ModerationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealEligible rdf:type rdf:Property ;
    rdfs:label 'Appeal Eligible' ;
    rdfs:comment 'Indicates whether the targeted player is eligible to submit a formal appeal against this moderation action. Eligibility may be restricted for certain violation types (e.g., confirmed cheating, COPPA violations) or repeat offenders.' ;
    rdfs:domain ind:ModerationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:automationConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Automation Confidence Score' ;
    rdfs:comment 'For automated moderation actions, the confidence score (0.0000–1.0000) produced by the automated moderation model at the time of action. Null for human-executed actions. Used to assess model accuracy, calibrate thresholds, and flag low-confidence decisions for human review.' ;
    rdfs:domain ind:ModerationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:banDurationHours rdf:type rdf:Property ;
    rdfs:label 'Ban Duration Hours' ;
    rdfs:comment 'The length of a temporary ban or mute expressed in hours. Null for permanent bans (perma_ban) or non-ban action types. Used to calculate ban_end_timestamp and to support duration-based analytics and escalation policies.' ;
    rdfs:domain ind:ModerationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:banEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ban End Timestamp' ;
    rdfs:comment 'The date and time at which a temporary ban or mute is scheduled to expire and the player\'s access is automatically restored. Null for permanent bans or non-ban action types. Stored in ISO 8601 format with timezone offset.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contentCategory rdf:type rdf:Property ;
    rdfs:label 'Content Category' ;
    rdfs:comment 'The content classification category of the violating material as assessed by the moderator (e.g., HATE_SPEECH, ADULT_CONTENT, VIOLENCE, CHEATING_EXPLOIT, SPAM_ADVERTISING). Aligns with ESRB and PEGI content descriptors for regulatory reporting. [ENUM-REF-CANDIDATE: HATE_SPEECH|ADULT_CONTENT|VIOLENCE|CHEATING_EXPLOIT|SPAM_ADVERTISING|MINOR_ENDANGERMENT|FRAUD|IMPERSONATION — promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationTier rdf:type rdf:Property ;
    rdfs:label 'Escalation Tier' ;
    rdfs:comment 'The escalation level to which this action has been routed: tier_1 (frontline community moderation), tier_2 (senior moderation review), tier_3 (trust and safety team), legal (referred to legal or compliance team). Null for non-escalated actions.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceReference rdf:type rdf:Property ;
    rdfs:label 'Evidence Reference' ;
    rdfs:comment 'Identifier or URI pointing to the stored evidence package (screenshots, chat logs, replay files, UGC assets) that supports this moderation decision. May reference a content delivery network (CDN) path, internal document store, or case management system artifact.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moderatorNotes rdf:type rdf:Property ;
    rdfs:label 'Moderator Notes' ;
    rdfs:comment 'Internal free-text notes recorded by the moderator for case context, coordination with other team members, or documentation of edge-case circumstances. Not visible to the player. Supports case handoff and audit review.' ;
    rdfs:domain ind:ModerationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerNotified rdf:type rdf:Property ;
    rdfs:label 'Player Notified' ;
    rdfs:comment 'Indicates whether the targeted player has been formally notified of this moderation action via in-game notification, email, or support ticket. Required for GDPR transparency obligations and internal player communication standards.' ;
    rdfs:domain ind:ModerationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorActionCount rdf:type rdf:Property ;
    rdfs:label 'Prior Action Count' ;
    rdfs:comment 'The number of previous moderation actions recorded against the target player at the time this action was issued. Captured as a point-in-time snapshot to support escalation logic, recidivism analysis, and progressive discipline enforcement.' ;
    rdfs:domain ind:ModerationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Flag' ;
    rdfs:comment 'Indicates whether this moderation action has been flagged as potentially involving a regulatory compliance obligation (e.g., COPPA minor safety incident, GDPR data misuse, illegal content under DSA). Triggers mandatory regulatory review and reporting workflows.' ;
    rdfs:domain ind:ModerationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryFrameworkCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework Code' ;
    rdfs:comment 'Identifies the specific regulatory framework applicable to this moderation action when regulatory_flag is True (e.g., GDPR for EU player data, COPPA for under-13 player content, DSA for illegal content under the EU Digital Services Act). Null or NONE when no regulatory obligation applies. [ENUM-REF-CANDIDATE: GDPR|COPPA|DSA|ESRB|PEGI|PCI_DSS|NONE — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ModerationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedContentReference rdf:type rdf:Property ;
    rdfs:label 'Reported Content Reference' ;
    rdfs:comment 'Reference to the specific player-reported content record (forum post, UGC submission, chat message, or other community content) that is the subject of this moderation action.' ;
    rdfs:domain ind:ModerationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetEntityReference rdf:type rdf:Property ;
    rdfs:label 'Target Entity Reference' ;
    rdfs:comment 'The system-specific identifier of the targeted entity (e.g., forum post ID, UGC asset ID, chat message ID, guild ID). Stored as a string to accommodate identifiers from multiple source systems. Used in conjunction with target_entity_type to locate the exact subject of enforcement.' ;
    rdfs:domain ind:ModerationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetEntityType rdf:type rdf:Property ;
    rdfs:label 'Target Entity Type' ;
    rdfs:comment 'The type of community entity against which this moderation action is directed. Distinguishes whether the action targets a player account, a specific piece of content (forum post, UGC submission, chat message), a guild/clan, or a player review.' ;
    rdfs:domain ind:ModerationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerFeedbackId rdf:type rdf:Property ;
    rdfs:label 'Player Feedback Id' ;
    rdfs:comment 'Unique surrogate identifier for each player feedback record in the silver layer lakehouse. Primary key for the player_feedback data product.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerFeedback .

ind:assignedEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Player feedback triage and resolution workflows require tracking assignment to specific product managers, designers, or engineers. Enables accountability metrics (resolution time by assignee), workloa' ;
    rdfs:domain ind:PlayerFeedback ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:regulatoryChangeId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Change Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_change. Business justification: Player feedback about loot box mechanics, data handling, or age restrictions informs impact assessments and response plans for new regulations (e.g., EU loot box restrictions). Links community sentime' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryChange .

ind:reportedAssetId rdf:type rdf:Property ;
    rdfs:label 'Reported Asset Id' ;
    rdfs:comment 'Foreign key linking to content.asset. Business justification: QA triage workflow links player-reported bugs (broken textures, missing models, audio glitches) to specific assets for artist/engineer assignment. Content quality dashboards aggregate feedback-per-ass' ;
    rdfs:domain ind:Community ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:contentReference rdf:type rdf:Property ;
    rdfs:label 'Content Reference' ;
    rdfs:comment 'Identifier of the specific in-game content item (DLC, UGC, quest, event, cosmetic) the feedback relates to, if applicable. Enables content-level feedback aggregation for live-ops and content teams to assess reception of specific releases.' ;
    rdfs:domain ind:PlayerFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackBody rdf:type rdf:Property ;
    rdfs:label 'Feedback Body' ;
    rdfs:comment 'The full unstructured text of the player\'s feedback submission. Contains the player\'s verbatim input describing their experience, issue, or suggestion. Subject to content moderation and PII scrubbing before use in analytics. Classified confidential due to potential inclusion of personal expressions and opinions.' ;
    rdfs:domain ind:PlayerFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackCategory rdf:type rdf:Property ;
    rdfs:label 'Feedback Category' ;
    rdfs:comment 'Primary classification of the feedback topic as selected by the player or auto-classified at submission. Drives routing to the appropriate product, engineering, or live-ops team. Values: gameplay (mechanics, controls, balance), ui (interface, UX), performance (FPS, latency, crashes), content (story, levels, DLC), monetization (MTX, IAP, pricing), other.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Feedback Reference Number' ;
    rdfs:comment 'Human-readable, externally visible reference number assigned to the feedback submission. Used by community managers and player support agents to reference a specific submission in communications. Sourced from the in-game feedback tool or community portal at submission time.' ;
    rdfs:domain ind:PlayerFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackStatus rdf:type rdf:Property ;
    rdfs:label 'Feedback Status' ;
    rdfs:comment 'Current workflow lifecycle state of the feedback record. Tracks progression from initial submission through triage, actioning, and closure by community or product teams. [ENUM-REF-CANDIDATE: submitted|under_review|actioned|closed|duplicate|rejected — promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackSubcategory rdf:type rdf:Property ;
    rdfs:label 'Feedback Subcategory' ;
    rdfs:comment 'Secondary classification providing granular topic detail within the primary feedback category (e.g., \'matchmaking\' under gameplay, \'loot_box_pricing\' under monetization, \'menu_navigation\' under ui). Populated from a controlled taxonomy maintained by the community team. [ENUM-REF-CANDIDATE: promote to reference product — values vary by category]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackTitle rdf:type rdf:Property ;
    rdfs:label 'Feedback Title' ;
    rdfs:comment 'Short, player-provided or auto-generated title summarising the feedback submission. Used in community portal listings, moderation queues, and reporting dashboards for quick identification without reading the full body text.' ;
    rdfs:domain ind:PlayerFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gameMode rdf:type rdf:Property ;
    rdfs:label 'Game Mode' ;
    rdfs:comment 'The game mode the player was engaged in when the feedback was submitted (e.g., PvP, PvE, co-op, single player, MMO, ranked). Enables mode-specific feedback analysis to identify issues isolated to particular play contexts. [ENUM-REF-CANDIDATE: pvp|pve|co_op|single_player|mmo|battle_royale|ranked|casual|tutorial — promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gameVersion rdf:type rdf:Property ;
    rdfs:label 'Game Version' ;
    rdfs:comment 'The semantic version string of the game build active at the time of feedback submission (e.g., \'2.4.1.1023\'). Enables engineering teams to correlate feedback spikes with specific releases, hotfixes, or patches. Sourced from the game client at submission time.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBetaParticipant rdf:type rdf:Property ;
    rdfs:label 'Is Beta Participant' ;
    rdfs:comment 'Indicates whether the feedback was submitted by a player participating in a beta or soft launch programme. Beta feedback is typically weighted differently in product prioritisation and is subject to separate NDA and data handling policies.' ;
    rdfs:domain ind:PlayerFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isModerated rdf:type rdf:Property ;
    rdfs:label 'Is Moderated' ;
    rdfs:comment 'Indicates whether the feedback body text has been reviewed by a community moderator or automated moderation system. Unmoderated feedback should not be surfaced in public-facing community portals or shared externally.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPayingPlayer rdf:type rdf:Property ;
    rdfs:label 'Is Paying Player' ;
    rdfs:comment 'Indicates whether the player had made at least one IAP or MTX purchase prior to submitting the feedback. Enables differentiation of paying vs. F2P player feedback, particularly relevant for monetisation category feedback analysis.' ;
    rdfs:domain ind:PlayerFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jiraIssueKey rdf:type rdf:Property ;
    rdfs:label 'Jira Issue Key' ;
    rdfs:comment 'Reference to the Jira issue (bug, story, or task) created as a result of this feedback, if actioned by the product or engineering team. Enables traceability from player feedback to development backlog items and sprint planning.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mapOrLevelName rdf:type rdf:Property ;
    rdfs:label 'Map Or Level Name' ;
    rdfs:comment 'The name of the in-game map, level, zone, or area the player was in when the feedback was submitted. Enables spatial correlation of feedback to specific content areas, supporting level design and QA triage.' ;
    rdfs:domain ind:PlayerFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moderationOutcome rdf:type rdf:Property ;
    rdfs:label 'Moderation Outcome' ;
    rdfs:comment 'Result of the content moderation review for this feedback submission. Approved records are safe for internal analytics and community reporting. Flagged or removed records indicate policy violations. Escalated records require senior review or legal assessment.' ;
    rdfs:domain ind:PlayerFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingSystem rdf:type rdf:Property ;
    rdfs:label 'Operating System' ;
    rdfs:comment 'Operating system name and version reported by the player\'s device at feedback submission (e.g., \'Windows 11 23H2\', \'iOS 17.4\', \'Android 14\'). Critical for PC and mobile platform bug triage and compatibility analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piiDetected rdf:type rdf:Property ;
    rdfs:label 'Pii Detected' ;
    rdfs:comment 'Indicates whether the automated PII detection pipeline identified personally identifiable information within the feedback body text. When true, the feedback_body field must be treated as restricted and the PII scrubbed before downstream use. Supports GDPR and COPPA compliance.' ;
    rdfs:domain ind:PlayerFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:playerRating rdf:type rdf:Property ;
    rdfs:label 'Player Rating' ;
    rdfs:comment 'Optional numeric rating (1–5) provided by the player alongside their feedback, representing their overall satisfaction with the specific feature or experience being commented on. Distinct from NPS/CSAT scores which are survey-driven; this is feature-specific and submission-attached.' ;
    rdfs:domain ind:PlayerFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Triage priority assigned to the feedback by community managers or automated scoring, indicating urgency for product team review. Critical priority feedback (e.g., game-breaking bugs, safety concerns) triggers immediate escalation workflows.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentimentClassification rdf:type rdf:Property ;
    rdfs:label 'Sentiment Classification' ;
    rdfs:comment 'Sentiment label assigned to the feedback body text, either by an NLP model or manual review. Used to track community health trends, identify emerging negative sentiment spikes, and measure the impact of live-ops changes on player satisfaction. Distinct from NPS/CSAT scores.' ;
    rdfs:domain ind:PlayerFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentimentConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Sentiment Confidence Score' ;
    rdfs:comment 'Probability score (0.0000–1.0000) representing the NLP model\'s confidence in the assigned sentiment classification. Scores below a defined threshold flag the record for manual review. Supports model performance monitoring and quality assurance of automated classification.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sessionLengthSeconds rdf:type rdf:Property ;
    rdfs:label 'Session Length Seconds' ;
    rdfs:comment 'Duration in seconds of the game session at the point the feedback was submitted. Provides context on whether feedback was submitted early (FTUE friction) or late in a session (deep gameplay issues). Sourced from the game client session context.' ;
    rdfs:domain ind:PlayerFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submissionChannel rdf:type rdf:Property ;
    rdfs:label 'Submission Channel' ;
    rdfs:comment 'The interface or channel through which the player submitted the feedback. Enables channel-level analysis of feedback volume and quality. In-game tool submissions are typically contextually richer (session data attached); community portal submissions may be more deliberate. [ENUM-REF-CANDIDATE: in_game_tool|community_portal|beta_channel|playtesting|support_ticket|social_media — promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted Timestamp' ;
    rdfs:comment 'The precise date and time (ISO 8601 with timezone offset) at which the player submitted the feedback. This is the principal business event timestamp — distinct from ETL ingestion time. Critical for time-series analysis, D1/D7/D30 retention correlation, and live-ops response SLA measurement.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:zendeskTicketCode rdf:type rdf:Property ;
    rdfs:label 'Zendesk Ticket Code' ;
    rdfs:comment 'Reference to the associated Zendesk support ticket if the feedback was escalated to or originated from the player support system. Enables cross-referencing between community feedback and formal support cases for holistic player care analysis.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gachaPullId rdf:type rdf:Property ;
    rdfs:label 'Gacha Pull Id' ;
    rdfs:comment 'Foreign key linking to monetization.gacha_pull. Business justification: Players report perceived unfair gacha outcomes or regulatory concerns about drop rates. Reports reference specific pull events for investigation - moderation verifies disclosed rates match actual outc' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GachaPull .

ind:primaryPlayerAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Player Account Id' ;
    rdfs:comment 'Reference to the player who submitted this report. Identifies the originating party of the moderation action.' ;
    rdfs:domain ind:PlayerReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerAccount .

ind:evidenceAttachmentUrls rdf:type rdf:Property ;
    rdfs:label 'Evidence Attachment Urls' ;
    rdfs:comment 'Comma-separated list of CDN-hosted URLs pointing to evidence files (screenshots, video clips, chat exports) submitted with the report. Stored as a delimited string per Silver layer conventions.' ;
    rdfs:domain ind:PlayerReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Incident Timestamp' ;
    rdfs:comment 'The real-world date and time when the alleged violation occurred, as reported by the submitting player or inferred from game session logs. Distinct from the report submission timestamp.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isAutomatedFlag rdf:type rdf:Property ;
    rdfs:label 'Is Automated Flag' ;
    rdfs:comment 'Indicates whether this report was generated by an automated detection system (e.g., anti-cheat engine, chat filter, UGC scanner) rather than a player submission. Distinguishes system-generated from player-generated reports.' ;
    rdfs:domain ind:PlayerReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRepeatReport rdf:type rdf:Property ;
    rdfs:label 'Is Repeat Report' ;
    rdfs:comment 'Indicates whether the reporting player has previously submitted a report against the same reported entity. True signals potential targeted harassment by the reporter or a persistent offender pattern.' ;
    rdfs:domain ind:PlayerReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:moderationQueue rdf:type rdf:Property ;
    rdfs:label 'Moderation Queue' ;
    rdfs:comment 'The moderation queue to which this report was routed based on violation severity, reporter history, and automated triage rules. Determines handling SLA tier.' ;
    rdfs:domain ind:PlayerReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportDescription rdf:type rdf:Property ;
    rdfs:label 'Report Description' ;
    rdfs:comment 'Free-text narrative provided by the reporting player describing the alleged violation in their own words. Primary evidence input for moderator review.' ;
    rdfs:domain ind:PlayerReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportNumber rdf:type rdf:Property ;
    rdfs:label 'Report Number' ;
    rdfs:comment 'Human-readable, externally referenceable business identifier for the report (e.g., RPT-0000123456). Used in player communications, Zendesk tickets, and audit trails.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportSourceChannel rdf:type rdf:Property ;
    rdfs:label 'Report Source Channel' ;
    rdfs:comment 'The channel through which the report was submitted (e.g., in-game report UI, web portal, mobile app, Zendesk support form). Informs channel-specific moderation workflow routing.' ;
    rdfs:domain ind:PlayerReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportStatus rdf:type rdf:Property ;
    rdfs:label 'Report Status' ;
    rdfs:comment 'Current lifecycle state of the player report within the moderation workflow. Drives queue management and SLA tracking. [ENUM-REF-CANDIDATE: pending|under_review|actioned|dismissed|escalated|closed — promote to reference product if additional statuses are required]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedEntityPriorViolationCount rdf:type rdf:Property ;
    rdfs:label 'Reported Entity Prior Violation Count' ;
    rdfs:comment 'Number of confirmed prior violations on the reported entity\'s record at the time of this report. Informs severity escalation and repeat-offender enforcement policies.' ;
    rdfs:domain ind:PlayerReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportedEntityReference rdf:type rdf:Property ;
    rdfs:label 'Reported Entity Reference' ;
    rdfs:comment 'Identifier of the entity being reported (player, post, UGC item, or chat message). The entity type is specified in reported_entity_type.' ;
    rdfs:domain ind:PlayerReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportedEntityType rdf:type rdf:Property ;
    rdfs:label 'Reported Entity Type' ;
    rdfs:comment 'Discriminator indicating the type of entity being reported. Determines which downstream moderation workflow and evidence schema applies. [ENUM-REF-CANDIDATE: player|post|ugc|chat|clan|profile — promote to reference product if additional types are required]' ;
    rdfs:domain ind:PlayerReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reporterAccountAgeDays rdf:type rdf:Property ;
    rdfs:label 'Reporter Account Age Days' ;
    rdfs:comment 'Age of the reporting player\'s account in days at the time of report submission. Used in automated triage to weight report credibility and detect smurf or throwaway accounts.' ;
    rdfs:domain ind:PlayerReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reporterPriorReportCount rdf:type rdf:Property ;
    rdfs:label 'Reporter Prior Report Count' ;
    rdfs:comment 'Total number of reports previously submitted by the reporting player at the time of this submission. Supports reporter credibility scoring and abuse-of-report-system detection.' ;
    rdfs:domain ind:PlayerReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionAction rdf:type rdf:Property ;
    rdfs:label 'Resolution Action' ;
    rdfs:comment 'The specific enforcement action taken as a result of this report. Drives enforcement analytics and appeals tracking. [ENUM-REF-CANDIDATE: warning_issued|account_suspended|account_banned|content_removed|no_action|escalated_to_trust_safety — promote to reference product if additional actions are required]' ;
    rdfs:domain ind:PlayerReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Moderator-authored free-text notes documenting the rationale for the resolution decision, evidence reviewed, and any mitigating factors considered. Critical for appeals and audit trails.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTimeHours rdf:type rdf:Property ;
    rdfs:label 'Resolution Time Hours' ;
    rdfs:comment 'Actual elapsed time in hours from report submission to resolution. Calculated field stored for operational reporting; used to assess moderation efficiency and SLA adherence.' ;
    rdfs:domain ind:PlayerReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolved Timestamp' ;
    rdfs:comment 'Date and time when the report was fully resolved (actioned or dismissed). Used to calculate end-to-end resolution time and SLA compliance.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reviewed Timestamp' ;
    rdfs:comment 'Date and time when a moderator first opened and began reviewing this report. Used to calculate time-to-first-review SLA metrics.' ;
    rdfs:domain ind:PlayerReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'The target resolution time in hours for this report based on its severity level and moderation queue tier. Used to measure SLA compliance and moderator performance.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerReputationId rdf:type rdf:Property ;
    rdfs:label 'Player Reputation Id' ;
    rdfs:comment 'Unique identifier for the player reputation record. Primary key for the player reputation entity.' ;
    rdfs:domain ind:PlayerReputation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:canInvite rdf:type rdf:Property ;
    rdfs:label 'Can Invite' ;
    rdfs:comment 'Boolean flag indicating whether the player can send guild or event invitations. Privilege earned through positive community standing.' ;
    rdfs:domain ind:PlayerReputation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:canModerate rdf:type rdf:Property ;
    rdfs:label 'Can Moderate' ;
    rdfs:comment 'Boolean flag indicating whether the player has community moderation privileges. Reserved for leader and moderator trust tiers.' ;
    rdfs:domain ind:PlayerReputation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:canPost rdf:type rdf:Property ;
    rdfs:label 'Can Post' ;
    rdfs:comment 'Boolean flag indicating whether the player has privilege to post in community forums. Gated by trust tier and violation history.' ;
    rdfs:domain ind:PlayerReputation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:canUploadUgc rdf:type rdf:Property ;
    rdfs:label 'Can Upload Ugc' ;
    rdfs:comment 'Boolean flag indicating whether the player has privilege to upload UGC submissions. Requires minimum trust tier and clean moderation record.' ;
    rdfs:domain ind:PlayerReputation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:canVote rdf:type rdf:Property ;
    rdfs:label 'Can Vote' ;
    rdfs:comment 'Boolean flag indicating whether the player can vote on community content, polls, or UGC submissions. Basic privilege for established members.' ;
    rdfs:domain ind:PlayerReputation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endorsementCount rdf:type rdf:Property ;
    rdfs:label 'Endorsement Count' ;
    rdfs:comment 'Total number of endorsements received from other community members. Reflects peer recognition of positive contributions.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:helpfulContributionCount rdf:type rdf:Property ;
    rdfs:label 'Helpful Contribution Count' ;
    rdfs:comment 'Number of forum posts, UGC submissions, or support responses marked as helpful by the community. Key metric for reputation advancement.' ;
    rdfs:domain ind:PlayerReputation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isVerifiedContributor rdf:type rdf:Property ;
    rdfs:label 'Is Verified Contributor' ;
    rdfs:comment 'Boolean flag indicating whether the player has been verified as a trusted content contributor. Verified status displayed publicly and influences trust tier.' ;
    rdfs:domain ind:PlayerReputation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kFactorContribution rdf:type rdf:Property ;
    rdfs:label 'K Factor Contribution' ;
    rdfs:comment 'Player\'s contribution to viral growth through community referrals and invitations. Measures organic community expansion driven by this player.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moderationThresholdLevel rdf:type rdf:Property ;
    rdfs:label 'Moderation Threshold Level' ;
    rdfs:comment 'Automated moderation sensitivity level applied to this player based on trust tier and history. Higher trust tiers receive relaxed thresholds.' ;
    rdfs:domain ind:PlayerReputation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousTrustTier rdf:type rdf:Property ;
    rdfs:label 'Previous Trust Tier' ;
    rdfs:comment 'The trust tier held immediately before the most recent tier change. Enables tier transition analysis and rollback scenarios.' ;
    rdfs:domain ind:PlayerReputation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reputationDecayRate rdf:type rdf:Property ;
    rdfs:label 'Reputation Decay Rate' ;
    rdfs:comment 'Percentage rate at which reputation points decay due to inactivity or negative behavior. Applied periodically to maintain active community engagement.' ;
    rdfs:domain ind:PlayerReputation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reputationNumber rdf:type rdf:Property ;
    rdfs:label 'Reputation Number' ;
    rdfs:comment 'Human-readable business identifier for the reputation record. Format: REP-XXXXXXXXXX.' ;
    rdfs:domain ind:PlayerReputation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reputationPoints rdf:type rdf:Property ;
    rdfs:label 'Reputation Points' ;
    rdfs:comment 'Total accumulated reputation score based on positive community contributions, endorsements, and helpful actions. Used to calculate trust tier and privilege eligibility.' ;
    rdfs:domain ind:PlayerReputation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reputationStatus rdf:type rdf:Property ;
    rdfs:label 'Reputation Status' ;
    rdfs:comment 'Current lifecycle status of the reputation record. Active indicates normal operation; suspended/frozen indicates temporary restriction; under_review indicates pending moderation action; banned indicates permanent revocation.' ;
    rdfs:domain ind:PlayerReputation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionEndDate rdf:type rdf:Property ;
    rdfs:label 'Suspension End Date' ;
    rdfs:comment 'Date when temporary reputation suspension expires and privileges are restored. Null for permanent bans or active reputations.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'Free-text explanation for reputation suspension or restriction. Provides context for moderation actions and player communication.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierChangeReason rdf:type rdf:Property ;
    rdfs:label 'Tier Change Reason' ;
    rdfs:comment 'Reason code for the most recent trust tier change. Supports audit trail and player communication.' ;
    rdfs:domain ind:PlayerReputation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierDemotionDate rdf:type rdf:Property ;
    rdfs:label 'Tier Demotion Date' ;
    rdfs:comment 'Date when the player was last demoted to a lower trust tier due to violations or inactivity. Tracks negative reputation events.' ;
    rdfs:domain ind:PlayerReputation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierPromotionDate rdf:type rdf:Property ;
    rdfs:label 'Tier Promotion Date' ;
    rdfs:comment 'Date when the player was last promoted to a higher trust tier. Tracks progression through the reputation system.' ;
    rdfs:domain ind:PlayerReputation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trustTier rdf:type rdf:Property ;
    rdfs:label 'Trust Tier' ;
    rdfs:comment 'Current trust level classification earned through positive community participation. Determines privilege access and automated moderation thresholds. Values: new (new account), basic (minimal activity), member (established presence), regular (consistent positive contributor), leader (community influencer), moderator (elevated privileges).' ;
    rdfs:domain ind:PlayerReputation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'Date when the player achieved verified contributor status. Null if not verified.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:violationCount rdf:type rdf:Property ;
    rdfs:label 'Violation Count' ;
    rdfs:comment 'Total number of confirmed community guideline violations. Impacts trust tier and may result in privilege revocation.' ;
    rdfs:domain ind:PlayerReputation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warningCount rdf:type rdf:Property ;
    rdfs:label 'Warning Count' ;
    rdfs:comment 'Total number of moderation warnings issued to the player. Negative indicator that may trigger reputation decay or tier demotion.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:socialConnectionId rdf:type rdf:Property ;
    rdfs:label 'Social Connection Id' ;
    rdfs:comment 'Unique surrogate identifier for each social graph relationship record between two players. Primary key for the social_connection entity.' ;
    rdfs:domain ind:SocialConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySocialPlayerAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Social Player Account Id' ;
    rdfs:comment 'Reference to the player who originated or initiated the social connection request (the source node in the social graph). Used to determine directionality of the relationship.' ;
    rdfs:domain ind:SocialConnection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerAccount .

ind:targetPlayerPlayerAccountId rdf:type rdf:Property ;
    rdfs:label 'Target Player Player Account Id' ;
    rdfs:comment 'Reference to the player who is the recipient or target of the social connection request (the destination node in the social graph). Used to determine directionality of the relationship.' ;
    rdfs:domain ind:SocialConnection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerAccount .

ind:blockReasonCode rdf:type rdf:Property ;
    rdfs:label 'Block Reason Code' ;
    rdfs:comment 'Standardized reason code provided by the initiating player when blocking the target player. Populated only when connection_type is \'blocked\'. Supports community safety analytics and moderation reporting.' ;
    rdfs:domain ind:SocialConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coPlaySessionCount rdf:type rdf:Property ;
    rdfs:label 'Co Play Session Count' ;
    rdfs:comment 'Number of game sessions in which both the initiating and target players participated together since the connection was established. Key metric for measuring social engagement depth and retention correlation.' ;
    rdfs:domain ind:SocialConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:connectionDirection rdf:type rdf:Property ;
    rdfs:label 'Connection Direction' ;
    rdfs:comment 'Indicates whether the social relationship is unidirectional (e.g., follower, blocked, muted — only the initiating player\'s perspective applies) or bidirectional (e.g., mutual friend where both parties have accepted).' ;
    rdfs:domain ind:SocialConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectionLabel rdf:type rdf:Property ;
    rdfs:label 'Connection Label' ;
    rdfs:comment 'Optional free-text label or nickname assigned by the initiating player to categorize or personalize this connection (e.g., \'Raid Team\', \'IRL Friend\', \'Clan Leader\'). Supports player-defined social graph organization.' ;
    rdfs:domain ind:SocialConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectionNumber rdf:type rdf:Property ;
    rdfs:label 'Connection Number' ;
    rdfs:comment 'Human-readable business identifier for the social connection record, used for support, audit, and operational reference. Format: SC- followed by 10 digits.' ;
    rdfs:domain ind:SocialConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectionSource rdf:type rdf:Property ;
    rdfs:label 'Connection Source' ;
    rdfs:comment 'The channel or surface through which the social connection was initiated. Supports attribution analysis for community growth and K-Factor viral coefficient measurement. Values: in_game (initiated during gameplay), forum (community forum), guild (guild/clan membership), external (external social platform import), platform (console or PC platform friend list).' ;
    rdfs:domain ind:SocialConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectionStatus rdf:type rdf:Property ;
    rdfs:label 'Connection Status' ;
    rdfs:comment 'Current lifecycle state of the social connection. \'pending\' means the request has been sent but not yet acted upon; \'accepted\' means the connection is active; \'declined\' means the target player rejected the request; \'removed\' means a previously accepted connection was dissolved.' ;
    rdfs:domain ind:SocialConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectionStrengthScore rdf:type rdf:Property ;
    rdfs:label 'Connection Strength Score' ;
    rdfs:comment 'Numeric score (0.00–100.00) representing the strength or closeness of the social connection based on interaction frequency, co-play sessions, and engagement signals. Used in community analytics, recommendation engines, and K-Factor viral coefficient modeling.' ;
    rdfs:domain ind:SocialConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:connectionTier rdf:type rdf:Property ;
    rdfs:label 'Connection Tier' ;
    rdfs:comment 'Player-assigned or system-inferred tier classifying the closeness of the social relationship. Used for prioritized content feeds, notification filtering, and social graph segmentation in community analytics.' ;
    rdfs:domain ind:SocialConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectionType rdf:type rdf:Property ;
    rdfs:label 'Connection Type' ;
    rdfs:comment 'Categorical classification of the social relationship between the two players. \'friend\' indicates a mutual bidirectional relationship; \'follower\' indicates a unidirectional follow; \'blocked\' indicates the initiating player has blocked the target; \'muted\' indicates the initiating player has silenced the target without blocking.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectionVersion rdf:type rdf:Property ;
    rdfs:label 'Connection Version' ;
    rdfs:comment 'Optimistic locking version counter incremented on each update to the social connection record. Supports concurrent update conflict detection and Silver Layer SCD (Slowly Changing Dimension) processing in the Databricks Lakehouse.' ;
    rdfs:domain ind:SocialConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:establishedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Established Timestamp' ;
    rdfs:comment 'Timestamp when the social connection transitioned to an active/accepted state. Represents the real-world business event time of the connection being formed. Distinct from the record creation timestamp.' ;
    rdfs:domain ind:SocialConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interactionCount rdf:type rdf:Property ;
    rdfs:label 'Interaction Count' ;
    rdfs:comment 'Cumulative count of social interactions (messages, co-play sessions, gift exchanges, reactions) recorded between the two players since the connection was established. Raw signal used for connection strength scoring and community engagement analytics.' ;
    rdfs:domain ind:SocialConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isCrossGame rdf:type rdf:Property ;
    rdfs:label 'Is Cross Game' ;
    rdfs:comment 'Indicates whether this social connection spans multiple game titles within the platform ecosystem, as opposed to being scoped to a single game title. Supports cross-title community analytics.' ;
    rdfs:domain ind:SocialConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFavorite rdf:type rdf:Property ;
    rdfs:label 'Is Favorite' ;
    rdfs:comment 'Indicates whether the initiating player has marked this connection as a favorite or best friend, enabling prioritized display and notification preferences within the social graph.' ;
    rdfs:domain ind:SocialConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMinorRestricted rdf:type rdf:Property ;
    rdfs:label 'Is Minor Restricted' ;
    rdfs:comment 'Indicates whether this social connection involves at least one player identified as a minor, triggering COPPA-compliant restrictions on social features, messaging, and data processing.' ;
    rdfs:domain ind:SocialConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMutual rdf:type rdf:Property ;
    rdfs:label 'Is Mutual' ;
    rdfs:comment 'Indicates whether the social connection is bidirectional and mutually acknowledged by both players. True for accepted friend relationships; False for unidirectional follower, blocked, or muted connections.' ;
    rdfs:domain ind:SocialConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastInteractionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Interaction Timestamp' ;
    rdfs:comment 'Timestamp of the most recent social interaction between the two connected players. Used to identify dormant connections, calculate connection recency, and support churn prediction models.' ;
    rdfs:domain ind:SocialConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:muteReasonCode rdf:type rdf:Property ;
    rdfs:label 'Mute Reason Code' ;
    rdfs:comment 'Standardized reason code provided by the initiating player when muting the target player. Populated only when connection_type is \'muted\'. Supports community health and player experience analytics.' ;
    rdfs:domain ind:SocialConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationEnabled rdf:type rdf:Property ;
    rdfs:label 'Notification Enabled' ;
    rdfs:comment 'Indicates whether the initiating player has enabled activity notifications for this specific social connection (e.g., when the connected player goes online, achieves a milestone, or posts content).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npsInfluenceFlag rdf:type rdf:Property ;
    rdfs:label 'Nps Influence Flag' ;
    rdfs:comment 'Indicates whether this social connection was established as a result of an NPS (Net Promoter Score) promoter referral, linking community satisfaction data to social graph growth for player advocacy analytics.' ;
    rdfs:domain ind:SocialConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privacyVisibility rdf:type rdf:Property ;
    rdfs:label 'Privacy Visibility' ;
    rdfs:comment 'Privacy setting controlling who can see this social connection in the player\'s social graph. \'public\' allows all players to see the connection; \'friends_only\' restricts visibility to mutual friends; \'private\' hides the connection entirely.' ;
    rdfs:domain ind:SocialConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:removedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Removed Timestamp' ;
    rdfs:comment 'Timestamp when the social connection was dissolved or removed by either party. Populated only when connection_status is \'removed\'. Used for social graph churn analysis and community health monitoring.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestMessage rdf:type rdf:Property ;
    rdfs:label 'Request Message' ;
    rdfs:comment 'Optional personalized message submitted by the initiating player when sending a friend or follow request. Captured for community moderation review and player experience analytics.' ;
    rdfs:domain ind:SocialConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Sent Timestamp' ;
    rdfs:comment 'Timestamp when the initiating player sent the social connection request. Captures the origination event for funnel analysis, pending request aging, and FTUE (First-Time User Experience) social onboarding analytics.' ;
    rdfs:domain ind:SocialConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:respondedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Responded Timestamp' ;
    rdfs:comment 'Timestamp when the target player responded to the connection request (accepted, declined, or blocked). Used to calculate request response latency and pending request conversion rates.' ;
    rdfs:domain ind:SocialConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:battlePassEntitlementId rdf:type rdf:Property ;
    rdfs:label 'Battle Pass Entitlement Id' ;
    rdfs:comment 'Foreign key linking to monetization.battle_pass_entitlement. Business justification: Battle pass issues (progression bugs, missing rewards, purchase problems) are common support category. Tickets require entitlement state verification to diagnose tier unlock issues, XP discrepancies, ' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BattlePassEntitlement .

ind:dlcEntitlementId rdf:type rdf:Property ;
    rdfs:label 'Dlc Entitlement Id' ;
    rdfs:comment 'Foreign key linking to monetization.dlc_entitlement. Business justification: DLC access issues (download failures, license verification problems, missing content) are common support requests. Tickets require entitlement verification to diagnose platform sync issues, re-grant l' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DlcEntitlement .

ind:milestoneId rdf:type rdf:Property ;
    rdfs:label 'Milestone Id' ;
    rdfs:comment 'Foreign key linking to studio.milestone. Business justification: Release readiness assessment: critical bugs reported near milestones are tracked against those milestones for go/no-go decisions. Required for launch quality gates and certification compliance.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Milestone .

ind:regulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_filing. Business justification: Player complaints about loot box odds, underage purchases, or data handling trigger mandatory regulatory filings in many jurisdictions. Links support evidence to formal submissions to rating boards or' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFiling .

ind:botHandledFlag rdf:type rdf:Property ;
    rdfs:label 'Bot Handled Flag' ;
    rdfs:comment 'Indicates whether this ticket was fully or partially handled by an automated bot or virtual agent before human agent involvement. Used to measure automation deflection rates and evaluate chatbot effectiveness in reducing agent workload.' ;
    rdfs:domain ind:SupportTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closedAt rdf:type rdf:Property ;
    rdfs:label 'Closed At' ;
    rdfs:comment 'Timestamp when the ticket was permanently closed by the system (typically 72 hours after solved status). A closed ticket cannot be reopened. Distinct from solved_at — represents the final end-of-lifecycle event.' ;
    rdfs:domain ind:SupportTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dueAt rdf:type rdf:Property ;
    rdfs:label 'Due At' ;
    rdfs:comment 'The SLA deadline timestamp by which this ticket must be resolved to avoid an SLA breach. Set automatically based on ticket priority and channel SLA policy at time of creation. Used for real-time SLA monitoring and proactive escalation triggers.' ;
    rdfs:domain ind:SupportTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:firstResponseAt rdf:type rdf:Property ;
    rdfs:label 'First Response At' ;
    rdfs:comment 'Timestamp of the first public agent reply on this ticket. Used alongside opened_at to derive first_response_time_seconds and to validate SLA compliance at the event level. Distinct from first_response_time_seconds which is the computed duration.' ;
    rdfs:domain ind:SupportTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gdprDataRequestFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Data Request Flag' ;
    rdfs:comment 'Indicates whether this ticket contains or is associated with a GDPR data subject request (e.g., right of access, right to erasure, right to portability). Triggers mandatory compliance workflows with statutory response deadlines under GDPR Article 12.' ;
    rdfs:domain ind:SupportTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:groupName rdf:type rdf:Property ;
    rdfs:label 'Group Name' ;
    rdfs:comment 'Name of the Zendesk agent group or support team to which this ticket is assigned. Examples: \'Billing & Payments\', \'Technical Support - PC\', \'Trust & Safety\', \'VIP Player Care\'. Used for team-level workload and performance reporting.' ;
    rdfs:domain ind:SupportTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFirstContactResolved rdf:type rdf:Property ;
    rdfs:label 'Is First Contact Resolved' ;
    rdfs:comment 'Indicates whether the player\'s issue was fully resolved in a single interaction without requiring escalation, follow-up, or reopening. First Contact Resolution (FCR) is a primary KPI for support efficiency and player satisfaction.' ;
    rdfs:domain ind:SupportTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:knowledgeBaseArticleId rdf:type rdf:Property ;
    rdfs:label 'Knowledge Base Article Id' ;
    rdfs:comment 'Identifier of the Zendesk Help Center knowledge base article linked to or suggested for this ticket. Used to measure self-service deflection effectiveness and identify gaps in the knowledge base requiring new content.' ;
    rdfs:domain ind:SupportTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAssigneeUpdateAt rdf:type rdf:Property ;
    rdfs:label 'Last Assignee Update At' ;
    rdfs:comment 'Timestamp of the most recent comment or update submitted by the assigned agent on this ticket. Used to monitor agent responsiveness and identify tickets that have gone stale on the agent side.' ;
    rdfs:domain ind:SupportTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastRequesterUpdateAt rdf:type rdf:Property ;
    rdfs:label 'Last Requester Update At' ;
    rdfs:comment 'Timestamp of the most recent comment or update submitted by the player (requester) on this ticket. Used to identify stale tickets awaiting player response and to trigger automated follow-up reminders.' ;
    rdfs:domain ind:SupportTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:openedAt rdf:type rdf:Property ;
    rdfs:label 'Opened At' ;
    rdfs:comment 'Timestamp when the support ticket was first created and entered the support queue. Maps to BUSINESS_EVENT_TIMESTAMP category for TRANSACTION_HEADER role. The authoritative start-of-lifecycle timestamp for SLA calculation and cohort analysis.' ;
    rdfs:domain ind:SupportTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:organizationCode rdf:type rdf:Property ;
    rdfs:label 'Organization Code' ;
    rdfs:comment 'Reference to the Zendesk organization associated with the player, used for B2B or esports organization-level support grouping. Enables aggregated support reporting for esports teams, studio partners, or enterprise accounts.' ;
    rdfs:domain ind:SupportTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playerAccountType rdf:type rdf:Property ;
    rdfs:label 'Player Account Type' ;
    rdfs:comment 'Classification of the player\'s monetization tier at the time of ticket submission. F2P (Free-to-Play) players, premium purchasers, subscribers, and high-spending \'whale\' players may receive differentiated SLA treatment. Supports priority routing and ARPPU-aware support strategies.' ;
    rdfs:domain ind:SupportTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reopenCount rdf:type rdf:Property ;
    rdfs:label 'Reopen Count' ;
    rdfs:comment 'Number of times this ticket has been reopened after being marked as solved. A high reopen count indicates unresolved issues, poor first-contact resolution, or player dissatisfaction. Used in quality assurance and agent coaching workflows.' ;
    rdfs:domain ind:SupportTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Resolution Time Seconds' ;
    rdfs:comment 'Total elapsed time in seconds from ticket creation to the ticket being marked as solved. Key operational metric for support efficiency, SLA compliance, and player satisfaction correlation analysis.' ;
    rdfs:domain ind:SupportTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Indicates whether this ticket breached its assigned Service Level Agreement (SLA) target for first response or resolution time. True = SLA was breached. Used for operational KPI reporting, agent performance reviews, and SLA compliance dashboards.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:solvedAt rdf:type rdf:Property ;
    rdfs:label 'Solved At' ;
    rdfs:comment 'Timestamp when the ticket status was first set to \'solved\' by an agent or automation. Used to calculate resolution_time_seconds and to measure time-to-resolution distributions across issue categories and platforms.' ;
    rdfs:domain ind:SupportTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Short summary line of the player\'s support request as entered by the player or auto-populated by the in-game support widget. Used for full-text search, NLP topic modeling, and agent triage.' ;
    rdfs:domain ind:SupportTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportTicketDescription rdf:type rdf:Property ;
    rdfs:label 'Support Ticket Description' ;
    rdfs:comment 'Full initial description of the player\'s issue as submitted in the first message of the ticket. May contain account details, transaction references, or gameplay context. Classified confidential due to potential inclusion of player-specific operational data.' ;
    rdfs:domain ind:SupportTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketPriority rdf:type rdf:Property ;
    rdfs:label 'Ticket Priority' ;
    rdfs:comment 'Priority level assigned to the ticket, determining SLA tier and queue routing. \'urgent\' is reserved for critical issues such as account compromise, payment fraud, or widespread outages affecting CCU.' ;
    rdfs:domain ind:SupportTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketStatus rdf:type rdf:Property ;
    rdfs:label 'Ticket Status' ;
    rdfs:comment 'Current lifecycle state of the support ticket as tracked in Zendesk. Maps to LIFECYCLE_STATUS category for TRANSACTION_HEADER role. \'new\' = unassigned; \'open\' = assigned and active; \'pending\' = awaiting player response; \'on_hold\' = awaiting third-party; \'solved\' = agent-resolved; \'closed\' = system-locked after solve.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedAt rdf:type rdf:Property ;
    rdfs:label 'Updated At' ;
    rdfs:comment 'Timestamp of the most recent update to this ticket record in the lakehouse, reflecting the latest sync from Zendesk. Maps to RECORD_AUDIT_UPDATED category for TRANSACTION_HEADER role. Used for incremental ETL processing and change detection.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:surveyResponseId rdf:type rdf:Property ;
    rdfs:label 'Survey Response Id' ;
    rdfs:comment 'Primary key for survey_response' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playerLtvSegmentId rdf:type rdf:Property ;
    rdfs:label 'Player Ltv Segment Id' ;
    rdfs:comment 'Foreign key linking to monetization.player_ltv_segment. Business justification: Survey targeting segments by LTV (whales get retention surveys, non-payers get monetization friction surveys). Responses analyzed by player value tier for product decisions - different segments have d' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerLtvSegment .

ind:surveyId rdf:type rdf:Property ;
    rdfs:label 'Survey Id' ;
    rdfs:comment 'Reference to the parent survey definition that this response belongs to, linking back to the survey catalog.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Survey .

ind:answeredQuestionCount rdf:type rdf:Property ;
    rdfs:label 'Answered Question Count' ;
    rdfs:comment 'The number of survey questions the player actually answered. Compared against question_count to determine partial completion rate and identify drop-off points in the survey flow.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cesScore rdf:type rdf:Property ;
    rdfs:label 'Ces Score' ;
    rdfs:comment 'The player\'s raw Customer Effort Score on a 1–7 scale measuring how easy it was to resolve their issue or complete an in-game action. Null for non-CES survey types. Lower scores indicate higher effort and friction.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectionChannel rdf:type rdf:Property ;
    rdfs:label 'Collection Channel' ;
    rdfs:comment 'The channel through which the survey was delivered to the player. In_game indicates an in-game prompt; email indicates an email campaign; push_notification indicates a mobile push; web_portal indicates the player support portal; support_chat indicates a Zendesk chat trigger; post_ticket indicates a post-resolution Zendesk CSAT survey. [ENUM-REF-CANDIDATE: in_game|email|push_notification|web_portal|support_chat|post_ticket — promote to reference product]' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coppaVerifiedAge rdf:type rdf:Property ;
    rdfs:label 'Coppa Verified Age' ;
    rdfs:comment 'Indicates whether the player\'s age was verified as 13 or older (True) prior to survey collection, as required by COPPA for US-based players. False or null indicates age verification was not completed, and the response must be handled with restricted data processing.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customScore rdf:type rdf:Property ;
    rdfs:label 'Custom Score' ;
    rdfs:comment 'Numeric score captured for custom or bespoke survey instruments that do not conform to NPS, CSAT, or CES scales. The scale and interpretation are defined by the parent survey definition. Null for standard survey types.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:esrbRatingContext rdf:type rdf:Property ;
    rdfs:label 'Esrb Rating Context' ;
    rdfs:comment 'The ESRB content rating of the game title associated with this survey response at the time of collection. Used to ensure age-appropriate survey content and to apply correct data handling rules for minors (COPPA compliance for E/E10+ rated titles).' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followupStatus rdf:type rdf:Property ;
    rdfs:label 'Followup Status' ;
    rdfs:comment 'Current status of the player follow-up action triggered by this survey response. Pending indicates follow-up is queued; contacted indicates the player has been reached; resolved indicates the issue was addressed; no_action_required indicates the response did not warrant follow-up; opted_out indicates the player declined contact.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentRecorded rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Recorded' ;
    rdfs:comment 'Indicates whether explicit GDPR consent for processing this survey response and associated personal data was recorded at the time of collection (True = consent on file). Required for EU player data processing compliance.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOptedInFollowup rdf:type rdf:Property ;
    rdfs:label 'Is Opted In Followup' ;
    rdfs:comment 'Indicates whether the player consented to being contacted for follow-up based on their survey response (True = opted in). Used by the community management and player support teams to prioritize outreach to detractors and high-effort players.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kFactorReferralCode rdf:type rdf:Property ;
    rdfs:label 'K Factor Referral Code' ;
    rdfs:comment 'The referral or invite code associated with this survey response when the survey is part of a viral referral or K-Factor measurement program. Enables tracking of organic player advocacy and viral growth driven by promoter-segment players.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsCategory rdf:type rdf:Property ;
    rdfs:label 'Nps Category' ;
    rdfs:comment 'Derived classification of the NPS respondent based on their nps_score: promoter (9–10), passive (7–8), or detractor (0–6). Populated only for NPS survey type responses. Used directly in NPS calculation and community health reporting.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerCountryCode rdf:type rdf:Property ;
    rdfs:label 'Player Country Code' ;
    rdfs:comment 'The ISO 3166-1 alpha-3 three-letter country code of the player\'s registered or detected location at the time of survey response. Enables regional satisfaction benchmarking and compliance with jurisdiction-specific data handling (GDPR, COPPA).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerTenureDays rdf:type rdf:Property ;
    rdfs:label 'Player Tenure Days' ;
    rdfs:comment 'The number of days since the player\'s first recorded session at the time of survey response. Used to segment satisfaction scores by player lifecycle stage (e.g., new vs. veteran players) and correlate with D1/D7/D30 retention metrics.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:questionCount rdf:type rdf:Property ;
    rdfs:label 'Question Count' ;
    rdfs:comment 'The total number of questions presented to the player in this survey instance. Used to normalize completion rates and assess survey fatigue impact on response quality.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseCompletionSeconds rdf:type rdf:Property ;
    rdfs:label 'Response Completion Seconds' ;
    rdfs:comment 'The number of seconds the player took to complete the survey from first open to submission. Used to assess survey quality (very fast responses may indicate low-effort or bot submissions) and optimize survey length.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseExternalRef rdf:type rdf:Property ;
    rdfs:label 'Response External Ref' ;
    rdfs:comment 'Externally-known unique identifier for this survey response as assigned by the survey platform (e.g., SurveyMonkey response ID, Qualtrics response ID, or Zendesk CSAT token). Used for cross-system reconciliation.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseLanguage rdf:type rdf:Property ;
    rdfs:label 'Response Language' ;
    rdfs:comment 'The ISO 639-1 two-letter language code of the language in which the player completed the survey (e.g., en, fr, de, ja, ko). Used for localization quality analysis and multilingual NLP processing of verbatim feedback.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseStatus rdf:type rdf:Property ;
    rdfs:label 'Response Status' ;
    rdfs:comment 'Current lifecycle state of the survey response. Submitted indicates a fully completed response; partial indicates the player started but did not finish; abandoned indicates the survey was opened but no answers recorded; disqualified indicates the response was flagged as invalid; duplicate indicates a detected duplicate submission.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Timestamp' ;
    rdfs:comment 'The exact date and time (UTC) when the player submitted the survey response. This is the principal business event timestamp for this transaction record.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sentimentLabel rdf:type rdf:Property ;
    rdfs:label 'Sentiment Label' ;
    rdfs:comment 'Automated sentiment classification applied to the verbatim_feedback field by the NLP/text analytics pipeline. Indicates the overall emotional tone of the player\'s open-ended response. Used for community health monitoring and escalation routing.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveySentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Survey Sent Timestamp' ;
    rdfs:comment 'The date and time (UTC) when the survey invitation was dispatched to the player via the collection channel. Used to calculate response latency and optimize send-time strategies.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:surveyTriggerEvent rdf:type rdf:Property ;
    rdfs:label 'Survey Trigger Event' ;
    rdfs:comment 'The specific in-game or system event that caused the survey to be presented to the player (e.g., session_end, level_complete, ticket_resolved, purchase_complete, ftue_complete, d7_retention_check). Enables event-level satisfaction attribution. [ENUM-REF-CANDIDATE: session_end|level_complete|ticket_resolved|purchase_complete|ftue_complete|d7_retention_check|match_end|onboarding_complete — promote to reference product]' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyType rdf:type rdf:Property ;
    rdfs:label 'Survey Type' ;
    rdfs:comment 'Classification of the survey instrument used. NPS (Net Promoter Score) measures likelihood to recommend; CSAT (Customer Satisfaction Score) measures satisfaction with a specific interaction; CES (Customer Effort Score) measures ease of resolution; custom covers bespoke surveys; onboarding covers First-Time User Experience (FTUE) surveys; exit covers churn surveys.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyVersion rdf:type rdf:Property ;
    rdfs:label 'Survey Version' ;
    rdfs:comment 'The version identifier of the survey instrument used to collect this response (e.g., v1.0, v2.3). Enables longitudinal comparison of satisfaction scores across survey redesigns and question changes.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verbatimFeedback rdf:type rdf:Property ;
    rdfs:label 'Verbatim Feedback' ;
    rdfs:comment 'The player\'s free-text open-ended response providing qualitative context for their score. May contain opinions about game quality, support experience, or community sentiment. Used for text analytics, sentiment analysis, and AI/ML topic modeling. Classified confidential as it may contain player-identifiable opinions.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketCommentId rdf:type rdf:Property ;
    rdfs:label 'Ticket Comment Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual comment or response within a support ticket thread. Primary key for the ticket_comment data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:TicketComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agentDisplayName rdf:type rdf:Property ;
    rdfs:label 'Agent Display Name' ;
    rdfs:comment 'The display name of the support agent as shown to the player in the ticket thread. May differ from the agent\'s internal HR name. Used for player-facing communication quality review and community trust analytics.' ;
    rdfs:domain ind:TicketComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attachmentCount rdf:type rdf:Property ;
    rdfs:label 'Attachment Count' ;
    rdfs:comment 'Number of file attachments (screenshots, log files, video clips) included with this comment. Used to assess evidence richness in bug reports and player-reported content moderation cases.' ;
    rdfs:domain ind:TicketComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorType rdf:type rdf:Property ;
    rdfs:label 'Author Type' ;
    rdfs:comment 'Categorises the entity that authored the comment: player (end-user submitting or replying), agent (human support representative), bot (automated response system such as a Zendesk Answer Bot or AI assistant), or system (automated platform-generated message). Drives routing analytics and automation performance measurement.' ;
    rdfs:domain ind:TicketComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelSource rdf:type rdf:Property ;
    rdfs:label 'Channel Source' ;
    rdfs:comment 'The support channel through which this comment was submitted or received. Enables omnichannel support analytics and channel-specific CSAT (Customer Satisfaction Score) performance tracking. [ENUM-REF-CANDIDATE: web|email|chat|api|mobile_sdk|voice|social|community_forum — promote to reference product]' ;
    rdfs:domain ind:TicketComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commentBody rdf:type rdf:Property ;
    rdfs:label 'Comment Body' ;
    rdfs:comment 'The full plain-text content of the comment or response as submitted within the support ticket thread. May contain player-reported issues, agent instructions, bot-generated responses, or internal notes. Classified confidential due to potential inclusion of sensitive player communication.' ;
    rdfs:domain ind:TicketComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commentBodyHtml rdf:type rdf:Property ;
    rdfs:label 'Comment Body Html' ;
    rdfs:comment 'The HTML-formatted version of the comment body as rendered in the Zendesk interface. Preserves rich-text formatting, hyperlinks, and embedded media references for accurate conversation replay and agent tooling.' ;
    rdfs:domain ind:TicketComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commentSequence rdf:type rdf:Property ;
    rdfs:label 'Comment Sequence' ;
    rdfs:comment 'Ordinal position of this comment within the parent ticket\'s conversation thread, starting at 1. Enables chronological ordering of the full conversation history and identification of first-response, escalation points, and resolution comments.' ;
    rdfs:domain ind:TicketComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commentType rdf:type rdf:Property ;
    rdfs:label 'Comment Type' ;
    rdfs:comment 'Indicates the structural type of the comment as classified by Zendesk. Differentiates standard text comments from channel-specific comment types such as voice transcripts, social media replies, or native messaging interactions. [ENUM-REF-CANDIDATE: Comment|VoiceComment|TweetComment|FacebookComment|InstagramDm|NativeMessaging — promote to reference product]' ;
    rdfs:domain ind:TicketComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coppaRestrictedFlag rdf:type rdf:Property ;
    rdfs:label 'Coppa Restricted Flag' ;
    rdfs:comment 'Indicates whether this comment is associated with a player account subject to COPPA (Children\'s Online Privacy Protection Act) restrictions (player age under 13). When True, additional data handling restrictions apply to comment content and player-identifying metadata.' ;
    rdfs:domain ind:TicketComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:editTimestamp rdf:type rdf:Property ;
    rdfs:label 'Edit Timestamp' ;
    rdfs:comment 'The date and time when the comment body was last edited after initial submission. Populated only when is_edited is True. Supports audit trail and GDPR compliance tracking for comment content modifications.' ;
    rdfs:domain ind:TicketComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gdprErasureFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Erasure Flag' ;
    rdfs:comment 'Indicates whether the comment body and player-identifying content has been erased or anonymised in response to a GDPR Article 17 right-to-erasure (right to be forgotten) request. When True, comment_body and related PII fields are replaced with anonymised placeholders.' ;
    rdfs:domain ind:TicketComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ingestedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingested Timestamp' ;
    rdfs:comment 'The date and time when this comment record was ingested into the Databricks Silver Layer from the Zendesk source system. Used for ETL (Extract Transform Load) pipeline monitoring and data latency measurement.' ;
    rdfs:domain ind:TicketComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isFirstResponse rdf:type rdf:Property ;
    rdfs:label 'Is First Response' ;
    rdfs:comment 'Indicates whether this comment represents the first public agent or bot response to the player\'s initial ticket submission. Used to calculate First Response Time (FRT) KPI (Key Performance Indicator) for SLA compliance and CSAT (Customer Satisfaction Score) correlation analysis.' ;
    rdfs:domain ind:TicketComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPublic rdf:type rdf:Property ;
    rdfs:label 'Is Public' ;
    rdfs:comment 'Indicates whether the comment is visible to the player (public = True) or is an internal agent note not visible to the player (private = False). Critical for distinguishing player-facing communication from internal operational notes in conversation analytics.' ;
    rdfs:domain ind:TicketComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isResolutionComment rdf:type rdf:Property ;
    rdfs:label 'Is Resolution Comment' ;
    rdfs:comment 'Indicates whether this comment was the comment that triggered ticket resolution or closure. Enables identification of the resolution message for quality review, knowledge base article creation, and resolution time analytics.' ;
    rdfs:domain ind:TicketComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:macroCode rdf:type rdf:Property ;
    rdfs:label 'Macro Code' ;
    rdfs:comment 'Reference to the Zendesk macro (pre-defined response template) applied by the agent to generate this comment, if applicable. Null for manually authored comments. Enables macro usage analytics and response template effectiveness measurement.' ;
    rdfs:domain ind:TicketComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playerDisplayName rdf:type rdf:Property ;
    rdfs:label 'Player Display Name' ;
    rdfs:comment 'The in-game or platform display name (gamertag/username) of the player who authored this comment when author_type is \'player\'. Classified confidential as it is a player-linked identifier. Used for community moderation and player experience analytics.' ;
    rdfs:domain ind:TicketComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Response Time Seconds' ;
    rdfs:comment 'Elapsed time in seconds between the previous comment in the thread and this comment, representing the agent or player response latency. Used for SLA (Service Level Agreement) compliance measurement, First Response Time (FRT) tracking, and support efficiency analytics.' ;
    rdfs:domain ind:TicketComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:satisfactionComment rdf:type rdf:Property ;
    rdfs:label 'Satisfaction Comment' ;
    rdfs:comment 'Free-text feedback provided by the player alongside their CSAT (Customer Satisfaction Score) rating. Captures qualitative player sentiment for support quality improvement, agent coaching, and community health reporting.' ;
    rdfs:domain ind:TicketComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketStatusAtComment rdf:type rdf:Property ;
    rdfs:label 'Ticket Status At Comment' ;
    rdfs:comment 'The status of the parent support ticket at the time this comment was submitted. Captures the ticket lifecycle state snapshot per comment, enabling analysis of comment patterns across ticket workflow stages and SLA breach risk identification.' ;
    rdfs:domain ind:TicketComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viaSource rdf:type rdf:Property ;
    rdfs:label 'Via Source' ;
    rdfs:comment 'The specific Zendesk \'via\' source descriptor indicating the exact mechanism by which this comment was created (e.g., web form, email reply, API call, trigger automation, macro application). Provides granular channel attribution beyond channel_source for operational analytics.' ;
    rdfs:domain ind:TicketComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zendeskCommentCode rdf:type rdf:Property ;
    rdfs:label 'Zendesk Comment Code' ;
    rdfs:comment 'The native comment identifier assigned by Zendesk at the source system level. Used for lineage tracing and reconciliation between the Silver Layer and the Zendesk operational system of record.' ;
    rdfs:domain ind:TicketComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:zendeskTicketNumber rdf:type rdf:Property ;
    rdfs:label 'Zendesk Ticket Number' ;
    rdfs:comment 'The human-readable, externally-known ticket reference number displayed to players and agents in Zendesk (e.g., #12345). Enables players and support staff to reference the ticket in communications without exposing internal surrogate keys.' ;
    rdfs:domain ind:TicketComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ugcReviewId rdf:type rdf:Property ;
    rdfs:label 'Ugc Review Id' ;
    rdfs:comment 'Unique surrogate identifier for each UGC review record in the Gaming platform. Primary key for the ugc_review data product.' ;
    rdfs:domain ind:UgcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentRatingComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Content Rating Compliance Flag' ;
    rdfs:comment 'Indicates whether this review has been assessed and confirmed compliant with applicable content rating standards (ESRB, PEGI, USK, CERO, GRAC) for the target audience of the associated game title.' ;
    rdfs:domain ind:UgcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deletionReason rdf:type rdf:Property ;
    rdfs:label 'Deletion Reason' ;
    rdfs:comment 'Reason code for the soft deletion of this review. Supports compliance audit trails for GDPR erasure requests, moderation enforcement, and account ban processing.' ;
    rdfs:domain ind:UgcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSpoiler rdf:type rdf:Property ;
    rdfs:label 'Is Spoiler' ;
    rdfs:comment 'Indicates whether the reviewer or moderation team has flagged this review as containing spoilers for the UGC content or associated game. Triggers spoiler-blur UI treatment in community displays.' ;
    rdfs:domain ind:UgcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVerifiedDownload rdf:type rdf:Property ;
    rdfs:label 'Is Verified Download' ;
    rdfs:comment 'Indicates whether the reviewing player has a verified download or install of the UGC content on record. Verified reviews carry higher trust weight in community ranking algorithms.' ;
    rdfs:domain ind:UgcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVerifiedPlaytime rdf:type rdf:Property ;
    rdfs:label 'Is Verified Playtime' ;
    rdfs:comment 'Indicates whether the reviewing player has logged a minimum verified playtime threshold for the UGC content before submitting the review. Reduces low-effort or fraudulent reviews.' ;
    rdfs:domain ind:UgcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:moderationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Moderation Reason Code' ;
    rdfs:comment 'Standardized code identifying the reason for the moderation action applied to this review (e.g., SPAM, HATE_SPEECH, SPOILER, OFF_TOPIC, FAKE_REVIEW). [ENUM-REF-CANDIDATE: SPAM|HATE_SPEECH|SPOILER|OFF_TOPIC|FAKE_REVIEW|HARASSMENT|ADULT_CONTENT — promote to reference product]' ;
    rdfs:domain ind:UgcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notHelpfulVoteCount rdf:type rdf:Property ;
    rdfs:label 'Not Helpful Vote Count' ;
    rdfs:comment 'Number of community players who have marked this review as not helpful. Used alongside helpful_vote_count to compute net helpfulness score for review ranking.' ;
    rdfs:domain ind:UgcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playtimeAtReviewMinutes rdf:type rdf:Property ;
    rdfs:label 'Playtime At Review Minutes' ;
    rdfs:comment 'Total minutes of playtime the reviewer had accumulated on the UGC content at the time of review submission. Used to assess review credibility and weight in ranking models.' ;
    rdfs:domain ind:UgcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewBody rdf:type rdf:Property ;
    rdfs:label 'Review Body' ;
    rdfs:comment 'Full free-text review content authored by the player describing their experience with the UGC submission. Subject to moderation and community guidelines.' ;
    rdfs:domain ind:UgcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Review Language Code' ;
    rdfs:comment 'ISO 639-1 language code (optionally with ISO 3166-1 region subtag) of the review text (e.g., en, en-US, fr, de). Supports localized moderation workflows and multilingual community analytics.' ;
    rdfs:domain ind:UgcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewNumber rdf:type rdf:Property ;
    rdfs:label 'Review Number' ;
    rdfs:comment 'Externally visible, human-readable business identifier for this review (e.g., REV-0000123456). Used in player support, moderation workflows, and community reporting.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewSourceChannel rdf:type rdf:Property ;
    rdfs:label 'Review Source Channel' ;
    rdfs:comment 'The platform channel through which the player submitted this review (e.g., in-game overlay, web community portal, mobile app, Steam Workshop, Epic Games Store, console marketplace). Supports channel-level community analytics.' ;
    rdfs:domain ind:UgcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewTitle rdf:type rdf:Property ;
    rdfs:label 'Review Title' ;
    rdfs:comment 'Short headline or title of the review as entered by the player. Displayed in community listings and UGC detail pages.' ;
    rdfs:domain ind:UgcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewType rdf:type rdf:Property ;
    rdfs:label 'Review Type' ;
    rdfs:comment 'Classification of the review format submitted by the player. Distinguishes between written text reviews, video reviews, screenshot-based reviews, and quick star-only ratings without text.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerAccountAgeDays rdf:type rdf:Property ;
    rdfs:label 'Reviewer Account Age Days' ;
    rdfs:comment 'Age of the reviewer\'s player account in days at the time of review submission. Used in anti-fraud and fake review detection models; new accounts with reviews may be flagged for additional scrutiny.' ;
    rdfs:domain ind:UgcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewerTotalReviews rdf:type rdf:Property ;
    rdfs:label 'Reviewer Total Reviews' ;
    rdfs:comment 'Total number of UGC reviews the reviewer had submitted on the platform at the time this review was created. Contextualizes reviewer credibility and activity level for ranking models.' ;
    rdfs:domain ind:UgcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:starRating rdf:type rdf:Property ;
    rdfs:label 'Star Rating' ;
    rdfs:comment 'Numeric star rating assigned by the reviewer to the UGC content, on a 1–5 scale (1 = lowest quality, 5 = highest quality). Core community quality signal used for UGC discovery and ranking algorithms.' ;
    rdfs:domain ind:UgcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalVoteCount rdf:type rdf:Property ;
    rdfs:label 'Total Vote Count' ;
    rdfs:comment 'Total number of community votes (helpful + not helpful) received by this review. Indicates review engagement volume and statistical significance of helpfulness signals.' ;
    rdfs:domain ind:UgcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baseAssetId rdf:type rdf:Property ;
    rdfs:label 'Base Asset Id' ;
    rdfs:comment 'Foreign key linking to content.asset. Business justification: UGC moderation pipeline validates that player-created content references approved base assets. Content distribution tracks which game assets are used in UGC for licensing/IP clearance and usage analyt' ;
    rdfs:domain ind:UgcSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:dlcBundleId rdf:type rdf:Property ;
    rdfs:label 'Dlc Bundle Id' ;
    rdfs:comment 'Reference to the specific DLC product required to use this UGC submission, when requires_base_game_dlc is true. Used for entitlement checks during download and in-game loading.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DlcBundle .

ind:reviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reviewer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: UGC approval workflows require tracking which employee reviewed/approved submissions for IP clearance, content rating compliance, and monetization eligibility. Critical for audit trails, quality assur' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assetUrl rdf:type rdf:Property ;
    rdfs:label 'Asset Url' ;
    rdfs:comment 'Secure HTTPS URL pointing to the hosted UGC asset package on the CDN or platform storage. Used by game clients and platform SDKs to download the UGC content. Must be a valid HTTPS endpoint.' ;
    rdfs:domain ind:UgcSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creatorRevenueSharePct rdf:type rdf:Property ;
    rdfs:label 'Creator Revenue Share Pct' ;
    rdfs:comment 'Percentage of monetization revenue allocated to the UGC creator under the platform\'s creator economy program. Applicable only when is_monetization_eligible is true. Confidential commercial term.' ;
    rdfs:domain ind:UgcSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downloadCount rdf:type rdf:Property ;
    rdfs:label 'Download Count' ;
    rdfs:comment 'Cumulative number of times this UGC submission has been downloaded by players. Key community engagement metric used to rank popular content, inform creator reward programs, and drive workshop recommendation algorithms.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalSubmissionCode rdf:type rdf:Property ;
    rdfs:label 'External Submission Code' ;
    rdfs:comment 'Externally visible alphanumeric identifier for the UGC submission, used in platform workshop URLs, community portal deep links, and Steamworks/Epic Games Store SDK references. Serves as the BUSINESS_IDENTIFIER for this MASTER_RESOURCE.' ;
    rdfs:domain ind:UgcSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:favoriteCount rdf:type rdf:Property ;
    rdfs:label 'Favorite Count' ;
    rdfs:comment 'Number of players who have added this UGC submission to their favorites or wishlist. Indicates sustained player interest beyond initial download and is used for community engagement analytics and recommendation ranking.' ;
    rdfs:domain ind:UgcSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'Total file size of the UGC asset package in bytes. Used for CDN storage capacity planning, download time estimation, platform certification size limit checks, and player-facing display. Serves as the principal MEASUREMENT_OR_VALUE for this MASTER_RESOURCE.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gameEngineVersion rdf:type rdf:Property ;
    rdfs:label 'Game Engine Version' ;
    rdfs:comment 'Version of the game engine (Unity or Unreal Engine) used to create or required to run this UGC submission. Critical for compatibility validation during the asset pipeline ingestion and platform certification process.' ;
    rdfs:domain ind:UgcSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Ip Clearance Status' ;
    rdfs:comment 'Status of intellectual property rights clearance review for this UGC submission. Ensures the content does not infringe on third-party IP, trademarks, or copyrights before approval and distribution.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCrossPlatformCompatible rdf:type rdf:Property ;
    rdfs:label 'Is Cross Platform Compatible' ;
    rdfs:comment 'Indicates whether this UGC submission is certified as compatible across multiple gaming platforms (PC, console, mobile). Drives cross-platform distribution eligibility and platform certification routing.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMonetizationEligible rdf:type rdf:Property ;
    rdfs:label 'Is Monetization Eligible' ;
    rdfs:comment 'Indicates whether this UGC submission is eligible for in-game monetization programs (e.g., creator marketplace, revenue share, MTX integration). Determined by content type, approval status, and creator agreement acceptance.' ;
    rdfs:domain ind:UgcSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the UGC submission record, including creator-initiated version updates, moderation status changes, or metadata edits. Supports audit trail and change detection in the Silver layer.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:licenseType rdf:type rdf:Property ;
    rdfs:label 'License Type' ;
    rdfs:comment 'Licensing terms under which the UGC submission is distributed. Governs redistribution rights, modification permissions, and commercial use eligibility for the creator\'s content.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformTarget rdf:type rdf:Property ;
    rdfs:label 'Platform Target' ;
    rdfs:comment 'The gaming platform(s) for which this UGC submission is designed and compatible. Drives platform-specific certification checks, distribution routing, and compatibility filtering in workshop listings.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previewImageUrl rdf:type rdf:Property ;
    rdfs:label 'Preview Image Url' ;
    rdfs:comment 'Secure HTTPS URL for the thumbnail or preview image of the UGC submission displayed in community portals, workshop listings, and in-game browsing interfaces. Supports player discovery and click-through engagement.' ;
    rdfs:domain ind:UgcSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceVirtualCurrency rdf:type rdf:Property ;
    rdfs:label 'Price Virtual Currency' ;
    rdfs:comment 'Price of the UGC submission in the game\'s virtual currency units (e.g., coins, gems, credits) if sold through the in-game marketplace. Zero or null indicates free content. Supports in-game monetization (MTX/IAP) analytics.' ;
    rdfs:domain ind:UgcSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publishedDate rdf:type rdf:Property ;
    rdfs:label 'Published Date' ;
    rdfs:comment 'Calendar date when the UGC submission was first made publicly available to the player community. Used for date-based reporting, anniversary promotions, and community content calendars.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratingCount rdf:type rdf:Property ;
    rdfs:label 'Rating Count' ;
    rdfs:comment 'Total number of individual player ratings submitted for this UGC asset. Used alongside rating_score to assess statistical confidence of the aggregate rating and prevent manipulation by low-volume outliers.' ;
    rdfs:domain ind:UgcSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ratingScore rdf:type rdf:Property ;
    rdfs:label 'Rating Score' ;
    rdfs:comment 'Aggregate community rating score for the UGC submission, typically on a 0.00–5.00 scale. Computed from player ratings and used for workshop ranking, featured content selection, and creator reputation scoring.' ;
    rdfs:domain ind:UgcSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:removalReason rdf:type rdf:Property ;
    rdfs:label 'Removal Reason' ;
    rdfs:comment 'Reason code for the removal of the UGC submission from public availability. Required for compliance reporting under the Digital Services Act and internal moderation audit trails. Null if not removed.' ;
    rdfs:domain ind:UgcSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresBaseGameDlc rdf:type rdf:Property ;
    rdfs:label 'Requires Base Game Dlc' ;
    rdfs:comment 'Indicates whether this UGC submission requires the player to own a specific Downloadable Content (DLC) pack in addition to the base game in order to use the content. Used for entitlement validation and player-facing compatibility warnings.' ;
    rdfs:domain ind:UgcSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewerNotes rdf:type rdf:Property ;
    rdfs:label 'Reviewer Notes' ;
    rdfs:comment 'Free-text notes entered by the content moderation reviewer during the approval or rejection process. Documents the rationale for moderation decisions and supports appeals handling and compliance audits.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcePlatform rdf:type rdf:Property ;
    rdfs:label 'Source Platform' ;
    rdfs:comment 'The distribution platform through which this UGC submission was originally uploaded. Used for platform-specific compliance checks, certification routing, and cross-platform availability management. [ENUM-REF-CANDIDATE: steam|epic_games|playstation|xbox|nintendo|mobile_ios|mobile_android|web — promote to reference product]' ;
    rdfs:domain ind:UgcSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionStatus rdf:type rdf:Property ;
    rdfs:label 'Submission Status' ;
    rdfs:comment 'Current lifecycle state of the UGC submission within the moderation and publishing workflow. Controls visibility, download availability, and monetization eligibility. Serves as the LIFECYCLE_STATUS for this MASTER_RESOURCE. [ENUM-REF-CANDIDATE: draft|pending_review|approved|rejected|removed|archived — promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'Timestamp when the UGC submission was first submitted by the creator for review. Represents the principal business event time for this entity. Used for SLA tracking of moderation turnaround and community activity trend analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ugcSubmissionDescription rdf:type rdf:Property ;
    rdfs:label 'Ugc Submission Description' ;
    rdfs:comment 'Full text description of the UGC submission as authored by the creator. Describes the content, features, installation instructions, and intended use. Used for community discovery, search indexing, and moderation review.' ;
    rdfs:domain ind:UgcSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ugcType rdf:type rdf:Property ;
    rdfs:label 'Ugc Type' ;
    rdfs:comment 'Category of UGC asset submitted by the player. Drives content moderation workflows, monetization eligibility rules, and community portal routing. [ENUM-REF-CANDIDATE: map|mod|skin|game_mode|guide|fan_art|other — promote to reference product]' ;
    rdfs:domain ind:UgcSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viralReferralId rdf:type rdf:Property ;
    rdfs:label 'Viral Referral Id' ;
    rdfs:comment 'Unique surrogate identifier for each player-to-player referral event record. Primary key for the viral_referral data product. Entity role: TRANSACTION_HEADER — discrete referral lifecycle event with its own status funnel, timestamps, and reward state.' ;
    rdfs:domain ind:ViralReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryViralPlayerAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Viral Player Account Id' ;
    rdfs:comment 'Identifier of the player who initiated the referral (the referrer). Used to attribute K-Factor viral coefficient contributions and calculate referral program ROI per player. Maps to the player master entity. PARTY_REFERENCE (referrer side).' ;
    rdfs:domain ind:ViralReferral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerAccount .

ind:attributionConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Attribution Confidence Score' ;
    rdfs:comment 'A probabilistic score between 0.0000 and 1.0000 representing the attribution provider\'s confidence that this referral is correctly attributed to the referring player (e.g., based on device fingerprint match strength). Used to weight K-Factor calculations and filter low-confidence attributions.' ;
    rdfs:domain ind:ViralReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attributionProvider rdf:type rdf:Property ;
    rdfs:label 'Attribution Provider' ;
    rdfs:comment 'The mobile measurement partner (MMP) or internal system that attributed this referral event. Identifies the source of attribution data for auditability and cross-provider reconciliation. [ENUM-REF-CANDIDATE: appsflyer|adjust|internal|branch|singular — promote to reference product if providers expand]' ;
    rdfs:domain ind:ViralReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clickedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clicked Timestamp' ;
    rdfs:comment 'The date and time when the referred player first clicked the referral link or entered the friend code. Null if the referral has not yet been clicked. Used to compute click-through latency and CTR (Click-Through Rate) for referral campaigns.' ;
    rdfs:domain ind:ViralReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:convertedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Converted Timestamp' ;
    rdfs:comment 'The date and time when the referred player completed the qualifying conversion action (e.g., first purchase, first match played, reaching a level threshold) as defined by the referral campaign. Null if conversion has not occurred. Used for days-to-conversion calculation and referral ROI measurement.' ;
    rdfs:domain ind:ViralReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:daysToConversion rdf:type rdf:Property ;
    rdfs:label 'Days To Conversion' ;
    rdfs:comment 'Number of calendar days elapsed between the referral sent date and the conversion event date. Null if conversion has not occurred. Used to benchmark referral program velocity and optimize campaign reward timing windows.' ;
    rdfs:domain ind:ViralReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firstIapFlag rdf:type rdf:Property ;
    rdfs:label 'First Iap Flag' ;
    rdfs:comment 'Indicates whether the referred player made their first In-App Purchase (IAP) within the attribution window of this referral. True = first IAP made; False = no IAP made. Used to measure referral-to-payer conversion rate and ARPPU (Average Revenue Per Paying User) impact of referral programs.' ;
    rdfs:domain ind:ViralReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fraudReason rdf:type rdf:Property ;
    rdfs:label 'Fraud Reason' ;
    rdfs:comment 'The specific reason code assigned when a referral is flagged as fraudulent. Null or \'none\' for clean referrals. Used by the trust and safety team to categorize fraud patterns and refine detection rules. [ENUM-REF-CANDIDATE: self_referral|duplicate_device|bot_install|vpn_detected|velocity_abuse|none — promote to reference product if reasons expand]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftueCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Ftue Completed Flag' ;
    rdfs:comment 'Indicates whether the referred player completed the First-Time User Experience (FTUE) onboarding flow after install. True = FTUE completed; False = FTUE not completed. Used to measure onboarding quality for referred cohorts and identify drop-off points in the referral-to-engagement funnel.' ;
    rdfs:domain ind:ViralReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:installedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Installed Timestamp' ;
    rdfs:comment 'The date and time when the referred player completed the game installation attributed to this referral. Null if install has not occurred. Used to compute install latency and CPI (Cost Per Install) attribution for organic referral channels.' ;
    rdfs:domain ind:ViralReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:referralChannel rdf:type rdf:Property ;
    rdfs:label 'Referral Channel' ;
    rdfs:comment 'The distribution channel through which the referral was sent or shared. Drives channel-level K-Factor decomposition and informs which acquisition channels generate the highest organic growth. [ENUM-REF-CANDIDATE: invite_link|social_share|friend_code|in_game_invite|email_invite|push_notification — promote to reference product if channels expand]' ;
    rdfs:domain ind:ViralReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Referral Expiry Date' ;
    rdfs:comment 'The date on which this referral invite expires and is no longer eligible for conversion credit or reward payout. Null for referrals with no expiry. Used to enforce campaign time-boxing and clean up stale referral records.' ;
    rdfs:domain ind:ViralReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referralSourceUrl rdf:type rdf:Property ;
    rdfs:label 'Referral Source Url' ;
    rdfs:comment 'The deep-link or tracking URL through which the referral was delivered (e.g., invite link shared on social media or in-game). Used by AppsFlyer/Adjust for attribution matching and channel source verification. May be null for friend-code or in-game-invite channels.' ;
    rdfs:domain ind:ViralReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralStatus rdf:type rdf:Property ;
    rdfs:label 'Referral Status' ;
    rdfs:comment 'Current stage of the referral in the conversion funnel: sent (invite dispatched), clicked (link opened), installed (game installed), registered (account created), converted (qualifying in-game action completed). LIFECYCLE_STATUS for the TRANSACTION_HEADER role. Drives funnel drop-off analytics and K-Factor computation.' ;
    rdfs:domain ind:ViralReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referredPlayerD30Retained rdf:type rdf:Property ;
    rdfs:label 'Referred Player D30 Retained' ;
    rdfs:comment 'Indicates whether the referred player was still active in the game 30 days after their first session (D30 retention). True = retained at D30; False = churned before D30; Null = D30 window not yet elapsed. Used to evaluate the long-term quality of referred player cohorts and referral program LTV impact.' ;
    rdfs:domain ind:ViralReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referredPlayerD7Retained rdf:type rdf:Property ;
    rdfs:label 'Referred Player D7 Retained' ;
    rdfs:comment 'Indicates whether the referred player was still active in the game 7 days after their first session (D7 retention). True = retained at D7; False = churned before D7; Null = D7 window not yet elapsed. Key metric for assessing referral quality and long-term LTV (Lifetime Value) of referred cohorts.' ;
    rdfs:domain ind:ViralReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referredPlayerIsNew rdf:type rdf:Property ;
    rdfs:label 'Referred Player Is New' ;
    rdfs:comment 'Indicates whether the referred player was a genuinely new account at the time of referral attribution (True) or an existing player who re-engaged via a referral link (False). Critical for fraud prevention, reward eligibility validation, and accurate K-Factor computation.' ;
    rdfs:domain ind:ViralReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registeredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Registered Timestamp' ;
    rdfs:comment 'The date and time when the referred player completed account registration attributed to this referral. Null if registration has not occurred. Key milestone for funnel conversion rate analysis.' ;
    rdfs:domain ind:ViralReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rewardClaimedFlag rdf:type rdf:Property ;
    rdfs:label 'Reward Claimed Flag' ;
    rdfs:comment 'Indicates whether the referring player has claimed the reward associated with this eligible referral. True = reward claimed; False = reward not yet claimed. Used to track reward redemption rates and outstanding reward liabilities.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rewardClaimedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reward Claimed Timestamp' ;
    rdfs:comment 'The date and time when the referring player claimed or was granted the referral reward. Null if reward has not been claimed. Used for reward fulfillment SLA tracking and financial accrual timing.' ;
    rdfs:domain ind:ViralReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rewardCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Reward Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the reward value when the reward is denominated in fiat currency (e.g., USD, EUR, GBP). Null or a game-specific virtual currency code (e.g., GEMS, COINS) for virtual currency rewards. Required for financial reporting and PCI DSS compliance.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Reward Eligible Flag' ;
    rdfs:comment 'Indicates whether this referral event qualifies for a reward payout to the referring player based on campaign eligibility rules (e.g., referred player must be a new account, must convert within the campaign window). True = eligible; False = not eligible.' ;
    rdfs:domain ind:ViralReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rewardType rdf:type rdf:Property ;
    rdfs:label 'Reward Type' ;
    rdfs:comment 'The category of reward granted to the referring player upon successful referral conversion. Drives reward fulfillment routing and in-game economy impact analysis. [ENUM-REF-CANDIDATE: virtual_currency|premium_item|dlc_unlock|subscription_days|real_money — promote to reference product if reward types expand]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardValue rdf:type rdf:Property ;
    rdfs:label 'Reward Value' ;
    rdfs:comment 'The quantity or monetary value of the reward granted for this referral. For virtual currency rewards, this is the number of in-game currency units. For real-money rewards, this is the fiat amount in the campaign\'s base currency. Used for referral program cost accounting and ROI measurement.' ;
    rdfs:domain ind:ViralReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sent Timestamp' ;
    rdfs:comment 'The date and time when the referral invite was dispatched by the referring player. BUSINESS_EVENT_TIMESTAMP — the principal real-world event time marking the start of the referral lifecycle. Stored in ISO 8601 format with timezone offset.' ;
    rdfs:domain ind:ViralReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:utmCampaign rdf:type rdf:Property ;
    rdfs:label 'Utm Campaign' ;
    rdfs:comment 'The UTM campaign parameter captured from the referral tracking URL, identifying the specific campaign name or code. Enables campaign-level referral conversion and ROI analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmMedium rdf:type rdf:Property ;
    rdfs:label 'Utm Medium' ;
    rdfs:comment 'The UTM medium parameter captured from the referral tracking URL, identifying the marketing medium (e.g., social, referral, in-game). Complements utm_source for multi-dimensional attribution analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmSource rdf:type rdf:Property ;
    rdfs:label 'Utm Source' ;
    rdfs:comment 'The UTM source parameter captured from the referral tracking URL, identifying the originating platform or network (e.g., twitter, discord, facebook). Used for marketing attribution and channel-level referral performance reporting.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingAuthorityId rdf:type rdf:Property ;
    rdfs:label 'Rating Authority Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_authority. Business justification: Age rating certificates are issued by regulatory authorities (ESRB, PEGI, etc.). Currently has rating_authority_code (STRING) but should FK to regulatory_authority master table for normalization and t' ;
    rdfs:domain ind:AgeRatingCert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryAuthority .

ind:certificateDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Certificate Document Url' ;
    rdfs:comment 'URL or storage path to the official certificate document or PDF issued by the rating authority.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'The official certificate number or identifier issued by the rating authority upon approval.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateStatus rdf:type rdf:Property ;
    rdfs:label 'Certificate Status' ;
    rdfs:comment 'Current lifecycle status of the age rating certificate. Pending: submitted but not yet approved; Approved: approved but not yet active; Active: currently valid; Expired: validity period has ended; Revoked: withdrawn by authority; Suspended: temporarily invalid.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentDescriptorDrugs rdf:type rdf:Property ;
    rdfs:label 'Content Descriptor Drugs' ;
    rdfs:comment 'Flag indicating whether the certificate includes a content descriptor for drug or alcohol use or references.' ;
    rdfs:domain ind:AgeRatingCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentDescriptorFear rdf:type rdf:Property ;
    rdfs:label 'Content Descriptor Fear' ;
    rdfs:comment 'Flag indicating whether the certificate includes a content descriptor for fear, horror, or frightening content.' ;
    rdfs:domain ind:AgeRatingCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentDescriptorGambling rdf:type rdf:Property ;
    rdfs:label 'Content Descriptor Gambling' ;
    rdfs:comment 'Flag indicating whether the certificate includes a content descriptor for gambling, simulated gambling, or loot box mechanics.' ;
    rdfs:domain ind:AgeRatingCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentDescriptorLanguage rdf:type rdf:Property ;
    rdfs:label 'Content Descriptor Language' ;
    rdfs:comment 'Flag indicating whether the certificate includes a content descriptor for strong language or profanity.' ;
    rdfs:domain ind:AgeRatingCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentDescriptorSexual rdf:type rdf:Property ;
    rdfs:label 'Content Descriptor Sexual' ;
    rdfs:comment 'Flag indicating whether the certificate includes a content descriptor for sexual content, nudity, or sexual themes.' ;
    rdfs:domain ind:AgeRatingCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentDescriptorViolence rdf:type rdf:Property ;
    rdfs:label 'Content Descriptor Violence' ;
    rdfs:comment 'Flag indicating whether the certificate includes a content descriptor for violence (e.g., blood, gore, intense violence).' ;
    rdfs:domain ind:AgeRatingCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'The date from which the age rating certificate becomes valid and the game may be published under this rating in the applicable territory.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interactiveElementLocationSharing rdf:type rdf:Property ;
    rdfs:label 'Interactive Element Location Sharing' ;
    rdfs:comment 'Flag indicating whether the certificate notes that the game shares user location data.' ;
    rdfs:domain ind:AgeRatingCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interactiveElementOnline rdf:type rdf:Property ;
    rdfs:label 'Interactive Element Online' ;
    rdfs:comment 'Flag indicating whether the certificate notes that the game includes online interaction with other players (e.g., Users Interact, Online Interactions Not Rated by the ESRB).' ;
    rdfs:domain ind:AgeRatingCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interactiveElementPurchases rdf:type rdf:Property ;
    rdfs:label 'Interactive Element Purchases' ;
    rdfs:comment 'Flag indicating whether the certificate notes that the game includes in-game purchases, microtransactions (MTX), or in-app purchases (IAP).' ;
    rdfs:domain ind:AgeRatingCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interactiveElementUgc rdf:type rdf:Property ;
    rdfs:label 'Interactive Element Ugc' ;
    rdfs:comment 'Flag indicating whether the certificate notes that the game includes user-generated content (UGC) that may not be rated.' ;
    rdfs:domain ind:AgeRatingCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lootBoxDisclosureRequired rdf:type rdf:Property ;
    rdfs:label 'Loot Box Disclosure Required' ;
    rdfs:comment 'Flag indicating whether the game is required to disclose loot box probabilities or mechanics under the rating authoritys or jurisdictional regulations.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lootBoxProbabilityDisclosed rdf:type rdf:Property ;
    rdfs:label 'Loot Box Probability Disclosed' ;
    rdfs:comment 'Flag indicating whether loot box probabilities have been disclosed to the rating authority and are included in the certificate documentation.' ;
    rdfs:domain ind:AgeRatingCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ratingCategory rdf:type rdf:Property ;
    rdfs:label 'Rating Category' ;
    rdfs:comment 'The age rating category assigned by the authority (e.g., E, E10+, T, M, AO for ESRB; PEGI 3, PEGI 7, PEGI 12, PEGI 16, PEGI 18 for PEGI; equivalent categories for other authorities). [ENUM-REF-CANDIDATE: E|E10+|T|M|AO|PEGI_3|PEGI_7|PEGI_12|PEGI_16|PEGI_18|USK_0|USK_6|USK_12|USK_16|USK_18|CERO_A|CERO_B|CERO_C|CERO_D|CERO_Z|GRAC_ALL|GRAC_12|GRAC_15|GRAC_18|ACB_G|ACB_PG|ACB_M|ACB_MA15|ACB_R18|ACB_RC — promote to reference product]' ;
    rdfs:domain ind:AgeRatingCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingSummary rdf:type rdf:Property ;
    rdfs:label 'Rating Summary' ;
    rdfs:comment 'A textual summary provided by the rating authority describing the content and reasons for the assigned rating category.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'The date on which the certificate was renewed or re-certified, if applicable. Nullable for certificates that do not require renewal.' ;
    rdfs:domain ind:AgeRatingCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revocationDate rdf:type rdf:Property ;
    rdfs:label 'Revocation Date' ;
    rdfs:comment 'The date on which the certificate was revoked by the rating authority, if applicable. Nullable for active certificates.' ;
    rdfs:domain ind:AgeRatingCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revocationReason rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason' ;
    rdfs:comment 'The reason provided by the rating authority for revoking the certificate (e.g., content violation, misrepresentation, regulatory non-compliance).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'The date on which the game was submitted to the rating authority for certification review.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Submission Reference Number' ;
    rdfs:comment 'The unique reference or tracking number assigned by the rating authority when the game was submitted for certification.' ;
    rdfs:domain ind:AgeRatingCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ageRequirement rdf:type rdf:Property ;
    rdfs:label 'Age Requirement' ;
    rdfs:comment 'The minimum age required for the player to access the game or feature without parental consent, as determined by the jurisdiction and game rating (e.g., 13 for COPPA in USA, 16 for GDPR in EU, 18 for M-rated games).' ;
    rdfs:domain ind:AgeVerificationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditLogReference rdf:type rdf:Property ;
    rdfs:label 'Audit Log Reference' ;
    rdfs:comment 'A reference identifier linking this age verification event to the broader audit log or compliance tracking system for regulatory reporting and audit trail purposes.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentGiven rdf:type rdf:Property ;
    rdfs:label 'Consent Given' ;
    rdfs:comment 'Boolean flag indicating whether the player (or parent/guardian) provided explicit consent for data processing as part of the age verification process. True if consent was given, False otherwise.' ;
    rdfs:domain ind:AgeVerificationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'The player\'s date of birth as provided during the verification process, in yyyy-MM-dd format. Restricted PII. Nullable if verification method did not require DOB entry.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:failureReason rdf:type rdf:Property ;
    rdfs:label 'Failure Reason' ;
    rdfs:comment 'A textual description of why the age verification failed, if applicable (e.g., \'Player under minimum age\', \'Invalid date of birth\', \'Third-party service error\', \'Parental consent not obtained\'). Nullable if verification passed.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gameRating rdf:type rdf:Property ;
    rdfs:label 'Game Rating' ;
    rdfs:comment 'The age rating of the game title that triggered the verification, using ESRB or PEGI classification codes (e.g., E, E10+, T, M, AO, RP for ESRB; PEGI 3, 7, 12, 16, 18 for PEGI). Determines age gate thresholds.' ;
    rdfs:domain ind:AgeVerificationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentalConsentToken rdf:type rdf:Property ;
    rdfs:label 'Parental Consent Token' ;
    rdfs:comment 'A unique token or reference identifier linking to the parental consent record, if parental consent was required and obtained. Nullable if not applicable.' ;
    rdfs:domain ind:AgeVerificationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerDeclaredAge rdf:type rdf:Property ;
    rdfs:label 'Player Declared Age' ;
    rdfs:comment 'The age declared by the player at the time of verification, calculated from the date of birth provided or stated directly. Nullable if age was not explicitly declared.' ;
    rdfs:domain ind:AgeVerificationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retryCount rdf:type rdf:Property ;
    rdfs:label 'Retry Count' ;
    rdfs:comment 'The number of times the player has attempted age verification for this specific trigger or session. Used to detect fraud or user experience issues.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thirdPartyProvider rdf:type rdf:Property ;
    rdfs:label 'Third Party Provider' ;
    rdfs:comment 'The name of the third-party age verification service provider used, if applicable (e.g., Yoti, Jumio, Veriff). Nullable if verification was performed in-house.' ;
    rdfs:domain ind:AgeVerificationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Third Party Transaction Reference' ;
    rdfs:comment 'The transaction or session identifier provided by the third-party age verification service for audit and reconciliation purposes. Nullable if not applicable.' ;
    rdfs:domain ind:AgeVerificationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationChannel rdf:type rdf:Property ;
    rdfs:label 'Verification Channel' ;
    rdfs:comment 'The channel or interface through which the age verification was performed (e.g., in-game, web portal, mobile app, customer support, email, SMS).' ;
    rdfs:domain ind:AgeVerificationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Verification Expiry Date' ;
    rdfs:comment 'The date on which the age verification expires and must be re-verified, in yyyy-MM-dd format. Nullable if verification does not expire.' ;
    rdfs:domain ind:AgeVerificationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationIpAddress rdf:type rdf:Property ;
    rdfs:label 'Verification Ip Address' ;
    rdfs:comment 'The IP address from which the age verification event was initiated. Used for fraud detection and jurisdiction determination. Confidential PII in some jurisdictions.' ;
    rdfs:domain ind:AgeVerificationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationOutcome rdf:type rdf:Property ;
    rdfs:label 'Verification Outcome' ;
    rdfs:comment 'The result of the age verification attempt. Passed indicates the player met age requirements; failed indicates they did not; pending_parental_consent indicates parental approval is required; under_review indicates manual review is in progress; expired indicates a previously valid verification has lapsed.' ;
    rdfs:domain ind:AgeVerificationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationTrigger rdf:type rdf:Property ;
    rdfs:label 'Verification Trigger' ;
    rdfs:comment 'The event or action that triggered the age verification requirement. Examples include account creation, game launch, in-game purchase attempt, loot box access, mature content access, chat feature access, UGC submission, or periodic revalidation. [ENUM-REF-CANDIDATE: account_creation|game_launch|in_game_purchase|loot_box_access|mature_content_access|chat_feature_access|ugc_submission|periodic_revalidation — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AgeVerificationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditEngagementId rdf:type rdf:Property ;
    rdfs:label 'Audit Engagement Id' ;
    rdfs:comment 'Unique identifier for the audit engagement record. Primary key.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditEngagement .

ind:auditScheduleId rdf:type rdf:Property ;
    rdfs:label 'Audit Schedule Id' ;
    rdfs:comment 'Reference to the scheduled audit plan that triggered this engagement. Links to the audit schedule master record.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditSchedule .

ind:regulatoryAuthorityId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_authority. Business justification: Audit engagement has regulatory_authority (STRING) field identifying the authority being audited for. Should FK to regulatory_authority master table for normalization.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryAuthority .

ind:auditCostAmount rdf:type rdf:Property ;
    rdfs:label 'Audit Cost Amount' ;
    rdfs:comment 'Total cost incurred for the audit engagement, including auditor fees, travel expenses, and internal resource costs. Expressed in the company\'s reporting currency.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditEndDate rdf:type rdf:Property ;
    rdfs:label 'Audit End Date' ;
    rdfs:comment 'Date when the audit fieldwork and evidence collection activities concluded. Null if audit is still in progress.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditFirmName rdf:type rdf:Property ;
    rdfs:label 'Audit Firm Name' ;
    rdfs:comment 'Name of the auditing organization or firm conducting the engagement (e.g., Big Four firm, specialized compliance consultancy, internal audit department, regulatory body).' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditOpinion rdf:type rdf:Property ;
    rdfs:label 'Audit Opinion' ;
    rdfs:comment 'Overall auditor conclusion on compliance status: unqualified (clean, no material issues), qualified (generally compliant with noted exceptions), adverse (material non-compliance), disclaimer (insufficient evidence to form opinion).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'Primary compliance domain or regulatory area under examination in this engagement (e.g., GDPR compliance, COPPA compliance, loot box probability disclosure, age rating certification, PCI DSS payment security, data retention policies, platform certification requirements). [ENUM-REF-CANDIDATE: gdpr_compliance|coppa_compliance|loot_box_disclosure|age_rating|payment_security|data_retention|platform_certification|esrb_rating|pegi_rating|financial_controls|revenue_recognition|mtx_fairness|player_data_privacy — promote to reference product]' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStartDate rdf:type rdf:Property ;
    rdfs:label 'Audit Start Date' ;
    rdfs:comment 'Date when the audit fieldwork and evidence collection activities commenced.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current lifecycle state of the audit engagement: scheduled (planned but not started), in_progress (active fieldwork), fieldwork_complete (evidence gathering done), report_draft (auditor preparing findings), management_review (company reviewing draft), finalized (report issued), closed (all follow-up complete). [ENUM-REF-CANDIDATE: scheduled|in_progress|fieldwork_complete|report_draft|management_review|finalized|closed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTeamSize rdf:type rdf:Property ;
    rdfs:label 'Audit Team Size' ;
    rdfs:comment 'Number of auditors and specialists assigned to the engagement team.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:boardPresentationDate rdf:type rdf:Property ;
    rdfs:label 'Board Presentation Date' ;
    rdfs:comment 'Date when audit results were presented to the board of directors or audit committee for governance oversight. Null if board presentation not required.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:criticalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Findings Count' ;
    rdfs:comment 'Number of critical or high-severity findings that represent material compliance failures or significant risk exposures requiring immediate remediation.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:engagementNumber rdf:type rdf:Property ;
    rdfs:label 'Engagement Number' ;
    rdfs:comment 'Externally-known unique business identifier for the audit engagement, formatted as AE-YYYY-NNNNNN for tracking and reporting purposes.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementType rdf:type rdf:Property ;
    rdfs:label 'Engagement Type' ;
    rdfs:comment 'Classification of the audit engagement by origin and purpose: internal (company-initiated), external (third-party), regulatory (mandated by authority), certification (for standards compliance), follow-up (remediation verification), or special (ad-hoc investigation).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceItemsReviewed rdf:type rdf:Property ;
    rdfs:label 'Evidence Items Reviewed' ;
    rdfs:comment 'Total count of documents, records, system logs, and other evidence items examined during the audit fieldwork.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fieldworkDurationDays rdf:type rdf:Property ;
    rdfs:label 'Fieldwork Duration Days' ;
    rdfs:comment 'Total number of calendar days spent on active audit fieldwork and evidence gathering, calculated from start to end date.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finalReportDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Final Report Document Reference' ;
    rdfs:comment 'Document management system reference, URI, or file path to the final signed audit report document for retrieval and archival purposes.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingsCount rdf:type rdf:Property ;
    rdfs:label 'Findings Count' ;
    rdfs:comment 'Total number of audit findings, observations, or non-conformities identified during the engagement across all severity levels.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:followUpDeadline rdf:type rdf:Property ;
    rdfs:label 'Follow Up Deadline' ;
    rdfs:comment 'Target date by which follow-up audit or remediation verification must be completed. Null if no follow-up is required.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required Flag' ;
    rdfs:comment 'Boolean indicator of whether a follow-up audit or verification engagement is required to confirm remediation of findings. True if follow-up is mandated, False if no follow-up needed.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interviewsConducted rdf:type rdf:Property ;
    rdfs:label 'Interviews Conducted' ;
    rdfs:comment 'Number of formal interviews or meetings conducted with personnel during the audit engagement.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadAuditorName rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Name' ;
    rdfs:comment 'Full name of the principal auditor responsible for conducting the engagement and signing the final audit opinion.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Major Findings Count' ;
    rdfs:comment 'Number of major or medium-severity findings that represent notable compliance gaps or control weaknesses requiring timely remediation.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managementResponseDate rdf:type rdf:Property ;
    rdfs:label 'Management Response Date' ;
    rdfs:comment 'Date when management formally submitted their response to the audit findings and recommendations.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:managementResponseSummary rdf:type rdf:Property ;
    rdfs:label 'Management Response Summary' ;
    rdfs:comment 'Executive summary of management\'s formal response to audit findings, including acceptance, dispute, or planned corrective actions.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Minor Findings Count' ;
    rdfs:comment 'Number of minor or low-severity findings that represent opportunities for improvement or minor procedural deviations.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:opinionRationale rdf:type rdf:Property ;
    rdfs:label 'Opinion Rationale' ;
    rdfs:comment 'Textual explanation of the basis for the audit opinion, summarizing key evidence, findings, and reasoning that led to the auditor\'s conclusion.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Record Source System' ;
    rdfs:comment 'Name of the operational system or compliance management platform from which this audit engagement record originated (e.g., Jira, SAP GRC, custom compliance portal).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFilingDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Date' ;
    rdfs:comment 'Date when audit results were submitted to the regulatory authority. Null if no regulatory filing required.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryFilingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Required Flag' ;
    rdfs:comment 'Boolean indicator of whether audit results must be filed with or reported to a regulatory authority. True if regulatory filing is mandated, False otherwise.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Report Issued Date' ;
    rdfs:comment 'Date when the final audit report was formally issued to management and stakeholders.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scopeNarrative rdf:type rdf:Property ;
    rdfs:label 'Scope Narrative' ;
    rdfs:comment 'Detailed textual description of the audit boundaries, including specific game titles, territories, business processes, systems, and time periods examined during the engagement.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemsTested rdf:type rdf:Property ;
    rdfs:label 'Systems Tested' ;
    rdfs:comment 'Number of IT systems, platforms, or applications subjected to audit testing and control evaluation.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Auditor Employee Id' ;
    rdfs:comment 'Reference to the auditor or audit team member who identified and documented this finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:previousFindingAuditFindingId rdf:type rdf:Property ;
    rdfs:label 'Previous Finding Audit Finding Id' ;
    rdfs:comment 'Reference to the previous audit finding record if this is a recurrence, enabling trend analysis and escalation.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditFinding .

ind:primaryAuditEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Audit Employee Id' ;
    rdfs:comment 'Reference to the employee or team assigned responsibility for implementing the remediation action and closing the finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:closureEvidence rdf:type rdf:Property ;
    rdfs:label 'Closure Evidence' ;
    rdfs:comment 'Description or reference to the evidence provided to demonstrate that the finding has been remediated (e.g., updated policy document, system configuration screenshot, training completion records).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'Date when the finding was escalated to executive leadership or the board.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialImpactEstimate rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Estimate' ;
    rdfs:comment 'Estimated financial impact or potential loss associated with the finding if not remediated, expressed in the company\'s reporting currency.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:findingCategory rdf:type rdf:Property ;
    rdfs:label 'Finding Category' ;
    rdfs:comment 'Severity classification of the audit finding indicating the level of risk or non-conformance: critical (immediate action required), major (significant non-conformance), minor (isolated issue), observation (improvement opportunity).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingDescription rdf:type rdf:Property ;
    rdfs:label 'Finding Description' ;
    rdfs:comment 'Detailed narrative description of the audit finding, including the specific non-conformance, observation, or control deficiency identified during the audit.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingNumber rdf:type rdf:Property ;
    rdfs:label 'Finding Number' ;
    rdfs:comment 'Business identifier for the finding within the audit engagement, typically a sequential or hierarchical code (e.g., AUD-2024-001-F01).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingTitle rdf:type rdf:Property ;
    rdfs:label 'Finding Title' ;
    rdfs:comment 'Concise summary title of the audit finding for quick identification and reporting purposes.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identified Date' ;
    rdfs:comment 'Date when the finding was first identified during the audit engagement.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:managementResponse rdf:type rdf:Property ;
    rdfs:label 'Management Response' ;
    rdfs:comment 'Formal response from management acknowledging the finding and committing to remediation actions, including any alternative approaches or risk acceptance decisions.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedRemediationAction rdf:type rdf:Property ;
    rdfs:label 'Recommended Remediation Action' ;
    rdfs:comment 'Auditor\'s recommended corrective or preventive action to address the finding and prevent recurrence.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceFlag rdf:type rdf:Property ;
    rdfs:label 'Recurrence Flag' ;
    rdfs:comment 'Indicates whether this finding is a recurrence of a previously identified and closed finding, signaling potential systemic control weakness.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryArea rdf:type rdf:Property ;
    rdfs:label 'Regulatory Area' ;
    rdfs:comment 'The regulatory domain or compliance framework to which this finding relates, such as GDPR (General Data Protection Regulation), COPPA (Children\'s Online Privacy Protection Act), loot box disclosure requirements, age rating certification (ESRB, PEGI), financial reporting standards, PCI DSS (Payment Card Industry Data Security Standard), or platform-specific compliance requirements. [ENUM-REF-CANDIDATE: gdpr|coppa|loot_box|age_rating|financial_reporting|pci_dss|esrb|pegi|data_protection|consumer_protection|advertising_standards|platform_compliance — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Completion Date' ;
    rdfs:comment 'Actual date when the remediation action was completed by the remediation owner, prior to verification.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationDueDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Due Date' ;
    rdfs:comment 'Target date by which the remediation action must be completed and the finding closed, based on severity and regulatory requirements.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationStatus rdf:type rdf:Property ;
    rdfs:label 'Remediation Status' ;
    rdfs:comment 'Current lifecycle status of the remediation effort: open (not started), in_progress (work underway), pending_verification (awaiting audit review), closed (remediation verified and accepted), overdue (past due date), deferred (postponed with justification).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Overall risk assessment of the finding based on likelihood and impact, used for prioritization and executive reporting.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysis rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis' ;
    rdfs:comment 'Analysis of the underlying root cause(s) that led to the finding, identifying systemic issues, process gaps, or control weaknesses.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatingPolicyId rdf:type rdf:Property ;
    rdfs:label 'Mandating Policy Id' ;
    rdfs:comment 'Foreign key linking to compliance.policy. Business justification: Audit schedules may be driven by internal policy requirements (in addition to regulatory obligations which are already FK\'d). Should FK to the policy that mandates the audit.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether executive or board-level approval is required before this audit can proceed. True for high-risk or high-cost audits.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'The date when the audit schedule received formal approval. Null if approval is not required or still pending.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditCriteria rdf:type rdf:Property ;
    rdfs:label 'Audit Criteria' ;
    rdfs:comment 'The set of policies, procedures, standards, or regulations against which the audit will evaluate compliance (e.g., \'GDPR Articles 12-22\', \'ESRB Marketing Guidelines\').' ;
    rdfs:domain ind:AuditSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditLeadContactEmail rdf:type rdf:Property ;
    rdfs:label 'Audit Lead Contact Email' ;
    rdfs:comment 'Email address of the audit lead contact for coordination and communication purposes.' ;
    rdfs:domain ind:AuditSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditLeadContactName rdf:type rdf:Property ;
    rdfs:label 'Audit Lead Contact Name' ;
    rdfs:comment 'Name of the primary contact person leading the audit engagement on behalf of the auditor.' ;
    rdfs:domain ind:AuditSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditName rdf:type rdf:Property ;
    rdfs:label 'Audit Name' ;
    rdfs:comment 'The official name or title of the scheduled audit (e.g., \'Q1 2024 GDPR Compliance Audit\', \'Annual Loot Box Disclosure Review\').' ;
    rdfs:domain ind:AuditSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditObjectives rdf:type rdf:Property ;
    rdfs:label 'Audit Objectives' ;
    rdfs:comment 'A detailed description of the specific objectives and goals of this audit engagement, defining what the audit aims to verify or assess.' ;
    rdfs:domain ind:AuditSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Classification of the audit by its nature and origin. Determines the audit framework and stakeholders involved.' ;
    rdfs:domain ind:AuditSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorType rdf:type rdf:Property ;
    rdfs:label 'Auditor Type' ;
    rdfs:comment 'Classification of the auditor as internal staff, external regulatory body, or third-party independent auditor.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAllocated rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated' ;
    rdfs:comment 'The financial budget allocated for this audit engagement, covering auditor fees, travel, and related expenses. Stored in the organization\'s base currency.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedDurationDays rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Days' ;
    rdfs:comment 'The estimated number of business days required to complete the audit engagement, from start to final report delivery.' ;
    rdfs:domain ind:AuditSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:internalCoordinatorEmail rdf:type rdf:Property ;
    rdfs:label 'Internal Coordinator Email' ;
    rdfs:comment 'Email address of the internal coordinator for audit scheduling and document exchange.' ;
    rdfs:domain ind:AuditSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalCoordinatorName rdf:type rdf:Property ;
    rdfs:label 'Internal Coordinator Name' ;
    rdfs:comment 'Name of the internal compliance or legal team member responsible for coordinating the audit on behalf of the organization.' ;
    rdfs:domain ind:AuditSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastOccurrenceDate rdf:type rdf:Property ;
    rdfs:label 'Last Occurrence Date' ;
    rdfs:comment 'For recurring audits, the date when the most recent occurrence of this audit was completed. Null for first-time audits.' ;
    rdfs:domain ind:AuditSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextOccurrenceDate rdf:type rdf:Property ;
    rdfs:label 'Next Occurrence Date' ;
    rdfs:comment 'For recurring audits, the calculated date when the next occurrence of this audit is scheduled, based on the recurrence_pattern.' ;
    rdfs:domain ind:AuditSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationSentDate rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Date' ;
    rdfs:comment 'The date when formal audit notification was sent to relevant stakeholders and auditees, initiating the audit process.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preparationStartDate rdf:type rdf:Property ;
    rdfs:label 'Preparation Start Date' ;
    rdfs:comment 'The date when internal audit preparation activities (document gathering, pre-audit reviews) are scheduled to begin, typically preceding the scheduled_start_date.' ;
    rdfs:domain ind:AuditSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rescheduledFromDate rdf:type rdf:Property ;
    rdfs:label 'Rescheduled From Date' ;
    rdfs:comment 'The original scheduled start date, if this audit was rescheduled. Null for audits that have not been rescheduled.' ;
    rdfs:domain ind:AuditSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsibleAuditor rdf:type rdf:Property ;
    rdfs:label 'Responsible Auditor' ;
    rdfs:comment 'Name of the internal team or external audit firm responsible for conducting the audit (e.g., \'Internal Compliance Team\', \'Deloitte LLP\', \'KPMG\').' ;
    rdfs:domain ind:AuditSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'The assessed risk level associated with the compliance area being audited. Determines audit priority and resource allocation.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the audit schedule. Tracks the audit from planning through execution to completion. [ENUM-REF-CANDIDATE: draft|scheduled|in_progress|completed|cancelled|postponed|rescheduled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AuditSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEndDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Date' ;
    rdfs:comment 'The planned date when the audit engagement is scheduled to conclude. Defines the audit window and reporting deadline.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'The planned date when the audit engagement is scheduled to begin. Used for audit calendar planning and resource allocation.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedPlayerAccountId rdf:type rdf:Property ;
    rdfs:label 'Affected Player Account Id' ;
    rdfs:comment 'Foreign key linking to player.player_account. Business justification: Many compliance incidents involve specific player accounts (unauthorized account access, data breach affecting player, consent violation). Essential for player notification obligations (GDPR Article 3' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerAccount .

ind:dataSubjectRequestId rdf:type rdf:Property ;
    rdfs:label 'Data Subject Request Id' ;
    rdfs:comment 'Foreign key linking to compliance.data_subject_request. Business justification: Compliance incidents may be triggered by data subject requests (e.g., DSR reveals data breach, DSR cannot be fulfilled within SLA). Should FK to the originating data_subject_request when incident is D' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DataSubjectRequest .

ind:primaryComplianceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Compliance Employee Id' ;
    rdfs:comment 'Identifier of the compliance officer or legal team member responsible for managing the incident investigation and resolution. Links to internal workforce user master data.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualFinancialImpact rdf:type rdf:Property ;
    rdfs:label 'Actual Financial Impact' ;
    rdfs:comment 'Actual realized financial cost of the compliance incident after resolution, including confirmed regulatory fines, remediation expenses, legal settlements, and quantified business losses. Expressed in USD.' ;
    rdfs:domain ind:ComplianceIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affectedJurisdictions rdf:type rdf:Property ;
    rdfs:label 'Affected Jurisdictions' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes representing territories where affected players reside. Determines which regulatory authorities must be notified and which compliance frameworks apply.' ;
    rdfs:domain ind:ComplianceIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedPlayerCount rdf:type rdf:Property ;
    rdfs:label 'Affected Player Count' ;
    rdfs:comment 'Total number of players whose data or rights were impacted by the compliance incident. Critical metric for determining regulatory notification obligations and assessing incident severity.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditTrail rdf:type rdf:Property ;
    rdfs:label 'Audit Trail' ;
    rdfs:comment 'Chronological log of all actions taken during the incident lifecycle including investigation steps, communications, decisions, and status changes. Provides complete audit trail for regulatory review.' ;
    rdfs:domain ind:ComplianceIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentActionsTaken rdf:type rdf:Property ;
    rdfs:label 'Containment Actions Taken' ;
    rdfs:comment 'Description of immediate actions taken to contain the compliance incident and prevent further harm. Includes technical remediation, player notifications, service suspensions, or data access restrictions implemented as first response.' ;
    rdfs:domain ind:ComplianceIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCategoriesAffected rdf:type rdf:Property ;
    rdfs:label 'Data Categories Affected' ;
    rdfs:comment 'Comma-separated list of personal data categories impacted by the incident such as player names, email addresses, payment information, gameplay data, or chat logs. Used for assessing breach severity and notification requirements.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryChannel rdf:type rdf:Property ;
    rdfs:label 'Discovery Channel' ;
    rdfs:comment 'Source or method through which the compliance incident was detected. Identifies whether the incident was found proactively through internal controls or reactively through external notification.' ;
    rdfs:domain ind:ComplianceIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryDate rdf:type rdf:Property ;
    rdfs:label 'Discovery Date' ;
    rdfs:comment 'Date when the compliance incident was first identified or became known to the organization. Critical for calculating regulatory notification deadlines such as GDPR 72-hour breach notification requirement.' ;
    rdfs:domain ind:ComplianceIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discoveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Discovery Timestamp' ;
    rdfs:comment 'Precise date and time when the compliance incident was first identified. Used for accurate timeline reconstruction and regulatory reporting where hour-level precision is required.' ;
    rdfs:domain ind:ComplianceIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'Organizational level to which the compliance incident has been escalated. Critical and high-severity incidents typically require executive or board-level awareness and oversight.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedFinancialImpact rdf:type rdf:Property ;
    rdfs:label 'Estimated Financial Impact' ;
    rdfs:comment 'Estimated total financial cost of the compliance incident including potential regulatory fines, remediation costs, legal fees, and business disruption. Expressed in USD for consistent reporting.' ;
    rdfs:domain ind:ComplianceIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalCounselEngagedFlag rdf:type rdf:Property ;
    rdfs:label 'External Counsel Engaged Flag' ;
    rdfs:comment 'Indicates whether external legal counsel has been retained to advise on the compliance incident. True for incidents with significant legal exposure or complex regulatory implications.' ;
    rdfs:domain ind:ComplianceIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incidentDescription rdf:type rdf:Property ;
    rdfs:label 'Incident Description' ;
    rdfs:comment 'Detailed narrative description of the compliance incident, including what occurred, how it was discovered, and the circumstances surrounding the breach or violation. Used for internal investigation and regulatory reporting.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Number' ;
    rdfs:comment 'Externally-visible unique business identifier for the compliance incident, used for tracking and reporting to regulators and internal stakeholders.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentStatus rdf:type rdf:Property ;
    rdfs:label 'Incident Status' ;
    rdfs:comment 'Current lifecycle state of the compliance incident. Tracks progression from discovery through investigation, containment, resolution, and closure.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentType rdf:type rdf:Property ;
    rdfs:label 'Incident Type' ;
    rdfs:comment 'Classification of the compliance incident by regulatory domain. Identifies the nature of the breach or violation across all regulatory frameworks applicable to gaming operations.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceClaimFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Filed Flag' ;
    rdfs:comment 'Indicates whether a claim has been filed with cyber liability or errors and omissions insurance for the compliance incident. True when financial impact exceeds deductible thresholds.' ;
    rdfs:domain ind:ComplianceIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Number' ;
    rdfs:comment 'Reference number assigned by the insurance carrier for the compliance incident claim. Used for tracking insurance recovery and coordinating with carrier investigation.' ;
    rdfs:domain ind:ComplianceIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lessonsLearned rdf:type rdf:Property ;
    rdfs:label 'Lessons Learned' ;
    rdfs:comment 'Summary of key insights and organizational learnings from the compliance incident. Captures what went well, what could be improved, and recommendations for preventing similar incidents in the future.' ;
    rdfs:domain ind:ComplianceIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationDeadline rdf:type rdf:Property ;
    rdfs:label 'Notification Deadline' ;
    rdfs:comment 'Date and time by which regulatory notification must be completed. Calculated based on discovery timestamp and applicable regulatory framework requirements such as GDPR 72-hour breach notification rule.' ;
    rdfs:domain ind:ComplianceIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:playerNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Player Notification Required Flag' ;
    rdfs:comment 'Indicates whether affected players must be directly notified of the compliance incident. True when the incident poses high risk to player rights and freedoms under GDPR or when COPPA parental notification is required.' ;
    rdfs:domain ind:ComplianceIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:playerNotificationSentDate rdf:type rdf:Property ;
    rdfs:label 'Player Notification Sent Date' ;
    rdfs:comment 'Date when notification communications were sent to affected players. Documents compliance with player notification obligations under data protection regulations.' ;
    rdfs:domain ind:ComplianceIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatorReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulator Reference Number' ;
    rdfs:comment 'Case or reference number assigned by the regulatory authority upon receipt of the incident notification. Used for tracking regulatory correspondence and investigation status.' ;
    rdfs:domain ind:ComplianceIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required Flag' ;
    rdfs:comment 'Indicates whether the compliance incident meets the threshold for mandatory notification to regulatory authorities. True for incidents requiring GDPR breach notification, COPPA violation reporting, or other jurisdictional reporting obligations.' ;
    rdfs:domain ind:ComplianceIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationPlan rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan' ;
    rdfs:comment 'Detailed plan for addressing the compliance incident and preventing recurrence. Includes corrective actions, process improvements, system enhancements, and training initiatives to be implemented.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityRating rdf:type rdf:Property ;
    rdfs:label 'Severity Rating' ;
    rdfs:comment 'Business impact severity classification of the compliance incident. Critical incidents require immediate executive notification and regulatory reporting; low severity incidents may be handled through standard remediation processes.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDirectiveId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Directive Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_directive. Business justification: Internal policies are often created in response to regulatory directives. Should FK to the regulatory_directive that mandates the policy. Currently has regulatory_framework_reference (STRING); should ' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryDirective .

ind:applicableBusinessUnits rdf:type rdf:Property ;
    rdfs:label 'Applicable Business Units' ;
    rdfs:comment 'Comma-separated list or description of business units, studios, or divisions to which this policy applies (e.g., All Studios, Publishing Division, Live Ops, Esports).' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableGameTitles rdf:type rdf:Property ;
    rdfs:label 'Applicable Game Titles' ;
    rdfs:comment 'Comma-separated list of specific game titles or franchises to which this policy applies, or \'All Titles\' if universally applicable.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicablePlatforms rdf:type rdf:Property ;
    rdfs:label 'Applicable Platforms' ;
    rdfs:comment 'Comma-separated list of gaming platforms to which this policy applies (e.g., Console, PC, Mobile, VR, All Platforms).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'Governing body or executive role with formal authority to approve or ratify the policy.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency Months' ;
    rdfs:comment 'Frequency in months at which compliance with this policy is formally audited by internal audit or compliance teams.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataRetentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Data Retention Period Days' ;
    rdfs:comment 'Number of days that data subject to this policy must be retained before eligible for deletion. Null if no specific retention period applies.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'URL link to the authoritative policy document stored in the document management system or intranet.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementMechanism rdf:type rdf:Property ;
    rdfs:label 'Enforcement Mechanism' ;
    rdfs:comment 'Description of how the policy is enforced internally (e.g., automated controls, manual audits, training requirements, disciplinary procedures).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedImplementationCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Implementation Cost' ;
    rdfs:comment 'Estimated total cost in USD to implement the policy, including technology, process changes, training, and compliance infrastructure. Business-confidential financial data.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implementationDeadline rdf:type rdf:Property ;
    rdfs:label 'Implementation Deadline' ;
    rdfs:comment 'Target date by which the policy must be fully implemented and operational. May be driven by regulatory deadlines or internal governance timelines.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementationStatus rdf:type rdf:Property ;
    rdfs:label 'Implementation Status' ;
    rdfs:comment 'Current status of the operational implementation of the policy across systems, processes, and business units.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent compliance audit conducted for this policy.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date of the most recent formal review of the policy by the policy owner or governance committee.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Date' ;
    rdfs:comment 'Scheduled date for the next compliance audit of this policy. Calculated based on last audit date and audit frequency.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownerName rdf:type rdf:Property ;
    rdfs:label 'Owner Name' ;
    rdfs:comment 'Full name of the individual currently serving as the policy owner. Business-confidential organizational information.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerRole rdf:type rdf:Property ;
    rdfs:label 'Owner Role' ;
    rdfs:comment 'Executive or senior management role responsible for the policy\'s content, enforcement, and updates (e.g., DPO for data protection, General Counsel for legal compliance).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyForNonCompliance rdf:type rdf:Property ;
    rdfs:label 'Penalty For Non Compliance' ;
    rdfs:comment 'Description of internal or external penalties for policy violations (e.g., disciplinary action, fines, suspension of operations, regulatory sanctions).' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyCategory rdf:type rdf:Property ;
    rdfs:label 'Policy Category' ;
    rdfs:comment 'High-level classification of the policy type. Aligns with major regulatory and ethical compliance domains in gaming.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyCode rdf:type rdf:Property ;
    rdfs:label 'Policy Code' ;
    rdfs:comment 'Unique business identifier code for the compliance policy, typically following a structured format (e.g., GDPR-DPP-001, LOOT-DSC-002).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyDescription rdf:type rdf:Property ;
    rdfs:label 'Policy Description' ;
    rdfs:comment 'Detailed narrative description of the policy\'s purpose, scope, and key provisions. Provides business context and intent.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyName rdf:type rdf:Property ;
    rdfs:label 'Policy Name' ;
    rdfs:comment 'Full official name of the compliance policy (e.g., Data Protection Policy, Loot Box Disclosure Policy, Age Rating Compliance Policy).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyStatus rdf:type rdf:Property ;
    rdfs:label 'Policy Status' ;
    rdfs:comment 'Current lifecycle status of the compliance policy. Tracks progression from draft through approval to active enforcement and eventual retirement.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresAgeVerification rdf:type rdf:Property ;
    rdfs:label 'Requires Age Verification' ;
    rdfs:comment 'Indicates whether this policy mandates age verification mechanisms to comply with child protection regulations (e.g., COPPA, GDPR for minors).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresDataPortability rdf:type rdf:Property ;
    rdfs:label 'Requires Data Portability' ;
    rdfs:comment 'Indicates whether this policy mandates support for data subject right to data portability under GDPR or similar regulations.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresDataRetention rdf:type rdf:Property ;
    rdfs:label 'Requires Data Retention' ;
    rdfs:comment 'Indicates whether this policy mandates specific data retention periods for compliance or audit purposes.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresDisclosure rdf:type rdf:Property ;
    rdfs:label 'Requires Disclosure' ;
    rdfs:comment 'Indicates whether this policy requires public or player-facing disclosure (e.g., loot box probability disclosure, privacy notice publication).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresPlayerConsent rdf:type rdf:Property ;
    rdfs:label 'Requires Player Consent' ;
    rdfs:comment 'Indicates whether this policy mandates obtaining explicit player consent (e.g., for data processing under GDPR, for marketing communications).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresRightToErasure rdf:type rdf:Property ;
    rdfs:label 'Requires Right To Erasure' ;
    rdfs:comment 'Indicates whether this policy mandates support for data subject right to erasure (right to be forgotten) under GDPR or similar regulations.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewCycleMonths rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Months' ;
    rdfs:comment 'Frequency in months at which the policy must be reviewed and revalidated (e.g., 12 for annual review, 24 for biennial).' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Training Frequency Months' ;
    rdfs:comment 'Frequency in months at which employees must complete refresher training on this policy. Null if one-time training only.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingRequired rdf:type rdf:Property ;
    rdfs:label 'Training Required' ;
    rdfs:comment 'Indicates whether employees in applicable business units must complete formal training on this policy.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version number of the policy document following semantic versioning (e.g., 1.0, 2.1, 3.0.1).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentPolicyId rdf:type rdf:Property ;
    rdfs:label 'Parent Policy Id' ;
    rdfs:comment 'Foreign key linking to compliance.policy. Business justification: Consent_policy is a specialized type of policy and should reference the parent policy table for policy hierarchy. This enables modeling consent policies as a subtype of the general policy framework.' ;
    rdfs:domain ind:ConsentPolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:supersededByPolicyConsentPolicyId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Policy Consent Policy Id' ;
    rdfs:comment 'Foreign key reference to the consent_policy_id that supersedes this policy version. Null for active policies. Enables tracking policy evolution and version chains.' ;
    rdfs:domain ind:ConsentPolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsentPolicy .

ind:allowsWithdrawal rdf:type rdf:Property ;
    rdfs:label 'Allows Withdrawal' ;
    rdfs:comment 'Boolean flag indicating whether players can withdraw consent under this policy (true) or consent is irrevocable (false). GDPR Article 7(3) mandates withdrawal must be as easy as giving consent.' ;
    rdfs:domain ind:ConsentPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableJurisdictions rdf:type rdf:Property ;
    rdfs:label 'Applicable Jurisdictions' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes or regional codes (e.g., \'USA,CAN,MEX\' or \'EU,GBR,JPN\') where this consent policy applies. Enables jurisdiction-specific consent management for GDPR, COPPA, CCPA compliance.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automatedDecisionMaking rdf:type rdf:Property ;
    rdfs:label 'Automated Decision Making' ;
    rdfs:comment 'Boolean flag indicating whether this policy covers automated decision-making or profiling (e.g., AI-driven content recommendations, dynamic pricing, matchmaking algorithms). GDPR Article 22 grants players rights regarding automated decisions.' ;
    rdfs:domain ind:ConsentPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentCategories rdf:type rdf:Property ;
    rdfs:label 'Consent Categories' ;
    rdfs:comment 'Comma-separated list of consent categories this policy governs (e.g., \'marketing,analytics,personalization,third_party_sharing,age_verification,cross_game_tracking\'). Defines the scope of data processing activities covered.' ;
    rdfs:domain ind:ConsentPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Email address for players to contact regarding consent, privacy inquiries, or data subject rights requests (e.g., privacy@company.com, dpo@company.com). Required per GDPR Article 13(1)(a).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossBorderTransferAllowed rdf:type rdf:Property ;
    rdfs:label 'Cross Border Transfer Allowed' ;
    rdfs:comment 'Boolean flag indicating whether this policy permits transferring player data outside the originating jurisdiction (e.g., EU to USA). GDPR Chapter V requires adequate safeguards for international transfers.' ;
    rdfs:domain ind:ConsentPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSubjectRightsSummary rdf:type rdf:Property ;
    rdfs:label 'Data Subject Rights Summary' ;
    rdfs:comment 'Summary of player rights under this consent policy (e.g., \'Right to access, rectification, erasure, restriction, portability, objection per GDPR Articles 15-21\'). Must be communicated clearly per GDPR Article 12.' ;
    rdfs:domain ind:ConsentPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpoName rdf:type rdf:Property ;
    rdfs:label 'Dpo Name' ;
    rdfs:comment 'Name of the Data Protection Officer responsible for overseeing compliance with this consent policy. GDPR Article 37 mandates DPO appointment for certain organizations.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalBasis rdf:type rdf:Property ;
    rdfs:label 'Legal Basis' ;
    rdfs:comment 'Primary legal basis under GDPR Article 6 justifying data processing under this policy. Consent requires explicit opt-in, legitimate_interest balances business needs with player rights, contract supports service delivery, legal_obligation for regulatory compliance.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumAgeRequirement rdf:type rdf:Property ;
    rdfs:label 'Minimum Age Requirement' ;
    rdfs:comment 'Minimum age (in years) required to provide valid consent under this policy. Varies by jurisdiction: COPPA requires 13+ in USA, GDPR allows member states to set 13-16. Null if no age restriction applies.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentalConsentRequired rdf:type rdf:Property ;
    rdfs:label 'Parental Consent Required' ;
    rdfs:comment 'Boolean flag indicating whether parental or guardian consent is required for players below the minimum age threshold. COPPA and GDPR Article 8 mandate parental consent for children.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policyDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Policy Document Url' ;
    rdfs:comment 'Fully qualified URL to the published consent policy document (privacy policy, terms of service, consent notice) that players review before consenting. Must be accessible and archived for audit purposes.' ;
    rdfs:domain ind:ConsentPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyHash rdf:type rdf:Property ;
    rdfs:label 'Policy Hash' ;
    rdfs:comment 'Cryptographic hash (e.g., SHA-256) of the policy document content at policy_document_url. Ensures document integrity and detects unauthorized modifications for audit and compliance verification.' ;
    rdfs:domain ind:ConsentPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyLanguage rdf:type rdf:Property ;
    rdfs:label 'Policy Language' ;
    rdfs:comment 'ISO 639-1 two-letter language code (e.g., \'en\', \'fr\', \'de\', \'ja\') indicating the language of the policy document. Supports multi-language consent compliance.' ;
    rdfs:domain ind:ConsentPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyScope rdf:type rdf:Property ;
    rdfs:label 'Policy Scope' ;
    rdfs:comment 'Scope of applicability for this consent policy. Single_game policies apply to one title, game_franchise covers a series, all_games spans the publishers portfolio, platform_wide for gaming platforms, corporate_wide for entire organization including non-gaming services.' ;
    rdfs:domain ind:ConsentPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profilingPurposes rdf:type rdf:Property ;
    rdfs:label 'Profiling Purposes' ;
    rdfs:comment 'Comma-separated list of purposes for which player profiling is conducted under this policy (e.g., \'personalized_content,targeted_advertising,churn_prediction,fraud_detection\'). Must be disclosed per GDPR Article 13(2)(f).' ;
    rdfs:domain ind:ConsentPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresExplicitConsent rdf:type rdf:Property ;
    rdfs:label 'Requires Explicit Consent' ;
    rdfs:comment 'Boolean flag indicating whether this policy requires explicit opt-in consent (true) or allows implied consent (false). GDPR and COPPA typically require explicit consent for sensitive data processing.' ;
    rdfs:domain ind:ConsentPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supervisoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority' ;
    rdfs:comment 'Name of the regulatory supervisory authority with jurisdiction over this consent policy (e.g., \'Irish Data Protection Commission\', \'California Attorney General\', \'FTC\'). Players have the right to lodge complaints per GDPR Article 77.' ;
    rdfs:domain ind:ConsentPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyCategories rdf:type rdf:Property ;
    rdfs:label 'Third Party Categories' ;
    rdfs:comment 'Comma-separated list of third-party categories with whom data may be shared under this policy (e.g., \'advertising_networks,analytics_providers,payment_processors,cloud_infrastructure\'). Required for GDPR Article 13 transparency.' ;
    rdfs:domain ind:ConsentPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartySharingAllowed rdf:type rdf:Property ;
    rdfs:label 'Third Party Sharing Allowed' ;
    rdfs:comment 'Boolean flag indicating whether this policy permits sharing player data with third parties (advertisers, analytics providers, partners). Must be disclosed per GDPR Article 13(1)(e).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transferMechanism rdf:type rdf:Property ;
    rdfs:label 'Transfer Mechanism' ;
    rdfs:comment 'Legal mechanism enabling cross-border data transfers under GDPR Chapter V. Standard contractual clauses (SCCs) are most common, adequacy_decision for approved countries (e.g., EU-US Data Privacy Framework), binding_corporate_rules for intra-group transfers.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalMechanism rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Mechanism' ;
    rdfs:comment 'Description of how players can withdraw consent (e.g., \'In-game settings menu\', \'Email to privacy@company.com\', \'Account portal\'). Required for GDPR Article 7(3) compliance.' ;
    rdfs:domain ind:ConsentPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsrFulfillmentStepId rdf:type rdf:Property ;
    rdfs:label 'Dsr Fulfillment Step Id' ;
    rdfs:comment 'Unique identifier for the DSR fulfillment step. Primary key for this transactional record capturing each discrete action taken to satisfy a data subject request under GDPR, COPPA, or other privacy regulations.' ;
    rdfs:domain ind:DsrFulfillmentStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dsrId rdf:type rdf:Property ;
    rdfs:label 'Dsr Id' ;
    rdfs:comment 'Reference to the parent data subject request that this fulfillment step belongs to. Links this step to the overarching DSR case.' ;
    rdfs:domain ind:DsrFulfillmentStep ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DataSubjectRequest .

ind:assignedTeamMember rdf:type rdf:Property ;
    rdfs:label 'Assigned Team Member' ;
    rdfs:comment 'Name or identifier of the employee or team member assigned to execute this fulfillment step. Provides accountability and contact point for step-level issues.' ;
    rdfs:domain ind:DsrFulfillmentStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockerDescription rdf:type rdf:Property ;
    rdfs:label 'Blocker Description' ;
    rdfs:comment 'Free-text description of any blockers, exceptions, or issues encountered during execution of this step. Captures obstacles that prevent or delay step completion for audit and resolution purposes.' ;
    rdfs:domain ind:DsrFulfillmentStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockerResolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Blocker Resolution Timestamp' ;
    rdfs:comment 'Date and time when a blocker or exception was resolved, allowing the step to proceed. Nullable if no blocker occurred or if blocker remains unresolved.' ;
    rdfs:domain ind:DsrFulfillmentStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceDeadline rdf:type rdf:Property ;
    rdfs:label 'Compliance Deadline' ;
    rdfs:comment 'Regulatory deadline by which this fulfillment step must be completed to remain compliant. Derived from parent DSR deadline and step dependencies. Enables proactive escalation of at-risk steps.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataVolumeProcessed rdf:type rdf:Property ;
    rdfs:label 'Data Volume Processed' ;
    rdfs:comment 'Number of records, files, or data objects processed during this fulfillment step. Provides quantitative measure of step scope and complexity for audit and capacity planning.' ;
    rdfs:domain ind:DsrFulfillmentStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataVolumeUnit rdf:type rdf:Property ;
    rdfs:label 'Data Volume Unit' ;
    rdfs:comment 'Unit of measurement for the data volume processed (e.g., records, files, megabytes). Provides context for interpreting the data_volume_processed metric.' ;
    rdfs:domain ind:DsrFulfillmentStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerNotificationSent rdf:type rdf:Property ;
    rdfs:label 'Player Notification Sent' ;
    rdfs:comment 'Indicates whether the data subject (player) was notified of the completion or status of this fulfillment step. Required for transparency and regulatory compliance.' ;
    rdfs:domain ind:DsrFulfillmentStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:playerNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Player Notification Timestamp' ;
    rdfs:comment 'Date and time when the player notification was sent. Documents compliance with obligation to inform data subjects of actions taken on their requests.' ;
    rdfs:domain ind:DsrFulfillmentStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responsibleSystem rdf:type rdf:Property ;
    rdfs:label 'Responsible System' ;
    rdfs:comment 'Name of the system, platform, or data domain responsible for executing this fulfillment step (e.g., player, billing, analytics, marketing, community, Salesforce CRM, GameAnalytics, Zendesk). Identifies the technical boundary where action must be taken.' ;
    rdfs:domain ind:DsrFulfillmentStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaMet rdf:type rdf:Property ;
    rdfs:label 'Sla Met' ;
    rdfs:comment 'Indicates whether this fulfillment step was completed within the defined SLA target. Nullable until step is completed. Used for operational performance reporting.' ;
    rdfs:domain ind:DsrFulfillmentStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stepNumber rdf:type rdf:Property ;
    rdfs:label 'Step Number' ;
    rdfs:comment 'Sequential order of this fulfillment step within the parent DSR workflow. Enables chronological tracking and orchestration of multi-step DSR processes.' ;
    rdfs:domain ind:DsrFulfillmentStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stepStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Step Start Timestamp' ;
    rdfs:comment 'Date and time when work on this fulfillment step began. Marks the initiation of the step in the DSR workflow and enables duration tracking.' ;
    rdfs:domain ind:DsrFulfillmentStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stepStatus rdf:type rdf:Property ;
    rdfs:label 'Step Status' ;
    rdfs:comment 'Current lifecycle state of this fulfillment step. Tracks progress through the step workflow and identifies steps requiring attention or intervention.' ;
    rdfs:domain ind:DsrFulfillmentStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepType rdf:type rdf:Property ;
    rdfs:label 'Step Type' ;
    rdfs:comment 'Category of fulfillment action being performed in this step. Defines the nature of the work required to satisfy the DSR obligation.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyName rdf:type rdf:Property ;
    rdfs:label 'Third Party Name' ;
    rdfs:comment 'Name of the third-party organization notified during this step (e.g., payment processor, analytics vendor, marketing platform). Nullable if no third-party notification was required.' ;
    rdfs:domain ind:DsrFulfillmentStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Third Party Notification Timestamp' ;
    rdfs:comment 'Date and time when the third-party notification was sent. Provides audit evidence of timely downstream notification as required by privacy regulations.' ;
    rdfs:domain ind:DsrFulfillmentStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:thirdPartyNotified rdf:type rdf:Property ;
    rdfs:label 'Third Party Notified' ;
    rdfs:comment 'Indicates whether a third-party data processor or partner was notified as part of this fulfillment step. Required for DSR types that mandate downstream notification (e.g., erasure requests).' ;
    rdfs:domain ind:DsrFulfillmentStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'Name or identifier of the person or system that performed verification of this step. Provides accountability for quality assurance in the DSR fulfillment process.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentJurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Parent Jurisdiction Id' ;
    rdfs:comment 'Reference to the parent jurisdiction for hierarchical relationships. For example, California (US-CA) would reference United States (US). Null for top-level jurisdictions.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:primaryRegulatoryAuthorityId rdf:type rdf:Property ;
    rdfs:label 'Primary Regulatory Authority Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_authority. Business justification: Jurisdiction should reference the primary regulatory_authority that governs it. Currently has regulatory_contact_email (STRING) but no FK to the authority master table. Adding FK enables proper normal' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryAuthority .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Indicates whether Gaming currently publishes or distributes games in this jurisdiction. True if active, false if the jurisdiction is no longer served or is under embargo.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:advertisingRestrictions rdf:type rdf:Property ;
    rdfs:label 'Advertising Restrictions' ;
    rdfs:comment 'Summary of advertising and marketing restrictions applicable to game promotion in this jurisdiction (e.g., restrictions on advertising to minors, disclosure requirements for in-game purchases, influencer marketing rules). Free-text field for compliance reference.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ageVerificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Age Verification Required Flag' ;
    rdfs:comment 'Indicates whether age verification is legally required for game access or monetization features in this jurisdiction (e.g., for mature-rated content or in-app purchases).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consumerProtectionFramework rdf:type rdf:Property ;
    rdfs:label 'Consumer Protection Framework' ;
    rdfs:comment 'Name or reference to the primary consumer protection legal framework governing game sales, refunds, and player rights in this jurisdiction (e.g., EU Consumer Rights Directive, FTC Act, national consumer protection acts).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentCensorshipLevel rdf:type rdf:Property ;
    rdfs:label 'Content Censorship Level' ;
    rdfs:comment 'Degree of government-mandated content censorship or restriction for game content in this jurisdiction. None (no censorship), moderate (some content restrictions, e.g., violence or political themes), strict (extensive censorship or pre-approval required).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coppaApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Coppa Applicable Flag' ;
    rdfs:comment 'Indicates whether COPPA (Children\'s Online Privacy Protection Act) applies in this jurisdiction. True for United States and territories where COPPA is enforced by the FTC.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataBreachNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Data Breach Notification Required Flag' ;
    rdfs:comment 'Indicates whether the company is legally required to notify players and/or regulators in the event of a data breach in this jurisdiction. True for jurisdictions with mandatory breach notification laws.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataLocalizationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Data Localization Required Flag' ;
    rdfs:comment 'Indicates whether player data must be stored or processed within the jurisdictions borders (data residency requirement). True for jurisdictions with data localization laws (e.g., Russia, China).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:digitalGoodsVatRate rdf:type rdf:Property ;
    rdfs:label 'Digital Goods Vat Rate' ;
    rdfs:comment 'Standard VAT or sales tax rate (as a percentage) applicable to digital goods and services (games, DLC, MTX) sold in this jurisdiction. Null if no VAT/sales tax applies.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeResolutionMechanism rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Mechanism' ;
    rdfs:comment 'Primary legal mechanism for resolving player disputes in this jurisdiction. Arbitration (binding arbitration clauses enforceable), litigation (court-based resolution), ombudsman (government or industry ombudsman available), mediation (alternative dispute resolution preferred).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:embargoStatus rdf:type rdf:Property ;
    rdfs:label 'Embargo Status' ;
    rdfs:comment 'Trade embargo or sanctions status affecting game distribution in this jurisdiction. None (no embargo), partial (restricted distribution or content), full (complete embargo, no distribution allowed).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esportsGamblingRegulatedFlag rdf:type rdf:Property ;
    rdfs:label 'Esports Gambling Regulated Flag' ;
    rdfs:comment 'Indicates whether esports betting and gambling activities are regulated or restricted in this jurisdiction. True if esports gambling is subject to gaming/gambling laws.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Applicable Flag' ;
    rdfs:comment 'Indicates whether GDPR (General Data Protection Regulation) applies to player data processing in this jurisdiction. True for EU/EEA member states and territories where GDPR is in force.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionName rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Name' ;
    rdfs:comment 'Full legal name of the jurisdiction (e.g., United States, California, European Union).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionType rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Type' ;
    rdfs:comment 'Classification of the jurisdiction: country (sovereign nation), state/province/territory (subdivision of a country), supranational (multi-country region such as EU or EEA).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lootBoxRegulatoryStatus rdf:type rdf:Property ;
    rdfs:label 'Loot Box Regulatory Status' ;
    rdfs:comment 'Regulatory treatment of loot boxes and randomized monetization mechanics in this jurisdiction. Unrestricted (no specific regulation), disclosure_required (probability disclosure mandated), restricted (age or spending limits apply), prohibited (loot boxes banned), under_review (pending legislation).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumAgeForMonetization rdf:type rdf:Property ;
    rdfs:label 'Minimum Age For Monetization' ;
    rdfs:comment 'Minimum age (in years) at which a player may engage in in-app purchases (IAP) or microtransactions (MTX) without parental consent in this jurisdiction. Null if no specific age restriction applies.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onlineServiceLicenseRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Online Service License Required Flag' ;
    rdfs:comment 'Indicates whether a special license or permit is required to operate online gaming services (GaaS, multiplayer, live operations) in this jurisdiction. True for jurisdictions with online service licensing requirements (e.g., China ICP license).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pciDssEnforcementLevel rdf:type rdf:Property ;
    rdfs:label 'Pci Dss Enforcement Level' ;
    rdfs:comment 'Level of PCI DSS (Payment Card Industry Data Security Standard) enforcement for payment processing in this jurisdiction. Standard (normal PCI DSS compliance required), enhanced (additional local requirements), not_applicable (jurisdiction does not enforce PCI DSS or does not support card payments).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformCertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Platform Certification Required Flag' ;
    rdfs:comment 'Indicates whether games must pass platform-specific certification (TRC/TCR - Technical Requirements Checklist/Technical Certification Requirements) to be published in this jurisdiction. True for jurisdictions where console manufacturers or app stores enforce certification.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ratingAuthority rdf:type rdf:Property ;
    rdfs:label 'Rating Authority' ;
    rdfs:comment 'The primary game content rating authority applicable in this jurisdiction. ESRB (Entertainment Software Rating Board) for North America, PEGI (Pan European Game Information) for Europe, USK (Unterhaltungssoftware Selbstkontrolle) for Germany, CERO (Computer Entertainment Rating Organization) for Japan, GRAC (Game Rating and Administration Committee) for South Korea, ACB (Australian Classification Board) for Australia, IARC (International Age Rating Coalition) for multi-territory digital distribution. [ENUM-REF-CANDIDATE: ESRB|PEGI|USK|CERO|GRAC|ACB|IARC — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightToBeForgottenApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Right To Be Forgotten Applicable Flag' ;
    rdfs:comment 'Indicates whether players have a legal right to request deletion of their personal data (right to erasure / right to be forgotten) in this jurisdiction. True for GDPR jurisdictions and others with similar data subject rights.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lootBoxDisclosureId rdf:type rdf:Property ;
    rdfs:label 'Loot Box Disclosure Id' ;
    rdfs:comment 'Unique identifier for the loot box disclosure record. Primary key for the loot box disclosure entity.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LootBoxDisclosure .

ind:certificationAuthorityId rdf:type rdf:Property ;
    rdfs:label 'Certification Authority Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_authority. Business justification: Loot box disclosures reference certification_authority (STRING) for the authority that certified the disclosure. Should FK to regulatory_authority master table for normalization. Note: certification_a' ;
    rdfs:domain ind:LootBoxDisclosure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryAuthority .

ind:ageRating rdf:type rdf:Property ;
    rdfs:label 'Age Rating' ;
    rdfs:comment 'Age rating assigned to the game title by the jurisdictions rating authority (e.g., ESRB E10+, PEGI 12, CERO B). Relevant because some jurisdictions impose stricter loot box disclosure requirements for games accessible to minors.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailNotes rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Notes' ;
    rdfs:comment 'Free-text field for compliance team notes, audit findings, regulatory correspondence references, or historical context related to this disclosure. Used for internal compliance documentation and audit preparation.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current compliance status of this loot box disclosure. Indicates whether the published disclosure meets the jurisdictions regulatory requirements and whether any discrepancies or remediation actions are in progress.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosedItemProbabilities rdf:type rdf:Property ;
    rdfs:label 'Disclosed Item Probabilities' ;
    rdfs:comment 'JSON or structured text representation of the item probabilities disclosed to players, including item names, rarity tiers, and percentage drop rates. This is the published, player-facing version of the odds.' ;
    rdfs:domain ind:LootBoxDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Disclosure Effective Date' ;
    rdfs:comment 'Date when this loot box disclosure became effective and enforceable under the jurisdictions regulation. Represents when the disclosure obligation started.' ;
    rdfs:domain ind:LootBoxDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disclosureExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Disclosure Expiration Date' ;
    rdfs:comment 'Date when this disclosure version expires or is superseded by a new disclosure. Null if the disclosure remains current and has no planned end date.' ;
    rdfs:domain ind:LootBoxDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disclosureFormat rdf:type rdf:Property ;
    rdfs:label 'Disclosure Format' ;
    rdfs:comment 'Required format for publishing loot box probabilities as mandated by the jurisdiction. Specifies where and how odds must be disclosed to players.' ;
    rdfs:domain ind:LootBoxDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureLanguage rdf:type rdf:Property ;
    rdfs:label 'Disclosure Language' ;
    rdfs:comment 'ISO 639-1 language code (with optional ISO 3166-1 country code) for the language in which the disclosure is published (e.g., en-US, zh-CN, nl-NL). Jurisdictions typically require disclosures in the local language.' ;
    rdfs:domain ind:LootBoxDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureUrl rdf:type rdf:Property ;
    rdfs:label 'Disclosure Url' ;
    rdfs:comment 'Public URL where the loot box probabilities are published for player access, such as a dedicated disclosure page on the game website or app store listing. Required for website posting and app store label formats.' ;
    rdfs:domain ind:LootBoxDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyDescription rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Description' ;
    rdfs:comment 'Detailed description of any discrepancies between disclosed odds and actual gacha pool configuration, including which items or probabilities differ. Null if odds_match_flag is true. Used for remediation tracking and audit documentation.' ;
    rdfs:domain ind:LootBoxDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementActionDescription rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Description' ;
    rdfs:comment 'Detailed description of any regulatory enforcement action, including the nature of the violation, penalties imposed, and remediation requirements. Null if enforcement_action_flag is false.' ;
    rdfs:domain ind:LootBoxDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementActionFlag rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Flag' ;
    rdfs:comment 'Boolean flag indicating whether any regulatory enforcement action, warning, or penalty has been issued related to this loot box disclosure. True if enforcement action has occurred, false otherwise.' ;
    rdfs:domain ind:LootBoxDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inGameDisplayLocation rdf:type rdf:Property ;
    rdfs:label 'In Game Display Location' ;
    rdfs:comment 'Description of where the loot box odds are displayed within the game client (e.g., store menu, loot box preview screen, help section). Applicable when disclosure_format includes in-game odds display.' ;
    rdfs:domain ind:LootBoxDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Last Updated By' ;
    rdfs:comment 'User ID or name of the individual who last modified this disclosure record. Used for accountability and audit trail purposes.' ;
    rdfs:domain ind:LootBoxDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monetizationModel rdf:type rdf:Property ;
    rdfs:label 'Monetization Model' ;
    rdfs:comment 'Monetization model of the game title for which this disclosure applies. Relevant because F2P (Free-to-Play) games with MTX (Microtransactions) face stricter loot box scrutiny in many jurisdictions.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oddsMatchFlag rdf:type rdf:Property ;
    rdfs:label 'Odds Match Flag' ;
    rdfs:comment 'Boolean flag indicating whether the disclosed item probabilities match the actual gacha pool configuration in the monetization domain. False indicates a discrepancy requiring remediation to ensure truth in advertising and regulatory compliance.' ;
    rdfs:domain ind:LootBoxDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pitySystemDisclosedFlag rdf:type rdf:Property ;
    rdfs:label 'Pity System Disclosed Flag' ;
    rdfs:comment 'Boolean flag indicating whether the disclosure includes information about any pity or guaranteed drop mechanics (e.g., guaranteed rare item after X attempts). Some jurisdictions require disclosure of pity systems as part of transparent odds communication.' ;
    rdfs:domain ind:LootBoxDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:playerComplaintCount rdf:type rdf:Property ;
    rdfs:label 'Player Complaint Count' ;
    rdfs:comment 'Number of player complaints or support tickets received related to loot box odds transparency or perceived discrepancies for this game title and jurisdiction. Used to identify potential compliance risks and player trust issues.' ;
    rdfs:domain ind:LootBoxDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Regulatory Contact Email' ;
    rdfs:comment 'Email address of the regulatory authority contact or compliance officer responsible for this jurisdictions loot box disclosure requirements. Used for regulatory correspondence and audit inquiries.' ;
    rdfs:domain ind:LootBoxDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Reference' ;
    rdfs:comment 'Reference number or identifier for the formal submission of this disclosure to the regulatory authority, if required by the jurisdiction. Used for tracking compliance filings and audit responses.' ;
    rdfs:domain ind:LootBoxDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleParty rdf:type rdf:Property ;
    rdfs:label 'Responsible Party' ;
    rdfs:comment 'Name or identifier of the individual, team, or role responsible for maintaining this disclosure and ensuring compliance (e.g., Compliance Manager, Legal Team, Live Ops Producer). Used for accountability and escalation.' ;
    rdfs:domain ind:LootBoxDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'Date when the privacy impact assessment was formally conducted or completed by the assessment team.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentMethodology rdf:type rdf:Property ;
    rdfs:label 'Assessment Methodology' ;
    rdfs:comment 'Framework or methodology used to conduct the privacy impact assessment (e.g., ICO DPIA template, CNIL methodology, ISO 29134).' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Number' ;
    rdfs:comment 'Business identifier or reference number assigned to this privacy impact assessment for tracking and audit purposes.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assessment Status' ;
    rdfs:comment 'Current lifecycle status of the privacy impact assessment in the review and approval workflow. [ENUM-REF-CANDIDATE: Draft|Under_Review|DPO_Review|Approved|Rejected|Consultation_Required|Completed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentTeamMembers rdf:type rdf:Property ;
    rdfs:label 'Assessment Team Members' ;
    rdfs:comment 'Comma-separated list of team members who participated in conducting this privacy impact assessment, including roles (e.g., Product Manager, Legal Counsel, Security Architect).' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentTitle rdf:type rdf:Property ;
    rdfs:label 'Assessment Title' ;
    rdfs:comment 'Descriptive title of the privacy impact assessment, identifying the feature, processing activity, or integration being assessed.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentType rdf:type rdf:Property ;
    rdfs:label 'Assessment Type' ;
    rdfs:comment 'Type of privacy impact assessment conducted: Data Protection Impact Assessment (DPIA) under GDPR, Privacy Impact Assessment (PIA) for other jurisdictions, or updates to existing assessments.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:childrenDataInvolved rdf:type rdf:Property ;
    rdfs:label 'Children Data Involved' ;
    rdfs:comment 'Indicates whether the processing involves personal data of children, triggering additional protections under GDPR Article 8 and COPPA.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossBorderTransfer rdf:type rdf:Property ;
    rdfs:label 'Cross Border Transfer' ;
    rdfs:comment 'Indicates whether the processing involves cross-border transfer of personal data outside the EEA, requiring additional safeguards under GDPR Chapter V.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataCategories rdf:type rdf:Property ;
    rdfs:label 'Data Categories' ;
    rdfs:comment 'Comma-separated list or description of the categories of personal data involved in the processing activity (e.g., player identifiers, behavioral data, payment information, location data).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionPeriod rdf:type rdf:Property ;
    rdfs:label 'Data Retention Period' ;
    rdfs:comment 'Planned retention period for the personal data collected through this processing activity, in compliance with data minimization principles.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectCategories rdf:type rdf:Property ;
    rdfs:label 'Data Subject Categories' ;
    rdfs:comment 'Categories of data subjects affected by the processing activity (e.g., adult players, child players under 13, EU residents, California residents).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpoReviewerEmail rdf:type rdf:Property ;
    rdfs:label 'Dpo Reviewer Email' ;
    rdfs:comment 'Email address of the Data Protection Officer who reviewed this assessment for contact and audit trail purposes.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpoReviewerName rdf:type rdf:Property ;
    rdfs:label 'Dpo Reviewer Name' ;
    rdfs:comment 'Full name of the Data Protection Officer who reviewed this privacy impact assessment.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpoSignOffDate rdf:type rdf:Property ;
    rdfs:label 'Dpo Sign Off Date' ;
    rdfs:comment 'Date when the Data Protection Officer formally approved and signed off on the privacy impact assessment.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:identifiedPrivacyRisks rdf:type rdf:Property ;
    rdfs:label 'Identified Privacy Risks' ;
    rdfs:comment 'Detailed description of the privacy risks identified during the assessment, including potential impacts on data subjects\' rights and freedoms.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Initial Risk Level' ;
    rdfs:comment 'Initial privacy risk level assessed before mitigating controls are applied, based on the nature and scope of the processing activity.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigatingControls rdf:type rdf:Property ;
    rdfs:label 'Mitigating Controls' ;
    rdfs:comment 'Description of the technical and organizational measures implemented or planned to mitigate the identified privacy risks.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformFeature rdf:type rdf:Property ;
    rdfs:label 'Platform Feature' ;
    rdfs:comment 'Specific platform feature or system component being assessed (e.g., matchmaking system, in-game chat, player analytics, third-party SDK integration).' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingActivityDescription rdf:type rdf:Property ;
    rdfs:label 'Processing Activity Description' ;
    rdfs:comment 'Detailed description of the data processing activity, feature, or third-party integration that triggered the need for this privacy impact assessment.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Level' ;
    rdfs:comment 'Privacy risk level remaining after mitigating controls have been applied. Determines whether supervisory authority consultation is required.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Frequency' ;
    rdfs:comment 'Scheduled frequency for reviewing and updating this privacy impact assessment to ensure ongoing compliance as processing activities evolve.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialCategoryDataInvolved rdf:type rdf:Property ;
    rdfs:label 'Special Category Data Involved' ;
    rdfs:comment 'Indicates whether the processing involves special categories of personal data under GDPR Article 9 (e.g., biometric data, health data).' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stakeholderConsultationNotes rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Consultation Notes' ;
    rdfs:comment 'Notes from consultations with relevant stakeholders, including data subjects where appropriate, as required under GDPR Article 35(9).' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisoryAuthorityConsultationDate rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Consultation Date' ;
    rdfs:comment 'Date when the supervisory authority was consulted regarding this high-risk processing activity, if consultation was required.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supervisoryAuthorityConsultationRequired rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Consultation Required' ;
    rdfs:comment 'Indicates whether consultation with the supervisory authority is required under GDPR Article 36 due to high residual risk that cannot be adequately mitigated.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supervisoryAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Name' ;
    rdfs:comment 'Name of the GDPR supervisory authority consulted (e.g., ICO, CNIL, BfDI) for this privacy impact assessment.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisoryAuthorityResponseDate rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Response Date' ;
    rdfs:comment 'Date when the supervisory authority provided their response or guidance following consultation.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:thirdPartyIntegration rdf:type rdf:Property ;
    rdfs:label 'Third Party Integration' ;
    rdfs:comment 'Name of the third-party service, SDK, or data processor being integrated that triggered this privacy impact assessment.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityCode rdf:type rdf:Property ;
    rdfs:label 'Activity Code' ;
    rdfs:comment 'Standardized code identifier for the processing activity following the format PA-[DOMAIN]-[NUMBER] (e.g., PA-PLR-0001 for player registration).' ;
    rdfs:domain ind:ProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityName rdf:type rdf:Property ;
    rdfs:label 'Activity Name' ;
    rdfs:comment 'The business-friendly name of the data processing activity (e.g., Player Registration, In-Game Analytics Collection, Marketing Campaign Management).' ;
    rdfs:domain ind:ProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityOwner rdf:type rdf:Property ;
    rdfs:label 'Activity Owner' ;
    rdfs:comment 'Name or role of the individual accountable for ensuring compliance of this processing activity with data protection regulations.' ;
    rdfs:domain ind:ProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automatedDecisionLogic rdf:type rdf:Property ;
    rdfs:label 'Automated Decision Logic' ;
    rdfs:comment 'If automated decision-making is used, this field provides meaningful information about the logic involved and the significance and envisaged consequences for the data subject.' ;
    rdfs:domain ind:ProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automatedDecisionMakingFlag rdf:type rdf:Property ;
    rdfs:label 'Automated Decision Making Flag' ;
    rdfs:comment 'Indicates whether the processing activity involves automated decision-making, including profiling, that produces legal or similarly significant effects.' ;
    rdfs:domain ind:ProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessUnit rdf:type rdf:Property ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'The business unit or department responsible for this processing activity (e.g., Live Operations, Marketing, Player Support, Game Development).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpaApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Ccpa Applicable Flag' ;
    rdfs:comment 'Indicates whether this processing activity is subject to CCPA requirements due to processing of California resident data.' ;
    rdfs:domain ind:ProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:childrenDataFlag rdf:type rdf:Property ;
    rdfs:label 'Children Data Flag' ;
    rdfs:comment 'Indicates whether the processing activity involves personal data of children, triggering additional protections under GDPR Article 8 and COPPA compliance requirements.' ;
    rdfs:domain ind:ProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controllerProcessorRole rdf:type rdf:Property ;
    rdfs:label 'Controller Processor Role' ;
    rdfs:comment 'Indicates whether Gaming acts as a data controller, processor, or joint controller for this processing activity under GDPR definitions.' ;
    rdfs:domain ind:ProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProtectionOfficerContact rdf:type rdf:Property ;
    rdfs:label 'Data Protection Officer Contact' ;
    rdfs:comment 'Contact information for the Data Protection Officer responsible for overseeing this processing activity and handling data subject requests.' ;
    rdfs:domain ind:ProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'Description of where personal data originates (e.g., directly from data subject, from third-party data brokers, from public sources, from platform SDKs).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectRightsProcedure rdf:type rdf:Property ;
    rdfs:label 'Data Subject Rights Procedure' ;
    rdfs:comment 'Description of the procedure by which data subjects can exercise their rights (access, rectification, erasure, restriction, portability, objection) in relation to this processing activity.' ;
    rdfs:domain ind:ProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpiaCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Dpia Completion Date' ;
    rdfs:comment 'The date on which the DPIA for this processing activity was completed and approved by the Data Protection Officer.' ;
    rdfs:domain ind:ProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dpiaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Dpia Required Flag' ;
    rdfs:comment 'Indicates whether a Data Protection Impact Assessment is required for this processing activity due to high risk to data subject rights and freedoms.' ;
    rdfs:domain ind:ProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internationalTransferFlag rdf:type rdf:Property ;
    rdfs:label 'International Transfer Flag' ;
    rdfs:comment 'Indicates whether personal data is transferred to third countries or international organizations outside the European Economic Area (EEA).' ;
    rdfs:domain ind:ProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legitimateInterestDescription rdf:type rdf:Property ;
    rdfs:label 'Legitimate Interest Description' ;
    rdfs:comment 'If legal basis is legitimate interests, this field documents the specific legitimate interest pursued and the balancing test performed against data subject rights.' ;
    rdfs:domain ind:ProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationalSecurityMeasures rdf:type rdf:Property ;
    rdfs:label 'Organizational Security Measures' ;
    rdfs:comment 'Description of organizational security measures implemented (e.g., staff training, access authorization procedures, incident response plan, data protection impact assessments).' ;
    rdfs:domain ind:ProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privacyNoticeUrl rdf:type rdf:Property ;
    rdfs:label 'Privacy Notice Url' ;
    rdfs:comment 'URL link to the public-facing privacy notice or policy that discloses this processing activity to data subjects.' ;
    rdfs:domain ind:ProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingActivityStatus rdf:type rdf:Property ;
    rdfs:label 'Processing Activity Status' ;
    rdfs:comment 'Current operational status of the processing activity indicating whether it is actively processing data, temporarily suspended, permanently discontinued, or under compliance review.' ;
    rdfs:domain ind:ProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingPurpose rdf:type rdf:Property ;
    rdfs:label 'Processing Purpose' ;
    rdfs:comment 'Detailed description of the specific, explicit, and legitimate purpose for which personal data is processed (e.g., to provide game services, to process payments, to deliver targeted advertising).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientCategories rdf:type rdf:Property ;
    rdfs:label 'Recipient Categories' ;
    rdfs:comment 'Comma-separated list of categories of recipients to whom personal data may be disclosed (e.g., cloud service providers, payment processors, analytics vendors, advertising networks, platform holders, law enforcement).' ;
    rdfs:domain ind:ProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriod rdf:type rdf:Property ;
    rdfs:label 'Retention Period' ;
    rdfs:comment 'The time period for which personal data will be retained, or the criteria used to determine that period (e.g., 3 years after account closure, duration of contract plus 6 years for legal claims).' ;
    rdfs:domain ind:ProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Retention Period Days' ;
    rdfs:comment 'Numeric representation of the retention period in days for automated retention policy enforcement and data lifecycle management.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sccVersion rdf:type rdf:Property ;
    rdfs:label 'Scc Version' ;
    rdfs:comment 'If Standard Contractual Clauses are used, this field documents the version and date of the SCCs in place (e.g., EU Commission SCCs 2021/914).' ;
    rdfs:domain ind:ProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialCategoryDataFlag rdf:type rdf:Property ;
    rdfs:label 'Special Category Data Flag' ;
    rdfs:comment 'Indicates whether the processing activity involves special categories of personal data under GDPR Article 9 (e.g., health data, biometric data, data revealing racial or ethnic origin).' ;
    rdfs:domain ind:ProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialCategoryLegalBasis rdf:type rdf:Property ;
    rdfs:label 'Special Category Legal Basis' ;
    rdfs:comment 'If special category data is processed, this field documents the specific legal basis under GDPR Article 9(2) that permits such processing.' ;
    rdfs:domain ind:ProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalSecurityMeasures rdf:type rdf:Property ;
    rdfs:label 'Technical Security Measures' ;
    rdfs:comment 'Description of technical security measures implemented to protect personal data (e.g., encryption at rest and in transit, access controls, pseudonymization, secure key management).' ;
    rdfs:domain ind:ProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferCountries rdf:type rdf:Property ;
    rdfs:label 'Transfer Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes to which personal data is transferred (e.g., USA, JPN, SGP).' ;
    rdfs:domain ind:ProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferSafeguardMechanism rdf:type rdf:Property ;
    rdfs:label 'Transfer Safeguard Mechanism' ;
    rdfs:comment 'The legal mechanism used to safeguard international data transfers (e.g., EU Commission adequacy decision, Standard Contractual Clauses, Binding Corporate Rules).' ;
    rdfs:domain ind:ProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Implementation Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Regulatory changes (new loot box laws, GDPR updates, age rating changes) have estimated implementation costs and effort hours that must be allocated to cost centers for budgeting. Gaming companies tra' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:updatedPolicyId rdf:type rdf:Property ;
    rdfs:label 'Updated Policy Id' ;
    rdfs:comment 'Foreign key linking to compliance.policy. Business justification: Regulatory changes often require policy updates. Should FK to the policy that was updated or created in response to the regulatory change. Nullable until policy update is completed.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:affectedComplianceDomainAdvertising rdf:type rdf:Property ;
    rdfs:label 'Affected Compliance Domain Advertising' ;
    rdfs:comment 'Flag indicating whether the regulatory change impacts advertising standards, marketing practices, or promotional content requirements.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:affectedComplianceDomainAgeRating rdf:type rdf:Property ;
    rdfs:label 'Affected Compliance Domain Age Rating' ;
    rdfs:comment 'Flag indicating whether the regulatory change impacts age rating certification, content descriptors, or rating authority requirements.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:affectedComplianceDomainCoppa rdf:type rdf:Property ;
    rdfs:label 'Affected Compliance Domain Coppa' ;
    rdfs:comment 'Flag indicating whether the regulatory change impacts COPPA compliance or children\'s privacy protection requirements.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:affectedComplianceDomainEsportsBetting rdf:type rdf:Property ;
    rdfs:label 'Affected Compliance Domain Esports Betting' ;
    rdfs:comment 'Flag indicating whether the regulatory change impacts esports betting, gambling regulations, or wagering compliance.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:affectedComplianceDomainGdpr rdf:type rdf:Property ;
    rdfs:label 'Affected Compliance Domain Gdpr' ;
    rdfs:comment 'Flag indicating whether the regulatory change impacts GDPR compliance, data subject rights, or data protection obligations.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:affectedComplianceDomainLootBox rdf:type rdf:Property ;
    rdfs:label 'Affected Compliance Domain Loot Box' ;
    rdfs:comment 'Flag indicating whether the regulatory change impacts loot box mechanics, probability disclosure, or monetization practices.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:affectedComplianceDomainPayment rdf:type rdf:Property ;
    rdfs:label 'Affected Compliance Domain Payment' ;
    rdfs:comment 'Flag indicating whether the regulatory change impacts payment processing, PCI DSS compliance, or financial transaction requirements.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:affectedGameTitles rdf:type rdf:Property ;
    rdfs:label 'Affected Game Titles' ;
    rdfs:comment 'Comma-separated list of specific game titles or franchises impacted by the regulatory change, or \'all\' if applicable to entire portfolio.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedPlatforms rdf:type rdf:Property ;
    rdfs:label 'Affected Platforms' ;
    rdfs:comment 'Comma-separated list of gaming platforms affected by the regulatory change (e.g., console, PC, mobile, web).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Change Reference Number' ;
    rdfs:comment 'External reference number or identifier assigned by the issuing authority or internal tracking system for this regulatory change.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeType rdf:type rdf:Property ;
    rdfs:label 'Change Type' ;
    rdfs:comment 'Classification of the regulatory change indicating whether it is a new law, an amendment to existing regulation, updated guidance, enforcement action, repeal, or consultation.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRequired rdf:type rdf:Property ;
    rdfs:label 'Escalation Required' ;
    rdfs:comment 'Flag indicating whether the regulatory change requires escalation to executive leadership or board-level review due to materiality or strategic impact.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedImplementationEffortHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Implementation Effort Hours' ;
    rdfs:comment 'Estimated total effort in person-hours required to implement compliance changes across all affected teams and systems.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impactAssessmentSummary rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment Summary' ;
    rdfs:comment 'High-level summary of the business impact of the regulatory change, including affected operations, systems, and processes.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalDocumentationUrl rdf:type rdf:Property ;
    rdfs:label 'Internal Documentation Url' ;
    rdfs:comment 'URL or document repository link to internal impact assessment, response plan, or implementation documentation.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Legal Review Completion Date' ;
    rdfs:comment 'Date when legal review of the regulatory change was completed and opinion provided.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Monitoring Frequency' ;
    rdfs:comment 'Frequency at which compliance with the regulatory change is monitored and reviewed after implementation.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Player Notification Date' ;
    rdfs:comment 'Date when players were notified of changes resulting from the regulatory change.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'Date when the regulatory change was officially published or announced by the issuing authority.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Regulatory Document Url' ;
    rdfs:comment 'URL or document repository link to the official regulatory text, guidance document, or announcement.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresLegalReview rdf:type rdf:Property ;
    rdfs:label 'Requires Legal Review' ;
    rdfs:comment 'Flag indicating whether the regulatory change requires formal legal review and opinion before implementation.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresPlayerNotification rdf:type rdf:Property ;
    rdfs:label 'Requires Player Notification' ;
    rdfs:comment 'Flag indicating whether the regulatory change requires direct notification or communication to players (e.g., updated terms of service, privacy policy changes).' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresPolicyUpdate rdf:type rdf:Property ;
    rdfs:label 'Requires Policy Update' ;
    rdfs:comment 'Flag indicating whether the regulatory change requires updates to internal policies, procedures, or governance documentation.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresSystemChanges rdf:type rdf:Property ;
    rdfs:label 'Requires System Changes' ;
    rdfs:comment 'Flag indicating whether the regulatory change requires modifications to game engines, platforms, or operational systems.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsePlanStatus rdf:type rdf:Property ;
    rdfs:label 'Response Plan Status' ;
    rdfs:comment 'Current status of the internal response plan to address the regulatory change.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentOfFilingId rdf:type rdf:Property ;
    rdfs:label 'Amendment Of Filing Id' ;
    rdfs:comment 'Identifier of the original filing that this filing amends or supersedes. Null if this is an original filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFiling .

ind:responsiblePartyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Employee Id' ;
    rdfs:comment 'Identifier of the employee or compliance officer responsible for preparing and submitting this filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tournamentId rdf:type rdf:Property ;
    rdfs:label 'Tournament Id' ;
    rdfs:comment 'Foreign key linking to esports.tournament. Business justification: Regulatory filings for esports betting licenses, prize pool disclosures, and tournament compliance requirements should reference specific tournaments. Many jurisdictions require tournament-specific fi' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tournament .

ind:acknowledgementReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Receipt Date' ;
    rdfs:comment 'Date on which the regulatory authority formally acknowledged receipt of the filing. Null if not yet acknowledged.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ageRatingAssigned rdf:type rdf:Property ;
    rdfs:label 'Age Rating Assigned' ;
    rdfs:comment 'Age rating or content classification assigned by the rating board (e.g., ESRB: E, E10+, T, M, AO; PEGI: 3, 7, 12, 16, 18; CERO: A, B, C, D, Z). Null if filing is not an age rating submission or if not yet assigned.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentDescriptors rdf:type rdf:Property ;
    rdfs:label 'Content Descriptors' ;
    rdfs:comment 'Comma-separated list of content descriptors or warning labels assigned by the rating board (e.g., Violence, Blood, Strong Language, In-Game Purchases). Null if not applicable.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectRequestCount rdf:type rdf:Property ;
    rdfs:label 'Data Subject Request Count' ;
    rdfs:comment 'Number of data subject access requests, erasure requests, or portability requests covered by this filing (relevant for GDPR Article 30 or COPPA filings). Null if not applicable.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:esportsBettingLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Esports Betting License Number' ;
    rdfs:comment 'License or permit number issued by a gambling or gaming authority for esports betting operations. Null if filing is not esports betting compliance-related.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAuditFlag rdf:type rdf:Property ;
    rdfs:label 'External Audit Flag' ;
    rdfs:comment 'Boolean indicator of whether this filing has been reviewed by an external auditor or third-party compliance assessor. True if externally audited, False otherwise.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:filingDescription rdf:type rdf:Property ;
    rdfs:label 'Filing Description' ;
    rdfs:comment 'Detailed textual description of the filing content, purpose, and scope. May include summary of disclosures, data subject request details, or certification scope.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Filing Document Url' ;
    rdfs:comment 'Internal or external URL or storage path to the official filing document, submission package, or evidence bundle. Confidential.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Filing Reference Number' ;
    rdfs:comment 'External reference number or tracking identifier assigned by the regulatory authority or internal compliance system for this filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingStatus rdf:type rdf:Property ;
    rdfs:label 'Filing Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory filing (e.g., draft, submitted, under review, acknowledged, approved, rejected, withdrawn, amended). [ENUM-REF-CANDIDATE: draft|submitted|under_review|acknowledged|approved|rejected|withdrawn|amended — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingType rdf:type rdf:Property ;
    rdfs:label 'Filing Type' ;
    rdfs:comment 'Category of regulatory filing. Indicates the nature of the submission (e.g., loot box probability disclosure, GDPR Article 30 records of processing, COPPA verifiable parental consent, age rating submission to ESRB/PEGI/USK/CERO, financial regulatory disclosure, esports betting compliance).' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalAuditFlag rdf:type rdf:Property ;
    rdfs:label 'Internal Audit Flag' ;
    rdfs:comment 'Boolean indicator of whether this filing has been reviewed and validated by internal audit or compliance review. True if audited, False otherwise.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lootBoxDisclosureUrl rdf:type rdf:Property ;
    rdfs:label 'Loot Box Disclosure Url' ;
    rdfs:comment 'Public URL where loot box probability disclosures are published, as required by certain jurisdictions. Null if filing is not a loot box disclosure or if not yet published.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentalConsentMethod rdf:type rdf:Property ;
    rdfs:label 'Parental Consent Method' ;
    rdfs:comment 'Method used to obtain verifiable parental consent for COPPA compliance (e.g., credit card verification, government ID check, video conference, signed consent form). Null if filing is not COPPA-related.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'Monetary value of any fine or penalty imposed by the regulatory authority in connection with this filing. Null if no penalty was imposed.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the penalty amount (e.g., USD, EUR, GBP, JPY). Null if no penalty was imposed.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyImposedFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Imposed Flag' ;
    rdfs:comment 'Boolean indicator of whether a penalty, fine, or sanction was imposed as a result of this filing or related non-compliance. True if penalty imposed, False otherwise.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryResponseText rdf:type rdf:Property ;
    rdfs:label 'Regulatory Response Text' ;
    rdfs:comment 'Textual content of the official response, feedback, or decision issued by the regulatory authority. Null if no response has been received.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionDate rdf:type rdf:Property ;
    rdfs:label 'Rejection Date' ;
    rdfs:comment 'Date on which the regulatory authority rejected the filing. Null if not rejected.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditFrequency rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency' ;
    rdfs:comment 'Required or planned frequency of compliance audits for this obligation.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceOwner rdf:type rdf:Property ;
    rdfs:label 'Compliance Owner' ;
    rdfs:comment 'Name or identifier of the individual or team responsible for ensuring compliance with this obligation.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingBody rdf:type rdf:Property ;
    rdfs:label 'Governing Body' ;
    rdfs:comment 'Name of the regulatory authority or governing body that mandates this obligation (e.g., ESRB, PEGI, FTC, European Commission, GDPR Supervisory Authority).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Penalty Amount' ;
    rdfs:comment 'Maximum financial penalty amount in USD for non-compliance. NULL if penalty is not monetary or is variable.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextReportingDeadline rdf:type rdf:Property ;
    rdfs:label 'Next Reporting Deadline' ;
    rdfs:comment 'Next scheduled deadline for submitting compliance reports to the governing body.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:obligationCode rdf:type rdf:Property ;
    rdfs:label 'Obligation Code' ;
    rdfs:comment 'Unique business identifier code for the regulatory obligation (e.g., GDPR-ART17, COPPA-CONSENT, LOOTBOX-DISC-EU).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationDescription rdf:type rdf:Property ;
    rdfs:label 'Obligation Description' ;
    rdfs:comment 'Detailed description of what the regulatory obligation requires Gaming to do or refrain from doing.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationName rdf:type rdf:Property ;
    rdfs:label 'Obligation Name' ;
    rdfs:comment 'Full descriptive name of the regulatory obligation (e.g., Right to Erasure, Parental Consent Requirement, Loot Box Probability Disclosure).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationType rdf:type rdf:Property ;
    rdfs:label 'Obligation Type' ;
    rdfs:comment 'Category of regulatory obligation defining the compliance domain.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyDescription rdf:type rdf:Property ;
    rdfs:label 'Penalty Description' ;
    rdfs:comment 'Description of the financial, operational, or reputational penalties for non-compliance (e.g., fines up to 4% of global revenue, platform removal, criminal liability).' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'Frequency at which compliance status must be reported to the governing body or internal stakeholders.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationActionId rdf:type rdf:Property ;
    rdfs:label 'Remediation Action Id' ;
    rdfs:comment 'Unique identifier for the remediation action record. Primary key for the remediation action entity.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RemediationAction .

ind:affectedGameTitleId rdf:type rdf:Property ;
    rdfs:label 'Affected Game Title Id' ;
    rdfs:comment 'Reference to the game title affected by the compliance issue and remediation action. Null if action is enterprise-wide or not game-specific.' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GameTitle .

ind:primaryRemediationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Remediation Employee Id' ;
    rdfs:comment 'Reference to the employee or team responsible for executing and completing the remediation action. Accountable party for delivery.' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryRemediationLastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Remediation Last Modified By Employee Id' ;
    rdfs:comment 'Reference to the employee who last modified the remediation action record. Provides audit trail for changes.' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:remediationCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Remediation Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Remediation actions have actual costs (estimated_cost, actual_cost fields present) that must be allocated to cost centers for financial tracking. Gaming companies budget for compliance remediation and' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:tertiaryRemediationCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Remediation Created By Employee Id' ;
    rdfs:comment 'Reference to the employee who created the remediation action record. Provides accountability for action initiation.' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionDescription rdf:type rdf:Property ;
    rdfs:label 'Action Description' ;
    rdfs:comment 'Detailed description of the remediation action plan, including specific steps, scope, and expected outcomes. Provides full context for execution.' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionNumber rdf:type rdf:Property ;
    rdfs:label 'Action Number' ;
    rdfs:comment 'Business-facing unique identifier for the remediation action, used for tracking and reporting. Format: REM-NNNNNN.' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionTitle rdf:type rdf:Property ;
    rdfs:label 'Action Title' ;
    rdfs:comment 'Short descriptive title summarizing the remediation action. Used for quick identification in dashboards and reports.' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'Date when the remediation action was actually completed and closed. Null if action is still open or in progress.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'Actual financial cost incurred to complete the remediation action. Null if action is not yet completed or cost not yet finalized.' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedDepartment rdf:type rdf:Property ;
    rdfs:label 'Assigned Department' ;
    rdfs:comment 'Business department or functional area responsible for executing the remediation action (e.g., Legal, IT Security, Player Support, Game Operations).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for estimated and actual costs (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost' ;
    rdfs:comment 'Estimated financial cost to implement the remediation action, including labor, technology, legal, and operational expenses. Used for budgeting and risk assessment.' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evidenceDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Evidence Document Reference' ;
    rdfs:comment 'Reference identifier or URI to the supporting documentation that evidences completion of the remediation action (e.g., policy document version, system change ticket, training completion report, payment receipt).' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalConsultantEngaged rdf:type rdf:Property ;
    rdfs:label 'External Consultant Engaged' ;
    rdfs:comment 'Boolean flag indicating whether external legal, compliance, or technical consultants were engaged to support the remediation action.' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Business priority level for completing the remediation action, reflecting urgency and risk exposure. Critical actions require immediate attention, high within days, medium within weeks, low within months.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrencePreventionPlan rdf:type rdf:Property ;
    rdfs:label 'Recurrence Prevention Plan' ;
    rdfs:comment 'Description of measures implemented to prevent recurrence of the compliance issue, including process changes, controls, and monitoring enhancements.' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'Primary regulatory framework or standard governing this remediation action: GDPR (General Data Protection Regulation), COPPA (Children\'s Online Privacy Protection Act), ESRB (Entertainment Software Rating Board), PEGI (Pan European Game Information), CERO (Computer Entertainment Rating Organization), FTC (Federal Trade Commission), PCI_DSS (Payment Card Industry Data Security Standard), CCPA (California Consumer Privacy Act), or other. [ENUM-REF-CANDIDATE: GDPR|COPPA|ESRB|PEGI|CERO|FTC|PCI_DSS|CCPA|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationActionStatus rdf:type rdf:Property ;
    rdfs:label 'Remediation Action Status' ;
    rdfs:comment 'Current lifecycle status of the remediation action: open (not yet started), in_progress (work underway), completed (action finished but not yet verified), verified (completion confirmed by compliance team), cancelled (action no longer required), overdue (past target completion date).' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationType rdf:type rdf:Property ;
    rdfs:label 'Remediation Type' ;
    rdfs:comment 'Classification of the remediation action by the nature of the corrective measure: process change (operational procedure update), technical control (system or security enhancement), policy update (documentation or governance change), player notification (communication to affected users), regulatory payment (fine or penalty settlement), or training (staff education program).' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskLevelAfter rdf:type rdf:Property ;
    rdfs:label 'Risk Level After' ;
    rdfs:comment 'Assessed risk level of the compliance issue after remediation action was completed and verified. Null if action not yet verified.' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskLevelBefore rdf:type rdf:Property ;
    rdfs:label 'Risk Level Before' ;
    rdfs:comment 'Assessed risk level of the compliance issue before remediation action was implemented. Used to measure risk reduction effectiveness.' ;
    rdfs:domain ind:RemediationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'Planned or mandated date by which the remediation action must be completed. May be set by regulatory authority or internal risk assessment.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicableRegulations rdf:type rdf:Property ;
    rdfs:label 'Applicable Regulations' ;
    rdfs:comment 'Comma-separated list of regulations and compliance frameworks applicable to this screening (e.g., OFAC, EU Sanctions, UN Sanctions, AML, CFT, EAR, ITAR).' ;
    rdfs:domain ind:SanctionsScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyReference rdf:type rdf:Property ;
    rdfs:label 'Counterparty Reference' ;
    rdfs:comment 'Reference to the business counterparty (vendor, partner, licensee) that was screened, if applicable.' ;
    rdfs:domain ind:SanctionsScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:determinationDate rdf:type rdf:Property ;
    rdfs:label 'Determination Date' ;
    rdfs:comment 'Date when the final disposition decision was made and documented.' ;
    rdfs:domain ind:SanctionsScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposition rdf:type rdf:Property ;
    rdfs:label 'Disposition' ;
    rdfs:comment 'Final disposition or action taken based on the screening result.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionReason rdf:type rdf:Property ;
    rdfs:label 'Disposition Reason' ;
    rdfs:comment 'Explanation or justification for the disposition decision, including any mitigating factors or additional evidence reviewed.' ;
    rdfs:domain ind:SanctionsScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportControlFlag rdf:type rdf:Property ;
    rdfs:label 'Export Control Flag' ;
    rdfs:comment 'Flag indicating whether this screening was performed for export control compliance purposes related to game engine technology or other controlled exports.' ;
    rdfs:domain ind:SanctionsScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exportLicenseRequired rdf:type rdf:Property ;
    rdfs:label 'Export License Required' ;
    rdfs:comment 'Flag indicating whether an export license is required for the transaction or relationship based on the screening result.' ;
    rdfs:domain ind:SanctionsScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchDetails rdf:type rdf:Property ;
    rdfs:label 'Match Details' ;
    rdfs:comment 'Detailed information about the match including matched list name, matched entity name, match criteria, and any aliases or identifiers that triggered the match.' ;
    rdfs:domain ind:SanctionsScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchScore rdf:type rdf:Property ;
    rdfs:label 'Match Score' ;
    rdfs:comment 'Numerical confidence score (0-100) indicating the likelihood that the screened entity matches a sanctioned party, as calculated by the screening system.' ;
    rdfs:domain ind:SanctionsScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchStatus rdf:type rdf:Property ;
    rdfs:label 'Match Status' ;
    rdfs:comment 'Result of the sanctions screening indicating whether the entity matched any sanctions list entries.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedEntityName rdf:type rdf:Property ;
    rdfs:label 'Matched Entity Name' ;
    rdfs:comment 'Name of the sanctioned entity from the list that matched the screened entity.' ;
    rdfs:domain ind:SanctionsScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedListName rdf:type rdf:Property ;
    rdfs:label 'Matched List Name' ;
    rdfs:comment 'Name of the specific sanctions or restricted party list on which a match was found.' ;
    rdfs:domain ind:SanctionsScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresSarFiling rdf:type rdf:Property ;
    rdfs:label 'Requires Sar Filing' ;
    rdfs:comment 'Flag indicating whether this screening result requires filing a Suspicious Activity Report with financial authorities.' ;
    rdfs:domain ind:SanctionsScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Timestamp' ;
    rdfs:comment 'Date and time when the compliance officer completed their review of the screening result.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewingOfficerName rdf:type rdf:Property ;
    rdfs:label 'Reviewing Officer Name' ;
    rdfs:comment 'Name of the compliance officer who reviewed and adjudicated the screening result.' ;
    rdfs:domain ind:SanctionsScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sarFilingDate rdf:type rdf:Property ;
    rdfs:label 'Sar Filing Date' ;
    rdfs:comment 'Date when the Suspicious Activity Report was filed with the appropriate financial authority, if applicable.' ;
    rdfs:domain ind:SanctionsScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sarReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sar Reference Number' ;
    rdfs:comment 'Reference number assigned to the filed Suspicious Activity Report by the financial authority.' ;
    rdfs:domain ind:SanctionsScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenedEntityCountry rdf:type rdf:Property ;
    rdfs:label 'Screened Entity Country' ;
    rdfs:comment 'Three-letter ISO country code representing the country of residence or registration of the screened entity.' ;
    rdfs:domain ind:SanctionsScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenedEntityIdentifier rdf:type rdf:Property ;
    rdfs:label 'Screened Entity Identifier' ;
    rdfs:comment 'Unique identifier of the screened entity such as national ID, passport number, tax ID, or business registration number.' ;
    rdfs:domain ind:SanctionsScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenedEntityName rdf:type rdf:Property ;
    rdfs:label 'Screened Entity Name' ;
    rdfs:comment 'Name of the entity (individual or organization) that was screened against sanctions lists.' ;
    rdfs:domain ind:SanctionsScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenedEntityType rdf:type rdf:Property ;
    rdfs:label 'Screened Entity Type' ;
    rdfs:comment 'Type of entity that was subjected to sanctions screening.' ;
    rdfs:domain ind:SanctionsScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningListsChecked rdf:type rdf:Property ;
    rdfs:label 'Screening Lists Checked' ;
    rdfs:comment 'Comma-separated list of sanctions and restricted party lists checked during this screening (e.g., OFAC SDN, EU Consolidated Sanctions List, UN Security Council Sanctions, EAR, ITAR).' ;
    rdfs:domain ind:SanctionsScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningMethod rdf:type rdf:Property ;
    rdfs:label 'Screening Method' ;
    rdfs:comment 'Method used to perform the screening check.' ;
    rdfs:domain ind:SanctionsScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningProvider rdf:type rdf:Property ;
    rdfs:label 'Screening Provider' ;
    rdfs:comment 'Name of the third-party screening service or internal system that performed the sanctions check.' ;
    rdfs:domain ind:SanctionsScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Screening Reference Number' ;
    rdfs:comment 'External reference number or case identifier assigned by the screening system or compliance platform.' ;
    rdfs:domain ind:SanctionsScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningTimestamp rdf:type rdf:Property ;
    rdfs:label 'Screening Timestamp' ;
    rdfs:comment 'Date and time when the sanctions screening check was performed.' ;
    rdfs:domain ind:SanctionsScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:screeningTrigger rdf:type rdf:Property ;
    rdfs:label 'Screening Trigger' ;
    rdfs:comment 'Event or action that triggered the sanctions screening check (e.g., new account registration, payment processing, counterparty onboarding, periodic review).' ;
    rdfs:domain ind:SanctionsScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendLimitControlId rdf:type rdf:Property ;
    rdfs:label 'Spend Limit Control Id' ;
    rdfs:comment 'Unique identifier for the spend limit control record.' ;
    rdfs:domain ind:SpendLimitControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableMtxCategories rdf:type rdf:Property ;
    rdfs:label 'Applicable Mtx Categories' ;
    rdfs:comment 'Comma-separated list of microtransaction or in-app purchase (IAP) categories subject to this limit (e.g., loot_boxes, virtual_currency, cosmetics, battle_pass). Null or \'ALL\' indicates all MTX types are covered.' ;
    rdfs:domain ind:SpendLimitControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailUrl rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Url' ;
    rdfs:comment 'URL or reference to the detailed audit trail or documentation supporting this spending limit control for regulatory compliance and audit purposes.' ;
    rdfs:domain ind:SpendLimitControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachCount rdf:type rdf:Property ;
    rdfs:label 'Breach Count' ;
    rdfs:comment 'Number of times the player has attempted to exceed this spending limit, used for compliance monitoring and escalation.' ;
    rdfs:domain ind:SpendLimitControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:controlReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Control Reference Number' ;
    rdfs:comment 'External reference number or code assigned to this spending limit control for tracking and audit purposes.' ;
    rdfs:domain ind:SpendLimitControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlSource rdf:type rdf:Property ;
    rdfs:label 'Control Source' ;
    rdfs:comment 'Origin or authority that established this spending limit: regulatory mandate, player self-set preference, parental control, platform policy, court order, or third-party exclusion program (e.g., GamStop).' ;
    rdfs:domain ind:SpendLimitControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlType rdf:type rdf:Property ;
    rdfs:label 'Control Type' ;
    rdfs:comment 'Classification of the spending limit control mechanism: mandatory regulatory cap imposed by law, voluntary self-exclusion set by player, parental spending limit for minor accounts, platform-imposed cap, temporary cooling-off period, or permanent exclusion.' ;
    rdfs:domain ind:SpendLimitControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coolingOffPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Cooling Off Period Days' ;
    rdfs:comment 'Number of days the player must wait before a self-imposed spending limit can be increased or removed, as required by responsible gaming regulations.' ;
    rdfs:domain ind:SpendLimitControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentPeriodSpend rdf:type rdf:Property ;
    rdfs:label 'Current Period Spend' ;
    rdfs:comment 'Total amount spent by the player within the current limit period, used to track proximity to the limit threshold.' ;
    rdfs:domain ind:SpendLimitControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enforcementStatus rdf:type rdf:Property ;
    rdfs:label 'Enforcement Status' ;
    rdfs:comment 'Current enforcement state of the spending limit control: active and enforced, suspended temporarily, expired, revoked, pending activation, or in cooling-off period.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastBreachTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Breach Timestamp' ;
    rdfs:comment 'Timestamp of the most recent attempt to breach the spending limit.' ;
    rdfs:domain ind:SpendLimitControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:limitAmount rdf:type rdf:Property ;
    rdfs:label 'Limit Amount' ;
    rdfs:comment 'Maximum spending amount allowed within the specified limit period, expressed in the local currency of the jurisdiction.' ;
    rdfs:domain ind:SpendLimitControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:limitCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Limit Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the limit amount (e.g., EUR, GBP, USD).' ;
    rdfs:domain ind:SpendLimitControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitPeriod rdf:type rdf:Property ;
    rdfs:label 'Limit Period' ;
    rdfs:comment 'Time period over which the spending limit is enforced: daily, weekly, monthly, quarterly, annual, lifetime, or per-session. [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|annual|lifetime|per_session — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SpendLimitControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modificationEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Modification Effective Date' ;
    rdfs:comment 'Date when a requested modification to the spending limit will take effect, accounting for any mandatory cooling-off period.' ;
    rdfs:domain ind:SpendLimitControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modificationRequestDate rdf:type rdf:Property ;
    rdfs:label 'Modification Request Date' ;
    rdfs:comment 'Date when the player requested a modification to the spending limit (increase, decrease, or removal).' ;
    rdfs:domain ind:SpendLimitControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overrideAuthorizedBy rdf:type rdf:Property ;
    rdfs:label 'Override Authorized By' ;
    rdfs:comment 'Name or identifier of the authorized personnel who approved any override or exception to the spending limit control.' ;
    rdfs:domain ind:SpendLimitControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideTimestamp rdf:type rdf:Property ;
    rdfs:label 'Override Timestamp' ;
    rdfs:comment 'Timestamp when an override or exception to the spending limit control was authorized and applied.' ;
    rdfs:domain ind:SpendLimitControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'End date of the current limit period, after which the spend counter resets for recurring periods.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'Start date of the current limit period for tracking spend accumulation.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:playerAcknowledgmentRequired rdf:type rdf:Property ;
    rdfs:label 'Player Acknowledgment Required' ;
    rdfs:comment 'Indicates whether the player is required to explicitly acknowledge and accept the spending limit control.' ;
    rdfs:domain ind:SpendLimitControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:playerAcknowledgmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Player Acknowledgment Timestamp' ;
    rdfs:comment 'Timestamp when the player acknowledged the spending limit control.' ;
    rdfs:domain ind:SpendLimitControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:thirdPartyProcessorId rdf:type rdf:Property ;
    rdfs:label 'Third Party Processor Id' ;
    rdfs:comment 'Unique identifier for the third-party data processor or sub-processor record.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ThirdPartyProcessor .

ind:annualContractValue rdf:type rdf:Property ;
    rdfs:label 'Annual Contract Value' ;
    rdfs:comment 'The total annual contract value in USD for services provided by this processor.' ;
    rdfs:domain ind:ThirdPartyProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditReportUrl rdf:type rdf:Property ;
    rdfs:label 'Audit Report Url' ;
    rdfs:comment 'URL or document reference to the most recent audit report or security assessment for this processor.' ;
    rdfs:domain ind:ThirdPartyProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpaCompliant rdf:type rdf:Property ;
    rdfs:label 'Ccpa Compliant' ;
    rdfs:comment 'Indicates whether the processor is contractually committed to CCPA compliance for processing California resident data.' ;
    rdfs:domain ind:ThirdPartyProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'The date on which the service contract with this processor expires or is scheduled for renewal.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'The date on which the service contract with this processor became effective.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coppaCompliant rdf:type rdf:Property ;
    rdfs:label 'Coppa Compliant' ;
    rdfs:comment 'Indicates whether the processor is certified or contractually committed to COPPA compliance for processing data of children under 13.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataBreachNotificationEmail rdf:type rdf:Property ;
    rdfs:label 'Data Breach Notification Email' ;
    rdfs:comment 'Dedicated email address for receiving data breach notifications from this processor as required by GDPR Article 33.' ;
    rdfs:domain ind:ThirdPartyProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCategoriesShared rdf:type rdf:Property ;
    rdfs:label 'Data Categories Shared' ;
    rdfs:comment 'Comma-separated list of personal data categories shared with this processor (e.g., player identifiers, device IDs, gameplay telemetry, payment information, support tickets, email addresses).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProcessingLocation rdf:type rdf:Property ;
    rdfs:label 'Data Processing Location' ;
    rdfs:comment 'Primary geographic location or region where the processor stores and processes player data (e.g., EU, USA, Asia-Pacific). Critical for GDPR transfer mechanism compliance.' ;
    rdfs:domain ind:ThirdPartyProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpaExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Dpa Execution Date' ;
    rdfs:comment 'The date on which the Data Processing Agreement was signed and became effective.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dpaExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Dpa Expiry Date' ;
    rdfs:comment 'The date on which the Data Processing Agreement expires or requires renewal. Null if the agreement is perpetual or tied to service contract.' ;
    rdfs:domain ind:ThirdPartyProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dpaReference rdf:type rdf:Property ;
    rdfs:label 'Dpa Reference' ;
    rdfs:comment 'Reference number or identifier of the executed Data Processing Agreement (DPA) or Data Processing Addendum governing the processor relationship.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpoEmail rdf:type rdf:Property ;
    rdfs:label 'Dpo Email' ;
    rdfs:comment 'Email address of the Data Protection Officer at the processor organization.' ;
    rdfs:domain ind:ThirdPartyProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsrResponseSlaHours rdf:type rdf:Property ;
    rdfs:label 'Dsr Response Sla Hours' ;
    rdfs:comment 'The contractual Service Level Agreement (SLA) in hours for the processor to respond to Data Subject Requests.' ;
    rdfs:domain ind:ThirdPartyProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gdprCompliant rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliant' ;
    rdfs:comment 'Indicates whether the processor is contractually committed to GDPR compliance for processing EU player data.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastDueDiligenceDate rdf:type rdf:Property ;
    rdfs:label 'Last Due Diligence Date' ;
    rdfs:comment 'The date of the most recent due diligence review or security assessment conducted on this processor.' ;
    rdfs:domain ind:ThirdPartyProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextDueDiligenceDate rdf:type rdf:Property ;
    rdfs:label 'Next Due Diligence Date' ;
    rdfs:comment 'The scheduled date for the next due diligence review or security assessment of this processor.' ;
    rdfs:domain ind:ThirdPartyProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Email address of the primary contact person at the processor organization.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary contact person at the processor organization for data protection and compliance matters.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Phone number of the primary contact person at the processor organization.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privacyPolicyUrl rdf:type rdf:Property ;
    rdfs:label 'Privacy Policy Url' ;
    rdfs:comment 'URL to the processors public privacy policy or data protection documentation.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processorCode rdf:type rdf:Property ;
    rdfs:label 'Processor Code' ;
    rdfs:comment 'Internal unique code or identifier assigned to the processor for reference in contracts and systems.' ;
    rdfs:domain ind:ThirdPartyProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processorName rdf:type rdf:Property ;
    rdfs:label 'Processor Name' ;
    rdfs:comment 'The legal business name of the third-party data processor or sub-processor organization.' ;
    rdfs:domain ind:ThirdPartyProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processorRiskRating rdf:type rdf:Property ;
    rdfs:label 'Processor Risk Rating' ;
    rdfs:comment 'The assessed risk level of this processor based on data sensitivity, volume, jurisdictional risk, and security posture.' ;
    rdfs:domain ind:ThirdPartyProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processorStatus rdf:type rdf:Property ;
    rdfs:label 'Processor Status' ;
    rdfs:comment 'Current lifecycle status of the processor relationship.' ;
    rdfs:domain ind:ThirdPartyProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processorType rdf:type rdf:Property ;
    rdfs:label 'Processor Type' ;
    rdfs:comment 'The category of service provided by the processor. [ENUM-REF-CANDIDATE: analytics_sdk|ad_network|cloud_provider|payment_processor|customer_support_platform|marketing_automation|cdn|drm_provider|anti_cheat_service|email_service|sms_gateway|push_notification_service|crash_reporting|ab_testing_platform — promote to reference product]' ;
    rdfs:domain ind:ThirdPartyProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityCertification rdf:type rdf:Property ;
    rdfs:label 'Security Certification' ;
    rdfs:comment 'Comma-separated list of security and compliance certifications held by the processor (e.g., ISO 27001, SOC 2 Type II, PCI DSS, ISO 27018, CSA STAR).' ;
    rdfs:domain ind:ThirdPartyProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicesProvided rdf:type rdf:Property ;
    rdfs:label 'Services Provided' ;
    rdfs:comment 'Detailed description of the data processing services provided by this processor (e.g., player behavior analytics, payment processing, cloud hosting, customer support ticketing).' ;
    rdfs:domain ind:ThirdPartyProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subProcessorListUrl rdf:type rdf:Property ;
    rdfs:label 'Sub Processor List Url' ;
    rdfs:comment 'URL to the processors publicly available or contractually provided list of sub-processors they engage to process player data.' ;
    rdfs:domain ind:ThirdPartyProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportsDataPortability rdf:type rdf:Property ;
    rdfs:label 'Supports Data Portability' ;
    rdfs:comment 'Indicates whether the processor can export player data in a structured, commonly used, and machine-readable format to support GDPR data portability rights.' ;
    rdfs:domain ind:ThirdPartyProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsDsr rdf:type rdf:Property ;
    rdfs:label 'Supports Dsr' ;
    rdfs:comment 'Indicates whether the processor has technical and operational capability to support Data Subject Requests (access, erasure, portability) as required by GDPR.' ;
    rdfs:domain ind:ThirdPartyProcessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingCompletionId rdf:type rdf:Property ;
    rdfs:label 'Training Completion Id' ;
    rdfs:comment 'Unique identifier for the training completion record. Primary key.' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTrainingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Training Employee Id' ;
    rdfs:comment 'Reference to the employee or contractor who completed the training module.' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:trainingCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Training Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Compliance training costs (GDPR, COPPA, age rating, loot box disclosure training) are allocated to cost centers for budget tracking. Gaming companies track training spend per studio/department for com' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:trainingModuleId rdf:type rdf:Property ;
    rdfs:label 'Training Module Id' ;
    rdfs:comment 'Reference to the specific compliance training module completed.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingModule .

ind:applicableJurisdictionCodes rdf:type rdf:Property ;
    rdfs:label 'Applicable Jurisdiction Codes' ;
    rdfs:comment 'Comma-separated list of jurisdiction codes where this training compliance is applicable (e.g., USA, GBR, DEU, FRA).' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentMaxScore rdf:type rdf:Property ;
    rdfs:label 'Assessment Max Score' ;
    rdfs:comment 'Maximum possible score for the training assessment (typically 100).' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessmentScore rdf:type rdf:Property ;
    rdfs:label 'Assessment Score' ;
    rdfs:comment 'Numerical score achieved on the training assessment (e.g., 85.50 out of 100).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attemptNumber rdf:type rdf:Property ;
    rdfs:label 'Attempt Number' ;
    rdfs:comment 'Sequential attempt number for this training module (1 for first attempt, 2 for second, etc.).' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificateIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Issued Date' ;
    rdfs:comment 'Date when the completion certificate was issued to the employee.' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateReference rdf:type rdf:Property ;
    rdfs:label 'Certificate Reference' ;
    rdfs:comment 'Unique reference number or identifier for the completion certificate issued to the employee.' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateUrl rdf:type rdf:Property ;
    rdfs:label 'Certificate Url' ;
    rdfs:comment 'URL or file path to the digital certificate document stored in the document management system.' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'Date when the employee or contractor successfully completed the training module.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'Precise timestamp when the training module was completed, including time zone information.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mandatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Flag' ;
    rdfs:comment 'Indicates whether this training is mandatory (true) or optional (false) for the employee based on their role and jurisdiction.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextRenewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Renewal Due Date' ;
    rdfs:comment 'Date by which the employee must complete the next renewal of this training module. Null if no renewal required.' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:passFailStatus rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Status' ;
    rdfs:comment 'Outcome of the training assessment indicating whether the employee passed, failed, did not complete, or was waived from the requirement.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passingThreshold rdf:type rdf:Property ;
    rdfs:label 'Passing Threshold' ;
    rdfs:comment 'Minimum score required to pass the training assessment (e.g., 80.00).' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Frequency Months' ;
    rdfs:comment 'Number of months between required renewals for this training module (e.g., 12 for annual, 24 for biennial). Null if no renewal required.' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Required Flag' ;
    rdfs:comment 'Indicates whether this training requires periodic renewal (true) or is a one-time completion (false).' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roleRequirement rdf:type rdf:Property ;
    rdfs:label 'Role Requirement' ;
    rdfs:comment 'Job role or function for which this training is required (e.g., All Employees, Game Developers, Marketing, Customer Support, Finance).' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCategory rdf:type rdf:Property ;
    rdfs:label 'Training Category' ;
    rdfs:comment 'Category of compliance training (data privacy, child protection, anti-bribery, sanctions, responsible gaming, loot box regulation, other). [ENUM-REF-CANDIDATE: data_privacy|child_protection|anti_bribery|sanctions|responsible_gaming|loot_box_regulation|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Training Delivery Method' ;
    rdfs:comment 'Method by which the training was delivered (online, instructor-led, blended, self-paced, webinar, workshop).' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingModuleName rdf:type rdf:Property ;
    rdfs:label 'Training Module Name' ;
    rdfs:comment 'Name of the compliance training module (e.g., GDPR Awareness, COPPA Handling, Anti-Bribery FCPA/UK Bribery Act, Sanctions Compliance, Responsible Gaming, Loot Box Regulatory Training).' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingProvider rdf:type rdf:Property ;
    rdfs:label 'Training Provider' ;
    rdfs:comment 'Name of the organization or vendor that provided the training content (internal or external provider).' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingVersion rdf:type rdf:Property ;
    rdfs:label 'Training Version' ;
    rdfs:comment 'Version identifier of the training module content completed (e.g., v2.1, 2024-Q1).' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Approval Date' ;
    rdfs:comment 'Date when the training waiver was approved. Null if not waived.' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved By' ;
    rdfs:comment 'Name or identifier of the compliance officer or manager who approved the training waiver. Null if not waived.' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverReason rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason' ;
    rdfs:comment 'Explanation for why the training requirement was waived for this employee (e.g., prior certification, role exemption). Null if not waived.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAssetId rdf:type rdf:Property ;
    rdfs:label 'Parent Asset Id' ;
    rdfs:comment 'Reference to the parent or base asset ID if this asset is a variant (LOD variant, locale variant, platform variant). Null for base assets.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:assetCode rdf:type rdf:Property ;
    rdfs:label 'Asset Code' ;
    rdfs:comment 'Unique business identifier or SKU (Stock Keeping Unit) for the asset used across development tools and pipelines.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Description' ;
    rdfs:comment 'Detailed textual description of the asset including its purpose, visual or audio characteristics, and usage notes for developers and artists.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetName rdf:type rdf:Property ;
    rdfs:label 'Asset Name' ;
    rdfs:comment 'Human-readable name of the digital asset as it appears in the content management system and game engine.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetType rdf:type rdf:Property ;
    rdfs:label 'Asset Type' ;
    rdfs:comment 'Classification of the digital asset by its primary content type in the game development pipeline. [ENUM-REF-CANDIDATE: art|audio|texture|mesh|animation|shader|vfx|ui_element|video|script — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioBitDepth rdf:type rdf:Property ;
    rdfs:label 'Audio Bit Depth' ;
    rdfs:comment 'Bit depth for audio assets (e.g., 16, 24). Applicable only to audio asset types. Affects dynamic range and audio fidelity.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:audioChannelConfig rdf:type rdf:Property ;
    rdfs:label 'Audio Channel Config' ;
    rdfs:comment 'Channel configuration for audio assets (mono, stereo, 5.1 surround, 7.1 surround, Dolby Atmos). Applicable only to audio asset types.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioMiddlewareFormat rdf:type rdf:Property ;
    rdfs:label 'Audio Middleware Format' ;
    rdfs:comment 'Audio middleware system format for the asset (Wwise, FMOD, Unity Audio, Unreal Audio, proprietary). Applicable only to audio asset types.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioSampleRateHz rdf:type rdf:Property ;
    rdfs:label 'Audio Sample Rate Hz' ;
    rdfs:comment 'Sample rate in Hertz for audio assets (e.g., 44100, 48000). Applicable only to audio asset types. Determines audio quality and file size.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cdnUrl rdf:type rdf:Property ;
    rdfs:label 'Cdn Url' ;
    rdfs:comment 'CDN (Content Delivery Network) URL or endpoint where the asset is hosted for distribution to players. Used for live-ops content delivery and patches.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationTags rdf:type rdf:Property ;
    rdfs:label 'Classification Tags' ;
    rdfs:comment 'Comma-separated or pipe-separated tags for categorizing the asset by genre, art style, feature area, platform, sensitivity, or other business dimensions. Enables search and filtering.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentHash rdf:type rdf:Property ;
    rdfs:label 'Content Hash' ;
    rdfs:comment 'Cryptographic hash (e.g., SHA-256) of the asset file content for integrity verification, deduplication, and change detection.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deprecatedDate rdf:type rdf:Property ;
    rdfs:label 'Deprecated Date' ;
    rdfs:comment 'Date when the asset was marked as deprecated and scheduled for removal from active use.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drmProtected rdf:type rdf:Property ;
    rdfs:label 'Drm Protected' ;
    rdfs:comment 'Boolean flag indicating whether the asset is protected by DRM (Digital Rights Management) technology (True) or is unprotected (False).' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:engineCompatibility rdf:type rdf:Property ;
    rdfs:label 'Engine Compatibility' ;
    rdfs:comment 'Game engine(s) with which this asset is compatible (Unity, Unreal Engine, proprietary engine, or cross-engine).' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureArea rdf:type rdf:Property ;
    rdfs:label 'Feature Area' ;
    rdfs:comment 'Game feature or system area where the asset is used (e.g., combat, UI, environment, character, vehicle). Aligns with game design documentation.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:format rdf:type rdf:Property ;
    rdfs:label 'Format' ;
    rdfs:comment 'File format or extension of the asset (e.g., PNG, FBX, WAV, MP4, JSON). Determines compatibility with game engines and platforms.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipRightsStatus rdf:type rdf:Property ;
    rdfs:label 'Ip Rights Status' ;
    rdfs:comment 'Intellectual Property (IP) rights status of the asset indicating ownership or licensing arrangement (owned, licensed, third-party, public domain, pending clearance).' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLocaleVariant rdf:type rdf:Property ;
    rdfs:label 'Is Locale Variant' ;
    rdfs:comment 'Boolean flag indicating whether this asset is a locale-specific variant (True) or a locale-agnostic base asset (False).' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Modified Date' ;
    rdfs:comment 'Date when the asset was last modified or updated in the content pipeline.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'License Expiry Date' ;
    rdfs:comment 'Expiration date for licensed third-party assets. Null for owned or perpetual-license assets. Critical for compliance and content continuity.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current state of the asset in its content lifecycle from creation through deployment to retirement.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lodTier rdf:type rdf:Property ;
    rdfs:label 'Lod Tier' ;
    rdfs:comment 'LOD (Level of Detail) tier indicating the quality/complexity variant of the asset for performance optimization across different hardware capabilities.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perforceDepotPath rdf:type rdf:Property ;
    rdfs:label 'Perforce Depot Path' ;
    rdfs:comment 'Full depot path in Perforce Helix Core version control system where the asset is stored. Authoritative source location for the asset file.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionSpec rdf:type rdf:Property ;
    rdfs:label 'Resolution Spec' ;
    rdfs:comment 'Resolution or quality specification for visual and audio assets (e.g., 1920x1080, 4K, 48kHz/16-bit). Used for LOD (Level of Detail) management and platform targeting.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedLocales rdf:type rdf:Property ;
    rdfs:label 'Supported Locales' ;
    rdfs:comment 'Comma-separated or pipe-separated list of locale codes (e.g., en-US, fr-FR, ja-JP) for which this asset has localized variants or is applicable. Used for localization targeting.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ugcFlag rdf:type rdf:Property ;
    rdfs:label 'Ugc Flag' ;
    rdfs:comment 'Boolean flag indicating whether this asset is User-Generated Content (UGC) created by players (True) or first-party content created by the studio (False).' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creationDate rdf:type rdf:Property ;
    rdfs:label 'Creation Date' ;
    rdfs:comment 'Date when the asset was first created or ingested into the content management system.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capexProjectId rdf:type rdf:Property ;
    rdfs:label 'Capex Project Id' ;
    rdfs:comment 'Foreign key linking to finance.capex_project. Business justification: Asset bundles represent deliverable units that trigger capitalization milestones and amortization start dates. Finance tracks bundle certification and release dates to determine when development costs' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapexProject .

ind:cdnNodeId rdf:type rdf:Property ;
    rdfs:label 'Cdn Node Id' ;
    rdfs:comment 'Foreign key linking to infrastructure.cdn_node. Business justification: Asset bundles are distributed via CDN nodes for player downloads. CDN operators track which bundles are cached on which nodes to optimize cache hit ratios, plan bandwidth allocation, and diagnose down' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CdnNode .

ind:perforceChangelistId rdf:type rdf:Property ;
    rdfs:label 'Perforce Changelist Id' ;
    rdfs:comment 'Perforce Helix Core changelist number associated with this bundle version, enabling traceability to source control commits and asset pipeline history.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Changelist .

ind:primaryAssetEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Asset Employee Id' ;
    rdfs:comment 'Foreign key reference to the workforce user who created this asset bundle record. Used for accountability and audit trail.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:serverFleetId rdf:type rdf:Property ;
    rdfs:label 'Server Fleet Id' ;
    rdfs:comment 'Foreign key linking to infrastructure.server_fleet. Business justification: Asset bundles are deployed to server fleets as atomic content units. Fleet operators track which bundle versions are active on each fleet to coordinate staged rollouts, diagnose version conflicts, and' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServerFleet .

ind:assetCount rdf:type rdf:Property ;
    rdfs:label 'Asset Count' ;
    rdfs:comment 'Total number of individual assets (textures, models, audio files, localization strings, etc.) packaged within this bundle.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:buildConfiguration rdf:type rdf:Property ;
    rdfs:label 'Build Configuration' ;
    rdfs:comment 'Build configuration type for the bundle: debug (internal testing with symbols), development (QA testing), shipping (release candidate), gold_master (final approved build for distribution).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleCode rdf:type rdf:Property ;
    rdfs:label 'Bundle Code' ;
    rdfs:comment 'Unique business identifier or SKU (Stock Keeping Unit) for the asset bundle used in distribution and tracking systems.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleName rdf:type rdf:Property ;
    rdfs:label 'Bundle Name' ;
    rdfs:comment 'Human-readable name of the asset bundle (e.g., \'Winter Event 2024\', \'Patch 1.5.3\', \'Console Launch DLC\').' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleStatus rdf:type rdf:Property ;
    rdfs:label 'Bundle Status' ;
    rdfs:comment 'Current lifecycle state of the asset bundle: draft (initial creation), in_development (active work), qa_testing (quality assurance review), approved (ready for release), published (live in production), deprecated (retired from use).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleType rdf:type rdf:Property ;
    rdfs:label 'Bundle Type' ;
    rdfs:comment 'Classification of the asset bundle by delivery purpose: base game (initial release), DLC (Downloadable Content), hotfix (urgent fix), patch (scheduled update), seasonal event (limited-time content), or expansion (major content addition).' ;
    rdfs:domain ind:AssetBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnDistributionPath rdf:type rdf:Property ;
    rdfs:label 'Cdn Distribution Path' ;
    rdfs:comment 'URL or path on the CDN where the asset bundle is hosted for player download. Business-confidential to prevent unauthorized direct access.' ;
    rdfs:domain ind:AssetBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compressedSizeMb rdf:type rdf:Property ;
    rdfs:label 'Compressed Size Mb' ;
    rdfs:comment 'Total size of the asset bundle in megabytes after compression, used for CDN (Content Delivery Network) bandwidth planning and player download estimates.' ;
    rdfs:domain ind:AssetBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compressionFormat rdf:type rdf:Property ;
    rdfs:label 'Compression Format' ;
    rdfs:comment 'Compression algorithm used for the bundle (e.g., zip, gzip, lz4, zstd, proprietary engine format).' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deprecatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deprecated Timestamp' ;
    rdfs:comment 'Timestamp when the asset bundle was deprecated and removed from active distribution. Null if still active.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:encryptionEnabled rdf:type rdf:Property ;
    rdfs:label 'Encryption Enabled' ;
    rdfs:comment 'Indicates whether the asset bundle is encrypted to protect intellectual property (IP) and prevent unauthorized access or piracy. Aligns with DRM (Digital Rights Management) requirements.' ;
    rdfs:domain ind:AssetBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:errorRatePercent rdf:type rdf:Property ;
    rdfs:label 'Error Rate Percent' ;
    rdfs:comment 'Percentage of failed download attempts for this bundle, used to monitor CDN health and content delivery quality.' ;
    rdfs:domain ind:AssetBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localizationLanguages rdf:type rdf:Property ;
    rdfs:label 'Localization Languages' ;
    rdfs:comment 'Comma-separated list of language codes (ISO 639-1) for which localization strings are included in this bundle (e.g., \'en,es,fr,de,ja,zh\').' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lodVariantIncluded rdf:type rdf:Property ;
    rdfs:label 'Lod Variant Included' ;
    rdfs:comment 'Indicates whether this bundle includes multiple LOD (Level of Detail) variants of assets for performance optimization across different hardware tiers.' ;
    rdfs:domain ind:AssetBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manifestHash rdf:type rdf:Property ;
    rdfs:label 'Manifest Hash' ;
    rdfs:comment 'Cryptographic hash (e.g., SHA-256) of the bundle manifest file, used for integrity verification and version control in Perforce Helix Core and distribution systems.' ;
    rdfs:domain ind:AssetBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumEngineVersion rdf:type rdf:Property ;
    rdfs:label 'Minimum Engine Version' ;
    rdfs:comment 'Minimum version of the game engine (Unity, Unreal Engine, or proprietary) required to load and run this asset bundle. Ensures compatibility with the game client.' ;
    rdfs:domain ind:AssetBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Published Timestamp' ;
    rdfs:comment 'Timestamp when the asset bundle was published to production CDN and made available to players. Null if not yet published.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Planned or actual date when the asset bundle was or will be released to players. Used for live operations (live-ops) scheduling and content roadmap planning.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetPlatform rdf:type rdf:Property ;
    rdfs:label 'Target Platform' ;
    rdfs:comment 'Platform(s) this bundle is built for, pipe-separated if multi-platform (e.g., \'PC\', \'PlayStation 5\', \'Xbox Series X|S\', \'Nintendo Switch\', \'iOS\', \'Android\'). Aligns with first-party console manufacturer and mobile platform requirements.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ugcContentIncluded rdf:type rdf:Property ;
    rdfs:label 'Ugc Content Included' ;
    rdfs:comment 'Indicates whether this bundle includes UGC (User-Generated Content) that has passed moderation review. Important for content policy compliance and community management.' ;
    rdfs:domain ind:AssetBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:uncompressedSizeMb rdf:type rdf:Property ;
    rdfs:label 'Uncompressed Size Mb' ;
    rdfs:comment 'Total size of the asset bundle in megabytes after decompression on the player\'s device, used for storage requirement planning.' ;
    rdfs:domain ind:AssetBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetDependencyId rdf:type rdf:Property ;
    rdfs:label 'Asset Dependency Id' ;
    rdfs:comment 'Unique identifier for the asset dependency record. Primary key.' ;
    rdfs:domain ind:AssetDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceAssetId rdf:type rdf:Property ;
    rdfs:label 'Source Asset Id' ;
    rdfs:comment 'The asset that declares or originates the dependency relationship. This is the dependent asset that requires or references the target asset.' ;
    rdfs:domain ind:AssetDependency ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:targetAssetId rdf:type rdf:Property ;
    rdfs:label 'Target Asset Id' ;
    rdfs:comment 'The asset that is being depended upon. This is the asset that the source asset requires, references, or overrides.' ;
    rdfs:domain ind:AssetDependency ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:assetBundleInclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Asset Bundle Inclusion Flag' ;
    rdfs:comment 'Indicates whether both source and target assets must be included in the same asset bundle for runtime resolution. If true, the build pipeline ensures co-location.' ;
    rdfs:domain ind:AssetDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:buildOrderPriority rdf:type rdf:Property ;
    rdfs:label 'Build Order Priority' ;
    rdfs:comment 'Numeric priority used by the build pipeline to determine asset compilation order. Lower numbers are built first. Used to resolve dependency graphs and ensure targets are built before sources.' ;
    rdfs:domain ind:AssetDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:circularDependencyChain rdf:type rdf:Property ;
    rdfs:label 'Circular Dependency Chain' ;
    rdfs:comment 'If validation_status is circular, this field contains the chain of asset IDs forming the dependency loop (e.g., A->B->C->A). Used for debugging circular reference issues.' ;
    rdfs:domain ind:AssetDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependencyPath rdf:type rdf:Property ;
    rdfs:label 'Dependency Path' ;
    rdfs:comment 'The file system or depot path expression that defines how the source asset references the target. May include relative paths, symbolic references, or Perforce depot paths.' ;
    rdfs:domain ind:AssetDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependencyStrength rdf:type rdf:Property ;
    rdfs:label 'Dependency Strength' ;
    rdfs:comment 'Indicates whether the dependency is hard (required for build success) or soft (optional, build can proceed without it). Hard dependencies block builds if missing; soft dependencies generate warnings.' ;
    rdfs:domain ind:AssetDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependencyType rdf:type rdf:Property ;
    rdfs:label 'Dependency Type' ;
    rdfs:comment 'The nature of the dependency relationship between source and target assets. Defines how the source asset relates to the target asset in the build pipeline.' ;
    rdfs:domain ind:AssetDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deprecatedFlag rdf:type rdf:Property ;
    rdfs:label 'Deprecated Flag' ;
    rdfs:comment 'Indicates whether this dependency has been marked as deprecated and should be removed in future builds. Used to track technical debt and plan refactoring.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discoveredByTool rdf:type rdf:Property ;
    rdfs:label 'Discovered By Tool' ;
    rdfs:comment 'The name and version of the tool or system that discovered this dependency (e.g., Unity Asset Analyzer 2.1, Unreal Header Tool 5.3, Custom Dependency Scanner).' ;
    rdfs:domain ind:AssetDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryMethod rdf:type rdf:Property ;
    rdfs:label 'Discovery Method' ;
    rdfs:comment 'The method by which this dependency was identified. Static analysis scans code/assets automatically; manual declaration is explicitly defined by developers; runtime scan detects dependencies during execution.' ;
    rdfs:domain ind:AssetDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incrementalBuildFlag rdf:type rdf:Property ;
    rdfs:label 'Incremental Build Flag' ;
    rdfs:comment 'Indicates whether this dependency participates in incremental build scope computation. If true, changes to the target asset will trigger rebuild of the source asset.' ;
    rdfs:domain ind:AssetDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastValidatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Validated Timestamp' ;
    rdfs:comment 'The timestamp when this dependency was last validated by the build pipeline or asset integrity checker.' ;
    rdfs:domain ind:AssetDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lodVariantDependencyFlag rdf:type rdf:Property ;
    rdfs:label 'Lod Variant Dependency Flag' ;
    rdfs:comment 'Indicates whether this dependency is specific to a particular LOD (Level of Detail) variant. If true, the dependency applies only to specific quality tiers and may be stripped for lower-tier builds.' ;
    rdfs:domain ind:AssetDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:memoryImpactMb rdf:type rdf:Property ;
    rdfs:label 'Memory Impact Mb' ;
    rdfs:comment 'Estimated memory footprint in megabytes when both source and target assets are loaded simultaneously. Used for memory budget planning and optimization.' ;
    rdfs:domain ind:AssetDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformSpecificFlag rdf:type rdf:Property ;
    rdfs:label 'Platform Specific Flag' ;
    rdfs:comment 'Indicates whether this dependency is platform-specific (true) or applies across all platforms (false). Platform-specific dependencies are used for conditional asset stripping during packaging.' ;
    rdfs:domain ind:AssetDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:runtimeLoadOrder rdf:type rdf:Property ;
    rdfs:label 'Runtime Load Order' ;
    rdfs:comment 'Specifies the order in which assets should be loaded at runtime to satisfy this dependency. Lower numbers load first. Used by streaming systems and level loading.' ;
    rdfs:domain ind:AssetDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetPlatformCodes rdf:type rdf:Property ;
    rdfs:label 'Target Platform Codes' ;
    rdfs:comment 'Comma-separated list of platform codes for which this dependency applies (e.g., PC, PS5, XBOX, IOS, ANDROID). Empty if dependency applies to all platforms.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Current validation state of the dependency. Valid means target exists and is accessible; invalid indicates broken reference; missing-target means target asset not found; circular indicates dependency loop detected.' ;
    rdfs:domain ind:AssetDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionConstraint rdf:type rdf:Property ;
    rdfs:label 'Version Constraint' ;
    rdfs:comment 'Specifies version requirements for the target asset (e.g., >=2.0, ==1.5.3, ~>3.0). Used to ensure compatibility between dependent assets across versions.' ;
    rdfs:domain ind:AssetDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetReviewId rdf:type rdf:Property ;
    rdfs:label 'Asset Review Id' ;
    rdfs:comment 'Unique identifier for the asset review record. Primary key for the asset review entity.' ;
    rdfs:domain ind:AssetReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetVersionId rdf:type rdf:Property ;
    rdfs:label 'Asset Version Id' ;
    rdfs:comment 'Foreign key linking to content.asset_version. Business justification: Asset reviews are conducted on specific immutable asset versions (Perforce revisions). Currently asset_review has asset_id (asset-level) and asset_version (STRING). Adding FK to asset_version table en' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetVersion .

ind:complianceChecklistId rdf:type rdf:Property ;
    rdfs:label 'Compliance Checklist Id' ;
    rdfs:comment 'Identifier of the compliance checklist template used for this review, particularly for platform certification, legal clearance, and IP compliance reviews.' ;
    rdfs:domain ind:AssetReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CertificationChecklist .

ind:lodVariantId rdf:type rdf:Property ;
    rdfs:label 'Lod Variant Id' ;
    rdfs:comment 'Foreign key linking to content.lod_variant. Business justification: LOD variants require separate performance certification (polygon count, texture resolution, rendering distance validation). One review certifies ONE LOD variant; one LOD variant can have MANY reviews ' ;
    rdfs:domain ind:Content ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LodVariant .

ind:previousReviewId rdf:type rdf:Property ;
    rdfs:label 'Previous Review Id' ;
    rdfs:comment 'Identifier of the prior review record for this asset, creating a linked audit trail of iterative reviews and revisions through the pipeline.' ;
    rdfs:domain ind:AssetReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetReview .

ind:accessibilityComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Accessibility Compliance Flag' ;
    rdfs:comment 'Indicates whether the asset meets accessibility standards for inclusive design (true) or requires accessibility improvements (false), covering visual, auditory, and cognitive accessibility.' ;
    rdfs:domain ind:AssetReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:audioDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Audio Duration Seconds' ;
    rdfs:comment 'The duration of audio assets in seconds, applicable to sound effect, music, and voice-over reviews.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:automatedCheckPassed rdf:type rdf:Property ;
    rdfs:label 'Automated Check Passed' ;
    rdfs:comment 'Indicates whether automated validation checks (file format, naming convention, technical specs) passed (true) or failed (false) prior to manual review.' ;
    rdfs:domain ind:AssetReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockingIssuesCount rdf:type rdf:Property ;
    rdfs:label 'Blocking Issues Count' ;
    rdfs:comment 'The number of critical issues identified that must be resolved before the asset can proceed to the next pipeline stage.' ;
    rdfs:domain ind:AssetReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentPolicyViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Content Policy Violation Flag' ;
    rdfs:comment 'Indicates whether the asset violates community content policies (true) or is compliant (false), used in UGC moderation and legal clearance reviews.' ;
    rdfs:domain ind:AssetReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decision rdf:type rdf:Property ;
    rdfs:label 'Decision' ;
    rdfs:comment 'The outcome of the review: approved (asset passes and may proceed), rejected (asset fails and must be reworked), revision-required (specific changes needed), conditional-approval (approved with minor follow-up), deferred (decision postponed), escalated (requires higher authority).' ;
    rdfs:domain ind:AssetReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esrbRatingImpact rdf:type rdf:Property ;
    rdfs:label 'Esrb Rating Impact' ;
    rdfs:comment 'Assessment of how this asset may impact the games ESRB rating: none (no impact), mild (E/E10+ content), moderate (T content), mature (M content), ao-risk (potential AO rating risk).' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackNotes rdf:type rdf:Property ;
    rdfs:label 'Feedback Notes' ;
    rdfs:comment 'Detailed textual feedback provided by the reviewer, including observations, recommendations, and specific issues identified during the review.' ;
    rdfs:domain ind:AssetReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeMb rdf:type rdf:Property ;
    rdfs:label 'File Size Mb' ;
    rdfs:comment 'The file size of the asset in megabytes at the time of review, used to assess memory budget compliance and optimization requirements.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iterationNumber rdf:type rdf:Property ;
    rdfs:label 'Iteration Number' ;
    rdfs:comment 'The sequential iteration count for this asset at this pipeline stage, tracking how many review cycles have occurred (1 = first submission, 2+ = resubmissions after revisions).' ;
    rdfs:domain ind:AssetReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:jiraTicketKey rdf:type rdf:Property ;
    rdfs:label 'Jira Ticket Key' ;
    rdfs:comment 'The Jira ticket identifier associated with this review, linking the review to project management tracking, sprints, and bug reports.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localizationLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Localization Language Code' ;
    rdfs:comment 'The ISO 639-1 language code and ISO 3166-1 country code (e.g., en-US, ja-JP, de-DE) for localized assets, used in localization reviews.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lodVariant rdf:type rdf:Property ;
    rdfs:label 'Lod Variant' ;
    rdfs:comment 'The LOD variant of the asset being reviewed: lod0 (highest detail), lod1-4 (progressive simplification), billboard (lowest detail sprite), used for performance optimization across platforms.' ;
    rdfs:domain ind:AssetReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonBlockingIssuesCount rdf:type rdf:Property ;
    rdfs:label 'Non Blocking Issues Count' ;
    rdfs:comment 'The number of minor or advisory issues identified that should be addressed but do not prevent pipeline progression.' ;
    rdfs:domain ind:AssetReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pegiRatingImpact rdf:type rdf:Property ;
    rdfs:label 'Pegi Rating Impact' ;
    rdfs:comment 'Assessment of how this asset may impact the games PEGI rating: none (no impact), mild (PEGI 3/7 content), moderate (PEGI 12/16 content), mature (PEGI 18 content), restricted (potential classification issues).' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perforceChangelist rdf:type rdf:Property ;
    rdfs:label 'Perforce Changelist' ;
    rdfs:comment 'The Perforce Helix Core changelist number containing the asset version under review, providing version control traceability.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineStage rdf:type rdf:Property ;
    rdfs:label 'Pipeline Stage' ;
    rdfs:comment 'The stage in the content production pipeline where this review occurred: concept (initial ideation), blockout (rough layout), greybox (functional prototype), art-pass (visual polish), tech-art-review (technical validation), qa-review (quality assurance), certification (platform compliance), approved (production-ready), deprecated (retired from use). [ENUM-REF-CANDIDATE: concept|blockout|greybox|art-pass|tech-art-review|qa-review|certification|approved|deprecated — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssetReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:polygonCount rdf:type rdf:Property ;
    rdfs:label 'Polygon Count' ;
    rdfs:comment 'The number of polygons in the 3D asset, applicable to mesh and model reviews, used to validate performance budgets and technical art standards.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Review Duration Minutes' ;
    rdfs:comment 'The actual time spent by the reviewer conducting the review in minutes, used for workload analysis and process optimization.' ;
    rdfs:domain ind:AssetReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revisionRequestDetails rdf:type rdf:Property ;
    rdfs:label 'Revision Request Details' ;
    rdfs:comment 'Specific instructions and requirements for asset revisions when decision is revision-required or conditional-approval, detailing what changes must be made before re-submission.' ;
    rdfs:domain ind:AssetReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signOffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sign Off Timestamp' ;
    rdfs:comment 'The date and time when the reviewer formally signed off on the review decision, marking the completion of this stage-gate checkpoint.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaActualHours rdf:type rdf:Property ;
    rdfs:label 'Sla Actual Hours' ;
    rdfs:comment 'The actual elapsed time in hours from review assignment to review completion, used to measure SLA compliance and pipeline efficiency.' ;
    rdfs:domain ind:AssetReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Flag' ;
    rdfs:comment 'Indicates whether the review was completed within the SLA target hours (true) or exceeded the target (false), used for pipeline performance monitoring.' ;
    rdfs:domain ind:AssetReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:textureResolution rdf:type rdf:Property ;
    rdfs:label 'Texture Resolution' ;
    rdfs:comment 'The resolution of texture assets in pixels (e.g., 2048x2048, 4096x4096), used to validate visual quality and memory budget compliance.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ugcModerationFlag rdf:type rdf:Property ;
    rdfs:label 'Ugc Moderation Flag' ;
    rdfs:comment 'Indicates whether this review is for user-generated content requiring moderation (true) or first-party content (false), triggering additional content policy checks.' ;
    rdfs:domain ind:AssetReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:committedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Committed By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Version control systems require tracking who committed each asset revision for code review workflows, accountability, and audit compliance. Essential for Perforce/source control integration and change' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:rollbackFromVersionId rdf:type rdf:Property ;
    rdfs:label 'Rollback From Version Id' ;
    rdfs:comment 'Reference to the asset version that this version rolled back from during a live-ops incident. Null for normal forward progression. Used for incident analysis.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetVersion .

ind:assetCategory rdf:type rdf:Property ;
    rdfs:label 'Asset Category' ;
    rdfs:comment 'High-level classification of the asset type. Used for pipeline routing and build system processing. [ENUM-REF-CANDIDATE: texture|model|audio|animation|level|script|localization|ui|vfx|shader — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchName rdf:type rdf:Property ;
    rdfs:label 'Branch Name' ;
    rdfs:comment 'Name of the Perforce branch or stream where this version was committed. Examples: main, dev, release/1.5, feature/new-character.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildErrorMessage rdf:type rdf:Property ;
    rdfs:label 'Build Error Message' ;
    rdfs:comment 'Error message from the build pipeline if processing failed. Null for successful builds. Used for troubleshooting and QA.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildPipelineStatus rdf:type rdf:Property ;
    rdfs:label 'Build Pipeline Status' ;
    rdfs:comment 'Current status of the automated build pipeline processing for this asset version. Tracks whether the asset has been successfully compiled, optimized, and packaged.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildPipelineTimestamp rdf:type rdf:Property ;
    rdfs:label 'Build Pipeline Timestamp' ;
    rdfs:comment 'Date and time when the build pipeline last processed this asset version. Null if not yet processed.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cdnDistributionStatus rdf:type rdf:Property ;
    rdfs:label 'Cdn Distribution Status' ;
    rdfs:comment 'Status of this asset versions distribution to CDN edge nodes for player download. Tracks global content propagation.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnDistributionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cdn Distribution Timestamp' ;
    rdfs:comment 'Date and time when this asset version was successfully distributed to all CDN regions. Null if not yet distributed.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:changeDescription rdf:type rdf:Property ;
    rdfs:label 'Change Description' ;
    rdfs:comment 'Commit message provided by the author describing what was changed in this version. May include Jira ticket references, bug fix notes, or feature descriptions.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changelistNumber rdf:type rdf:Property ;
    rdfs:label 'Changelist Number' ;
    rdfs:comment 'Perforce Helix Core changelist number representing the atomic commit that introduced this asset version. Unique identifier for the commit transaction.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checksumMd5 rdf:type rdf:Property ;
    rdfs:label 'Checksum Md5' ;
    rdfs:comment 'MD5 hash of the asset file content for integrity verification and duplicate detection. Used to validate file transfers and detect corruption.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitTimestamp rdf:type rdf:Property ;
    rdfs:label 'Commit Timestamp' ;
    rdfs:comment 'Exact date and time when this asset version was committed to Perforce Helix Core. Represents the business event time of the version creation.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:depotPath rdf:type rdf:Property ;
    rdfs:label 'Depot Path' ;
    rdfs:comment 'Full Perforce depot path to the asset file including depot name, directory structure, and filename. Example: //depot/GameAssets/Characters/Hero/hero_model.fbx' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeDeltaBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Delta Bytes' ;
    rdfs:comment 'Change in file size compared to the previous revision in bytes. Positive for growth, negative for reduction. Null for first revision.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fileType rdf:type rdf:Property ;
    rdfs:label 'File Type' ;
    rdfs:comment 'Perforce file type classification indicating how the file is stored and merged. Examples: text, binary, binary+l (exclusive lock), utf16.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDeprecated rdf:type rdf:Property ;
    rdfs:label 'Is Deprecated' ;
    rdfs:comment 'Indicates whether this asset version has been marked as deprecated and should no longer be used in new builds. Used for asset lifecycle management.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lodLevel rdf:type rdf:Property ;
    rdfs:label 'Lod Level' ;
    rdfs:comment 'LOD variant level for this asset version. LOD0 is highest quality, higher numbers are progressively lower detail for performance optimization. None for non-LOD assets. [ENUM-REF-CANDIDATE: lod0|lod1|lod2|lod3|lod4|lod5|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotedToLiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Promoted To Live Timestamp' ;
    rdfs:comment 'Date and time when this asset version was deployed to the live production environment and became visible to players. Null if not yet live.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:promotedToStagingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Promoted To Staging Timestamp' ;
    rdfs:comment 'Date and time when this asset version was promoted to the staging environment for UAT. Null if not yet promoted.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:promotionStage rdf:type rdf:Property ;
    rdfs:label 'Promotion Stage' ;
    rdfs:comment 'Current deployment stage of this asset version in the content delivery lifecycle. Tracks progression from development through to live production.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Sequential revision number for this asset file within its depot path. Increments with each commit to the same file.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:streamPath rdf:type rdf:Property ;
    rdfs:label 'Stream Path' ;
    rdfs:comment 'Perforce stream path if using stream-based development model. Defines the stream hierarchy and inheritance. Null for classic branch-based workflows.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ugcModerationStatus rdf:type rdf:Property ;
    rdfs:label 'Ugc Moderation Status' ;
    rdfs:comment 'Moderation review status for user-generated content assets. None for first-party studio assets. Used to enforce community standards and COPPA compliance.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualGoLiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Go Live Timestamp' ;
    rdfs:comment 'Actual date and time when the content release was deployed to production and became available to players. Null if not yet deployed.' ;
    rdfs:domain ind:ContentRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assetBundleReferences rdf:type rdf:Property ;
    rdfs:label 'Asset Bundle References' ;
    rdfs:comment 'Comma-separated list of asset bundle identifiers or Perforce Helix Core changelist numbers associated with this content release. Links the release to the underlying digital assets.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalIssuesCount rdf:type rdf:Property ;
    rdfs:label 'Critical Issues Count' ;
    rdfs:comment 'Number of critical bugs or issues reported by players or QA after this content release went live. Used for quality monitoring and hotfix prioritization.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deploymentStatus rdf:type rdf:Property ;
    rdfs:label 'Deployment Status' ;
    rdfs:comment 'Technical deployment status of the content release: not_started (scheduled but not yet deployed), in_progress (deployment underway), completed (successfully deployed to all target platforms), failed (deployment encountered errors).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downloadSizeMbConsole rdf:type rdf:Property ;
    rdfs:label 'Download Size Mb Console' ;
    rdfs:comment 'Download package size in megabytes for console platforms (PlayStation, Xbox, Switch). Used for bandwidth planning and player communication.' ;
    rdfs:domain ind:ContentRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downloadSizeMbMobile rdf:type rdf:Property ;
    rdfs:label 'Download Size Mb Mobile' ;
    rdfs:comment 'Download package size in megabytes for mobile platforms (iOS, Android). Critical for mobile data usage and app store optimization.' ;
    rdfs:domain ind:ContentRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downloadSizeMbPc rdf:type rdf:Property ;
    rdfs:label 'Download Size Mb Pc' ;
    rdfs:comment 'Download package size in megabytes for PC platform. Used for bandwidth planning and player communication.' ;
    rdfs:domain ind:ContentRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dropName rdf:type rdf:Property ;
    rdfs:label 'Drop Name' ;
    rdfs:comment 'Human-readable name or title of the content release (e.g., \'Winter Wonderland Event\', \'Patch 2.4.1\', \'Season 3 Battle Pass\').' ;
    rdfs:domain ind:ContentRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityRules rdf:type rdf:Property ;
    rdfs:label 'Eligibility Rules' ;
    rdfs:comment 'Player eligibility criteria for accessing this content release (e.g., \'Level 10+\', \'Premium subscribers only\', \'All players\'). Used for access control and segmentation.' ;
    rdfs:domain ind:ContentRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event End Timestamp' ;
    rdfs:comment 'Date and time when a seasonal or limited-time event concludes and is no longer available to players. Applicable for event-based releases.' ;
    rdfs:domain ind:ContentRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Start Timestamp' ;
    rdfs:comment 'Date and time when a seasonal or limited-time event becomes active for players. Applicable for event-based releases.' ;
    rdfs:domain ind:ContentRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventTheme rdf:type rdf:Property ;
    rdfs:label 'Event Theme' ;
    rdfs:comment 'Thematic description of seasonal or limited-time events (e.g., \'Winter Holiday\', \'Halloween\', \'Summer Festival\'). Applicable when release_type is seasonal_event or limited_time_event.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusiveRewards rdf:type rdf:Property ;
    rdfs:label 'Exclusive Rewards' ;
    rdfs:comment 'Description of exclusive rewards or items available only during this content release (e.g., \'Legendary Winter Sword,Exclusive Holiday Avatar\'). Used for player engagement and retention.' ;
    rdfs:domain ind:ContentRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featuredBundles rdf:type rdf:Property ;
    rdfs:label 'Featured Bundles' ;
    rdfs:comment 'Comma-separated list of featured in-game bundles or offers associated with this content release (e.g., \'Winter Skin Pack,Holiday Emote Bundle\'). Used for monetization and marketing alignment.' ;
    rdfs:domain ind:ContentRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goldMasterDate rdf:type rdf:Property ;
    rdfs:label 'Gold Master Date' ;
    rdfs:comment 'Date when the content release reached gold master status (final, production-ready build). Marks the completion of development and testing.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:liveOpsOwner rdf:type rdf:Property ;
    rdfs:label 'Live Ops Owner' ;
    rdfs:comment 'Name or identifier of the live operations team member or product owner responsible for this content release. Used for accountability and cross-functional coordination.' ;
    rdfs:domain ind:ContentRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingCampaignAlignment rdf:type rdf:Property ;
    rdfs:label 'Marketing Campaign Alignment' ;
    rdfs:comment 'Name or identifier of the marketing campaign aligned with this content release (e.g., \'Holiday 2024 Campaign\', \'Season 3 Launch\'). Used for cross-functional planning and ROI tracking.' ;
    rdfs:domain ind:ContentRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumClientVersion rdf:type rdf:Property ;
    rdfs:label 'Minimum Client Version' ;
    rdfs:comment 'Minimum game client version required to support this content release. Players on older client versions may be blocked or prompted to update. Follows semver format.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notesUrl rdf:type rdf:Property ;
    rdfs:label 'Notes Url' ;
    rdfs:comment 'URL to the public-facing release notes or patch notes document for this content release. Used for player communication and transparency.' ;
    rdfs:domain ind:ContentRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participationMechanics rdf:type rdf:Property ;
    rdfs:label 'Participation Mechanics' ;
    rdfs:comment 'Description of gameplay mechanics or activities players must complete to participate in the event or unlock rewards (e.g., \'Complete 10 daily quests\', \'Win 5 PvP matches\').' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patchType rdf:type rdf:Property ;
    rdfs:label 'Patch Type' ;
    rdfs:comment 'Classification of patch releases: major (significant feature additions or breaking changes), minor (incremental features or improvements), hotfix (emergency bug fixes). Applicable only when release_type is patch or hotfix.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerFeedbackScore rdf:type rdf:Property ;
    rdfs:label 'Player Feedback Score' ;
    rdfs:comment 'Aggregated player sentiment score for this content release, typically on a scale of 1.00 to 5.00. Derived from player surveys, reviews, and community feedback post-launch.' ;
    rdfs:domain ind:ContentRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qaSignOffDate rdf:type rdf:Property ;
    rdfs:label 'Qa Sign Off Date' ;
    rdfs:comment 'Date when the QA team formally approved this content release for deployment. Indicates completion of quality assurance and playtesting.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releaseStatus rdf:type rdf:Property ;
    rdfs:label 'Release Status' ;
    rdfs:comment 'Current lifecycle status of the content release: planned (scheduled but not yet approved), approved (greenlit for development), in_qa (undergoing quality assurance testing), certified (passed platform TRC/TCR certification), live (deployed to production), rolled_back (reverted due to issues), cancelled (release aborted). [ENUM-REF-CANDIDATE: planned|approved|in_qa|certified|live|rolled_back|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseType rdf:type rdf:Property ;
    rdfs:label 'Release Type' ;
    rdfs:comment 'Type discriminator for the content release: seasonal_event (recurring themed events), patch (scheduled version updates), hotfix (emergency fixes), battle_pass_season (new battle pass tier progression), dlc_drop (downloadable content expansion), limited_time_event (one-off special events).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rollbackTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rollback Timestamp' ;
    rdfs:comment 'Date and time when the content release was rolled back or reverted due to critical issues. Null if no rollback occurred.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledGoLiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Go Live Timestamp' ;
    rdfs:comment 'Planned date and time when the content release is scheduled to go live to players. This is the target deployment timestamp set during release planning.' ;
    rdfs:domain ind:ContentRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:targetPlatforms rdf:type rdf:Property ;
    rdfs:label 'Target Platforms' ;
    rdfs:comment 'Comma-separated list of platforms this content release targets (e.g., \'PC,PlayStation,Xbox,Mobile,Switch\'). Indicates which platforms will receive this content drop.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trcTcrCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Trc Tcr Certification Status' ;
    rdfs:comment 'Platform certification status for console releases: not_required (PC/mobile only), pending (submitted for certification), in_progress (under review by first party), passed (certified), failed (rejected, requires fixes). Required for PlayStation, Xbox, Switch releases.' ;
    rdfs:domain ind:ContentRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionString rdf:type rdf:Property ;
    rdfs:label 'Version String' ;
    rdfs:comment 'Semantic versioning identifier for patches and hotfixes (e.g., \'2.4.1\', \'3.0.0\'). Follows semver convention: major.minor.patch. Null for non-patch release types.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:window rdf:type rdf:Property ;
    rdfs:label 'Window' ;
    rdfs:comment 'Deployment strategy for the content release: soft_launch (limited geographic or player segment release for testing), hard_launch (full production release), phased_rollout (gradual deployment across regions or player cohorts), global_simultaneous (worldwide release at the same time).' ;
    rdfs:domain ind:ContentRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentDeploymentId rdf:type rdf:Property ;
    rdfs:label 'Content Deployment Id' ;
    rdfs:comment 'Unique identifier for the content deployment event. Primary key.' ;
    rdfs:domain ind:ContentDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certFindingId rdf:type rdf:Property ;
    rdfs:label 'Cert Finding Id' ;
    rdfs:comment 'Foreign key linking to quality.cert_finding. Business justification: Deployments blocked by unresolved certification findings (deployment cannot proceed until cert finding resolved, deployment rollback due to cert finding). Deployment blocker tracking for platform comp' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CertFinding .

ind:cicdPipelineId rdf:type rdf:Property ;
    rdfs:label 'Cicd Pipeline Id' ;
    rdfs:comment 'Reference to the CI/CD (Continuous Integration/Continuous Deployment) pipeline that executed this deployment.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CicdPipeline .

ind:networkRegionId rdf:type rdf:Property ;
    rdfs:label 'Network Region Id' ;
    rdfs:comment 'Foreign key linking to infrastructure.network_region. Business justification: Content deployments are region-specific for data residency compliance and latency optimization. Release managers coordinate deployments by region to manage player impact windows, CDN pre-warming sched' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkRegion .

ind:patchId rdf:type rdf:Property ;
    rdfs:label 'Patch Id' ;
    rdfs:comment 'Foreign key linking to content.patch. Business justification: Content deployments need to track which specific patch is being pushed to live environments. One deployment pushes ONE patch to a specific environment/region; one patch can have MANY deployments (mult' ;
    rdfs:domain ind:Content ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Patch .

ind:primaryContentDeployerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Content Deployer Employee Id' ;
    rdfs:comment 'Reference to the employee or system user who initiated the deployment.' ;
    rdfs:domain ind:ContentDeployment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:releaseGateId rdf:type rdf:Property ;
    rdfs:label 'Release Gate Id' ;
    rdfs:comment 'Foreign key linking to quality.release_gate. Business justification: Deployments require release gate approval before production (gate-to-deployment workflow, deployment blocked until gate passes). Gate approval tracking enables deployment authorization and audit trail' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReleaseGate .

ind:testPlanId rdf:type rdf:Property ;
    rdfs:label 'Test Plan Id' ;
    rdfs:comment 'Foreign key linking to quality.test_plan. Business justification: Deployments execute against test plans for validation (deployment requires test plan sign-off, post-deployment validation against test plan). Deployment testing workflow links deployment to test plan ' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestPlan .

ind:validationTestSuiteId rdf:type rdf:Property ;
    rdfs:label 'Validation Test Suite Id' ;
    rdfs:comment 'Reference to the QA (Quality Assurance) test suite executed for post-deployment validation.' ;
    rdfs:domain ind:ContentDeployment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestSuite .

ind:assetBundleSizeMb rdf:type rdf:Property ;
    rdfs:label 'Asset Bundle Size Mb' ;
    rdfs:comment 'Total size of the deployed asset bundle in megabytes, representing the download size for players.' ;
    rdfs:domain ind:ContentDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buildNumber rdf:type rdf:Property ;
    rdfs:label 'Build Number' ;
    rdfs:comment 'The CI/CD (Continuous Integration/Continuous Deployment) build number or version identifier for the deployed content package.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Cdn Endpoint Url' ;
    rdfs:comment 'The primary CDN (Content Delivery Network) endpoint URL where the deployed content is accessible to players.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentMethod rdf:type rdf:Property ;
    rdfs:label 'Deployment Method' ;
    rdfs:comment 'The technical approach used to deploy the content: full push (complete asset bundle), delta patch (incremental changes), hotfix (emergency fix), rollback (revert to previous version), staged rollout (phased deployment), or canary (limited test deployment).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentNumber rdf:type rdf:Property ;
    rdfs:label 'Deployment Number' ;
    rdfs:comment 'Externally-known unique identifier for this deployment event, used for tracking and audit purposes.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentType rdf:type rdf:Property ;
    rdfs:label 'Deployment Type' ;
    rdfs:comment 'Classification of the deployment by business purpose: content drop (scheduled release), patch (bug fix), hotfix (emergency fix), DLC (Downloadable Content), seasonal event (limited-time content), or live ops (ongoing service update).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Downtime Duration Minutes' ;
    rdfs:comment 'Total duration in minutes that the game or service was offline for this deployment, if downtime was required.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:downtimeRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Downtime Required Flag' ;
    rdfs:comment 'Indicates whether the deployment required taking the game or service offline (True) or was deployed with zero downtime (False).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'Total time in seconds from deployment initiation to completion or failure.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perforceChangelistNumber rdf:type rdf:Property ;
    rdfs:label 'Perforce Changelist Number' ;
    rdfs:comment 'The Perforce Helix Core changelist number associated with this deployment, providing version control traceability.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerImpactLevel rdf:type rdf:Property ;
    rdfs:label 'Player Impact Level' ;
    rdfs:comment 'Assessment of the expected impact on live players: none (backend only), low (minor changes), medium (noticeable changes), high (significant gameplay changes), or critical (major content update or fix).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postDeploymentValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Post Deployment Validation Status' ;
    rdfs:comment 'Status of automated or manual validation checks performed after deployment to verify content integrity and functionality.' ;
    rdfs:domain ind:ContentDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionCodes rdf:type rdf:Property ;
    rdfs:label 'Region Codes' ;
    rdfs:comment 'Comma-separated list of geographic region codes where this deployment was pushed (e.g., NAM, EUR, APAC, LATAM). Used for geo-specific content rollouts.' ;
    rdfs:domain ind:ContentDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rollbackFlag rdf:type rdf:Property ;
    rdfs:label 'Rollback Flag' ;
    rdfs:comment 'Indicates whether this deployment was subsequently rolled back due to issues (True) or remains active (False).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rollbackReason rdf:type rdf:Property ;
    rdfs:label 'Rollback Reason' ;
    rdfs:comment 'Business justification or technical reason for rolling back the deployment (e.g., critical bug, performance degradation, player complaints).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetEnvironment rdf:type rdf:Property ;
    rdfs:label 'Target Environment' ;
    rdfs:comment 'The environment to which the content is being deployed: dev (development), qa (quality assurance), uat (user acceptance testing), staging (pre-production), production (live), or live (player-facing).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowEnd rdf:type rdf:Property ;
    rdfs:label 'Window End' ;
    rdfs:comment 'The scheduled end time of the deployment maintenance window.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:windowStart rdf:type rdf:Property ;
    rdfs:label 'Window Start' ;
    rdfs:comment 'The scheduled start time of the deployment maintenance window.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:accessibilityFeatures rdf:type rdf:Property ;
    rdfs:label 'Accessibility Features' ;
    rdfs:comment 'Comma-separated list of accessibility features implemented in this level (e.g., \'colorblind_mode,subtitle_support,reduced_motion,audio_cues\').' ;
    rdfs:domain ind:LevelMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioAmbienceProfile rdf:type rdf:Property ;
    rdfs:label 'Audio Ambience Profile' ;
    rdfs:comment 'Identifier for the audio ambience profile used in this level (e.g., \'forest_day\', \'urban_night\', \'dungeon_echo\'). References audio asset configuration.' ;
    rdfs:domain ind:LevelMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildStatus rdf:type rdf:Property ;
    rdfs:label 'Build Status' ;
    rdfs:comment 'Current production status of the level: blockout (initial layout/greybox), art_pass (art assets applied), optimization (performance tuning), gold (production-ready), deprecated (no longer in use).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dayNightCycleEnabled rdf:type rdf:Property ;
    rdfs:label 'Day Night Cycle Enabled' ;
    rdfs:comment 'Indicates whether the level supports a dynamic day-night cycle affecting lighting and gameplay.' ;
    rdfs:domain ind:LevelMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:difficultyRating rdf:type rdf:Property ;
    rdfs:label 'Difficulty Rating' ;
    rdfs:comment 'Designed difficulty level of the level: easy (beginner-friendly), normal (standard challenge), hard (experienced players), expert (advanced), nightmare (maximum difficulty).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedPlayDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Play Duration Minutes' ;
    rdfs:comment 'Expected average time in minutes for a player to complete or experience this level under normal gameplay conditions.' ;
    rdfs:domain ind:LevelMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gameModeCompatibility rdf:type rdf:Property ;
    rdfs:label 'Game Mode Compatibility' ;
    rdfs:comment 'Comma-separated list of game modes this level supports (e.g., \'deathmatch,capture_the_flag,team_deathmatch\'). Indicates which gameplay rulesets can be played on this map.' ;
    rdfs:domain ind:LevelMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geometryComplexityTier rdf:type rdf:Property ;
    rdfs:label 'Geometry Complexity Tier' ;
    rdfs:comment 'Classification of the level\'s geometric complexity and polygon count: low (simple geometry), medium (moderate detail), high (detailed environments), ultra (maximum fidelity).' ;
    rdfs:domain ind:LevelMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactiveObjectCount rdf:type rdf:Property ;
    rdfs:label 'Interactive Object Count' ;
    rdfs:comment 'Total number of interactive objects (doors, switches, loot containers, destructible elements) placed in the level.' ;
    rdfs:domain ind:LevelMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:knownBugCount rdf:type rdf:Property ;
    rdfs:label 'Known Bug Count' ;
    rdfs:comment 'Current count of known open bugs or issues logged in Jira for this level. Used for quality tracking and release readiness.' ;
    rdfs:domain ind:LevelMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:levelCode rdf:type rdf:Property ;
    rdfs:label 'Level Code' ;
    rdfs:comment 'Unique alphanumeric code or identifier used in game engine and asset pipeline to reference this level (e.g., \'LVL_001\', \'MAP_TUTORIAL_01\').' ;
    rdfs:domain ind:LevelMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:levelName rdf:type rdf:Property ;
    rdfs:label 'Level Name' ;
    rdfs:comment 'Human-readable name of the level, map, or zone (e.g., \'Crimson Fortress\', \'Tutorial Island\', \'Arena of Champions\').' ;
    rdfs:domain ind:LevelMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:levelType rdf:type rdf:Property ;
    rdfs:label 'Level Type' ;
    rdfs:comment 'Classification of the level based on gameplay purpose: tutorial (onboarding), PvP (Player versus Player) arena, PvE (Player versus Environment) dungeon, open world, hub (social space), lobby (matchmaking), boss arena, raid, or story mission. [ENUM-REF-CANDIDATE: tutorial|pvp_arena|pve_dungeon|open_world|hub|lobby|boss_arena|raid|story_mission — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LevelMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lightingModel rdf:type rdf:Property ;
    rdfs:label 'Lighting Model' ;
    rdfs:comment 'Lighting technique used in the level: baked (pre-computed lightmaps), dynamic (real-time lighting), mixed (combination of baked and dynamic).' ;
    rdfs:domain ind:LevelMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localizationStringCount rdf:type rdf:Property ;
    rdfs:label 'Localization String Count' ;
    rdfs:comment 'Total number of localization strings (text, dialogue, UI labels) associated with this level across all supported languages.' ;
    rdfs:domain ind:LevelMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:memoryBudgetMb rdf:type rdf:Property ;
    rdfs:label 'Memory Budget Mb' ;
    rdfs:comment 'Allocated memory budget in megabytes for this level\'s assets and runtime data. Used for performance optimization and platform compliance.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumFpsTarget rdf:type rdf:Property ;
    rdfs:label 'Minimum Fps Target' ;
    rdfs:comment 'Minimum target frame rate (FPS - Frames Per Second) the level is optimized to maintain on supported platforms.' ;
    rdfs:domain ind:LevelMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:navmeshComplexity rdf:type rdf:Property ;
    rdfs:label 'Navmesh Complexity' ;
    rdfs:comment 'Complexity of the AI navigation mesh for NPC (Non-Player Character) pathfinding: simple (basic navigation), moderate (standard pathfinding), complex (advanced multi-layer navigation), none (no AI navigation).' ;
    rdfs:domain ind:LevelMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npcSpawnZonesCount rdf:type rdf:Property ;
    rdfs:label 'Npc Spawn Zones Count' ;
    rdfs:comment 'Number of designated zones where NPCs (Non-Player Characters) can spawn or patrol within the level.' ;
    rdfs:domain ind:LevelMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:objectiveMarkerCount rdf:type rdf:Property ;
    rdfs:label 'Objective Marker Count' ;
    rdfs:comment 'Number of objective markers or mission waypoints placed in the level for gameplay guidance.' ;
    rdfs:domain ind:LevelMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:physicsConfiguration rdf:type rdf:Property ;
    rdfs:label 'Physics Configuration' ;
    rdfs:comment 'Physics simulation complexity for the level: standard (default physics), high_fidelity (advanced physics interactions), simplified (reduced physics for performance), disabled (no physics simulation).' ;
    rdfs:domain ind:LevelMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaTestPassCount rdf:type rdf:Property ;
    rdfs:label 'Qa Test Pass Count' ;
    rdfs:comment 'Number of QA (Quality Assurance) test passes completed for this level. Indicates testing maturity and quality validation.' ;
    rdfs:domain ind:LevelMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonalEventVariant rdf:type rdf:Property ;
    rdfs:label 'Seasonal Event Variant' ;
    rdfs:comment 'Identifier for seasonal or live-ops event variant of this level (e.g., \'halloween_2024\', \'winter_festival\'). Null if base version.' ;
    rdfs:domain ind:LevelMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spawnPointCount rdf:type rdf:Property ;
    rdfs:label 'Spawn Point Count' ;
    rdfs:comment 'Total number of player spawn points configured in the level for matchmaking and respawn mechanics.' ;
    rdfs:domain ind:LevelMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:streamingStrategy rdf:type rdf:Property ;
    rdfs:label 'Streaming Strategy' ;
    rdfs:comment 'Memory and asset loading strategy for the level: full_load (entire level loaded at once), streaming_chunks (progressive streaming of level sections), hybrid (combination approach).' ;
    rdfs:domain ind:LevelMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedPlatforms rdf:type rdf:Property ;
    rdfs:label 'Supported Platforms' ;
    rdfs:comment 'Comma-separated list of platforms this level is certified for (e.g., \'PC,PS5,Xbox_Series_X,Nintendo_Switch,iOS,Android\'). Indicates platform compatibility.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPlayerCountMax rdf:type rdf:Property ;
    rdfs:label 'Target Player Count Max' ;
    rdfs:comment 'Maximum number of players the level is designed to support for optimal gameplay experience.' ;
    rdfs:domain ind:LevelMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetPlayerCountMin rdf:type rdf:Property ;
    rdfs:label 'Target Player Count Min' ;
    rdfs:comment 'Minimum number of players the level is designed to support for optimal gameplay experience.' ;
    rdfs:domain ind:LevelMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ugcEnabled rdf:type rdf:Property ;
    rdfs:label 'Ugc Enabled' ;
    rdfs:comment 'Indicates whether this level supports user-generated content (UGC) modifications, custom maps, or player-created elements.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verticalLayersCount rdf:type rdf:Property ;
    rdfs:label 'Vertical Layers Count' ;
    rdfs:comment 'Number of distinct vertical layers or floors in the level (e.g., multi-story buildings, underground sections). Indicates vertical complexity.' ;
    rdfs:domain ind:LevelMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weatherSystemEnabled rdf:type rdf:Property ;
    rdfs:label 'Weather System Enabled' ;
    rdfs:comment 'Indicates whether dynamic weather effects (rain, snow, fog) are enabled for this level.' ;
    rdfs:domain ind:LevelMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:worldSizeSquareMeters rdf:type rdf:Property ;
    rdfs:label 'World Size Square Meters' ;
    rdfs:comment 'Total playable area of the level measured in square meters. Indicates the physical scale of the game space.' ;
    rdfs:domain ind:LevelMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localizationStringId rdf:type rdf:Property ;
    rdfs:label 'Localization String Id' ;
    rdfs:comment 'Unique identifier for the localization string record. Primary key.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LocalizationString .

ind:audioAssetId rdf:type rdf:Property ;
    rdfs:label 'Audio Asset Id' ;
    rdfs:comment 'Foreign key linking to content.asset. Business justification: Localization strings with voice-over (audio_vo_required = true) reference an audio asset. This FK links the string to its recorded VO asset, enabling asset lifecycle tracking and referential integrity' ;
    rdfs:domain ind:Content ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:musicSyncLicenseId rdf:type rdf:Property ;
    rdfs:label 'Music Sync License Id' ;
    rdfs:comment 'Foreign key linking to licensing.music_sync_license. Business justification: Subtitle and lyric strings for licensed music tracks must link to sync licenses to verify territory and platform usage rights, validate content rating impacts, and ensure compliance with PRO clearance' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MusicSyncLicense .

ind:audioVoRequired rdf:type rdf:Property ;
    rdfs:label 'Audio Vo Required' ;
    rdfs:comment 'Indicates whether this string requires voice-over audio recording for localization. True for dialogue and narrative strings; false for UI labels and system messages.' ;
    rdfs:domain ind:LocalizationString ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:characterLimit rdf:type rdf:Property ;
    rdfs:label 'Character Limit' ;
    rdfs:comment 'Maximum number of characters allowed for this string to fit within UI constraints or subtitle timing. Null if no limit applies.' ;
    rdfs:domain ind:LocalizationString ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentWarningFlags rdf:type rdf:Property ;
    rdfs:label 'Content Warning Flags' ;
    rdfs:comment 'Comma-separated list of content warning categories applicable to this string (e.g., \'violence,profanity,drug_reference\'). Used for age rating and content filtering.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contextNotes rdf:type rdf:Property ;
    rdfs:label 'Context Notes' ;
    rdfs:comment 'Contextual information for translators describing where and how the string is used in the game (e.g., \'Button label on main menu\', \'NPC greeting when player enters village\').' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentDate rdf:type rdf:Property ;
    rdfs:label 'Deployment Date' ;
    rdfs:comment 'Date when this string was deployed to production. Null if not yet deployed.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genderVariantRequired rdf:type rdf:Property ;
    rdfs:label 'Gender Variant Required' ;
    rdfs:comment 'Indicates whether this string requires gender-specific variants for languages with grammatical gender (e.g., French, Spanish, German).' ;
    rdfs:domain ind:LocalizationString ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPlaceholder rdf:type rdf:Property ;
    rdfs:label 'Is Placeholder' ;
    rdfs:comment 'Indicates whether this string is a temporary placeholder (true) or final content (false). Placeholder strings are used during development and must be replaced before release.' ;
    rdfs:domain ind:LocalizationString ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:perforcePath rdf:type rdf:Property ;
    rdfs:label 'Perforce Path' ;
    rdfs:comment 'File path in Perforce Helix Core version control system where this string is stored (e.g., //depot/GameTitle/Localization/Strings/UI/MainMenu.json).' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pluralVariantRequired rdf:type rdf:Property ;
    rdfs:label 'Plural Variant Required' ;
    rdfs:comment 'Indicates whether this string requires plural form variants for languages with complex plural rules (e.g., Russian, Arabic, Polish).' ;
    rdfs:domain ind:LocalizationString ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Source Language Code' ;
    rdfs:comment 'ISO 639-1 two-letter language code (with optional ISO 3166-1 alpha-2 country code) for the original language of the string (e.g., en, en-US, ja-JP).' ;
    rdfs:domain ind:LocalizationString ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceText rdf:type rdf:Property ;
    rdfs:label 'Source Text' ;
    rdfs:comment 'The original text content in the source language. This is the master text from which all translations are derived.' ;
    rdfs:domain ind:LocalizationString ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stringCategory rdf:type rdf:Property ;
    rdfs:label 'String Category' ;
    rdfs:comment 'Classification of the string by functional area: UI (user interface labels), narrative (dialogue and story text), marketing (promotional copy), tutorial (instructional text), system (technical messages), achievement (achievement descriptions), store (in-game store copy), error (error messages). [ENUM-REF-CANDIDATE: ui|narrative|marketing|tutorial|system|achievement|store|error — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LocalizationString ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stringKey rdf:type rdf:Property ;
    rdfs:label 'String Key' ;
    rdfs:comment 'Unique programmatic identifier for the string used by the game engine to reference this text. Typically uppercase with underscores (e.g., UI_BUTTON_START, NPC_DIALOGUE_GREETING_01).' ;
    rdfs:domain ind:LocalizationString ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtitleTimingEnd rdf:type rdf:Property ;
    rdfs:label 'Subtitle Timing End' ;
    rdfs:comment 'End time in seconds for subtitle display when this string is used as a subtitle. Null if not applicable.' ;
    rdfs:domain ind:LocalizationString ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subtitleTimingStart rdf:type rdf:Property ;
    rdfs:label 'Subtitle Timing Start' ;
    rdfs:comment 'Start time in seconds for subtitle display when this string is used as a subtitle. Null if not applicable.' ;
    rdfs:domain ind:LocalizationString ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportsRichText rdf:type rdf:Property ;
    rdfs:label 'Supports Rich Text' ;
    rdfs:comment 'Indicates whether this string supports rich text formatting (bold, italic, color tags) as defined by the game engine\'s text rendering system.' ;
    rdfs:domain ind:LocalizationString ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsVariables rdf:type rdf:Property ;
    rdfs:label 'Supports Variables' ;
    rdfs:comment 'Indicates whether this string contains dynamic variables or placeholders that are replaced at runtime (e.g., {player_name}, {item_count}).' ;
    rdfs:domain ind:LocalizationString ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:translationStatus rdf:type rdf:Property ;
    rdfs:label 'Translation Status' ;
    rdfs:comment 'Current status of the string in the localization workflow: not_started (no translation work begun), in_progress (being translated), translated (initial translation complete), reviewed (reviewed by linguist), approved (approved for use), rejected (needs rework), final (locked for release). [ENUM-REF-CANDIDATE: not_started|in_progress|translated|reviewed|approved|rejected|final — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LocalizationString ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variableList rdf:type rdf:Property ;
    rdfs:label 'Variable List' ;
    rdfs:comment 'Comma-separated list of variable names used in this string (e.g., \'player_name,item_count,gold_amount\'). Null if no variables are present.' ;
    rdfs:domain ind:LocalizationString ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localizationTranslationId rdf:type rdf:Property ;
    rdfs:label 'Localization Translation Id' ;
    rdfs:comment 'Unique identifier for the localization translation record. Primary key for the translation entity.' ;
    rdfs:domain ind:LocalizationTranslation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:translatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Translator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: When translations are performed in-house (translator_type=\'internal\'), linking to employee enables cost allocation to projects, performance tracking, and workload management. Essential for internal lo' ;
    rdfs:domain ind:LocalizationTranslation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:characterCount rdf:type rdf:Property ;
    rdfs:label 'Character Count' ;
    rdfs:comment 'Total number of characters in the translated text. Used for translation billing, UI layout validation, and quality assurance checks to ensure text fits within UI constraints.' ;
    rdfs:domain ind:LocalizationTranslation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:culturalAdaptationNotes rdf:type rdf:Property ;
    rdfs:label 'Cultural Adaptation Notes' ;
    rdfs:comment 'Documentation of cultural localization decisions made for this translation, such as idiom adaptation, humor localization, or culturally sensitive content modifications to meet regional standards (ESRB, PEGI, CERO, GRAC).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glossaryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Glossary Compliance Flag' ;
    rdfs:comment 'Boolean indicator whether the translation adheres to the game-specific terminology glossary and style guide. True indicates compliance with brand and terminology standards.' ;
    rdfs:domain ind:LocalizationTranslation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:machineTranslationFlag rdf:type rdf:Property ;
    rdfs:label 'Machine Translation Flag' ;
    rdfs:comment 'Boolean indicator whether this translation was generated by machine translation (MT) engine. True indicates machine-generated content that may require human post-editing.' ;
    rdfs:domain ind:LocalizationTranslation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Platform Certification Status' ;
    rdfs:comment 'Status of this translation in platform-specific certification processes (TRC/TCR for console manufacturers). Tracks compliance with first-party platform localization requirements.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaFlag rdf:type rdf:Property ;
    rdfs:label 'Qa Flag' ;
    rdfs:comment 'Boolean indicator for translations requiring additional quality assurance attention due to complexity, cultural sensitivity, or previous issues. True indicates QA escalation needed.' ;
    rdfs:domain ind:LocalizationTranslation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Detailed explanation for why a translation was rejected during QA review. Nullable for approved translations. Used for translator feedback and quality improvement.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Date when the translation review was completed. Nullable for translations that have not yet been reviewed.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerIdentity rdf:type rdf:Property ;
    rdfs:label 'Reviewer Identity' ;
    rdfs:comment 'Identifier of the QA (Quality Assurance) reviewer or linguistic expert who evaluated this translation. Nullable until review is assigned.' ;
    rdfs:domain ind:LocalizationTranslation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionCount rdf:type rdf:Property ;
    rdfs:label 'Revision Count' ;
    rdfs:comment 'Number of times this translation has been revised and resubmitted. Used to track translation complexity and identify problematic strings requiring additional localization guidance.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceTextHash rdf:type rdf:Property ;
    rdfs:label 'Source Text Hash' ;
    rdfs:comment 'Hash of the original source string at the time of translation. Used to detect when source content has changed and translation needs updating.' ;
    rdfs:domain ind:LocalizationTranslation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:translatedText rdf:type rdf:Property ;
    rdfs:label 'Translated Text' ;
    rdfs:comment 'The translated string content in the target locale. Contains the localized text that will be displayed to players in-game or in platform interfaces.' ;
    rdfs:domain ind:LocalizationTranslation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:translationCost rdf:type rdf:Property ;
    rdfs:label 'Translation Cost' ;
    rdfs:comment 'Cost incurred for this translation in USD. Used for vendor billing, budget tracking, and localization ROI (Return on Investment) analysis. Nullable for internal or community translations.' ;
    rdfs:domain ind:LocalizationTranslation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:translationDate rdf:type rdf:Property ;
    rdfs:label 'Translation Date' ;
    rdfs:comment 'Date when the translation was completed and submitted. Used for tracking translation velocity and vendor SLA (Service Level Agreement) compliance.' ;
    rdfs:domain ind:LocalizationTranslation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:translationMemoryMatchScore rdf:type rdf:Property ;
    rdfs:label 'Translation Memory Match Score' ;
    rdfs:comment 'Percentage match score from translation memory system (0-100). Indicates how closely this translation matched existing approved translations. Used for cost optimization and consistency.' ;
    rdfs:domain ind:LocalizationTranslation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:translatorIdentity rdf:type rdf:Property ;
    rdfs:label 'Translator Identity' ;
    rdfs:comment 'Identifier of the individual translator, vendor company name, or machine translation service that produced this translation. Used for quality tracking and vendor performance analysis.' ;
    rdfs:domain ind:LocalizationTranslation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:translatorType rdf:type rdf:Property ;
    rdfs:label 'Translator Type' ;
    rdfs:comment 'Classification of the translation source: internal localization team, external vendor agency, machine translation engine, community contributor, or hybrid (machine + human review).' ;
    rdfs:domain ind:LocalizationTranslation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceAssetVersionId rdf:type rdf:Property ;
    rdfs:label 'Source Asset Version Id' ;
    rdfs:comment 'Foreign key linking to content.asset_version. Business justification: LOD variants are generated from a specific source asset version (the high-res master). Currently lod_variant has parent_asset_id (asset-level) but no version-level FK. Adding source_asset_version_id e' ;
    rdfs:domain ind:LodVariant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetVersion .

ind:audioBitrateKbps rdf:type rdf:Property ;
    rdfs:label 'Audio Bitrate Kbps' ;
    rdfs:comment 'Audio bitrate in kilobits per second for audio LOD variants. Null for non-audio assets. Higher bitrate means better quality but larger file size.' ;
    rdfs:domain ind:LodVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checksumHash rdf:type rdf:Property ;
    rdfs:label 'Checksum Hash' ;
    rdfs:comment 'SHA-256 or MD5 hash of the LOD variant asset file. Used for integrity verification, duplicate detection, and CDN cache validation.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compressionMethod rdf:type rdf:Property ;
    rdfs:label 'Compression Method' ;
    rdfs:comment 'Compression algorithm applied to this LOD variant (e.g., \'DXT5\', \'BC7\', \'ASTC\', \'Vorbis\', \'None\'). Affects runtime decompression performance and memory usage.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRatingImpact rdf:type rdf:Property ;
    rdfs:label 'Content Rating Impact' ;
    rdfs:comment 'Indicates if this LOD variant contains content that affects ESRB, PEGI, or other content rating classifications. Used for compliance and regional variant management.' ;
    rdfs:domain ind:LodVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'File format of the LOD variant asset (e.g., \'FBX\', \'OBJ\', \'PNG\', \'DDS\', \'WAV\', \'OGG\'). Determines compatibility with game engine import pipeline.' ;
    rdfs:domain ind:LodVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstDeployedTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Deployed Timestamp' ;
    rdfs:comment 'Date and time when this LOD variant was first deployed to a production build. Null if never deployed. Follows format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:LodVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:generationMethod rdf:type rdf:Property ;
    rdfs:label 'Generation Method' ;
    rdfs:comment 'Method used to create this LOD variant. Manual indicates artist-created; auto-generated indicates engine or tool-generated decimation; procedural indicates runtime generation.' ;
    rdfs:domain ind:LodVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generationTool rdf:type rdf:Property ;
    rdfs:label 'Generation Tool' ;
    rdfs:comment 'Name and version of the tool used to generate this LOD variant (e.g., \'Simplygon 9.1\', \'Unity LOD Generator 2021.3\', \'Manual in Blender 3.4\'). Supports asset pipeline traceability.' ;
    rdfs:domain ind:LodVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasCollisionMesh rdf:type rdf:Property ;
    rdfs:label 'Has Collision Mesh' ;
    rdfs:comment 'Indicates whether this LOD variant includes a simplified collision mesh for physics calculations. Null for non-geometry assets.' ;
    rdfs:domain ind:LodVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStreamingEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Streaming Enabled' ;
    rdfs:comment 'Indicates whether this LOD variant supports runtime streaming (progressive loading). Used for large open-world games to manage memory.' ;
    rdfs:domain ind:LodVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenseRestriction rdf:type rdf:Property ;
    rdfs:label 'License Restriction' ;
    rdfs:comment 'Any third-party licensing restrictions or intellectual property constraints on this LOD variant (e.g., \'Licensed from XYZ Corp\', \'Internal Use Only\', \'Royalty-Free\'). Confidential business information.' ;
    rdfs:domain ind:LodVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localizationVariant rdf:type rdf:Property ;
    rdfs:label 'Localization Variant' ;
    rdfs:comment 'ISO 639-1 language code or region code if this LOD variant is specific to a localization (e.g., \'en-US\', \'ja-JP\', \'de-DE\'). Null for language-agnostic assets.' ;
    rdfs:domain ind:LodVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lodLevelIndex rdf:type rdf:Property ;
    rdfs:label 'Lod Level Index' ;
    rdfs:comment 'The LOD tier index (0-5) where LOD0 is highest quality and LOD5 is lowest quality. Used by the rendering engine to select the appropriate variant based on camera distance or device performance.' ;
    rdfs:domain ind:LodVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialCount rdf:type rdf:Property ;
    rdfs:label 'Material Count' ;
    rdfs:comment 'Number of unique materials applied to this LOD variant. Null for non-geometry assets. Affects draw call count and rendering performance.' ;
    rdfs:domain ind:LodVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:memoryFootprintMb rdf:type rdf:Property ;
    rdfs:label 'Memory Footprint Mb' ;
    rdfs:comment 'Estimated runtime memory footprint of this LOD variant in megabytes when loaded into GPU or system memory. Critical for platform memory budget compliance.' ;
    rdfs:domain ind:LodVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Validation Status' ;
    rdfs:comment 'Current quality assurance status of this LOD variant. Approved variants are eligible for deployment; rejected variants require rework.' ;
    rdfs:domain ind:LodVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renderingDistanceMaxMeters rdf:type rdf:Property ;
    rdfs:label 'Rendering Distance Max Meters' ;
    rdfs:comment 'Maximum camera distance in meters at which this LOD variant should be used. Beyond this distance, the next lower LOD or culling applies. Null if distance-based LOD is not applicable.' ;
    rdfs:domain ind:LodVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renderingDistanceMinMeters rdf:type rdf:Property ;
    rdfs:label 'Rendering Distance Min Meters' ;
    rdfs:comment 'Minimum camera distance in meters at which this LOD variant should be used. Null if distance-based LOD is not applicable. Used by LOD Group components in game engines.' ;
    rdfs:domain ind:LodVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetFpsImpact rdf:type rdf:Property ;
    rdfs:label 'Target Fps Impact' ;
    rdfs:comment 'Estimated impact of this LOD variant on target frame rate performance. Used by technical artists to balance visual quality and performance.' ;
    rdfs:domain ind:LodVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPlatformTier rdf:type rdf:Property ;
    rdfs:label 'Target Platform Tier' ;
    rdfs:comment 'The device or platform performance tier this LOD variant is optimized for. Guides runtime LOD selection based on detected hardware capabilities. [ENUM-REF-CANDIDATE: high|medium|low|mobile|console|pc|vr — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LodVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uvChannelCount rdf:type rdf:Property ;
    rdfs:label 'Uv Channel Count' ;
    rdfs:comment 'Number of UV texture coordinate channels in this geometry LOD variant. Null for non-geometry assets. Supports multi-texture workflows (diffuse, lightmap, detail).' ;
    rdfs:domain ind:LodVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validatedBy rdf:type rdf:Property ;
    rdfs:label 'Validated By' ;
    rdfs:comment 'Name or identifier of the QA engineer or technical artist who validated this LOD variant. Supports accountability and audit trail.' ;
    rdfs:domain ind:LodVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validated Timestamp' ;
    rdfs:comment 'Date and time when this LOD variant was validated. Follows format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:LodVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:validationNotes rdf:type rdf:Property ;
    rdfs:label 'Validation Notes' ;
    rdfs:comment 'Quality assurance notes from the validation process. Captures issues found, approval rationale, or rework instructions.' ;
    rdfs:domain ind:LodVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantName rdf:type rdf:Property ;
    rdfs:label 'Variant Name' ;
    rdfs:comment 'Human-readable name for this LOD variant (e.g., \'High_Detail\', \'Mobile_Low\', \'Console_Medium\'). Used for identification in asset pipeline tools and Perforce Helix Core.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vertexCount rdf:type rdf:Property ;
    rdfs:label 'Vertex Count' ;
    rdfs:comment 'Number of vertices in this geometry LOD variant. Null for non-geometry assets. Complements polygon count for performance profiling.' ;
    rdfs:domain ind:LodVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:npcDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Npc Definition Id' ;
    rdfs:comment 'Unique identifier for the NPC definition record. Primary key for the NPC definition master data.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NpcDefinition .

ind:contentPackId rdf:type rdf:Property ;
    rdfs:label 'Content Pack Id' ;
    rdfs:comment 'Foreign key reference to the DLC or content pack that introduced this NPC. Null for base game content. Used for entitlement checks and content gating.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContentPack .

ind:modelAssetId rdf:type rdf:Property ;
    rdfs:label 'Model Asset Id' ;
    rdfs:comment 'Foreign key linking to content.asset. Business justification: NPC definitions reference a 3D model asset. Currently stored as model_asset_path (STRING path). Normalizing to FK enables referential integrity, asset lifecycle tracking, and JOIN-based queries. N:1 c' ;
    rdfs:domain ind:NpcDefinition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:aggroRange rdf:type rdf:Property ;
    rdfs:label 'Aggro Range' ;
    rdfs:comment 'Distance in game units within which this NPC will detect and engage hostile targets. Critical for encounter design and difficulty balancing.' ;
    rdfs:domain ind:NpcDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aiBehaviorProfile rdf:type rdf:Property ;
    rdfs:label 'Ai Behavior Profile' ;
    rdfs:comment 'Reference to the AI behavior script or profile that governs this NPC\'s decision-making, combat tactics, patrol patterns, and interaction logic. Links to game engine AI system configuration.' ;
    rdfs:domain ind:NpcDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:animationRigReference rdf:type rdf:Property ;
    rdfs:label 'Animation Rig Reference' ;
    rdfs:comment 'Reference to the skeletal animation rig asset used for this NPC. Links to the animation pipeline in Unity or Unreal Engine and defines available animation sequences.' ;
    rdfs:domain ind:NpcDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByUser rdf:type rdf:Property ;
    rdfs:label 'Approved By User' ;
    rdfs:comment 'Username or identifier of the lead designer or content director who approved this NPC definition for production deployment.' ;
    rdfs:domain ind:NpcDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archetypeType rdf:type rdf:Property ;
    rdfs:label 'Archetype Type' ;
    rdfs:comment 'Classification of the NPC by its primary gameplay role: enemy (hostile combatant), ally (friendly combatant), vendor (merchant), quest_giver (mission provider), boss (major encounter), or ambient (background character).' ;
    rdfs:domain ind:NpcDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioAssetBundle rdf:type rdf:Property ;
    rdfs:label 'Audio Asset Bundle' ;
    rdfs:comment 'Reference to the audio asset bundle containing voice lines, sound effects, and ambient audio for this NPC. Used by the game engine audio system.' ;
    rdfs:domain ind:NpcDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseAttackPower rdf:type rdf:Property ;
    rdfs:label 'Base Attack Power' ;
    rdfs:comment 'The default attack damage value for this NPC archetype at base level. Used for combat balancing and player difficulty progression.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baseDefenseRating rdf:type rdf:Property ;
    rdfs:label 'Base Defense Rating' ;
    rdfs:comment 'The default defense or armor value for this NPC archetype at base level. Determines damage mitigation in combat encounters.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baseHealthPoints rdf:type rdf:Property ;
    rdfs:label 'Base Health Points' ;
    rdfs:comment 'The default health points value for this NPC archetype at base level. Part of the core stat block used for combat balancing and difficulty tuning.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baseMovementSpeed rdf:type rdf:Property ;
    rdfs:label 'Base Movement Speed' ;
    rdfs:comment 'The default movement speed for this NPC archetype measured in game units per second. Affects chase mechanics, patrol behavior, and encounter pacing.' ;
    rdfs:domain ind:NpcDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collisionProfile rdf:type rdf:Property ;
    rdfs:label 'Collision Profile' ;
    rdfs:comment 'Physics collision profile that defines the NPC\'s physical boundaries and interaction with the game world. Determines hitbox size and collision detection behavior.' ;
    rdfs:domain ind:NpcDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deployedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deployed Timestamp' ;
    rdfs:comment 'Date and time when this NPC definition was deployed to live game servers. Used for live operations tracking and content drop scheduling.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:designNotes rdf:type rdf:Property ;
    rdfs:label 'Design Notes' ;
    rdfs:comment 'Internal design notes and rationale for this NPC\'s creation, balancing decisions, and intended player experience. Used for knowledge transfer and iteration planning.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dialogueTreeReference rdf:type rdf:Property ;
    rdfs:label 'Dialogue Tree Reference' ;
    rdfs:comment 'Reference identifier to the dialogue tree or conversation script asset used when players interact with this NPC. Links to narrative content and localization systems.' ;
    rdfs:domain ind:NpcDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experienceReward rdf:type rdf:Property ;
    rdfs:label 'Experience Reward' ;
    rdfs:comment 'Amount of experience points awarded to players upon defeating or completing interactions with this NPC. Used for player progression and leveling systems.' ;
    rdfs:domain ind:NpcDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:faction rdf:type rdf:Property ;
    rdfs:label 'Faction' ;
    rdfs:comment 'The faction or allegiance group to which this NPC belongs. Determines relationship dynamics with player and other NPCs in the game world.' ;
    rdfs:domain ind:NpcDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isQuestCritical rdf:type rdf:Property ;
    rdfs:label 'Is Quest Critical' ;
    rdfs:comment 'Indicates whether this NPC is essential to main story quest progression and cannot be permanently removed from the game world. Affects respawn logic and narrative continuity.' ;
    rdfs:domain ind:NpcDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localizationKeyPrefix rdf:type rdf:Property ;
    rdfs:label 'Localization Key Prefix' ;
    rdfs:comment 'Prefix identifier used to look up localized strings for this NPC across all supported languages. Links to the localization string database for dialogue, names, and descriptions.' ;
    rdfs:domain ind:NpcDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lodVariantCount rdf:type rdf:Property ;
    rdfs:label 'Lod Variant Count' ;
    rdfs:comment 'Number of LOD mesh variants available for this NPC to optimize rendering performance at different camera distances. Critical for performance optimization in large-scale scenes.' ;
    rdfs:domain ind:NpcDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lootTableReference rdf:type rdf:Property ;
    rdfs:label 'Loot Table Reference' ;
    rdfs:comment 'Reference identifier to the loot table configuration that defines item drops when this NPC is defeated or interacted with. Used for reward balancing and economy management.' ;
    rdfs:domain ind:NpcDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npcCode rdf:type rdf:Property ;
    rdfs:label 'Npc Code' ;
    rdfs:comment 'Unique business identifier code for the NPC definition used across game engine, content management systems, and development tools. Typically used in Perforce Helix Core and Unity/Unreal Engine asset pipelines.' ;
    rdfs:domain ind:NpcDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npcDefinitionDescription rdf:type rdf:Property ;
    rdfs:label 'Npc Definition Description' ;
    rdfs:comment 'Detailed narrative description of the NPC including backstory, role in the game world, and design intent. Used for documentation and content review.' ;
    rdfs:domain ind:NpcDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npcName rdf:type rdf:Property ;
    rdfs:label 'Npc Name' ;
    rdfs:comment 'The display name of the NPC as shown to players in-game. This is the canonical identity label for the NPC archetype.' ;
    rdfs:domain ind:NpcDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:respawnCooldownSeconds rdf:type rdf:Property ;
    rdfs:label 'Respawn Cooldown Seconds' ;
    rdfs:comment 'Time in seconds before this NPC respawns after being defeated. Used for encounter pacing and resource farming balance.' ;
    rdfs:domain ind:NpcDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:respawnEnabled rdf:type rdf:Property ;
    rdfs:label 'Respawn Enabled' ;
    rdfs:comment 'Indicates whether this NPC can respawn after being defeated or removed. Affects world population management and farming mechanics.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spawnRuleSet rdf:type rdf:Property ;
    rdfs:label 'Spawn Rule Set' ;
    rdfs:comment 'Reference to the spawn rule configuration that defines where, when, and under what conditions this NPC appears in the game world. Includes location constraints, time-of-day rules, and event triggers.' ;
    rdfs:domain ind:NpcDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:textureAssetPath rdf:type rdf:Property ;
    rdfs:label 'Texture Asset Path' ;
    rdfs:comment 'File path or asset reference to the texture map(s) applied to the NPC model. Includes diffuse, normal, and material maps stored in the content pipeline.' ;
    rdfs:domain ind:NpcDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voiceActorCredit rdf:type rdf:Property ;
    rdfs:label 'Voice Actor Credit' ;
    rdfs:comment 'Name of the voice actor who provided voice-over performance for this NPC. Used for credits, royalty tracking, and talent management.' ;
    rdfs:domain ind:NpcDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformPatchReleaseId rdf:type rdf:Property ;
    rdfs:label 'Platform Patch Release Id' ;
    rdfs:comment 'Foreign key linking to platform.patch_release. Business justification: Content patches map to platform-specific patch releases for distribution. Live ops teams coordinate content patch versions with platform patch releases for multi-platform deployment synchronization.' ;
    rdfs:domain ind:Patch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PatchRelease .

ind:contentDropFlag rdf:type rdf:Property ;
    rdfs:label 'Content Drop Flag' ;
    rdfs:comment 'Boolean flag indicating whether this patch includes a live-ops content drop (seasonal event, new maps, new characters, limited-time content). True if content drop is included, false otherwise.' ;
    rdfs:domain ind:Patch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deploymentDateConsole rdf:type rdf:Property ;
    rdfs:label 'Deployment Date Console' ;
    rdfs:comment 'The date when the patch was deployed live to console platforms (PlayStation, Xbox, Switch).' ;
    rdfs:domain ind:Patch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deploymentDateMobile rdf:type rdf:Property ;
    rdfs:label 'Deployment Date Mobile' ;
    rdfs:comment 'The date when the patch was deployed live to mobile platforms (iOS App Store, Google Play).' ;
    rdfs:domain ind:Patch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deploymentDatePc rdf:type rdf:Property ;
    rdfs:label 'Deployment Date Pc' ;
    rdfs:comment 'The date when the patch was deployed live to PC platforms (Steam, Epic Games Store, etc.).' ;
    rdfs:domain ind:Patch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dlcIncluded rdf:type rdf:Property ;
    rdfs:label 'Dlc Included' ;
    rdfs:comment 'Comma-separated list of DLC SKUs or identifiers that are bundled or enabled by this patch. Null if no DLC is associated.' ;
    rdfs:domain ind:Patch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmVersion rdf:type rdf:Property ;
    rdfs:label 'Drm Version' ;
    rdfs:comment 'Version identifier of the DRM protection applied to this patch, if applicable. Used to track anti-piracy measures and compatibility.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalChangeLog rdf:type rdf:Property ;
    rdfs:label 'Internal Change Log' ;
    rdfs:comment 'Internal technical change log detailing code commits, asset changes, and engineering notes not intended for public release. Used for development team reference and audit.' ;
    rdfs:domain ind:Patch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMandatory rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory' ;
    rdfs:comment 'Boolean flag indicating whether players are required to install this patch to continue playing (true) or if it is optional (false).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patchName rdf:type rdf:Property ;
    rdfs:label 'Patch Name' ;
    rdfs:comment 'Human-readable name or codename for the patch (e.g., \'Winter Festival Update\', \'Critical Stability Hotfix\').' ;
    rdfs:domain ind:Patch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patchStatus rdf:type rdf:Property ;
    rdfs:label 'Patch Status' ;
    rdfs:comment 'Current lifecycle status of the patch: draft (in development), qa_testing (undergoing QA), trc_submission (submitted for platform certification), approved (passed TRC/TCR), deployed (live on platforms), rolled_back (reverted due to issues), deprecated (superseded by newer patch). [ENUM-REF-CANDIDATE: draft|qa_testing|trc_submission|approved|deployed|rolled_back|deprecated — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceImprovementNotes rdf:type rdf:Property ;
    rdfs:label 'Performance Improvement Notes' ;
    rdfs:comment 'Description of performance optimizations included in this patch, such as FPS (Frames Per Second) improvements, load time reductions, memory optimizations, or LOD (Level of Detail) enhancements.' ;
    rdfs:domain ind:Patch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaSignOffReference rdf:type rdf:Property ;
    rdfs:label 'Qa Sign Off Reference' ;
    rdfs:comment 'Reference identifier to the QA test cycle or approval record that certified this patch as ready for release (e.g., Jira ticket, test plan ID).' ;
    rdfs:domain ind:Patch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rollbackDate rdf:type rdf:Property ;
    rdfs:label 'Rollback Date' ;
    rdfs:comment 'The date when the patch was rolled back or reverted due to critical issues discovered post-deployment. Null if no rollback occurred.' ;
    rdfs:domain ind:Patch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:securityFixesIncluded rdf:type rdf:Property ;
    rdfs:label 'Security Fixes Included' ;
    rdfs:comment 'Boolean flag indicating whether this patch includes security vulnerability fixes or anti-cheat improvements. True if security fixes are present, false otherwise.' ;
    rdfs:domain ind:Patch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sizeConsoleMb rdf:type rdf:Property ;
    rdfs:label 'Size Console Mb' ;
    rdfs:comment 'Size of the patch download for console platforms (PlayStation, Xbox, Switch) in megabytes. May vary by specific console; this represents a typical or average size.' ;
    rdfs:domain ind:Patch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sizeMobileMb rdf:type rdf:Property ;
    rdfs:label 'Size Mobile Mb' ;
    rdfs:comment 'Size of the patch download for mobile platforms (iOS, Android) in megabytes.' ;
    rdfs:domain ind:Patch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sizePcMb rdf:type rdf:Property ;
    rdfs:label 'Size Pc Mb' ;
    rdfs:comment 'Size of the patch download for PC platform in megabytes.' ;
    rdfs:domain ind:Patch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trcApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Trc Approval Date' ;
    rdfs:comment 'The date when the patch received approval from platform certification, clearing it for deployment.' ;
    rdfs:domain ind:Patch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trcSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Trc Submission Date' ;
    rdfs:comment 'The date when the patch was submitted to platform holders (Sony, Microsoft, Nintendo, Apple, Google) for technical certification review.' ;
    rdfs:domain ind:Patch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualParticipationCount rdf:type rdf:Property ;
    rdfs:label 'Actual Participation Count' ;
    rdfs:comment 'Actual number of unique players who participated in the event after completion. Null until event concludes and analytics are finalized.' ;
    rdfs:domain ind:SeasonalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetBundlePath rdf:type rdf:Property ;
    rdfs:label 'Asset Bundle Path' ;
    rdfs:comment 'File system or repository path to the event asset bundle in Perforce Helix Core, Unity, or Unreal Engine asset pipeline (e.g., \'/content/events/seasonal/winter_2024/\').' ;
    rdfs:domain ind:SeasonalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Status of first-party platform certification review (TRC/TCR compliance for console manufacturers): not_submitted, submitted, in_review, approved, rejected.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedParticipationCount rdf:type rdf:Property ;
    rdfs:label 'Estimated Participation Count' ;
    rdfs:comment 'Projected number of unique players expected to participate in the event, based on historical data, player base size, and marketing reach. Used for capacity planning.' ;
    rdfs:domain ind:SeasonalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Event Budget Amount' ;
    rdfs:comment 'Total allocated budget for event development, marketing, and operations (in USD or base currency). Includes content creation, QA, localization, and promotional spend.' ;
    rdfs:domain ind:SeasonalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusiveCosmeticRewardIds rdf:type rdf:Property ;
    rdfs:label 'Exclusive Cosmetic Reward Ids' ;
    rdfs:comment 'Comma-separated list of exclusive cosmetic item identifiers (skins, emotes, banners, avatars) available only during this event as participation rewards or purchasable items.' ;
    rdfs:domain ind:SeasonalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featuredContentBundleIds rdf:type rdf:Property ;
    rdfs:label 'Featured Content Bundle Ids' ;
    rdfs:comment 'Comma-separated list of content bundle identifiers associated with this event, including new maps, levels, missions, or story chapters released as part of the event.' ;
    rdfs:domain ind:SeasonalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localizationStatus rdf:type rdf:Property ;
    rdfs:label 'Localization Status' ;
    rdfs:comment 'Current state of localization and translation work for event strings, UI text, and narrative content across supported languages.' ;
    rdfs:domain ind:SeasonalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformEligibility rdf:type rdf:Property ;
    rdfs:label 'Platform Eligibility' ;
    rdfs:comment 'Comma-separated list of platforms where the event is available (e.g., \'PC,Console,Mobile\' or \'PlayStation,Xbox,Switch\'). Defines cross-platform availability.' ;
    rdfs:domain ind:SeasonalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerEligibilityRules rdf:type rdf:Property ;
    rdfs:label 'Player Eligibility Rules' ;
    rdfs:comment 'Business rules defining which players can participate in the event, including level requirements, region restrictions, account age, previous event participation, or VIP status criteria.' ;
    rdfs:domain ind:SeasonalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaStatus rdf:type rdf:Property ;
    rdfs:label 'Qa Status' ;
    rdfs:comment 'Current state of quality assurance testing for the event: not_started, in_progress, passed (approved for release), failed (issues found), blocked (dependencies unmet).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceSchedule rdf:type rdf:Property ;
    rdfs:label 'Recurrence Schedule' ;
    rdfs:comment 'Detailed schedule specification for recurring events, including specific dates, times, or calendar rules (e.g., \'Every December 15-31\', \'First weekend of each quarter\'). Null for one-time events.' ;
    rdfs:domain ind:SeasonalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardStructure rdf:type rdf:Property ;
    rdfs:label 'Reward Structure' ;
    rdfs:comment 'Detailed description of the reward distribution model: milestone-based, leaderboard rankings, participation tiers, daily login bonuses, or completion-based rewards.' ;
    rdfs:domain ind:SeasonalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedLanguages rdf:type rdf:Property ;
    rdfs:label 'Supported Languages' ;
    rdfs:comment 'Comma-separated list of ISO 639-1 language codes for which event content has been localized (e.g., \'en,es,fr,de,ja,zh,pt,ru\').' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDauLiftPercent rdf:type rdf:Property ;
    rdfs:label 'Target Dau Lift Percent' ;
    rdfs:comment 'Target percentage increase in Daily Active Users (DAU) expected during the event period compared to baseline. Key performance indicator for event success.' ;
    rdfs:domain ind:SeasonalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Target Revenue Amount' ;
    rdfs:comment 'Target incremental revenue (in USD or base currency) expected from event-related in-app purchases (IAP), microtransactions (MTX), and battle pass sales during the event window.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bracketId rdf:type rdf:Property ;
    rdfs:label 'Bracket Id' ;
    rdfs:comment 'Unique identifier for the bracket or group stage within a tournament. Primary key.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bracket .

ind:bracketCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Bracket Created By User Employee Id' ;
    rdfs:comment 'Reference to the user or system account that created this bracket record. Used for audit trail and accountability in tournament operations.' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bracketEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Bracket Employee Id' ;
    rdfs:comment 'Reference to the tournament organizer entity responsible for operating this bracket. May be first-party (game publisher) or third-party (external tournament operator). Used for contract management and revenue sharing calculations.' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:venueId rdf:type rdf:Property ;
    rdfs:label 'Venue Id' ;
    rdfs:comment 'Reference to the physical or virtual venue where this bracket stage is being held. Null for fully online brackets. Used for logistics, ticketing, and broadcast production planning.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Venue .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'The precise timestamp when the final match of this bracket stage actually concluded. Used for operational tracking, broadcast analytics, and schedule variance analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'The precise timestamp when the first match of this bracket stage actually began. Used for operational tracking, broadcast analytics, and schedule variance analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:advancementRule rdf:type rdf:Property ;
    rdfs:label 'Advancement Rule' ;
    rdfs:comment 'Business rule defining how teams progress to the next stage or round. Examples: \'Top 2 teams advance\', \'Winner advances to upper bracket, loser to lower bracket\', \'Top 4 by points qualify for playoffs\'. Free-text field capturing the specific progression logic for this bracket.' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageMinuteAudience rdf:type rdf:Property ;
    rdfs:label 'Average Minute Audience' ;
    rdfs:comment 'The average number of viewers watching at any given minute during this bracket stage. Standard broadcast metric used for advertising rate calculations and sponsorship deliverables.' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bestOfFormat rdf:type rdf:Property ;
    rdfs:label 'Best Of Format' ;
    rdfs:comment 'The match series length format for matches within this bracket. BO1 is single game; BO3 is best of three games; BO5 is best of five; BO7 is best of seven; variable indicates different rounds may have different formats (specified at match level).' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bracketName rdf:type rdf:Property ;
    rdfs:label 'Bracket Name' ;
    rdfs:comment 'Human-readable name or label for the bracket stage, such as \'Upper Bracket\', \'Lower Bracket\', \'Group A\', \'Playoffs\', \'Qualifier Round 1\'. Used for display and reporting purposes.' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bracketStatus rdf:type rdf:Property ;
    rdfs:label 'Bracket Status' ;
    rdfs:comment 'Current lifecycle state of the bracket. Draft indicates planning phase; scheduled means bracket is finalized and awaiting start; in_progress indicates active matches; completed means all matches finished; cancelled means bracket was terminated; suspended indicates temporary halt.' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bracketType rdf:type rdf:Property ;
    rdfs:label 'Bracket Type' ;
    rdfs:comment 'The competitive format structure of the bracket. Single elimination removes teams after one loss; double elimination allows one loss before elimination; round robin has all teams play each other; Swiss pairs teams with similar records; GSL group is a dual-tournament group stage; page playoff is a four-team format; gauntlet is a sequential challenge format. [ENUM-REF-CANDIDATE: single_elimination|double_elimination|round_robin|swiss|gsl_group|page_playoff|gauntlet — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastLanguageCodes rdf:type rdf:Property ;
    rdfs:label 'Broadcast Language Codes' ;
    rdfs:comment 'Comma-separated list of ISO 639-1 two-letter language codes for broadcast coverage of this bracket. Example: \'en,es,pt,zh,ko,ja\'. Used for localization planning and international audience tracking.' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastPriority rdf:type rdf:Property ;
    rdfs:label 'Broadcast Priority' ;
    rdfs:comment 'The broadcast coverage priority level for matches within this bracket. Primary indicates main stream coverage; secondary indicates alternate stream; tertiary indicates limited or VOD-only coverage; none indicates no broadcast planned.' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'The scheduled or actual date when the final match of this bracket stage is planned to complete or did complete. Used for tournament duration tracking and venue booking.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grandFinalResetFlag rdf:type rdf:Property ;
    rdfs:label 'Grand Final Reset Flag' ;
    rdfs:comment 'For double elimination brackets, indicates whether the grand final requires a bracket reset if the upper bracket finalist loses. True means the lower bracket winner must win two series; false means single series determines champion regardless of bracket path.' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchSchedulingBufferMinutes rdf:type rdf:Property ;
    rdfs:label 'Match Scheduling Buffer Minutes' ;
    rdfs:comment 'The standard time buffer in minutes allocated between consecutive matches in this bracket for player breaks, technical setup, and broadcast transitions. Used for automated scheduling and production planning.' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:peakCcu rdf:type rdf:Property ;
    rdfs:label 'Peak Ccu' ;
    rdfs:comment 'The maximum number of concurrent viewers across all broadcast channels during this bracket stage. Key performance indicator for broadcast success and sponsorship value. Measured across Twitch, YouTube, in-game spectator, and other platforms.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prizePoolAllocationPct rdf:type rdf:Property ;
    rdfs:label 'Prize Pool Allocation Pct' ;
    rdfs:comment 'The percentage of the total tournament prize pool allocated to this specific bracket stage. For example, if the main event bracket receives 80% of the total prize pool, this value would be 80.00. Used for prize distribution calculations and financial reporting.' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replayReviewEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Replay Review Enabled Flag' ;
    rdfs:comment 'Indicates whether match officials can review replays for disputed calls or rule violations during matches in this bracket. True means replay review is available; false means real-time officiating only.' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roundCount rdf:type rdf:Property ;
    rdfs:label 'Round Count' ;
    rdfs:comment 'Total number of competitive rounds within this bracket stage. For single elimination with 8 teams this would be 3 (quarterfinals, semifinals, finals). For round robin this represents the number of match days or cycles.' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rulesetVersion rdf:type rdf:Property ;
    rdfs:label 'Ruleset Version' ;
    rdfs:comment 'The version identifier of the competitive ruleset document governing this bracket. Tracks which set of tournament rules, map pools, character restrictions, and competitive settings apply. Example: \'LCS 2024 Spring v1.2\', \'TI12 Official Rules v3.0\'.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seedingMethod rdf:type rdf:Property ;
    rdfs:label 'Seeding Method' ;
    rdfs:comment 'The methodology used to determine initial team placement and matchup order within the bracket. Manual indicates tournament organizer assignment; performance-based uses historical stats; random draw is lottery-based; regional ranking uses geographic league standings; points-based uses accumulated tournament points; previous stage uses results from prior bracket.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spectatorMode rdf:type rdf:Property ;
    rdfs:label 'Spectator Mode' ;
    rdfs:comment 'The audience access model for this bracket stage. Live audience indicates in-person attendance allowed; online only means digital viewing only; hybrid allows both in-person and online; closed means no public viewing (internal/qualifier matches).' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorTier rdf:type rdf:Property ;
    rdfs:label 'Sponsor Tier' ;
    rdfs:comment 'The highest sponsorship tier associated with this bracket stage. Title sponsor has naming rights; presenting sponsor has secondary branding; official sponsor has category exclusivity; supporting sponsor has standard placement; none indicates no dedicated bracket sponsorship.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamCount rdf:type rdf:Property ;
    rdfs:label 'Team Count' ;
    rdfs:comment 'Number of teams or competitors participating in this bracket stage. Used for bracket structure validation and seeding calculations.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:technicalPauseAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Technical Pause Allowed Flag' ;
    rdfs:comment 'Indicates whether teams are permitted to request technical pauses during matches in this bracket. True means pauses are allowed per ruleset; false means no pauses permitted (typically for lower-tier or online qualifiers).' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdPlaceMatchFlag rdf:type rdf:Property ;
    rdfs:label 'Third Place Match Flag' ;
    rdfs:comment 'Indicates whether this bracket includes a third-place playoff match between the two semifinal losers. True means a bronze medal match is scheduled; false means no third-place match.' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tiebreakerRule rdf:type rdf:Property ;
    rdfs:label 'Tiebreaker Rule' ;
    rdfs:comment 'Business rule defining how ties in standings or match results are resolved. Examples: \'Head-to-head record\', \'Map differential\', \'Total kills\', \'Sudden death overtime\', \'Coin flip\'. Free-text field capturing the specific tiebreaker logic for this bracket.' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalViewership rdf:type rdf:Property ;
    rdfs:label 'Total Viewership' ;
    rdfs:comment 'The cumulative number of unique viewers who watched any portion of this bracket stage across all broadcast channels. Used for sponsorship reporting and media rights valuation.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:broadcastRightsId rdf:type rdf:Property ;
    rdfs:label 'Broadcast Rights Id' ;
    rdfs:comment 'Unique identifier for the broadcast rights agreement. Primary key.' ;
    rdfs:domain ind:BroadcastRights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Contract Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Broadcast rights agreements require internal contract owners for negotiation, compliance monitoring, revenue reconciliation, and renewal management. Gaming studios assign media rights managers to over' ;
    rdfs:domain ind:BroadcastRights ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:deferredRevenueId rdf:type rdf:Property ;
    rdfs:label 'Deferred Revenue Id' ;
    rdfs:comment 'Foreign key linking to finance.deferred_revenue. Business justification: Upfront broadcast rights payments create deferred revenue liabilities recognized over the contract term. Required for revenue recognition compliance (ASC 606), financial reporting, and liability track' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeferredRevenue .

ind:periodCloseId rdf:type rdf:Property ;
    rdfs:label 'Period Close Id' ;
    rdfs:comment 'Foreign key linking to finance.period_close. Business justification: Broadcast rights revenue recognition is reviewed during period close. Required for accurate revenue recognition, deferred revenue reconciliation, and financial statement preparation.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PeriodClose .

ind:advertisingRights rdf:type rdf:Property ;
    rdfs:label 'Advertising Rights' ;
    rdfs:comment 'Extent of advertising rights granted to the rights holder. Full means complete control over ad inventory; limited means restricted ad slots or types; none means no advertising permitted; shared means coordinated advertising with the league.' ;
    rdfs:domain ind:BroadcastRights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known unique identifier or contract number for the broadcast rights agreement. Used for legal and business reference.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the broadcast rights agreement. Tracks the agreement from initial draft through execution, active operation, and eventual termination or renewal. [ENUM-REF-CANDIDATE: draft|pending_approval|active|suspended|terminated|expired|renewed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirements rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirements' ;
    rdfs:comment 'Regulatory and industry compliance requirements applicable to the broadcast, including content rating disclosures (ESRB, PEGI), advertising standards (FTC), data protection (GDPR, COPPA), and platform-specific policies.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentScope rdf:type rdf:Property ;
    rdfs:label 'Content Scope' ;
    rdfs:comment 'Scope of content covered by the broadcast rights. May include live matches, replays, highlights, pre-game and post-game shows, player interviews, behind-the-scenes content, and other ancillary programming.' ;
    rdfs:domain ind:BroadcastRights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Flag' ;
    rdfs:comment 'Indicates whether the broadcast rights are exclusive to the rights holder within the specified territory and platform type. True means no other broadcaster can stream in that territory/platform; False means non-exclusive rights.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusivityScope rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Scope' ;
    rdfs:comment 'Detailed description of the exclusivity terms, including any carve-outs, co-exclusive arrangements, or platform-specific restrictions (e.g., exclusive for streaming but non-exclusive for linear TV).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highlightsRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Highlights Rights Flag' ;
    rdfs:comment 'Indicates whether the agreement includes rights to create and distribute highlight clips and short-form content. True if highlights rights are granted; False otherwise.' ;
    rdfs:domain ind:BroadcastRights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageRequirements rdf:type rdf:Property ;
    rdfs:label 'Language Requirements' ;
    rdfs:comment 'Languages in which the broadcast must be available, including commentary, subtitles, and localization requirements. May specify primary and secondary languages (e.g., English primary, Spanish and Portuguese secondary).' ;
    rdfs:domain ind:BroadcastRights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseFeeAmount rdf:type rdf:Property ;
    rdfs:label 'License Fee Amount' ;
    rdfs:comment 'Total license fee paid by the rights holder for the broadcast rights over the term of the agreement. Represents the guaranteed minimum payment.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:licenseFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'License Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the license fee amount (e.g., USD, EUR, GBP, JPY).' ;
    rdfs:domain ind:BroadcastRights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liveBroadcastFlag rdf:type rdf:Property ;
    rdfs:label 'Live Broadcast Flag' ;
    rdfs:comment 'Indicates whether the agreement includes rights to broadcast live matches and events. True if live broadcasting is permitted; False if only delayed or on-demand content is allowed.' ;
    rdfs:domain ind:BroadcastRights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localizationRequirements rdf:type rdf:Property ;
    rdfs:label 'Localization Requirements' ;
    rdfs:comment 'Detailed localization requirements beyond language, including cultural adaptations, regional commentary talent, local sponsorship integration, and territory-specific content adjustments.' ;
    rdfs:domain ind:BroadcastRights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumGuaranteedViewership rdf:type rdf:Property ;
    rdfs:label 'Minimum Guaranteed Viewership' ;
    rdfs:comment 'Minimum number of concurrent or cumulative viewers that the rights holder guarantees to deliver as part of the Service Level Agreement (SLA). Nullable if no viewership guarantee exists.' ;
    rdfs:domain ind:BroadcastRights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceBonusStructure rdf:type rdf:Property ;
    rdfs:label 'Performance Bonus Structure' ;
    rdfs:comment 'Structure of performance-based bonuses payable to the league or tournament organizer based on viewership milestones, engagement metrics, or other KPIs. Nullable if no performance bonuses exist.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformType rdf:type rdf:Property ;
    rdfs:label 'Platform Type' ;
    rdfs:comment 'Type of broadcast platform covered by the agreement. Streaming includes OTT and digital platforms; linear TV includes traditional broadcast and cable; in-game spectator refers to native game client viewing.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionQualityStandards rdf:type rdf:Property ;
    rdfs:label 'Production Quality Standards' ;
    rdfs:comment 'Minimum production quality standards required by the agreement, including resolution (e.g., 1080p, 4K), frame rate (e.g., 60 FPS), audio quality, and technical specifications.' ;
    rdfs:domain ind:BroadcastRights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionResponsibility rdf:type rdf:Property ;
    rdfs:label 'Production Responsibility' ;
    rdfs:comment 'Party responsible for producing the broadcast, including camera work, commentary, graphics, and technical production. May be the rights holder, the league/tournament organizer, a shared arrangement, or a contracted third party.' ;
    rdfs:domain ind:BroadcastRights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Flag' ;
    rdfs:comment 'Indicates whether the agreement includes an option for the rights holder to renew the broadcast rights for an additional term. True if renewal option exists; False otherwise.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalTerms rdf:type rdf:Property ;
    rdfs:label 'Renewal Terms' ;
    rdfs:comment 'Terms and conditions governing the renewal option, including renewal period duration, pricing adjustments, notice period required, and any changes to rights scope or exclusivity.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueShareBasis rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Basis' ;
    rdfs:comment 'Defines the basis on which revenue share is calculated: gross revenue, net revenue after costs, advertising revenue only, subscription revenue only, or not applicable if no revenue share exists.' ;
    rdfs:domain ind:BroadcastRights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Percentage' ;
    rdfs:comment 'Percentage of advertising, subscription, or other broadcast-related revenue that the rights holder must share with the league or tournament organizer. Nullable if the agreement is a flat-fee arrangement with no revenue share.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rightsEndDate rdf:type rdf:Property ;
    rdfs:label 'Rights End Date' ;
    rdfs:comment 'Date when the broadcast rights agreement expires. Nullable for open-ended or perpetual agreements subject to termination clauses.' ;
    rdfs:domain ind:BroadcastRights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rightsHolderName rdf:type rdf:Property ;
    rdfs:label 'Rights Holder Name' ;
    rdfs:comment 'Name of the organization or entity that holds the broadcast rights (e.g., Twitch, YouTube Gaming, ESPN, NBC Sports).' ;
    rdfs:domain ind:BroadcastRights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsHolderType rdf:type rdf:Property ;
    rdfs:label 'Rights Holder Type' ;
    rdfs:comment 'Classification of the rights holder by platform type. Distinguishes between streaming platforms, traditional television, in-game spectator modes, and other distribution channels. [ENUM-REF-CANDIDATE: streaming_platform|linear_tv|cable_network|digital_network|in_game_spectator|social_media|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BroadcastRights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsStartDate rdf:type rdf:Property ;
    rdfs:label 'Rights Start Date' ;
    rdfs:comment 'Date when the broadcast rights agreement becomes effective and the rights holder may begin broadcasting.' ;
    rdfs:domain ind:BroadcastRights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'Date when the broadcast rights agreement was signed by all parties. Represents the legal execution date of the contract.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sponsorshipIntegrationRights rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Integration Rights' ;
    rdfs:comment 'Rights and restrictions regarding integration of the rights holder\'s own sponsors into the broadcast, including on-screen branding, sponsored segments, and product placement. May include conflict-of-interest clauses with league sponsors.' ;
    rdfs:domain ind:BroadcastRights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sublicensingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Sublicensing Allowed Flag' ;
    rdfs:comment 'Indicates whether the rights holder is permitted to sublicense the broadcast rights to third parties. True if sublicensing is allowed; False if the rights are non-transferable.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sublicensingTerms rdf:type rdf:Property ;
    rdfs:label 'Sublicensing Terms' ;
    rdfs:comment 'Detailed terms and conditions governing sublicensing, including approval requirements, revenue share on sublicensed deals, and restrictions on sublicensee types or territories.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationClause rdf:type rdf:Property ;
    rdfs:label 'Termination Clause' ;
    rdfs:comment 'Summary of termination conditions and notice requirements, including breach conditions, force majeure provisions, and early termination penalties or buyout terms.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewershipMetricType rdf:type rdf:Property ;
    rdfs:label 'Viewership Metric Type' ;
    rdfs:comment 'Type of viewership metric used for the minimum guaranteed viewership SLA. CCU (Concurrent Users), PCU (Peak Concurrent Users), total views, unique viewers, or watch hours.' ;
    rdfs:domain ind:BroadcastRights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vodRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Vod Rights Flag' ;
    rdfs:comment 'Indicates whether the agreement includes rights to offer video-on-demand replays and archived content. True if VOD rights are granted; False if only live or time-limited content is permitted.' ;
    rdfs:domain ind:BroadcastRights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:broadcastViewershipId rdf:type rdf:Property ;
    rdfs:label 'Broadcast Viewership Id' ;
    rdfs:comment 'Primary key for broadcast_viewership' ;
    rdfs:domain ind:BroadcastViewership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:broadcastSessionId rdf:type rdf:Property ;
    rdfs:label 'Broadcast Session Id' ;
    rdfs:comment 'The unique session identifier assigned by the broadcast platform for this specific live stream. Used for platform-level reconciliation and SLA validation.' ;
    rdfs:domain ind:BroadcastViewership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Session .

ind:promotionalAssetId rdf:type rdf:Property ;
    rdfs:label 'Promotional Asset Id' ;
    rdfs:comment 'Foreign key linking to content.asset. Business justification: Broadcasts feature promotional assets (sponsor overlays, team logos, event graphics). Tracking asset usage is required for sponsor deliverable verification, rights management compliance, and broadcast' ;
    rdfs:domain ind:BroadcastViewership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:adBreakActive rdf:type rdf:Property ;
    rdfs:label 'Ad Break Active' ;
    rdfs:comment 'Indicates whether a commercial ad break was active at the time of this measurement. Used for monetization analysis and viewer retention impact assessment.' ;
    rdfs:domain ind:BroadcastViewership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:averageWatchTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Average Watch Time Minutes' ;
    rdfs:comment 'The average duration in minutes that viewers have watched the broadcast, calculated across all viewers at this measurement interval.' ;
    rdfs:domain ind:BroadcastViewership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bitrateKbps rdf:type rdf:Property ;
    rdfs:label 'Bitrate Kbps' ;
    rdfs:comment 'The average streaming bitrate in kilobits per second at this measurement interval. Technical metric for stream quality and CDN performance.' ;
    rdfs:domain ind:BroadcastViewership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:broadcastLanguage rdf:type rdf:Property ;
    rdfs:label 'Broadcast Language' ;
    rdfs:comment 'The primary language of the broadcast stream, represented as ISO 639-1 two-letter code. Supports multi-language broadcast strategy and regional targeting.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastPlatform rdf:type rdf:Property ;
    rdfs:label 'Broadcast Platform' ;
    rdfs:comment 'The streaming platform where the esports event was broadcast (e.g., Twitch, YouTube Gaming, Facebook Gaming).' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Broadcast Start Timestamp' ;
    rdfs:comment 'The timestamp when the live broadcast session began. Establishes the baseline for session duration and lifecycle analysis.' ;
    rdfs:domain ind:BroadcastViewership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:broadcastStatus rdf:type rdf:Property ;
    rdfs:label 'Broadcast Status' ;
    rdfs:comment 'The operational status of the broadcast at the time of this measurement. Tracks stream health and continuity for SLA compliance.' ;
    rdfs:domain ind:BroadcastViewership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bufferingRatio rdf:type rdf:Property ;
    rdfs:label 'Buffering Ratio' ;
    rdfs:comment 'The ratio of time spent buffering to total watch time, measured at this interval. Quality of Service (QoS) metric for viewer experience.' ;
    rdfs:domain ind:BroadcastViewership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ccu rdf:type rdf:Property ;
    rdfs:label 'Ccu' ;
    rdfs:comment 'The number of concurrent users watching the broadcast at the time of this measurement interval. Key metric for real-time audience engagement.' ;
    rdfs:domain ind:BroadcastViewership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chatMessageVolume rdf:type rdf:Property ;
    rdfs:label 'Chat Message Volume' ;
    rdfs:comment 'The cumulative number of chat messages posted by viewers during the broadcast session up to this measurement timestamp. Indicates audience engagement level.' ;
    rdfs:domain ind:BroadcastViewership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coStreamCount rdf:type rdf:Property ;
    rdfs:label 'Co Stream Count' ;
    rdfs:comment 'The number of authorized co-streams or watch parties running simultaneously for this event at this measurement interval. Amplification and reach metric.' ;
    rdfs:domain ind:BroadcastViewership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consoleViewerPercentage rdf:type rdf:Property ;
    rdfs:label 'Console Viewer Percentage' ;
    rdfs:comment 'The percentage of viewers watching via gaming console devices at this measurement interval. Platform distribution metric for audience segmentation.' ;
    rdfs:domain ind:BroadcastViewership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:desktopViewerPercentage rdf:type rdf:Property ;
    rdfs:label 'Desktop Viewer Percentage' ;
    rdfs:comment 'The percentage of viewers watching via desktop/PC devices at this measurement interval. Platform distribution metric for audience segmentation.' ;
    rdfs:domain ind:BroadcastViewership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:followerViewerCount rdf:type rdf:Property ;
    rdfs:label 'Follower Viewer Count' ;
    rdfs:comment 'The number of channel followers watching at this measurement interval. Community engagement and retention metric.' ;
    rdfs:domain ind:BroadcastViewership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geographicDistributionSnapshot rdf:type rdf:Property ;
    rdfs:label 'Geographic Distribution Snapshot' ;
    rdfs:comment 'A snapshot representation of viewer geographic distribution at this measurement interval, typically stored as JSON or delimited country codes with viewer counts. Supports regional audience analysis.' ;
    rdfs:domain ind:BroadcastViewership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Timestamp' ;
    rdfs:comment 'The exact timestamp when this viewership measurement was captured during the live broadcast. Represents the real-world event time of the telemetry snapshot.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mobileViewerPercentage rdf:type rdf:Property ;
    rdfs:label 'Mobile Viewer Percentage' ;
    rdfs:comment 'The percentage of viewers watching via mobile devices at this measurement interval. Platform distribution metric for audience segmentation.' ;
    rdfs:domain ind:BroadcastViewership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newViewerCount rdf:type rdf:Property ;
    rdfs:label 'New Viewer Count' ;
    rdfs:comment 'The number of new viewers who joined the broadcast since the previous measurement interval. Tracks audience growth and discovery during the event.' ;
    rdfs:domain ind:BroadcastViewership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pcu rdf:type rdf:Property ;
    rdfs:label 'Pcu' ;
    rdfs:comment 'The peak concurrent users recorded during this broadcast session up to the measurement timestamp. Represents the maximum simultaneous viewership achieved.' ;
    rdfs:domain ind:BroadcastViewership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:peakTimestamp rdf:type rdf:Property ;
    rdfs:label 'Peak Timestamp' ;
    rdfs:comment 'The timestamp when the peak concurrent users (PCU) was recorded during this broadcast session. Identifies the moment of maximum audience engagement.' ;
    rdfs:domain ind:BroadcastViewership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:raidIncomingViewers rdf:type rdf:Property ;
    rdfs:label 'Raid Incoming Viewers' ;
    rdfs:comment 'The number of viewers who joined via a raid or host from another channel at this measurement interval. Cross-promotion and discovery metric.' ;
    rdfs:domain ind:BroadcastViewership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sponsorshipOverlayActive rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Overlay Active' ;
    rdfs:comment 'Indicates whether sponsor branding or overlay graphics were displayed at the time of this measurement. Sponsorship fulfillment and impression tracking.' ;
    rdfs:domain ind:BroadcastViewership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:streamQualityTier rdf:type rdf:Property ;
    rdfs:label 'Stream Quality Tier' ;
    rdfs:comment 'The predominant stream quality tier being consumed by viewers at this measurement interval. Indicates technical delivery performance and viewer experience quality. [ENUM-REF-CANDIDATE: source|1080p60|1080p|720p60|720p|480p|360p|audio_only — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BroadcastViewership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriberViewerCount rdf:type rdf:Property ;
    rdfs:label 'Subscriber Viewer Count' ;
    rdfs:comment 'The number of platform subscribers (e.g., Twitch subscribers, YouTube members) watching at this measurement interval. Monetization and loyalty metric.' ;
    rdfs:domain ind:BroadcastViewership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uniqueViewers rdf:type rdf:Property ;
    rdfs:label 'Unique Viewers' ;
    rdfs:comment 'The cumulative count of unique individual viewers who have watched any portion of the broadcast session up to this measurement point.' ;
    rdfs:domain ind:BroadcastViewership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:viewerDropCount rdf:type rdf:Property ;
    rdfs:label 'Viewer Drop Count' ;
    rdfs:comment 'The number of viewers who disconnected or stopped watching since the previous measurement interval. Indicates audience retention and engagement fluctuations.' ;
    rdfs:domain ind:BroadcastViewership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vodAvailability rdf:type rdf:Property ;
    rdfs:label 'Vod Availability' ;
    rdfs:comment 'Indicates whether a video-on-demand recording will be available after the live broadcast ends. Content strategy and rights management indicator.' ;
    rdfs:domain ind:BroadcastViewership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:esportsSeasonId rdf:type rdf:Property ;
    rdfs:label 'Esports Season Id' ;
    rdfs:comment 'Unique identifier for the esports season. Primary key for the season entity.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EsportsSeason .

ind:titlePlId rdf:type rdf:Property ;
    rdfs:label 'Title Pl Id' ;
    rdfs:comment 'Foreign key linking to finance.title_pl. Business justification: Season financial performance (revenue, costs, EBITDA) rolls up into title P&L for game-level financial reporting. Required for title profitability tracking and financial analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TitlePl .

ind:broadcastRightsHolder rdf:type rdf:Property ;
    rdfs:label 'Broadcast Rights Holder' ;
    rdfs:comment 'The primary media partner or platform holding exclusive broadcast rights for the season (e.g., Twitch, YouTube, ESPN). Critical for revenue and viewership tracking.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crowdfundedAmount rdf:type rdf:Property ;
    rdfs:label 'Crowdfunded Amount' ;
    rdfs:comment 'The portion of the prize pool contributed by the player community through in-game purchases or battle passes. Tracks community contribution to prize pool.' ;
    rdfs:domain ind:EsportsSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:formatType rdf:type rdf:Property ;
    rdfs:label 'Format Type' ;
    rdfs:comment 'The competitive format structure used for the season. Defines how teams compete and advance through the season. [ENUM-REF-CANDIDATE: Round Robin|Single Elimination|Double Elimination|Swiss|Group Stage|Ladder|Hybrid — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLanEvent rdf:type rdf:Property ;
    rdfs:label 'Is Lan Event' ;
    rdfs:comment 'Indicates whether the season includes in-person LAN events or is entirely online. Impacts logistics, costs, and competitive integrity.' ;
    rdfs:domain ind:EsportsSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxTeams rdf:type rdf:Property ;
    rdfs:label 'Max Teams' ;
    rdfs:comment 'The maximum number of teams allowed to participate in the season. Defines the competitive field size and bracket structure.' ;
    rdfs:domain ind:EsportsSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minTeams rdf:type rdf:Property ;
    rdfs:label 'Min Teams' ;
    rdfs:comment 'The minimum number of teams required for the season to proceed. Used for viability assessment and cancellation decisions.' ;
    rdfs:domain ind:EsportsSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ordinal rdf:type rdf:Property ;
    rdfs:label 'Ordinal' ;
    rdfs:comment 'Sequential number of this season within the league (e.g., 1 for first season, 5 for fifth season). Used for historical ordering and analytics.' ;
    rdfs:domain ind:EsportsSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prizePoolCurrency rdf:type rdf:Property ;
    rdfs:label 'Prize Pool Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the prize pool (e.g., USD, EUR, GBP). Used for financial reporting and payout processing.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationSlots rdf:type rdf:Property ;
    rdfs:label 'Qualification Slots' ;
    rdfs:comment 'Number of top-performing teams that qualify for the next tier or championship event. Defines advancement opportunities from this season.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:registeredTeamsCount rdf:type rdf:Property ;
    rdfs:label 'Registered Teams Count' ;
    rdfs:comment 'The current number of teams registered for the season. Updated in real-time during registration period for capacity planning.' ;
    rdfs:domain ind:EsportsSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:registrationEndDate rdf:type rdf:Property ;
    rdfs:label 'Registration End Date' ;
    rdfs:comment 'The deadline for team and player registration for the season. After this date, rosters are typically locked for the season start.' ;
    rdfs:domain ind:EsportsSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationStartDate rdf:type rdf:Property ;
    rdfs:label 'Registration Start Date' ;
    rdfs:comment 'The date when team and player registration opens for the season. Critical for operational planning and team onboarding.' ;
    rdfs:domain ind:EsportsSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relegationSlots rdf:type rdf:Property ;
    rdfs:label 'Relegation Slots' ;
    rdfs:comment 'Number of bottom-performing teams that are relegated to a lower tier. Defines demotion risk and competitive stakes.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonCode rdf:type rdf:Property ;
    rdfs:label 'Season Code' ;
    rdfs:comment 'Short alphanumeric code used for internal identification and system integration (e.g., \'S5_2024\', \'SPR24\').' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonDescription rdf:type rdf:Property ;
    rdfs:label 'Season Description' ;
    rdfs:comment 'Detailed narrative description of the season including format details, special rules, and promotional messaging. Used for marketing and player communication.' ;
    rdfs:domain ind:EsportsSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonName rdf:type rdf:Property ;
    rdfs:label 'Season Name' ;
    rdfs:comment 'The official marketing and display name of the esports season (e.g., \'Spring Championship 2024\', \'World Series Season 5\').' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonStatus rdf:type rdf:Property ;
    rdfs:label 'Season Status' ;
    rdfs:comment 'Current lifecycle status of the season. Tracks the season from planning through completion and supports operational workflows. [ENUM-REF-CANDIDATE: Draft|Announced|Registration Open|Registration Closed|Active|Playoffs|Completed|Cancelled|Suspended — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:split rdf:type rdf:Property ;
    rdfs:label 'Split' ;
    rdfs:comment 'The calendar or competitive split designation for the season. Indicates which portion of the competitive year this season represents. [ENUM-REF-CANDIDATE: Spring|Summer|Fall|Winter|Annual|Mid-Season|Playoffs — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EsportsSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorPrimary rdf:type rdf:Property ;
    rdfs:label 'Sponsor Primary' ;
    rdfs:comment 'The name of the primary title sponsor for the season. Critical for branding, revenue attribution, and sponsorship fulfillment tracking.' ;
    rdfs:domain ind:EsportsSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierLevel rdf:type rdf:Property ;
    rdfs:label 'Tier Level' ;
    rdfs:comment 'The competitive tier or prestige level of the season within the league hierarchy. Determines prize pool scale and qualification pathways. [ENUM-REF-CANDIDATE: Premier|Major|Minor|Challenger|Amateur|Regional|International — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPrizePoolAmount rdf:type rdf:Property ;
    rdfs:label 'Total Prize Pool Amount' ;
    rdfs:comment 'The total monetary prize pool allocated for the season across all placements and awards. Includes base pool and any crowdfunded additions.' ;
    rdfs:domain ind:EsportsSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalViewershipHours rdf:type rdf:Property ;
    rdfs:label 'Total Viewership Hours' ;
    rdfs:comment 'Cumulative hours watched across all matches and broadcasts during the season. Primary metric for sponsor value and broadcast success.' ;
    rdfs:domain ind:EsportsSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:updatedBy rdf:type rdf:Property ;
    rdfs:label 'Updated By' ;
    rdfs:comment 'The user or system account that last modified the season record. Tracks change ownership for governance and audit.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueLocation rdf:type rdf:Property ;
    rdfs:label 'Venue Location' ;
    rdfs:comment 'The primary physical venue or city hosting LAN events for the season. Null for online-only seasons. Used for event operations and marketing.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:year rdf:type rdf:Property ;
    rdfs:label 'Year' ;
    rdfs:comment 'The calendar year in which the season primarily takes place. Used for year-over-year analytics and historical reporting.' ;
    rdfs:domain ind:EsportsSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:teamId rdf:type rdf:Property ;
    rdfs:label 'Team Id' ;
    rdfs:comment 'Unique identifier for the esports team. Primary key for the esports_team product. Serves as the identity anchor for all team-level relationships including rosters, contracts, standings, sponsorships, transfers, and tournament registrations.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:intercompanyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Intercompany Transaction Id' ;
    rdfs:comment 'Foreign key linking to finance.intercompany_transaction. Business justification: Teams owned by different subsidiaries generate intercompany transactions for player transfers, shared services, and cost allocations. Required for intercompany reconciliation and consolidation.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IntercompanyTransaction .

ind:primaryGameTitleId rdf:type rdf:Property ;
    rdfs:label 'Primary Game Title Id' ;
    rdfs:comment 'Foreign key reference to the primary game title that this team competes in (e.g., League of Legends, Counter-Strike, Valorant). Teams may compete in multiple titles, but this identifies their flagship game.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GameTitle .

ind:studioPlId rdf:type rdf:Property ;
    rdfs:label 'Studio Pl Id' ;
    rdfs:comment 'Foreign key linking to finance.studio_pl. Business justification: Publisher-owned teams operated by studios contribute costs to studio P&L. Required for studio cost tracking and financial reporting in franchise league models.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StudioPl .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Primary business contact phone number for the team organization. Used for urgent communications and operational coordination.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiry Date' ;
    rdfs:comment 'The date when the teams current league participation contract or franchise agreement expires. Used for contract renewal planning and partnership lifecycle management.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentWorldRanking rdf:type rdf:Property ;
    rdfs:label 'Current World Ranking' ;
    rdfs:comment 'The teams current global ranking position within their primary game title. Lower numbers indicate higher ranking (1 is best). Used for seeding, tournament invitations, and performance tracking.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:foundingDate rdf:type rdf:Property ;
    rdfs:label 'Founding Date' ;
    rdfs:comment 'The date when the esports team or organization was officially founded or established. Used for historical tracking and legacy analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:franchiseFeePaid rdf:type rdf:Property ;
    rdfs:label 'Franchise Fee Paid' ;
    rdfs:comment 'The total franchise fee paid by the organization to secure a permanent league slot. Tracked in USD. Highly confidential financial data used for revenue recognition and partnership valuation.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:generalManagerName rdf:type rdf:Property ;
    rdfs:label 'General Manager Name' ;
    rdfs:comment 'Full name of the teams general manager or director of esports operations. Responsible for roster decisions, contracts, and organizational strategy.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headCoachName rdf:type rdf:Property ;
    rdfs:label 'Head Coach Name' ;
    rdfs:comment 'Full name of the teams current head coach or manager. Key personnel information for broadcasts, media, and organizational tracking.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddress rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address' ;
    rdfs:comment 'Physical address of the teams headquarters, training facility, or primary business location. Used for legal correspondence, contract execution, and facility management.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'City where the teams headquarters or primary facility is located. Used for geographic analysis and regional market segmentation.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersPostalCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the teams headquarters location. Used for shipping, logistics, and geographic analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFranchiseTeam rdf:type rdf:Property ;
    rdfs:label 'Is Franchise Team' ;
    rdfs:comment 'Boolean flag indicating whether this team holds a franchise slot in a Gaming-operated franchised league. Franchise teams have permanent league positions and revenue sharing agreements.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leagueChampionships rdf:type rdf:Property ;
    rdfs:label 'League Championships' ;
    rdfs:comment 'Total number of league championships won by the team in Gaming-operated leagues. Distinct from tournament wins, represents seasonal league titles.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:organizationLegalName rdf:type rdf:Property ;
    rdfs:label 'Organization Legal Name' ;
    rdfs:comment 'The legal registered name of the organization or entity that owns and operates the esports team. Used for contracts, prize pool disbursements, and regulatory compliance.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionalRanking rdf:type rdf:Property ;
    rdfs:label 'Regional Ranking' ;
    rdfs:comment 'The teams current ranking position within their home region. Used for regional tournament seeding and qualification tracking.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rosterLockDate rdf:type rdf:Property ;
    rdfs:label 'Roster Lock Date' ;
    rdfs:comment 'The date when the current roster lock period began. Used to enforce roster change restrictions during tournament phases and calculate lock duration.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rosterLockStatus rdf:type rdf:Property ;
    rdfs:label 'Roster Lock Status' ;
    rdfs:comment 'Boolean flag indicating whether the teams roster is currently locked for tournament play. True means no roster changes are allowed during the lock period (typically during active tournament phases), False means roster changes are permitted.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rosterSize rdf:type rdf:Property ;
    rdfs:label 'Roster Size' ;
    rdfs:comment 'The current number of active players on the teams roster. Used for roster compliance checks against league minimum and maximum roster size rules.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:secondaryGameTitleIds rdf:type rdf:Property ;
    rdfs:label 'Secondary Game Title Ids' ;
    rdfs:comment 'Comma-separated list of additional game title IDs that this team competes in beyond their primary title. Supports multi-game organizations.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorshipTier rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Tier' ;
    rdfs:comment 'Classification of the teams sponsorship level or tier within Gaming-operated leagues. Higher tiers indicate more valuable sponsorship packages and revenue sharing agreements. Used for revenue allocation and partnership management.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamName rdf:type rdf:Property ;
    rdfs:label 'Team Name' ;
    rdfs:comment 'The full display name of the esports team or organization (e.g., \'Cloud9\', \'Team Liquid\', \'FaZe Clan\'). This is the primary human-readable identifier used in broadcasts, standings, and marketing materials.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamStatus rdf:type rdf:Property ;
    rdfs:label 'Team Status' ;
    rdfs:comment 'Current operational status of the esports team. Active teams are competing, inactive teams are not currently competing but still exist, disbanded teams have permanently ceased operations, suspended teams are temporarily barred from competition, on_hiatus teams are taking a break.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierClassification rdf:type rdf:Property ;
    rdfs:label 'Tier Classification' ;
    rdfs:comment 'Classification of the teams competitive tier or level (Tier 1 for top-level professional teams, Tier 2/3 for semi-professional, Academy for development teams, Amateur for grassroots). Determines tournament eligibility and prize pool access.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPrizeMoneyWon rdf:type rdf:Property ;
    rdfs:label 'Total Prize Money Won' ;
    rdfs:comment 'Cumulative total prize money won by the team across all Gaming-operated tournaments and leagues. Tracked in USD. Used for performance analytics, team valuation, and historical achievement tracking.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tournamentWins rdf:type rdf:Property ;
    rdfs:label 'Tournament Wins' ;
    rdfs:comment 'Total number of tournament championships won by the team in Gaming-operated competitions. Key performance indicator for team success and legacy.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:twitchChannel rdf:type rdf:Property ;
    rdfs:label 'Twitch Channel' ;
    rdfs:comment 'Official Twitch channel name for the team. Used for live streaming, broadcast rights tracking, and viewership analytics.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:twitterHandle rdf:type rdf:Property ;
    rdfs:label 'Twitter Handle' ;
    rdfs:comment 'Official Twitter/X handle for the team (e.g., \'@Cloud9\'). Used for social media tracking, engagement analytics, and community management.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Official website URL for the esports team or organization. Primary digital presence for fans, sponsors, and media.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:youtubeChannel rdf:type rdf:Property ;
    rdfs:label 'Youtube Channel' ;
    rdfs:comment 'Official YouTube channel name or handle for the team. Used for content distribution, VOD hosting, and video engagement tracking.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gameResultId rdf:type rdf:Property ;
    rdfs:label 'Game Result Id' ;
    rdfs:comment 'Unique identifier for the game result record. Primary key for this transactional entity representing a single game (map/round) within a competitive match.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GameResult .

ind:primaryGamePlayerAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Game Player Account Id' ;
    rdfs:comment 'Reference to the player awarded MVP (Most Valuable Player) for this game based on performance metrics (kills, assists, objectives, damage). Nullable if MVP is not awarded.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerAccount .

ind:primaryGameWinningTeamId rdf:type rdf:Property ;
    rdfs:label 'Primary Game Winning Team Id' ;
    rdfs:comment 'Reference to the team that won this game. Nullable if the game ended in a draw or was not completed.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:roundId rdf:type rdf:Property ;
    rdfs:label 'Round Id' ;
    rdfs:comment 'Reference to the tournament round or stage this game belongs to (e.g., Group Stage, Quarterfinals, Grand Finals). Used for bracket progression and standings calculation.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Round .

ind:tertiaryGameTeamBEsportsTeamId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Game Team B Esports Team Id' ;
    rdfs:comment 'Reference to the second competing team in this game. Typically the away team or lower-seeded team in bracket play.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:broadcastFlag rdf:type rdf:Property ;
    rdfs:label 'Broadcast Flag' ;
    rdfs:comment 'Indicates whether this game was broadcast live on streaming platforms (Twitch, YouTube, etc.). True if broadcast, False otherwise. Used for rights management and viewership correlation.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competitiveTier rdf:type rdf:Property ;
    rdfs:label 'Competitive Tier' ;
    rdfs:comment 'Classification of the competitive level of this game (e.g., professional, semi-professional, amateur, collegiate). Used for prize pool allocation, broadcast rights, and player eligibility.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disqualificationFlag rdf:type rdf:Property ;
    rdfs:label 'Disqualification Flag' ;
    rdfs:comment 'Indicates whether this game result was disqualified due to rule violations, cheating, or technical issues. True if disqualified, False otherwise.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disqualificationReason rdf:type rdf:Property ;
    rdfs:label 'Disqualification Reason' ;
    rdfs:comment 'Detailed explanation of why the game was disqualified, if applicable. Includes rule violations, cheating incidents, technical failures, or administrative decisions.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gameEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Game End Timestamp' ;
    rdfs:comment 'Timestamp when the game officially ended (victory condition met or forfeit declared). Used for duration calculation and event sequencing.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gameNumber rdf:type rdf:Property ;
    rdfs:label 'Game Number' ;
    rdfs:comment 'Sequential number of this game within the match (e.g., 1, 2, 3 for a BO3). Determines ordering and progression through the match series.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gameStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Game Start Timestamp' ;
    rdfs:comment 'Timestamp when the game officially started (first frame rendered or countdown completed). Used for live operations, broadcast synchronization, and CCU (Concurrent Users) tracking.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gameStatus rdf:type rdf:Property ;
    rdfs:label 'Game Status' ;
    rdfs:comment 'Current lifecycle status of the game. Indicates whether the game was completed normally, forfeited by a team, disqualified due to rule violations, or cancelled by tournament officials.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pauseCount rdf:type rdf:Property ;
    rdfs:label 'Pause Count' ;
    rdfs:comment 'Number of times the game was paused during play due to technical issues, player requests, or referee intervention. Used for match quality assessment and technical operations review.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prizePoolContributionFlag rdf:type rdf:Property ;
    rdfs:label 'Prize Pool Contribution Flag' ;
    rdfs:comment 'Indicates whether this game result contributes to prize pool distribution calculations. True if it counts toward prize money, False for exhibition or practice games.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:replayFileUrl rdf:type rdf:Property ;
    rdfs:label 'Replay File Url' ;
    rdfs:comment 'URL or storage path to the game replay file for post-match analysis, content creation, and dispute resolution. Stored in CDN (Content Delivery Network) for player and analyst access.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sideSelection rdf:type rdf:Property ;
    rdfs:label 'Side Selection' ;
    rdfs:comment 'Method used to determine which team selected their starting side (e.g., attacking/defending, blue/red side). Important for competitive balance analysis in asymmetric games.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spectatorCount rdf:type rdf:Property ;
    rdfs:label 'Spectator Count' ;
    rdfs:comment 'Number of live spectators watching this game through in-game spectator mode or tournament observer slots. Excludes broadcast viewers.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:teamAScore rdf:type rdf:Property ;
    rdfs:label 'Team A Score' ;
    rdfs:comment 'Final score achieved by Team A in this game. Scoring semantics vary by game title (kills, rounds won, points, objectives captured).' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:teamASide rdf:type rdf:Property ;
    rdfs:label 'Team A Side' ;
    rdfs:comment 'The starting side or faction assigned to Team A (e.g., CT, Radiant, Blue Side, Attackers). Used for win-rate analysis by side and competitive balance tuning.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamBScore rdf:type rdf:Property ;
    rdfs:label 'Team B Score' ;
    rdfs:comment 'Final score achieved by Team B in this game. Scoring semantics vary by game title (kills, rounds won, points, objectives captured).' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:teamBSide rdf:type rdf:Property ;
    rdfs:label 'Team B Side' ;
    rdfs:comment 'The starting side or faction assigned to Team B (e.g., T, Dire, Red Side, Defenders). Used for win-rate analysis by side and competitive balance tuning.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalIssueDescription rdf:type rdf:Property ;
    rdfs:label 'Technical Issue Description' ;
    rdfs:comment 'Detailed description of any technical issues that occurred during the game, including server problems, client crashes, or game-breaking bugs. Used for post-match review and infrastructure improvement.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalIssueFlag rdf:type rdf:Property ;
    rdfs:label 'Technical Issue Flag' ;
    rdfs:comment 'Indicates whether technical issues (server lag, disconnects, bugs) occurred during this game that may have impacted competitive integrity. True if issues occurred, False otherwise.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalPauseDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Total Pause Duration Seconds' ;
    rdfs:comment 'Cumulative time in seconds that the game was paused. Excludes active gameplay time. Used for broadcast scheduling and match quality metrics.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Status of official verification for this game result by tournament administrators. Verified results are final and used for standings; disputed results are under review.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationId rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_allocation. Business justification: League overhead costs are allocated to participating teams or titles using allocation methods. Required for accurate cost center reporting and shared service cost allocation.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostAllocation .

ind:operationsEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Operations Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Leagues require internal operational owners for scheduling coordination, rulebook enforcement, team compliance monitoring, and broadcast logistics. Gaming studios assign dedicated league operations ma' ;
    rdfs:domain ind:League ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ageRestriction rdf:type rdf:Property ;
    rdfs:label 'Age Restriction' ;
    rdfs:comment 'Minimum age requirement for players to participate in the league (none, 13+, 16+, 18+).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leagueCode rdf:type rdf:Property ;
    rdfs:label 'League Code' ;
    rdfs:comment 'Short alphanumeric code or abbreviation for the league (e.g., LCS, VCT, RLCS).' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leagueName rdf:type rdf:Property ;
    rdfs:label 'League Name' ;
    rdfs:comment 'Official name of the esports league (e.g., League Championship Series, Valorant Champions Tour).' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leagueStatus rdf:type rdf:Property ;
    rdfs:label 'League Status' ;
    rdfs:comment 'Current operational status of the league (active, inactive, suspended, planned, archived).' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leagueTier rdf:type rdf:Property ;
    rdfs:label 'League Tier' ;
    rdfs:comment 'Competitive tier classification of the league (T1 for top-tier professional, T2 for secondary professional, T3 for semi-professional, amateur, grassroots).' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchCount rdf:type rdf:Property ;
    rdfs:label 'Match Count' ;
    rdfs:comment 'Total number of matches scheduled or played in the current or most recent season.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:organizerName rdf:type rdf:Property ;
    rdfs:label 'Organizer Name' ;
    rdfs:comment 'Name of the organization or entity responsible for operating the league.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patchVersionEnd rdf:type rdf:Property ;
    rdfs:label 'Patch Version End' ;
    rdfs:comment 'Game patch version at the end of the season (e.g., 13.8, 7.12). Tracks game evolution during the competitive season.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patchVersionStart rdf:type rdf:Property ;
    rdfs:label 'Patch Version Start' ;
    rdfs:comment 'Game patch version at the start of the season (e.g., 13.1, 7.04). Defines the game balance and feature set for competitive play.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prizePoolCeilingUsd rdf:type rdf:Property ;
    rdfs:label 'Prize Pool Ceiling Usd' ;
    rdfs:comment 'Maximum total prize pool amount allocated for the league across all seasons, in United States Dollars (USD).' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seasonEndDate rdf:type rdf:Property ;
    rdfs:label 'Season End Date' ;
    rdfs:comment 'Official end date of the season when competitive play concludes.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seasonOrdinal rdf:type rdf:Property ;
    rdfs:label 'Season Ordinal' ;
    rdfs:comment 'Sequential number of the season within the league (1 for first season, 2 for second, etc.).' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonPrizePoolUsd rdf:type rdf:Property ;
    rdfs:label 'Season Prize Pool Usd' ;
    rdfs:comment 'Total prize pool allocated for this specific season, in United States Dollars (USD).' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seasonSplit rdf:type rdf:Property ;
    rdfs:label 'Season Split' ;
    rdfs:comment 'Seasonal split or period designation for the season (spring, summer, fall, winter, annual for year-long, none if not applicable).' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonStartDate rdf:type rdf:Property ;
    rdfs:label 'Season Start Date' ;
    rdfs:comment 'Official start date of the season when competitive play begins.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetCcu rdf:type rdf:Property ;
    rdfs:label 'Target Ccu' ;
    rdfs:comment 'Target number of concurrent viewers/users for live league events. CCU (Concurrent Users) represents the number of users simultaneously watching or participating at any given moment.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetPcu rdf:type rdf:Property ;
    rdfs:label 'Target Pcu' ;
    rdfs:comment 'Target peak concurrent viewers/users for live league events. PCU (Peak Concurrent Users) represents the maximum number of users simultaneously watching or participating during the highest traffic moment.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:matchTeamBEsportsTeamId rdf:type rdf:Property ;
    rdfs:label 'Match Team B Esports Team Id' ;
    rdfs:comment 'Reference to the second competing team in the match.' ;
    rdfs:domain ind:Match ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:matchTeamId rdf:type rdf:Property ;
    rdfs:label 'Match Team Id' ;
    rdfs:comment 'Reference to the first competing team in the match.' ;
    rdfs:domain ind:Match ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:matchWinningTeamId rdf:type rdf:Property ;
    rdfs:label 'Match Winning Team Id' ;
    rdfs:comment 'Reference to the team that won the match. Null if match is not yet completed or was cancelled.' ;
    rdfs:domain ind:Match ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:averageCcu rdf:type rdf:Property ;
    rdfs:label 'Average Ccu' ;
    rdfs:comment 'Average number of concurrent viewers throughout the match duration. Used for broadcast performance analysis.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:broadcastDelaySeconds rdf:type rdf:Property ;
    rdfs:label 'Broadcast Delay Seconds' ;
    rdfs:comment 'Number of seconds the broadcast is delayed behind live gameplay to prevent competitive advantage from stream viewing. Typically 0-180 seconds.' ;
    rdfs:domain ind:Match ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:broadcastUrl rdf:type rdf:Property ;
    rdfs:label 'Broadcast Url' ;
    rdfs:comment 'Primary streaming or broadcast URL where the match is being televised or streamed (e.g., Twitch, YouTube, platform-specific channels).' ;
    rdfs:domain ind:Match ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchNumber rdf:type rdf:Property ;
    rdfs:label 'Match Number' ;
    rdfs:comment 'Business-facing match identifier or code used for external communication, broadcasting, and scheduling (e.g., \'QF-1\', \'GF-2023-001\').' ;
    rdfs:domain ind:Match ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prizeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Prize Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the prize pool amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Match ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prizePoolAmount rdf:type rdf:Property ;
    rdfs:label 'Prize Pool Amount' ;
    rdfs:comment 'Total prize money allocated to this specific match. Typically applies to finals or special showcase matches. Null for regular season matches without direct prize allocation.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replayAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Replay Available Flag' ;
    rdfs:comment 'Indicates whether a full replay or video-on-demand recording of the match is available for viewing. True if replay exists.' ;
    rdfs:domain ind:Match ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:replayUrl rdf:type rdf:Property ;
    rdfs:label 'Replay Url' ;
    rdfs:comment 'URL link to the match replay or video-on-demand content. Null if replay is not available.' ;
    rdfs:domain ind:Match ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Timestamp' ;
    rdfs:comment 'Planned date and time when the match is scheduled to begin. Used for broadcast scheduling and player coordination.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:technicalPauseCount rdf:type rdf:Property ;
    rdfs:label 'Technical Pause Count' ;
    rdfs:comment 'Number of technical pauses called during the match due to equipment failure, network issues, or other technical problems.' ;
    rdfs:domain ind:Match ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:technicalPauseDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Technical Pause Duration Seconds' ;
    rdfs:comment 'Total cumulative time spent in technical pauses during the match, measured in seconds.' ;
    rdfs:domain ind:Match ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalViews rdf:type rdf:Property ;
    rdfs:label 'Total Views' ;
    rdfs:comment 'Total number of unique views or impressions for the match broadcast across all platforms and channels.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:venueType rdf:type rdf:Property ;
    rdfs:label 'Venue Type' ;
    rdfs:comment 'Physical or virtual venue type where the match is played. Online = remote play, LAN = local area network in-person event, Hybrid = mixed format.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchIncidentId rdf:type rdf:Property ;
    rdfs:label 'Match Incident Id' ;
    rdfs:comment 'Unique identifier for the competitive integrity incident or rule violation record.' ;
    rdfs:domain ind:MatchIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryMatchPlayerAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Match Player Account Id' ;
    rdfs:comment 'Reference to the individual player who reported the incident, if applicable.' ;
    rdfs:domain ind:MatchIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerAccount .

ind:primaryMatchReportingTeamId rdf:type rdf:Property ;
    rdfs:label 'Primary Match Reporting Team Id' ;
    rdfs:comment 'Reference to the team that filed the protest or report, if applicable.' ;
    rdfs:domain ind:MatchIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:appealDeadline rdf:type rdf:Property ;
    rdfs:label 'Appeal Deadline' ;
    rdfs:comment 'The deadline by which an appeal must be filed per league rules.' ;
    rdfs:domain ind:MatchIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:appealFiled rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed' ;
    rdfs:comment 'Indicates whether an appeal has been filed against the ruling.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appealFiledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Timestamp' ;
    rdfs:comment 'Date and time when the appeal was officially submitted.' ;
    rdfs:domain ind:MatchIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:appealRulingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Appeal Ruling Timestamp' ;
    rdfs:comment 'Date and time when the appeal decision was issued.' ;
    rdfs:domain ind:MatchIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assigned Timestamp' ;
    rdfs:comment 'Date and time when the incident was assigned to an administrator for review.' ;
    rdfs:domain ind:MatchIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:disclosureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disclosure Timestamp' ;
    rdfs:comment 'Date and time when the incident details were publicly disclosed.' ;
    rdfs:domain ind:MatchIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:evidenceReferences rdf:type rdf:Property ;
    rdfs:label 'Evidence References' ;
    rdfs:comment 'Comma-separated list of evidence artifact identifiers (video clips, screenshots, logs, replay files) supporting the incident report.' ;
    rdfs:domain ind:MatchIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inGameTime rdf:type rdf:Property ;
    rdfs:label 'In Game Time' ;
    rdfs:comment 'The in-game timestamp or match clock time when the incident occurred (e.g., 23:45 game time).' ;
    rdfs:domain ind:MatchIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:matchResultAffected rdf:type rdf:Property ;
    rdfs:label 'Match Result Affected' ;
    rdfs:comment 'Indicates whether the incident ruling resulted in a change to the official match result.' ;
    rdfs:domain ind:MatchIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount Usd' ;
    rdfs:comment 'Monetary fine amount assessed in United States Dollars, if applicable.' ;
    rdfs:domain ind:MatchIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyType rdf:type rdf:Property ;
    rdfs:label 'Penalty Type' ;
    rdfs:comment 'The type of disciplinary penalty applied as a result of the incident ruling. [ENUM-REF-CANDIDATE: none|warning|fine|match_forfeit|game_forfeit|point_deduction|suspension|disqualification|prize_forfeiture|probation|other — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MatchIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicDisclosure rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure' ;
    rdfs:comment 'Indicates whether the incident and ruling have been publicly disclosed or remain confidential.' ;
    rdfs:domain ind:MatchIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingPartyType rdf:type rdf:Property ;
    rdfs:label 'Reporting Party Type' ;
    rdfs:comment 'The type of entity that initially reported or flagged the incident. [ENUM-REF-CANDIDATE: team|player|referee|broadcast_observer|league_official|tournament_admin|automated_system|spectator|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MatchIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Start Timestamp' ;
    rdfs:comment 'Date and time when the formal review or investigation of the incident began.' ;
    rdfs:domain ind:MatchIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rulingOutcome rdf:type rdf:Property ;
    rdfs:label 'Ruling Outcome' ;
    rdfs:comment 'The final decision or verdict rendered by the league official on the incident. [ENUM-REF-CANDIDATE: upheld|dismissed|partial_upheld|no_fault_found|technical_issue_confirmed|rematch_ordered|forfeit_declared|warning_issued|inconclusive — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MatchIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rulingRationale rdf:type rdf:Property ;
    rdfs:label 'Ruling Rationale' ;
    rdfs:comment 'Detailed explanation of the reasoning and evidence basis for the ruling outcome.' ;
    rdfs:domain ind:MatchIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rulingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ruling Timestamp' ;
    rdfs:comment 'Date and time when the final ruling or decision on the incident was issued.' ;
    rdfs:domain ind:MatchIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:suspensionDurationDays rdf:type rdf:Property ;
    rdfs:label 'Suspension Duration Days' ;
    rdfs:comment 'Number of days the player or team is suspended from competition, if applicable.' ;
    rdfs:domain ind:MatchIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:suspensionStartDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Start Date' ;
    rdfs:comment 'The date when the suspension period begins.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:matchStatId rdf:type rdf:Property ;
    rdfs:label 'Match Stat Id' ;
    rdfs:comment 'Primary key for match_stat' ;
    rdfs:domain ind:MatchStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:championCharacterId rdf:type rdf:Property ;
    rdfs:label 'Champion Character Id' ;
    rdfs:comment 'Identifier for the specific champion, hero, or character the player selected for this match. Enables meta-analysis and pick/ban trends.' ;
    rdfs:domain ind:MatchStat ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayableCharacter .

ind:accuracyPercentage rdf:type rdf:Property ;
    rdfs:label 'Accuracy Percentage' ;
    rdfs:comment 'Overall shooting or ability accuracy expressed as a percentage. Measures mechanical precision across applicable game genres.' ;
    rdfs:domain ind:MatchStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apm rdf:type rdf:Property ;
    rdfs:label 'Apm' ;
    rdfs:comment 'RTS-specific metric measuring the number of game actions executed per minute. Indicator of mechanical skill and multitasking ability.' ;
    rdfs:domain ind:MatchStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assists rdf:type rdf:Property ;
    rdfs:label 'Assists' ;
    rdfs:comment 'Total number of assists credited to the player for contributing to enemy eliminations. Core component of KDA ratio.' ;
    rdfs:domain ind:MatchStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clutchRoundsWon rdf:type rdf:Property ;
    rdfs:label 'Clutch Rounds Won' ;
    rdfs:comment 'Number of rounds won by the player in outnumbered situations. Indicator of high-pressure performance and decision-making.' ;
    rdfs:domain ind:MatchStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crowdControlDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Crowd Control Duration Seconds' ;
    rdfs:comment 'Total duration in seconds that the player applied crowd control effects to enemies. Relevant for support and tank role evaluation.' ;
    rdfs:domain ind:MatchStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:csPerMin rdf:type rdf:Property ;
    rdfs:label 'Cs Per Min' ;
    rdfs:comment 'MOBA-specific metric tracking the rate of minion/creep kills per minute. Key farming efficiency indicator for carry and mid roles.' ;
    rdfs:domain ind:MatchStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:damageDealt rdf:type rdf:Property ;
    rdfs:label 'Damage Dealt' ;
    rdfs:comment 'Total damage output inflicted by the player during the match. Key offensive performance metric across multiple game genres.' ;
    rdfs:domain ind:MatchStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:damageTaken rdf:type rdf:Property ;
    rdfs:label 'Damage Taken' ;
    rdfs:comment 'Total damage absorbed by the player during the match. Relevant for tank and frontline role evaluation.' ;
    rdfs:domain ind:MatchStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deaths rdf:type rdf:Property ;
    rdfs:label 'Deaths' ;
    rdfs:comment 'Total number of times the player was eliminated during the match. Core component of KDA ratio and survival analysis.' ;
    rdfs:domain ind:MatchStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:economyScore rdf:type rdf:Property ;
    rdfs:label 'Economy Score' ;
    rdfs:comment 'Measure of the player\'s in-game economic performance including gold earned, resources gathered, or economy management efficiency.' ;
    rdfs:domain ind:MatchStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firstBloodFlag rdf:type rdf:Property ;
    rdfs:label 'First Blood Flag' ;
    rdfs:comment 'Boolean indicator of whether the player achieved the first kill of the match. High-value early-game performance marker.' ;
    rdfs:domain ind:MatchStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:headshotRate rdf:type rdf:Property ;
    rdfs:label 'Headshot Rate' ;
    rdfs:comment 'FPS-specific metric representing the percentage of shots that resulted in headshots. Precision and accuracy indicator.' ;
    rdfs:domain ind:MatchStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:healingDone rdf:type rdf:Property ;
    rdfs:label 'Healing Done' ;
    rdfs:comment 'Total healing or health restoration provided by the player to teammates. Critical metric for support role performance.' ;
    rdfs:domain ind:MatchStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inGameName rdf:type rdf:Property ;
    rdfs:label 'In Game Name' ;
    rdfs:comment 'The player\'s display name or gamertag used during this specific match. May differ from official roster name for branding or sponsorship reasons.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemsPurchased rdf:type rdf:Property ;
    rdfs:label 'Items Purchased' ;
    rdfs:comment 'Comma-separated list or JSON array of in-game items purchased by the player during the match. Supports build path and itemization analysis.' ;
    rdfs:domain ind:MatchStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kills rdf:type rdf:Property ;
    rdfs:label 'Kills' ;
    rdfs:comment 'Total number of enemy eliminations achieved by the player during the match. Core component of KDA (Kills/Deaths/Assists) ratio.' ;
    rdfs:domain ind:MatchStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:matchFormat rdf:type rdf:Property ;
    rdfs:label 'Match Format' ;
    rdfs:comment 'The competitive format of the match in which this performance occurred. Context for interpreting performance under different tournament structures.' ;
    rdfs:domain ind:MatchStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchTimestamp rdf:type rdf:Property ;
    rdfs:label 'Match Timestamp' ;
    rdfs:comment 'The date and time when this match performance occurred. Principal business event timestamp for temporal analysis and trend tracking.' ;
    rdfs:domain ind:MatchStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:multikillCount rdf:type rdf:Property ;
    rdfs:label 'Multikill Count' ;
    rdfs:comment 'Total number of multikill events (double kills, triple kills, etc.) achieved by the player during the match.' ;
    rdfs:domain ind:MatchStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mvpFlag rdf:type rdf:Property ;
    rdfs:label 'Mvp Flag' ;
    rdfs:comment 'Boolean indicator of whether the player was awarded MVP status for this match based on overall performance metrics.' ;
    rdfs:domain ind:MatchStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:objectiveScore rdf:type rdf:Property ;
    rdfs:label 'Objective Score' ;
    rdfs:comment 'Aggregate score representing the player\'s contribution to match objectives such as capturing points, securing objectives, or completing mission goals.' ;
    rdfs:domain ind:MatchStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceRating rdf:type rdf:Property ;
    rdfs:label 'Performance Rating' ;
    rdfs:comment 'Composite performance score calculated from multiple in-game metrics. Standardized rating for cross-player and cross-match comparison.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerRole rdf:type rdf:Property ;
    rdfs:label 'Player Role' ;
    rdfs:comment 'The competitive role or position the player fulfilled during this match. Role-specific KPIs are evaluated based on this classification. [ENUM-REF-CANDIDATE: carry|support|mid|jungle|top|tank|dps|healer|flex|entry_fragger|awper|igl|rifler — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MatchStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sidePlayed rdf:type rdf:Property ;
    rdfs:label 'Side Played' ;
    rdfs:comment 'The map side or faction the player competed on during this match. Relevant for side-balance analysis and map-specific performance. [ENUM-REF-CANDIDATE: blue|red|ct|t|radiant|dire|attacker|defender — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MatchStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Stat Source System' ;
    rdfs:comment 'The system or method by which these performance statistics were captured. Supports data quality assessment and lineage tracking.' ;
    rdfs:domain ind:MatchStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timePlayedSeconds rdf:type rdf:Property ;
    rdfs:label 'Time Played Seconds' ;
    rdfs:comment 'Total duration in seconds that the player was active in the match. Used for per-minute stat normalization.' ;
    rdfs:domain ind:MatchStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ultimateAbilityUses rdf:type rdf:Property ;
    rdfs:label 'Ultimate Ability Uses' ;
    rdfs:comment 'Number of times the player activated their ultimate or signature ability during the match. Tracks high-impact ability usage.' ;
    rdfs:domain ind:MatchStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visionScore rdf:type rdf:Property ;
    rdfs:label 'Vision Score' ;
    rdfs:comment 'MOBA-specific metric quantifying the player\'s contribution to map vision through ward placement and enemy ward denial.' ;
    rdfs:domain ind:MatchStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playerContractId rdf:type rdf:Property ;
    rdfs:label 'Player Contract Id' ;
    rdfs:comment 'Unique identifier for the esports player contract record. Primary key.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerContract .

ind:financeTaxRecordId rdf:type rdf:Property ;
    rdfs:label 'Finance Tax Record Id' ;
    rdfs:comment 'Foreign key linking to finance.finance_tax_record. Business justification: Player contracts trigger tax withholding obligations (income tax, social security) in multiple jurisdictions. Required for tax compliance, regulatory reporting (1099/W-2), and audit trail.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinanceTaxRecord .

ind:parentContractPlayerContractId rdf:type rdf:Property ;
    rdfs:label 'Parent Contract Player Contract Id' ;
    rdfs:comment 'Reference to the original contract if this is a loan or amendment contract, establishing the contract hierarchy.' ;
    rdfs:domain ind:PlayerContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerContract .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the contract automatically renews for an additional term upon expiration if not explicitly terminated by either party.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:buyoutClauseAmount rdf:type rdf:Property ;
    rdfs:label 'Buyout Clause Amount' ;
    rdfs:comment 'The monetary amount required for another team to acquire the player before contract expiration, releasing the player from current obligations.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buyoutClauseCurrency rdf:type rdf:Property ;
    rdfs:label 'Buyout Clause Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the buyout clause amount.' ;
    rdfs:domain ind:PlayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityTerms rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Terms' ;
    rdfs:comment 'Non-disclosure obligations protecting team strategies, roster changes, financial information, and other proprietary business information.' ;
    rdfs:domain ind:PlayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractLanguage rdf:type rdf:Property ;
    rdfs:label 'Contract Language' ;
    rdfs:comment 'Three-letter ISO 639-2 language code indicating the primary language in which the contract is written and legally binding.' ;
    rdfs:domain ind:PlayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Externally-known unique business identifier for the player contract, used for legal and operational reference.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle state of the player contract. Draft indicates unsigned or pending approval; active indicates in force; suspended indicates temporarily paused; terminated indicates ended before expiration; expired indicates naturally ended; completed indicates fulfilled all terms.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Classification of the contract governing the player-team relationship. Standard contracts are full-time competitive agreements; loan contracts are temporary assignments from another team; trial contracts are probationary periods; academy contracts are for developmental rosters; substitute contracts are for backup players; free agent contracts are short-term engagements.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Method' ;
    rdfs:comment 'The agreed-upon mechanism for resolving contractual disputes between player and team, including arbitration, mediation, litigation, or league-administered tribunal.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Equipment Provided Flag' ;
    rdfs:comment 'Indicates whether the team provides gaming equipment (PC, peripherals, etc.) to the player as part of the contract.' ;
    rdfs:domain ind:PlayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusivityClause rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Clause' ;
    rdfs:comment 'Terms requiring the player to compete exclusively for this team and prohibiting simultaneous contracts with other esports organizations.' ;
    rdfs:domain ind:PlayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthInsuranceProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Health Insurance Provided Flag' ;
    rdfs:comment 'Indicates whether the team provides health insurance coverage for the player as part of the contract benefits.' ;
    rdfs:domain ind:PlayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:housingProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Housing Provided Flag' ;
    rdfs:comment 'Indicates whether the team provides housing accommodations for the player as part of the contract terms.' ;
    rdfs:domain ind:PlayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:imageRightsTerms rdf:type rdf:Property ;
    rdfs:label 'Image Rights Terms' ;
    rdfs:comment 'Terms governing the use of the players name, likeness, and image in marketing, merchandise, and promotional materials, including revenue sharing and approval rights.' ;
    rdfs:domain ind:PlayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonCompeteTerms rdf:type rdf:Property ;
    rdfs:label 'Non Compete Terms' ;
    rdfs:comment 'Textual description of restrictions on the player competing for rival teams or in competing leagues during and after the contract period.' ;
    rdfs:domain ind:PlayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Notice Period Days' ;
    rdfs:comment 'The number of days advance notice required by either party to terminate the contract without penalty.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:relocationAssistanceAmount rdf:type rdf:Property ;
    rdfs:label 'Relocation Assistance Amount' ;
    rdfs:comment 'Monetary amount provided to the player to cover relocation expenses when joining the team, if applicable.' ;
    rdfs:domain ind:PlayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalTermMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Term Months' ;
    rdfs:comment 'The duration in months for which the contract will automatically renew if auto-renewal is enabled.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salaryAmount rdf:type rdf:Property ;
    rdfs:label 'Salary Amount' ;
    rdfs:comment 'The base annual salary paid to the player under this contract, excluding bonuses and revenue share.' ;
    rdfs:domain ind:PlayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salaryCurrency rdf:type rdf:Property ;
    rdfs:label 'Salary Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the salary amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signingDate rdf:type rdf:Property ;
    rdfs:label 'Signing Date' ;
    rdfs:comment 'The date on which the contract was signed by all parties, establishing legal commitment.' ;
    rdfs:domain ind:PlayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:streamingRightsRestrictions rdf:type rdf:Property ;
    rdfs:label 'Streaming Rights Restrictions' ;
    rdfs:comment 'Contractual limitations on the players ability to stream gameplay, including platform exclusivity, content restrictions, and revenue sharing for streaming income.' ;
    rdfs:domain ind:PlayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'The actual date on which the contract was terminated early, if applicable. Null if contract was not terminated early.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Explanation for early contract termination, including mutual agreement, breach of contract, performance issues, or organizational restructuring.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tournamentParticipationRequirements rdf:type rdf:Property ;
    rdfs:label 'Tournament Participation Requirements' ;
    rdfs:comment 'Contractual obligations regarding minimum tournament participation, practice schedules, and competitive availability requirements.' ;
    rdfs:domain ind:PlayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prizeAllocationId rdf:type rdf:Property ;
    rdfs:label 'Prize Allocation Id' ;
    rdfs:comment 'Unique identifier for the prize allocation record. Primary key for this transactional entity capturing prize money awarded to teams or individual players upon tournament completion.' ;
    rdfs:domain ind:PrizeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentAllocationPrizeAllocationId rdf:type rdf:Property ;
    rdfs:label 'Parent Allocation Prize Allocation Id' ;
    rdfs:comment 'Reference to the parent prize allocation when this record represents a split or sub-allocation. Used to track hierarchical prize distribution from team to individual players.' ;
    rdfs:domain ind:PrizeAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrizeAllocation .

ind:prizePoolId rdf:type rdf:Property ;
    rdfs:label 'Prize Pool Id' ;
    rdfs:comment 'Reference to the prize pool from which this allocation is drawn. Links to the prize pool entity that defines total available prize money and distribution structure.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrizePool .

ind:royaltyAccrualId rdf:type rdf:Property ;
    rdfs:label 'Royalty Accrual Id' ;
    rdfs:comment 'Foreign key linking to finance.royalty_accrual. Business justification: Prize payments to players under revenue-share contracts (common in esports) may be structured as royalties. Linking enables accrual tracking, payment reconciliation, and financial reporting.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoyaltyAccrual .

ind:allocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount' ;
    rdfs:comment 'Gross prize money amount allocated to the payee before any deductions. Represents the full prize value as defined by the prize pool distribution rules.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationNotes rdf:type rdf:Property ;
    rdfs:label 'Allocation Notes' ;
    rdfs:comment 'Free-text notes regarding special circumstances, adjustments, or conditions related to this prize allocation. Used for documentation and audit purposes.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Number' ;
    rdfs:comment 'Externally-visible unique business identifier for this prize allocation. Used for tracking, reconciliation, and communication with payees. Format: PA-YYYYMMDD-NNNN.' ;
    rdfs:domain ind:PrizeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Allocation Timestamp' ;
    rdfs:comment 'Date and time when this prize allocation record was created in the system. Represents the business event time when the prize was officially allocated following tournament completion.' ;
    rdfs:domain ind:PrizeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bonusPrizeCategory rdf:type rdf:Property ;
    rdfs:label 'Bonus Prize Category' ;
    rdfs:comment 'Category or type of bonus prize when is_bonus_prize is true. Examples: MVP, Best Play, Most Kills, Fan Favorite, Sportsmanship Award. Null for standard placement prizes.' ;
    rdfs:domain ind:PrizeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'Reference to the player or team contract governing prize payment terms. Used when contractual obligations affect prize distribution or payment timing.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBonusPrize rdf:type rdf:Property ;
    rdfs:label 'Is Bonus Prize' ;
    rdfs:comment 'Indicates whether this allocation represents a bonus prize awarded in addition to standard placement prizes. Examples: MVP award, best play award, fan favorite award.' ;
    rdfs:domain ind:PrizeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:otherDeductionsAmount rdf:type rdf:Property ;
    rdfs:label 'Other Deductions Amount' ;
    rdfs:comment 'Sum of any additional deductions not captured in tax withholding or platform fees. May include penalties, chargebacks, or contractual adjustments.' ;
    rdfs:domain ind:PrizeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payeeBankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Payee Bank Account Number' ;
    rdfs:comment 'Reference to the bank account or payment destination used for disbursement. Links to the payee financial account entity containing routing and account details.' ;
    rdfs:domain ind:PrizeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payeeType rdf:type rdf:Property ;
    rdfs:label 'Payee Type' ;
    rdfs:comment 'Indicates whether the prize is paid to a team organization, directly to an individual player, or split between both. Determines payment routing and tax treatment.' ;
    rdfs:domain ind:PrizeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'Date on which the prize payment was successfully disbursed to the payee. Null until payment status reaches Paid.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:placementDescription rdf:type rdf:Property ;
    rdfs:label 'Placement Description' ;
    rdfs:comment 'Human-readable description of the placement achievement. Examples: Champion, Runner-Up, Semi-Finalist, Top 8, Participation Prize.' ;
    rdfs:domain ind:PrizeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementRank rdf:type rdf:Property ;
    rdfs:label 'Placement Rank' ;
    rdfs:comment 'Final placement rank achieved in the tournament that determines prize eligibility. 1 = first place, 2 = second place, etc. Used to map to prize pool distribution rules.' ;
    rdfs:domain ind:PrizeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Payment Date' ;
    rdfs:comment 'Target date for prize disbursement as defined by tournament rules or contractual agreements. May differ from actual payment_date due to processing delays or holds.' ;
    rdfs:domain ind:PrizeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:splitPercentage rdf:type rdf:Property ;
    rdfs:label 'Split Percentage' ;
    rdfs:comment 'Percentage of the total prize allocated to this specific payee when prize is split among multiple recipients. Example: 0.6000 represents 60% of the total prize. Null for non-split allocations.' ;
    rdfs:domain ind:PrizeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxFormIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Tax Form Issued Date' ;
    rdfs:comment 'Date on which the tax form was generated and issued to the payee. Required for regulatory compliance and audit trails.' ;
    rdfs:domain ind:PrizeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxFormType rdf:type rdf:Property ;
    rdfs:label 'Tax Form Type' ;
    rdfs:comment 'Type of tax form issued for this prize payment. Examples: W-2G (US gambling winnings), 1099-MISC (US miscellaneous income), W-8BEN (foreign person certification). Null if no form required.' ;
    rdfs:domain ind:PrizeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxWithholdingAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Withholding Amount' ;
    rdfs:comment 'Amount withheld for tax purposes based on jurisdiction and payee tax status. Calculated according to applicable tax treaties and local regulations.' ;
    rdfs:domain ind:PrizeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxWithholdingRate rdf:type rdf:Property ;
    rdfs:label 'Tax Withholding Rate' ;
    rdfs:comment 'Tax withholding rate applied as a decimal. Example: 0.3000 represents 30% withholding. Determined by payee residency, tax treaty status, and local regulations.' ;
    rdfs:domain ind:PrizeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingReason rdf:type rdf:Property ;
    rdfs:label 'Withholding Reason' ;
    rdfs:comment 'Explanation for why payment is withheld when payment_status is Withheld. Examples: pending tax documentation, contract dispute, eligibility verification, regulatory hold, fraud investigation.' ;
    rdfs:domain ind:PrizeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundAdministratorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Fund Administrator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Prize pools require internal fund administrators for crowdfunding oversight, sponsor contribution tracking, tax withholding compliance, payment processor coordination, and distribution audit trails. S' ;
    rdfs:domain ind:PrizePool ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:royaltyReportId rdf:type rdf:Property ;
    rdfs:label 'Royalty Report Id' ;
    rdfs:comment 'Foreign key linking to licensing.royalty_report. Business justification: Publisher-funded prize pools often require royalty reporting for revenue share calculations and IP holder financial reconciliation. Links prize pool funding to licensing financial reporting for audit ' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoyaltyReport .

ind:broadcastRightsLinked rdf:type rdf:Property ;
    rdfs:label 'Broadcast Rights Linked' ;
    rdfs:comment 'Indicates whether this prize pool is tied to broadcast rights agreements or revenue-sharing arrangements with streaming platforms or media partners.' ;
    rdfs:domain ind:PrizePool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crowdfundAmount rdf:type rdf:Property ;
    rdfs:label 'Crowdfund Amount' ;
    rdfs:comment 'Portion of the total prize pool contributed through crowdfunding mechanisms (e.g., battle pass sales, in-game purchases). Null if not applicable.' ;
    rdfs:domain ind:PrizePool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defaultTaxRate rdf:type rdf:Property ;
    rdfs:label 'Default Tax Rate' ;
    rdfs:comment 'Default tax withholding rate (as percentage) applied to prize payments unless overridden by jurisdiction-specific rules or tax treaty provisions.' ;
    rdfs:domain ind:PrizePool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Distribution Completion Date' ;
    rdfs:comment 'Date when all prize payments from this pool were fully processed and disbursed.' ;
    rdfs:domain ind:PrizePool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distributionMethod rdf:type rdf:Property ;
    rdfs:label 'Distribution Method' ;
    rdfs:comment 'Method used to allocate prize pool funds: placement_based (by tournament rank), point_based (by accumulated league points), hybrid (combination), or custom (unique distribution logic).' ;
    rdfs:domain ind:PrizePool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionStartDate rdf:type rdf:Property ;
    rdfs:label 'Distribution Start Date' ;
    rdfs:comment 'Date when prize disbursement processing began for this pool.' ;
    rdfs:domain ind:PrizePool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstPlaceAmount rdf:type rdf:Property ;
    rdfs:label 'First Place Amount' ;
    rdfs:comment 'Prize amount allocated to the first-place finisher or team. Null if distribution is not placement-based.' ;
    rdfs:domain ind:PrizePool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundingSource rdf:type rdf:Property ;
    rdfs:label 'Funding Source' ;
    rdfs:comment 'Primary source of prize pool funding: first_party (publisher/developer funded), crowdfunded (community contributions), sponsor_contributed (external sponsor), or mixed (combination of sources).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumGuaranteedAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Guaranteed Amount' ;
    rdfs:comment 'Minimum prize pool amount guaranteed regardless of crowdfunding or sponsorship performance. Represents the baseline commitment.' ;
    rdfs:domain ind:PrizePool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfPaidPlacements rdf:type rdf:Property ;
    rdfs:label 'Number Of Paid Placements' ;
    rdfs:comment 'Total number of tournament placements that receive prize money from this pool (e.g., top 8, top 16).' ;
    rdfs:domain ind:PrizePool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payeeTypeDefault rdf:type rdf:Property ;
    rdfs:label 'Payee Type Default' ;
    rdfs:comment 'Default recipient type for prize payments: team_organization (paid to team entity), individual_player (paid directly to players), or mixed (varies by placement or agreement).' ;
    rdfs:domain ind:PrizePool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolAnnouncementDate rdf:type rdf:Property ;
    rdfs:label 'Pool Announcement Date' ;
    rdfs:comment 'Date when the prize pool was publicly announced to the esports community and participants.' ;
    rdfs:domain ind:PrizePool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poolLockDate rdf:type rdf:Property ;
    rdfs:label 'Pool Lock Date' ;
    rdfs:comment 'Date when the prize pool was locked and finalized, preventing further changes to the total amount or distribution structure.' ;
    rdfs:domain ind:PrizePool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poolName rdf:type rdf:Property ;
    rdfs:label 'Pool Name' ;
    rdfs:comment 'Business-friendly name or identifier for the prize pool (e.g., \'World Championship 2024 Prize Pool\', \'Spring Split Finals Prize Pool\').' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolStatus rdf:type rdf:Property ;
    rdfs:label 'Pool Status' ;
    rdfs:comment 'Current lifecycle status of the prize pool: draft (being defined), active (tournament ongoing), locked (finalized, awaiting distribution), distributed (payments processed), closed (fully reconciled).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondPlaceAmount rdf:type rdf:Property ;
    rdfs:label 'Second Place Amount' ;
    rdfs:comment 'Prize amount allocated to the second-place finisher or team. Null if distribution is not placement-based.' ;
    rdfs:domain ind:PrizePool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sponsorAmount rdf:type rdf:Property ;
    rdfs:label 'Sponsor Amount' ;
    rdfs:comment 'Portion of the total prize pool contributed by external sponsors. Null if not applicable.' ;
    rdfs:domain ind:PrizePool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxWithholdingRule rdf:type rdf:Property ;
    rdfs:label 'Tax Withholding Rule' ;
    rdfs:comment 'Description or reference to the tax withholding rules applied to prize disbursements, which may vary by jurisdiction and payee residency status.' ;
    rdfs:domain ind:PrizePool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPlaceAmount rdf:type rdf:Property ;
    rdfs:label 'Third Place Amount' ;
    rdfs:comment 'Prize amount allocated to the third-place finisher or team. Null if distribution is not placement-based.' ;
    rdfs:domain ind:PrizePool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPoolAmount rdf:type rdf:Property ;
    rdfs:label 'Total Pool Amount' ;
    rdfs:comment 'Total monetary value of the prize pool available for distribution across all placements and participants.' ;
    rdfs:domain ind:PrizePool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rosterId rdf:type rdf:Property ;
    rdfs:label 'Roster Id' ;
    rdfs:comment 'Unique identifier for the esports team roster entry. Primary key for the roster product.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rosterPreviousTeamId rdf:type rdf:Property ;
    rdfs:label 'Roster Previous Team Id' ;
    rdfs:comment 'Reference to the team the player was rostered with immediately before joining this team. Nullable for players entering professional competition for the first time. Links to the team master data.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:rosterTeamId rdf:type rdf:Property ;
    rdfs:label 'Roster Team Id' ;
    rdfs:comment 'Reference to the esports team that this roster entry belongs to. Links to the team master data.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:ageAtRosterLock rdf:type rdf:Property ;
    rdfs:label 'Age At Roster Lock' ;
    rdfs:comment 'The player\'s age in years at the time of roster lock. Used for age eligibility validation and compliance with league minimum/maximum age requirements.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:announcementDate rdf:type rdf:Property ;
    rdfs:label 'Announcement Date' ;
    rdfs:comment 'The date when the roster change or player signing was officially announced to the public. Used for tracking announcement timing and media coordination.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eligibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Eligibility Status' ;
    rdfs:comment 'The current eligibility status of the player for competitive play in this league or tournament. Eligible players can compete, ineligible players cannot, suspended players are temporarily barred, pending_review indicates ongoing investigation, restricted indicates conditional eligibility, and retired indicates the player has withdrawn from competition.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAcademyPromotion rdf:type rdf:Property ;
    rdfs:label 'Is Academy Promotion' ;
    rdfs:comment 'Boolean flag indicating whether the player was promoted from the organization\'s academy or development team (true) or acquired externally (false). Used for tracking talent development pipeline effectiveness.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCaptain rdf:type rdf:Property ;
    rdfs:label 'Is Captain' ;
    rdfs:comment 'Boolean flag indicating whether the player is designated as the team captain (true) or not (false). The captain typically has leadership responsibilities and represents the team in official matters.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStarter rdf:type rdf:Property ;
    rdfs:label 'Is Starter' ;
    rdfs:comment 'Boolean flag indicating whether the player is designated as a starting lineup member (true) or a substitute/reserve (false). Determines default match participation.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jerseyNumber rdf:type rdf:Property ;
    rdfs:label 'Jersey Number' ;
    rdfs:comment 'The official jersey or uniform number assigned to the player for identification during broadcasts and live events. Used for merchandising and fan engagement.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lockDate rdf:type rdf:Property ;
    rdfs:label 'Lock Date' ;
    rdfs:comment 'The date when the roster was locked for the league or tournament, after which no changes are permitted without league approval. Critical for competitive integrity and compliance with league rules.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nationality rdf:type rdf:Property ;
    rdfs:label 'Nationality' ;
    rdfs:comment 'The three-letter ISO 3166-1 alpha-3 country code representing the player\'s nationality. Used for regional eligibility validation, import slot tracking, and compliance with league residency rules.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residencyStatus rdf:type rdf:Property ;
    rdfs:label 'Residency Status' ;
    rdfs:comment 'The residency classification of the player for league import slot rules. Resident players count as local talent, import players occupy limited foreign slots, exempt players have special status, and pending indicates residency determination is in progress.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rosterRole rdf:type rdf:Property ;
    rdfs:label 'Roster Role' ;
    rdfs:comment 'The competitive role or position assigned to the player within the team structure. IGL (In-Game Leader) directs strategy, support provides utility, carry focuses on damage output, flex adapts to multiple roles, substitute is a backup player, and coach provides strategic guidance.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rosterStatus rdf:type rdf:Property ;
    rdfs:label 'Roster Status' ;
    rdfs:comment 'The current operational status of this roster entry. Active indicates the player is available for competition, inactive indicates temporary unavailability, on_loan indicates the player is temporarily assigned to another team, injured_reserve indicates medical leave, and suspended indicates disciplinary action.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Transfer Fee Amount' ;
    rdfs:comment 'The monetary amount paid to acquire the player from their previous team, if applicable. Nullable for free agent signings or internal promotions. Expressed in the organization\'s reporting currency.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Transfer Fee Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the transfer fee amount. Nullable if no transfer fee was paid.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorshipId rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Id' ;
    rdfs:comment 'Unique identifier for the sponsorship agreement. Primary key for the sponsorship entity.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Account Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Sponsorship contracts require internal account managers to coordinate deliverables tracking, activation campaigns, renewal negotiations, and sponsor satisfaction reporting. The internal_owner_name fie' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:brandingAssetId rdf:type rdf:Property ;
    rdfs:label 'Branding Asset Id' ;
    rdfs:comment 'Foreign key linking to content.asset. Business justification: Sponsor branding assets (logos, banners, in-game overlays) used in broadcasts and venues. Asset tracking required for sponsor deliverable fulfillment, rights compliance, and brand guideline enforcemen' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:activationType rdf:type rdf:Property ;
    rdfs:label 'Activation Type' ;
    rdfs:comment 'Primary method of sponsor brand activation and visibility (jersey patch, stream overlay, naming rights, in-game branding, arena signage, etc.). May contain multiple comma-separated values.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastRightsIncluded rdf:type rdf:Property ;
    rdfs:label 'Broadcast Rights Included' ;
    rdfs:comment 'Indicates whether the sponsorship includes rights to sponsor branding in broadcast and streaming content.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractSignedDate rdf:type rdf:Property ;
    rdfs:label 'Contract Signed Date' ;
    rdfs:comment 'Date when the sponsorship contract was executed and signed by all parties.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractedValue rdf:type rdf:Property ;
    rdfs:label 'Contracted Value' ;
    rdfs:comment 'Total monetary value of the sponsorship agreement in the contract currency.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliverablesList rdf:type rdf:Property ;
    rdfs:label 'Deliverables List' ;
    rdfs:comment 'Detailed list or summary of contractual deliverables and sponsor benefits to be provided (logo placements, social media posts, hospitality packages, etc.).' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalRightsIncluded rdf:type rdf:Property ;
    rdfs:label 'Digital Rights Included' ;
    rdfs:comment 'Indicates whether the sponsorship includes rights to sponsor branding in digital channels (social media, websites, mobile apps).' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusivityCategory rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Category' ;
    rdfs:comment 'Product or service category for which the sponsor has exclusive rights within the league, tournament, or team (e.g., energy drinks, gaming peripherals, automotive).' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hospitalityPackageIncluded rdf:type rdf:Property ;
    rdfs:label 'Hospitality Package Included' ;
    rdfs:comment 'Indicates whether the sponsorship includes VIP hospitality benefits for sponsor representatives at live events.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inGameBrandingIncluded rdf:type rdf:Property ;
    rdfs:label 'In Game Branding Included' ;
    rdfs:comment 'Indicates whether the sponsorship includes rights to place sponsor branding within the game title itself (virtual billboards, branded items, etc.).' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inKindValue rdf:type rdf:Property ;
    rdfs:label 'In Kind Value' ;
    rdfs:comment 'Estimated monetary value of non-cash contributions provided by the sponsor (products, services, equipment).' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceMetrics rdf:type rdf:Property ;
    rdfs:label 'Performance Metrics' ;
    rdfs:comment 'Key performance indicators or metrics used to measure sponsorship effectiveness and ROI (impressions, reach, engagement, brand lift, etc.).' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Deadline Date' ;
    rdfs:comment 'Date by which the sponsor must exercise their renewal option, if applicable.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sponsorContactEmail rdf:type rdf:Property ;
    rdfs:label 'Sponsor Contact Email' ;
    rdfs:comment 'Email address of the primary contact person at the sponsoring organization.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorContactName rdf:type rdf:Property ;
    rdfs:label 'Sponsor Contact Name' ;
    rdfs:comment 'Name of the primary contact person at the sponsoring organization for this agreement.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorContactPhone rdf:type rdf:Property ;
    rdfs:label 'Sponsor Contact Phone' ;
    rdfs:comment 'Phone number of the primary contact person at the sponsoring organization.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorshipStatus rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Status' ;
    rdfs:comment 'Current lifecycle status of the sponsorship agreement. [ENUM-REF-CANDIDATE: draft|negotiation|active|suspended|completed|terminated|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standingId rdf:type rdf:Property ;
    rdfs:label 'Standing Id' ;
    rdfs:comment 'Unique identifier for the league standing record. Primary key.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:divisionId rdf:type rdf:Property ;
    rdfs:label 'Division Id' ;
    rdfs:comment 'Reference to the division or conference within the league, if applicable.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Division .

ind:clinchedPlayoff rdf:type rdf:Property ;
    rdfs:label 'Clinched Playoff' ;
    rdfs:comment 'Indicates whether the team has mathematically clinched a playoff berth.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentStreak rdf:type rdf:Property ;
    rdfs:label 'Current Streak' ;
    rdfs:comment 'Current winning or losing streak (e.g., W5 = 5 wins in a row, L3 = 3 losses in a row, D1 = 1 draw).' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eliminated rdf:type rdf:Property ;
    rdfs:label 'Eliminated' ;
    rdfs:comment 'Indicates whether the team has been mathematically eliminated from playoff contention.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMatchDate rdf:type rdf:Property ;
    rdfs:label 'Last Match Date' ;
    rdfs:comment 'Date of the most recent match played by the team that affected this standing.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:longestLossStreak rdf:type rdf:Property ;
    rdfs:label 'Longest Loss Streak' ;
    rdfs:comment 'Longest consecutive losing streak experienced by the team during the season.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:longestWinStreak rdf:type rdf:Property ;
    rdfs:label 'Longest Win Streak' ;
    rdfs:comment 'Longest consecutive winning streak achieved by the team during the season.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mapDifferential rdf:type rdf:Property ;
    rdfs:label 'Map Differential' ;
    rdfs:comment 'Net difference between maps won and maps lost (maps_won - maps_lost). Used for tiebreaker calculations.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mapsLost rdf:type rdf:Property ;
    rdfs:label 'Maps Lost' ;
    rdfs:comment 'Total number of individual maps or games lost across all matches.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mapsWon rdf:type rdf:Property ;
    rdfs:label 'Maps Won' ;
    rdfs:comment 'Total number of individual maps or games won across all matches.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:matchesDrawn rdf:type rdf:Property ;
    rdfs:label 'Matches Drawn' ;
    rdfs:comment 'Total number of matches that ended in a draw or tie.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:matchesLost rdf:type rdf:Property ;
    rdfs:label 'Matches Lost' ;
    rdfs:comment 'Total number of matches lost by the team.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:matchesPlayed rdf:type rdf:Property ;
    rdfs:label 'Matches Played' ;
    rdfs:comment 'Total number of matches the team has played in the season.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:matchesWon rdf:type rdf:Property ;
    rdfs:label 'Matches Won' ;
    rdfs:comment 'Total number of matches won by the team.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextMatchDate rdf:type rdf:Property ;
    rdfs:label 'Next Match Date' ;
    rdfs:comment 'Date of the next scheduled match for the team.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:playoffEligible rdf:type rdf:Property ;
    rdfs:label 'Playoff Eligible' ;
    rdfs:comment 'Indicates whether the team is currently eligible for playoff qualification based on their standing.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rankPosition rdf:type rdf:Property ;
    rdfs:label 'Rank Position' ;
    rdfs:comment 'Current rank position of the team in the league standings (1 = first place).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:relegationZone rdf:type rdf:Property ;
    rdfs:label 'Relegation Zone' ;
    rdfs:comment 'Indicates whether the team is currently in the relegation zone and at risk of demotion.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roundDifferential rdf:type rdf:Property ;
    rdfs:label 'Round Differential' ;
    rdfs:comment 'Net difference between rounds won and rounds lost (rounds_won - rounds_lost). Used for tiebreaker calculations.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roundsLost rdf:type rdf:Property ;
    rdfs:label 'Rounds Lost' ;
    rdfs:comment 'Total number of rounds lost across all maps and matches.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roundsWon rdf:type rdf:Property ;
    rdfs:label 'Rounds Won' ;
    rdfs:comment 'Total number of rounds won across all maps and matches.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standingStatus rdf:type rdf:Property ;
    rdfs:label 'Standing Status' ;
    rdfs:comment 'Current status of the standing record. Active = season in progress, Provisional = pending match result verification, Final = season completed, Archived = historical record.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tiebreakerRank rdf:type rdf:Property ;
    rdfs:label 'Tiebreaker Rank' ;
    rdfs:comment 'Rank position after applying tiebreaker rules (map differential, round differential, head-to-head). Used when teams have equal points.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPoints rdf:type rdf:Property ;
    rdfs:label 'Total Points' ;
    rdfs:comment 'Total league points accumulated by the team based on match results (e.g., 3 points per win, 1 per draw).' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:winRate rdf:type rdf:Property ;
    rdfs:label 'Win Rate' ;
    rdfs:comment 'Percentage of matches won (matches_won / matches_played). Expressed as decimal (e.g., 0.6500 = 65%).' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationBody rdf:type rdf:Property ;
    rdfs:label 'Certification Body' ;
    rdfs:comment 'Name of the esports governing body or league authority that certified the tournament (e.g., IGDA, game publisher league authority). Null if not certified.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Entry Fee Amount' ;
    rdfs:comment 'Entry fee amount required for teams/players to register for the tournament. Zero for free-to-enter tournaments.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entryFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Entry Fee Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the entry fee (e.g., USD, EUR, GBP). Null if entry is free.' ;
    rdfs:domain ind:Tournament ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxTeamCapacity rdf:type rdf:Property ;
    rdfs:label 'Max Team Capacity' ;
    rdfs:comment 'Maximum number of teams or individual players allowed to participate in the tournament.' ;
    rdfs:domain ind:Tournament ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prizePoolCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Prize Pool Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the prize pool (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prizePoolTotal rdf:type rdf:Property ;
    rdfs:label 'Prize Pool Total' ;
    rdfs:comment 'Total monetary prize pool amount available for distribution to tournament winners and top performers.' ;
    rdfs:domain ind:Tournament ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registeredTeamCount rdf:type rdf:Property ;
    rdfs:label 'Registered Team Count' ;
    rdfs:comment 'Current number of teams or players registered for the tournament.' ;
    rdfs:domain ind:Tournament ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:registrationCloseDate rdf:type rdf:Property ;
    rdfs:label 'Registration Close Date' ;
    rdfs:comment 'Date when team/player registration closes for the tournament.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationOpenDate rdf:type rdf:Property ;
    rdfs:label 'Registration Open Date' ;
    rdfs:comment 'Date when team/player registration opens for the tournament.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rulesDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Rules Document Url' ;
    rdfs:comment 'URL link to the official tournament rules and regulations document hosted on internal or external platform.' ;
    rdfs:domain ind:Tournament ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tournamentCode rdf:type rdf:Property ;
    rdfs:label 'Tournament Code' ;
    rdfs:comment 'Short alphanumeric code used for internal tracking and external identification of the tournament (e.g., \'SPRING24\', \'GLOBAL_INV_2024\').' ;
    rdfs:domain ind:Tournament ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tournamentDescription rdf:type rdf:Property ;
    rdfs:label 'Tournament Description' ;
    rdfs:comment 'Detailed description of the tournament including objectives, special rules, and promotional messaging for players and spectators.' ;
    rdfs:domain ind:Tournament ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tournamentName rdf:type rdf:Property ;
    rdfs:label 'Tournament Name' ;
    rdfs:comment 'Official name of the tournament as displayed to players and spectators (e.g., \'Spring Championship 2024\', \'Global Invitational\').' ;
    rdfs:domain ind:Tournament ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tournamentStatus rdf:type rdf:Property ;
    rdfs:label 'Tournament Status' ;
    rdfs:comment 'Current lifecycle status of the tournament indicating its operational state. [ENUM-REF-CANDIDATE: draft|scheduled|registration_open|registration_closed|in_progress|completed|cancelled|postponed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Tournament ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tournamentRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Tournament Registration Id' ;
    rdfs:comment 'Unique identifier for the tournament registration record. Primary key.' ;
    rdfs:domain ind:TournamentRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checkInStatus rdf:type rdf:Property ;
    rdfs:label 'Check In Status' ;
    rdfs:comment 'Status of pre-event check-in requirement: not_required (no check-in needed), pending (awaiting check-in), checked_in (confirmed attendance), no_show (failed to check in).' ;
    rdfs:domain ind:TournamentRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Check In Timestamp' ;
    rdfs:comment 'Date and time when the registrant completed check-in. Null if not yet checked in or check-in not required.' ;
    rdfs:domain ind:TournamentRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contactDiscord rdf:type rdf:Property ;
    rdfs:label 'Contact Discord' ;
    rdfs:comment 'Discord username or handle for tournament organizer communication. Null if not provided.' ;
    rdfs:domain ind:TournamentRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityVerifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Eligibility Verified Timestamp' ;
    rdfs:comment 'Date and time when eligibility verification was completed. Null if not yet verified.' ;
    rdfs:domain ind:TournamentRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:entryFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Entry Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the entry fee (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:TournamentRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReference rdf:type rdf:Property ;
    rdfs:label 'Payment Reference' ;
    rdfs:comment 'External payment transaction reference or receipt number from payment processor. Null if no payment required or not yet paid.' ;
    rdfs:domain ind:TournamentRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousTournamentWins rdf:type rdf:Property ;
    rdfs:label 'Previous Tournament Wins' ;
    rdfs:comment 'Count of previous tournament wins by this registrant in the same game title or league. Used for seeding and eligibility.' ;
    rdfs:domain ind:TournamentRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:registrantType rdf:type rdf:Property ;
    rdfs:label 'Registrant Type' ;
    rdfs:comment 'Type of registrant submitting the entry: team (full roster), individual (solo player), duo (two-player team), or squad (small group).' ;
    rdfs:domain ind:TournamentRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'Externally-visible unique registration confirmation number or code issued to the registrant upon submission.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationStatus rdf:type rdf:Property ;
    rdfs:label 'Registration Status' ;
    rdfs:comment 'Current lifecycle status of the registration: pending (under review), approved (accepted into tournament), waitlisted (on standby), rejected (denied entry), withdrawn (registrant cancelled), cancelled (tournament organizer cancelled).' ;
    rdfs:domain ind:TournamentRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Registration Timestamp' ;
    rdfs:comment 'Date and time when the registration was submitted by the registrant. Principal business event timestamp.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rosterLockTimestamp rdf:type rdf:Property ;
    rdfs:label 'Roster Lock Timestamp' ;
    rdfs:comment 'Date and time when the roster was locked and no further changes are permitted. Null if roster not yet locked.' ;
    rdfs:domain ind:TournamentRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:seedAssignment rdf:type rdf:Property ;
    rdfs:label 'Seed Assignment' ;
    rdfs:comment 'Seeding position assigned to the registrant for bracket placement. Lower numbers indicate higher seeds. Null if seeding not yet assigned or not applicable.' ;
    rdfs:domain ind:TournamentRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:skillTier rdf:type rdf:Property ;
    rdfs:label 'Skill Tier' ;
    rdfs:comment 'Skill tier or rank of the registrant at time of registration (e.g., Bronze, Silver, Gold, Platinum, Diamond, Master, Grandmaster). Used for tier-restricted tournaments.' ;
    rdfs:domain ind:TournamentRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionAllowed rdf:type rdf:Property ;
    rdfs:label 'Substitution Allowed' ;
    rdfs:comment 'Indicates whether player substitutions are permitted for this registration per tournament rules. True if allowed, False if not.' ;
    rdfs:domain ind:TournamentRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverSigned rdf:type rdf:Property ;
    rdfs:label 'Waiver Signed' ;
    rdfs:comment 'Indicates whether the registrant has signed the tournament liability waiver and terms of participation. True if signed, False if not.' ;
    rdfs:domain ind:TournamentRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverSignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Waiver Signed Timestamp' ;
    rdfs:comment 'Date and time when the waiver was signed. Null if not yet signed.' ;
    rdfs:domain ind:TournamentRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transferId rdf:type rdf:Property ;
    rdfs:label 'Transfer Id' ;
    rdfs:comment 'Unique identifier for the esports player transfer transaction.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationTeamId rdf:type rdf:Property ;
    rdfs:label 'Destination Team Id' ;
    rdfs:comment 'Identifier of the team to which the player is transferring.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:originTeamId rdf:type rdf:Property ;
    rdfs:label 'Origin Team Id' ;
    rdfs:comment 'Identifier of the team from which the player is transferring. Null for free agent signings.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:windowId rdf:type rdf:Property ;
    rdfs:label 'Window Id' ;
    rdfs:comment 'Identifier of the official transfer window period during which this transfer was executed, ensuring compliance with league roster lock rules.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransferWindow .

ind:agentCommissionAmount rdf:type rdf:Property ;
    rdfs:label 'Agent Commission Amount' ;
    rdfs:comment 'Commission paid to the player\'s agent as part of the transfer transaction. Null if undisclosed or not applicable.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:announcementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Announcement Timestamp' ;
    rdfs:comment 'Precise timestamp of the public transfer announcement, used for media tracking and fan engagement analytics.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:buyoutClauseTriggered rdf:type rdf:Property ;
    rdfs:label 'Buyout Clause Triggered' ;
    rdfs:comment 'Indicates whether this transfer was executed via a pre-existing buyout clause in the player\'s contract, bypassing negotiation.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feeAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Amount' ;
    rdfs:comment 'Monetary value paid by the destination team to the origin team for the player transfer rights. Zero for free agent signings. Null if undisclosed.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeCurrency rdf:type rdf:Property ;
    rdfs:label 'Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the transfer fee (e.g., USD, EUR, KRW).' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leagueApprovalDate rdf:type rdf:Property ;
    rdfs:label 'League Approval Date' ;
    rdfs:comment 'The date on which the league officially approved the transfer. Null if approval is not required or still pending.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leagueApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'League Approval Required' ;
    rdfs:comment 'Indicates whether this transfer requires explicit approval from the league governing body before completion.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leagueApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'League Approval Status' ;
    rdfs:comment 'Current status of league approval process for this transfer.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loanDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Loan Duration Months' ;
    rdfs:comment 'Duration in months for loan-type transfers. Null for permanent transfers and free agent signings.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loanFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Loan Fee Amount' ;
    rdfs:comment 'Fee paid by the destination team to the origin team for the loan period. Null for non-loan transfers.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loanOptionToBuy rdf:type rdf:Property ;
    rdfs:label 'Loan Option To Buy' ;
    rdfs:comment 'Indicates whether the loan agreement includes an option for the destination team to purchase the player permanently at the end of the loan period.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalClearanceDate rdf:type rdf:Property ;
    rdfs:label 'Medical Clearance Date' ;
    rdfs:comment 'The date on which the player received medical clearance for the transfer. Null if not required or not yet completed.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Medical Clearance Required' ;
    rdfs:comment 'Indicates whether the transfer is contingent upon the player passing a medical or health assessment.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optionToBuyAmount rdf:type rdf:Property ;
    rdfs:label 'Option To Buy Amount' ;
    rdfs:comment 'Pre-agreed purchase price if the destination team exercises the option to buy at the end of the loan. Null if no option exists.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceBonusClause rdf:type rdf:Property ;
    rdfs:label 'Performance Bonus Clause' ;
    rdfs:comment 'Description of any performance-based bonus payments owed to the origin team based on the player\'s achievements with the destination team (e.g., tournament wins, MVP awards).' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicAnnouncementUrl rdf:type rdf:Property ;
    rdfs:label 'Public Announcement Url' ;
    rdfs:comment 'URL link to the official public announcement or press release for this transfer.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryResponsibilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Salary Responsibility Percentage' ;
    rdfs:comment 'Percentage of the player\'s salary that the origin team continues to pay during a loan transfer. Null for permanent transfers.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sellOnClausePercentage rdf:type rdf:Property ;
    rdfs:label 'Sell On Clause Percentage' ;
    rdfs:comment 'Percentage of any future transfer fee that the origin team is entitled to receive if the destination team sells the player to another team. Null if no sell-on clause exists.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialMediaEngagementCount rdf:type rdf:Property ;
    rdfs:label 'Social Media Engagement Count' ;
    rdfs:comment 'Aggregate count of social media engagements (likes, shares, comments) on the transfer announcement, used for marketing and fan sentiment analysis.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transferNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Number' ;
    rdfs:comment 'Externally-known unique business identifier for this transfer transaction, used in public announcements and league filings.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Status' ;
    rdfs:comment 'Current lifecycle state of the transfer: pending league approval, publicly announced, completed and roster-locked, cancelled by parties, or rejected by league.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferType rdf:type rdf:Property ;
    rdfs:label 'Transfer Type' ;
    rdfs:comment 'Classification of the transfer mechanism: permanent transfer, loan, free agent signing, buyout clause activation, or player trade.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartOfAccountsId rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Id' ;
    rdfs:comment 'Foreign key linking to finance.chart_of_accounts. Business justification: budget has gl_account_code (STRING) referencing chart of accounts. Normalize by adding chart_of_accounts_id FK to chart_of_accounts.chart_of_accounts_id and removing redundant gl_account_code string.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChartOfAccounts .

ind:budgetCategory rdf:type rdf:Property ;
    rdfs:label 'Budget Category' ;
    rdfs:comment 'The high-level category of the budget: opex (operating expenses), capex (capital expenditures for game development and infrastructure), revenue (top-line targets), headcount (FTE budget).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Status' ;
    rdfs:comment 'The current lifecycle status of the budget record: draft (in preparation), submitted (awaiting approval), approved (active for spending), rejected (not approved), active (in execution), closed (fiscal period ended).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessUnitCode rdf:type rdf:Property ;
    rdfs:label 'Business Unit Code' ;
    rdfs:comment 'The business unit code representing the organizational division (e.g., game_publishing, esports, engine_licensing, live_ops). Enables business-unit-level financial reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignCode rdf:type rdf:Property ;
    rdfs:label 'Campaign Code' ;
    rdfs:comment 'The marketing campaign code for campaign-specific budget allocation. Links budget to player acquisition and retention campaigns.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementCode rdf:type rdf:Property ;
    rdfs:label 'Cost Element Code' ;
    rdfs:comment 'The cost element code from controlling (CO) module, representing the type of cost (primary or secondary) for internal cost allocation and activity-based costing.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'The fiscal period (month) within the fiscal year (1-12). Enables monthly budget tracking and variance analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gameTitleCode rdf:type rdf:Property ;
    rdfs:label 'Game Title Code' ;
    rdfs:comment 'The code of the game title to which this budget is allocated. Enables title-level P&L and budget tracking for individual games or franchises.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountFte rdf:type rdf:Property ;
    rdfs:label 'Headcount Fte' ;
    rdfs:comment 'The budgeted headcount in full-time equivalents for this cost center and period. Supports workforce planning and personnel cost budgeting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Order Number' ;
    rdfs:comment 'The internal order number for project-based budgeting (e.g., game development projects, marketing campaigns, infrastructure initiatives). Enables project cost tracking.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionReason rdf:type rdf:Property ;
    rdfs:label 'Revision Reason' ;
    rdfs:comment 'The business reason for a revised or forecast budget version (e.g., game_launch_delay, live_ops_performance_change, market_conditions, headcount_adjustment). Provides context for mid-year changes.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioName rdf:type rdf:Property ;
    rdfs:label 'Scenario Name' ;
    rdfs:comment 'The name of the planning scenario (e.g., base, upside, downside, aggressive_launch, conservative_ops). Used for scenario planning and sensitivity analysis.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'The unique identifier of this budget record in the source system. Enables traceability back to the originating system for reconciliation and troubleshooting.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studioCode rdf:type rdf:Property ;
    rdfs:label 'Studio Code' ;
    rdfs:comment 'The code of the game development studio responsible for this budget line. Supports studio-level financial reporting and resource allocation.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'The detailed subcategory within the budget category (e.g., marketing_spend, server_infrastructure, game_development, royalty_payments, personnel_costs).' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Percent' ;
    rdfs:comment 'The acceptable variance threshold percentage for budget vs. actuals comparison. Triggers alerts when actual spending exceeds this threshold (e.g., 10.00 for 10%).' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:versionType rdf:type rdf:Property ;
    rdfs:label 'Version Type' ;
    rdfs:comment 'The type of budget version: original (initial approved budget), revised (mid-year adjustments), forecast (rolling forecast updates), scenario (what-if planning scenarios).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetVersionId rdf:type rdf:Property ;
    rdfs:label 'Budget Version Id' ;
    rdfs:comment 'Unique identifier for the budget version snapshot. Primary key.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BudgetVersion .

ind:primaryBudgetEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Budget Employee Id' ;
    rdfs:comment 'Reference to the user (typically CFO, finance director, or budget owner) who approved this budget version. Nullable for draft or rejected versions.' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryBudgetLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Budget Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this budget version record. Supports audit trail and change tracking.' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryBudgetCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Budget Created By User Employee Id' ;
    rdfs:comment 'Reference to the user who created this budget version record. Supports audit trail and accountability.' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:budgetVersionStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Version Status' ;
    rdfs:comment 'Current lifecycle status of the budget version: draft (in preparation), submitted (awaiting approval), approved (finalized and active), rejected (not approved), active (currently in use), superseded (replaced by newer version), archived (historical record). [ENUM-REF-CANDIDATE: draft|submitted|approved|rejected|active|superseded|archived — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capexBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Capex Budget Amount' ;
    rdfs:comment 'The total budgeted capital expenditures for this version. Includes game development costs capitalized as assets, infrastructure investments, and technology platform upgrades.' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ebitdaBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Ebitda Budget Amount' ;
    rdfs:comment 'The budgeted EBITDA for this version. Key profitability metric used for studio performance evaluation and title-level return on investment (ROI) analysis.' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBaseline rdf:type rdf:Property ;
    rdfs:label 'Is Baseline' ;
    rdfs:comment 'Boolean flag indicating whether this version serves as the baseline for variance analysis. Typically the original approved budget is marked as baseline.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:opexBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Opex Budget Amount' ;
    rdfs:comment 'The total budgeted operating expenses for this version. Includes studio operations, live operations (LiveOps), marketing, player support, and general administrative costs.' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Budget Amount' ;
    rdfs:comment 'The total budgeted revenue for this version. Includes all revenue streams: game sales, in-app purchases (IAP), microtransactions (MTX), subscriptions, licensing, and esports.' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scenarioDescription rdf:type rdf:Property ;
    rdfs:label 'Scenario Description' ;
    rdfs:comment 'Detailed description of the scenario assumptions for this budget version. Used for scenario planning (e.g., \'Assumes game launch delay by 2 quarters\', \'Upside case with 20% higher Daily Active Users (DAU)\').' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Total Budget Amount' ;
    rdfs:comment 'The total budgeted amount across all cost centers, general ledger (GL) accounts, and line items for this version. Represents the aggregate financial plan.' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Percentage' ;
    rdfs:comment 'The acceptable variance threshold percentage for this budget version. Used to trigger alerts when actual spend deviates from budget by more than this percentage (e.g., 10.00 for 10%).' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:versionName rdf:type rdf:Property ;
    rdfs:label 'Version Name' ;
    rdfs:comment 'Human-readable name or label for this budget version (e.g., \'FY2024 Original Budget\', \'Q2 Revised Forecast\', \'Post-Launch Upside Scenario\').' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Fixed Asset Id' ;
    rdfs:comment 'Foreign key linking to finance.fixed_asset. Business justification: capex_project can result in tangible fixed assets (studio equipment, facilities). Add nullable fixed_asset_id FK for projects that capitalize to tangible assets rather than intangible. Asset_number is' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:intangibleAssetId rdf:type rdf:Property ;
    rdfs:label 'Intangible Asset Id' ;
    rdfs:comment 'Foreign key linking to finance.intangible_asset. Business justification: capex_project tracks game development projects that become intangible assets upon capitalization. capex_project.asset_number (STRING) references the resulting intangible asset. Normalize by adding int' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IntangibleAsset .

ind:accountingStandard rdf:type rdf:Property ;
    rdfs:label 'Accounting Standard' ;
    rdfs:comment 'The accounting framework under which this project is capitalized: GAAP (US Generally Accepted Accounting Principles, ASC 350-40 for internal-use software) or IFRS (International Financial Reporting Standards, IAS 38 for intangible assets).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accumulatedAmortization rdf:type rdf:Property ;
    rdfs:label 'Accumulated Amortization' ;
    rdfs:comment 'Total amortization expense recognized to date for this capitalized asset. Contra-asset account reducing the net book value.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualSpendToDate rdf:type rdf:Property ;
    rdfs:label 'Actual Spend To Date' ;
    rdfs:comment 'Cumulative actual capital expenditure incurred on this project from capitalization start date through the current reporting period. Sourced from SAP S/4HANA FI/CO actual postings.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amortizationMethod rdf:type rdf:Property ;
    rdfs:label 'Amortization Method' ;
    rdfs:comment 'The depreciation method applied to this asset: straight_line (equal expense each period), accelerated (higher expense in early periods), or units_of_production (based on usage metrics such as player sessions or revenue).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amortizationPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Amortization Period Months' ;
    rdfs:comment 'The total number of months over which the capitalized asset will be amortized (depreciated). Typically 36-60 months for software and technology assets, per company policy and accounting standards.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amortizationStartDate rdf:type rdf:Property ;
    rdfs:label 'Amortization Start Date' ;
    rdfs:comment 'The date on which amortization (depreciation) of the capitalized asset begins, typically the go-live date or the first day of the month following go-live.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Budget Amount' ;
    rdfs:comment 'Total capital expenditure budget approved for this project by finance and executive leadership. Represents the maximum authorized spend for capitalization.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetClass rdf:type rdf:Property ;
    rdfs:label 'Asset Class' ;
    rdfs:comment 'Fixed asset classification for the capitalized asset: software (internal-use software, game code), technology (servers, network equipment), building (owned real estate), equipment (hardware, furniture), leasehold_improvement (tenant improvements), or other.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetUnderConstructionBalance rdf:type rdf:Property ;
    rdfs:label 'Asset Under Construction Balance' ;
    rdfs:comment 'Current balance sheet value of the asset under construction (AUC) for this project. Represents capitalized costs accumulated but not yet placed in service. Transfers to fixed asset or intangible asset account upon go-live.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessJustification rdf:type rdf:Property ;
    rdfs:label 'Business Justification' ;
    rdfs:comment 'Executive summary of the business case and strategic rationale for this capital investment (e.g., expected ROI, competitive advantage, platform expansion, regulatory compliance).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationEndDate rdf:type rdf:Property ;
    rdfs:label 'Capitalization End Date' ;
    rdfs:comment 'The date on which the project exited the capitalization phase, typically when the asset is placed in service (go-live date for software, completion date for infrastructure). Nullable for projects still in progress.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capitalizationStartDate rdf:type rdf:Property ;
    rdfs:label 'Capitalization Start Date' ;
    rdfs:comment 'The date on which the project entered the capitalization phase, meaning costs incurred from this date forward qualify for capitalization under the applicable accounting standard (typically when technological feasibility is established for software projects).' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capitalizationStatus rdf:type rdf:Property ;
    rdfs:label 'Capitalization Status' ;
    rdfs:comment 'Current lifecycle status of the capital project: planning (pre-approval), approved (budget authorized), in_progress (active spend phase), capitalized (asset placed in service, amortization started), amortizing (ongoing depreciation), closed (project complete and fully amortized or written off).' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Amount' ;
    rdfs:comment 'Total value of purchase orders and contractual commitments issued against this project that have not yet been invoiced or paid. Used for budget tracking and forecasting.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedRoiPercent rdf:type rdf:Property ;
    rdfs:label 'Expected Roi Percent' ;
    rdfs:comment 'Projected return on investment for this capital project, expressed as a percentage. Used for investment prioritization and post-launch performance evaluation.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goLiveDate rdf:type rdf:Property ;
    rdfs:label 'Go Live Date' ;
    rdfs:comment 'The date the capitalized asset was placed into production use (e.g., game launch date, engine release date, infrastructure cutover date). Triggers the start of amortization. Nullable for projects not yet live.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:impairmentIndicatorFlag rdf:type rdf:Property ;
    rdfs:label 'Impairment Indicator Flag' ;
    rdfs:comment 'Boolean flag indicating whether an impairment indicator has been identified for this asset (e.g., project cancellation, significant underperformance, technology obsolescence). Triggers impairment testing per ASC 350-30 or IAS 36.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impairmentLossAmount rdf:type rdf:Property ;
    rdfs:label 'Impairment Loss Amount' ;
    rdfs:comment 'Total impairment loss recognized for this asset to date. Represents write-downs when the carrying value exceeds recoverable amount. Nullable if no impairment has occurred.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netBookValue rdf:type rdf:Property ;
    rdfs:label 'Net Book Value' ;
    rdfs:comment 'Current net book value of the capitalized asset: asset_under_construction_balance (or capitalized cost if live) minus accumulated_amortization. Represents the carrying value on the balance sheet.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectCode rdf:type rdf:Property ;
    rdfs:label 'Project Code' ;
    rdfs:comment 'Business identifier for the capital project, typically aligned with SAP S/4HANA internal order or Work Breakdown Structure (WBS) element code. Used for cross-system reference and financial reporting.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectDescription rdf:type rdf:Property ;
    rdfs:label 'Project Description' ;
    rdfs:comment 'Detailed business description of the capital project scope, objectives, and deliverables. Used for reporting and audit documentation.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectName rdf:type rdf:Property ;
    rdfs:label 'Project Name' ;
    rdfs:comment 'Human-readable name of the capital project (e.g., \'Unreal Engine 5 Migration\', \'New Studio Build-Out Seattle\', \'Cloud Infrastructure Expansion EMEA\').' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectType rdf:type rdf:Property ;
    rdfs:label 'Project Type' ;
    rdfs:comment 'Classification of the capital project by business purpose: game development (title-specific capitalized development costs), engine technology (game engine licensing or internal development), infrastructure (servers, CDN, cloud), studio facility (physical office or production space), platform integration (console SDK, storefront integration), or other.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingBudget rdf:type rdf:Property ;
    rdfs:label 'Remaining Budget' ;
    rdfs:comment 'Calculated remaining budget available for this project: approved_budget_amount minus (actual_spend_to_date plus committed_amount). May be negative if project is over budget.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wbsElement rdf:type rdf:Property ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'SAP S/4HANA Project System (PS) Work Breakdown Structure element code for this capital project. Hierarchical project structure used for detailed cost tracking and reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountCategory rdf:type rdf:Property ;
    rdfs:label 'Account Category' ;
    rdfs:comment 'The primary financial statement category indicating whether this account appears on the balance sheet, profit and loss statement, or is used for statistical tracking only.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountDescription rdf:type rdf:Property ;
    rdfs:label 'Account Description' ;
    rdfs:comment 'Detailed description of the GL account explaining its purpose, usage, and what types of transactions should be posted to it.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountGroup rdf:type rdf:Property ;
    rdfs:label 'Account Group' ;
    rdfs:comment 'The hierarchical grouping code used to organize accounts into logical clusters for reporting and analysis. Gaming-specific groups include game development costs, platform fees, virtual currency liability, and esports operations.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'The short descriptive name of the GL account used for display and identification purposes.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountSubgroup rdf:type rdf:Property ;
    rdfs:label 'Account Subgroup' ;
    rdfs:comment 'Secondary level of account grouping providing finer granularity within account groups for detailed financial analysis and reporting.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'The fundamental financial statement classification of the account indicating whether it represents assets, liabilities, equity, revenue, or expenses.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceSheetClassification rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Classification' ;
    rdfs:comment 'For balance sheet accounts, indicates whether the account represents current or non-current assets/liabilities, or equity. Not applicable for P&L accounts.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAreaRequiredIndicator rdf:type rdf:Property ;
    rdfs:label 'Business Area Required Indicator' ;
    rdfs:comment 'Flag indicating whether a business area assignment is mandatory when posting to this account, enabling cross-company business segment reporting.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capitalizationEligibleIndicator rdf:type rdf:Property ;
    rdfs:label 'Capitalization Eligible Indicator' ;
    rdfs:comment 'Flag indicating whether costs posted to this account are eligible for capitalization as game development assets under ASC 985-20 software development cost accounting.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'The SAP company code to which this account is assigned, representing the legal entity for financial reporting purposes. Multiple company codes may use the same account structure.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationAccountCode rdf:type rdf:Property ;
    rdfs:label 'Consolidation Account Code' ;
    rdfs:comment 'The account code used in group consolidation reporting, enabling mapping from local company chart of accounts to standardized group reporting structure.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'The SAP Controlling (CO) area code used for management accounting and cost center reporting, enabling cross-company cost analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterRequiredIndicator rdf:type rdf:Property ;
    rdfs:label 'Cost Center Required Indicator' ;
    rdfs:comment 'Flag indicating whether a cost center assignment is mandatory when posting to this account, enabling departmental cost tracking.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costElementCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Element Category' ;
    rdfs:comment 'For accounts that are cost elements, indicates whether they are primary cost elements (linked to GL accounts) or secondary cost elements (used for internal allocations only).' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementIndicator rdf:type rdf:Property ;
    rdfs:label 'Cost Element Indicator' ;
    rdfs:comment 'Flag indicating whether this GL account is also defined as a cost element in SAP CO for cost center and internal order postings.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currencyType rdf:type rdf:Property ;
    rdfs:label 'Currency Type' ;
    rdfs:comment 'Indicates which currency types are maintained for this account: local currency only, group currency, transaction currency, or all currency types for multi-currency reporting.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitCreditIndicator rdf:type rdf:Property ;
    rdfs:label 'Debit Credit Indicator' ;
    rdfs:comment 'Indicates whether increases to this account are recorded as debits or credits, following standard accounting conventions for the account type.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esportsCategory rdf:type rdf:Property ;
    rdfs:label 'Esports Category' ;
    rdfs:comment 'For esports-related accounts, indicates the specific esports financial category (e.g., prize pool accruals, tournament operations, sponsorship revenue, broadcast rights, team salaries) to enable esports P&L tracking.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldStatusGroup rdf:type rdf:Property ;
    rdfs:label 'Field Status Group' ;
    rdfs:comment 'The SAP field status group code that controls which fields are required, optional, or suppressed when posting to this account.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementLineItem rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Line Item' ;
    rdfs:comment 'The specific line item on published financial statements where this account balance is reported, enabling mapping from GL detail to external reporting.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'The functional area code used for segment reporting and cost-of-sales accounting, enabling analysis by business function (e.g., game development, publishing, live ops, esports).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gamingAccountPurpose rdf:type rdf:Property ;
    rdfs:label 'Gaming Account Purpose' ;
    rdfs:comment 'Gaming-industry-specific classification describing the specialized purpose of this account (e.g., deferred revenue for GaaS subscriptions, season pass liability, game development cost capitalization, virtual currency liability, platform fee expense, esports prize pool accruals, royalty accruals, DLC revenue, MTX revenue, licensing revenue).' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'The SAP user ID of the person who last modified this account master record.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemDisplayIndicator rdf:type rdf:Property ;
    rdfs:label 'Line Item Display Indicator' ;
    rdfs:comment 'Flag indicating whether individual line item detail is stored and displayable for this account, or only summary balances are maintained.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openItemManagementIndicator rdf:type rdf:Property ;
    rdfs:label 'Open Item Management Indicator' ;
    rdfs:comment 'Flag indicating whether this account uses open item management for tracking and clearing individual transactions (common for receivables, payables, and clearing accounts).' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformFeeCategory rdf:type rdf:Property ;
    rdfs:label 'Platform Fee Category' ;
    rdfs:comment 'For platform fee expense accounts, indicates the platform or distribution channel (e.g., Steam, Epic Games Store, PlayStation, Xbox, Apple App Store, Google Play) to enable platform-specific profitability analysis.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingAllowedIndicator rdf:type rdf:Property ;
    rdfs:label 'Posting Allowed Indicator' ;
    rdfs:comment 'Flag indicating whether direct manual or automated postings are allowed to this account, or if it only receives postings through specific processes.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterRequiredIndicator rdf:type rdf:Property ;
    rdfs:label 'Profit Center Required Indicator' ;
    rdfs:comment 'Flag indicating whether a profit center assignment is mandatory when posting to this account, enabling studio-level and title-level P&L tracking.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationAccountIndicator rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Indicator' ;
    rdfs:comment 'Flag indicating whether this is a reconciliation account used to summarize subledger balances (e.g., accounts receivable, accounts payable, fixed assets).' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueRecognitionPattern rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Pattern' ;
    rdfs:comment 'For revenue accounts, indicates whether revenue is recognized at a point in time (e.g., game sales, DLC purchases) or over time (e.g., GaaS subscriptions, season passes), per ASC 606 guidance.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyType rdf:type rdf:Property ;
    rdfs:label 'Royalty Type' ;
    rdfs:comment 'For royalty accrual accounts, indicates the type of royalty (e.g., developer royalty, IP licensing royalty, engine licensing royalty, music licensing royalty) to support royalty reporting and payment processing.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortKey rdf:type rdf:Property ;
    rdfs:label 'Sort Key' ;
    rdfs:comment 'The field used to sort line items within this account for display and reporting purposes (e.g., posting date, document number, assignment field).' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subledgerType rdf:type rdf:Property ;
    rdfs:label 'Subledger Type' ;
    rdfs:comment 'For reconciliation accounts, indicates which subledger module (AR, AP, AA, MM, HR) feeds into this GL account.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'The tax classification code indicating how transactions posted to this account should be treated for tax reporting purposes (e.g., taxable revenue, exempt, input tax, output tax).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'The date after which this account definition is no longer valid for new postings. Null indicates the account is valid indefinitely.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:virtualEconomyIndicator rdf:type rdf:Property ;
    rdfs:label 'Virtual Economy Indicator' ;
    rdfs:comment 'Flag indicating whether this account is used to track virtual currency liabilities, virtual goods inventory, or other virtual economy financial elements requiring specialized accounting treatment.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allocationCycleId rdf:type rdf:Property ;
    rdfs:label 'Allocation Cycle Id' ;
    rdfs:comment 'Identifier of the allocation cycle or run during which this cost allocation was executed. Links to the batch or period in which allocations were processed.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AllocationCycle .

ind:originalAllocationCostAllocationId rdf:type rdf:Property ;
    rdfs:label 'Original Allocation Cost Allocation Id' ;
    rdfs:comment 'Identifier of the original cost allocation record that this entry reverses or adjusts. Nullable if this is not a reversal or adjustment.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostAllocation .

ind:primarySenderCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Primary Sender Cost Center Id' ;
    rdfs:comment 'Identifier of the cost center that is the source of the allocated cost. References the cost center that incurred the original expense being distributed.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:receiverProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Receiver Profit Center Id' ;
    rdfs:comment 'Identifier of the profit center receiving the allocated cost. Used for title-level and studio-level P&L (Profit and Loss) construction.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:allocationBaseUnit rdf:type rdf:Property ;
    rdfs:label 'Allocation Base Unit' ;
    rdfs:comment 'Unit of measure for the allocation base value. Examples: FTE (Full-Time Equivalent), USD, hours, square_meters, transactions.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationBaseValue rdf:type rdf:Property ;
    rdfs:label 'Allocation Base Value' ;
    rdfs:comment 'Quantitative value of the allocation key driver for the receiver. For example, headcount number, revenue amount, server hours, or square meters used by the receiver.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationKeyCode rdf:type rdf:Property ;
    rdfs:label 'Allocation Key Code' ;
    rdfs:comment 'Code representing the allocation key or driver used to distribute costs. Examples include headcount, revenue share, server usage, square footage, or transaction volume.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationKeyName rdf:type rdf:Property ;
    rdfs:label 'Allocation Key Name' ;
    rdfs:comment 'Descriptive name of the allocation key or driver used for cost distribution. Human-readable label for the allocation basis.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocation Percentage' ;
    rdfs:comment 'Percentage of the total sender cost center expense allocated to this receiver. Represents the proportional share of the allocation key driver.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationRunDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Run Date' ;
    rdfs:comment 'Date on which the allocation cycle was executed and this allocation record was created. Represents the processing date of the allocation batch.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current status of the cost allocation record in its lifecycle. Indicates whether the allocation is preliminary, finalized, or has been adjusted or reversed.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costType rdf:type rdf:Property ;
    rdfs:label 'Cost Type' ;
    rdfs:comment 'High-level category of the cost being allocated. Classifies the nature of the shared cost for reporting and analysis purposes. [ENUM-REF-CANDIDATE: shared_services|platform_infrastructure|corporate_overhead|engine_licensing|it_services|facilities|hr_services|finance_services|legal_services|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'Unique document number assigned by the financial system for this cost allocation posting. Used for audit trail and reconciliation with general ledger.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'Date on which the cost allocation was posted to the general ledger and cost accounting modules. Represents the accounting effective date.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Flag indicating whether this allocation record is a reversal of a previous allocation. True if this is a reversal entry; False otherwise.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Parent Cost Center Id' ;
    rdfs:comment 'Identifier of the parent cost center in the cost center hierarchy. Supports roll-up reporting and organizational structure analysis. Null for top-level cost centers.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'The approved budget amount for this cost center for the current fiscal period. Used for budget vs. actuals variance analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessArea rdf:type rdf:Property ;
    rdfs:label 'Business Area' ;
    rdfs:comment 'The SAP Business Area representing a segment of the business (e.g., console games, mobile games, esports). Supports segment reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Center Category' ;
    rdfs:comment 'Classification of the cost center by functional area. Supports EBITDA decomposition and organizational cost analysis. [ENUM-REF-CANDIDATE: studio|game_title|platform_engineering|esports_operations|live_ops|corporate_overhead|shared_services|marketing|qa|support — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Center Description' ;
    rdfs:comment 'Detailed description of the cost center\'s purpose, scope, and responsibilities within the organization.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'The human-readable name of the cost center (e.g., \'Studio Alpha - Engineering\', \'Live Ops Team\', \'Platform Infrastructure\').' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center. Active cost centers can receive postings; inactive cost centers are closed; blocked cost centers are temporarily suspended; planned cost centers are not yet operational.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterType rdf:type rdf:Property ;
    rdfs:label 'Cost Center Type' ;
    rdfs:comment 'Type of cost center indicating its role in the cost allocation hierarchy (production centers directly contribute to game development; service centers provide internal support; administrative centers are overhead; auxiliary centers support production indirectly).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementGroup rdf:type rdf:Property ;
    rdfs:label 'Cost Element Group' ;
    rdfs:comment 'The primary cost element group associated with this cost center (e.g., personnel costs, infrastructure costs, licensing fees). Supports cost type analysis.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currency rdf:type rdf:Property ;
    rdfs:label 'Currency' ;
    rdfs:comment 'The currency in which costs are recorded for this cost center. ISO 4217 three-letter currency code.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'The department code representing the organizational department to which this cost center belongs. Supports departmental cost roll-up.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountAllocationKey rdf:type rdf:Property ;
    rdfs:label 'Headcount Allocation Key' ;
    rdfs:comment 'The headcount-based allocation key used to distribute shared costs. Represents the proportion of total headcount assigned to this cost center.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'The level of this cost center in the organizational hierarchy (1 = top level, increasing for nested levels). Supports hierarchical roll-up and drill-down reporting.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isAllocable rdf:type rdf:Property ;
    rdfs:label 'Is Allocable' ;
    rdfs:comment 'Indicates whether costs from this cost center can be allocated to other cost centers or profit centers. True for shared services and overhead cost centers; false for final cost centers.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOverhead rdf:type rdf:Property ;
    rdfs:label 'Is Overhead' ;
    rdfs:comment 'Indicates whether this cost center represents corporate overhead or indirect costs. True for overhead cost centers; false for direct production cost centers.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSharedService rdf:type rdf:Property ;
    rdfs:label 'Is Shared Service' ;
    rdfs:comment 'Indicates whether this cost center provides shared services to multiple business units or titles. True for shared service centers; false for dedicated cost centers.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Three-letter code representing the geographic location or office where this cost center operates. Supports location-based cost analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueAllocationKey rdf:type rdf:Property ;
    rdfs:label 'Revenue Allocation Key' ;
    rdfs:comment 'The revenue-based allocation key used to distribute shared costs. Represents the proportion of total revenue attributed to this cost center.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liabilityChartOfAccountsId rdf:type rdf:Property ;
    rdfs:label 'Liability Chart Of Accounts Id' ;
    rdfs:comment 'Foreign key linking to finance.chart_of_accounts. Business justification: deferred_revenue has gl_account_code (STRING) for the liability account. Normalize by adding liability_chart_of_accounts_id FK to chart_of_accounts.chart_of_accounts_id and removing gl_account_code st' ;
    rdfs:domain ind:DeferredRevenue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChartOfAccounts .

ind:transactionId rdf:type rdf:Property ;
    rdfs:label 'Transaction Id' ;
    rdfs:comment 'Reference to the originating billing transaction that created this deferred revenue liability.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Gaming .

ind:contentDeliverySchedule rdf:type rdf:Property ;
    rdfs:label 'Content Delivery Schedule' ;
    rdfs:comment 'Planned schedule for content delivery milestones that trigger revenue recognition events (e.g., Season 1: March, Season 2: June, Season 3: September, Season 4: December).' ;
    rdfs:domain ind:DeferredRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractLiabilityNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Liability Number' ;
    rdfs:comment 'Business identifier for the contract liability, used for external reporting and audit trail under ASC 606 / IFRS 15.' ;
    rdfs:domain ind:DeferredRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferredRevenueStatus rdf:type rdf:Property ;
    rdfs:label 'Deferred Revenue Status' ;
    rdfs:comment 'Current lifecycle status of the deferred revenue liability (open, partially recognized, fully recognized, refunded, cancelled).' ;
    rdfs:domain ind:DeferredRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialLiabilityAmount rdf:type rdf:Property ;
    rdfs:label 'Initial Liability Amount' ;
    rdfs:comment 'The original deferred revenue liability amount recorded at the time of cash receipt, representing the total performance obligation value.' ;
    rdfs:domain ind:DeferredRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPreOrder rdf:type rdf:Property ;
    rdfs:label 'Is Pre Order' ;
    rdfs:comment 'Flag indicating whether this deferred revenue originated from a game pre-order (True) or post-launch purchase (False).' ;
    rdfs:domain ind:DeferredRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Last Recognition Date' ;
    rdfs:comment 'The date of the most recent revenue recognition event for this liability.' ;
    rdfs:domain ind:DeferredRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:liabilityType rdf:type rdf:Property ;
    rdfs:label 'Liability Type' ;
    rdfs:comment 'Classification of the deferred revenue liability based on the type of performance obligation (season pass, annual subscription, game pre-order, DLC bundle, virtual currency, battle pass).' ;
    rdfs:domain ind:DeferredRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Next Recognition Date' ;
    rdfs:comment 'The scheduled date for the next revenue recognition event, used for forward-looking revenue forecasting.' ;
    rdfs:domain ind:DeferredRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:purchaseDate rdf:type rdf:Property ;
    rdfs:label 'Purchase Date' ;
    rdfs:comment 'The date when the player made the purchase that created this deferred revenue liability.' ;
    rdfs:domain ind:DeferredRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:purchaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Purchase Timestamp' ;
    rdfs:comment 'The precise timestamp when the purchase transaction was completed, used for detailed revenue timing analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recognitionEndDate rdf:type rdf:Property ;
    rdfs:label 'Recognition End Date' ;
    rdfs:comment 'The date when revenue recognition is expected to complete, representing the end of the performance obligation period.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionFrequency rdf:type rdf:Property ;
    rdfs:label 'Recognition Frequency' ;
    rdfs:comment 'The frequency at which revenue recognition events occur (daily, weekly, monthly, quarterly, event-based for content drops, usage-based for virtual currency spend).' ;
    rdfs:domain ind:DeferredRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Recognition Period Months' ;
    rdfs:comment 'The total number of months over which revenue will be recognized, used for straight-line recognition calculations.' ;
    rdfs:domain ind:DeferredRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recognitionStartDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Start Date' ;
    rdfs:comment 'The date when revenue recognition begins for this liability, typically the service start date or content availability date.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognizedRevenueToDate rdf:type rdf:Property ;
    rdfs:label 'Recognized Revenue To Date' ;
    rdfs:comment 'Cumulative amount of revenue recognized from this liability since inception, representing satisfied performance obligations.' ;
    rdfs:domain ind:DeferredRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingLiabilityBalance rdf:type rdf:Property ;
    rdfs:label 'Remaining Liability Balance' ;
    rdfs:comment 'The current outstanding deferred revenue liability balance that has not yet been recognized as earned revenue.' ;
    rdfs:domain ind:DeferredRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueGlAccountCode rdf:type rdf:Property ;
    rdfs:label 'Revenue Gl Account Code' ;
    rdfs:comment 'General ledger account code for the revenue account where recognized amounts are posted.' ;
    rdfs:domain ind:DeferredRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessedTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Assessed Tax Amount' ;
    rdfs:comment 'Tax amount determined by the tax authority in an assessment or audit, which may differ from the originally filed amount. Null if no assessment issued.' ;
    rdfs:domain ind:FinanceTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessmentReference rdf:type rdf:Property ;
    rdfs:label 'Assessment Reference' ;
    rdfs:comment 'Reference number for any tax assessment or notice issued by the tax authority, including audit findings or adjustments.' ;
    rdfs:domain ind:FinanceTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDate rdf:type rdf:Property ;
    rdfs:label 'Filing Date' ;
    rdfs:comment 'Actual date the tax return was filed with the tax authority, in yyyy-MM-dd format. Null if not yet filed.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingDueDate rdf:type rdf:Property ;
    rdfs:label 'Filing Due Date' ;
    rdfs:comment 'Statutory due date for filing the tax return with the tax authority, in yyyy-MM-dd format.' ;
    rdfs:domain ind:FinanceTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:groupCurrency rdf:type rdf:Property ;
    rdfs:label 'Group Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the corporate group reporting currency (e.g., USD).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCurrencyTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Group Currency Tax Amount' ;
    rdfs:comment 'Tax amount converted to the corporate group reporting currency for consolidated financial reporting.' ;
    rdfs:domain ind:FinanceTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestAmount rdf:type rdf:Property ;
    rdfs:label 'Interest Amount' ;
    rdfs:comment 'Interest amount charged by the tax authority on late or underpaid taxes. Zero if no interest.' ;
    rdfs:domain ind:FinanceTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localCurrency rdf:type rdf:Property ;
    rdfs:label 'Local Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the local currency in which the tax is calculated and remitted (e.g., USD, GBP, EUR, JPY).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'Statutory due date for remitting the tax payment to the tax authority, in yyyy-MM-dd format.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'Reference number or transaction ID for the tax payment, used for reconciliation with tax authority records.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Registration Number' ;
    rdfs:comment 'Company\'s tax registration number or VAT identification number with the tax authority in this jurisdiction (e.g., VAT number, TIN, EIN). Business-confidential identifier.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReturnReference rdf:type rdf:Property ;
    rdfs:label 'Tax Return Reference' ;
    rdfs:comment 'Official reference number or filing ID assigned by the tax authority upon submission of the tax return.' ;
    rdfs:domain ind:FinanceTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Status' ;
    rdfs:comment 'Current lifecycle status of the tax obligation: ACCRUED (recognized but not yet filed), FILED (return submitted), PAID (remitted to authority), ASSESSED (authority issued assessment), UNDER_AUDIT (subject to tax audit), DISPUTED (under appeal), REFUNDED (overpayment returned). [ENUM-REF-CANDIDATE: ACCRUED|FILED|PAID|ASSESSED|UNDER_AUDIT|DISPUTED|REFUNDED — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FinanceTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxableBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Taxable Base Amount' ;
    rdfs:comment 'The taxable base amount (revenue, income, or transaction value) upon which the tax is calculated, in local currency.' ;
    rdfs:domain ind:FinanceTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCategory rdf:type rdf:Property ;
    rdfs:label 'Transaction Category' ;
    rdfs:comment 'Category of underlying transactions subject to this tax (e.g., Digital Goods Sales, Royalty Payments, Intercompany Services, In-App Purchases, DLC Sales). Provides business context for the tax obligation.' ;
    rdfs:domain ind:FinanceTaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetChartOfAccountsId rdf:type rdf:Property ;
    rdfs:label 'Asset Chart Of Accounts Id' ;
    rdfs:comment 'Foreign key linking to finance.chart_of_accounts. Business justification: fixed_asset has gl_account_code (STRING) for the asset account. Normalize by adding asset_chart_of_accounts_id FK to chart_of_accounts.chart_of_accounts_id and removing gl_account_code string. Labeled' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChartOfAccounts .

ind:accumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Accumulated Depreciation' ;
    rdfs:comment 'Total depreciation expense recognized to date since the asset was placed in service. Contra-asset account that reduces the gross carrying amount.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accumulatedDepreciationGlAccountCode rdf:type rdf:Property ;
    rdfs:label 'Accumulated Depreciation Gl Account Code' ;
    rdfs:comment 'General ledger contra-asset account code where accumulated depreciation is recorded.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accumulatedImpairment rdf:type rdf:Property ;
    rdfs:label 'Accumulated Impairment' ;
    rdfs:comment 'Total impairment losses recognized to date when the asset\'s recoverable amount falls below its carrying value. Reduces net book value.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'Date when the fixed asset was acquired or purchased by the company. Used as the starting point for depreciation calculations.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'Externally-known unique asset tag or registration number assigned to the fixed asset for tracking and identification purposes. Used for physical labeling and inventory management.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetSubclass rdf:type rdf:Property ;
    rdfs:label 'Asset Subclass' ;
    rdfs:comment 'Secondary classification or subcategory within the asset class for granular tracking (e.g., Console Dev Kit, PC Workstation, Rack Server, Camera System).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationDate rdf:type rdf:Property ;
    rdfs:label 'Capitalization Date' ;
    rdfs:comment 'Date when the asset was placed in service and capitalization began. May differ from acquisition date for assets under construction.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depreciationGlAccountCode rdf:type rdf:Property ;
    rdfs:label 'Depreciation Gl Account Code' ;
    rdfs:comment 'General ledger account code to which periodic depreciation expense is posted.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method' ;
    rdfs:comment 'Accounting method used to calculate periodic depreciation expense for this asset. Determines how the asset cost is allocated over its useful life.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalDate rdf:type rdf:Property ;
    rdfs:label 'Disposal Date' ;
    rdfs:comment 'Date when the asset was disposed of, sold, scrapped, or retired from service. Marks the end of the asset\'s lifecycle.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalGainLoss rdf:type rdf:Property ;
    rdfs:label 'Disposal Gain Loss' ;
    rdfs:comment 'Calculated gain or loss on disposal, computed as disposal proceeds minus net book value at disposal date. Positive values indicate gain, negative indicate loss.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disposalMethod rdf:type rdf:Property ;
    rdfs:label 'Disposal Method' ;
    rdfs:comment 'Method by which the asset was disposed of. Determines accounting treatment for disposal gain or loss.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalProceeds rdf:type rdf:Property ;
    rdfs:label 'Disposal Proceeds' ;
    rdfs:comment 'Amount received from the sale or disposal of the asset. Used to calculate gain or loss on disposal.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastImpairmentTestDate rdf:type rdf:Property ;
    rdfs:label 'Last Impairment Test Date' ;
    rdfs:comment 'Date when the most recent impairment test was performed to assess whether the asset\'s carrying value exceeds its recoverable amount.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalCost rdf:type rdf:Property ;
    rdfs:label 'Original Cost' ;
    rdfs:comment 'Initial acquisition cost or cost basis of the fixed asset including purchase price, delivery, installation, and any costs necessary to bring the asset to working condition.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualValue rdf:type rdf:Property ;
    rdfs:label 'Residual Value' ;
    rdfs:comment 'Estimated salvage or residual value of the asset at the end of its useful life. The amount expected to be recovered upon disposal.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsiblePersonName rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Name' ;
    rdfs:comment 'Name of the individual responsible for the custody, maintenance, or management of this asset.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Manufacturer\'s serial number or unique device identifier for the asset. Used for warranty tracking and support.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxBasis rdf:type rdf:Property ;
    rdfs:label 'Tax Basis' ;
    rdfs:comment 'Tax basis or book value of the asset for tax depreciation purposes. May differ from financial accounting basis due to different depreciation methods.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'Estimated useful life of the asset in years over which depreciation will be calculated. Reflects the expected period the asset will provide economic benefit.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'Name of the vendor or supplier from whom the asset was purchased.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiration Date' ;
    rdfs:comment 'Date when the manufacturer or vendor warranty coverage expires for this asset.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:generalLedgerId rdf:type rdf:Property ;
    rdfs:label 'General Ledger Id' ;
    rdfs:comment 'Unique identifier for the general ledger entry. Primary key for the general ledger data product.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeneralLedger .

ind:assignmentField rdf:type rdf:Property ;
    rdfs:label 'Assignment Field' ;
    rdfs:comment 'Free-text field used for grouping related entries for clearing, reconciliation, or reporting purposes.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'The date from which payment terms are calculated for payables and receivables.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'The date on which this open item was cleared. Null if not cleared.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'The document number that cleared this open item (for receivables, payables, or other clearing accounts). Null if not cleared.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitAmount rdf:type rdf:Property ;
    rdfs:label 'Debit Amount' ;
    rdfs:comment 'The debit amount posted to the GL account in the document currency. Zero if the entry is a credit.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentCurrency rdf:type rdf:Property ;
    rdfs:label 'Document Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code of the original transaction (e.g., USD, EUR, GBP, JPY).' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The date on the source document (invoice date, receipt date, etc.). May differ from posting date.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Two-character code classifying the accounting document type (e.g., SA=GL account document, DR=customer invoice, KR=vendor invoice, DZ=payment document).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Date' ;
    rdfs:comment 'The date on which the document was entered into the system by the user.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Entry Timestamp' ;
    rdfs:comment 'The precise date and time when the document was entered into the system.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:groupCurrencyCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Group Currency Credit Amount' ;
    rdfs:comment 'The credit amount converted to the group reporting currency for consolidated financial statements.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groupCurrencyDebitAmount rdf:type rdf:Property ;
    rdfs:label 'Group Currency Debit Amount' ;
    rdfs:comment 'The debit amount converted to the group reporting currency for consolidated financial statements.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ledgerGroup rdf:type rdf:Property ;
    rdfs:label 'Ledger Group' ;
    rdfs:comment 'Two-character code identifying the ledger (e.g., 0L=leading ledger, 2L=IFRS ledger, 3L=local GAAP ledger) for parallel accounting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencyCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Credit Amount' ;
    rdfs:comment 'The credit amount converted to the company code local currency for statutory reporting.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localCurrencyDebitAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Debit Amount' ;
    rdfs:comment 'The debit amount converted to the company code local currency for statutory reporting.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'Two-digit code that controls the posting behavior (debit or credit) and account type. Standard SAP posting keys: 40=debit GL, 50=credit GL, 01=debit customer, 11=credit customer, 31=debit vendor, 21=credit vendor.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceKey rdf:type rdf:Property ;
    rdfs:label 'Reference Key' ;
    rdfs:comment 'Free-text reference field containing additional document identifiers such as invoice numbers, purchase order numbers, or payment references.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'The document number of the original entry that this reversal entry is reversing. Null if not a reversal.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segment rdf:type rdf:Property ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Segment code for IFRS 8 and GAAP ASC 280 segment reporting, typically aligned with game titles, platforms, or geographic regions.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:textDescription rdf:type rdf:Property ;
    rdfs:label 'Text Description' ;
    rdfs:comment 'Free-text description providing additional context about the accounting entry (e.g., \'Deferred revenue recognition for Q1 season pass sales\').' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userName rdf:type rdf:Property ;
    rdfs:label 'User Name' ;
    rdfs:comment 'The SAP user ID of the person who posted this accounting entry.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionMethod rdf:type rdf:Property ;
    rdfs:label 'Acquisition Method' ;
    rdfs:comment 'Method by which the intangible asset was acquired. Internal development represents capitalized development costs. Business acquisition represents assets acquired through studio or company acquisitions. Asset purchase represents direct purchase of IP or technology. License acquisition represents purchased licenses with capitalized costs.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amortizationEndDate rdf:type rdf:Property ;
    rdfs:label 'Amortization End Date' ;
    rdfs:comment 'Expected date when the intangible asset will be fully amortized based on useful life and amortization method. Null for indefinite-lived assets.' ;
    rdfs:domain ind:IntangibleAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossCarryingAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Carrying Amount' ;
    rdfs:comment 'Original cost or fair value of the intangible asset at acquisition or capitalization, before any accumulated amortization or impairment. Represents the total capitalized cost for internally developed assets or purchase price for acquired assets.' ;
    rdfs:domain ind:IntangibleAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isIndefiniteLived rdf:type rdf:Property ;
    rdfs:label 'Is Indefinite Lived' ;
    rdfs:comment 'Flag indicating whether the intangible asset has an indefinite useful life. True for goodwill and certain brands that are expected to generate cash flows indefinitely. Indefinite-lived assets are not amortized but tested annually for impairment.' ;
    rdfs:domain ind:IntangibleAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInternallyDeveloped rdf:type rdf:Property ;
    rdfs:label 'Is Internally Developed' ;
    rdfs:comment 'Flag indicating whether the intangible asset was internally developed (true) or externally acquired (false). Internally developed assets follow ASC 985-20 capitalization rules for game development costs.' ;
    rdfs:domain ind:IntangibleAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastImpairmentChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Last Impairment Charge Amount' ;
    rdfs:comment 'Amount of the most recent impairment charge recognized. Represents the write-down from carrying amount to recoverable amount. Null if no impairment has been recorded.' ;
    rdfs:domain ind:IntangibleAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastImpairmentChargeDate rdf:type rdf:Property ;
    rdfs:label 'Last Impairment Charge Date' ;
    rdfs:comment 'Date of the most recent impairment charge recognized for this intangible asset. Null if no impairment has been recorded.' ;
    rdfs:domain ind:IntangibleAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryIntercompanyLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Primary Intercompany Legal Entity Id' ;
    rdfs:comment 'Identifier of the legal entity originating the intercompany transaction (e.g., parent company, studio subsidiary, regional publishing entity).' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:receivingEntityLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Receiving Entity Legal Entity Id' ;
    rdfs:comment 'Identifier of the legal entity receiving the intercompany transaction (e.g., studio subsidiary, esports subsidiary, regional entity).' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:eliminationDate rdf:type rdf:Property ;
    rdfs:label 'Elimination Date' ;
    rdfs:comment 'The date on which the intercompany transaction was eliminated in the consolidation process.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eliminationStatus rdf:type rdf:Property ;
    rdfs:label 'Elimination Status' ;
    rdfs:comment 'Indicates whether the intercompany transaction has been eliminated in the consolidated financial statements to avoid double-counting.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Functional Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code representing the functional currency of the sending entity.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Amount' ;
    rdfs:comment 'The transaction amount converted to the functional currency of the sending entity for local reporting.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groupCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Group Currency Amount' ;
    rdfs:comment 'The transaction amount converted to the group reporting currency for consolidated financial statements.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intercompanyTransactionDescription rdf:type rdf:Property ;
    rdfs:label 'Intercompany Transaction Description' ;
    rdfs:comment 'Free-text description providing additional context or details about the intercompany transaction.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationReference rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Reference' ;
    rdfs:comment 'Reference number or identifier linking this transaction to the corresponding entry in the receiving entitys books for reconciliation purposes.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementStatus rdf:type rdf:Property ;
    rdfs:label 'Settlement Status' ;
    rdfs:comment 'Indicates whether the intercompany transaction has been settled (paid) between the entities.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount' ;
    rdfs:comment 'The monetary value of the intercompany transaction in the transaction currency.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code in which the intercompany transaction was originally denominated.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'Business-facing unique transaction number or document reference for the intercompany transaction, typically generated by the ERP system.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Classification of the intercompany transaction indicating the nature of the financial flow between entities. [ENUM-REF-CANDIDATE: intercompany_loan|management_fee|royalty_transfer|cost_recharge|service_fee|license_fee|dividend|equity_contribution — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPricingMethod rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Method' ;
    rdfs:comment 'The transfer pricing methodology applied to determine the intercompany transaction price for tax compliance and regulatory purposes.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'The withholding tax amount deducted from the intercompany transaction, if applicable for cross-border transactions.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryJournalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Journal Employee Id' ;
    rdfs:comment 'The user ID of the person who posted this journal entry. Used for audit trail and accountability.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryJournalApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Journal Approved By User Employee Id' ;
    rdfs:comment 'The user ID of the person who approved this journal entry. Populated when workflow approval is required and has been completed.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignmentReference rdf:type rdf:Property ;
    rdfs:label 'Assignment Reference' ;
    rdfs:comment 'Assignment field used for grouping and sorting journal entries. Often contains project numbers, order numbers, or other business reference keys for reconciliation purposes.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Changed Timestamp' ;
    rdfs:comment 'The timestamp when the journal entry was last modified. Null if the entry has never been changed after initial posting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:documentHeaderText rdf:type rdf:Property ;
    rdfs:label 'Document Header Text' ;
    rdfs:comment 'Free-text description or memo at the document header level providing context about the purpose or nature of the journal entry.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStatus rdf:type rdf:Property ;
    rdfs:label 'Document Status' ;
    rdfs:comment 'Current lifecycle status of the journal entry document. Draft entries are not yet posted; parked entries are saved but not yet final; posted entries are active in the ledger; cleared entries have been reconciled; reversed entries have been cancelled; cancelled entries are voided.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryTime rdf:type rdf:Property ;
    rdfs:label 'Entry Time' ;
    rdfs:comment 'The timestamp when the journal entry was created in the system. Provides precise audit trail for when the entry was recorded.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'The local currency of the company code. All journal entries are also recorded in local currency for statutory reporting purposes.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'External reference number from the source document (invoice number, purchase order number, contract number, etc.). Used to trace the journal entry back to its originating business transaction.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'Code indicating the reason for reversing the original journal entry (e.g., error correction, period adjustment, cancellation).' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartner rdf:type rdf:Property ;
    rdfs:label 'Trading Partner' ;
    rdfs:comment 'Identifier of the trading partner company code for intercompany transactions. Used to track and eliminate intercompany balances in consolidated reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Code' ;
    rdfs:comment 'The SAP transaction code (T-code) used to create this journal entry (e.g., FB01 for manual entry, F-02 for general posting, MIRO for invoice verification).' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxCode rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Code' ;
    rdfs:comment 'Withholding tax code applicable to this journal entry. Used for automatic withholding tax calculation on vendor payments and certain revenue transactions.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowStatus rdf:type rdf:Property ;
    rdfs:label 'Workflow Status' ;
    rdfs:comment 'Status of the approval workflow for this journal entry. Manual journal entries and certain automated postings may require approval before final posting.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentEntityLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Parent Entity Legal Entity Id' ;
    rdfs:comment 'Reference to the immediate parent legal entity in the corporate ownership hierarchy. Used to construct consolidation hierarchies and organizational reporting structures.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:primaryUltimateParentEntityLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Primary Ultimate Parent Entity Legal Entity Id' ;
    rdfs:comment 'Reference to the top-level parent entity in the corporate group. Used for ultimate consolidation and group-level regulatory reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:auditOpinionType rdf:type rdf:Property ;
    rdfs:label 'Audit Opinion Type' ;
    rdfs:comment 'The type of audit opinion issued by the external auditor for the most recent fiscal year. Unqualified is clean; qualified indicates exceptions; adverse indicates material misstatement; disclaimer indicates scope limitation.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorName rdf:type rdf:Property ;
    rdfs:label 'Auditor Name' ;
    rdfs:comment 'Name of the external audit firm responsible for statutory audit of this legal entity. Used for audit coordination and regulatory compliance.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessSegment rdf:type rdf:Property ;
    rdfs:label 'Business Segment' ;
    rdfs:comment 'The primary business segment or operating division to which this legal entity belongs. Used for segment reporting under IFRS 8 and management reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationGroupCode rdf:type rdf:Property ;
    rdfs:label 'Consolidation Group Code' ;
    rdfs:comment 'Identifier for the consolidation group or reporting unit to which this entity belongs. Used for segment reporting and management consolidation hierarchies.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationMethod rdf:type rdf:Property ;
    rdfs:label 'Consolidation Method' ;
    rdfs:comment 'The accounting method used to consolidate this entity into group financial statements. Full consolidation for subsidiaries, proportional for joint ventures, equity method for associates, none for non-consolidated entities.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dissolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dissolution Date' ;
    rdfs:comment 'The date on which the legal entity was officially dissolved or deregistered. Null for active entities. Used for entity lifecycle tracking and historical reporting.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entityStatus rdf:type rdf:Property ;
    rdfs:label 'Entity Status' ;
    rdfs:comment 'Current operational and legal status of the entity. Active entities are operational and reporting; dormant entities are registered but inactive; liquidation and dissolved entities are in wind-down or closed.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'Classification of the legal entity structure. Determines consolidation treatment and reporting requirements.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearEndMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year End Month' ;
    rdfs:comment 'The month number (1-12) in which the entitys fiscal year ends. Used for statutory reporting deadlines and audit planning.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalYearVariant rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Variant' ;
    rdfs:comment 'Code representing the fiscal year calendar configuration for this entity. Defines the number of periods, period start/end dates, and year-end closing rules.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code representing the primary economic environment currency in which the entity operates. Used for financial statement preparation and consolidation.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'The geographic region in which the entity primarily operates. Used for geographic segment reporting and regional performance analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationDate rdf:type rdf:Property ;
    rdfs:label 'Incorporation Date' ;
    rdfs:comment 'The date on which the legal entity was officially incorporated or registered in its jurisdiction. Used for statutory reporting and entity lifecycle tracking.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:intercompanyPartnerNumber rdf:type rdf:Property ;
    rdfs:label 'Intercompany Partner Number' ;
    rdfs:comment 'Unique identifier used for intercompany transactions and transfer pricing documentation. Links to intercompany reconciliation and elimination processes.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRegulatedEntity rdf:type rdf:Property ;
    rdfs:label 'Is Regulated Entity' ;
    rdfs:comment 'Boolean flag indicating whether the entity is subject to industry-specific regulatory oversight beyond standard corporate law (e.g., gaming commissions, financial services regulators). True if regulated, false otherwise.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'The official registered legal name of the entity as recorded in the jurisdiction of incorporation. Used for statutory filings, contracts, and regulatory reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leiCode rdf:type rdf:Property ;
    rdfs:label 'Lei Code' ;
    rdfs:comment 'The 20-character ISO 17442 Legal Entity Identifier used for global financial reporting and regulatory transparency. Required for entities engaged in financial transactions.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'The percentage of equity ownership held by the parent company or controlling entity. Used to determine consolidation treatment and minority interest calculations.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registeredAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line1' ;
    rdfs:comment 'First line of the official registered address of the legal entity as recorded with the jurisdiction authority. Used for statutory correspondence and legal notices.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line2' ;
    rdfs:comment 'Second line of the official registered address, typically containing suite, floor, or building information.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCity rdf:type rdf:Property ;
    rdfs:label 'Registered City' ;
    rdfs:comment 'City or municipality of the registered address.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCountryCode rdf:type rdf:Property ;
    rdfs:label 'Registered Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the registered address.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredPostalCode rdf:type rdf:Property ;
    rdfs:label 'Registered Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the registered address.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredStateProvince rdf:type rdf:Property ;
    rdfs:label 'Registered State Province' ;
    rdfs:comment 'State, province, or administrative region of the registered address.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority' ;
    rdfs:comment 'Name of the primary regulatory body with oversight authority over this entity. Applicable for regulated entities such as those holding gaming licenses or financial services licenses.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFilingRequirement rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Requirement' ;
    rdfs:comment 'Classification of the entitys regulatory filing obligations. Public entities file with securities regulators; private entities file with corporate registries; exempt entities have reduced filing requirements.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code used for consolidated group reporting. May differ from functional currency for subsidiaries operating in different economic environments.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated or trading name used for internal reporting and operational purposes. Commonly used in dashboards and management reports.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockExchangeListing rdf:type rdf:Property ;
    rdfs:label 'Stock Exchange Listing' ;
    rdfs:comment 'The stock exchange and ticker symbol if the entity is publicly traded. Null for private entities. Used for investor relations and market data integration.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'The primary tax identification number assigned by the jurisdiction tax authority. Used for tax filings, transfer pricing documentation, and regulatory compliance.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predecessorTaskPeriodCloseId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Task Period Close Id' ;
    rdfs:comment 'Identifier of the predecessor close task that must be completed before this task can begin, supporting workflow dependencies.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PeriodClose .

ind:primaryPeriodEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Period Employee Id' ;
    rdfs:comment 'Identifier of the employee or user responsible for completing this close task.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryPeriodLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Period Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified this period close record.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryPeriodCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Period Created By User Employee Id' ;
    rdfs:comment 'Identifier of the user who created this period close record.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acceleratedCloseFlag rdf:type rdf:Property ;
    rdfs:label 'Accelerated Close Flag' ;
    rdfs:comment 'Indicator of whether this close task is part of an accelerated close initiative with compressed timelines (True) or follows standard close calendar (False).' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Timestamp' ;
    rdfs:comment 'Actual date and time when the close task was completed.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:automationEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Automation Enabled Flag' ;
    rdfs:comment 'Indicator of whether this close task is automated through RPA (Robotic Process Automation) or other automation tools (True) or performed manually (False).' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockingIssueDescription rdf:type rdf:Property ;
    rdfs:label 'Blocking Issue Description' ;
    rdfs:comment 'Detailed description of any blocking issue or impediment preventing the completion of the close task.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingIssueFlag rdf:type rdf:Property ;
    rdfs:label 'Blocking Issue Flag' ;
    rdfs:comment 'Indicator of whether there is a blocking issue preventing the completion of this close task (True) or not (False).' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closeStatus rdf:type rdf:Property ;
    rdfs:label 'Close Status' ;
    rdfs:comment 'Current lifecycle status of the period close process: not started, in progress, pending review, approved, completed, or reopened for adjustments.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeTaskName rdf:type rdf:Property ;
    rdfs:label 'Close Task Name' ;
    rdfs:comment 'Name of the specific close task or step being tracked (e.g., Subledger Reconciliation, Intercompany Elimination, FX Revaluation, Accrual Postings, Management Review).' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeType rdf:type rdf:Property ;
    rdfs:label 'Close Type' ;
    rdfs:comment 'Type of financial close being executed: month-end, quarter-end, year-end, or special close.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-text comments or notes related to the close task execution, issues encountered, or special circumstances.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlEvidenceDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Control Evidence Document Url' ;
    rdfs:comment 'URL or file path to the control evidence documentation supporting the completion of this close task for audit purposes.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Completion Date' ;
    rdfs:comment 'Scheduled date when the close task is planned to be completed according to the close calendar.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'Scheduled date when the close task is planned to begin according to the close calendar.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsibleOwnerName rdf:type rdf:Property ;
    rdfs:label 'Responsible Owner Name' ;
    rdfs:comment 'Full name of the employee or user responsible for completing this close task.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signOffUserName rdf:type rdf:Property ;
    rdfs:label 'Sign Off User Name' ;
    rdfs:comment 'Full name of the user who signed off on the completion of the close task.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlReference rdf:type rdf:Property ;
    rdfs:label 'Sox Control Reference' ;
    rdfs:comment 'Reference number or identifier of the SOX control that this close task supports or evidences.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskCategory rdf:type rdf:Property ;
    rdfs:label 'Task Category' ;
    rdfs:comment 'Functional category of the close task: reconciliation, posting, elimination, revaluation, review, approval, or reporting. [ENUM-REF-CANDIDATE: reconciliation|posting|elimination|revaluation|review|approval|reporting — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Task Sequence Number' ;
    rdfs:comment 'Sequential order of the close task within the overall close process, used to enforce task dependencies and workflow.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taskStatus rdf:type rdf:Property ;
    rdfs:label 'Task Status' ;
    rdfs:comment 'Current status of the individual close task: not started, in progress, completed, blocked, or deferred.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceExplanation rdf:type rdf:Property ;
    rdfs:label 'Variance Explanation' ;
    rdfs:comment 'Explanation of any significant variances or deviations from expected results identified during the close task.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Parent Profit Center Id' ;
    rdfs:comment 'Reference to the parent profit center in a hierarchical structure. Enables roll-up reporting from title-level to studio-level to business-line-level P&L. Nullable for top-level profit centers.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:budgetFiscalYear rdf:type rdf:Property ;
    rdfs:label 'Budget Fiscal Year' ;
    rdfs:comment 'The fiscal year for which the budget_amount is defined (e.g., 2024). Enables multi-year budget tracking and year-over-year variance analysis.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessAreaCode rdf:type rdf:Property ;
    rdfs:label 'Business Area Code' ;
    rdfs:comment 'The SAP business area code representing a cross-company-code segment for consolidated financial statements (e.g., \'Console Games\', \'Mobile Games\', \'Esports\').' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingAreaCode rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Code' ;
    rdfs:comment 'The SAP Controlling Area to which this profit center belongs. Controlling areas represent organizational units for cost accounting and internal reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterGroup rdf:type rdf:Property ;
    rdfs:label 'Cost Center Group' ;
    rdfs:comment 'The cost center group code that aggregates multiple cost centers feeding into this profit center. Used for indirect cost allocation and overhead absorption.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esrbRating rdf:type rdf:Property ;
    rdfs:label 'Esrb Rating' ;
    rdfs:comment 'The ESRB content rating for title-level profit centers: EC (Early Childhood), E (Everyone), E10 (Everyone 10+), T (Teen), M (Mature 17+), AO (Adults Only 18+), RP (Rating Pending), not_applicable (non-title profit centers). Impacts marketing strategy and regional distribution. [ENUM-REF-CANDIDATE: EC|E|E10|T|M|AO|RP|not_applicable — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gameGenre rdf:type rdf:Property ;
    rdfs:label 'Game Genre' ;
    rdfs:comment 'The primary game genre for title-level profit centers (e.g., \'Battle Royale\', \'Sports Simulation\', \'MMORPG\', \'Puzzle\'). Nullable for non-title profit centers. Used for genre-level profitability benchmarking. [ENUM-REF-CANDIDATE: action|adventure|rpg|strategy|sports|racing|simulation|puzzle|shooter|fighting|platformer|mmo|battle_royale|moba|card_game|casual — promote to reference product]' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFirstParty rdf:type rdf:Property ;
    rdfs:label 'Is First Party' ;
    rdfs:comment 'Indicates whether this profit center represents a first-party title (developed and published by the console manufacturer) or third-party title (external developer/publisher). Impacts revenue share and platform certification requirements.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLiveService rdf:type rdf:Property ;
    rdfs:label 'Is Live Service' ;
    rdfs:comment 'Indicates whether this profit center operates as a live service (GaaS) with ongoing content updates, events, and player engagement. Impacts cost structure (live ops team) and revenue forecasting (LTV vs upfront).' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:launchDate rdf:type rdf:Property ;
    rdfs:label 'Launch Date' ;
    rdfs:comment 'The official launch date (hard launch) for title-level profit centers. Used for post-launch profitability tracking, D1/D7/D30 retention correlation, and LTV modeling. Nullable for non-title profit centers.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lockIndicator rdf:type rdf:Property ;
    rdfs:label 'Lock Indicator' ;
    rdfs:comment 'Indicates whether this profit center is locked for posting transactions. Set to true during period-end close or when a profit center is being archived. Prevents accidental postings to closed periods.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformCategory rdf:type rdf:Property ;
    rdfs:label 'Platform Category' ;
    rdfs:comment 'The primary gaming platform category for this profit center. Used for platform-level P&L segmentation and platform strategy analysis. Set to not_applicable for non-platform profit centers (e.g., corporate services). [ENUM-REF-CANDIDATE: console|pc|mobile|cross_platform|cloud_gaming|vr_ar|not_applicable — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'The externally-known unique alphanumeric code for the profit center as defined in SAP S/4HANA CO module. Used for reporting and integration with external systems.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Profit Center Description' ;
    rdfs:comment 'A detailed description of the profit center\'s scope, business purpose, and key responsibilities. Used for onboarding new finance team members and audit documentation.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterName rdf:type rdf:Property ;
    rdfs:label 'Profit Center Name' ;
    rdfs:comment 'The human-readable name of the profit center (e.g., \'Fortnite Live Ops\', \'EA Sports FC Studio\', \'Mobile F2P Portfolio\').' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Profit Center Status' ;
    rdfs:comment 'Current lifecycle status of the profit center: active (operational and reporting), inactive (temporarily suspended), planned (future launch), sunset (end-of-life phase), archived (historical record only).' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterType rdf:type rdf:Property ;
    rdfs:label 'Profit Center Type' ;
    rdfs:comment 'Classification of the profit center by organizational structure: game_title (individual game P&L), studio (development studio), platform (console/PC/mobile), business_line (F2P/premium/GaaS), esports_league (competitive gaming), licensing (engine/IP licensing), corporate (shared services). [ENUM-REF-CANDIDATE: game_title|studio|platform|business_line|esports_league|licensing|corporate — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePersonEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Email' ;
    rdfs:comment 'The email address of the person responsible for this profit center. Used for automated P&L distribution and budget variance alerts.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyRatePct rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Pct' ;
    rdfs:comment 'The royalty rate percentage applied to revenue for licensed IP or third-party publishing agreements (e.g., 15.00 represents 15%). Used for royalty accrual calculations and licensor reporting. Nullable for wholly-owned IP.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sunsetDate rdf:type rdf:Property ;
    rdfs:label 'Sunset Date' ;
    rdfs:comment 'The planned or actual date when a game title or service is discontinued. Used for end-of-life cost planning and player migration strategies. Nullable for active profit centers.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetEbitdaMarginPct rdf:type rdf:Property ;
    rdfs:label 'Target Ebitda Margin Pct' ;
    rdfs:comment 'The target EBITDA margin percentage for this profit center (e.g., 25.00 represents 25%). Used for performance evaluation and executive compensation metrics.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryDisclosureId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Disclosure Id' ;
    rdfs:comment 'Unique identifier for the regulatory disclosure filing record.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryDisclosure .

ind:filingJurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Filing Jurisdiction Id' ;
    rdfs:comment 'Foreign key linking to compliance.jurisdiction. Business justification: Financial disclosures are filed in specific jurisdictions with distinct requirements (SEC for US, FCA for UK, etc.). Gaming companies operating globally must track which jurisdiction each disclosure s' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'Date when the regulatory authority or stock exchange officially accepted the filing as complete and compliant.' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'Sequential amendment number if this is an amended filing (1 for first amendment, 2 for second, etc.; null if original filing).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditReportDate rdf:type rdf:Property ;
    rdfs:label 'Audit Report Date' ;
    rdfs:comment 'Date when the external auditor signed and issued their audit report on the financial statements.' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cikNumber rdf:type rdf:Property ;
    rdfs:label 'Cik Number' ;
    rdfs:comment 'SEC Central Index Key number assigned to the filer for EDGAR system identification (10-digit number used by SEC).' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureType rdf:type rdf:Property ;
    rdfs:label 'Disclosure Type' ;
    rdfs:comment 'Type of regulatory disclosure filing (10-K annual report, 10-Q quarterly report, 8-K current report, 20-F foreign issuer annual report, annual report, statutory accounts, proxy statement, registration statement, prospectus). [ENUM-REF-CANDIDATE: 10-K|10-Q|8-K|20-F|annual_report|statutory_accounts|proxy_statement|registration_statement|prospectus — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ebitdaReported rdf:type rdf:Property ;
    rdfs:label 'Ebitda Reported' ;
    rdfs:comment 'EBITDA figure disclosed for the reporting period, representing operating performance before non-cash charges and financing costs.' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:esportsPrizePoolLiability rdf:type rdf:Property ;
    rdfs:label 'Esports Prize Pool Liability' ;
    rdfs:comment 'Total accrued liability for esports tournament prize pools that are committed but not yet paid as of the reporting period end date.' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeCode rdf:type rdf:Property ;
    rdfs:label 'Exchange Code' ;
    rdfs:comment 'Stock exchange where the company is listed and where the disclosure is filed (NYSE, NASDAQ, LSE, TSE, etc.). [ENUM-REF-CANDIDATE: NYSE|NASDAQ|LSE|TSE|HKEX|SSE|SZSE|ASX|TSX|BSE|NSE|EURONEXT — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAuditorName rdf:type rdf:Property ;
    rdfs:label 'External Auditor Name' ;
    rdfs:comment 'Name of the external audit firm that audited the financial statements included in this disclosure (e.g., Deloitte, PwC, EY, KPMG).' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Filing Deadline Date' ;
    rdfs:comment 'Regulatory deadline by which the disclosure must be filed to remain compliant (e.g., 60 days after quarter end for 10-Q, 90 days for 10-K).' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingNumber rdf:type rdf:Property ;
    rdfs:label 'Filing Number' ;
    rdfs:comment 'Official filing number or reference code assigned by the regulatory authority or stock exchange (e.g., SEC accession number, EDGAR filing number).' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gameDevelopmentImpairmentAmount rdf:type rdf:Property ;
    rdfs:label 'Game Development Impairment Amount' ;
    rdfs:comment 'Total impairment charges recognized for capitalized game development costs during the reporting period (write-downs of in-development or released game titles).' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalControlOpinion rdf:type rdf:Property ;
    rdfs:label 'Internal Control Opinion' ;
    rdfs:comment 'Management and auditor assessment of internal controls over financial reporting effectiveness (effective, material weakness identified, significant deficiency, not applicable for smaller reporting companies).' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipWriteDownAmount rdf:type rdf:Property ;
    rdfs:label 'Ip Write Down Amount' ;
    rdfs:comment 'Total write-down or impairment charges for intellectual property assets (game franchises, licenses, trademarks) during the reporting period.' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAmended rdf:type rdf:Property ;
    rdfs:label 'Is Amended' ;
    rdfs:comment 'Indicates whether this disclosure is an amendment to a previously filed disclosure (True if amended, False if original filing).' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialDisclosureSummary rdf:type rdf:Property ;
    rdfs:label 'Material Disclosure Summary' ;
    rdfs:comment 'Summary of material disclosures, events, or items requiring special attention in this filing (e.g., game development impairments, IP write-downs, esports prize pool liabilities, litigation, restructuring charges, goodwill impairment, going concern issues).' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netIncomeReported rdf:type rdf:Property ;
    rdfs:label 'Net Income Reported' ;
    rdfs:comment 'Net income (profit after tax) figure disclosed for the reporting period in the filing currency.' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalFilingNumber rdf:type rdf:Property ;
    rdfs:label 'Original Filing Number' ;
    rdfs:comment 'Filing number of the original disclosure that this amendment corrects or updates (null if this is an original filing).' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparedByUser rdf:type rdf:Property ;
    rdfs:label 'Prepared By User' ;
    rdfs:comment 'Username or identifier of the internal user who prepared the disclosure filing.' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCurrency rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency' ;
    rdfs:comment 'Currency in which the financial figures in the disclosure are reported (3-letter ISO 4217 currency code). [ENUM-REF-CANDIDATE: USD|EUR|GBP|JPY|CNY|KRW|CAD|AUD|INR|BRL|MXN — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End Date' ;
    rdfs:comment 'End date of the financial reporting period covered by this disclosure (e.g., end of fiscal quarter or year).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start Date' ;
    rdfs:comment 'Start date of the financial reporting period covered by this disclosure (e.g., beginning of fiscal quarter or year).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewedByUser rdf:type rdf:Property ;
    rdfs:label 'Reviewed By User' ;
    rdfs:comment 'Username or identifier of the internal user who reviewed and approved the disclosure filing before submission.' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Sox Certification Status' ;
    rdfs:comment 'Status of Sarbanes-Oxley Act Section 302 and 906 CEO/CFO certifications for this disclosure (certified, not certified, pending).' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockholdersEquityReported rdf:type rdf:Property ;
    rdfs:label 'Stockholders Equity Reported' ;
    rdfs:comment 'Total stockholders equity (shareholders equity) figure disclosed on the balance sheet as of the reporting period end date.' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tickerSymbol rdf:type rdf:Property ;
    rdfs:label 'Ticker Symbol' ;
    rdfs:comment 'Stock ticker symbol under which the company trades on the stock exchange (e.g., GAME, GMNG).' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAssetsReported rdf:type rdf:Property ;
    rdfs:label 'Total Assets Reported' ;
    rdfs:comment 'Total assets figure disclosed on the balance sheet as of the reporting period end date.' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLiabilitiesReported rdf:type rdf:Property ;
    rdfs:label 'Total Liabilities Reported' ;
    rdfs:comment 'Total liabilities figure disclosed on the balance sheet as of the reporting period end date.' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRevenueReported rdf:type rdf:Property ;
    rdfs:label 'Total Revenue Reported' ;
    rdfs:comment 'Total revenue figure disclosed for the reporting period in the filing currency.' ;
    rdfs:domain ind:RegulatoryDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyStatementId rdf:type rdf:Property ;
    rdfs:label 'Royalty Statement Id' ;
    rdfs:comment 'Unique identifier for the formal royalty statement issued to the counterparty for this accrual period. Null if statement not yet generated.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoyaltyStatement .

ind:accrualPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Accrual Period End Date' ;
    rdfs:comment 'The end date of the period for which royalties are being accrued. Defines the close of the revenue or usage measurement window.' ;
    rdfs:domain ind:RoyaltyAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accrualPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Accrual Period Start Date' ;
    rdfs:comment 'The start date of the period for which royalties are being accrued. Defines the beginning of the revenue or usage measurement window.' ;
    rdfs:domain ind:RoyaltyAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accrualStatus rdf:type rdf:Property ;
    rdfs:label 'Accrual Status' ;
    rdfs:comment 'Current lifecycle status of the royalty accrual: draft (in preparation), calculated (computation complete), approved (finance approved), posted (posted to GL), settled (payment issued), disputed (under review), or cancelled. [ENUM-REF-CANDIDATE: draft|calculated|approved|posted|settled|disputed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RoyaltyAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accruedRoyaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Accrued Royalty Amount' ;
    rdfs:comment 'The total royalty amount accrued for this period, calculated as royalty_base_amount multiplied by royalty_rate_percent, adjusted for any tiers or thresholds.' ;
    rdfs:domain ind:RoyaltyAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:advanceRecoupedAmount rdf:type rdf:Property ;
    rdfs:label 'Advance Recouped Amount' ;
    rdfs:comment 'The portion of previously paid advances that is recouped (offset) against this accrual period\'s royalty. Reduces the net payable to the counterparty.' ;
    rdfs:domain ind:RoyaltyAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'The method used to calculate the royalty: flat rate (single percentage), tiered (rate varies by revenue bands), threshold-based (rate changes after threshold), hybrid (combination), or manual (manually entered).' ;
    rdfs:domain ind:RoyaltyAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this royalty accrual is currently under dispute by the counterparty or internal audit.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netRoyaltyPayable rdf:type rdf:Property ;
    rdfs:label 'Net Royalty Payable' ;
    rdfs:comment 'The net royalty amount payable to the counterparty after deducting advance recoupment and any other adjustments. This is the amount due for payment.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Royalty Base Amount' ;
    rdfs:comment 'The total revenue or usage amount (in the accrual period) on which the royalty is calculated, before applying the royalty rate.' ;
    rdfs:domain ind:RoyaltyAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyBaseType rdf:type rdf:Property ;
    rdfs:label 'Royalty Base Type' ;
    rdfs:comment 'The revenue or usage metric on which the royalty calculation is based: net revenue, gross revenue, units sold, in-app purchase (IAP) revenue, downloadable content (DLC) revenue, or subscription revenue.' ;
    rdfs:domain ind:RoyaltyAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyRatePercent rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Percent' ;
    rdfs:comment 'The percentage rate applied to the royalty base to calculate the accrued royalty amount. May vary by tier or threshold as defined in the agreement.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statementDueDate rdf:type rdf:Property ;
    rdfs:label 'Statement Due Date' ;
    rdfs:comment 'The date by which payment of the net royalty payable is due to the counterparty, as defined in the agreement payment terms.' ;
    rdfs:domain ind:RoyaltyAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementIssueDate rdf:type rdf:Property ;
    rdfs:label 'Statement Issue Date' ;
    rdfs:comment 'The date on which the formal royalty statement was issued to the counterparty. Null if not yet issued.' ;
    rdfs:domain ind:RoyaltyAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractIpAgreementId rdf:type rdf:Property ;
    rdfs:label 'Contract Ip Agreement Id' ;
    rdfs:comment 'Reference to the master royalty contract or licensing agreement governing the terms of this statement.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IpAgreement .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Manual or contractual adjustments applied to the royalty (e.g., prior period corrections, dispute settlements, bonus payments).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:advanceRecoupmentAmount rdf:type rdf:Property ;
    rdfs:label 'Advance Recoupment Amount' ;
    rdfs:comment 'Amount of previously paid advances recouped (offset) against the calculated royalty in this statement period.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculatedRoyaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Calculated Royalty Amount' ;
    rdfs:comment 'Gross royalty amount calculated by applying the royalty rate to the net royalty base (net royalty base × royalty rate).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductionAmount rdf:type rdf:Property ;
    rdfs:label 'Deduction Amount' ;
    rdfs:comment 'Total deductions applied to gross revenue (e.g., platform fees, returns, refunds, marketing costs) per contract terms.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Date' ;
    rdfs:comment 'Date on which the dispute was resolved or closed. Null if dispute is ongoing.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketingCostAmount rdf:type rdf:Property ;
    rdfs:label 'Marketing Cost Amount' ;
    rdfs:comment 'Marketing and promotional costs allocated to this title and deducted per contract terms.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPayableAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payable Amount' ;
    rdfs:comment 'Final net amount payable to the counterparty after all recoupments and adjustments (calculated royalty minus advance recoupment plus/minus adjustments).' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netRoyaltyBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Net Royalty Base Amount' ;
    rdfs:comment 'Net revenue base after deductions, upon which the royalty rate is applied (gross revenue minus deductions).' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformFeesAmount rdf:type rdf:Property ;
    rdfs:label 'Platform Fees Amount' ;
    rdfs:comment 'Total platform distribution fees (e.g., Steam, Epic Games Store, console platform fees) deducted from gross revenue.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnRefundAmount rdf:type rdf:Property ;
    rdfs:label 'Return Refund Amount' ;
    rdfs:comment 'Total value of product returns and customer refunds deducted from gross revenue.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Percentage' ;
    rdfs:comment 'Effective royalty rate percentage applied to the net royalty base for this statement period. May reflect tiered or blended rates.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyTier rdf:type rdf:Property ;
    rdfs:label 'Royalty Tier' ;
    rdfs:comment 'Tiered royalty bracket applied for this statement period (e.g., Tier 1, Tier 2, Tier 3) if contract uses tiered rates based on revenue thresholds.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Statement Issued Date' ;
    rdfs:comment 'Date on which the royalty statement was formally issued to the counterparty.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementNumber rdf:type rdf:Property ;
    rdfs:label 'Statement Number' ;
    rdfs:comment 'Externally-known unique identifier for this royalty statement, used for audit and dispute resolution.' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementStatus rdf:type rdf:Property ;
    rdfs:label 'Statement Status' ;
    rdfs:comment 'Current lifecycle status of the royalty statement in the approval and settlement workflow.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementType rdf:type rdf:Property ;
    rdfs:label 'Statement Type' ;
    rdfs:comment 'Indicates whether this statement represents a royalty payable (owed to counterparty) or receivable (owed by counterparty).' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Code' ;
    rdfs:comment 'Geographic territory or region code for which this royalty statement applies (e.g., USA, EUR, APAC). Null if statement is global.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocatedOverhead rdf:type rdf:Property ;
    rdfs:label 'Allocated Overhead' ;
    rdfs:comment 'Corporate overhead costs allocated to the studio based on allocation keys (e.g., headcount, revenue share).' ;
    rdfs:domain ind:StudioPl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depreciationAmortization rdf:type rdf:Property ;
    rdfs:label 'Depreciation Amortization' ;
    rdfs:comment 'Depreciation of studio assets and amortization of intangible assets (e.g., acquired IP, capitalized development costs).' ;
    rdfs:domain ind:StudioPl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ebitda rdf:type rdf:Property ;
    rdfs:label 'Ebitda' ;
    rdfs:comment 'Studio earnings before interest, taxes, depreciation, and amortization, a key profitability metric for investment decisions.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engineLicensingRevenue rdf:type rdf:Property ;
    rdfs:label 'Engine Licensing Revenue' ;
    rdfs:comment 'Revenue earned from licensing proprietary game engine technology to third parties.' ;
    rdfs:domain ind:StudioPl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossProfit rdf:type rdf:Property ;
    rdfs:label 'Gross Profit' ;
    rdfs:comment 'Total revenue minus total direct costs, representing the studios contribution margin before overhead allocation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headcountCost rdf:type rdf:Property ;
    rdfs:label 'Headcount Cost' ;
    rdfs:comment 'Total personnel costs including salaries, benefits, bonuses, and payroll taxes for studio employees.' ;
    rdfs:domain ind:StudioPl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:infrastructureCost rdf:type rdf:Property ;
    rdfs:label 'Infrastructure Cost' ;
    rdfs:comment 'Costs for cloud services, on-premise servers, build farms, and IT infrastructure supporting studio operations.' ;
    rdfs:domain ind:StudioPl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketingCost rdf:type rdf:Property ;
    rdfs:label 'Marketing Cost' ;
    rdfs:comment 'Marketing, advertising, and promotional expenses directly attributable to the studio or its titles.' ;
    rdfs:domain ind:StudioPl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingProfit rdf:type rdf:Property ;
    rdfs:label 'Operating Profit' ;
    rdfs:comment 'Gross profit minus allocated overhead, depreciation, and royalty accruals, representing the studios operating income.' ;
    rdfs:domain ind:StudioPl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherDirectCost rdf:type rdf:Property ;
    rdfs:label 'Other Direct Cost' ;
    rdfs:comment 'Miscellaneous direct costs not classified under standard categories.' ;
    rdfs:domain ind:StudioPl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherRevenue rdf:type rdf:Property ;
    rdfs:label 'Other Revenue' ;
    rdfs:comment 'Miscellaneous revenue streams not classified under title royalties, work-for-hire, or engine licensing.' ;
    rdfs:domain ind:StudioPl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outsourcingCost rdf:type rdf:Property ;
    rdfs:label 'Outsourcing Cost' ;
    rdfs:comment 'Costs for external contractors, freelancers, and outsourced development services.' ;
    rdfs:domain ind:StudioPl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformCertificationCost rdf:type rdf:Property ;
    rdfs:label 'Platform Certification Cost' ;
    rdfs:comment 'Fees and costs associated with platform certification and compliance (console manufacturers, app stores).' ;
    rdfs:domain ind:StudioPl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qaTestingCost rdf:type rdf:Property ;
    rdfs:label 'Qa Testing Cost' ;
    rdfs:comment 'Costs for quality assurance, playtesting, user acceptance testing, and certification processes.' ;
    rdfs:domain ind:StudioPl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyAccrual rdf:type rdf:Property ;
    rdfs:label 'Royalty Accrual' ;
    rdfs:comment 'Accrued royalty obligations owed to external IP holders, talent, or partners based on studio performance.' ;
    rdfs:domain ind:StudioPl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:studioName rdf:type rdf:Property ;
    rdfs:label 'Studio Name' ;
    rdfs:comment 'The business name of the development studio for reporting and display purposes.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studioStatus rdf:type rdf:Property ;
    rdfs:label 'Studio Status' ;
    rdfs:comment 'Current operational status of the studio during this reporting period.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studioType rdf:type rdf:Property ;
    rdfs:label 'Studio Type' ;
    rdfs:comment 'Classification of the studio ownership and operational model: internal (wholly-owned first-party), external (third-party partner), acquired (recently integrated), joint venture, or work-for-hire contractor.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:titleRoyaltyRevenue rdf:type rdf:Property ;
    rdfs:label 'Title Royalty Revenue' ;
    rdfs:comment 'Revenue earned by the studio from royalties on published game titles during the reporting period.' ;
    rdfs:domain ind:StudioPl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toolingCost rdf:type rdf:Property ;
    rdfs:label 'Tooling Cost' ;
    rdfs:comment 'Costs for development tools, software licenses, middleware, and third-party SDKs used by the studio.' ;
    rdfs:domain ind:StudioPl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDirectCost rdf:type rdf:Property ;
    rdfs:label 'Total Direct Cost' ;
    rdfs:comment 'Sum of all direct costs incurred by the studio during the reporting period.' ;
    rdfs:domain ind:StudioPl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRevenue rdf:type rdf:Property ;
    rdfs:label 'Total Revenue' ;
    rdfs:comment 'Sum of all revenue streams for the studio during the reporting period.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workForHireRevenue rdf:type rdf:Property ;
    rdfs:label 'Work For Hire Revenue' ;
    rdfs:comment 'Revenue earned from contracted development services provided to external publishers or partners.' ;
    rdfs:domain ind:StudioPl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arppu rdf:type rdf:Property ;
    rdfs:label 'Arppu' ;
    rdfs:comment 'Average Revenue Per Paying User calculated as net revenue divided by the number of paying users. Measures monetization among payers only.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arpu rdf:type rdf:Property ;
    rdfs:label 'Arpu' ;
    rdfs:comment 'Average Revenue Per User calculated as net revenue divided by MAU. Measures monetization efficiency across all users.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandMarketingSpend rdf:type rdf:Property ;
    rdfs:label 'Brand Marketing Spend' ;
    rdfs:comment 'Brand and awareness marketing spend including influencer campaigns, esports sponsorships, PR, community events, and above-the-line advertising.' ;
    rdfs:domain ind:TitlePl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cdnCosts rdf:type rdf:Property ;
    rdfs:label 'Cdn Costs' ;
    rdfs:comment 'Content Delivery Network costs for distributing game patches, updates, and downloadable content to players globally.' ;
    rdfs:domain ind:TitlePl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cogsTotal rdf:type rdf:Property ;
    rdfs:label 'Cogs Total' ;
    rdfs:comment 'Total Cost of Goods Sold, summing development amortization, server/CDN costs, QA costs, royalties, and other direct costs attributable to delivering the game service.' ;
    rdfs:domain ind:TitlePl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conversionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Conversion Rate Percent' ;
    rdfs:comment 'Percentage of active users who made a purchase during the period, calculated as (paying_user_count / MAU) * 100.' ;
    rdfs:domain ind:TitlePl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dauAverage rdf:type rdf:Property ;
    rdfs:label 'Dau Average' ;
    rdfs:comment 'Average Daily Active Users for the title during the reporting period. Key engagement metric for GaaS titles.' ;
    rdfs:domain ind:TitlePl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:developmentAmortization rdf:type rdf:Property ;
    rdfs:label 'Development Amortization' ;
    rdfs:comment 'Amortized development costs allocated to this period, representing the capitalized development investment spread over the title\'s commercial lifecycle.' ;
    rdfs:domain ind:TitlePl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossMarginPercent rdf:type rdf:Property ;
    rdfs:label 'Gross Margin Percent' ;
    rdfs:comment 'Gross margin as a percentage of net revenue, calculated as (gross_profit / net_revenue) * 100. Key profitability indicator for title performance.' ;
    rdfs:domain ind:TitlePl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossRevenue rdf:type rdf:Property ;
    rdfs:label 'Gross Revenue' ;
    rdfs:comment 'Total gross sales revenue generated by the title before any deductions, including all In-App Purchases (IAP), Downloadable Content (DLC), Microtransactions (MTX), and initial game sales.' ;
    rdfs:domain ind:TitlePl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mauAverage rdf:type rdf:Property ;
    rdfs:label 'Mau Average' ;
    rdfs:comment 'Average Monthly Active Users for the title during the reporting period. Broader engagement metric than DAU.' ;
    rdfs:domain ind:TitlePl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatingExpenses rdf:type rdf:Property ;
    rdfs:label 'Operating Expenses' ;
    rdfs:comment 'Other operating expenses allocated to the title including player support, community management, live operations staff, and administrative overhead.' ;
    rdfs:domain ind:TitlePl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingIncome rdf:type rdf:Property ;
    rdfs:label 'Operating Income' ;
    rdfs:comment 'Operating income (EBIT) calculated as gross profit minus total marketing spend and operating expenses. Primary measure of title profitability.' ;
    rdfs:domain ind:TitlePl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingMarginPercent rdf:type rdf:Property ;
    rdfs:label 'Operating Margin Percent' ;
    rdfs:comment 'Operating margin as a percentage of net revenue, calculated as (operating_income / net_revenue) * 100. Key indicator of title operational efficiency.' ;
    rdfs:domain ind:TitlePl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payingUserCount rdf:type rdf:Property ;
    rdfs:label 'Paying User Count' ;
    rdfs:comment 'Total number of unique users who made at least one purchase during the reporting period.' ;
    rdfs:domain ind:TitlePl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plStatus rdf:type rdf:Property ;
    rdfs:label 'Pl Status' ;
    rdfs:comment 'Current status of this P&L statement in the financial close and reporting workflow.' ;
    rdfs:domain ind:TitlePl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformFees rdf:type rdf:Property ;
    rdfs:label 'Platform Fees' ;
    rdfs:comment 'Total fees paid to platform holders (Apple App Store, Google Play, Steam, Epic Games Store, console first parties) as a percentage of gross revenue. Typically 15-30% of gross sales.' ;
    rdfs:domain ind:TitlePl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qaTestingCosts rdf:type rdf:Property ;
    rdfs:label 'Qa Testing Costs' ;
    rdfs:comment 'Quality Assurance and playtesting costs allocated to this title for the period, including internal QA staff and external testing services.' ;
    rdfs:domain ind:TitlePl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roiPercent rdf:type rdf:Property ;
    rdfs:label 'Roi Percent' ;
    rdfs:comment 'Return on Investment calculated as (operating_income / total_marketing_spend) * 100. Measures marketing efficiency and profitability.' ;
    rdfs:domain ind:TitlePl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyExpenses rdf:type rdf:Property ;
    rdfs:label 'Royalty Expenses' ;
    rdfs:comment 'Royalty payments to Intellectual Property (IP) licensors, game engine providers (Unity, Unreal), middleware vendors, and talent (voice actors, composers) based on revenue or unit sales.' ;
    rdfs:domain ind:TitlePl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serverHostingCosts rdf:type rdf:Property ;
    rdfs:label 'Server Hosting Costs' ;
    rdfs:comment 'Cloud infrastructure and game server hosting costs for live operations, including compute, storage, and database services for Game-as-a-Service (GaaS) titles.' ;
    rdfs:domain ind:TitlePl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalMarketingSpend rdf:type rdf:Property ;
    rdfs:label 'Total Marketing Spend' ;
    rdfs:comment 'Total marketing expenditure combining user acquisition and brand marketing spend for the title during the period.' ;
    rdfs:domain ind:TitlePl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:userAcquisitionSpend rdf:type rdf:Property ;
    rdfs:label 'User Acquisition Spend' ;
    rdfs:comment 'Total marketing spend on user acquisition campaigns, including Cost Per Install (CPI), Cost Per Mille (CPM), and paid advertising across mobile, social, and digital channels.' ;
    rdfs:domain ind:TitlePl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityPlanId rdf:type rdf:Property ;
    rdfs:label 'Capacity Plan Id' ;
    rdfs:comment 'Unique identifier for the capacity plan record. Primary key for this operational planning document capturing CCU/PCU forecasts, scaling decisions, and maintenance windows.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapacityPlan .

ind:capacityAuthorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Capacity Author Employee Id' ;
    rdfs:comment 'Reference to the analyst or engineer who authored and submitted this capacity plan. Links to workforce/employee master data.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryCapacityEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Capacity Employee Id' ;
    rdfs:comment 'Reference to the engineer or technical lead who approved this capacity plan for execution. Links to workforce/employee master data.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:slaPolicyId rdf:type rdf:Property ;
    rdfs:label 'Sla Policy Id' ;
    rdfs:comment 'Foreign key linking to infrastructure.sla_policy. Business justification: capacity_plan targets SLA metrics defined in sla_policy. Many plans reference one SLA policy (N:1). capacity_plan has target_latency_ms and target_uptime_percentage which are defined in sla_policy. Ad' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaPolicy .

ind:targetKpiDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Target Kpi Definition Id' ;
    rdfs:comment 'Foreign key linking to analytics.kpi_definition. Business justification: Capacity plans target specific KPIs (peak CCU, average latency, uptime percentage) defined in analytics. Infrastructure teams plan capacity to meet KPI thresholds for business commitments and player e' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KpiDefinition .

ind:actualCostUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Usd' ;
    rdfs:comment 'Actual total cost in USD incurred for executing this capacity plan. Used for cost variance analysis and financial reconciliation.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualMaintenanceEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Maintenance End Timestamp' ;
    rdfs:comment 'Actual date and time when maintenance execution completed. Used to track variance from scheduled maintenance window and measure operational precision.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualMaintenanceStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Maintenance Start Timestamp' ;
    rdfs:comment 'Actual date and time when maintenance execution began. Used to track variance from scheduled maintenance window and measure operational precision.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:autoscalingCooldownSeconds rdf:type rdf:Property ;
    rdfs:label 'Autoscaling Cooldown Seconds' ;
    rdfs:comment 'Number of seconds to wait after a scaling action before triggering another scaling event. Prevents rapid oscillation in server fleet size.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoscalingTriggerThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Autoscaling Trigger Threshold Percentage' ;
    rdfs:comment 'CPU or memory utilization percentage threshold that triggers automatic scaling of server instances. Used to configure auto-scaling policies in cloud infrastructure.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Capacity Plan Status' ;
    rdfs:comment 'Current lifecycle status of the capacity plan: draft (under development), approved (ready for execution), active (currently in effect), completed (execution finished), cancelled (plan abandoned).' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnTopologyVersion rdf:type rdf:Property ;
    rdfs:label 'Cdn Topology Version' ;
    rdfs:comment 'Version identifier for the CDN topology configuration associated with this capacity plan. Tracks CDN edge node distribution and routing policies.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCostUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Usd' ;
    rdfs:comment 'Estimated total cost in USD for executing this capacity plan, including cloud compute, CDN bandwidth, and operational overhead. Used for budget planning and cost governance.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastedPeakCcu rdf:type rdf:Property ;
    rdfs:label 'Forecasted Peak Ccu' ;
    rdfs:comment 'Predicted maximum number of concurrent users expected during the planning horizon. Key input for server fleet sizing and auto-scaling policy configuration.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forecastedPeakPcu rdf:type rdf:Property ;
    rdfs:label 'Forecasted Peak Pcu' ;
    rdfs:comment 'Predicted absolute peak concurrent users (historical maximum) expected during the planning horizon. Used for worst-case capacity planning and SLA assurance.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenanceType rdf:type rdf:Property ;
    rdfs:label 'Maintenance Type' ;
    rdfs:comment 'Classification of the planned maintenance activity: patch (security or bug fixes), upgrade (version updates), migration (infrastructure changes), emergency (unplanned critical fixes), configuration (settings adjustments).' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceWindowEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Maintenance Window End Timestamp' ;
    rdfs:comment 'Scheduled end date and time for planned maintenance activities. Defines the conclusion of the maintenance window.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maintenanceWindowStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Maintenance Window Start Timestamp' ;
    rdfs:comment 'Scheduled start date and time for planned maintenance activities (patching, upgrades, migrations). Defines the beginning of the maintenance window.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:matchmakingServiceVersion rdf:type rdf:Property ;
    rdfs:label 'Matchmaking Service Version' ;
    rdfs:comment 'Version identifier for the matchmaking service configuration associated with this capacity plan. Tracks matchmaking algorithm and server allocation logic.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationStatus rdf:type rdf:Property ;
    rdfs:label 'Notification Status' ;
    rdfs:comment 'Status of player communication for this maintenance window: not_required (transparent maintenance), pending (notification scheduled), sent (players notified), acknowledged (confirmation received).' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onDemandInstanceCount rdf:type rdf:Property ;
    rdfs:label 'On Demand Instance Count' ;
    rdfs:comment 'Number of on-demand (pay-as-you-go) cloud compute instances allocated for this capacity plan. Provides elastic scaling capacity for peak demand.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Human-readable name or identifier for this capacity plan (e.g., \'Q4 2024 Holiday Peak Plan\', \'Season 3 Launch Scaling\').' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Classification of the capacity plan: baseline (steady-state), seasonal (recurring peak), event (esports tournament, content drop), launch (new title or DLC), emergency (unplanned surge), maintenance (scheduled downtime).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedServerInstanceCount rdf:type rdf:Property ;
    rdfs:label 'Planned Server Instance Count' ;
    rdfs:comment 'Total number of server instances (virtual machines or containers) planned to be provisioned to meet the forecasted CCU/PCU demand.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningHorizonEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon End Date' ;
    rdfs:comment 'End date of the time period covered by this capacity plan. Defines the conclusion of the forecast and scaling window.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningHorizonStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Start Date' ;
    rdfs:comment 'Start date of the time period covered by this capacity plan. Defines the beginning of the forecast and scaling window.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reservedInstanceCount rdf:type rdf:Property ;
    rdfs:label 'Reserved Instance Count' ;
    rdfs:comment 'Number of reserved (pre-purchased) cloud compute instances allocated for this capacity plan. Provides cost-optimized baseline capacity.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scalingHeadroomPercentage rdf:type rdf:Property ;
    rdfs:label 'Scaling Headroom Percentage' ;
    rdfs:comment 'Percentage of additional capacity provisioned above forecasted peak CCU to handle unexpected surges and ensure SLA compliance. Typically 10-30%.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaExclusionWindowFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Exclusion Window Flag' ;
    rdfs:comment 'Boolean flag indicating whether this maintenance window is excluded from SLA uptime calculations. True if downtime during this window does not count against SLA commitments.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:activatedDate rdf:type rdf:Property ;
    rdfs:label 'Activated Date' ;
    rdfs:comment 'Date when the CDN node was activated and began serving production traffic. Marks the start of operational service delivery.' ;
    rdfs:domain ind:CdnNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:averageLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Average Latency Ms' ;
    rdfs:comment 'Average network latency from the CDN node to end users measured in milliseconds. Critical KPI for player experience in online multiplayer games (PvP/PvE/MMO).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bandwidthCapacityGbps rdf:type rdf:Property ;
    rdfs:label 'Bandwidth Capacity Gbps' ;
    rdfs:comment 'Maximum network bandwidth capacity of the CDN node measured in gigabits per second. Critical for CCU/PCU capacity planning and ensuring sufficient throughput for game patches, DLC downloads, and live event streaming.' ;
    rdfs:domain ind:CdnNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cacheHitRatioPercentage rdf:type rdf:Property ;
    rdfs:label 'Cache Hit Ratio Percentage' ;
    rdfs:comment 'Percentage of content requests served from cache versus fetched from origin. Higher ratios indicate better CDN efficiency and lower origin server load.' ;
    rdfs:domain ind:CdnNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cacheStorageQuotaTb rdf:type rdf:Property ;
    rdfs:label 'Cache Storage Quota Tb' ;
    rdfs:comment 'Total cache storage capacity allocated to the CDN node measured in terabytes. Determines how much game content, patches, and assets can be cached locally for fast delivery.' ;
    rdfs:domain ind:CdnNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cacheStorageUsedTb rdf:type rdf:Property ;
    rdfs:label 'Cache Storage Used Tb' ;
    rdfs:comment 'Current cache storage utilization measured in terabytes. Monitored to prevent cache exhaustion and optimize content eviction policies.' ;
    rdfs:domain ind:CdnNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cdnNodeStatus rdf:type rdf:Property ;
    rdfs:label 'Cdn Node Status' ;
    rdfs:comment 'Current operational status of the CDN node. Active nodes serve traffic, maintenance nodes are temporarily offline, degraded nodes operate at reduced capacity.' ;
    rdfs:domain ind:CdnNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City where the CDN node data center or Point of Presence is physically located. Used for granular latency analysis and player proximity routing.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compressionEnabled rdf:type rdf:Property ;
    rdfs:label 'Compression Enabled' ;
    rdfs:comment 'Indicates whether the CDN node performs content compression (gzip, brotli) to reduce bandwidth consumption and improve download speeds.' ;
    rdfs:domain ind:CdnNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costPerGbUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Per Gb Usd' ;
    rdfs:comment 'Cost per gigabyte of bandwidth for this CDN node in USD. Confidential pricing information used for financial planning and vendor negotiations.' ;
    rdfs:domain ind:CdnNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentConcurrentConnections rdf:type rdf:Property ;
    rdfs:label 'Current Concurrent Connections' ;
    rdfs:comment 'Current number of active concurrent connections to the CDN node. Real-time metric for load balancing and capacity monitoring.' ;
    rdfs:domain ind:CdnNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataCenterFacility rdf:type rdf:Property ;
    rdfs:label 'Data Center Facility' ;
    rdfs:comment 'Name or identifier of the physical data center facility hosting the CDN node. Confidential operational information for infrastructure security and capacity planning.' ;
    rdfs:domain ind:CdnNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionedDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioned Date' ;
    rdfs:comment 'Date when the CDN node was decommissioned and removed from service. Nullable for active nodes. Used for infrastructure lifecycle management.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drmEnabled rdf:type rdf:Property ;
    rdfs:label 'Drm Enabled' ;
    rdfs:comment 'Indicates whether the CDN node supports DRM-protected content delivery. Essential for secure distribution of premium game content and preventing piracy.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hostname rdf:type rdf:Property ;
    rdfs:label 'Hostname' ;
    rdfs:comment 'Fully qualified domain name (FQDN) or hostname for the CDN node. Used for DNS routing, SSL certificate management, and operational monitoring.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipv4Address rdf:type rdf:Property ;
    rdfs:label 'Ipv4 Address' ;
    rdfs:comment 'Primary IPv4 address assigned to the CDN node. Confidential infrastructure information used for network routing and monitoring.' ;
    rdfs:domain ind:CdnNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipv6Address rdf:type rdf:Property ;
    rdfs:label 'Ipv6 Address' ;
    rdfs:comment 'Primary IPv6 address assigned to the CDN node. Supports modern network infrastructure and future-proofs content delivery as IPv6 adoption increases.' ;
    rdfs:domain ind:CdnNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date of the most recent scheduled maintenance performed on the CDN node. Used for maintenance scheduling and compliance with operational procedures.' ;
    rdfs:domain ind:CdnNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monitoringEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Monitoring Endpoint Url' ;
    rdfs:comment 'URL endpoint for health checks and monitoring of the CDN node. Confidential operational information used by DevOps and incident management systems.' ;
    rdfs:domain ind:CdnNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlyBandwidthQuotaTb rdf:type rdf:Property ;
    rdfs:label 'Monthly Bandwidth Quota Tb' ;
    rdfs:comment 'Monthly bandwidth transfer quota allocated to the CDN node measured in terabytes. Used for cost management and overage prevention.' ;
    rdfs:domain ind:CdnNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monthlyBandwidthUsedTb rdf:type rdf:Property ;
    rdfs:label 'Monthly Bandwidth Used Tb' ;
    rdfs:comment 'Bandwidth consumed by the CDN node in the current billing month measured in terabytes. Tracked for cost allocation and capacity forecasting.' ;
    rdfs:domain ind:CdnNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Date' ;
    rdfs:comment 'Scheduled date for the next planned maintenance window. Critical for coordinating maintenance with game launch schedules and live operations.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nodeCode rdf:type rdf:Property ;
    rdfs:label 'Node Code' ;
    rdfs:comment 'Business identifier or code assigned to the CDN node by the provider or internal operations team. Used for operational reference and monitoring dashboards.' ;
    rdfs:domain ind:CdnNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeName rdf:type rdf:Property ;
    rdfs:label 'Node Name' ;
    rdfs:comment 'Human-readable name or label for the CDN node, typically including geographic or facility identifiers for operational clarity.' ;
    rdfs:domain ind:CdnNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeType rdf:type rdf:Property ;
    rdfs:label 'Node Type' ;
    rdfs:comment 'Classification of the CDN node role in the content delivery topology. Edge nodes serve end users, origin shields protect origin servers, regional caches aggregate traffic.' ;
    rdfs:domain ind:CdnNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peakConcurrentConnections rdf:type rdf:Property ;
    rdfs:label 'Peak Concurrent Connections' ;
    rdfs:comment 'Maximum number of concurrent player connections the CDN node can support. Used for capacity planning during game launches, DLC releases, and live events.' ;
    rdfs:domain ind:CdnNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:peeringConfiguration rdf:type rdf:Property ;
    rdfs:label 'Peering Configuration' ;
    rdfs:comment 'Network peering strategy for the CDN node. Private peering and direct connect reduce latency and improve reliability for high-traffic game distribution.' ;
    rdfs:domain ind:CdnNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerName rdf:type rdf:Property ;
    rdfs:label 'Provider Name' ;
    rdfs:comment 'Name of the CDN service provider operating this node. Critical for vendor management, SLA tracking, and cost allocation. [ENUM-REF-CANDIDATE: akamai|cloudflare|fastly|amazon_cloudfront|azure_cdn|google_cloud_cdn|internal — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisionedDate rdf:type rdf:Property ;
    rdfs:label 'Provisioned Date' ;
    rdfs:comment 'Date when the CDN node was initially provisioned and configured. Used for infrastructure lifecycle tracking and depreciation planning.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sslCertificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Ssl Certificate Expiry Date' ;
    rdfs:comment 'Expiration date of the SSL/TLS certificate installed on the CDN node. Monitored to prevent service disruptions from expired certificates.' ;
    rdfs:domain ind:CdnNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supportsHttp2 rdf:type rdf:Property ;
    rdfs:label 'Supports Http2' ;
    rdfs:comment 'Indicates whether the CDN node supports HTTP/2 protocol for improved performance and multiplexing. Important for modern game client downloads and streaming.' ;
    rdfs:domain ind:CdnNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsHttp3 rdf:type rdf:Property ;
    rdfs:label 'Supports Http3' ;
    rdfs:comment 'Indicates whether the CDN node supports HTTP/3 protocol (QUIC) for reduced latency and improved connection reliability. Emerging standard for high-performance content delivery.' ;
    rdfs:domain ind:CdnNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:uptimeSlaPercentage rdf:type rdf:Property ;
    rdfs:label 'Uptime Sla Percentage' ;
    rdfs:comment 'Contractual uptime SLA target for the CDN node expressed as a percentage. Typically 99.9% or higher for production game distribution infrastructure.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalGateRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Gate Required' ;
    rdfs:comment 'Indicates whether this pipeline requires manual approval before proceeding to deployment stages.' ;
    rdfs:domain ind:CicdPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:artifactVersion rdf:type rdf:Property ;
    rdfs:label 'Artifact Version' ;
    rdfs:comment 'Version identifier of the build artifact produced by this pipeline run (e.g., \'1.2.3-build.456\', \'v2024.01.15\').' ;
    rdfs:domain ind:CicdPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildAgent rdf:type rdf:Property ;
    rdfs:label 'Build Agent' ;
    rdfs:comment 'Identifier of the CI/CD build agent or runner that executed this pipeline (e.g., \'jenkins-agent-03\', \'github-runner-linux-01\').' ;
    rdfs:domain ind:CicdPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitSha rdf:type rdf:Property ;
    rdfs:label 'Commit Sha' ;
    rdfs:comment 'Git commit SHA (40-character hexadecimal hash) that this pipeline run built and tested.' ;
    rdfs:domain ind:CicdPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerImageTag rdf:type rdf:Property ;
    rdfs:label 'Container Image Tag' ;
    rdfs:comment 'Docker or container image tag produced by this pipeline run (e.g., \'game-server:v1.2.3\', \'unity-client:latest\').' ;
    rdfs:domain ind:CicdPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Deployment Approval Status' ;
    rdfs:comment 'Status of manual deployment approval gate for this pipeline run (pending, approved, rejected, not_required).' ;
    rdfs:domain ind:CicdPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxExecutionTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Max Execution Time Minutes' ;
    rdfs:comment 'Maximum allowed execution time for this pipeline in minutes before automatic timeout and cancellation.' ;
    rdfs:domain ind:CicdPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationRecipients rdf:type rdf:Property ;
    rdfs:label 'Notification Recipients' ;
    rdfs:comment 'Comma-separated list of email addresses or Slack channels that receive notifications for this pipeline\'s execution results.' ;
    rdfs:domain ind:CicdPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parallelExecutionEnabled rdf:type rdf:Property ;
    rdfs:label 'Parallel Execution Enabled' ;
    rdfs:comment 'Indicates whether this pipeline is configured to execute stages in parallel for faster build times.' ;
    rdfs:domain ind:CicdPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pipelineConfigVersion rdf:type rdf:Property ;
    rdfs:label 'Pipeline Config Version' ;
    rdfs:comment 'Version or commit SHA of the pipeline configuration file used for this run (e.g., Jenkinsfile, .gitlab-ci.yml version).' ;
    rdfs:domain ind:CicdPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelinePriority rdf:type rdf:Property ;
    rdfs:label 'Pipeline Priority' ;
    rdfs:comment 'Execution priority level for this pipeline when multiple pipelines are queued (critical, high, normal, low).' ;
    rdfs:domain ind:CicdPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineTool rdf:type rdf:Property ;
    rdfs:label 'Pipeline Tool' ;
    rdfs:comment 'CI/CD platform or tool used to execute this pipeline (Jenkins, GitHub Actions, GitLab CI, TeamCity, Azure DevOps, CircleCI).' ;
    rdfs:domain ind:CicdPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityGatePassed rdf:type rdf:Property ;
    rdfs:label 'Quality Gate Passed' ;
    rdfs:comment 'Indicates whether all quality gates (code coverage, security scans, performance thresholds) were passed in this run.' ;
    rdfs:domain ind:CicdPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:repositoryUrl rdf:type rdf:Property ;
    rdfs:label 'Repository Url' ;
    rdfs:comment 'Source control repository URL that this pipeline monitors and builds from (e.g., GitHub, GitLab, Perforce Helix Core repository path).' ;
    rdfs:domain ind:CicdPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runNumber rdf:type rdf:Property ;
    rdfs:label 'Run Number' ;
    rdfs:comment 'Sequential execution number for this pipeline run, incremented with each execution.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runStatus rdf:type rdf:Property ;
    rdfs:label 'Run Status' ;
    rdfs:comment 'Current execution status of the pipeline run: queued, running, passed, failed, cancelled, or aborted.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityScanStatus rdf:type rdf:Property ;
    rdfs:label 'Security Scan Status' ;
    rdfs:comment 'Result of security vulnerability scanning during this pipeline run (passed, failed, skipped, warning).' ;
    rdfs:domain ind:CicdPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stagesFailed rdf:type rdf:Property ;
    rdfs:label 'Stages Failed' ;
    rdfs:comment 'Number of pipeline stages that failed during this run.' ;
    rdfs:domain ind:CicdPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stagesPassed rdf:type rdf:Property ;
    rdfs:label 'Stages Passed' ;
    rdfs:comment 'Number of pipeline stages that completed successfully in this run.' ;
    rdfs:domain ind:CicdPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tagName rdf:type rdf:Property ;
    rdfs:label 'Tag Name' ;
    rdfs:comment 'Source control tag associated with this pipeline run, if triggered by a tag (e.g., \'v1.2.3\', \'release-2024-01\').' ;
    rdfs:domain ind:CicdPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCoveragePercent rdf:type rdf:Property ;
    rdfs:label 'Test Coverage Percent' ;
    rdfs:comment 'Code test coverage percentage achieved during this pipeline run (0.00 to 100.00).' ;
    rdfs:domain ind:CicdPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggerSource rdf:type rdf:Property ;
    rdfs:label 'Trigger Source' ;
    rdfs:comment 'Specific source that triggered this run (e.g., commit SHA, schedule name, user ID, webhook event ID).' ;
    rdfs:domain ind:CicdPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerType rdf:type rdf:Property ;
    rdfs:label 'Trigger Type' ;
    rdfs:comment 'Mechanism that initiates pipeline execution: commit push, scheduled cron, manual invocation, pull request merge, tag creation, or external webhook.' ;
    rdfs:domain ind:CicdPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringActor rdf:type rdf:Property ;
    rdfs:label 'Triggering Actor' ;
    rdfs:comment 'Username or service account that initiated this pipeline run (human user, automated service, or webhook source).' ;
    rdfs:domain ind:CicdPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:webhookUrl rdf:type rdf:Property ;
    rdfs:label 'Webhook Url' ;
    rdfs:comment 'Webhook endpoint URL that external systems can call to trigger this pipeline execution.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cloudResourceId rdf:type rdf:Property ;
    rdfs:label 'Cloud Resource Id' ;
    rdfs:comment 'Unique identifier for the cloud compute resource. Primary key for cloud asset inventory tracking.' ;
    rdfs:domain ind:CloudResource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoScalingEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Scaling Enabled' ;
    rdfs:comment 'Indicates whether auto-scaling is enabled for this resource to handle dynamic CCU/PCU load. Critical for GaaS live service elasticity and cost optimization.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:availabilityZone rdf:type rdf:Property ;
    rdfs:label 'Availability Zone' ;
    rdfs:comment 'Specific availability zone within the region for high-availability and fault-tolerance architecture. Supports multi-AZ deployment strategies for live service uptime SLAs.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backupEnabled rdf:type rdf:Property ;
    rdfs:label 'Backup Enabled' ;
    rdfs:comment 'Indicates whether automated backups are configured for this resource. Supports disaster recovery planning and data protection compliance.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cloudProvider rdf:type rdf:Property ;
    rdfs:label 'Cloud Provider' ;
    rdfs:comment 'Cloud service provider hosting the resource. Supports multi-cloud infrastructure strategy and vendor cost analysis.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceScope rdf:type rdf:Property ;
    rdfs:label 'Compliance Scope' ;
    rdfs:comment 'Comma-separated list of compliance frameworks this resource must adhere to (e.g., GDPR, PCI DSS, SOC 2, ISO 27001, COPPA). Drives security controls and audit requirements. [ENUM-REF-CANDIDATE: GDPR|PCI DSS|SOC 2|ISO 27001|COPPA|CCPA|HIPAA|FedRAMP — promote to reference product]' ;
    rdfs:domain ind:CloudResource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Financial cost center code for chargeback and budget allocation. Links cloud spend to organizational units (studios, game titles, departments).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpuCores rdf:type rdf:Property ;
    rdfs:label 'Cpu Cores' ;
    rdfs:comment 'Number of virtual CPU cores allocated to the resource. Key metric for compute capacity planning and CCU/PCU scaling analysis.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cumulativeSpend rdf:type rdf:Property ;
    rdfs:label 'Cumulative Spend' ;
    rdfs:comment 'Total accumulated cost for this resource since provisioning. Supports lifetime cost analysis and ROI calculations for infrastructure investments.' ;
    rdfs:domain ind:CloudResource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environment rdf:type rdf:Property ;
    rdfs:label 'Environment' ;
    rdfs:comment 'Deployment environment classification. Supports environment-based cost tracking and CI/CD pipeline resource segregation.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpuCount rdf:type rdf:Property ;
    rdfs:label 'Gpu Count' ;
    rdfs:comment 'Number of GPU units allocated for game streaming, rendering, or AI/ML workloads. Nullable for non-GPU instances.' ;
    rdfs:domain ind:CloudResource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gpuModel rdf:type rdf:Property ;
    rdfs:label 'Gpu Model' ;
    rdfs:comment 'GPU hardware model (e.g., NVIDIA T4, V100, A100). Relevant for game streaming services and AI-powered game features. Nullable for non-GPU instances.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instanceFamily rdf:type rdf:Property ;
    rdfs:label 'Instance Family' ;
    rdfs:comment 'Cloud provider instance family classification (e.g., AWS t3, m5, c5, r5, g4; Azure D-series, F-series; GCP n1, n2, c2). Indicates compute, memory, or GPU optimization profile.' ;
    rdfs:domain ind:CloudResource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instanceSize rdf:type rdf:Property ;
    rdfs:label 'Instance Size' ;
    rdfs:comment 'Specific size or tier within the instance family (e.g., large, xlarge, 2xlarge). Determines compute capacity and cost rate.' ;
    rdfs:domain ind:CloudResource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleState rdf:type rdf:Property ;
    rdfs:label 'Lifecycle State' ;
    rdfs:comment 'Business lifecycle state indicating whether the resource is actively used, reserved for future use, or scheduled for decommissioning. Supports asset retirement planning and cost optimization.' ;
    rdfs:domain ind:CloudResource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memoryGb rdf:type rdf:Property ;
    rdfs:label 'Memory Gb' ;
    rdfs:comment 'Amount of RAM allocated to the resource in gigabytes. Critical for game server performance tuning and memory-intensive workload planning.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringEnabled rdf:type rdf:Property ;
    rdfs:label 'Monitoring Enabled' ;
    rdfs:comment 'Indicates whether performance and health monitoring is active for this resource. Supports proactive incident management and SLA compliance tracking.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monthlyCostRate rdf:type rdf:Property ;
    rdfs:label 'Monthly Cost Rate' ;
    rdfs:comment 'Projected monthly cost for this resource based on provisioning tier and instance size. Used for budget forecasting and FinOps cost governance.' ;
    rdfs:domain ind:CloudResource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkBandwidthGbps rdf:type rdf:Property ;
    rdfs:label 'Network Bandwidth Gbps' ;
    rdfs:comment 'Network throughput capacity in gigabits per second. Critical for CDN performance, multiplayer latency optimization, and live streaming quality.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:provisionedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Provisioned Timestamp' ;
    rdfs:comment 'Date and time when the resource was initially provisioned. Supports resource age analysis and lifecycle tracking.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:provisioningStatus rdf:type rdf:Property ;
    rdfs:label 'Provisioning Status' ;
    rdfs:comment 'Current operational state of the cloud resource in its provisioning lifecycle. Tracks resource availability for capacity planning and incident management.' ;
    rdfs:domain ind:CloudResource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisioningTier rdf:type rdf:Property ;
    rdfs:label 'Provisioning Tier' ;
    rdfs:comment 'Pricing and commitment model for the resource (on-demand, reserved instance, spot/preemptible for cost optimization). Critical for FinOps cost governance and budget forecasting.' ;
    rdfs:domain ind:CloudResource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservedUntilDate rdf:type rdf:Property ;
    rdfs:label 'Reserved Until Date' ;
    rdfs:comment 'Expiration date of reserved instance commitment. Nullable for on-demand and spot instances. Supports reservation renewal planning and cost optimization.' ;
    rdfs:domain ind:CloudResource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resourceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Resource Identifier' ;
    rdfs:comment 'Cloud provider-assigned unique identifier for the resource (e.g., AWS instance ID, Azure resource ID, GCP resource name). Used for cross-platform reconciliation and API operations.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceName rdf:type rdf:Property ;
    rdfs:label 'Resource Name' ;
    rdfs:comment 'Human-readable name assigned to the cloud resource for identification and operational management.' ;
    rdfs:domain ind:CloudResource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceType rdf:type rdf:Property ;
    rdfs:label 'Resource Type' ;
    rdfs:comment 'Category of cloud resource provisioned (virtual machine, container cluster, managed database, load balancer, GPU instance for game streaming, etc.). Enables resource type-based capacity planning and cost allocation. [ENUM-REF-CANDIDATE: VM|Container Cluster|Managed Database|Load Balancer|GPU Instance|Storage|CDN|Network|Serverless — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceName rdf:type rdf:Property ;
    rdfs:label 'Service Name' ;
    rdfs:comment 'Name of the live service, game title, or platform component this resource supports (e.g., matchmaking service, game server, CDN edge, analytics pipeline). Enables service-level cost attribution.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageGb rdf:type rdf:Property ;
    rdfs:label 'Storage Gb' ;
    rdfs:comment 'Allocated storage capacity in gigabytes. Tracks disk space for game assets, player data, logs, and backups.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tagsJson rdf:type rdf:Property ;
    rdfs:label 'Tags Json' ;
    rdfs:comment 'JSON-encoded key-value pairs of cloud provider tags applied to the resource for cost allocation, automation, and governance (e.g., {"game_title":"title_a","environment":"prod","team":"backend"}). Supports flexible tagging strategies and custom metadata.' ;
    rdfs:domain ind:CloudResource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Termination Timestamp' ;
    rdfs:comment 'Date and time when the resource was terminated or decommissioned. Nullable for active resources. Supports cost analysis and resource churn tracking.' ;
    rdfs:domain ind:CloudResource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:uptimeSlaPercent rdf:type rdf:Property ;
    rdfs:label 'Uptime Sla Percent' ;
    rdfs:comment 'Target uptime service level agreement percentage for this resource (e.g., 99.9, 99.99). Critical for live service reliability commitments and player experience quality.' ;
    rdfs:domain ind:CloudResource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:antiCheatVersion rdf:type rdf:Property ;
    rdfs:label 'Anti Cheat Version' ;
    rdfs:comment 'Version identifier of the anti-cheat software or service integrated with this server instance. Critical for maintaining competitive integrity in PvP and esports environments.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoScalingGroup rdf:type rdf:Property ;
    rdfs:label 'Auto Scaling Group' ;
    rdfs:comment 'Identifier for the auto-scaling group or fleet management pool this server belongs to. Supports dynamic capacity provisioning based on CCU/PCU demand patterns.' ;
    rdfs:domain ind:GameServer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityTier rdf:type rdf:Property ;
    rdfs:label 'Capacity Tier' ;
    rdfs:comment 'Business classification of server capacity tier based on expected player load and performance requirements. Used for CCU/PCU capacity planning and fleet provisioning decisions.' ;
    rdfs:domain ind:GameServer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerHour rdf:type rdf:Property ;
    rdfs:label 'Cost Per Hour' ;
    rdfs:comment 'Hourly infrastructure cost for running this server instance based on cloud provider pricing and instance type. Used for cost allocation, budgeting, and Return on Investment (ROI) analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpuUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'Cpu Utilization Pct' ;
    rdfs:comment 'Current CPU utilization percentage for the server instance. Monitoring metric for capacity planning, auto-scaling decisions, and performance optimization.' ;
    rdfs:domain ind:GameServer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentPlayerCount rdf:type rdf:Property ;
    rdfs:label 'Current Player Count' ;
    rdfs:comment 'Current number of active players connected to this server instance. Real-time metric for load monitoring, matchmaking decisions, and capacity utilization analytics.' ;
    rdfs:domain ind:GameServer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gameBuildVersion rdf:type rdf:Property ;
    rdfs:label 'Game Build Version' ;
    rdfs:comment 'Version identifier of the game server build deployed on this instance. Tracks which game code version is running for compatibility, Quality Assurance (QA), and rollback purposes.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Health Check Status' ;
    rdfs:comment 'Result of the most recent health check. Healthy indicates all systems operational; degraded indicates partial functionality; unhealthy indicates failure requiring intervention; unknown indicates monitoring gap.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentCount rdf:type rdf:Property ;
    rdfs:label 'Incident Count' ;
    rdfs:comment 'Cumulative count of incidents or failures recorded for this server instance since provisioning. Tracks reliability and identifies problematic instances for replacement.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastHealthCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Health Check Timestamp' ;
    rdfs:comment 'Timestamp of the most recent health check performed on this server instance. Used for monitoring service alerting and incident detection.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxPlayerCapacity rdf:type rdf:Property ;
    rdfs:label 'Max Player Capacity' ;
    rdfs:comment 'Maximum number of concurrent players this server instance can support based on its capacity tier and instance type. Critical for matchmaking service load balancing and CCU/PCU monitoring.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:memoryUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'Memory Utilization Pct' ;
    rdfs:comment 'Current memory utilization percentage for the server instance. Critical for identifying memory leaks, capacity constraints, and optimization opportunities.' ;
    rdfs:domain ind:GameServer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkBandwidthMbps rdf:type rdf:Property ;
    rdfs:label 'Network Bandwidth Mbps' ;
    rdfs:comment 'Current network bandwidth utilization in megabits per second. Monitors network capacity consumption for CDN topology optimization and cost management.' ;
    rdfs:domain ind:GameServer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:osImageVersion rdf:type rdf:Property ;
    rdfs:label 'Os Image Version' ;
    rdfs:comment 'Version identifier of the operating system image deployed on this server instance. Critical for patch management, security compliance, and DevOps CI/CD pipeline tracking.' ;
    rdfs:domain ind:GameServer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portNumber rdf:type rdf:Property ;
    rdfs:label 'Port Number' ;
    rdfs:comment 'Network port number on which the game server instance listens for player connections. Part of the server endpoint configuration for matchmaking and connectivity.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serverCode rdf:type rdf:Property ;
    rdfs:label 'Server Code' ;
    rdfs:comment 'Externally-known unique code or identifier for the game server instance used in operational systems, monitoring dashboards, and DevOps Continuous Integration/Continuous Deployment (CI/CD) pipelines.' ;
    rdfs:domain ind:GameServer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serverName rdf:type rdf:Property ;
    rdfs:label 'Server Name' ;
    rdfs:comment 'Human-readable name or label assigned to the game server instance for operational identification and monitoring purposes.' ;
    rdfs:domain ind:GameServer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serverStatus rdf:type rdf:Property ;
    rdfs:label 'Server Status' ;
    rdfs:comment 'Current operational state of the game server instance in its lifecycle. Running indicates active service; draining indicates graceful shutdown in progress; terminated indicates decommissioned; provisioning indicates startup in progress; maintenance indicates scheduled downtime; failed indicates error state requiring intervention.' ;
    rdfs:domain ind:GameServer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serverType rdf:type rdf:Property ;
    rdfs:label 'Server Type' ;
    rdfs:comment 'Classification of server architecture type. Dedicated servers are fully managed by the platform; listen servers are player-hosted with platform oversight; peer-to-peer supports direct player connections; hybrid combines approaches.' ;
    rdfs:domain ind:GameServer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Started Timestamp' ;
    rdfs:comment 'Timestamp when the server instance last transitioned to running status and began accepting player connections. Distinct from provisioning for restart scenarios.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tagsMetadata rdf:type rdf:Property ;
    rdfs:label 'Tags Metadata' ;
    rdfs:comment 'Free-form metadata tags applied to the server instance for operational categorization, cost allocation, and DevOps automation (e.g., environment=production, team=live_ops, project=season_5).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Terminated Timestamp' ;
    rdfs:comment 'Timestamp when the server instance was terminated or decommissioned from the fleet. Null for active servers; populated for historical fleet analysis.' ;
    rdfs:domain ind:GameServer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:uptimePercentage rdf:type rdf:Property ;
    rdfs:label 'Uptime Percentage' ;
    rdfs:comment 'Server uptime percentage over a defined measurement period. Critical SLA metric for GaaS live service delivery and operational excellence tracking.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:infrastructureDeploymentId rdf:type rdf:Property ;
    rdfs:label 'Infrastructure Deployment Id' ;
    rdfs:comment 'Unique identifier for the infrastructure deployment record. Primary key for the infrastructure deployment entity.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InfrastructureDeployment .

ind:changeRequestId rdf:type rdf:Property ;
    rdfs:label 'Change Request Id' ;
    rdfs:comment 'Foreign key linking to infrastructure.change_request. Business justification: infrastructure_deployment currently has change_ticket_reference (STRING) but no proper FK to change_request. Deployments must be authorized through change management processes. Adding change_request_i' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChangeRequest .

ind:primaryInfrastructureEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Infrastructure Employee Id' ;
    rdfs:comment 'Reference to the engineer or automated system that triggered this deployment. Used for accountability and audit trail.' ;
    rdfs:domain ind:InfrastructureDeployment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualDowntimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Downtime Minutes' ;
    rdfs:comment 'Actual duration in minutes that game services were unavailable during deployment. Zero for zero-downtime deployments. Used for SLA tracking and player impact analysis.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:artifactRepositoryUrl rdf:type rdf:Property ;
    rdfs:label 'Artifact Repository Url' ;
    rdfs:comment 'URL to the deployment artifact in the artifact repository (e.g., Docker registry, S3 bucket, Artifactory). Used for traceability and rollback operations.' ;
    rdfs:domain ind:InfrastructureDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automatedDeploymentFlag rdf:type rdf:Property ;
    rdfs:label 'Automated Deployment Flag' ;
    rdfs:comment 'Indicates whether this deployment was fully automated or required manual intervention. True for fully automated; false for manual or semi-automated deployments.' ;
    rdfs:domain ind:InfrastructureDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:buildVersion rdf:type rdf:Property ;
    rdfs:label 'Build Version' ;
    rdfs:comment 'Semantic version number of the game build being deployed. Follows semantic versioning convention (major.minor.patch.build).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:canaryPercentage rdf:type rdf:Property ;
    rdfs:label 'Canary Percentage' ;
    rdfs:comment 'Percentage of traffic or server instances receiving the canary deployment. Null for non-canary deployments. Range 0.00 to 100.00.' ;
    rdfs:domain ind:InfrastructureDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Total elapsed time in minutes from deployment start to completion. Used for performance tracking and capacity planning.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousBuildVersion rdf:type rdf:Property ;
    rdfs:label 'Previous Build Version' ;
    rdfs:comment 'Version number of the build that was running before this deployment. Used for rollback operations and version history tracking.' ;
    rdfs:domain ind:InfrastructureDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rollbackEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Rollback Eligible Flag' ;
    rdfs:comment 'Indicates whether this deployment can be automatically rolled back to the previous version. True if rollback is supported; false if manual intervention is required.' ;
    rdfs:domain ind:InfrastructureDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serverCount rdf:type rdf:Property ;
    rdfs:label 'Server Count' ;
    rdfs:comment 'Number of server instances included in this deployment. Used for capacity tracking and deployment scope analysis.' ;
    rdfs:domain ind:InfrastructureDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:strategy rdf:type rdf:Property ;
    rdfs:label 'Strategy' ;
    rdfs:comment 'Technical strategy used to roll out the deployment. Blue-green switches traffic between two identical environments; canary gradually increases traffic to new version; rolling updates instances incrementally; recreate terminates old version before starting new; all-at-once updates all instances simultaneously.' ;
    rdfs:domain ind:InfrastructureDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:infrastructureIncidentId rdf:type rdf:Property ;
    rdfs:label 'Infrastructure Incident Id' ;
    rdfs:comment 'Unique identifier for the infrastructure incident record. Primary key for incident tracking and post-mortem analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InfrastructureIncident .

ind:acknowledgmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Timestamp' ;
    rdfs:comment 'Timestamp when the incident was acknowledged by the on-call engineer or incident response team. Measures time-to-acknowledge SLA.' ;
    rdfs:domain ind:InfrastructureIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualResolutionMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Resolution Minutes' ;
    rdfs:comment 'Actual time in minutes from detection to resolution. Compared against SLA target for performance measurement.' ;
    rdfs:domain ind:InfrastructureIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedServiceComponent rdf:type rdf:Property ;
    rdfs:label 'Affected Service Component' ;
    rdfs:comment 'Primary infrastructure component or service experiencing the incident (e.g., matchmaking service, game server fleet, CDN edge nodes, authentication API, player data store).' ;
    rdfs:domain ind:InfrastructureIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccuAffectedCount rdf:type rdf:Property ;
    rdfs:label 'Ccu Affected Count' ;
    rdfs:comment 'Estimated number of concurrent users impacted by the incident at peak. Critical metric for SLA breach assessment and business impact quantification.' ;
    rdfs:domain ind:InfrastructureIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closure Timestamp' ;
    rdfs:comment 'Timestamp when the incident record was formally closed after post-mortem review and documentation completion.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:communicationChannel rdf:type rdf:Property ;
    rdfs:label 'Communication Channel' ;
    rdfs:comment 'Primary communication channel used for incident coordination (e.g., Slack war room, PagerDuty, Zoom bridge, Jira ticket).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedBySource rdf:type rdf:Property ;
    rdfs:label 'Detected By Source' ;
    rdfs:comment 'Origin of the incident detection. Tracks effectiveness of monitoring systems versus reactive player reports.' ;
    rdfs:domain ind:InfrastructureIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedRevenueImpactUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Revenue Impact Usd' ;
    rdfs:comment 'Estimated revenue loss in USD due to the incident, calculated from CCU affected, average ARPU, and outage duration. Used for business impact assessment.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalCommunicationFlag rdf:type rdf:Property ;
    rdfs:label 'External Communication Flag' ;
    rdfs:comment 'Indicates whether the incident required public status page updates or player-facing communication. True if external communication was issued.' ;
    rdfs:domain ind:InfrastructureIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mitigationActionSummary rdf:type rdf:Property ;
    rdfs:label 'Mitigation Action Summary' ;
    rdfs:comment 'Brief summary of the immediate actions taken to mitigate the incident (e.g., failover to backup region, service restart, traffic throttling).' ;
    rdfs:domain ind:InfrastructureIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringAlertId rdf:type rdf:Property ;
    rdfs:label 'Monitoring Alert Id' ;
    rdfs:comment 'Identifier of the monitoring system alert that triggered incident detection. Links to observability platform for detailed metrics.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playerFacingImpactDescription rdf:type rdf:Property ;
    rdfs:label 'Player Facing Impact Description' ;
    rdfs:comment 'Business-friendly description of how the incident affects player experience (e.g., unable to join matches, login failures, high latency, store unavailable). Used for status page communication.' ;
    rdfs:domain ind:InfrastructureIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postMortemReference rdf:type rdf:Property ;
    rdfs:label 'Post Mortem Reference' ;
    rdfs:comment 'URL or document identifier linking to the full post-mortem report with detailed timeline, root cause analysis, and action items.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveActionItems rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Items' ;
    rdfs:comment 'List of follow-up action items identified to prevent recurrence (e.g., add monitoring, update runbook, increase capacity, patch software).' ;
    rdfs:domain ind:InfrastructureIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedIncidentIds rdf:type rdf:Property ;
    rdfs:label 'Related Incident Ids' ;
    rdfs:comment 'Comma-separated list of related or duplicate incident IDs that share the same root cause or are part of a cascading failure.' ;
    rdfs:domain ind:InfrastructureIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'High-level classification of the underlying cause of the incident. Used for trend analysis and preventive action planning. [ENUM-REF-CANDIDATE: infrastructure_failure|software_bug|configuration_error|capacity_overload|network_issue|third_party_dependency|human_error|security_incident|unknown — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed technical explanation of the root cause identified during post-incident analysis. Supports knowledge base and runbook updates.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceWindowId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Window Id' ;
    rdfs:comment 'Unique identifier for the planned maintenance window record. Primary key.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryMaintenanceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Maintenance Employee Id' ;
    rdfs:comment 'Identifier of the DevOps or infrastructure engineer who approved and authorized the maintenance window.' ;
    rdfs:domain ind:MaintenanceWindow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedComponentReference rdf:type rdf:Property ;
    rdfs:label 'Affected Component Reference' ;
    rdfs:comment 'Identifier or name of the specific infrastructure component(s) being maintained (e.g., server pool ID, CDN region code, database cluster name). May reference multiple components as comma-separated list.' ;
    rdfs:domain ind:MaintenanceWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedComponentType rdf:type rdf:Property ;
    rdfs:label 'Affected Component Type' ;
    rdfs:comment 'Type of infrastructure component being maintained: game_server (live game instances), matchmaking_service (player pairing systems), cdn_node (content delivery network edge), database_cluster (data persistence layer), api_gateway (API routing layer), authentication_service (player login systems).' ;
    rdfs:domain ind:MaintenanceWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedGameTitleIds rdf:type rdf:Property ;
    rdfs:label 'Affected Game Title Ids' ;
    rdfs:comment 'Comma-separated list of game title identifiers impacted by this maintenance window. Used to target player notifications to affected game communities.' ;
    rdfs:domain ind:MaintenanceWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCcuImpact rdf:type rdf:Property ;
    rdfs:label 'Estimated Ccu Impact' ;
    rdfs:comment 'Estimated number of concurrent users (CCU) who will be affected during the maintenance window. Used for capacity planning and player communication prioritization.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenanceDescription rdf:type rdf:Property ;
    rdfs:label 'Maintenance Description' ;
    rdfs:comment 'Detailed technical description of the maintenance activities being performed, including specific patches, upgrades, or configuration changes.' ;
    rdfs:domain ind:MaintenanceWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceWindowStatus rdf:type rdf:Property ;
    rdfs:label 'Maintenance Window Status' ;
    rdfs:comment 'Current lifecycle state of the maintenance window: scheduled (approved and planned), in_progress (actively executing), completed (successfully finished), cancelled (aborted before start), failed (execution encountered errors), rolled_back (changes reverted).' ;
    rdfs:domain ind:MaintenanceWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerFacingMessage rdf:type rdf:Property ;
    rdfs:label 'Player Facing Message' ;
    rdfs:comment 'Non-technical message communicated to players about the maintenance window, explaining impact and expected duration in player-friendly language.' ;
    rdfs:domain ind:MaintenanceWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postMaintenanceValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Post Maintenance Validation Status' ;
    rdfs:comment 'Status of post-maintenance testing and validation: not_started (validation pending), in_progress (tests running), passed (all checks successful), failed (issues detected), skipped (validation not performed).' ;
    rdfs:domain ind:MaintenanceWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rollbackPlanAvailable rdf:type rdf:Property ;
    rdfs:label 'Rollback Plan Available' ;
    rdfs:comment 'Indicates whether a tested rollback plan exists (True) to revert changes if maintenance fails. Required for high-impact maintenance windows.' ;
    rdfs:domain ind:MaintenanceWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Timestamp' ;
    rdfs:comment 'Planned date and time when the maintenance window is scheduled to conclude. Used for SLA exclusion calculations and player communication.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaExclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Exclusion Flag' ;
    rdfs:comment 'Indicates whether this maintenance window should be excluded from uptime SLA calculations (True) or counted as downtime (False). Planned maintenance is typically excluded.' ;
    rdfs:domain ind:MaintenanceWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:windowCode rdf:type rdf:Property ;
    rdfs:label 'Window Code' ;
    rdfs:comment 'Externally-known unique code for the maintenance window, used in player communications and SLA tracking (e.g., \'MW-20240315001\').' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowName rdf:type rdf:Property ;
    rdfs:label 'Window Name' ;
    rdfs:comment 'Human-readable name or title for the maintenance window (e.g., \'Q1 2024 Platform Upgrade\', \'Emergency CDN Patch\').' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchmakingServiceId rdf:type rdf:Property ;
    rdfs:label 'Matchmaking Service Id' ;
    rdfs:comment 'Foreign key linking to infrastructure.matchmaking_service. Business justification: matchmaking_pool currently has matchmaking_service_endpoint (STRING) but no FK to the matchmaking_service product. Pools are served by matchmaking services and should reference the service definition.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MatchmakingService .

ind:acceptableLatencyThresholdMs rdf:type rdf:Property ;
    rdfs:label 'Acceptable Latency Threshold Ms' ;
    rdfs:comment 'Maximum acceptable network latency in milliseconds for players to be matched into this pool. Critical for player experience in real-time multiplayer.' ;
    rdfs:domain ind:MatchmakingPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activeFromTimestamp rdf:type rdf:Property ;
    rdfs:label 'Active From Timestamp' ;
    rdfs:comment 'Timestamp when this matchmaking pool configuration became active and available for player queuing.' ;
    rdfs:domain ind:MatchmakingPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:activeUntilTimestamp rdf:type rdf:Property ;
    rdfs:label 'Active Until Timestamp' ;
    rdfs:comment 'Timestamp when this matchmaking pool configuration is scheduled to be deactivated or deprecated. Null if indefinitely active.' ;
    rdfs:domain ind:MatchmakingPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:antiCheatEnforcementLevel rdf:type rdf:Property ;
    rdfs:label 'Anti Cheat Enforcement Level' ;
    rdfs:comment 'Level of anti-cheat enforcement applied to this pool: standard, strict (for ranked/competitive), tournament-grade, or disabled (for testing).' ;
    rdfs:domain ind:MatchmakingPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backfillEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Backfill Enabled Flag' ;
    rdfs:comment 'Indicates whether this pool supports backfilling players into in-progress matches when players leave.' ;
    rdfs:domain ind:MatchmakingPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ccuCapacityTarget rdf:type rdf:Property ;
    rdfs:label 'Ccu Capacity Target' ;
    rdfs:comment 'Target concurrent user capacity this pool is provisioned to support. Used for infrastructure capacity planning.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crossplayPolicy rdf:type rdf:Property ;
    rdfs:label 'Crossplay Policy' ;
    rdfs:comment 'Defines whether and how crossplay is supported: fully enabled, disabled, player opt-in, or restricted to specific platform combinations.' ;
    rdfs:domain ind:MatchmakingPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputMethodRestriction rdf:type rdf:Property ;
    rdfs:label 'Input Method Restriction' ;
    rdfs:comment 'Restriction or matching rule based on player input device: any input allowed, controller-only, keyboard/mouse-only, or input-based matching pools.' ;
    rdfs:domain ind:MatchmakingPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchTimeoutSeconds rdf:type rdf:Property ;
    rdfs:label 'Match Timeout Seconds' ;
    rdfs:comment 'Maximum duration in seconds for a match instance before automatic termination or forfeit rules apply.' ;
    rdfs:domain ind:MatchmakingPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:matchmakingAlgorithmType rdf:type rdf:Property ;
    rdfs:label 'Matchmaking Algorithm Type' ;
    rdfs:comment 'The primary algorithm used for player matching: skill-based matchmaking (SBMM), latency-based, hybrid (skill + latency), input-based (controller vs keyboard/mouse), or random.' ;
    rdfs:domain ind:MatchmakingPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxMatchSize rdf:type rdf:Property ;
    rdfs:label 'Max Match Size' ;
    rdfs:comment 'The maximum number of players allowed in a single match instance for this pool.' ;
    rdfs:domain ind:MatchmakingPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxQueueWaitTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Max Queue Wait Time Seconds' ;
    rdfs:comment 'Maximum time in seconds a player can wait in queue before matchmaking relaxes constraints or times out.' ;
    rdfs:domain ind:MatchmakingPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minMatchSize rdf:type rdf:Property ;
    rdfs:label 'Min Match Size' ;
    rdfs:comment 'The minimum number of players required to start a match if target size cannot be met within timeout.' ;
    rdfs:domain ind:MatchmakingPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mmrRangeMax rdf:type rdf:Property ;
    rdfs:label 'Mmr Range Max' ;
    rdfs:comment 'Maximum matchmaking rating (MMR) or Elo score allowed. Null if no upper MMR bound.' ;
    rdfs:domain ind:MatchmakingPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mmrRangeMin rdf:type rdf:Property ;
    rdfs:label 'Mmr Range Min' ;
    rdfs:comment 'Minimum matchmaking rating (MMR) or Elo score required for entry. Null if no MMR constraint.' ;
    rdfs:domain ind:MatchmakingPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partySizeMax rdf:type rdf:Property ;
    rdfs:label 'Party Size Max' ;
    rdfs:comment 'Maximum number of players in a party/group allowed to queue together. Null if no maximum.' ;
    rdfs:domain ind:MatchmakingPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partySizeMin rdf:type rdf:Property ;
    rdfs:label 'Party Size Min' ;
    rdfs:comment 'Minimum number of players in a party/group allowed to queue together. Null if no minimum.' ;
    rdfs:domain ind:MatchmakingPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pcuHistoricalPeak rdf:type rdf:Property ;
    rdfs:label 'Pcu Historical Peak' ;
    rdfs:comment 'Historical peak concurrent users observed in this pool. Used for capacity planning and SLA monitoring.' ;
    rdfs:domain ind:MatchmakingPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:platformRestriction rdf:type rdf:Property ;
    rdfs:label 'Platform Restriction' ;
    rdfs:comment 'Comma-separated list of platform codes this pool is restricted to (e.g., \'PS5,XBOX_SERIES_X,PC\'). Null if available on all platforms.' ;
    rdfs:domain ind:MatchmakingPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolCode rdf:type rdf:Property ;
    rdfs:label 'Pool Code' ;
    rdfs:comment 'Unique business identifier code for the pool used in system integrations and APIs.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolDescription rdf:type rdf:Property ;
    rdfs:label 'Pool Description' ;
    rdfs:comment 'Detailed business description of the matchmaking pool purpose, rules, and player experience expectations.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queuePriorityTier rdf:type rdf:Property ;
    rdfs:label 'Queue Priority Tier' ;
    rdfs:comment 'Priority ranking of this pool relative to others (1=highest priority). Used when players qualify for multiple pools.' ;
    rdfs:domain ind:MatchmakingPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rankTierMax rdf:type rdf:Property ;
    rdfs:label 'Rank Tier Max' ;
    rdfs:comment 'Maximum rank or tier allowed for players in this pool. Used to segment competitive tiers. Null if no upper bound.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rankTierMin rdf:type rdf:Property ;
    rdfs:label 'Rank Tier Min' ;
    rdfs:comment 'Minimum rank or tier required for players to enter this pool (e.g., \'Bronze\', \'Silver\', \'Gold\'). Null if no rank restriction.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionRestriction rdf:type rdf:Property ;
    rdfs:label 'Region Restriction' ;
    rdfs:comment 'Geographic region or data center locality constraint for this pool (e.g., \'NA-EAST\', \'EU-WEST\', \'APAC\'). Null if globally available.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalEventFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Event Flag' ;
    rdfs:comment 'Indicates whether this pool is associated with a limited-time seasonal or special event.' ;
    rdfs:domain ind:MatchmakingPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:skillVarianceTolerance rdf:type rdf:Property ;
    rdfs:label 'Skill Variance Tolerance' ;
    rdfs:comment 'Acceptable variance in skill rating (MMR/Elo) between matched players, expressed as a percentage or absolute value. Used to balance match quality vs. queue time.' ;
    rdfs:domain ind:MatchmakingPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaTargetMatchTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Sla Target Match Time Seconds' ;
    rdfs:comment 'Target time in seconds to form a match under normal conditions, as defined by the service level agreement.' ;
    rdfs:domain ind:MatchmakingPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetMatchSize rdf:type rdf:Property ;
    rdfs:label 'Target Match Size' ;
    rdfs:comment 'The target number of players required for a complete match in this pool (e.g., 2 for 1v1, 10 for 5v5).' ;
    rdfs:domain ind:MatchmakingPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:teamCompositionRule rdf:type rdf:Property ;
    rdfs:label 'Team Composition Rule' ;
    rdfs:comment 'Business rules defining how teams are formed (e.g., \'balanced_skill\', \'party_priority\', \'role_based\', \'free_for_all\'). Free-text to accommodate complex rule descriptions.' ;
    rdfs:domain ind:MatchmakingPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchmakingTicketId rdf:type rdf:Property ;
    rdfs:label 'Matchmaking Ticket Id' ;
    rdfs:comment 'Unique identifier for the matchmaking ticket. Primary key for this transactional record representing a single player\'s matchmaking request.' ;
    rdfs:domain ind:MatchmakingTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serverSessionId rdf:type rdf:Property ;
    rdfs:label 'Server Session Id' ;
    rdfs:comment 'Reference to the game server session that this ticket was matched to. Null if the ticket has not yet been matched, expired, or was cancelled.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServerSession .

ind:acceptableLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Acceptable Latency Ms' ;
    rdfs:comment 'Maximum acceptable network latency (in milliseconds) that the player is willing to tolerate for this match. Matchmaking will only assign servers within this latency threshold. Typical values: 50-150ms.' ;
    rdfs:domain ind:MatchmakingTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backfillEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Backfill Eligible Flag' ;
    rdfs:comment 'Indicates whether this ticket is eligible to backfill an in-progress match (True) or should only be matched to new sessions (False). Backfill reduces wait time but may place players into ongoing games.' ;
    rdfs:domain ind:MatchmakingTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossplayEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Crossplay Enabled Flag' ;
    rdfs:comment 'Indicates whether the player has opted into cross-platform play (True) or prefers platform-exclusive matchmaking (False). Affects matchmaking pool segmentation and server assignment.' ;
    rdfs:domain ind:MatchmakingTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedWaitTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Estimated Wait Time Seconds' ;
    rdfs:comment 'System-calculated estimated wait time (in seconds) provided to the player at ticket submission. Based on current queue depth, historical match times, and available server capacity. Used for player expectation management.' ;
    rdfs:domain ind:MatchmakingTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expiredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expired Timestamp' ;
    rdfs:comment 'The exact date and time when the ticket expired due to exceeding maximum wait time threshold. Null if ticket was matched or cancelled before expiration. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:MatchmakingTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inputMethod rdf:type rdf:Property ;
    rdfs:label 'Input Method' ;
    rdfs:comment 'The primary input method used by the player (keyboard_mouse, gamepad, touch, motion). Some games segregate matchmaking pools by input method to ensure competitive fairness (e.g., FPS games).' ;
    rdfs:domain ind:MatchmakingTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchQualityScore rdf:type rdf:Property ;
    rdfs:label 'Match Quality Score' ;
    rdfs:comment 'Algorithmic score (0-100) representing the quality of the match assignment based on skill balance, latency, party composition, and other factors. Higher scores indicate better matches. Null if ticket was not matched. Used for matchmaking algorithm tuning.' ;
    rdfs:domain ind:MatchmakingTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Matched Timestamp' ;
    rdfs:comment 'The exact date and time when the ticket was successfully matched to a server session. Null if not yet matched, expired, or cancelled. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:MatchmakingTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:matchmakingAlgorithmVersion rdf:type rdf:Property ;
    rdfs:label 'Matchmaking Algorithm Version' ;
    rdfs:comment 'Version identifier of the matchmaking algorithm or ruleset that processed this ticket (e.g., v2.1, skill_based_v3). Used for A/B testing, algorithm performance analysis, and rollback capability.' ;
    rdfs:domain ind:MatchmakingTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchmakingPriority rdf:type rdf:Property ;
    rdfs:label 'Matchmaking Priority' ;
    rdfs:comment 'Priority tier for this matchmaking request. Standard: normal queue; Premium: subscriber/paid priority; VIP: high-value player fast-track; Developer: internal testing priority. Affects queue position and wait time.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyLeaderFlag rdf:type rdf:Property ;
    rdfs:label 'Party Leader Flag' ;
    rdfs:comment 'Indicates whether the player who submitted this ticket is the party leader (True) or a party member (False). Only the party leader\'s ticket represents the entire party\'s matchmaking request.' ;
    rdfs:domain ind:MatchmakingTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partySize rdf:type rdf:Property ;
    rdfs:label 'Party Size' ;
    rdfs:comment 'Number of players in the party or group that submitted this matchmaking request together. 1 indicates solo queue; values >1 indicate group/party matchmaking. Affects matchmaking pool and balancing logic.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:queuePosition rdf:type rdf:Property ;
    rdfs:label 'Queue Position' ;
    rdfs:comment 'The player\'s position in the matchmaking queue at the time of ticket submission or last update. Lower numbers indicate higher priority. Null if position tracking is not enabled or ticket is no longer queued.' ;
    rdfs:domain ind:MatchmakingTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:skillRangeMax rdf:type rdf:Property ;
    rdfs:label 'Skill Range Max' ;
    rdfs:comment 'Maximum skill rating threshold for acceptable match opponents. Matchmaking will expand this range over time if no suitable match is found. Used to balance match quality vs. wait time.' ;
    rdfs:domain ind:MatchmakingTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:skillRangeMin rdf:type rdf:Property ;
    rdfs:label 'Skill Range Min' ;
    rdfs:comment 'Minimum skill rating threshold for acceptable match opponents. Matchmaking will expand this range over time if no suitable match is found. Used to balance match quality vs. wait time.' ;
    rdfs:domain ind:MatchmakingTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:skillRating rdf:type rdf:Property ;
    rdfs:label 'Skill Rating' ;
    rdfs:comment 'The player\'s skill rating (MMR, ELO, or similar ranking metric) at the time of ticket submission. Used by matchmaking algorithm to find balanced matches. Captured as snapshot to ensure consistent matching even if player rating changes during queue.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketNumber rdf:type rdf:Property ;
    rdfs:label 'Ticket Number' ;
    rdfs:comment 'Human-readable business identifier for the matchmaking ticket. Used for player support, debugging, and operational tracking. Format: MMT-<alphanumeric>.' ;
    rdfs:domain ind:MatchmakingTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voiceChatEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Voice Chat Enabled Flag' ;
    rdfs:comment 'Indicates whether the player has voice chat enabled (True) or disabled (False) for this matchmaking session. May influence team composition in team-based games.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waitDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Wait Duration Seconds' ;
    rdfs:comment 'Total time (in seconds) that the player waited in the matchmaking queue from submission to match, expiration, or cancellation. Key metric for matchmaking quality and player experience (FTUE). Null if ticket is still queued.' ;
    rdfs:domain ind:MatchmakingTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:networkPerformanceEventId rdf:type rdf:Property ;
    rdfs:label 'Network Performance Event Id' ;
    rdfs:comment 'Unique identifier for the network performance event record. Primary key for this transactional event log.' ;
    rdfs:domain ind:NetworkPerformanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alertTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Alert Triggered Flag' ;
    rdfs:comment 'Boolean indicator whether this measurement triggered an automated alert in the monitoring system. True indicates threshold breach requiring operational attention.' ;
    rdfs:domain ind:NetworkPerformanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:availabilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Availability Percentage' ;
    rdfs:comment 'Calculated availability percentage for the measurement period. Expressed as a percentage (0.00 to 100.00). Used for SLA compliance tracking and uptime reporting.' ;
    rdfs:domain ind:NetworkPerformanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachSeverity rdf:type rdf:Property ;
    rdfs:label 'Breach Severity' ;
    rdfs:comment 'Severity classification of the SLA breach if one occurred. Critical breaches require immediate escalation and incident management response.' ;
    rdfs:domain ind:NetworkPerformanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccuCount rdf:type rdf:Property ;
    rdfs:label 'Ccu Count' ;
    rdfs:comment 'Number of concurrent users connected to this component at the time of measurement. Used for capacity planning and correlating performance degradation with load.' ;
    rdfs:domain ind:NetworkPerformanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:componentType rdf:type rdf:Property ;
    rdfs:label 'Component Type' ;
    rdfs:comment 'Type of infrastructure component being monitored. Discriminator field indicating which resource reference is populated and what kind of performance data is being captured.' ;
    rdfs:domain ind:NetworkPerformanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpuUtilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Cpu Utilization Percentage' ;
    rdfs:comment 'CPU utilization percentage for the monitored component during the measurement period. Expressed as a percentage (0.00 to 100.00). Used for capacity planning and performance correlation.' ;
    rdfs:domain ind:NetworkPerformanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downtimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Downtime Seconds' ;
    rdfs:comment 'Total seconds the component was unavailable or non-operational during the measurement period. Used to calculate availability percentage and track service disruptions.' ;
    rdfs:domain ind:NetworkPerformanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:errorCount rdf:type rdf:Property ;
    rdfs:label 'Error Count' ;
    rdfs:comment 'Number of errors or exceptions encountered during the measurement period. Used to correlate performance degradation with application-level errors and stability issues.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fpsImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Fps Impact Flag' ;
    rdfs:comment 'Boolean indicator whether this performance measurement had a measurable negative impact on client-side FPS. True indicates degraded rendering performance due to network issues.' ;
    rdfs:domain ind:NetworkPerformanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:httpStatusCode rdf:type rdf:Property ;
    rdfs:label 'Http Status Code' ;
    rdfs:comment 'HTTP response status code for API gateway and web service measurements. Standard HTTP status codes (200, 404, 500, etc.) indicating request success or failure type.' ;
    rdfs:domain ind:NetworkPerformanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:jitterMs rdf:type rdf:Property ;
    rdfs:label 'Jitter Ms' ;
    rdfs:comment 'Variation in packet arrival times measured in milliseconds. High jitter causes inconsistent gameplay experience and affects real-time multiplayer synchronization.' ;
    rdfs:domain ind:NetworkPerformanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:latencyMs rdf:type rdf:Property ;
    rdfs:label 'Latency Ms' ;
    rdfs:comment 'Round-trip network latency measured in milliseconds. Critical metric for real-time multiplayer game quality (PvP/PvE/MMO). Lower values indicate better player experience.' ;
    rdfs:domain ind:NetworkPerformanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementMethod rdf:type rdf:Property ;
    rdfs:label 'Measurement Method' ;
    rdfs:comment 'Method used to capture this performance measurement. Distinguishes between continuous real-time monitoring, scheduled periodic checks, and event-driven measurements.' ;
    rdfs:domain ind:NetworkPerformanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Measurement Window End' ;
    rdfs:comment 'End of the time window for aggregated performance metrics. Used when the event represents a periodic summary rather than a point-in-time snapshot. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:NetworkPerformanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:measurementWindowStart rdf:type rdf:Property ;
    rdfs:label 'Measurement Window Start' ;
    rdfs:comment 'Start of the time window for aggregated performance metrics. Used when the event represents a periodic summary rather than a point-in-time snapshot. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:NetworkPerformanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:memoryUtilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Memory Utilization Percentage' ;
    rdfs:comment 'Memory utilization percentage for the monitored component during the measurement period. Expressed as a percentage (0.00 to 100.00). Used for capacity planning and performance correlation.' ;
    rdfs:domain ind:NetworkPerformanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringSource rdf:type rdf:Property ;
    rdfs:label 'Monitoring Source' ;
    rdfs:comment 'Type of monitoring tool or method that captured this performance measurement. Indicates the observability instrumentation source and data collection methodology.' ;
    rdfs:domain ind:NetworkPerformanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packetLossPercentage rdf:type rdf:Property ;
    rdfs:label 'Packet Loss Percentage' ;
    rdfs:comment 'Percentage of network packets lost during transmission. Expressed as a percentage (0.00 to 100.00). High packet loss degrades gameplay quality and player experience.' ;
    rdfs:domain ind:NetworkPerformanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseTimeMs rdf:type rdf:Property ;
    rdfs:label 'Response Time Ms' ;
    rdfs:comment 'API or service response time measured in milliseconds. Distinct from network latency; measures application-layer processing time for request-response cycles.' ;
    rdfs:domain ind:NetworkPerformanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:throughputMbps rdf:type rdf:Property ;
    rdfs:label 'Throughput Mbps' ;
    rdfs:comment 'Data transfer rate measured in megabits per second (Mbps). Indicates bandwidth capacity and utilization for game data, asset streaming, and CDN delivery.' ;
    rdfs:domain ind:NetworkPerformanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uptimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Uptime Seconds' ;
    rdfs:comment 'Total seconds the component was operational and available during the measurement period. Used to calculate availability percentage and track service reliability.' ;
    rdfs:domain ind:NetworkPerformanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'Date when this network region was first activated and made available for live service traffic.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:availabilityZoneCount rdf:type rdf:Property ;
    rdfs:label 'Availability Zone Count' ;
    rdfs:comment 'Number of distinct availability zones within this region. Higher counts provide better fault tolerance and disaster recovery capabilities.' ;
    rdfs:domain ind:NetworkRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageLatencyToPeersMs rdf:type rdf:Property ;
    rdfs:label 'Average Latency To Peers Ms' ;
    rdfs:comment 'Average network latency in milliseconds from this region to all other active peer regions. Used for matchmaking routing and cross-region replication planning.' ;
    rdfs:domain ind:NetworkRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ccuCapacity rdf:type rdf:Property ;
    rdfs:label 'Ccu Capacity' ;
    rdfs:comment 'Maximum number of concurrent users this region is provisioned to support under normal operating conditions. Used for capacity governance and scaling decisions.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cdnProvider rdf:type rdf:Property ;
    rdfs:label 'Cdn Provider' ;
    rdfs:comment 'CDN provider integrated with this region for game asset delivery and patch distribution (e.g., Akamai, Cloudflare, Fastly).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cicdPipelineEndpoint rdf:type rdf:Property ;
    rdfs:label 'Cicd Pipeline Endpoint' ;
    rdfs:comment 'API endpoint URL for the CI/CD pipeline serving this region. Used for automated deployment and rollback operations.' ;
    rdfs:domain ind:NetworkRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertifications rdf:type rdf:Property ;
    rdfs:label 'Compliance Certifications' ;
    rdfs:comment 'Comma-separated list of compliance certifications held by this region (e.g., ISO 27001, SOC 2, PCI DSS). Used for regulatory reporting and vendor audits.' ;
    rdfs:domain ind:NetworkRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:continentCode rdf:type rdf:Property ;
    rdfs:label 'Continent Code' ;
    rdfs:comment 'Two-letter continent code for geographic classification (NA=North America, SA=South America, EU=Europe, AF=Africa, AS=Asia, OC=Oceania, AN=Antarctica). [ENUM-REF-CANDIDATE: NA|SA|EU|AF|AS|OC|AN — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:NetworkRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataResidencyJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Data Residency Jurisdiction' ;
    rdfs:comment 'Legal jurisdiction governing data residency and sovereignty requirements for player data stored in this region (e.g., EU GDPR, China Cybersecurity Law).' ;
    rdfs:domain ind:NetworkRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Date when this network region was deactivated or scheduled for decommissioning. Null if region is still active.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:displayName rdf:type rdf:Property ;
    rdfs:label 'Display Name' ;
    rdfs:comment 'Human-readable name for the network region used in dashboards and operational interfaces (e.g., US East Virginia, Europe West London).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failoverDatacenterLocation rdf:type rdf:Property ;
    rdfs:label 'Failover Datacenter Location' ;
    rdfs:comment 'Physical city or metro area where the failover/backup datacenter for this region is located. Null if no failover is configured.' ;
    rdfs:domain ind:NetworkRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentEscalationContact rdf:type rdf:Property ;
    rdfs:label 'Incident Escalation Contact' ;
    rdfs:comment 'Primary email address or contact identifier for incident escalation in this region. Used by DevOps and on-call teams.' ;
    rdfs:domain ind:NetworkRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxLatencyThresholdMs rdf:type rdf:Property ;
    rdfs:label 'Max Latency Threshold Ms' ;
    rdfs:comment 'Maximum acceptable player latency in milliseconds for this region. Players exceeding this threshold may be routed to alternate regions or flagged for quality monitoring.' ;
    rdfs:domain ind:NetworkRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monthlyOperatingCostUsd rdf:type rdf:Property ;
    rdfs:label 'Monthly Operating Cost Usd' ;
    rdfs:comment 'Estimated monthly operating cost in USD for running this network region, including compute, storage, bandwidth, and support costs. Used for ROI analysis and budget planning.' ;
    rdfs:domain ind:NetworkRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkBackboneProvider rdf:type rdf:Property ;
    rdfs:label 'Network Backbone Provider' ;
    rdfs:comment 'Primary network backbone or transit provider serving this region (e.g., Level3, Cogent, Telia, Akamai). Critical for latency and routing optimization.' ;
    rdfs:domain ind:NetworkRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkRegionStatus rdf:type rdf:Property ;
    rdfs:label 'Network Region Status' ;
    rdfs:comment 'Current operational status of the network region. Active regions accept new player connections; inactive regions are offline; maintenance regions are temporarily unavailable; deprecated regions are scheduled for decommissioning.' ;
    rdfs:domain ind:NetworkRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcuRecord rdf:type rdf:Property ;
    rdfs:label 'Pcu Record' ;
    rdfs:comment 'Historical peak concurrent users observed in this region. Used for capacity planning and infrastructure investment decisions.' ;
    rdfs:domain ind:NetworkRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pcuRecordTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pcu Record Timestamp' ;
    rdfs:comment 'Timestamp when the PCU record was achieved. Helps identify seasonal patterns and event-driven spikes.' ;
    rdfs:domain ind:NetworkRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:playerPopulationDensityTier rdf:type rdf:Property ;
    rdfs:label 'Player Population Density Tier' ;
    rdfs:comment 'Classification of expected player population density for capacity planning. Tier 1 = highest density (major markets), Tier 4 = lowest density (emerging markets).' ;
    rdfs:domain ind:NetworkRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDatacenterLocation rdf:type rdf:Property ;
    rdfs:label 'Primary Datacenter Location' ;
    rdfs:comment 'Physical city or metro area where the primary datacenter for this region is located. Used for capacity planning and disaster recovery.' ;
    rdfs:domain ind:NetworkRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportsMmo rdf:type rdf:Property ;
    rdfs:label 'Supports Mmo' ;
    rdfs:comment 'Indicates whether this region has the infrastructure capacity and configuration to support MMO game instances with large concurrent player counts.' ;
    rdfs:domain ind:NetworkRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsPve rdf:type rdf:Property ;
    rdfs:label 'Supports Pve' ;
    rdfs:comment 'Indicates whether this region is configured to host PvE game modes.' ;
    rdfs:domain ind:NetworkRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsPvp rdf:type rdf:Property ;
    rdfs:label 'Supports Pvp' ;
    rdfs:comment 'Indicates whether this region is configured to host PvP game modes. False if region is dedicated to PvE or other workloads.' ;
    rdfs:domain ind:NetworkRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetFps rdf:type rdf:Property ;
    rdfs:label 'Target Fps' ;
    rdfs:comment 'Target server-side FPS for game simulation in this region. Typically 60 or 120 for competitive games. Impacts compute resource allocation.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityEventId rdf:type rdf:Property ;
    rdfs:label 'Security Event Id' ;
    rdfs:comment 'Unique identifier for the infrastructure security event record. Primary key.' ;
    rdfs:domain ind:SecurityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attackVector rdf:type rdf:Property ;
    rdfs:label 'Attack Vector' ;
    rdfs:comment 'Technical description of the method or pathway used to execute the security threat (e.g., volumetric flood, application layer exploit, authentication bypass).' ;
    rdfs:domain ind:SecurityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automatedResponseEnabled rdf:type rdf:Property ;
    rdfs:label 'Automated Response Enabled' ;
    rdfs:comment 'Indicates whether automated mitigation actions were enabled and executed without manual intervention.' ;
    rdfs:domain ind:SecurityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ccuAffected rdf:type rdf:Property ;
    rdfs:label 'Ccu Affected' ;
    rdfs:comment 'Estimated number of concurrent users impacted by the security event through service degradation or unavailability.' ;
    rdfs:domain ind:SecurityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:communicationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Communication Sent Flag' ;
    rdfs:comment 'Indicates whether player-facing or stakeholder communication was sent regarding the security event and its impact.' ;
    rdfs:domain ind:SecurityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detectionSource rdf:type rdf:Property ;
    rdfs:label 'Detection Source' ;
    rdfs:comment 'Origin of the security event detection indicating whether it was identified by automated monitoring, manual observation, external security service, or player report.' ;
    rdfs:domain ind:SecurityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionSystem rdf:type rdf:Property ;
    rdfs:label 'Detection System' ;
    rdfs:comment 'Name or identifier of the monitoring system, tool, or service that detected the security event (e.g., CloudFlare, AWS Shield, internal SIEM, WAF).' ;
    rdfs:domain ind:SecurityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalatedFlag rdf:type rdf:Property ;
    rdfs:label 'Escalated Flag' ;
    rdfs:comment 'Indicates whether the security event was escalated to formal infrastructure incident management due to severity or impact.' ;
    rdfs:domain ind:SecurityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eventNumber rdf:type rdf:Property ;
    rdfs:label 'Event Number' ;
    rdfs:comment 'Human-readable unique identifier for the security event, used for tracking and communication. Format: SE-YYYYMMDD-XXXXXX.' ;
    rdfs:domain ind:SecurityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:falsePositiveFlag rdf:type rdf:Property ;
    rdfs:label 'False Positive Flag' ;
    rdfs:comment 'Indicates whether the security event was later determined to be a false positive after investigation.' ;
    rdfs:domain ind:SecurityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latencySpikeMs rdf:type rdf:Property ;
    rdfs:label 'Latency Spike Ms' ;
    rdfs:comment 'Maximum increase in network latency in milliseconds observed during the security event, indicating player experience degradation.' ;
    rdfs:domain ind:SecurityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mitigationAction rdf:type rdf:Property ;
    rdfs:label 'Mitigation Action' ;
    rdfs:comment 'Primary defensive action taken to mitigate the security threat.' ;
    rdfs:domain ind:SecurityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationDescription rdf:type rdf:Property ;
    rdfs:label 'Mitigation Description' ;
    rdfs:comment 'Detailed narrative of the mitigation steps taken, including configuration changes, rules applied, and response actions executed.' ;
    rdfs:domain ind:SecurityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Mitigation End Timestamp' ;
    rdfs:comment 'Date and time when mitigation actions were completed and the threat was neutralized. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:SecurityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mitigationStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Mitigation Start Timestamp' ;
    rdfs:comment 'Date and time when mitigation actions were initiated to counter the security threat. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:SecurityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:peakAttackVolumeGbps rdf:type rdf:Property ;
    rdfs:label 'Peak Attack Volume Gbps' ;
    rdfs:comment 'Maximum network traffic volume in gigabits per second observed during the attack, applicable to volumetric DDoS events.' ;
    rdfs:domain ind:SecurityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakAttackVolumeMpps rdf:type rdf:Property ;
    rdfs:label 'Peak Attack Volume Mpps' ;
    rdfs:comment 'Maximum packet rate in millions of packets per second observed during the attack, applicable to protocol-based DDoS events.' ;
    rdfs:domain ind:SecurityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:playerImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Player Impact Assessment' ;
    rdfs:comment 'Qualitative assessment of the impact on player experience and game service availability.' ;
    rdfs:domain ind:SecurityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationActionItems rdf:type rdf:Property ;
    rdfs:label 'Remediation Action Items' ;
    rdfs:comment 'List of follow-up actions, patches, or configuration changes required to prevent recurrence of similar security events.' ;
    rdfs:domain ind:SecurityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestCount rdf:type rdf:Property ;
    rdfs:label 'Request Count' ;
    rdfs:comment 'Total number of malicious or suspicious requests detected during the security event (e.g., login attempts, API calls, bot requests).' ;
    rdfs:domain ind:SecurityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceDowntimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Service Downtime Minutes' ;
    rdfs:comment 'Total duration in minutes that affected services were unavailable or degraded due to the security event.' ;
    rdfs:domain ind:SecurityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceCountryCode rdf:type rdf:Property ;
    rdfs:label 'Source Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the geographic origin of the attack based on IP geolocation.' ;
    rdfs:domain ind:SecurityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceIpAddress rdf:type rdf:Property ;
    rdfs:label 'Source Ip Address' ;
    rdfs:comment 'Originating IP address or CIDR block from which the security threat originated. May be single IP or range.' ;
    rdfs:domain ind:SecurityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetServiceComponent rdf:type rdf:Property ;
    rdfs:label 'Target Service Component' ;
    rdfs:comment 'Specific infrastructure service component or endpoint that was targeted by the security event (e.g., matchmaking API, game server cluster, CDN edge, authentication service).' ;
    rdfs:domain ind:SecurityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoscalingPolicyReference rdf:type rdf:Property ;
    rdfs:label 'Autoscaling Policy Reference' ;
    rdfs:comment 'Reference identifier or name of the autoscaling policy governing when and how this fleet scales up or down based on load metrics.' ;
    rdfs:domain ind:ServerFleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnTopologyReference rdf:type rdf:Property ;
    rdfs:label 'Cdn Topology Reference' ;
    rdfs:comment 'Reference to the CDN topology configuration used for content delivery to players connecting to this fleet.' ;
    rdfs:domain ind:ServerFleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentCcu rdf:type rdf:Property ;
    rdfs:label 'Current Ccu' ;
    rdfs:comment 'Current number of concurrent users actively connected to servers in this fleet at the time of measurement.' ;
    rdfs:domain ind:ServerFleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentInstanceCount rdf:type rdf:Property ;
    rdfs:label 'Current Instance Count' ;
    rdfs:comment 'Actual number of server instances currently running in the fleet at the time of measurement.' ;
    rdfs:domain ind:ServerFleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:decommissionedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decommissioned Timestamp' ;
    rdfs:comment 'Date and time when this fleet was decommissioned or retired from service. Null if the fleet is still active.' ;
    rdfs:domain ind:ServerFleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deploymentTier rdf:type rdf:Property ;
    rdfs:label 'Deployment Tier' ;
    rdfs:comment 'Deployment environment tier indicating the fleet\'s operational stage (production, staging, canary for gradual rollout, development, or QA).' ;
    rdfs:domain ind:ServerFleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetCode rdf:type rdf:Property ;
    rdfs:label 'Fleet Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the fleet across systems and monitoring tools.' ;
    rdfs:domain ind:ServerFleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetName rdf:type rdf:Property ;
    rdfs:label 'Fleet Name' ;
    rdfs:comment 'Human-readable name for the server fleet, typically including game title, region, and deployment tier (e.g., \'Apex-NA-Prod-PvP\').' ;
    rdfs:domain ind:ServerFleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetStatus rdf:type rdf:Property ;
    rdfs:label 'Fleet Status' ;
    rdfs:comment 'Current operational status of the server fleet. Active indicates normal operation, maintenance indicates scheduled downtime, degraded indicates partial capacity, failed indicates critical issues.' ;
    rdfs:domain ind:ServerFleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instanceType rdf:type rdf:Property ;
    rdfs:label 'Instance Type' ;
    rdfs:comment 'Cloud compute instance type or server specification (e.g., \'c5.xlarge\' for AWS, \'Standard_D4s_v3\' for Azure). Defines CPU, memory, and network capacity.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastIncidentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Incident Timestamp' ;
    rdfs:comment 'Date and time of the most recent operational incident affecting this fleet.' ;
    rdfs:domain ind:ServerFleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxInstanceCount rdf:type rdf:Property ;
    rdfs:label 'Max Instance Count' ;
    rdfs:comment 'Maximum number of server instances allowed for this fleet, serving as a cost control and capacity ceiling.' ;
    rdfs:domain ind:ServerFleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minInstanceCount rdf:type rdf:Property ;
    rdfs:label 'Min Instance Count' ;
    rdfs:comment 'Minimum number of server instances that must always be running to maintain service availability, even during low-traffic periods.' ;
    rdfs:domain ind:ServerFleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownerTeam rdf:type rdf:Property ;
    rdfs:label 'Owner Team' ;
    rdfs:comment 'Name of the engineering or operations team responsible for managing and maintaining this fleet.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcuWatermark rdf:type rdf:Property ;
    rdfs:label 'Pcu Watermark' ;
    rdfs:comment 'Highest number of concurrent users this fleet has served simultaneously, used for capacity planning and performance benchmarking.' ;
    rdfs:domain ind:ServerFleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pcuWatermarkTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pcu Watermark Timestamp' ;
    rdfs:comment 'Date and time when the PCU watermark was recorded.' ;
    rdfs:domain ind:ServerFleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:targetCapacity rdf:type rdf:Property ;
    rdfs:label 'Target Capacity' ;
    rdfs:comment 'Desired number of server instances the fleet should maintain under normal load conditions.' ;
    rdfs:domain ind:ServerFleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:antiCheatFlags rdf:type rdf:Property ;
    rdfs:label 'Anti Cheat Flags' ;
    rdfs:comment 'Comma-separated list of anti-cheat system flags or alerts triggered during the session.' ;
    rdfs:domain ind:ServerSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averagePlayerCount rdf:type rdf:Property ;
    rdfs:label 'Average Player Count' ;
    rdfs:comment 'Mean number of players connected throughout the session duration.' ;
    rdfs:domain ind:ServerSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpuUtilizationPercent rdf:type rdf:Property ;
    rdfs:label 'Cpu Utilization Percent' ;
    rdfs:comment 'Average CPU utilization percentage on the server instance during the session.' ;
    rdfs:domain ind:ServerSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPrivate rdf:type rdf:Property ;
    rdfs:label 'Is Private' ;
    rdfs:comment 'Indicates whether this session was a private match created by players rather than public matchmaking.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRanked rdf:type rdf:Property ;
    rdfs:label 'Is Ranked' ;
    rdfs:comment 'Indicates whether this session was a ranked competitive match affecting player rankings and leaderboards.' ;
    rdfs:domain ind:ServerSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mapName rdf:type rdf:Property ;
    rdfs:label 'Map Name' ;
    rdfs:comment 'The name or identifier of the game map or level played during this session.' ;
    rdfs:domain ind:ServerSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchResult rdf:type rdf:Property ;
    rdfs:label 'Match Result' ;
    rdfs:comment 'Outcome of the match if applicable (e.g., team_a_win, team_b_win, draw, incomplete).' ;
    rdfs:domain ind:ServerSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memoryUtilizationPercent rdf:type rdf:Property ;
    rdfs:label 'Memory Utilization Percent' ;
    rdfs:comment 'Average memory utilization percentage on the server instance during the session.' ;
    rdfs:domain ind:ServerSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumFps rdf:type rdf:Property ;
    rdfs:label 'Minimum Fps' ;
    rdfs:comment 'Lowest server-side frames per second recorded during the session, indicating performance bottlenecks.' ;
    rdfs:domain ind:ServerSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packetLossPercent rdf:type rdf:Property ;
    rdfs:label 'Packet Loss Percent' ;
    rdfs:comment 'Average network packet loss percentage experienced during the session, critical for diagnosing connectivity issues.' ;
    rdfs:domain ind:ServerSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Peak Latency Ms' ;
    rdfs:comment 'Maximum network latency in milliseconds observed during the session.' ;
    rdfs:domain ind:ServerSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakPlayerCount rdf:type rdf:Property ;
    rdfs:label 'Peak Player Count' ;
    rdfs:comment 'Maximum number of concurrent players connected to this session at any point during its lifecycle.' ;
    rdfs:domain ind:ServerSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serverTickRate rdf:type rdf:Property ;
    rdfs:label 'Server Tick Rate' ;
    rdfs:comment 'Server simulation update frequency in ticks per second, affecting gameplay responsiveness and accuracy.' ;
    rdfs:domain ind:ServerSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serverVersion rdf:type rdf:Property ;
    rdfs:label 'Server Version' ;
    rdfs:comment 'Version of the game server software running this session, used for compatibility tracking and rollback analysis.' ;
    rdfs:domain ind:ServerSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Session Duration Seconds' ;
    rdfs:comment 'Total duration of the session in seconds, calculated from start to end timestamp.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sessionIdentifier rdf:type rdf:Property ;
    rdfs:label 'Session Identifier' ;
    rdfs:comment 'Externally-visible unique session code or GUID used by clients and matchmaking services to reference this session.' ;
    rdfs:domain ind:ServerSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalBandwidthMb rdf:type rdf:Property ;
    rdfs:label 'Total Bandwidth Mb' ;
    rdfs:comment 'Total network bandwidth consumed by the session in megabytes, used for CDN cost analysis and capacity planning.' ;
    rdfs:domain ind:ServerSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicableRegions rdf:type rdf:Property ;
    rdfs:label 'Applicable Regions' ;
    rdfs:comment 'Geographic regions or data center locations where this SLA policy applies (e.g., North America, Europe, Asia-Pacific, Global).' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Required' ;
    rdfs:comment 'Indicates whether executive or stakeholder approval is required before this SLA policy can be activated or modified.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breachEscalationPath rdf:type rdf:Property ;
    rdfs:label 'Breach Escalation Path' ;
    rdfs:comment 'Defined escalation procedure and contact chain when SLA thresholds are breached (e.g., DevOps team → Infrastructure Manager → VP Engineering).' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Breach Notification Required' ;
    rdfs:comment 'Indicates whether automatic notification is required when SLA thresholds are breached.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cdnCoverageRequired rdf:type rdf:Property ;
    rdfs:label 'Cdn Coverage Required' ;
    rdfs:comment 'Indicates whether CDN topology and performance are included in this SLA policy for content delivery and patch distribution.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ciCdPipelineSlaIncluded rdf:type rdf:Property ;
    rdfs:label 'Ci Cd Pipeline Sla Included' ;
    rdfs:comment 'Indicates whether DevOps CI/CD pipeline health and deployment success rates are covered under this SLA policy.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchmakingSlaIncluded rdf:type rdf:Property ;
    rdfs:label 'Matchmaking Sla Included' ;
    rdfs:comment 'Indicates whether matchmaking service performance and availability are covered under this SLA policy.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxCcuCapacity rdf:type rdf:Property ;
    rdfs:label 'Max Ccu Capacity' ;
    rdfs:comment 'Maximum number of concurrent users the infrastructure must support under this SLA policy. Critical for capacity planning and GaaS live service delivery.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Max Latency Ms' ;
    rdfs:comment 'Maximum allowable network latency in milliseconds for the service to meet SLA commitments. Critical for real-time multiplayer gaming (PvP/PvE/MMO) and player experience.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxPcuCapacity rdf:type rdf:Property ;
    rdfs:label 'Max Pcu Capacity' ;
    rdfs:comment 'Maximum peak concurrent users the infrastructure must handle during surge periods (e.g., game launches, events, tournaments).' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementPeriod rdf:type rdf:Property ;
    rdfs:label 'Measurement Period' ;
    rdfs:comment 'Time period over which SLA performance is measured and reported (e.g., monthly uptime calculation).' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringIntervalSeconds rdf:type rdf:Property ;
    rdfs:label 'Monitoring Interval Seconds' ;
    rdfs:comment 'Frequency in seconds at which infrastructure performance metrics (uptime, latency, FPS) are monitored and measured against SLA targets.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:penaltyClause rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause' ;
    rdfs:comment 'Description of financial or service credit penalties applied when SLA commitments are not met.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Days' ;
    rdfs:comment 'Number of days between scheduled reviews of this SLA policy to ensure it remains aligned with business needs and technical capabilities.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rpoMinutes rdf:type rdf:Property ;
    rdfs:label 'Rpo Minutes' ;
    rdfs:comment 'Recovery Point Objective in minutes - the maximum acceptable amount of data loss measured in time (e.g., data must be recoverable to within 5 minutes of failure).' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rtoMinutes rdf:type rdf:Property ;
    rdfs:label 'Rto Minutes' ;
    rdfs:comment 'Recovery Time Objective in minutes - the maximum acceptable time to restore service after an incident or outage.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceScope rdf:type rdf:Property ;
    rdfs:label 'Service Scope' ;
    rdfs:comment 'Description of the infrastructure components and services covered by this SLA policy (e.g., server fleet, CDN, matchmaking, game servers, PvP/PvE/MMO services).' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaPolicyDescription rdf:type rdf:Property ;
    rdfs:label 'Sla Policy Description' ;
    rdfs:comment 'Detailed description of the SLA policy including its purpose, scope, and key commitments.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaPolicyStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Policy Status' ;
    rdfs:comment 'Current lifecycle status of the SLA policy indicating whether it is in use, being drafted, or retired.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetUptimePercentage rdf:type rdf:Property ;
    rdfs:label 'Target Uptime Percentage' ;
    rdfs:comment 'Committed uptime availability percentage for the service (e.g., 99.99%, 99.95%, 99.9%). Represents the percentage of time the service must be operational.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agreementAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Agreement Amendment Id' ;
    rdfs:comment 'Unique identifier for the IP agreement amendment record. Primary key.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amendmentDate rdf:type rdf:Property ;
    rdfs:label 'Amendment Date' ;
    rdfs:comment 'Date when the amendment was formally drafted or proposed. Represents the business event timestamp for the amendment creation.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentDescription rdf:type rdf:Property ;
    rdfs:label 'Amendment Description' ;
    rdfs:comment 'Detailed narrative description of the changes introduced by this amendment, including specific clauses modified, new terms added, or provisions removed. Supports legal and audit requirements for amendment history.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentStatus rdf:type rdf:Property ;
    rdfs:label 'Amendment Status' ;
    rdfs:comment 'Current lifecycle status of the amendment: draft (being prepared), pending_approval (under review), approved (authorized but not yet signed), executed (fully signed and active), rejected (declined), or superseded (replaced by newer amendment).' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentType rdf:type rdf:Property ;
    rdfs:label 'Amendment Type' ;
    rdfs:comment 'Classification of the amendment by its primary purpose: rate adjustment (pricing changes), territory expansion (geographic scope), term extension (duration), scope modification (deliverables/rights), royalty change (payment terms), or termination clause (exit conditions).' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalChain rdf:type rdf:Property ;
    rdfs:label 'Approval Chain' ;
    rdfs:comment 'Comma-separated list of roles or individuals who must approve this amendment (e.g., Legal Counsel, CFO, VP Licensing, General Counsel). Tracks the approval workflow.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceImpact rdf:type rdf:Property ;
    rdfs:label 'Compliance Impact' ;
    rdfs:comment 'Assessment of the amendments impact on regulatory compliance obligations (ESRB, PEGI, GDPR, COPPA, etc.). Ranges from none (no compliance impact) to critical (significant compliance implications).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReference rdf:type rdf:Property ;
    rdfs:label 'Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the physical or digital amendment document stored in the document management system. Supports audit trail and legal discovery.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executedByLicensee rdf:type rdf:Property ;
    rdfs:label 'Executed By Licensee' ;
    rdfs:comment 'Name or identifier of the licensee representative who signed the amendment. Nullable if amendment is not yet executed.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executedByLicensor rdf:type rdf:Property ;
    rdfs:label 'Executed By Licensor' ;
    rdfs:comment 'Name or identifier of the licensor representative who signed the amendment. Nullable if amendment is not yet executed.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'Date when the amendment was fully executed (signed by all parties). Nullable if amendment is not yet executed.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'Estimated financial impact of this amendment on the agreement value, expressed in the agreements base currency. Positive for revenue increases, negative for decreases. Nullable if financial impact is not quantified.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legalReviewCompleted rdf:type rdf:Property ;
    rdfs:label 'Legal Review Completed' ;
    rdfs:comment 'Indicates whether legal review has been completed for this amendment. True if review is complete, False otherwise. Nullable if legal review is not required.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalReviewDate rdf:type rdf:Property ;
    rdfs:label 'Legal Review Date' ;
    rdfs:comment 'Date when legal review was completed. Nullable if legal review is not required or not yet completed.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Legal Review Required' ;
    rdfs:comment 'Indicates whether this amendment requires formal legal counsel review before execution. True if legal review is mandatory, False otherwise.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalReviewer rdf:type rdf:Property ;
    rdfs:label 'Legal Reviewer' ;
    rdfs:comment 'Name or identifier of the legal counsel who reviewed this amendment. Nullable if legal review is not required or not yet completed.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newMinimumGuarantee rdf:type rdf:Property ;
    rdfs:label 'New Minimum Guarantee' ;
    rdfs:comment 'Updated minimum guarantee payment amount introduced by this amendment. Represents the floor payment obligation regardless of actual usage or sales. Nullable if amendment does not affect minimum guarantees.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newRoyaltyRate rdf:type rdf:Property ;
    rdfs:label 'New Royalty Rate' ;
    rdfs:comment 'Updated royalty percentage or rate introduced by this amendment. Expressed as a decimal (e.g., 0.0500 for 5%). Nullable if amendment does not affect royalty rates.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationDate rdf:type rdf:Property ;
    rdfs:label 'Notification Date' ;
    rdfs:comment 'Date when formal notification of this amendment was sent to stakeholders. Nullable if notification has not been sent.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scopeChangeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Change Description' ;
    rdfs:comment 'Detailed description of changes to the agreement scope, including new IP rights granted, restrictions added, or deliverables modified. Supports tracking of scope evolution.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededTermVersion rdf:type rdf:Property ;
    rdfs:label 'Superseded Term Version' ;
    rdfs:comment 'Identifier of the previous agreement version or amendment that this amendment replaces or modifies. Maintains lineage of contract evolution.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termExtensionMonths rdf:type rdf:Property ;
    rdfs:label 'Term Extension Months' ;
    rdfs:comment 'Number of months by which the agreement term is extended by this amendment. Positive integer for extensions, negative for reductions. Nullable if amendment does not affect term duration.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:territoryAdded rdf:type rdf:Property ;
    rdfs:label 'Territory Added' ;
    rdfs:comment 'Geographic territories or markets added to the agreement scope by this amendment. Comma-separated list of ISO 3166-1 alpha-3 country codes or region names.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryRemoved rdf:type rdf:Property ;
    rdfs:label 'Territory Removed' ;
    rdfs:comment 'Geographic territories or markets removed from the agreement scope by this amendment. Comma-separated list of ISO 3166-1 alpha-3 country codes or region names.' ;
    rdfs:domain ind:AgreementAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditEventId rdf:type rdf:Property ;
    rdfs:label 'Audit Event Id' ;
    rdfs:comment 'Unique identifier for the licensing audit or dispute event. Primary key.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimantPartyLicenseeId rdf:type rdf:Property ;
    rdfs:label 'Claimant Party Licensee Id' ;
    rdfs:comment 'Reference to the party initiating the dispute claim (IP owner, licensor, or third party).' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Licensee .

ind:respondentPartyLicenseeId rdf:type rdf:Property ;
    rdfs:label 'Respondent Party Licensee Id' ;
    rdfs:comment 'Reference to the party responding to the dispute claim (alleged infringer or licensee).' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Licensee .

ind:auditPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Audit Period End Date' ;
    rdfs:comment 'The ending date of the period covered by the audit or dispute.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Audit Period Start Date' ;
    rdfs:comment 'The beginning date of the period covered by the audit or dispute.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditorOrganization rdf:type rdf:Property ;
    rdfs:label 'Auditor Organization' ;
    rdfs:comment 'Name of the organization or firm conducting the audit (e.g., Big Four accounting firm, law firm).' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceActionRequired rdf:type rdf:Property ;
    rdfs:label 'Compliance Action Required' ;
    rdfs:comment 'Description of any corrective actions, process changes, or compliance measures required as a result of the audit findings.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Agreement Flag' ;
    rdfs:comment 'Indicates whether the audit findings or settlement terms are subject to a confidentiality or non-disclosure agreement.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputedAmount rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount' ;
    rdfs:comment 'The monetary amount in dispute (underpaid royalties, claimed damages, settlement demand). Null for non-financial disputes.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputedAmountCurrency rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the disputed amount (e.g., USD, EUR, JPY).' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Event Completed Date' ;
    rdfs:comment 'The date the audit was finalized or the dispute was resolved or closed.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventInitiatedDate rdf:type rdf:Property ;
    rdfs:label 'Event Initiated Date' ;
    rdfs:comment 'The date the audit was scheduled or the dispute claim was filed.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:findingsSummary rdf:type rdf:Property ;
    rdfs:label 'Findings Summary' ;
    rdfs:comment 'High-level summary of audit findings, compliance gaps, or dispute allegations. Detailed findings are stored in separate audit detail records.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpAuditDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Date' ;
    rdfs:comment 'Scheduled date for the follow-up audit, if applicable.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpAuditScheduledFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Scheduled Flag' ;
    rdfs:comment 'Indicates whether a follow-up audit has been scheduled to verify compliance with corrective actions.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governingLaw rdf:type rdf:Property ;
    rdfs:label 'Governing Law' ;
    rdfs:comment 'The body of law governing the license agreement and dispute resolution (e.g., California Commercial Code, UK Contract Law).' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'The legal jurisdiction or territory governing the audit or dispute (e.g., USA-California, EU-Germany, JPN).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalCounselAssigned rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Assigned' ;
    rdfs:comment 'Name of the legal counsel or law firm assigned to represent the company in the dispute.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:litigationFlag rdf:type rdf:Property ;
    rdfs:label 'Litigation Flag' ;
    rdfs:comment 'Indicates whether the dispute has escalated to formal litigation or court proceedings.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediationFlag rdf:type rdf:Property ;
    rdfs:label 'Mediation Flag' ;
    rdfs:comment 'Indicates whether the dispute is currently in or has entered formal mediation or arbitration.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:settlementAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Amount' ;
    rdfs:comment 'The final agreed settlement or adjustment amount. Null if event is not yet settled.' ;
    rdfs:domain ind:Licensing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementCurrency rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the settlement amount.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementTermsSummary rdf:type rdf:Property ;
    rdfs:label 'Settlement Terms Summary' ;
    rdfs:comment 'High-level summary of settlement terms, including payment schedules, license modifications, or non-monetary remedies. Detailed terms are stored separately.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerReason rdf:type rdf:Property ;
    rdfs:label 'Trigger Reason' ;
    rdfs:comment 'The reason or mechanism that initiated the audit or dispute event.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalTurnaroundDays rdf:type rdf:Property ;
    rdfs:label 'Approval Turnaround Days' ;
    rdfs:comment 'Maximum number of business days the brand owner has to review and approve submitted materials. Null if no approval workflow.' ;
    rdfs:domain ind:BrandPartnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalWorkflowRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Required Flag' ;
    rdfs:comment 'Indicates whether brand owner approval is required for content, marketing materials, or product releases (True) or not (False).' ;
    rdfs:domain ind:BrandPartnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Rights Flag' ;
    rdfs:comment 'Indicates whether the brand owner has the right to audit revenue, usage, or compliance (True) or not (False).' ;
    rdfs:domain ind:Licensing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:brandUsageGuidelinesUrl rdf:type rdf:Property ;
    rdfs:label 'Brand Usage Guidelines Url' ;
    rdfs:comment 'URL reference to the brand owner\'s official usage guidelines, style guide, or brand standards documentation.' ;
    rdfs:domain ind:Licensing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coMarketingObligationFlag rdf:type rdf:Property ;
    rdfs:label 'Co Marketing Obligation Flag' ;
    rdfs:comment 'Indicates whether the partnership includes mandatory co-marketing or cross-promotional activities (True) or not (False).' ;
    rdfs:domain ind:BrandPartnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coMarketingRequirements rdf:type rdf:Property ;
    rdfs:label 'Co Marketing Requirements' ;
    rdfs:comment 'Detailed description of co-marketing obligations (e.g., \'Minimum 3 social media posts per quarter\', \'Joint press release at launch\', \'Brand logo in all trailers\').' ;
    rdfs:domain ind:BrandPartnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Contract Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the signed legal contract document in the document management system.' ;
    rdfs:domain ind:Licensing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityTerms rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Terms' ;
    rdfs:comment 'Detailed description of exclusivity conditions, restrictions, and carve-outs (e.g., \'Exclusive for sports simulation genre only\', \'Non-exclusive with right of first refusal\').' ;
    rdfs:domain ind:BrandPartnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Fixed Fee Amount' ;
    rdfs:comment 'One-time or periodic fixed payment amount for the partnership. Null if royalty-based model.' ;
    rdfs:domain ind:Licensing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gameTitleScope rdf:type rdf:Property ;
    rdfs:label 'Game Title Scope' ;
    rdfs:comment 'Specific game titles or product lines covered by this partnership (e.g., \'FIFA 24\', \'Marvel\'s Spider-Man Series\', \'All Mobile Titles\').' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipOwnershipTerms rdf:type rdf:Property ;
    rdfs:label 'Ip Ownership Terms' ;
    rdfs:comment 'Detailed terms regarding IP ownership of derivative works, new characters, or co-created content (e.g., \'All derivative IP owned by brand owner\', \'Joint ownership of new characters\').' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensedBrandAssets rdf:type rdf:Property ;
    rdfs:label 'Licensed Brand Assets' ;
    rdfs:comment 'Detailed description of the specific brand assets covered by the license (character names, logos, trademarks, visual designs, audio elements, storylines, etc.).' ;
    rdfs:domain ind:BrandPartnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumGuaranteeAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Guarantee Amount' ;
    rdfs:comment 'Minimum guaranteed payment to brand owner regardless of actual sales performance. Null if no MG applies.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnershipName rdf:type rdf:Property ;
    rdfs:label 'Partnership Name' ;
    rdfs:comment 'Human-readable name of the brand partnership (e.g., \'FIFA World Cup 2024 License\', \'Marvel Cinematic Universe Character Pack\').' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnershipStatus rdf:type rdf:Property ;
    rdfs:label 'Partnership Status' ;
    rdfs:comment 'Current lifecycle status of the brand partnership agreement (draft for initial creation, negotiation for under discussion, active for in force, suspended for temporarily paused, terminated for ended early, expired for naturally ended, renewed for extended). [ENUM-REF-CANDIDATE: draft|negotiation|active|suspended|terminated|expired|renewed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnershipType rdf:type rdf:Property ;
    rdfs:label 'Partnership Type' ;
    rdfs:comment 'Classification of the brand partnership agreement type (character license for fictional characters, franchise license for entire IP universes, sports league for official league/team rights, celebrity likeness for real person representation, music rights for soundtrack/score, art asset license for visual content).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceMilestones rdf:type rdf:Property ;
    rdfs:label 'Performance Milestones' ;
    rdfs:comment 'Specific performance targets or milestones tied to the partnership (e.g., \'Launch within 12 months\', \'Achieve 1M DAU (Daily Active Users) in first quarter\', \'Minimum $5M revenue in year 1\').' ;
    rdfs:domain ind:BrandPartnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingBoardRestrictions rdf:type rdf:Property ;
    rdfs:label 'Rating Board Restrictions' ;
    rdfs:comment 'Content rating restrictions imposed by the brand owner (e.g., \'Must maintain ESRB E10+ or lower\', \'No M-rated content allowed\', \'PEGI 12 maximum\').' ;
    rdfs:domain ind:BrandPartnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueShareModel rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Model' ;
    rdfs:comment 'Financial structure of the partnership (fixed fee for flat payment, percentage royalty for revenue share, hybrid for combination, minimum guarantee plus royalty for MG+royalty structure).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryScope rdf:type rdf:Property ;
    rdfs:label 'Territory Scope' ;
    rdfs:comment 'Geographic territories where the licensed brand assets may be used (e.g., \'Worldwide\', \'North America Only\', \'EU and APAC\').' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialTermId rdf:type rdf:Property ;
    rdfs:label 'Commercial Term Id' ;
    rdfs:comment 'Primary key for commercial_term' ;
    rdfs:domain ind:CommercialTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:advancePaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Advance Payment Amount' ;
    rdfs:comment 'Upfront payment made by licensee, typically recoupable against future royalties.' ;
    rdfs:domain ind:CommercialTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:advanceRecoupmentTerms rdf:type rdf:Property ;
    rdfs:label 'Advance Recoupment Terms' ;
    rdfs:comment 'Detailed terms describing how advance payments are recouped from future royalty payments (e.g., 100% recoupment, cross-collateralization rules).' ;
    rdfs:domain ind:CommercialTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFrequencyLimit rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency Limit' ;
    rdfs:comment 'Maximum frequency at which licensor may conduct audits (e.g., once per calendar year, twice per contract term).' ;
    rdfs:domain ind:Licensing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditRightsClause rdf:type rdf:Property ;
    rdfs:label 'Audit Rights Clause' ;
    rdfs:comment 'Text describing licensors rights to audit licensees books and records to verify royalty calculations and compliance.' ;
    rdfs:domain ind:CommercialTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:derivativeWorksRights rdf:type rdf:Property ;
    rdfs:label 'Derivative Works Rights' ;
    rdfs:comment 'Specifies licensees rights to create derivative works based on the licensed IP (e.g., sequels, spin-offs, adaptations).' ;
    rdfs:domain ind:CommercialTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityWindowMonths rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Window Months' ;
    rdfs:comment 'Duration in months for which platform or territory exclusivity applies before rights expand.' ;
    rdfs:domain ind:CommercialTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:indemnificationTerms rdf:type rdf:Property ;
    rdfs:label 'Indemnification Terms' ;
    rdfs:comment 'Detailed indemnification obligations of each party, including scope of liability, defense obligations, and limitations.' ;
    rdfs:domain ind:CommercialTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latePaymentPenaltyRate rdf:type rdf:Property ;
    rdfs:label 'Late Payment Penalty Rate' ;
    rdfs:comment 'Percentage penalty rate applied to overdue payments, typically expressed as annual percentage rate (APR).' ;
    rdfs:domain ind:Licensing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liabilityCapAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Cap Amount' ;
    rdfs:comment 'Maximum liability amount either party may be held responsible for under the agreement, excluding certain carve-outs.' ;
    rdfs:domain ind:CommercialTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketingApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Approval Required Flag' ;
    rdfs:comment 'Indicates whether licensee must obtain licensor approval for marketing materials, promotional campaigns, and brand usage.' ;
    rdfs:domain ind:CommercialTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingSpendCommitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Marketing Spend Commitment Amount' ;
    rdfs:comment 'Minimum marketing spend amount licensee commits to invest in promoting the licensed IP or product.' ;
    rdfs:domain ind:CommercialTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDueDays rdf:type rdf:Property ;
    rdfs:label 'Payment Due Days' ;
    rdfs:comment 'Number of days after period end or invoice date by which payment must be received.' ;
    rdfs:domain ind:Licensing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Payment Frequency' ;
    rdfs:comment 'Cadence at which royalty or license fee payments are due (e.g., quarterly, annually).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceMilestoneTerms rdf:type rdf:Property ;
    rdfs:label 'Performance Milestone Terms' ;
    rdfs:comment 'Detailed terms describing performance milestones that trigger payments, bonuses, or rights adjustments (e.g., sales thresholds, user acquisition targets).' ;
    rdfs:domain ind:CommercialTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformExclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Platform Exclusivity Flag' ;
    rdfs:comment 'Indicates whether this agreement grants exclusive rights to specific gaming platforms (console, PC, mobile).' ;
    rdfs:domain ind:CommercialTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformExclusivityList rdf:type rdf:Property ;
    rdfs:label 'Platform Exclusivity List' ;
    rdfs:comment 'Comma-separated list of platforms covered by exclusivity (e.g., PlayStation, Xbox, Nintendo Switch, PC, iOS, Android).' ;
    rdfs:domain ind:CommercialTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityAssuranceRequirements rdf:type rdf:Property ;
    rdfs:label 'Quality Assurance Requirements' ;
    rdfs:comment 'Quality standards and certification requirements licensee must meet, including ESRB, PEGI, or platform Technical Requirements Checklist (TRC) compliance.' ;
    rdfs:domain ind:CommercialTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of days prior to expiration by which licensee must provide notice to exercise renewal option.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalOptionPeriods rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Periods' ;
    rdfs:comment 'Number of renewal periods available to licensee (e.g., two 2-year renewal options).' ;
    rdfs:domain ind:CommercialTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueReportingDueDays rdf:type rdf:Property ;
    rdfs:label 'Revenue Reporting Due Days' ;
    rdfs:comment 'Number of days after period end by which revenue reports must be submitted to licensor.' ;
    rdfs:domain ind:CommercialTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueReportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Revenue Reporting Frequency' ;
    rdfs:comment 'Cadence at which licensee must provide revenue and usage reports to licensor for royalty calculation.' ;
    rdfs:domain ind:CommercialTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyBasis rdf:type rdf:Property ;
    rdfs:label 'Royalty Basis' ;
    rdfs:comment 'The financial or usage metric upon which royalty calculations are based (e.g., net revenue, gross revenue, units sold).' ;
    rdfs:domain ind:Licensing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sublicensingPermittedFlag rdf:type rdf:Property ;
    rdfs:label 'Sublicensing Permitted Flag' ;
    rdfs:comment 'Indicates whether licensee is permitted to sublicense the IP or technology to third parties.' ;
    rdfs:domain ind:Licensing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Term Effective Date' ;
    rdfs:comment 'Date when this version of commercial terms becomes binding and enforceable.' ;
    rdfs:domain ind:CommercialTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:termExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Term Expiration Date' ;
    rdfs:comment 'Date when this version of commercial terms ceases to be effective. Nullable for open-ended terms.' ;
    rdfs:domain ind:CommercialTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:termStatus rdf:type rdf:Property ;
    rdfs:label 'Term Status' ;
    rdfs:comment 'Current lifecycle status of this commercial term version.' ;
    rdfs:domain ind:CommercialTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Term Version Number' ;
    rdfs:comment 'Sequential version number for this term set. Agreements may have multiple versioned term sets reflecting amendments over time.' ;
    rdfs:domain ind:CommercialTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:terminationCurePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Termination Cure Period Days' ;
    rdfs:comment 'Number of days the breaching party has to cure a breach before termination becomes effective.' ;
    rdfs:domain ind:CommercialTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:terminationForCauseConditions rdf:type rdf:Property ;
    rdfs:label 'Termination For Cause Conditions' ;
    rdfs:comment 'Detailed conditions under which either party may terminate the agreement for cause (e.g., material breach, bankruptcy, failure to meet minimum guarantees).' ;
    rdfs:domain ind:CommercialTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of days advance notice required for termination, either for cause or for convenience.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:territoryExpansionOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Territory Expansion Option Flag' ;
    rdfs:comment 'Indicates whether licensee has the option to expand into additional territories under predefined terms.' ;
    rdfs:domain ind:CommercialTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:territoryExpansionTerms rdf:type rdf:Property ;
    rdfs:label 'Territory Expansion Terms' ;
    rdfs:comment 'Detailed terms governing territory expansion options, including pricing, approval process, and timing.' ;
    rdfs:domain ind:CommercialTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryList rdf:type rdf:Property ;
    rdfs:label 'Territory List' ;
    rdfs:comment 'Comma-separated list of countries or regions where license rights apply, using ISO 3166-1 alpha-3 country codes.' ;
    rdfs:domain ind:CommercialTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedGameTitleId rdf:type rdf:Property ;
    rdfs:label 'Linked Game Title Id' ;
    rdfs:comment 'Reference to the specific game title to which this compliance obligation applies, if applicable.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GameTitle .

ind:linkedPlatformStorefrontId rdf:type rdf:Property ;
    rdfs:label 'Linked Platform Storefront Id' ;
    rdfs:comment 'Reference to the platform (console, PC, mobile) to which this compliance obligation applies, if platform-specific.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Storefront .

ind:auditSubmissionRequirement rdf:type rdf:Property ;
    rdfs:label 'Audit Submission Requirement' ;
    rdfs:comment 'Details of audit reports, financial statements, or compliance documentation that must be submitted to the licensor or regulatory body.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRestrictionClause rdf:type rdf:Property ;
    rdfs:label 'Content Restriction Clause' ;
    rdfs:comment 'Specific content restrictions imposed by the IP agreement or regulatory body (e.g., no violence, age-appropriate content, no gambling mechanics).' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataHandlingRequirement rdf:type rdf:Property ;
    rdfs:label 'Data Handling Requirement' ;
    rdfs:comment 'Specific data privacy and handling obligations tied to licensed player-facing features (e.g., GDPR consent requirements, COPPA parental consent, data retention limits).' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmRequirement rdf:type rdf:Property ;
    rdfs:label 'Drm Requirement' ;
    rdfs:comment 'Specific DRM implementation requirements mandated by the IP agreement or platform (e.g., Denuvo, Steamworks DRM, platform-native DRM).' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationContact rdf:type rdf:Property ;
    rdfs:label 'Escalation Contact' ;
    rdfs:comment 'Email address of the internal or external contact to escalate to if this obligation is at risk of breach.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBlockingRelease rdf:type rdf:Property ;
    rdfs:label 'Is Blocking Release' ;
    rdfs:comment 'Boolean flag indicating whether this compliance obligation must be fulfilled before a game title can be released (true) or is non-blocking (false).' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextRecurrenceDate rdf:type rdf:Property ;
    rdfs:label 'Next Recurrence Date' ;
    rdfs:comment 'For recurring obligations, the date when the next instance of this obligation is due.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:obligationStatus rdf:type rdf:Property ;
    rdfs:label 'Obligation Status' ;
    rdfs:comment 'Current lifecycle status of the compliance obligation: pending (not started), in progress (work underway), submitted (awaiting review), approved (accepted by governing body), rejected (failed review), completed (fulfilled), overdue (past due date), or waived (exempted). [ENUM-REF-CANDIDATE: pending|in_progress|submitted|approved|rejected|completed|overdue|waived — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerDepartment rdf:type rdf:Property ;
    rdfs:label 'Owner Department' ;
    rdfs:comment 'The department or business unit responsible for managing this compliance obligation (e.g., Legal, Compliance, Publishing, Platform Relations).' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyForBreach rdf:type rdf:Property ;
    rdfs:label 'Penalty For Breach' ;
    rdfs:comment 'Description of penalties, fines, or consequences if this compliance obligation is not met (e.g., financial penalty, license termination, platform delisting).' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformCertificationRequirement rdf:type rdf:Property ;
    rdfs:label 'Platform Certification Requirement' ;
    rdfs:comment 'Platform-specific certification obligations (TRC for Sony, TCR for Microsoft, lotcheck for Nintendo) that must be met before release.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceFrequency rdf:type rdf:Property ;
    rdfs:label 'Recurrence Frequency' ;
    rdfs:comment 'Indicates how often this obligation recurs: one-time, monthly, quarterly, annually, per game release, or event-driven (triggered by specific business events).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Calculated risk score (0-100) representing the business impact and likelihood of breach for this obligation. Higher scores indicate higher risk.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentationUrl rdf:type rdf:Property ;
    rdfs:label 'Supporting Documentation Url' ;
    rdfs:comment 'URL or file path to supporting documentation, guidelines, or reference materials for this compliance obligation.' ;
    rdfs:domain ind:Licensing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedDistributionChannels rdf:type rdf:Property ;
    rdfs:label 'Authorized Distribution Channels' ;
    rdfs:comment 'Comma-separated list of distribution channels through which the licensee is authorized to distribute the licensed content (e.g., Steam, Epic Games Store, PlayStation Store, Xbox Store, retail, direct download).' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedPlatforms rdf:type rdf:Property ;
    rdfs:label 'Authorized Platforms' ;
    rdfs:comment 'Comma-separated list of gaming platforms on which the licensee is authorized to distribute or use the licensed IP or technology (e.g., PlayStation, Xbox, PC, Mobile, Nintendo Switch).' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceAuditRights rdf:type rdf:Property ;
    rdfs:label 'Compliance Audit Rights' ;
    rdfs:comment 'Indicates whether the licensor retains the right to audit the licensee\'s usage and compliance with entitlement terms.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentRatingRequirements rdf:type rdf:Property ;
    rdfs:label 'Content Rating Requirements' ;
    rdfs:comment 'Comma-separated list of required content ratings by territory and rating board (e.g., ESRB:M for USA, PEGI:18 for Europe, CERO:D for Japan) that must be obtained before distribution.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coveredTerritories rdf:type rdf:Property ;
    rdfs:label 'Covered Territories' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes representing the geographic territories where the entitlement is valid.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmActivationLimit rdf:type rdf:Property ;
    rdfs:label 'Drm Activation Limit' ;
    rdfs:comment 'Maximum number of device activations permitted per end-user license under the DRM implementation requirements. Null if unlimited or not applicable.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drmOfflineGracePeriodHours rdf:type rdf:Property ;
    rdfs:label 'Drm Offline Grace Period Hours' ;
    rdfs:comment 'Number of hours that the licensed content can be used offline without DRM re-authentication. Null if always-online or not applicable.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drmProvider rdf:type rdf:Property ;
    rdfs:label 'Drm Provider' ;
    rdfs:comment 'The DRM technology provider that must be implemented for content distributed under this entitlement to protect intellectual property.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineVersionScope rdf:type rdf:Property ;
    rdfs:label 'Engine Version Scope' ;
    rdfs:comment 'Specific game engine versions or SDK versions covered by this entitlement (e.g., Unity 2021.x, Unreal Engine 5.x). Applicable for game engine technology licenses.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementNumber rdf:type rdf:Property ;
    rdfs:label 'Entitlement Number' ;
    rdfs:comment 'Business-facing unique identifier for the entitlement, used in contracts and communications.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementType rdf:type rdf:Property ;
    rdfs:label 'Entitlement Type' ;
    rdfs:comment 'Classification of the entitlement based on the type of intellectual property or technology being licensed.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxInstallCount rdf:type rdf:Property ;
    rdfs:label 'Max Install Count' ;
    rdfs:comment 'Maximum number of installations or deployments permitted under this entitlement. Applicable for SDK, middleware, or technology licenses. Null if unlimited or not applicable.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxSeatCount rdf:type rdf:Property ;
    rdfs:label 'Max Seat Count' ;
    rdfs:comment 'Maximum number of concurrent developer seats or user licenses permitted under this entitlement for SDK or tool licenses. Null if unlimited or not applicable.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modificationRestrictions rdf:type rdf:Property ;
    rdfs:label 'Modification Restrictions' ;
    rdfs:comment 'Specific restrictions or conditions on modifications if modification rights are limited (e.g., no changes to core characters, must maintain brand guidelines, requires licensor approval).' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modificationRights rdf:type rdf:Property ;
    rdfs:label 'Modification Rights' ;
    rdfs:comment 'Level of rights granted to the licensee to modify, adapt, or create derivative works from the licensed IP or technology.' ;
    rdfs:domain ind:Licensing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueThresholdForRoyalty rdf:type rdf:Property ;
    rdfs:label 'Revenue Threshold For Royalty' ;
    rdfs:comment 'Revenue threshold that must be exceeded before royalty payments commence. Null if royalties apply from the first dollar.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyApplicable rdf:type rdf:Property ;
    rdfs:label 'Royalty Applicable' ;
    rdfs:comment 'Indicates whether royalty payments are required under this entitlement based on usage, revenue, or other metrics.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:royaltyCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Royalty Calculation Method' ;
    rdfs:comment 'Method used to calculate royalty payments if applicable (e.g., percentage of revenue, per-unit fee, per-install fee, tiered structure).' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sublicensingConditions rdf:type rdf:Property ;
    rdfs:label 'Sublicensing Conditions' ;
    rdfs:comment 'Specific terms, restrictions, or approval requirements that apply if sublicensing is permitted under this entitlement.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sublicensingPermitted rdf:type rdf:Property ;
    rdfs:label 'Sublicensing Permitted' ;
    rdfs:comment 'Indicates whether the licensee is permitted to grant sublicenses to third parties under this entitlement.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Period Days' ;
    rdfs:comment 'Number of days advance notice required by either party to terminate the entitlement before the expiry date.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:territoryRestrictions rdf:type rdf:Property ;
    rdfs:label 'Territory Restrictions' ;
    rdfs:comment 'Specific restrictions or conditions applied to certain territories, such as digital-only distribution, physical and digital rights, streaming rights, or content modifications required for regional compliance.' ;
    rdfs:domain ind:Licensing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trademarkUsageGuidelines rdf:type rdf:Property ;
    rdfs:label 'Trademark Usage Guidelines' ;
    rdfs:comment 'Reference to the brand guidelines document or specific requirements for trademark usage if permitted.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trademarkUsagePermitted rdf:type rdf:Property ;
    rdfs:label 'Trademark Usage Permitted' ;
    rdfs:comment 'Indicates whether the licensee is permitted to use the licensor\'s trademarks, logos, or brand assets in marketing and distribution.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usageReportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Usage Reporting Frequency' ;
    rdfs:comment 'Frequency at which usage reports must be submitted if usage reporting is required.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Usage Reporting Required' ;
    rdfs:comment 'Indicates whether the licensee is required to submit periodic usage reports (e.g., install counts, active users, revenue) to the licensor.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryIpLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Primary Ip Legal Entity Id' ;
    rdfs:comment 'External business identifier for the licensor organization, such as DUNS number or tax identifier.' ;
    rdfs:domain ind:Licensing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the licensing agreement by commercial structure: outbound engine (Unity/Unreal SDK licensing), inbound brand/franchise (licensed IP usage), middleware (physics, audio, anti-cheat, analytics SDKs), music synchronization, art asset licensing, or brand partnership. [ENUM-REF-CANDIDATE: outbound_engine|inbound_brand|inbound_franchise|middleware|music_sync|art_asset|brand_partnership — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedAccountManager rdf:type rdf:Property ;
    rdfs:label 'Assigned Account Manager' ;
    rdfs:comment 'Name or identifier of the internal account manager or business development representative responsible for managing this licensing relationship.' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandOwnerName rdf:type rdf:Property ;
    rdfs:label 'Brand Owner Name' ;
    rdfs:comment 'Name of the brand owner or franchise rights holder for brand partnership agreements. Nullable for non-brand-partnership agreements.' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandPartnershipType rdf:type rdf:Property ;
    rdfs:label 'Brand Partnership Type' ;
    rdfs:comment 'Type of brand partnership: co-marketing (joint promotional campaigns), co-development (collaborative game development), character licensing (use of brand characters), franchise adaptation (game based on existing IP), or cross-promotion. Nullable for non-brand-partnership agreements.' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coMarketingObligations rdf:type rdf:Property ;
    rdfs:label 'Co Marketing Obligations' ;
    rdfs:comment 'Description of co-marketing obligations, including minimum spend commitments, promotional activities, and joint campaign requirements for brand partnership agreements. Nullable for non-brand-partnership agreements.' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRatingBoardRequirements rdf:type rdf:Property ;
    rdfs:label 'Compliance Rating Board Requirements' ;
    rdfs:comment 'Specific rating board compliance requirements imposed by the agreement, including ESRB, PEGI, USK, CERO, or GRAC rating restrictions or content guidelines.' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'Legal jurisdiction whose laws govern the interpretation and enforcement of the agreement (e.g., \'State of California, USA\' or \'England and Wales\').' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseeName rdf:type rdf:Property ;
    rdfs:label 'Licensee Name' ;
    rdfs:comment 'Legal name of the party receiving the intellectual property license (the entity authorized to use the IP).' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensorName rdf:type rdf:Property ;
    rdfs:label 'Licensor Name' ;
    rdfs:comment 'Legal name of the party granting the intellectual property license (the IP owner or rights holder).' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:middlewareLicenseType rdf:type rdf:Property ;
    rdfs:label 'Middleware License Type' ;
    rdfs:comment 'Type of middleware license granted: per-title (licensed per game), per-seat (per developer), revenue-share, enterprise (organization-wide), or perpetual. Nullable for non-middleware agreements.' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:middlewareProductName rdf:type rdf:Property ;
    rdfs:label 'Middleware Product Name' ;
    rdfs:comment 'Name of the specific middleware product or SDK covered by the agreement (e.g., \'Havok Physics Engine\', \'Wwise Audio Middleware\'). Nullable for non-middleware agreements.' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:middlewareProductVersion rdf:type rdf:Property ;
    rdfs:label 'Middleware Product Version' ;
    rdfs:comment 'Version or release number of the middleware product licensed. Nullable for non-middleware agreements or version-agnostic licenses.' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:middlewareUsageScope rdf:type rdf:Property ;
    rdfs:label 'Middleware Usage Scope' ;
    rdfs:comment 'Description of permitted usage scope for middleware, including platform restrictions, title limits, or development team size constraints. Nullable for non-middleware agreements.' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:middlewareVendorName rdf:type rdf:Property ;
    rdfs:label 'Middleware Vendor Name' ;
    rdfs:comment 'Name of the middleware vendor for middleware-type agreements. Nullable for non-middleware agreements.' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:musicComposerName rdf:type rdf:Property ;
    rdfs:label 'Music Composer Name' ;
    rdfs:comment 'Name of the composer or songwriter for music synchronization licenses. Nullable for non-music agreements.' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:musicMediaUsageRights rdf:type rdf:Property ;
    rdfs:label 'Music Media Usage Rights' ;
    rdfs:comment 'Description of permitted media usage rights for music synchronization, including platforms (console, PC, mobile, streaming), territories, and duration. Nullable for non-music agreements.' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:musicProClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Music Pro Clearance Status' ;
    rdfs:comment 'Status of clearance from performing rights organizations (ASCAP, BMI, SESAC, PRS, etc.) for music synchronization licenses. Nullable for non-music agreements.' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:musicPublisherName rdf:type rdf:Property ;
    rdfs:label 'Music Publisher Name' ;
    rdfs:comment 'Name of the music publisher holding rights for music synchronization licenses. Nullable for non-music agreements.' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:musicTrackTitle rdf:type rdf:Property ;
    rdfs:label 'Music Track Title' ;
    rdfs:comment 'Title of the music track or composition for music synchronization licenses. Nullable for non-music agreements.' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Payment Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for all financial terms in this agreement (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNegotiationStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Negotiation Status' ;
    rdfs:comment 'Current status of renewal negotiations for agreements approaching expiry.' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticeDeadlineDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Deadline Days' ;
    rdfs:comment 'Number of days before expiry_date by which renewal notice must be provided to trigger automatic renewal or initiate renewal negotiations.' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:royaltyStructureType rdf:type rdf:Property ;
    rdfs:label 'Royalty Structure Type' ;
    rdfs:comment 'Classification of the royalty or payment structure: fixed fee (flat payment), revenue share (percentage of revenue), per-unit (per copy sold), per-seat (per developer license), tiered (rate changes by volume), or hybrid (combination).' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationClauseSummary rdf:type rdf:Property ;
    rdfs:label 'Termination Clause Summary' ;
    rdfs:comment 'Summary of termination conditions and notice requirements, including breach conditions, convenience termination rights, and wind-down obligations.' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipDisputeId rdf:type rdf:Property ;
    rdfs:label 'Ip Dispute Id' ;
    rdfs:comment 'Unique identifier for the IP dispute record. Primary key.' ;
    rdfs:domain ind:IpDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryIpEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Ip Employee Id' ;
    rdfs:comment 'Identifier of the internal legal counsel or external law firm assigned to manage this dispute on behalf of the company.' ;
    rdfs:domain ind:IpDispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualLegalCost rdf:type rdf:Property ;
    rdfs:label 'Actual Legal Cost' ;
    rdfs:comment 'Actual total legal and administrative costs incurred in managing and resolving this IP dispute.' ;
    rdfs:domain ind:IpDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allegedViolationDate rdf:type rdf:Property ;
    rdfs:label 'Alleged Violation Date' ;
    rdfs:comment 'Date when the alleged IP infringement or violation is claimed to have occurred or begun.' ;
    rdfs:domain ind:IpDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimAmount rdf:type rdf:Property ;
    rdfs:label 'Claim Amount' ;
    rdfs:comment 'Monetary amount claimed by the claimant as damages or compensation for the alleged IP violation.' ;
    rdfs:domain ind:IpDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimantLegalCounsel rdf:type rdf:Property ;
    rdfs:label 'Claimant Legal Counsel' ;
    rdfs:comment 'Name of the law firm or attorney representing the claimant in this dispute.' ;
    rdfs:domain ind:IpDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantName rdf:type rdf:Property ;
    rdfs:label 'Claimant Name' ;
    rdfs:comment 'Full legal name of the claimant party filing the IP dispute.' ;
    rdfs:domain ind:IpDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityFlag rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Flag' ;
    rdfs:comment 'Indicates whether the dispute and its resolution are subject to confidentiality or non-disclosure agreements.' ;
    rdfs:domain ind:IpDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeDescription rdf:type rdf:Property ;
    rdfs:label 'Dispute Description' ;
    rdfs:comment 'Detailed narrative description of the IP dispute, including the nature of the alleged infringement or violation and supporting facts.' ;
    rdfs:domain ind:IpDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeNumber rdf:type rdf:Property ;
    rdfs:label 'Dispute Number' ;
    rdfs:comment 'Externally-known case number or reference code assigned to this IP dispute for tracking and legal correspondence.' ;
    rdfs:domain ind:IpDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current lifecycle status of the IP dispute case indicating its progression through resolution stages.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeType rdf:type rdf:Property ;
    rdfs:label 'Dispute Type' ;
    rdfs:comment 'Classification of the IP dispute indicating the nature of the claim or violation.' ;
    rdfs:domain ind:IpDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedIpAssetName rdf:type rdf:Property ;
    rdfs:label 'Disputed Ip Asset Name' ;
    rdfs:comment 'Name or title of the IP asset under dispute (e.g., game title, engine SDK, franchise brand).' ;
    rdfs:domain ind:IpDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentRepositoryUrl rdf:type rdf:Property ;
    rdfs:label 'Document Repository Url' ;
    rdfs:comment 'URL or file path to the secure repository containing all legal documents, correspondence, and evidence related to this IP dispute.' ;
    rdfs:domain ind:IpDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedLegalCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Legal Cost' ;
    rdfs:comment 'Estimated total legal and administrative costs associated with managing and resolving this IP dispute.' ;
    rdfs:domain ind:IpDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:litigationStartDate rdf:type rdf:Property ;
    rdfs:label 'Litigation Start Date' ;
    rdfs:comment 'Date when formal litigation or court proceedings were initiated, if the dispute escalated beyond mediation.' ;
    rdfs:domain ind:IpDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mediationStartDate rdf:type rdf:Property ;
    rdfs:label 'Mediation Start Date' ;
    rdfs:comment 'Date when formal mediation or alternative dispute resolution proceedings began, if applicable.' ;
    rdfs:domain ind:IpDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:precedentFlag rdf:type rdf:Property ;
    rdfs:label 'Precedent Flag' ;
    rdfs:comment 'Indicates whether this dispute case sets a legal or business precedent that may impact future IP licensing or dispute handling.' ;
    rdfs:domain ind:IpDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:respondentLegalCounsel rdf:type rdf:Property ;
    rdfs:label 'Respondent Legal Counsel' ;
    rdfs:comment 'Name of the law firm or attorney representing the respondent in this dispute.' ;
    rdfs:domain ind:IpDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:respondentName rdf:type rdf:Property ;
    rdfs:label 'Respondent Name' ;
    rdfs:comment 'Full legal name of the respondent party defending against the IP dispute.' ;
    rdfs:domain ind:IpDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Category' ;
    rdfs:comment 'Primary risk category associated with this IP dispute (e.g., financial loss, brand reputation damage, operational disruption).' ;
    rdfs:domain ind:IpDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementTerms rdf:type rdf:Property ;
    rdfs:label 'Settlement Terms' ;
    rdfs:comment 'Detailed terms and conditions of the settlement agreement, including non-monetary provisions such as licensing adjustments, territory restrictions, or future royalty modifications.' ;
    rdfs:domain ind:IpDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseId rdf:type rdf:Property ;
    rdfs:label 'Franchise Id' ;
    rdfs:comment 'Foreign key linking to title.franchise. Business justification: Franchises often license third-party IP (Marvel, Star Wars, sports leagues). Tracks which franchises depend on external IP rights for portfolio planning and renewal negotiations.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:activeLicenseCount rdf:type rdf:Property ;
    rdfs:label 'Active License Count' ;
    rdfs:comment 'Current number of active licensing agreements in force for this IP asset. Used for portfolio management and capacity planning.' ;
    rdfs:domain ind:LicensedIp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetThumbnailUrl rdf:type rdf:Property ;
    rdfs:label 'Asset Thumbnail Url' ;
    rdfs:comment 'URL path to the thumbnail image or visual representation of the IP asset stored in the Content Delivery Network (CDN) or digital asset management system.' ;
    rdfs:domain ind:LicensedIp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceroRating rdf:type rdf:Property ;
    rdfs:label 'Cero Rating' ;
    rdfs:comment 'CERO content rating classification for Japan (A=All Ages, B=12+, C=15+, D=17+, Z=18+, or Not Rated).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmProtectionEnabled rdf:type rdf:Property ;
    rdfs:label 'Drm Protection Enabled' ;
    rdfs:comment 'Indicates whether this IP asset includes or requires DRM (Digital Rights Management) protection mechanisms for distribution and licensing enforcement.' ;
    rdfs:domain ind:LicensedIp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gracRating rdf:type rdf:Property ;
    rdfs:label 'Grac Rating' ;
    rdfs:comment 'GRAC content rating classification for South Korea (All, 12, 15, 18, or Not Rated).' ;
    rdfs:domain ind:LicensedIp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipCategory rdf:type rdf:Property ;
    rdfs:label 'Ip Category' ;
    rdfs:comment 'High-level category grouping for the IP asset (technology-based, creative content, brand/franchise, or hybrid).' ;
    rdfs:domain ind:LicensedIp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipCode rdf:type rdf:Property ;
    rdfs:label 'Ip Code' ;
    rdfs:comment 'Internal business identifier or SKU (Stock Keeping Unit) code for the IP asset used in licensing agreements and royalty tracking.' ;
    rdfs:domain ind:LicensedIp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipDescription rdf:type rdf:Property ;
    rdfs:label 'Ip Description' ;
    rdfs:comment 'Detailed business description of the intellectual property asset, including its purpose, key features, and licensing value proposition.' ;
    rdfs:domain ind:LicensedIp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipName rdf:type rdf:Property ;
    rdfs:label 'Ip Name' ;
    rdfs:comment 'The official name or title of the intellectual property asset (e.g., \'Unreal Engine 5\', \'Fortnite Brand\', \'Epic Soundtrack Collection\').' ;
    rdfs:domain ind:LicensedIp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipType rdf:type rdf:Property ;
    rdfs:label 'Ip Type' ;
    rdfs:comment 'Classification of the IP asset type. Determines licensing model and royalty structure. [ENUM-REF-CANDIDATE: game_engine|franchise_brand|game_title|character|music_composition|art_asset_library|middleware_library|rating_approved_content_package — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LicensedIp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastLicensedDate rdf:type rdf:Property ;
    rdfs:label 'Last Licensed Date' ;
    rdfs:comment 'Date when the most recent licensing agreement for this IP asset was executed. Null if never licensed.' ;
    rdfs:domain ind:LicensedIp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseModel rdf:type rdf:Property ;
    rdfs:label 'License Model' ;
    rdfs:comment 'Primary licensing business model applied to this IP asset (royalty percentage, fixed fee, subscription, revenue share, hybrid, or not applicable for internal-only IP).' ;
    rdfs:domain ind:LicensedIp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensingAvailabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Licensing Availability Status' ;
    rdfs:comment 'Current availability status of the IP asset for new licensing agreements. Indicates whether the IP can be licensed out and under what terms.' ;
    rdfs:domain ind:LicensedIp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingTagline rdf:type rdf:Property ;
    rdfs:label 'Marketing Tagline' ;
    rdfs:comment 'Official marketing tagline or slogan associated with the IP asset, used in licensing promotional materials and partner communications.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monetizationRestrictions rdf:type rdf:Property ;
    rdfs:label 'Monetization Restrictions' ;
    rdfs:comment 'Description of any restrictions on how licensees can monetize products built with this IP (e.g., \'No Pay-to-Win mechanics allowed\', \'In-App Purchases (IAP) permitted\', \'Ad-supported only\'). Null if no restrictions.' ;
    rdfs:domain ind:LicensedIp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipEntity rdf:type rdf:Property ;
    rdfs:label 'Ownership Entity' ;
    rdfs:comment 'The legal entity or studio that owns the intellectual property rights (e.g., \'Epic Games Inc.\', \'Subsidiary Studio LLC\').' ;
    rdfs:domain ind:LicensedIp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Nature of ownership rights held by the business (wholly owned, joint ownership with partner, licensed from third party, or acquired through M&A).' ;
    rdfs:domain ind:LicensedIp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pegiRating rdf:type rdf:Property ;
    rdfs:label 'Pegi Rating' ;
    rdfs:comment 'PEGI content rating classification for Europe (3, 7, 12, 16, 18, or Not Rated).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'Date when the intellectual property was officially registered with the governing authority.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Registration Jurisdiction' ;
    rdfs:comment 'The legal jurisdiction or territory where the IP is registered (e.g., \'USA\', \'EUR\', \'JPN\', \'Global\'). Uses 3-letter country codes or regional identifiers.' ;
    rdfs:domain ind:LicensedIp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdkVersion rdf:type rdf:Property ;
    rdfs:label 'Sdk Version' ;
    rdfs:comment 'Current version number of the SDK or game engine technology if this IP is a licensable technology platform (e.g., \'UE5.3\', \'Unity 2023.1\'). Null for non-technology IP.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardRoyaltyRate rdf:type rdf:Property ;
    rdfs:label 'Standard Royalty Rate' ;
    rdfs:comment 'Default royalty rate (as decimal, e.g., 0.0500 for 5%) applied to licensees for this IP asset. Actual rates may vary by agreement. Null if not royalty-based.' ;
    rdfs:domain ind:LicensedIp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thirdPartyDependencies rdf:type rdf:Property ;
    rdfs:label 'Third Party Dependencies' ;
    rdfs:comment 'Comma-separated list of third-party middleware, libraries, or licensed components embedded within this IP asset that licensees must also comply with (e.g., \'Havok Physics\', \'Wwise Audio\', \'SpeedTree\').' ;
    rdfs:domain ind:LicensedIp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalRevenueToDate rdf:type rdf:Property ;
    rdfs:label 'Total Revenue To Date' ;
    rdfs:comment 'Cumulative licensing revenue (in USD) generated from this IP asset since inception. Includes royalties, fixed fees, and minimum guarantees.' ;
    rdfs:domain ind:LicensedIp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uskRating rdf:type rdf:Property ;
    rdfs:label 'Usk Rating' ;
    rdfs:comment 'USK content rating classification for Germany (0, 6, 12, 16, 18, or Not Rated).' ;
    rdfs:domain ind:LicensedIp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualRevenueRange rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Range' ;
    rdfs:comment 'The estimated annual revenue range of the licensee organization in USD. Used for partner segmentation and deal sizing. Ranges: under $1M, $1M-$10M, $10M-$50M, $50M-$100M, $100M-$500M, over $500M.' ;
    rdfs:domain ind:Licensee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceTier rdf:type rdf:Property ;
    rdfs:label 'Compliance Tier' ;
    rdfs:comment 'The compliance risk tier assigned to the licensee based on their jurisdiction, business practices, and regulatory history. Tier 1 (high risk, enhanced due diligence), Tier 2 (medium risk, standard due diligence), Tier 3 (low risk, simplified due diligence), Tier 4 (trusted partner, minimal oversight).' ;
    rdfs:domain ind:Licensee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'The maximum credit exposure allowed for this licensee across all active licensing agreements, expressed in USD. Used for financial risk management.' ;
    rdfs:domain ind:Licensee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'The credit rating assigned to the licensee by a recognized credit rating agency (e.g., Moody\'s, S&P, Fitch). Used for financial risk assessment and payment term determination.' ;
    rdfs:domain ind:Licensee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doingBusinessAsName rdf:type rdf:Property ;
    rdfs:label 'Doing Business As Name' ;
    rdfs:comment 'The trade name or DBA name under which the licensee operates, if different from their legal entity name. Used for brand recognition and marketing purposes.' ;
    rdfs:domain ind:Licensee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'The 9-digit DUNS number assigned by Dun & Bradstreet for unique business entity identification. Used for credit checks and business verification.' ;
    rdfs:domain ind:Licensee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeCountRange rdf:type rdf:Property ;
    rdfs:label 'Employee Count Range' ;
    rdfs:comment 'The estimated number of employees at the licensee organization. Used for partner segmentation and capacity assessment. Ranges: 1-10, 11-50, 51-200, 201-500, 501-1000, over 1000.' ;
    rdfs:domain ind:Licensee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstContractDate rdf:type rdf:Property ;
    rdfs:label 'First Contract Date' ;
    rdfs:comment 'The date when the first licensing agreement with this licensee was executed. Used for relationship tenure analysis and anniversary tracking.' ;
    rdfs:domain ind:Licensee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:headquartersAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line1' ;
    rdfs:comment 'The first line of the licensee\'s headquarters street address, including building number and street name.' ;
    rdfs:domain ind:Licensee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line2' ;
    rdfs:comment 'The second line of the licensee\'s headquarters address, typically used for suite, floor, or building information.' ;
    rdfs:domain ind:Licensee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountryCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country Code' ;
    rdfs:comment 'The ISO 3166-1 alpha-3 country code for the licensee\'s headquarters location (e.g., USA, GBR, JPN).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersStateProvince rdf:type rdf:Property ;
    rdfs:label 'Headquarters State Province' ;
    rdfs:comment 'The state, province, or administrative region where the licensee\'s headquarters is located.' ;
    rdfs:domain ind:Licensee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPubliclyTraded rdf:type rdf:Property ;
    rdfs:label 'Is Publicly Traded' ;
    rdfs:comment 'Indicates whether the licensee is a publicly traded company (True) or privately held (False). Used for financial risk assessment and reporting requirements.' ;
    rdfs:domain ind:Licensee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionOfIncorporation rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Of Incorporation' ;
    rdfs:comment 'The country or jurisdiction where the licensee entity is legally incorporated, using ISO 3166-1 alpha-3 country codes (e.g., USA, GBR, JPN).' ;
    rdfs:domain ind:Licensee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Completion Date' ;
    rdfs:comment 'The date when the Know Your Customer due diligence process was completed and the licensee was approved for business. Required for compliance and audit purposes.' ;
    rdfs:domain ind:Licensee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Review Due Date' ;
    rdfs:comment 'The date when the next periodic KYC review is due for this licensee. Typically annual or biennial depending on compliance tier.' ;
    rdfs:domain ind:Licensee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastContractRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Last Contract Renewal Date' ;
    rdfs:comment 'The date when the most recent contract renewal or amendment was executed with this licensee. Used for renewal cycle tracking.' ;
    rdfs:domain ind:Licensee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalEntityName rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name' ;
    rdfs:comment 'The full legal name of the licensee organization as registered in their jurisdiction of incorporation. This is the official name used in all licensing contracts and legal documents.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseeCode rdf:type rdf:Property ;
    rdfs:label 'Licensee Code' ;
    rdfs:comment 'Unique alphanumeric business identifier assigned to the licensee for use in contracts, invoicing, and operational systems. Typically 4-12 characters.' ;
    rdfs:domain ind:Licensee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingStatus rdf:type rdf:Property ;
    rdfs:label 'Onboarding Status' ;
    rdfs:comment 'The current status of the licensee in the onboarding and lifecycle management process. Prospect (initial contact), KYC in progress (Know Your Customer due diligence underway), approved (cleared for contracting), active (has active agreements), suspended (temporarily inactive), terminated (relationship ended).' ;
    rdfs:domain ind:Licensee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredPaymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Preferred Payment Terms Days' ;
    rdfs:comment 'The standard payment terms in days negotiated with this licensee for royalty payments or license fees (e.g., Net 30, Net 60). Used for accounts payable and receivable management.' ;
    rdfs:domain ind:Licensee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPlatformFocus rdf:type rdf:Property ;
    rdfs:label 'Primary Platform Focus' ;
    rdfs:comment 'The primary gaming platform(s) that the licensee focuses on (e.g., PC, Console, Mobile, VR, Cross-Platform). Free-text field to accommodate multiple platforms and emerging technologies. [ENUM-REF-CANDIDATE: pc|console|mobile|vr|ar|xr|web|cross_platform — promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipDirection rdf:type rdf:Property ;
    rdfs:label 'Relationship Direction' ;
    rdfs:comment 'Indicates the direction of the licensing relationship. Licensee (they license FROM Gaming), licensor (they license TO Gaming), or bilateral (both directions active).' ;
    rdfs:domain ind:Licensee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipManagerName rdf:type rdf:Property ;
    rdfs:label 'Relationship Manager Name' ;
    rdfs:comment 'The name of the Gaming employee who serves as the primary relationship manager for this licensee. Responsible for contract negotiations, renewals, and ongoing relationship management.' ;
    rdfs:domain ind:Licensee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specializationArea rdf:type rdf:Property ;
    rdfs:label 'Specialization Area' ;
    rdfs:comment 'The primary area of specialization or expertise for the licensee (e.g., Game Engine Technology, Audio Middleware, Physics Engine, Animation Tools, Multiplayer Infrastructure, Analytics SDK, Monetization Platform, IP Licensing, Music Licensing). Free-text to accommodate diverse specializations.' ;
    rdfs:domain ind:Licensee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockTickerSymbol rdf:type rdf:Property ;
    rdfs:label 'Stock Ticker Symbol' ;
    rdfs:comment 'The stock ticker symbol for the licensee if they are publicly traded. Includes exchange prefix if applicable (e.g., NASDAQ:ATVI, NYSE:EA).' ;
    rdfs:domain ind:Licensee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:middlewareAgreementId rdf:type rdf:Property ;
    rdfs:label 'Middleware Agreement Id' ;
    rdfs:comment 'Unique identifier for the middleware licensing agreement record. Primary key.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MiddlewareAgreement .

ind:attributionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Attribution Required Flag' ;
    rdfs:comment 'Indicates whether the agreement requires public attribution or credit to the middleware vendor in game credits or documentation (True/False).' ;
    rdfs:domain ind:MiddlewareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditRights rdf:type rdf:Property ;
    rdfs:label 'Audit Rights' ;
    rdfs:comment 'Vendor rights to audit licensee usage and revenue reporting: none, annual scheduled audits, on-request, or quarterly.' ;
    rdfs:domain ind:MiddlewareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceObligations rdf:type rdf:Property ;
    rdfs:label 'Compliance Obligations' ;
    rdfs:comment 'Free-text description of specific compliance requirements passed through to game titles using this middleware (e.g., ESRB disclosure requirements, GDPR data handling, platform Technical Requirements Checklist (TRC) compliance).' ;
    rdfs:domain ind:MiddlewareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedLicenseFee rdf:type rdf:Property ;
    rdfs:label 'Fixed License Fee' ;
    rdfs:comment 'One-time or recurring fixed fee for the middleware license. Null for revenue-share-only agreements.' ;
    rdfs:domain ind:MiddlewareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permittedPlatforms rdf:type rdf:Property ;
    rdfs:label 'Permitted Platforms' ;
    rdfs:comment 'Comma-separated list of gaming platforms where the middleware may be deployed (e.g., PlayStation, Xbox, PC, iOS, Android, Nintendo Switch).' ;
    rdfs:domain ind:MiddlewareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postTerminationRights rdf:type rdf:Property ;
    rdfs:label 'Post Termination Rights' ;
    rdfs:comment 'Description of rights and obligations after agreement termination (e.g., continued use in already-shipped titles, removal from future releases, wind-down period).' ;
    rdfs:domain ind:MiddlewareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redistributionRights rdf:type rdf:Property ;
    rdfs:label 'Redistribution Rights' ;
    rdfs:comment 'Defines rights to redistribute middleware components: none (internal use only), embedded-only (within compiled game), limited (with restrictions), or full redistribution.' ;
    rdfs:domain ind:MiddlewareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Threshold Amount' ;
    rdfs:comment 'Minimum revenue threshold before revenue-share royalties apply (e.g., first $1M exempt). Null if no threshold exists.' ;
    rdfs:domain ind:MiddlewareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceCodeAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Source Code Access Flag' ;
    rdfs:comment 'Indicates whether the agreement grants access to middleware source code (True) or binary-only distribution (False).' ;
    rdfs:domain ind:Licensing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportEntitlement rdf:type rdf:Property ;
    rdfs:label 'Support Entitlement' ;
    rdfs:comment 'Level of technical support and maintenance included with the middleware license (e.g., basic email support, premium 24/7 support).' ;
    rdfs:domain ind:MiddlewareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationConditions rdf:type rdf:Property ;
    rdfs:label 'Termination Conditions' ;
    rdfs:comment 'Free-text description of conditions under which either party may terminate the agreement (e.g., breach of terms, non-payment, change of control).' ;
    rdfs:domain ind:Licensing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updateEntitlement rdf:type rdf:Property ;
    rdfs:label 'Update Entitlement' ;
    rdfs:comment 'Scope of software updates and upgrades included: patches only, minor version updates, major version updates, or all updates.' ;
    rdfs:domain ind:MiddlewareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageScope rdf:type rdf:Property ;
    rdfs:label 'Usage Scope' ;
    rdfs:comment 'Defines the breadth of permitted usage: single game title, multiple titles, specific studio, entire enterprise, or restricted to specific platforms (console, PC, mobile).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:composerName rdf:type rdf:Property ;
    rdfs:label 'Composer Name' ;
    rdfs:comment 'Name of the composer or songwriter who created the musical composition.' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compositionRightsStatus rdf:type rdf:Property ;
    rdfs:label 'Composition Rights Status' ;
    rdfs:comment 'Status of musical composition rights clearance (cleared, pending, not required, denied, or conditional).' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRatingRestrictions rdf:type rdf:Property ;
    rdfs:label 'Content Rating Restrictions' ;
    rdfs:comment 'Game content rating restrictions for the licensed music (e.g., ESRB ratings, PEGI ratings). Pipe-separated list of allowed ratings.' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAttributionRequired rdf:type rdf:Property ;
    rdfs:label 'Credit Attribution Required' ;
    rdfs:comment 'Specific credit or attribution text that must be displayed when the music is used (e.g., in game credits, promotional materials).' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:derivativeWorksAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Derivative Works Allowed Flag' ;
    rdfs:comment 'Indicates whether the licensee is permitted to create derivative works or remixes of the licensed music (true) or not (false).' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flatFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Flat Fee Amount' ;
    rdfs:comment 'One-time flat fee payment amount for the synchronization license, if applicable.' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isrcCode rdf:type rdf:Property ;
    rdfs:label 'Isrc Code' ;
    rdfs:comment 'International Standard Recording Code uniquely identifying the sound recording.' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iswcCode rdf:type rdf:Property ;
    rdfs:label 'Iswc Code' ;
    rdfs:comment 'International Standard Musical Work Code uniquely identifying the musical composition.' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'Externally-known unique identifier or contract number for this music synchronization license.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseStatus rdf:type rdf:Property ;
    rdfs:label 'License Status' ;
    rdfs:comment 'Current lifecycle status of the synchronization license (draft, pending approval, active, suspended, expired, terminated, or renewed). [ENUM-REF-CANDIDATE: draft|pending_approval|active|suspended|expired|terminated|renewed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensedDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Licensed Duration Seconds' ;
    rdfs:comment 'Duration of the music track or excerpt licensed for synchronization, measured in seconds.' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:masterRecordingOwner rdf:type rdf:Property ;
    rdfs:label 'Master Recording Owner' ;
    rdfs:comment 'Name of the party (typically a record label or artist) that owns the master recording rights.' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:masterRecordingRightsStatus rdf:type rdf:Property ;
    rdfs:label 'Master Recording Rights Status' ;
    rdfs:comment 'Status of master recording rights clearance (cleared, pending, not required, denied, or conditional).' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaUsageRights rdf:type rdf:Property ;
    rdfs:label 'Media Usage Rights' ;
    rdfs:comment 'Specific media contexts where the music may be synchronized (e.g., in-game background music, cinematic trailer, esports broadcast, streaming platform, promotional materials). Pipe-separated list.' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perUnitRoyaltyRate rdf:type rdf:Property ;
    rdfs:label 'Per Unit Royalty Rate' ;
    rdfs:comment 'Royalty amount payable per unit sold (e.g., per game copy sold), if applicable.' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformRights rdf:type rdf:Property ;
    rdfs:label 'Platform Rights' ;
    rdfs:comment 'Gaming platforms for which synchronization rights are granted (e.g., console, PC, mobile, VR, cloud gaming). Pipe-separated list.' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Pro Clearance Status' ;
    rdfs:comment 'Status of clearance with the Performance Rights Organization for public performance rights (cleared, pending, not required, or denied).' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proName rdf:type rdf:Property ;
    rdfs:label 'Pro Name' ;
    rdfs:comment 'Name of the Performance Rights Organization managing the performance rights (e.g., ASCAP, BMI, SESAC, PRS, SOCAN).' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publisherName rdf:type rdf:Property ;
    rdfs:label 'Publisher Name' ;
    rdfs:comment 'Name of the music publisher that controls the publishing rights to the composition.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syncLicenseType rdf:type rdf:Property ;
    rdfs:label 'Sync License Type' ;
    rdfs:comment 'Classification of the synchronization license based on duration and scope (perpetual, term-limited, project-specific, platform-specific, territory-specific, or buyout).' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackTitle rdf:type rdf:Property ;
    rdfs:label 'Track Title' ;
    rdfs:comment 'The title of the music track or composition being licensed for synchronization.' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRestrictions rdf:type rdf:Property ;
    rdfs:label 'Usage Restrictions' ;
    rdfs:comment 'Specific restrictions or limitations on how the music may be used (e.g., no use in violent scenes, no association with certain content ratings, no use in competitive titles).' ;
    rdfs:domain ind:Licensing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Rating Submission Id' ;
    rdfs:comment 'Unique identifier for the rating submission record. Primary key for the rating submission entity.' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publisherLicenseeId rdf:type rdf:Property ;
    rdfs:label 'Publisher Licensee Id' ;
    rdfs:comment 'Foreign key linking to licensing.licensee. Business justification: Publishers submitting rating applications are licensees. Currently tracked as publisher_name (STRING). Normalizing to publisher_licensee_id FK enables linking to full licensee details (legal entity, c' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Licensee .

ind:assignedRating rdf:type rdf:Property ;
    rdfs:label 'Assigned Rating' ;
    rdfs:comment 'The official rating assigned by the rating board (e.g., ESRB: E, E10+, T, M, AO; PEGI: 3, 7, 12, 16, 18). Null if rating not yet assigned or submission rejected.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentModificationsRequired rdf:type rdf:Property ;
    rdfs:label 'Content Modifications Required' ;
    rdfs:comment 'Indicates whether the rating board mandated content modifications as a condition of the assigned rating. True if modifications required, False if content approved as-is.' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:developerName rdf:type rdf:Property ;
    rdfs:label 'Developer Name' ;
    rdfs:comment 'Name of the game development studio that created the title being rated.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Expected Release Date' ;
    rdfs:comment 'The anticipated commercial release date for the game title. Used by rating boards to prioritize review timelines and ensure rating availability before launch.' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interactiveElements rdf:type rdf:Property ;
    rdfs:label 'Interactive Elements' ;
    rdfs:comment 'Comma-separated list of interactive elements disclosed in the submission (e.g., users interact, shares location, in-game purchases, unrestricted internet, digital purchases). Required by most rating boards for online-enabled games.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipOwnershipConfirmed rdf:type rdf:Property ;
    rdfs:label 'Ip Ownership Confirmed' ;
    rdfs:comment 'Indicates whether the submitter has confirmed ownership or licensing rights to all intellectual property (IP) contained in the game, including third-party assets, music, art, and franchise elements. Required for compliance with IP licensing terms.' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modificationComplianceDate rdf:type rdf:Property ;
    rdfs:label 'Modification Compliance Date' ;
    rdfs:comment 'The date by which mandated content modifications must be completed and verified. Null if no modifications required.' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modificationDescription rdf:type rdf:Property ;
    rdfs:label 'Modification Description' ;
    rdfs:comment 'Detailed description of content modifications mandated by the rating board. Includes specific scenes, dialogue, imagery, or gameplay elements that must be altered or removed. Null if no modifications required.' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingBoard rdf:type rdf:Property ;
    rdfs:label 'Rating Board' ;
    rdfs:comment 'The rating board organization to which this submission was made. ESRB (Entertainment Software Rating Board - North America), PEGI (Pan European Game Information - Europe), USK (Germany), CERO (Japan), GRAC (South Korea), ACB (Australia), DJCTQ (Brazil). [ENUM-REF-CANDIDATE: ESRB|PEGI|USK|CERO|GRAC|ACB|DJCTQ — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Rating Certificate Number' ;
    rdfs:comment 'Unique certificate or registration number issued by the rating board upon successful rating assignment. Used for compliance verification and platform certification.' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Rating Decision Date' ;
    rdfs:comment 'The date on which the rating board issued its rating decision. Null if rating not yet assigned.' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratingEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Rating Effective Date' ;
    rdfs:comment 'The date from which the assigned rating becomes valid and can be used in marketing and distribution. Typically the same as or shortly after the rating decision date.' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratingExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Rating Expiry Date' ;
    rdfs:comment 'The date on which the rating expires and must be renewed, if applicable. Some rating boards require periodic re-certification for live-service games. Null for ratings with no expiry.' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Submission Fee Amount' ;
    rdfs:comment 'The fee charged by the rating board for processing this submission. Amount varies by rating board, submission type, and title complexity.' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submissionFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Submission Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the submission fee (e.g., USD, EUR, GBP, JPY).' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionNumber rdf:type rdf:Property ;
    rdfs:label 'Submission Number' ;
    rdfs:comment 'Externally-known unique identifier for this rating submission, typically assigned by the submitting organization or rating board tracking system.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submitterEmail rdf:type rdf:Property ;
    rdfs:label 'Submitter Email' ;
    rdfs:comment 'Email address of the primary contact for this rating submission. Used for rating board correspondence and notifications.' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submitterName rdf:type rdf:Property ;
    rdfs:label 'Submitter Name' ;
    rdfs:comment 'Name of the individual or organization that submitted the rating application on behalf of the licensee or publisher.' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submitterPhone rdf:type rdf:Property ;
    rdfs:label 'Submitter Phone' ;
    rdfs:comment 'Phone number of the primary contact for this rating submission.' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyContentDisclosed rdf:type rdf:Property ;
    rdfs:label 'Third Party Content Disclosed' ;
    rdfs:comment 'Indicates whether the submission disclosed the use of third-party licensed content (music, art assets, middleware, game engine components). Required for rating board transparency and IP compliance.' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:titleName rdf:type rdf:Property ;
    rdfs:label 'Title Name' ;
    rdfs:comment 'The name of the game title or DLC being submitted for rating as it will appear on the rating certificate and in public-facing materials.' ;
    rdfs:domain ind:Licensing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyPaymentId rdf:type rdf:Property ;
    rdfs:label 'Royalty Payment Id' ;
    rdfs:comment 'Unique identifier for the royalty payment record. Primary key for the royalty payment entity.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payeeLicenseeId rdf:type rdf:Property ;
    rdfs:label 'Payee Licensee Id' ;
    rdfs:comment 'Foreign key linking to licensing.licensee. Business justification: Royalty payment payees are licensees (either receiving royalties for outbound licenses or paying royalties for inbound licenses). Currently tracked as payee_name (STRING) and payee_identifier (STRING)' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Licensee .

ind:bankReference rdf:type rdf:Property ;
    rdfs:label 'Bank Reference' ;
    rdfs:comment 'Bank transaction reference or confirmation number provided by the financial institution. Used for payment tracing and audit trail.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latePaymentFlag rdf:type rdf:Property ;
    rdfs:label 'Late Payment Flag' ;
    rdfs:comment 'Boolean indicator of whether this payment was made after the contractual due date. True indicates late payment, which may trigger penalty clauses or interest charges per the licensing agreement.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latePaymentPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Late Payment Penalty Amount' ;
    rdfs:comment 'Additional penalty or interest amount charged or owed due to late payment, as defined in the licensing agreement. Null if payment was on time or no penalty applies.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payment Amount' ;
    rdfs:comment 'The final net amount paid or received after applying withholding taxes, fees, and any other adjustments. This is the actual cash flow amount.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payeeIdentifier rdf:type rdf:Property ;
    rdfs:label 'Payee Identifier' ;
    rdfs:comment 'External identifier for the payee party, such as a vendor number, licensee code, or partner ID. Used for cross-system reconciliation.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'The gross monetary value of the royalty payment in the original transaction currency, before any adjustments or fees.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentAmountReportingCurrency rdf:type rdf:Property ;
    rdfs:label 'Payment Amount Reporting Currency' ;
    rdfs:comment 'The payment amount converted to the enterprise\'s standard reporting currency using the applied exchange rate. Used for consolidated financial reporting and analytics.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentCurrency rdf:type rdf:Property ;
    rdfs:label 'Payment Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the payment amount (e.g., USD, EUR, GBP, JPY). Represents the currency in which the payment was originally denominated.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDirection rdf:type rdf:Property ;
    rdfs:label 'Payment Direction' ;
    rdfs:comment 'Indicates whether this is an inbound payment (received from a licensee for use of our IP or game engine technology) or an outbound payment (paid to a rights holder for licensed content, music, art assets, or third-party IP).' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentNotes rdf:type rdf:Property ;
    rdfs:label 'Payment Notes' ;
    rdfs:comment 'Free-text notes or comments related to this royalty payment. May include special instructions, explanations of adjustments, or contextual information for finance and legal teams.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Payment Period End Date' ;
    rdfs:comment 'The end date of the reporting period covered by this royalty payment. Defines the conclusion of the usage or revenue period for which royalties are being settled.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Payment Period Start Date' ;
    rdfs:comment 'The start date of the reporting period covered by this royalty payment. Defines the beginning of the usage or revenue period for which royalties are being settled.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentProcessorFee rdf:type rdf:Property ;
    rdfs:label 'Payment Processor Fee' ;
    rdfs:comment 'Transaction fee charged by the payment processor or financial institution for executing the royalty payment. Deducted from the gross payment amount.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Variance Amount' ;
    rdfs:comment 'The monetary difference between the payment amount and the expected amount per the royalty report. Positive values indicate overpayment, negative values indicate underpayment. Null if fully reconciled.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingTaxRate rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Rate' ;
    rdfs:comment 'The percentage rate of withholding tax applied to this royalty payment, as mandated by tax treaty or local tax law. Expressed as a percentage (e.g., 15.00 for 15%).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicableRoyaltyRate rdf:type rdf:Property ;
    rdfs:label 'Applicable Royalty Rate' ;
    rdfs:comment 'The royalty rate percentage applied to the net revenue for this reporting period. May vary based on tiered thresholds, product type, or territory as defined in the license agreement.' ;
    rdfs:domain ind:RoyaltyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attachmentUrl rdf:type rdf:Property ;
    rdfs:label 'Attachment Url' ;
    rdfs:comment 'URL or file path to supporting documentation attached to this royalty report (e.g., detailed sales breakdowns, platform reports, reconciliation files).' ;
    rdfs:domain ind:RoyaltyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Flag' ;
    rdfs:comment 'Indicates whether this royalty report has been flagged for audit or detailed review due to discrepancies, thresholds, or compliance requirements.' ;
    rdfs:domain ind:RoyaltyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumGuaranteeCredit rdf:type rdf:Property ;
    rdfs:label 'Minimum Guarantee Credit' ;
    rdfs:comment 'Amount of minimum guarantee advance recouped or credited against this royalty payment. Tracks progress toward recoupment of upfront payments.' ;
    rdfs:domain ind:RoyaltyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportType rdf:type rdf:Property ;
    rdfs:label 'Report Type' ;
    rdfs:comment 'Classification of the royalty report based on reporting frequency or purpose (e.g., quarterly, monthly, annual, ad-hoc, final settlement).' ;
    rdfs:domain ind:Licensing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedDeductions rdf:type rdf:Property ;
    rdfs:label 'Reported Deductions' ;
    rdfs:comment 'Total deductions applied to gross revenue as permitted by the license agreement (e.g., platform fees, returns, refunds, taxes). Reduces the royalty base.' ;
    rdfs:domain ind:RoyaltyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportedGrossRevenue rdf:type rdf:Property ;
    rdfs:label 'Reported Gross Revenue' ;
    rdfs:comment 'Total gross revenue reported by the licensee for the reporting period, before any deductions or adjustments. Basis for royalty calculation.' ;
    rdfs:domain ind:RoyaltyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportedNetRevenue rdf:type rdf:Property ;
    rdfs:label 'Reported Net Revenue' ;
    rdfs:comment 'Net revenue after deductions, representing the royalty-bearing revenue base. Calculated as gross revenue minus deductions.' ;
    rdfs:domain ind:RoyaltyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportedUnitSales rdf:type rdf:Property ;
    rdfs:label 'Reported Unit Sales' ;
    rdfs:comment 'Total number of units sold or distributed during the reporting period, as reported by the licensee. May include game copies, DLC, or licensed content units.' ;
    rdfs:domain ind:RoyaltyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Review Completed Date' ;
    rdfs:comment 'The date on which the internal review of this royalty report was completed and a status decision (accepted, disputed, rejected) was made.' ;
    rdfs:domain ind:RoyaltyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'The channel or mechanism through which the royalty report was submitted (e.g., licensing portal, email, API integration, manual upload, FTP/SFTP).' ;
    rdfs:domain ind:RoyaltyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyScheduleId rdf:type rdf:Property ;
    rdfs:label 'Royalty Schedule Id' ;
    rdfs:comment 'Unique identifier for the royalty schedule record. Primary key.' ;
    rdfs:domain ind:RoyaltySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByScheduleRoyaltyScheduleId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Schedule Royalty Schedule Id' ;
    rdfs:comment 'Reference to the royalty_schedule_id that supersedes this schedule when a new version is activated. Null if this is the current active schedule.' ;
    rdfs:domain ind:RoyaltySchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoyaltySchedule .

ind:auditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Required Flag' ;
    rdfs:comment 'Indicates whether this royalty schedule requires periodic third-party audit of reported figures (True/False).' ;
    rdfs:domain ind:Licensing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Base Rate Percentage' ;
    rdfs:comment 'The baseline royalty rate expressed as a percentage (e.g., 5.0000 for 5%). Applicable when royalty_basis is revenue-based.' ;
    rdfs:domain ind:RoyaltySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumCapAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Cap Amount' ;
    rdfs:comment 'The maximum royalty payment cap per reporting period. Null if no cap applies.' ;
    rdfs:domain ind:RoyaltySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformDeductionRule rdf:type rdf:Property ;
    rdfs:label 'Platform Deduction Rule' ;
    rdfs:comment 'Specifies whether platform fees (e.g., Apple App Store 30%, Steam 30%, console first-party fees) are deducted before or after calculating royalties.' ;
    rdfs:domain ind:RoyaltySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productScope rdf:type rdf:Property ;
    rdfs:label 'Product Scope' ;
    rdfs:comment 'The specific game titles, SKUs (Stock Keeping Units), or product lines covered by this royalty schedule. May reference specific game IPs (Intellectual Property) or engine versions.' ;
    rdfs:domain ind:RoyaltySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateStructure rdf:type rdf:Property ;
    rdfs:label 'Rate Structure' ;
    rdfs:comment 'Describes how the royalty rate is applied: flat (single rate), tiered (different rates at different breakpoints), progressive (rate increases with volume), regressive (rate decreases with volume), or custom formula.' ;
    rdfs:domain ind:RoyaltySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoupmentAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Recoupment Allowed Flag' ;
    rdfs:comment 'Indicates whether advance payments or minimum guarantees can be recouped against future royalty earnings (True/False).' ;
    rdfs:domain ind:RoyaltySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingPeriodCadence rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Cadence' ;
    rdfs:comment 'The frequency at which royalty calculations and payments are reported and settled (e.g., monthly, quarterly, annually).' ;
    rdfs:domain ind:RoyaltySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Method' ;
    rdfs:comment 'The accounting method used to recognize royalty revenue or expense (accrual, cash basis, milestone-based, or usage-based).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyScheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Royalty Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the royalty schedule.' ;
    rdfs:domain ind:RoyaltySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleName rdf:type rdf:Property ;
    rdfs:label 'Schedule Name' ;
    rdfs:comment 'Business-friendly name or label for this royalty schedule (e.g., \'Unity Pro Tier 1\', \'Unreal Engine Standard\', \'IP License Q1 2024\').' ;
    rdfs:domain ind:RoyaltySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleType rdf:type rdf:Property ;
    rdfs:label 'Schedule Type' ;
    rdfs:comment 'Classification of the royalty schedule based on the nature of the licensing arrangement. [ENUM-REF-CANDIDATE: outbound_engine_licensing|inbound_ip_licensing|middleware_licensing|music_licensing|art_asset_licensing|franchise_partnership|technology_sdk — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RoyaltySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tier1RatePercentage rdf:type rdf:Property ;
    rdfs:label 'Tier 1 Rate Percentage' ;
    rdfs:comment 'The royalty rate percentage applicable to revenue or units within the first tier. Null if not applicable.' ;
    rdfs:domain ind:RoyaltySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier1Threshold rdf:type rdf:Property ;
    rdfs:label 'Tier 1 Threshold' ;
    rdfs:comment 'The upper boundary value for the first royalty rate tier. Null if rate structure is flat or only one tier exists.' ;
    rdfs:domain ind:RoyaltySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier2RatePercentage rdf:type rdf:Property ;
    rdfs:label 'Tier 2 Rate Percentage' ;
    rdfs:comment 'The royalty rate percentage applicable to revenue or units within the second tier. Null if not applicable.' ;
    rdfs:domain ind:RoyaltySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier2Threshold rdf:type rdf:Property ;
    rdfs:label 'Tier 2 Threshold' ;
    rdfs:comment 'The upper boundary value for the second royalty rate tier. Null if fewer than two tiers exist.' ;
    rdfs:domain ind:RoyaltySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier3RatePercentage rdf:type rdf:Property ;
    rdfs:label 'Tier 3 Rate Percentage' ;
    rdfs:comment 'The royalty rate percentage applicable to revenue or units within the third tier. Null if not applicable.' ;
    rdfs:domain ind:RoyaltySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier3Threshold rdf:type rdf:Property ;
    rdfs:label 'Tier 3 Threshold' ;
    rdfs:comment 'The upper boundary value for the third royalty rate tier. Null if fewer than three tiers exist.' ;
    rdfs:domain ind:RoyaltySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingTaxRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Rate Percentage' ;
    rdfs:comment 'The percentage of royalty payment subject to withholding tax, if applicable under the jurisdiction of the licensee or licensor. Null if no withholding applies.' ;
    rdfs:domain ind:RoyaltySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sublicenseId rdf:type rdf:Property ;
    rdfs:label 'Sublicense Id' ;
    rdfs:comment 'Unique identifier for the sublicense arrangement. Primary key.' ;
    rdfs:domain ind:Sublicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryLicenseeId rdf:type rdf:Property ;
    rdfs:label 'Primary Licensee Id' ;
    rdfs:comment 'Reference to the original licensee who is granting sublicense rights to the sublicensee under their master agreement.' ;
    rdfs:domain ind:Sublicense ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Licensee .

ind:complianceMonitoringRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Monitoring Required Flag' ;
    rdfs:comment 'Indicates whether the sublicensee must submit regular compliance reports or undergo audits to verify adherence to sublicense terms.' ;
    rdfs:domain ind:Sublicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passThroughRoyaltyRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Pass Through Royalty Rate Percentage' ;
    rdfs:comment 'Percentage of sublicense revenue that the primary licensee must pass through to the original licensor as per the parent agreement terms.' ;
    rdfs:domain ind:Sublicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postTerminationObligations rdf:type rdf:Property ;
    rdfs:label 'Post Termination Obligations' ;
    rdfs:comment 'Requirements the sublicensee must fulfill after sublicense termination, such as ceasing use, destroying copies, or completing sell-off periods.' ;
    rdfs:domain ind:Sublicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingBoardComplianceRequirements rdf:type rdf:Property ;
    rdfs:label 'Rating Board Compliance Requirements' ;
    rdfs:comment 'Specific content rating obligations the sublicensee must meet (ESRB, PEGI, CERO, etc.) when using the sublicensed IP in their products.' ;
    rdfs:domain ind:Sublicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sublicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Sublicense Number' ;
    rdfs:comment 'Externally-known unique business identifier for this sublicense arrangement, used in contracts and communications.' ;
    rdfs:domain ind:Sublicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sublicenseStatus rdf:type rdf:Property ;
    rdfs:label 'Sublicense Status' ;
    rdfs:comment 'Current lifecycle state of the sublicense arrangement indicating whether it is pending approval, active, suspended, expired, terminated, or revoked.' ;
    rdfs:domain ind:Sublicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sublicenseType rdf:type rdf:Property ;
    rdfs:label 'Sublicense Type' ;
    rdfs:comment 'Classification of the sublicensing arrangement based on the nature of rights granted (SDK access for contractors, co-development partnerships, distribution rights, etc.).' ;
    rdfs:domain ind:Sublicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sublicensedIpScope rdf:type rdf:Property ;
    rdfs:label 'Sublicensed Ip Scope' ;
    rdfs:comment 'Detailed description of the specific IP assets, SDK components, game engine features, or technology elements covered under this sublicense.' ;
    rdfs:domain ind:Sublicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sublicenseeRoyaltyRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Sublicensee Royalty Rate Percentage' ;
    rdfs:comment 'Percentage of revenue that the sublicensee must pay to the primary licensee for use of the sublicensed IP.' ;
    rdfs:domain ind:Sublicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageReportId rdf:type rdf:Property ;
    rdfs:label 'Usage Report Id' ;
    rdfs:comment 'Unique identifier for the usage report record. Primary key.' ;
    rdfs:domain ind:UsageReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactName rdf:type rdf:Property ;
    rdfs:label 'Contact Name' ;
    rdfs:comment 'Name of the licensee contact person responsible for this usage report submission.' ;
    rdfs:domain ind:UsageReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Date' ;
    rdfs:comment 'Date when the dispute was raised regarding this usage report.' ;
    rdfs:domain ind:UsageReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedValue rdf:type rdf:Property ;
    rdfs:label 'Expected Value' ;
    rdfs:comment 'Expected or forecasted usage value for the reporting period based on historical trends or contractual projections.' ;
    rdfs:domain ind:UsageReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metricType rdf:type rdf:Property ;
    rdfs:label 'Metric Type' ;
    rdfs:comment 'Type of operational consumption metric being reported (e.g., SDK active seat counts, DAU/MAU figures, impression counts, API call volumes). [ENUM-REF-CANDIDATE: active_seats|deployment_count|dau|mau|impression_count|play_count|api_calls — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:UsageReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorPeriodValue rdf:type rdf:Property ;
    rdfs:label 'Prior Period Value' ;
    rdfs:comment 'Reported value from the previous reporting period for variance comparison.' ;
    rdfs:domain ind:UsageReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportedValue rdf:type rdf:Property ;
    rdfs:label 'Reported Value' ;
    rdfs:comment 'Numeric value of the usage metric reported by the licensee for the reporting period.' ;
    rdfs:domain ind:UsageReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End' ;
    rdfs:comment 'End date of the period covered by this usage report.' ;
    rdfs:domain ind:UsageReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start' ;
    rdfs:comment 'Start date of the period covered by this usage report.' ;
    rdfs:domain ind:UsageReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:territory rdf:type rdf:Property ;
    rdfs:label 'Territory' ;
    rdfs:comment 'Geographic territory or market where the usage occurred, represented as ISO 3166-1 alpha-3 country code.' ;
    rdfs:domain ind:UsageReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Unit in which the reported value is measured (e.g., seats, users, impressions, API calls). [ENUM-REF-CANDIDATE: seats|deployments|users|impressions|plays|calls|sessions|downloads — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:UsageReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceFlag rdf:type rdf:Property ;
    rdfs:label 'Variance Flag' ;
    rdfs:comment 'Boolean indicator of whether the reported usage shows significant variance compared to prior periods or expected values.' ;
    rdfs:domain ind:UsageReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'Percentage variance of the reported value compared to the prior period or expected baseline.' ;
    rdfs:domain ind:UsageReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creativeProducerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Creative Producer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Gaming studios require accountability tracking for creative assets. Creative producer is currently denormalized text; linking to employee enables performance reviews, workload analysis, asset portfoli' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:gameEditionId rdf:type rdf:Property ;
    rdfs:label 'Game Edition Id' ;
    rdfs:comment 'Foreign key linking to title.game_edition. Business justification: Ad creatives frequently promote specific editions ("Pre-Order Ultimate Edition"). Creative approval workflows verify edition-specific claims (bonus content, pricing tier). Performance marketing tracks' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GameEdition .

ind:agencyName rdf:type rdf:Property ;
    rdfs:label 'Agency Name' ;
    rdfs:comment 'Name of the external creative agency that produced this asset, if applicable. Null for in-house creatives.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archivedDate rdf:type rdf:Property ;
    rdfs:label 'Archived Date' ;
    rdfs:comment 'Date when the creative was archived and removed from active use. Null if still active or not yet archived.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bodyText rdf:type rdf:Property ;
    rdfs:label 'Body Text' ;
    rdfs:comment 'Body copy or description text used in the creative. Provides additional context and messaging detail.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callToAction rdf:type rdf:Property ;
    rdfs:label 'Call To Action' ;
    rdfs:comment 'The call-to-action text or button label used in the creative. Examples: Install Now, Play Free, Download Today, Join the Battle.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeCode rdf:type rdf:Property ;
    rdfs:label 'Creative Code' ;
    rdfs:comment 'Unique business identifier or SKU (Stock Keeping Unit) for the creative asset. Used for tracking and attribution across platforms.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeConcept rdf:type rdf:Property ;
    rdfs:label 'Creative Concept' ;
    rdfs:comment 'The creative concept, theme, or messaging strategy used in the asset. Examples: character showcase, gameplay highlight, story teaser, competitive feature.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeName rdf:type rdf:Property ;
    rdfs:label 'Creative Name' ;
    rdfs:comment 'Human-readable name or title of the advertising creative asset. Used for identification and reference in campaign management systems.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeStatus rdf:type rdf:Property ;
    rdfs:label 'Creative Status' ;
    rdfs:comment 'Current lifecycle status of the creative asset. Tracks approval workflow and active deployment state. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|paused|archived|rejected — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esrbRatingCompliant rdf:type rdf:Property ;
    rdfs:label 'Esrb Rating Compliant' ;
    rdfs:comment 'Boolean flag indicating whether the creative content complies with ESRB content rating guidelines for the associated game title. Critical for North American market compliance.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fileReferenceUri rdf:type rdf:Property ;
    rdfs:label 'File Reference Uri' ;
    rdfs:comment 'URI or path reference to the creative asset file in the content delivery network or digital asset management system. Links to the actual media file.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstDeployedDate rdf:type rdf:Property ;
    rdfs:label 'First Deployed Date' ;
    rdfs:comment 'Date when the creative was first deployed in a live campaign. Marks the start of the creative\'s active lifecycle.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geoTargetCountries rdf:type rdf:Property ;
    rdfs:label 'Geo Target Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes this creative is targeted for. Used for localization and regional compliance.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headlineText rdf:type rdf:Property ;
    rdfs:label 'Headline Text' ;
    rdfs:comment 'Primary headline or title text displayed in the creative. Used for messaging analysis and ASO (App Store Optimization) alignment.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heightPixels rdf:type rdf:Property ;
    rdfs:label 'Height Pixels' ;
    rdfs:comment 'Height dimension of the creative asset in pixels. Used for platform compatibility validation and placement optimization.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isStoreListingCreative rdf:type rdf:Property ;
    rdfs:label 'Is Store Listing Creative' ;
    rdfs:comment 'Boolean flag indicating whether this creative is used in app store listings (Apple App Store, Google Play) as opposed to paid user acquisition campaigns. True for store assets, false for UA ads.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastDeployedDate rdf:type rdf:Property ;
    rdfs:label 'Last Deployed Date' ;
    rdfs:comment 'Date when the creative was most recently deployed in a campaign. Used for recency analysis and creative refresh planning.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pegiRatingCompliant rdf:type rdf:Property ;
    rdfs:label 'Pegi Rating Compliant' ;
    rdfs:comment 'Boolean flag indicating whether the creative content complies with PEGI content rating guidelines for the associated game title. Critical for European market compliance.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceTier rdf:type rdf:Property ;
    rdfs:label 'Performance Tier' ;
    rdfs:comment 'Classification of creative performance based on KPI (Key Performance Indicator) benchmarks such as CTR (Click-Through Rate), CPI (Cost Per Install), and conversion rate. Updated periodically based on campaign analytics.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionCostUsd rdf:type rdf:Property ;
    rdfs:label 'Production Cost Usd' ;
    rdfs:comment 'Total cost to produce this creative asset in USD. Used for ROI (Return on Investment) and ROAS (Return on Ad Spend) analysis.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetAudienceSegment rdf:type rdf:Property ;
    rdfs:label 'Target Audience Segment' ;
    rdfs:comment 'The player audience segment this creative is targeting. Examples: core gamers, casual players, lapsed users, high-value whales, new installs.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thumbnailUri rdf:type rdf:Property ;
    rdfs:label 'Thumbnail Uri' ;
    rdfs:comment 'URI reference to a thumbnail or preview image of the creative. Used for quick visual identification in campaign management dashboards.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:widthPixels rdf:type rdf:Property ;
    rdfs:label 'Width Pixels' ;
    rdfs:comment 'Width dimension of the creative asset in pixels. Used for platform compatibility validation and placement optimization.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adNetworkId rdf:type rdf:Property ;
    rdfs:label 'Ad Network Id' ;
    rdfs:comment 'Unique identifier for the advertising network or media source. Primary key.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdNetwork .

ind:apiKeyEncrypted rdf:type rdf:Property ;
    rdfs:label 'Api Key Encrypted' ;
    rdfs:comment 'Encrypted API key or authentication token used for programmatic integration with the networks reporting and campaign management APIs. Stored in encrypted format for security.' ;
    rdfs:domain ind:AdNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionWindowClickDays rdf:type rdf:Property ;
    rdfs:label 'Attribution Window Click Days' ;
    rdfs:comment 'Number of days after a click during which an install or conversion event can be attributed to this network. Standard values range from 1 to 30 days.' ;
    rdfs:domain ind:AdNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attributionWindowImpressionDays rdf:type rdf:Property ;
    rdfs:label 'Attribution Window Impression Days' ;
    rdfs:comment 'Number of days after an ad impression during which an install or conversion event can be attributed to this network. Typically shorter than click window (1-7 days).' ;
    rdfs:domain ind:AdNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costReportingMethod rdf:type rdf:Property ;
    rdfs:label 'Cost Reporting Method' ;
    rdfs:comment 'Primary granularity at which the network reports cost data for spend reconciliation. Impression = CPM model; Click = CPC model; Install = CPI model; Event = CPA/CPE model; None = no automated cost reporting.' ;
    rdfs:domain ind:AdNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Agreement Status' ;
    rdfs:comment 'Current status of the legal data sharing agreement between the business and the network, governing the exchange of attribution and cost data.' ;
    rdfs:domain ind:AdNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudProtectionTier rdf:type rdf:Property ;
    rdfs:label 'Fraud Protection Tier' ;
    rdfs:comment 'Classification of the networks fraud prevention and validation capabilities. Certified = MMP-certified fraud protection; Standard = basic validation; Unverified = no formal fraud protection.' ;
    rdfs:domain ind:AdNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationType rdf:type rdf:Property ;
    rdfs:label 'Integration Type' ;
    rdfs:comment 'Technical integration method used to connect the network with the MMP attribution stack. SDK = Software Development Kit embedded in app; S2S = Server-to-Server postback; API = Application Programming Interface; Manual = manual upload.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrivacySandboxCompatible rdf:type rdf:Property ;
    rdfs:label 'Is Privacy Sandbox Compatible' ;
    rdfs:comment 'Indicates whether the network supports Googles Privacy Sandbox attribution APIs for privacy-preserving measurement on Android.' ;
    rdfs:domain ind:AdNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSan rdf:type rdf:Property ;
    rdfs:label 'Is San' ;
    rdfs:comment 'Indicates whether the network is a Self-Attributing Network that reports its own attribution data rather than relying solely on MMP attribution logic (e.g., Facebook, Google, Apple Search Ads, TikTok).' ;
    rdfs:domain ind:AdNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSkanCompatible rdf:type rdf:Property ;
    rdfs:label 'Is Skan Compatible' ;
    rdfs:comment 'Indicates whether the network supports Apples SKAdNetwork framework for privacy-preserving attribution on iOS 14.5+.' ;
    rdfs:domain ind:AdNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCampaignDate rdf:type rdf:Property ;
    rdfs:label 'Last Campaign Date' ;
    rdfs:comment 'Date of the most recent campaign activity or spend recorded for this network. Used to identify inactive networks.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monthlySpendCapUsd rdf:type rdf:Property ;
    rdfs:label 'Monthly Spend Cap Usd' ;
    rdfs:comment 'Maximum monthly advertising spend budget allocated to this network in US Dollars. Used for budget pacing and alerts.' ;
    rdfs:domain ind:AdNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkCode rdf:type rdf:Property ;
    rdfs:label 'Network Code' ;
    rdfs:comment 'Standardized network identifier code registered in the MMP system (AppsFlyer or Adjust) for attribution and reporting purposes.' ;
    rdfs:domain ind:AdNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkName rdf:type rdf:Property ;
    rdfs:label 'Network Name' ;
    rdfs:comment 'Full business name of the advertising network or media source (e.g., Meta Ads, Google UAC, Apple Search Ads, ironSource, Unity Ads, AppLovin, TikTok Ads).' ;
    rdfs:domain ind:AdNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkStatus rdf:type rdf:Property ;
    rdfs:label 'Network Status' ;
    rdfs:comment 'Current operational status of the network in the marketing attribution stack. Active = live and running campaigns; Paused = temporarily disabled; Deprecated = phased out; Onboarding = integration in progress; Suspended = blocked due to fraud or policy violation.' ;
    rdfs:domain ind:AdNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkTier rdf:type rdf:Property ;
    rdfs:label 'Network Tier' ;
    rdfs:comment 'Internal classification of the networks strategic importance and spend volume. Tier 1 = top strategic partners with highest spend; Tier 2 = secondary partners; Tier 3 = tactical/test partners; Experimental = trial/pilot networks.' ;
    rdfs:domain ind:AdNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'Date when the network was first integrated and configured in the MMP attribution stack.' ;
    rdfs:domain ind:AdNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Number of days after invoice date that payment is due to the network (e.g., Net 30, Net 60).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postbackUrl rdf:type rdf:Property ;
    rdfs:label 'Postback Url' ;
    rdfs:comment 'Server-to-server postback URL endpoint provided by the network to receive attribution and conversion event notifications from the MMP.' ;
    rdfs:domain ind:AdNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportsCostApi rdf:type rdf:Property ;
    rdfs:label 'Supports Cost Api' ;
    rdfs:comment 'Indicates whether the network provides an API for automated cost data ingestion into the MMP for spend reconciliation.' ;
    rdfs:domain ind:AdNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsDeepLinking rdf:type rdf:Property ;
    rdfs:label 'Supports Deep Linking' ;
    rdfs:comment 'Indicates whether the network supports deep linking to specific in-app content or experiences from ad creative.' ;
    rdfs:domain ind:AdNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsRetargeting rdf:type rdf:Property ;
    rdfs:label 'Supports Retargeting' ;
    rdfs:comment 'Indicates whether the network supports retargeting campaigns to re-engage existing players or lapsed users.' ;
    rdfs:domain ind:AdNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:asoListingId rdf:type rdf:Property ;
    rdfs:label 'Aso Listing Id' ;
    rdfs:comment 'Unique identifier for the ASO listing record. Primary key.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AsoListing .

ind:activeExperimentFlag rdf:type rdf:Property ;
    rdfs:label 'Active Experiment Flag' ;
    rdfs:comment 'Indicates whether this listing is currently part of an active A/B test or ASO experiment. True = experiment running; False = baseline or no experiment.' ;
    rdfs:domain ind:AsoListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:averageRating rdf:type rdf:Property ;
    rdfs:label 'Average Rating' ;
    rdfs:comment 'The average user rating for the game on this storefront, typically on a 1-5 scale. Critical ASO factor influencing conversion.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:containsAdsFlag rdf:type rdf:Property ;
    rdfs:label 'Contains Ads Flag' ;
    rdfs:comment 'Indicates whether the game displays advertising to users. Required disclosure on most storefronts.' ;
    rdfs:domain ind:AsoListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentVersion rdf:type rdf:Property ;
    rdfs:label 'Current Version' ;
    rdfs:comment 'The current published version number of the game on this storefront. Follows platform-specific versioning conventions (e.g., semantic versioning).' ;
    rdfs:domain ind:AsoListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataClassification rdf:type rdf:Property ;
    rdfs:label 'Data Classification' ;
    rdfs:comment 'The data classification level for this ASO listing record. Public = publicly visible store data; Internal = internal marketing data; Confidential = competitive strategy data; Restricted = highly sensitive business data.' ;
    rdfs:domain ind:AsoListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentEndDate rdf:type rdf:Property ;
    rdfs:label 'Experiment End Date' ;
    rdfs:comment 'The date when the ASO experiment or A/B test concluded for this listing variant. Null if experiment is ongoing or not applicable.' ;
    rdfs:domain ind:AsoListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:experimentStartDate rdf:type rdf:Property ;
    rdfs:label 'Experiment Start Date' ;
    rdfs:comment 'The date when the ASO experiment or A/B test began for this listing variant. Null if not part of an experiment.' ;
    rdfs:domain ind:AsoListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:experimentVariantCode rdf:type rdf:Property ;
    rdfs:label 'Experiment Variant Code' ;
    rdfs:comment 'Identifier for the specific A/B test variant this listing represents (e.g., control, variant_a, variant_b). Null if not part of an experiment.' ;
    rdfs:domain ind:AsoListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureGraphicReference rdf:type rdf:Property ;
    rdfs:label 'Feature Graphic Reference' ;
    rdfs:comment 'Asset reference or URL for the primary feature graphic or hero image used in store promotions and featured placements. Platform-specific dimension requirements apply.' ;
    rdfs:domain ind:AsoListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:historicalConversionRate rdf:type rdf:Property ;
    rdfs:label 'Historical Conversion Rate' ;
    rdfs:comment 'The historical store page visit-to-install conversion rate for this listing, expressed as a decimal (e.g., 0.1250 = 12.50%). Used to measure ASO effectiveness and compare experiment variants.' ;
    rdfs:domain ind:AsoListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impressionCount rdf:type rdf:Property ;
    rdfs:label 'Impression Count' ;
    rdfs:comment 'Total number of times this store listing was displayed in search results or browse views. Key metric for ASO visibility tracking.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inAppPurchaseFlag rdf:type rdf:Property ;
    rdfs:label 'In App Purchase Flag' ;
    rdfs:comment 'Indicates whether the game offers in-app purchases (IAP) or microtransactions (MTX). Required disclosure on most storefronts.' ;
    rdfs:domain ind:AsoListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:installCount rdf:type rdf:Property ;
    rdfs:label 'Install Count' ;
    rdfs:comment 'Total number of installs attributed to this store listing. Used to calculate conversion rate from page views.' ;
    rdfs:domain ind:AsoListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:keywordSet rdf:type rdf:Property ;
    rdfs:label 'Keyword Set' ;
    rdfs:comment 'Comma-separated list of keywords and phrases used for App Store Optimization (ASO) to improve search discoverability. Platform-specific keyword strategies apply.' ;
    rdfs:domain ind:AsoListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMetadataUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Metadata Update Date' ;
    rdfs:comment 'The date when the store listing metadata (title, description, keywords, screenshots) was last updated. Distinct from version release date.' ;
    rdfs:domain ind:AsoListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:listingStatus rdf:type rdf:Property ;
    rdfs:label 'Listing Status' ;
    rdfs:comment 'Current lifecycle status of the store listing. Draft = being prepared; Pending Review = submitted to platform for approval; Live = published and discoverable; Suspended = temporarily removed; Delisted = permanently removed; Archived = historical record.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listingTitle rdf:type rdf:Property ;
    rdfs:label 'Listing Title' ;
    rdfs:comment 'The display title of the game as it appears on the storefront. Optimized for discoverability and conversion.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localizationLocale rdf:type rdf:Property ;
    rdfs:label 'Localization Locale' ;
    rdfs:comment 'The language and regional locale for this listing variant (e.g., en-US, ja-JP, de-DE, fr-FR). Each locale may have distinct metadata for ASO optimization.' ;
    rdfs:domain ind:AsoListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longDescription rdf:type rdf:Property ;
    rdfs:label 'Long Description' ;
    rdfs:comment 'Full detailed description of the game including features, gameplay, story, and selling points. Displayed on the full product page.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingUrl rdf:type rdf:Property ;
    rdfs:label 'Marketing Url' ;
    rdfs:comment 'URL to the games official marketing website or landing page. Used for additional promotional information and community links.' ;
    rdfs:domain ind:AsoListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pageViewCount rdf:type rdf:Property ;
    rdfs:label 'Page View Count' ;
    rdfs:comment 'Total number of times users viewed the full product page for this listing. Used to calculate click-through rate (CTR) from impressions.' ;
    rdfs:domain ind:AsoListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceTier rdf:type rdf:Property ;
    rdfs:label 'Price Tier' ;
    rdfs:comment 'The pricing tier or model for the game on this storefront (e.g., free, $0.99, $4.99, $9.99, premium). Platform-specific pricing tiers apply.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCategory rdf:type rdf:Property ;
    rdfs:label 'Primary Category' ;
    rdfs:comment 'The main category classification for the game on the storefront (e.g., Action, Strategy, RPG, Puzzle). Platform-specific category taxonomies apply.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoVideoReference rdf:type rdf:Property ;
    rdfs:label 'Promo Video Reference' ;
    rdfs:comment 'Asset reference or URL for the promotional video or app preview displayed on the store listing. Platform-specific format and duration requirements apply.' ;
    rdfs:domain ind:AsoListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCount rdf:type rdf:Property ;
    rdfs:label 'Review Count' ;
    rdfs:comment 'Total number of user reviews submitted for the game on this storefront. Review volume impacts social proof and conversion.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:screenshotReferences rdf:type rdf:Property ;
    rdfs:label 'Screenshot References' ;
    rdfs:comment 'Comma-separated list of asset references or URLs pointing to the promotional screenshots displayed on the store listing. Each platform has specific dimension and count requirements.' ;
    rdfs:domain ind:AsoListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryCategory rdf:type rdf:Property ;
    rdfs:label 'Secondary Category' ;
    rdfs:comment 'Optional secondary category classification for the game. Not all platforms support secondary categories.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportUrl rdf:type rdf:Property ;
    rdfs:label 'Support Url' ;
    rdfs:comment 'URL to the player support or customer service page for the game. Required by most storefronts.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Version Release Date' ;
    rdfs:comment 'The date when the current version was released or went live on the storefront.' ;
    rdfs:domain ind:AsoListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:attributionRecordId rdf:type rdf:Property ;
    rdfs:label 'Attribution Record Id' ;
    rdfs:comment 'Unique identifier for the attribution record. Primary key for the attribution ledger.' ;
    rdfs:domain ind:AttributionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adSetId rdf:type rdf:Property ;
    rdfs:label 'Ad Set Id' ;
    rdfs:comment 'Unique identifier of the ad set (ad group) within the campaign that drove this install.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdSet .

ind:firstPaymentId rdf:type rdf:Property ;
    rdfs:label 'First Payment Id' ;
    rdfs:comment 'Foreign key linking to billing.payment. Business justification: Links player\'s first payment to their install attribution source, enabling true LTV-by-source calculation critical for ROAS optimization and UA budget allocation decisions in performance marketing ope' ;
    rdfs:domain ind:AttributionRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payment .

ind:adSetName rdf:type rdf:Property ;
    rdfs:label 'Ad Set Name' ;
    rdfs:comment 'Human-readable name of the ad set (ad group) within the campaign.' ;
    rdfs:domain ind:AttributionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appCode rdf:type rdf:Property ;
    rdfs:label 'App Code' ;
    rdfs:comment 'The unique identifier of the game application in the attribution platform (e.g., bundle ID for iOS, package name for Android).' ;
    rdfs:domain ind:AttributionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appName rdf:type rdf:Property ;
    rdfs:label 'App Name' ;
    rdfs:comment 'The human-readable name of the game application for which this install was attributed.' ;
    rdfs:domain ind:AttributionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionPlatform rdf:type rdf:Property ;
    rdfs:label 'Attribution Platform' ;
    rdfs:comment 'The mobile attribution platform that generated this attribution record (AppsFlyer, Adjust, Branch, etc.). [ENUM-REF-CANDIDATE: AppsFlyer|Adjust|Branch|Kochava|Singular|Tenjin|internal — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AttributionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionPlatformRecordReference rdf:type rdf:Property ;
    rdfs:label 'Attribution Platform Record Reference' ;
    rdfs:comment 'The unique identifier of this attribution record in the source attribution platform (AppsFlyer or Adjust). Used for reconciliation and deduplication.' ;
    rdfs:domain ind:AttributionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Attribution Timestamp' ;
    rdfs:comment 'The timestamp when the attribution platform processed and attributed this install event. May differ from install_timestamp due to processing latency.' ;
    rdfs:domain ind:AttributionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:attributionType rdf:type rdf:Property ;
    rdfs:label 'Attribution Type' ;
    rdfs:comment 'The method by which the install was attributed: click (last-click), view-through (impression-based), probabilistic (fingerprinting), deterministic (device ID match), or organic (no paid attribution).' ;
    rdfs:domain ind:AttributionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clickTimestamp rdf:type rdf:Property ;
    rdfs:label 'Click Timestamp' ;
    rdfs:comment 'The timestamp when the player clicked on the ad, if attribution type is click-based. Null for view-through or organic installs.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cpiUsd rdf:type rdf:Property ;
    rdfs:label 'Cpi Usd' ;
    rdfs:comment 'The cost per install in US dollars for this attributed install, as reported by the media source or calculated from campaign spend data. Used to calculate ROAS and marketing efficiency.' ;
    rdfs:domain ind:AttributionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fraudRejectionFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Rejection Flag' ;
    rdfs:comment 'Boolean flag indicating whether this install was flagged as fraudulent by the attribution platforms fraud detection algorithms (True = fraud detected, False = legitimate install).' ;
    rdfs:domain ind:AttributionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impressionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Impression Timestamp' ;
    rdfs:comment 'The timestamp when the ad impression was served to the player, if attribution type is view-through. Null for click-based or organic installs.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:installTimestamp rdf:type rdf:Property ;
    rdfs:label 'Install Timestamp' ;
    rdfs:comment 'The exact date and time when the player installed the game or re-engaged, as reported by the attribution platform. This is the principal business event timestamp for this transaction.' ;
    rdfs:domain ind:AttributionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:installType rdf:type rdf:Property ;
    rdfs:label 'Install Type' ;
    rdfs:comment 'The type of install event: new_install (first-time install), re-install (player previously uninstalled and reinstalled), re-engagement (dormant player reactivated), or re-attribution (player attributed to a new campaign).' ;
    rdfs:domain ind:AttributionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOrganic rdf:type rdf:Property ;
    rdfs:label 'Is Organic' ;
    rdfs:comment 'Boolean flag indicating whether this install is organic (True = no paid attribution, False = attributed to a paid campaign). Organic installs have no associated CPI or campaign.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediaSource rdf:type rdf:Property ;
    rdfs:label 'Media Source' ;
    rdfs:comment 'The media source or advertising network that served the ad (e.g., Facebook Ads, Google Ads, TikTok Ads, Unity Ads, ironSource).' ;
    rdfs:domain ind:AttributionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osName rdf:type rdf:Property ;
    rdfs:label 'Os Name' ;
    rdfs:comment 'The operating system of the device on which the game was installed. [ENUM-REF-CANDIDATE: iOS|Android|Windows|macOS|Linux|PlayStation|Xbox|Nintendo|unknown — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osVersion rdf:type rdf:Property ;
    rdfs:label 'Os Version' ;
    rdfs:comment 'The version of the operating system on the device at the time of install (e.g., iOS 16.3, Android 13).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceId rdf:type rdf:Property ;
    rdfs:label 'Audience Id' ;
    rdfs:comment 'Unique identifier for the audience definition. Primary key.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By User Employee Id' ;
    rdfs:comment 'Reference to the user who created this audience definition.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:lastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this audience definition.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:playerSegmentId rdf:type rdf:Property ;
    rdfs:label 'Player Segment Id' ;
    rdfs:comment 'Reference to the player segment that serves as the seed or source population for this audience definition.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerSegment .

ind:sourcePlayerSegmentId rdf:type rdf:Property ;
    rdfs:label 'Source Player Segment Id' ;
    rdfs:comment 'Foreign key linking to player.segment. Business justification: Audiences for ad platform activation (Facebook, Google, TikTok) are synced FROM player domain segments. Marketing teams export player.segment definitions to create matched audiences on ad networks. Es' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:attOptInRequirement rdf:type rdf:Property ;
    rdfs:label 'Att Opt In Requirement' ;
    rdfs:comment 'Indicates whether this audience is restricted to iOS users who have granted ATT opt-in consent for tracking.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:audienceCode rdf:type rdf:Property ;
    rdfs:label 'Audience Code' ;
    rdfs:comment 'Unique business identifier or short code for the audience used in external systems and reporting.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceName rdf:type rdf:Property ;
    rdfs:label 'Audience Name' ;
    rdfs:comment 'Human-readable name for the audience segment (e.g., \'High-LTV Whales Q1 2024\', \'D7 Churned Non-Payers\').' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceStatus rdf:type rdf:Property ;
    rdfs:label 'Audience Status' ;
    rdfs:comment 'Current lifecycle status of the audience: draft (being built), active (syncing to platforms), paused (temporarily disabled), archived (no longer used), expired (past validity window).' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceType rdf:type rdf:Property ;
    rdfs:label 'Audience Type' ;
    rdfs:comment 'Classification of the audience definition method: lookalike (modeled from seed), custom (manually defined), behavioral (action-based), demographic (attribute-based), value_based (LTV/ARPU tier), or retargeting (re-engagement).' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageD7RetentionRate rdf:type rdf:Property ;
    rdfs:label 'Average D7 Retention Rate' ;
    rdfs:comment 'Average day-7 retention rate (percentage) of players in the source segment. Used to assess audience quality for lookalike modeling.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageLtvUsd rdf:type rdf:Property ;
    rdfs:label 'Average Ltv Usd' ;
    rdfs:comment 'Average lifetime value in USD of players in the source segment used to build this audience. Used for value-based lookalike modeling.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coppaExclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Coppa Exclusion Flag' ;
    rdfs:comment 'Indicates whether users under age 13 (or applicable age threshold) are excluded from this audience to comply with COPPA requirements.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedReach rdf:type rdf:Property ;
    rdfs:label 'Estimated Reach' ;
    rdfs:comment 'Ad platform\'s estimated reachable audience size based on the matched identifiers and platform\'s user base. Provided by platform API.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gdprLawfulBasis rdf:type rdf:Property ;
    rdfs:label 'Gdpr Lawful Basis' ;
    rdfs:comment 'Legal basis under GDPR for processing and exporting this audience data: consent, legitimate_interest, contract, legal_obligation, or not_applicable (non-EU audience).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hashingAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Hashing Algorithm' ;
    rdfs:comment 'Algorithm used to hash PII identifiers before export (SHA256, MD5, or none for non-PII identifiers).' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifierType rdf:type rdf:Property ;
    rdfs:label 'Identifier Type' ;
    rdfs:comment 'Type of player identifier used for matching with ad platforms: email (hashed), phone (hashed), device_id, IDFA (iOS), GAID (Android), or internal player_id.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Sync Timestamp' ;
    rdfs:comment 'Timestamp of the most recent successful or attempted sync to the target ad platform.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lookalikeExpansionPercentage rdf:type rdf:Property ;
    rdfs:label 'Lookalike Expansion Percentage' ;
    rdfs:comment 'Expansion factor for lookalike modeling (e.g., 1% = most similar, 10% = broader reach). Null for non-lookalike audiences.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lookalikeSeedSize rdf:type rdf:Property ;
    rdfs:label 'Lookalike Seed Size' ;
    rdfs:comment 'Number of seed users used to generate a lookalike audience. Null for non-lookalike audience types.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:matchRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Match Rate Percentage' ;
    rdfs:comment 'Percentage of audience members successfully matched by the ad platform (matched_count / audience_size * 100). Key metric for audience quality and targeting effectiveness.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchedCount rdf:type rdf:Property ;
    rdfs:label 'Matched Count' ;
    rdfs:comment 'Number of player identifiers successfully matched and accepted by the ad platform during last sync.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextScheduledSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Sync Timestamp' ;
    rdfs:comment 'Timestamp when the next automatic sync to the ad platform is scheduled to occur.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:platformAudienceReference rdf:type rdf:Property ;
    rdfs:label 'Platform Audience Reference' ;
    rdfs:comment 'External identifier assigned by the ad platform (e.g., Facebook Custom Audience ID, Google Audience ID) after successful sync.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:size rdf:type rdf:Property ;
    rdfs:label 'Size' ;
    rdfs:comment 'Total number of unique player identifiers included in this audience definition at last refresh.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:suppressionListApplied rdf:type rdf:Property ;
    rdfs:label 'Suppression List Applied' ;
    rdfs:comment 'Indicates whether a suppression list (e.g., opted-out users, existing players) has been applied to exclude certain identifiers from this audience.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:syncErrorMessage rdf:type rdf:Property ;
    rdfs:label 'Sync Error Message' ;
    rdfs:comment 'Error message returned by the ad platform if the last sync attempt failed. Null if sync was successful.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syncFrequency rdf:type rdf:Property ;
    rdfs:label 'Sync Frequency' ;
    rdfs:comment 'Cadence at which the audience is refreshed and re-synced to the ad platform: real_time, hourly, daily, weekly, or manual (on-demand only).' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syncStatus rdf:type rdf:Property ;
    rdfs:label 'Sync Status' ;
    rdfs:comment 'Current synchronization status with the target ad platform: pending (queued), syncing (in progress), synced (complete), failed (error), partial (some records failed).' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustCampaignToken rdf:type rdf:Property ;
    rdfs:label 'Adjust Campaign Token' ;
    rdfs:comment 'External identifier or token from Adjust attribution platform linking this campaign to attribution records and performance metrics.' ;
    rdfs:domain ind:MarketingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appsflyerCampaignReference rdf:type rdf:Property ;
    rdfs:label 'Appsflyer Campaign Reference' ;
    rdfs:comment 'External identifier from AppsFlyer attribution platform linking this campaign to attribution records and performance metrics.' ;
    rdfs:domain ind:MarketingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asoOptimized rdf:type rdf:Property ;
    rdfs:label 'Aso Optimized' ;
    rdfs:comment 'Boolean flag indicating whether this campaign includes App Store Optimization (ASO) efforts for organic discovery.' ;
    rdfs:domain ind:MarketingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:attributionLink rdf:type rdf:Property ;
    rdfs:label 'Attribution Link' ;
    rdfs:comment 'Full attribution tracking URL or deep link used for this campaign to measure installs and post-install events.' ;
    rdfs:domain ind:MarketingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionPartner rdf:type rdf:Property ;
    rdfs:label 'Attribution Partner' ;
    rdfs:comment 'Name of the mobile attribution platform or partner used to track campaign performance (e.g., AppsFlyer, Adjust, Branch, Kochava, Singular, or internal tracking).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the campaign budget (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignName rdf:type rdf:Property ;
    rdfs:label 'Campaign Name' ;
    rdfs:comment 'Human-readable name of the marketing campaign used for identification and reporting.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Status' ;
    rdfs:comment 'Current lifecycle status of the campaign indicating its operational state.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignType rdf:type rdf:Property ;
    rdfs:label 'Campaign Type' ;
    rdfs:comment 'Classification of the campaign by its primary objective: user acquisition (UA), retention, re-engagement, brand awareness, soft launch, or hard launch.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelName rdf:type rdf:Property ;
    rdfs:label 'Channel Name' ;
    rdfs:comment 'Specific marketing channel or platform where the campaign runs (e.g., Facebook, Google Ads, TikTok, YouTube, Apple Search Ads, influencer network).' ;
    rdfs:domain ind:MarketingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelSubtype rdf:type rdf:Property ;
    rdfs:label 'Channel Subtype' ;
    rdfs:comment 'Granular channel subtype or ad format (e.g., paid_social, display, search, video, CTV/OTT, influencer, email, push notification).' ;
    rdfs:domain ind:MarketingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'High-level channel taxonomy classification: organic, paid, owned, or earned media.' ;
    rdfs:domain ind:MarketingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeTheme rdf:type rdf:Property ;
    rdfs:label 'Creative Theme' ;
    rdfs:comment 'Primary creative theme or messaging angle used in campaign assets (e.g., gameplay showcase, character spotlight, seasonal event, competitive PvP).' ;
    rdfs:domain ind:MarketingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCrmLifecycleCampaign rdf:type rdf:Property ;
    rdfs:label 'Is Crm Lifecycle Campaign' ;
    rdfs:comment 'Boolean flag indicating whether this is a CRM-driven lifecycle campaign (e.g., onboarding, retention, win-back) managed through Salesforce.' ;
    rdfs:domain ind:MarketingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInfluencerCampaign rdf:type rdf:Property ;
    rdfs:label 'Is Influencer Campaign' ;
    rdfs:comment 'Boolean flag indicating whether this campaign involves influencer or affiliate partnerships.' ;
    rdfs:domain ind:MarketingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSoftLaunch rdf:type rdf:Property ;
    rdfs:label 'Is Soft Launch' ;
    rdfs:comment 'Boolean flag indicating whether this campaign is part of a soft launch (limited market test) or hard launch (full market release).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:managerName rdf:type rdf:Property ;
    rdfs:label 'Manager Name' ;
    rdfs:comment 'Name of the individual campaign manager or lead responsible for campaign execution and performance.' ;
    rdfs:domain ind:MarketingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:objective rdf:type rdf:Property ;
    rdfs:label 'Objective' ;
    rdfs:comment 'Detailed business objective or goal statement for the campaign, such as target installs, target ROAS (Return on Ad Spend), or target retention rate.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceCampaignReference rdf:type rdf:Property ;
    rdfs:label 'Salesforce Campaign Reference' ;
    rdfs:comment 'External identifier from Salesforce CRM system linking this campaign to the source system record.' ;
    rdfs:domain ind:MarketingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCpi rdf:type rdf:Property ;
    rdfs:label 'Target Cpi' ;
    rdfs:comment 'Target cost per install (CPI) goal for user acquisition campaigns, representing the maximum acceptable cost to acquire one new player install.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetRegion rdf:type rdf:Property ;
    rdfs:label 'Target Region' ;
    rdfs:comment 'Primary geographic region or country targeted by the campaign using three-letter ISO country codes (e.g., USA, GBR, JPN).' ;
    rdfs:domain ind:MarketingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRoas rdf:type rdf:Property ;
    rdfs:label 'Target Roas' ;
    rdfs:comment 'Target return on ad spend (ROAS) goal for the campaign, expressed as a ratio (e.g., 3.0 means $3 revenue for every $1 spent).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utmContent rdf:type rdf:Property ;
    rdfs:label 'Utm Content' ;
    rdfs:comment 'UTM content parameter used to differentiate similar content or links within the same campaign (e.g., A/B test variants).' ;
    rdfs:domain ind:MarketingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmTerm rdf:type rdf:Property ;
    rdfs:label 'Utm Term' ;
    rdfs:comment 'UTM term parameter identifying paid search keywords or targeting criteria used in the campaign.' ;
    rdfs:domain ind:MarketingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignSpendId rdf:type rdf:Property ;
    rdfs:label 'Campaign Spend Id' ;
    rdfs:comment 'Unique identifier for the campaign spend record. Primary key for daily transactional marketing spend records.' ;
    rdfs:domain ind:CampaignSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attributionWindowDays rdf:type rdf:Property ;
    rdfs:label 'Attribution Window Days' ;
    rdfs:comment 'The number of days used for install attribution lookback window (e.g., 7-day click, 1-day view).' ;
    rdfs:domain ind:CampaignSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clicks rdf:type rdf:Property ;
    rdfs:label 'Clicks' ;
    rdfs:comment 'Total number of clicks on the ad on the specified date.' ;
    rdfs:domain ind:CampaignSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cohortDate rdf:type rdf:Property ;
    rdfs:label 'Cohort Date' ;
    rdfs:comment 'The cohort date used for retention analysis (D1/D7/D30) tied to this spend record. Typically matches spend_date for acquisition campaigns.' ;
    rdfs:domain ind:CampaignSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conversionRate rdf:type rdf:Property ;
    rdfs:label 'Conversion Rate' ;
    rdfs:comment 'Install conversion rate expressed as a decimal. Calculated as installs / clicks. Measures post-click conversion effectiveness.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpc rdf:type rdf:Property ;
    rdfs:label 'Cpc' ;
    rdfs:comment 'Cost per click. Calculated as spend_amount / clicks.' ;
    rdfs:domain ind:CampaignSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpi rdf:type rdf:Property ;
    rdfs:label 'Cpi' ;
    rdfs:comment 'Cost per install. Calculated as spend_amount / installs. Key metric for user acquisition efficiency.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpm rdf:type rdf:Property ;
    rdfs:label 'Cpm' ;
    rdfs:comment 'Cost per thousand impressions. Calculated as (spend_amount / impressions) * 1000.' ;
    rdfs:domain ind:CampaignSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctr rdf:type rdf:Property ;
    rdfs:label 'Ctr' ;
    rdfs:comment 'Click-through rate expressed as a decimal. Calculated as clicks / impressions. Measures ad engagement effectiveness.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discrepancyAmount rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Amount' ;
    rdfs:comment 'The difference between ad network reported spend and attribution platform aggregated spend, if any. Null if reconciled.' ;
    rdfs:domain ind:CampaignSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geoCountryCode rdf:type rdf:Property ;
    rdfs:label 'Geo Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the geographic target of this campaign spend.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impressions rdf:type rdf:Property ;
    rdfs:label 'Impressions' ;
    rdfs:comment 'Total number of times the ad was displayed to users on the specified date.' ;
    rdfs:domain ind:CampaignSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:installs rdf:type rdf:Property ;
    rdfs:label 'Installs' ;
    rdfs:comment 'Total number of game installs attributed to this campaign spend on the specified date, as reported by attribution platform (AppsFlyer/Adjust).' ;
    rdfs:domain ind:CampaignSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:launchPhase rdf:type rdf:Property ;
    rdfs:label 'Launch Phase' ;
    rdfs:comment 'The game lifecycle phase during which this spend occurred (soft launch, hard launch, live operations, sunset).' ;
    rdfs:domain ind:CampaignSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendAmount rdf:type rdf:Property ;
    rdfs:label 'Spend Amount' ;
    rdfs:comment 'Total marketing spend amount incurred on the specified date for this campaign, ad set, and channel combination.' ;
    rdfs:domain ind:CampaignSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spendDate rdf:type rdf:Property ;
    rdfs:label 'Spend Date' ;
    rdfs:comment 'The calendar date on which the marketing spend was incurred. Principal business event timestamp for this transaction.' ;
    rdfs:domain ind:CampaignSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentRecordId rdf:type rdf:Property ;
    rdfs:label 'Consent Record Id' ;
    rdfs:comment 'Unique identifier for the marketing consent record. Primary key.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Age Verified Flag' ;
    rdfs:comment 'Indicates whether the players age has been verified at the time of consent collection. True if age verification was completed; False otherwise. Critical for COPPA compliance.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentCollectionContext rdf:type rdf:Property ;
    rdfs:label 'Consent Collection Context' ;
    rdfs:comment 'Free-text description of the context or scenario in which consent was collected (e.g., first-time user experience, account settings update, post-purchase prompt). Provides qualitative insight for consent UX optimization.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentGranularityLevel rdf:type rdf:Property ;
    rdfs:label 'Consent Granularity Level' ;
    rdfs:comment 'Defines the level of granularity at which consent was collected. All-marketing is a blanket consent; category-specific allows per-category control; channel-specific allows per-channel control; partner-specific allows per-partner control.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentLanguage rdf:type rdf:Property ;
    rdfs:label 'Consent Language' ;
    rdfs:comment 'The language in which the consent prompt or preference center was presented to the player. Uses ISO 639-1 two-letter language codes. [ENUM-REF-CANDIDATE: en|es|fr|de|ja|ko|pt|zh|it|ru|pl|nl|sv|tr|ar — 15 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentMethod rdf:type rdf:Property ;
    rdfs:label 'Consent Method' ;
    rdfs:comment 'The user interface mechanism through which consent was captured. Explicit opt-in requires active player action; implicit opt-in assumes consent unless declined; pre-checked box is generally non-compliant under GDPR.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentProofDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Consent Proof Document Url' ;
    rdfs:comment 'URL or reference to stored documentation proving consent was obtained (e.g., screenshot, signed form, email confirmation). Provides audit trail for regulatory inquiries.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentRenewalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Renewal Required Flag' ;
    rdfs:comment 'Indicates whether this consent requires periodic renewal or re-confirmation. True if renewal is required; False for perpetual consent until withdrawn.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentScope rdf:type rdf:Property ;
    rdfs:label 'Consent Scope' ;
    rdfs:comment 'Defines the scope of the consent grant. Global applies across all games and platforms; regional applies to a specific geographic region; game-specific applies to a single title; platform-specific applies to one platform.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentSource rdf:type rdf:Property ;
    rdfs:label 'Consent Source' ;
    rdfs:comment 'The channel or interface through which the player provided or modified their consent. Tracks the origin of the consent action for audit and compliance purposes. [ENUM-REF-CANDIDATE: in-game-prompt|web-preference-center|app-store-ATT|mobile-app-onboarding|email-link|customer-support|API — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'Current state of the consent. Granted indicates active permission; withdrawn indicates player has revoked consent; expired indicates consent has passed its validity period; pending indicates consent request awaiting player action; revoked indicates administratively cancelled consent.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentTextSnapshot rdf:type rdf:Property ;
    rdfs:label 'Consent Text Snapshot' ;
    rdfs:comment 'A snapshot or reference to the exact consent language and terms that were presented to the player at the time of consent. Provides audit trail for what the player agreed to.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentType rdf:type rdf:Property ;
    rdfs:label 'Consent Type' ;
    rdfs:comment 'The specific type of marketing communication or data processing activity for which consent is being recorded. Defines the scope of the consent grant or withdrawal.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Version' ;
    rdfs:comment 'Version identifier of the consent language, terms, or privacy policy that was presented to the player at the time of consent. Enables tracking of consent under different policy versions.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doubleOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Flag' ;
    rdfs:comment 'Indicates whether the consent was confirmed through a double opt-in process (e.g., email confirmation link). True if double opt-in was completed; False for single opt-in.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentalConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Parental Consent Flag' ;
    rdfs:comment 'Indicates whether parental or guardian consent was obtained for players under the age of digital consent. True if parental consent was provided; False otherwise. Required for minors under COPPA and GDPR.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferenceCenterUrl rdf:type rdf:Property ;
    rdfs:label 'Preference Center Url' ;
    rdfs:comment 'URL of the preference center or consent management interface where the player can view or modify their consent settings. Provides transparency and easy access to consent controls.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privacyPolicyVersion rdf:type rdf:Property ;
    rdfs:label 'Privacy Policy Version' ;
    rdfs:comment 'Version identifier of the privacy policy that was in effect and presented to the player at the time of consent. Tracks consent under different policy iterations.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceContactReference rdf:type rdf:Property ;
    rdfs:label 'Salesforce Contact Reference' ;
    rdfs:comment 'External identifier linking this consent record to the corresponding Contact record in Salesforce CRM. Enables synchronization of consent state with CRM for lifecycle campaigns.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyProcessor rdf:type rdf:Property ;
    rdfs:label 'Third Party Processor' ;
    rdfs:comment 'Name or identifier of the third-party data processor or advertising partner for whom consent was granted. Relevant for third-party-ad-sharing consent type.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Timestamp' ;
    rdfs:comment 'The date and time when the player withdrew their previously granted consent. Null if consent has not been withdrawn.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:crmCampaignId rdf:type rdf:Property ;
    rdfs:label 'Crm Campaign Id' ;
    rdfs:comment 'Unique identifier for the CRM lifecycle marketing campaign record. Primary key.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CrmCampaign .

ind:messageTemplateId rdf:type rdf:Property ;
    rdfs:label 'Message Template Id' ;
    rdfs:comment 'Reference to the message template or creative asset used for this campaign, stored in the CRM or marketing automation system.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MessageTemplate .

ind:suppressionListId rdf:type rdf:Property ;
    rdfs:label 'Suppression List Id' ;
    rdfs:comment 'Reference to the suppression list containing players who should be excluded from this campaign due to opt-out, frequency capping, or other business rules.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SuppressionList .

ind:abTestEnabled rdf:type rdf:Property ;
    rdfs:label 'Ab Test Enabled' ;
    rdfs:comment 'Indicates whether this campaign includes A/B testing of message variants, subject lines, or creative assets.' ;
    rdfs:domain ind:CrmCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:abTestSplitPercentage rdf:type rdf:Property ;
    rdfs:label 'Ab Test Split Percentage' ;
    rdfs:comment 'Percentage of target audience allocated to each test variant. For example, 50.00 for a 50/50 split. Null if A/B testing is not enabled.' ;
    rdfs:domain ind:CrmCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:abTestVariantCount rdf:type rdf:Property ;
    rdfs:label 'Ab Test Variant Count' ;
    rdfs:comment 'Number of test variants in the A/B test configuration. Null if A/B testing is not enabled.' ;
    rdfs:domain ind:CrmCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualSendTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Send Timestamp' ;
    rdfs:comment 'The actual timestamp when the campaign was executed and messages were sent. May differ from scheduled time due to system delays or manual intervention.' ;
    rdfs:domain ind:CrmCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:campaignBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Campaign Budget Usd' ;
    rdfs:comment 'Allocated budget for this campaign in USD, including creative production, platform fees, and incentive costs. Null for zero-cost campaigns.' ;
    rdfs:domain ind:CrmCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignObjective rdf:type rdf:Property ;
    rdfs:label 'Campaign Objective' ;
    rdfs:comment 'Primary business objective of the campaign: retention (keep active players), reactivation (bring back churned players), upsell (increase spending), cross_sell (promote other titles), engagement (increase activity), or education (onboard/inform).' ;
    rdfs:domain ind:CrmCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coppaAgeGateRequired rdf:type rdf:Property ;
    rdfs:label 'Coppa Age Gate Required' ;
    rdfs:comment 'Indicates whether COPPA age verification is required before sending campaign messages. True when targeting players who may be under 13 years old in the United States.' ;
    rdfs:domain ind:CrmCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expectedSendVolume rdf:type rdf:Property ;
    rdfs:label 'Expected Send Volume' ;
    rdfs:comment 'Expected number of messages to be sent after applying suppression lists, consent filters, and other exclusion rules.' ;
    rdfs:domain ind:CrmCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyCapEnabled rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap Enabled' ;
    rdfs:comment 'Indicates whether frequency capping rules are applied to prevent over-messaging players within a defined time window.' ;
    rdfs:domain ind:CrmCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:frequencyCapLimit rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap Limit' ;
    rdfs:comment 'Maximum number of campaign messages a player can receive within the frequency cap window. Null if frequency capping is not enabled.' ;
    rdfs:domain ind:CrmCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyCapWindowDays rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap Window Days' ;
    rdfs:comment 'Time window in days over which the frequency cap limit is enforced. Null if frequency capping is not enabled.' ;
    rdfs:domain ind:CrmCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gdprConsentRequired rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Required' ;
    rdfs:comment 'Indicates whether explicit GDPR consent is required from players before sending campaign messages. True for EU/EEA players under GDPR jurisdiction.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incentiveType rdf:type rdf:Property ;
    rdfs:label 'Incentive Type' ;
    rdfs:comment 'Type of incentive or reward offered in the campaign to drive player action: none, virtual currency, discount code, free in-game item, battle pass tier boost, or exclusive content unlock.' ;
    rdfs:domain ind:CrmCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveValue rdf:type rdf:Property ;
    rdfs:label 'Incentive Value' ;
    rdfs:comment 'Specific value or description of the incentive offered, such as amount of virtual currency, discount percentage, or item SKU. Null if no incentive.' ;
    rdfs:domain ind:CrmCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'The player lifecycle stage this campaign targets: onboarding (new players), active (engaged players), at_risk (declining engagement), churned (stopped playing), dormant (inactive), or win_back (re-engagement).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localizationEnabled rdf:type rdf:Property ;
    rdfs:label 'Localization Enabled' ;
    rdfs:comment 'Indicates whether campaign messages are localized into multiple languages based on player locale or region.' ;
    rdfs:domain ind:CrmCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:personalizationEnabled rdf:type rdf:Property ;
    rdfs:label 'Personalization Enabled' ;
    rdfs:comment 'Indicates whether campaign messages include personalized content based on player data such as name, game progress, or preferences.' ;
    rdfs:domain ind:CrmCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledSendDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Send Date' ;
    rdfs:comment 'The date when the campaign is scheduled to be sent or activated. For recurring campaigns, this represents the initial send date.' ;
    rdfs:domain ind:CrmCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledSendTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Send Time' ;
    rdfs:comment 'The precise timestamp when the campaign messages are scheduled to be sent, including time zone considerations for global player base.' ;
    rdfs:domain ind:CrmCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:targetAudienceSize rdf:type rdf:Property ;
    rdfs:label 'Target Audience Size' ;
    rdfs:comment 'Total number of players in the target segment eligible to receive this campaign at the time of campaign creation.' ;
    rdfs:domain ind:CrmCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:triggerEventType rdf:type rdf:Property ;
    rdfs:label 'Trigger Event Type' ;
    rdfs:comment 'The player behavior or system event that triggers this campaign for event-driven campaigns, such as \'player_inactive_7_days\', \'first_purchase\', or \'level_milestone\'. Null for non-triggered campaigns.' ;
    rdfs:domain ind:CrmCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affiliateCode rdf:type rdf:Property ;
    rdfs:label 'Affiliate Code' ;
    rdfs:comment 'The unique affiliate tracking code or referral code assigned to the influencer for tracking sales, installs, and conversions driven by their promotional content. Used in AppsFlyer/Adjust attribution and revenue-share calculations.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affiliateProgramEnrolled rdf:type rdf:Property ;
    rdfs:label 'Affiliate Program Enrolled' ;
    rdfs:comment 'Indicates whether the influencer is enrolled in the company\'s affiliate marketing program, earning commission on game sales or in-app purchases driven through their unique affiliate links. True means enrolled; False means not enrolled.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:audienceAgeGroup rdf:type rdf:Property ;
    rdfs:label 'Audience Age Group' ;
    rdfs:comment 'The primary age demographic of the influencers audience. Critical for ESRB/PEGI compliance, COPPA compliance, and ensuring age-appropriate game promotion. [ENUM-REF-CANDIDATE: under-13|13-17|18-24|25-34|35-44|45-plus|mixed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceGenderSplit rdf:type rdf:Property ;
    rdfs:label 'Audience Gender Split' ;
    rdfs:comment 'The gender distribution of the influencers audience, typically expressed as a percentage (e.g., 60% male, 40% female). Used for targeted campaign planning and demographic alignment with game titles.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageViewsPerPost rdf:type rdf:Property ;
    rdfs:label 'Average Views Per Post' ;
    rdfs:comment 'The average number of views or impressions the influencer generates per content post on their primary platform. Used for campaign reach estimation and Cost Per Mille (CPM) calculations.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentRatingSuitability rdf:type rdf:Property ;
    rdfs:label 'Content Rating Suitability' ;
    rdfs:comment 'The ESRB content rating level that best matches the influencers typical content and audience (E=Everyone, E10+=Everyone 10+, T=Teen, M=Mature, AO=Adults Only, RP=Rating Pending). Used to ensure appropriate game-influencer matching.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coppaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Coppa Compliance Flag' ;
    rdfs:comment 'Indicates whether the influencer has a significant audience under 13 years of age, requiring COPPA (Children\'s Online Privacy Protection Act) compliance measures in campaigns. True means COPPA compliance required; False means standard compliance.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cpiBenchmark rdf:type rdf:Property ;
    rdfs:label 'Cpi Benchmark' ;
    rdfs:comment 'The historical average Cost Per Install (CPI) achieved through campaigns with this influencer. Used for campaign planning, budget allocation, and influencer performance comparison.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engagementRate rdf:type rdf:Property ;
    rdfs:label 'Engagement Rate' ;
    rdfs:comment 'The average engagement rate (likes, comments, shares divided by followers) expressed as a percentage. Key metric for evaluating influencer effectiveness and campaign ROI.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:followerCount rdf:type rdf:Property ;
    rdfs:label 'Follower Count' ;
    rdfs:comment 'The current number of followers or subscribers on the influencers primary platform. Updated periodically for campaign planning and performance tracking.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:followerCountTier rdf:type rdf:Property ;
    rdfs:label 'Follower Count Tier' ;
    rdfs:comment 'Classification of the influencer based on follower count: nano (<10K), micro (10K-100K), mid-tier (100K-500K), macro (500K-1M), mega (>1M). Used for campaign targeting and rate negotiation.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handle rdf:type rdf:Property ;
    rdfs:label 'Handle' ;
    rdfs:comment 'The public username or handle of the influencer on their primary platform (e.g., @gamerpro123). This is the primary business identifier used in campaigns and contracts.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'The primary language used by the influencer in their content (e.g., English, Spanish, Japanese). Uses ISO 639-1 two-letter codes or full language names.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactEmail rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Email' ;
    rdfs:comment 'The primary email address for business communications, contract negotiations, and campaign coordination with the influencer.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactPhone rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Phone' ;
    rdfs:comment 'The primary phone number for urgent communications with the influencer or their management team.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPlatform rdf:type rdf:Property ;
    rdfs:label 'Primary Platform' ;
    rdfs:comment 'The primary social media or streaming platform where the influencer has the largest following and engagement.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Card Amount' ;
    rdfs:comment 'The standard rate or fee paid to the influencer per the agreed payment terms (e.g., per post, per campaign, or monthly retainer). Stored in the company\'s base currency (USD). Used for campaign budgeting and ROI analysis.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:realName rdf:type rdf:Property ;
    rdfs:label 'Real Name' ;
    rdfs:comment 'The legal or real name of the influencer for contract and payment purposes.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roasBenchmark rdf:type rdf:Property ;
    rdfs:label 'Roas Benchmark' ;
    rdfs:comment 'The historical average Return on Ad Spend (ROAS) achieved through campaigns with this influencer, expressed as a ratio (e.g., 3.5 means $3.50 revenue per $1 spent). Used for influencer selection and campaign optimization.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCampaignsCompleted rdf:type rdf:Property ;
    rdfs:label 'Total Campaigns Completed' ;
    rdfs:comment 'The cumulative number of marketing campaigns or content collaborations completed with this influencer since the partnership began. Used for partnership value assessment and performance trending.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:influencerCampaignId rdf:type rdf:Property ;
    rdfs:label 'Influencer Campaign Id' ;
    rdfs:comment 'Unique identifier for the influencer campaign association record.' ;
    rdfs:domain ind:InfluencerCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreedDeliverables rdf:type rdf:Property ;
    rdfs:label 'Agreed Deliverables' ;
    rdfs:comment 'Description of the contracted deliverables the influencer agreed to produce (e.g., 3 videos, 5 social posts, 2 live streams).' ;
    rdfs:domain ind:InfluencerCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributedInstalls rdf:type rdf:Property ;
    rdfs:label 'Attributed Installs' ;
    rdfs:comment 'Total number of game installs attributed to this influencer campaign engagement.' ;
    rdfs:domain ind:InfluencerCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attributedRevenue rdf:type rdf:Property ;
    rdfs:label 'Attributed Revenue' ;
    rdfs:comment 'Total revenue attributed to players acquired through this influencer campaign engagement.' ;
    rdfs:domain ind:InfluencerCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationModel rdf:type rdf:Property ;
    rdfs:label 'Compensation Model' ;
    rdfs:comment 'Payment structure for the influencer engagement: flat fee, Cost Per Install (CPI), Cost Per Acquisition (CPA), revenue share, or hybrid model.' ;
    rdfs:domain ind:InfluencerCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentGoLiveDate rdf:type rdf:Property ;
    rdfs:label 'Content Go Live Date' ;
    rdfs:comment 'Scheduled or actual date when the influencer content was published or went live.' ;
    rdfs:domain ind:InfluencerCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contentPlatform rdf:type rdf:Property ;
    rdfs:label 'Content Platform' ;
    rdfs:comment 'Primary social media or streaming platform where the influencer content was published (YouTube, Twitch, Instagram, TikTok, Twitter, Facebook, Discord). [ENUM-REF-CANDIDATE: youtube|twitch|instagram|tiktok|twitter|facebook|discord — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InfluencerCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentUrl rdf:type rdf:Property ;
    rdfs:label 'Content Url' ;
    rdfs:comment 'Direct URL to the published influencer content (video, post, stream recording).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDate rdf:type rdf:Property ;
    rdfs:label 'Contract Date' ;
    rdfs:comment 'Date when the influencer engagement contract was signed or agreed upon.' ;
    rdfs:domain ind:InfluencerCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractedFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Contracted Fee Amount' ;
    rdfs:comment 'Fixed fee amount contracted for the influencer engagement, if applicable.' ;
    rdfs:domain ind:InfluencerCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cookieWindowDays rdf:type rdf:Property ;
    rdfs:label 'Cookie Window Days' ;
    rdfs:comment 'Attribution window in days for tracking installs or conversions back to the influencer engagement.' ;
    rdfs:domain ind:InfluencerCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cpaRate rdf:type rdf:Property ;
    rdfs:label 'Cpa Rate' ;
    rdfs:comment 'Cost per acquisition rate agreed for performance-based compensation, if applicable.' ;
    rdfs:domain ind:InfluencerCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpiRate rdf:type rdf:Property ;
    rdfs:label 'Cpi Rate' ;
    rdfs:comment 'Cost per install rate agreed for performance-based compensation, if applicable.' ;
    rdfs:domain ind:InfluencerCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engagementCount rdf:type rdf:Property ;
    rdfs:label 'Engagement Count' ;
    rdfs:comment 'Total engagement actions (likes, comments, shares, clicks) on the influencer content.' ;
    rdfs:domain ind:InfluencerCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:engagementEndDate rdf:type rdf:Property ;
    rdfs:label 'Engagement End Date' ;
    rdfs:comment 'End date of the influencer campaign engagement period.' ;
    rdfs:domain ind:InfluencerCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engagementStartDate rdf:type rdf:Property ;
    rdfs:label 'Engagement Start Date' ;
    rdfs:comment 'Start date of the influencer campaign engagement period.' ;
    rdfs:domain ind:InfluencerCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engagementStatus rdf:type rdf:Property ;
    rdfs:label 'Engagement Status' ;
    rdfs:comment 'Current lifecycle status of the influencer campaign engagement (draft, contracted, active, completed, cancelled, suspended).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPayoutDate rdf:type rdf:Property ;
    rdfs:label 'Last Payout Date' ;
    rdfs:comment 'Date of the most recent payment made to the influencer for this engagement.' ;
    rdfs:domain ind:InfluencerCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payoutSchedule rdf:type rdf:Property ;
    rdfs:label 'Payout Schedule' ;
    rdfs:comment 'Description of the payment schedule or milestones for influencer compensation (e.g., 50% upfront, 50% on completion).' ;
    rdfs:domain ind:InfluencerCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceVsTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Performance Vs Target Percentage' ;
    rdfs:comment 'Overall performance percentage against contracted KPIs, calculated as actual divided by target.' ;
    rdfs:domain ind:InfluencerCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetEngagementCount rdf:type rdf:Property ;
    rdfs:label 'Target Engagement Count' ;
    rdfs:comment 'Contracted target number of engagement actions (likes, comments, shares) the influencer is expected to deliver.' ;
    rdfs:domain ind:InfluencerCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetInstalls rdf:type rdf:Property ;
    rdfs:label 'Target Installs' ;
    rdfs:comment 'Contracted target number of installs the influencer is expected to deliver.' ;
    rdfs:domain ind:InfluencerCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetViews rdf:type rdf:Property ;
    rdfs:label 'Target Views' ;
    rdfs:comment 'Contracted target number of views or impressions the influencer is expected to deliver.' ;
    rdfs:domain ind:InfluencerCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPayoutAmount rdf:type rdf:Property ;
    rdfs:label 'Total Payout Amount' ;
    rdfs:comment 'Total amount paid or payable to the influencer for this campaign engagement.' ;
    rdfs:domain ind:InfluencerCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackedLinkUrl rdf:type rdf:Property ;
    rdfs:label 'Tracked Link Url' ;
    rdfs:comment 'Unique tracking URL or deep link provided to the influencer for attribution of installs and conversions.' ;
    rdfs:domain ind:InfluencerCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewsDelivered rdf:type rdf:Property ;
    rdfs:label 'Views Delivered' ;
    rdfs:comment 'Total number of views or impressions delivered by the influencer content.' ;
    rdfs:domain ind:InfluencerCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:launchEventId rdf:type rdf:Property ;
    rdfs:label 'Launch Event Id' ;
    rdfs:comment 'Unique identifier for the launch event record. Primary key.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LaunchEvent .

ind:primaryLaunchEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Launch Employee Id' ;
    rdfs:comment 'Reference to the employee or team lead responsible for coordinating this launch event across marketing, studio, platform, and community domains. Links to workforce or employee master data.' ;
    rdfs:domain ind:LaunchEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryLaunchLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Launch Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user or system account that last modified this launch event record. Used for audit trail and change tracking.' ;
    rdfs:domain ind:LaunchEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Actual Launch Date' ;
    rdfs:comment 'The actual date the launch event went live. May differ from scheduled date due to delays, early releases, or other factors. Null if launch has not yet occurred.' ;
    rdfs:domain ind:LaunchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualSpendUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Spend Usd' ;
    rdfs:comment 'Actual marketing spend incurred for this launch event in US Dollars. Tracked against budget to monitor cost efficiency and calculate final ROAS.' ;
    rdfs:domain ind:LaunchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:asoOptimizationScore rdf:type rdf:Property ;
    rdfs:label 'Aso Optimization Score' ;
    rdfs:comment 'Composite score (0-100) representing the quality and completeness of ASO metadata (title, description, keywords, screenshots, videos, ratings) at launch. Higher scores correlate with better organic discoverability.' ;
    rdfs:domain ind:LaunchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageCpiUsd rdf:type rdf:Property ;
    rdfs:label 'Average Cpi Usd' ;
    rdfs:comment 'Average cost per install across all launch campaigns, calculated as total spend divided by total installs. Key efficiency metric for user acquisition performance.' ;
    rdfs:domain ind:LaunchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageCtrPct rdf:type rdf:Property ;
    rdfs:label 'Average Ctr Pct' ;
    rdfs:comment 'Average click-through rate across all launch campaign creatives, expressed as a percentage. Measures ad creative effectiveness and audience engagement.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coppaComplianceVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Coppa Compliance Verified Flag' ;
    rdfs:comment 'Boolean flag indicating whether COPPA compliance requirements (parental consent, data minimization for users under 13) have been verified for US launch. Required for games targeting or accessible to children.' ;
    rdfs:domain ind:LaunchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dayOneActualInstalls rdf:type rdf:Property ;
    rdfs:label 'Day One Actual Installs' ;
    rdfs:comment 'Actual number of installs recorded on the first day of launch. Compared against target to assess launch performance. Sourced from AppsFlyer/Adjust and platform analytics.' ;
    rdfs:domain ind:LaunchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dayOneInstallTarget rdf:type rdf:Property ;
    rdfs:label 'Day One Install Target' ;
    rdfs:comment 'Marketing and studio target for the number of installs to achieve on the first day of launch. Key performance indicator (KPI) for launch success.' ;
    rdfs:domain ind:LaunchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daySevenActualRetentionPct rdf:type rdf:Property ;
    rdfs:label 'Day Seven Actual Retention Pct' ;
    rdfs:comment 'Actual percentage of Day 1 players who returned on Day 7 post-launch. Null until D7 data is available. Used to assess FTUE (First-Time User Experience) effectiveness and early game engagement.' ;
    rdfs:domain ind:LaunchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daySevenRetentionTargetPct rdf:type rdf:Property ;
    rdfs:label 'Day Seven Retention Target Pct' ;
    rdfs:comment 'Target percentage of Day 1 players expected to return on Day 7 post-launch. Critical retention KPI for evaluating launch quality and player engagement.' ;
    rdfs:domain ind:LaunchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gdprComplianceVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliance Verified Flag' ;
    rdfs:comment 'Boolean flag indicating whether GDPR compliance requirements (player data consent, privacy policy, data subject rights) have been verified for EU launch regions. Required for launches targeting European markets.' ;
    rdfs:domain ind:LaunchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:influencerEmbargoLiftTimestamp rdf:type rdf:Property ;
    rdfs:label 'Influencer Embargo Lift Timestamp' ;
    rdfs:comment 'Date and time when influencers and content creators are permitted to publish gameplay videos, streams, and sponsored content. May differ from press embargo to manage launch narrative.' ;
    rdfs:domain ind:LaunchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:launchBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Launch Budget Usd' ;
    rdfs:comment 'Total marketing budget allocated for this launch event in US Dollars. Includes paid user acquisition, influencer partnerships, PR, events, and creative production. Used for ROAS (Return on Ad Spend) calculation.' ;
    rdfs:domain ind:LaunchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:launchCampaignIds rdf:type rdf:Property ;
    rdfs:label 'Launch Campaign Ids' ;
    rdfs:comment 'Comma-separated list of marketing campaign identifiers associated with this launch event. Links to campaign performance records in Salesforce CRM and attribution platforms for CPI, CTR, CPM, eCPM, and ROAS analysis.' ;
    rdfs:domain ind:LaunchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:launchEventCode rdf:type rdf:Property ;
    rdfs:label 'Launch Event Code' ;
    rdfs:comment 'Business identifier for the launch event, used for external reference and cross-functional coordination (e.g., APEX_SOFT_LAUNCH_Q1_2024).' ;
    rdfs:domain ind:LaunchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:launchStatus rdf:type rdf:Property ;
    rdfs:label 'Launch Status' ;
    rdfs:comment 'Current lifecycle status of the launch event. Tracks progression from planning through execution to completion or cancellation.' ;
    rdfs:domain ind:LaunchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:launchType rdf:type rdf:Property ;
    rdfs:label 'Launch Type' ;
    rdfs:comment 'Classification of the launch event type. Soft launch targets limited markets for testing; regional launch covers specific geographies; hard launch is full global release; major update launch is for significant DLC or expansion; beta and early access are pre-release phases.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postLaunchReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Post Launch Review Status' ;
    rdfs:comment 'Status of the post-launch retrospective and performance review process. Completed reviews capture lessons learned, KPI achievement, and recommendations for future launches.' ;
    rdfs:domain ind:LaunchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postLaunchReviewSummary rdf:type rdf:Property ;
    rdfs:label 'Post Launch Review Summary' ;
    rdfs:comment 'Executive summary of the post-launch review, including key successes, challenges, KPI performance vs. targets, and strategic recommendations. Captured for organizational learning and future launch planning.' ;
    rdfs:domain ind:LaunchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preRegistrationCount rdf:type rdf:Property ;
    rdfs:label 'Pre Registration Count' ;
    rdfs:comment 'Total number of players who pre-registered for the game prior to launch. Used to gauge initial interest and forecast Day 1 (D1) installs. Sourced from platform SDKs and marketing attribution systems.' ;
    rdfs:domain ind:LaunchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pressEmbargoLiftTimestamp rdf:type rdf:Property ;
    rdfs:label 'Press Embargo Lift Timestamp' ;
    rdfs:comment 'Date and time when press and media outlets are permitted to publish reviews, previews, and coverage of the game. Critical for coordinating PR and marketing efforts.' ;
    rdfs:domain ind:LaunchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:projectedD30LtvUsd rdf:type rdf:Property ;
    rdfs:label 'Projected D30 Ltv Usd' ;
    rdfs:comment 'Projected lifetime value per user at Day 30 post-launch, based on early monetization data and cohort analysis. Used to assess launch cohort quality and long-term revenue potential.' ;
    rdfs:domain ind:LaunchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Launch Date' ;
    rdfs:comment 'Planned date for the launch event to go live. This is the target date communicated to stakeholders and used for campaign planning.' ;
    rdfs:domain ind:LaunchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:storeFeaturingStatus rdf:type rdf:Property ;
    rdfs:label 'Store Featuring Status' ;
    rdfs:comment 'Indicates whether and how the game is featured on digital storefronts (Steam, Epic Games Store, App Store, Google Play, console stores) at launch. Featured placement significantly impacts discoverability and install volume.' ;
    rdfs:domain ind:LaunchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRegions rdf:type rdf:Property ;
    rdfs:label 'Target Regions' ;
    rdfs:comment 'Comma-separated list of 3-letter ISO country codes representing the geographic markets targeted for this launch (e.g., USA,CAN,GBR,DEU,JPN). For global launches, may contain GLOBAL keyword.' ;
    rdfs:domain ind:LaunchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingBudgetId rdf:type rdf:Property ;
    rdfs:label 'Marketing Budget Id' ;
    rdfs:comment 'Unique identifier for the marketing budget record. Primary key.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryMarketingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Marketing Employee Id' ;
    rdfs:comment 'Reference to the employee or user who owns and is accountable for this budget allocation (typically a marketing manager or campaign lead).' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryMarketingLastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Marketing Last Modified By Employee Id' ;
    rdfs:comment 'Reference to the employee or user who last modified this budget record.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryMarketingCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Marketing Created By Employee Id' ;
    rdfs:comment 'Reference to the employee or user who created this budget record.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Spend Amount' ;
    rdfs:comment 'The actual amount spent to date from this budget allocation. Updated in near real-time from campaign spend data.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCode rdf:type rdf:Property ;
    rdfs:label 'Budget Code' ;
    rdfs:comment 'Unique alphanumeric code identifying this budget allocation in financial systems and reporting.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetName rdf:type rdf:Property ;
    rdfs:label 'Budget Name' ;
    rdfs:comment 'Human-readable name or label for this budget allocation (e.g., Q1 2024 Mobile UA Budget - Game X).' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'Classification of the budget purpose: acquisition (player acquisition), retention (lifecycle marketing), brand (awareness campaigns), influencer (influencer/affiliate programs), aso (App Store Optimization), event (esports/live events).' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoRegion rdf:type rdf:Property ;
    rdfs:label 'Geo Region' ;
    rdfs:comment 'The geographic region or country this budget targets. Use 3-letter ISO country codes (e.g., USA, GBR, JPN) or regional codes (GLOBAL, NA, EU, APAC, LATAM, MEA).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRevisionDate rdf:type rdf:Property ;
    rdfs:label 'Last Revision Date' ;
    rdfs:comment 'The date this budget allocation was last revised or amended (e.g., budget increase, reallocation, or adjustment).' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remainingBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Remaining Budget Amount' ;
    rdfs:comment 'The remaining unspent budget amount. Calculated as total_approved_budget_amount minus actual_spend_amount minus committed_amount.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetD7RetentionRate rdf:type rdf:Property ;
    rdfs:label 'Target D7 Retention Rate' ;
    rdfs:comment 'The target Day 7 retention rate (percentage) for players acquired under this budget allocation. Used to evaluate cohort quality.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalApprovedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Total Approved Budget Amount' ;
    rdfs:comment 'The total budget amount approved by finance for this allocation. This is the authorized spending limit.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:activationChannels rdf:type rdf:Property ;
    rdfs:label 'Activation Channels' ;
    rdfs:comment 'Comma-separated list of channels where this segment is activated: paid_ua (user acquisition ads), crm_email, crm_push, retargeting, lookalike, in_game_offers. Tracks operational usage.' ;
    rdfs:domain ind:PlayerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualSegmentSize rdf:type rdf:Property ;
    rdfs:label 'Actual Segment Size' ;
    rdfs:comment 'Exact count of unique players in the segment after last materialization. Reflects the precise audience available for activation.' ;
    rdfs:domain ind:PlayerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageArppu rdf:type rdf:Property ;
    rdfs:label 'Average Arppu' ;
    rdfs:comment 'Average revenue per paying user for players in this segment. Calculated as total revenue divided by paying users only. Indicates monetization efficiency among payers.' ;
    rdfs:domain ind:PlayerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageArpu rdf:type rdf:Property ;
    rdfs:label 'Average Arpu' ;
    rdfs:comment 'Average revenue per user for players in this segment. Calculated as total revenue divided by total users. Used for monetization benchmarking.' ;
    rdfs:domain ind:PlayerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:d1RetentionRate rdf:type rdf:Property ;
    rdfs:label 'D1 Retention Rate' ;
    rdfs:comment 'Day 1 retention rate percentage (0.00 to 100.00) for players in this segment. Measures the percentage of players who return the day after first session.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:definitionCriteria rdf:type rdf:Property ;
    rdfs:label 'Definition Criteria' ;
    rdfs:comment 'Business rule or SQL-like expression defining segment membership criteria. For rule-based segments, contains the logical conditions; for ML-based segments, references the model identifier and feature set.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:definitionType rdf:type rdf:Property ;
    rdfs:label 'Definition Type' ;
    rdfs:comment 'Method used to define segment membership: rule-based (SQL/business logic), ML model (predictive algorithm), hybrid (rules + ML), or manual upload (curated list).' ;
    rdfs:domain ind:PlayerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedSegmentSize rdf:type rdf:Property ;
    rdfs:label 'Estimated Segment Size' ;
    rdfs:comment 'Approximate count of unique players currently matching the segment criteria at last refresh. Used for campaign planning and audience sizing.' ;
    rdfs:domain ind:PlayerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes defining the geographic scope of the segment (e.g., USA, GBR, JPN). Empty if global.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRefreshDate rdf:type rdf:Property ;
    rdfs:label 'Last Refresh Date' ;
    rdfs:comment 'Date when the segment membership was last recalculated and refreshed. Critical for ensuring targeting accuracy and data freshness.' ;
    rdfs:domain ind:PlayerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lookalikeSeedEligible rdf:type rdf:Property ;
    rdfs:label 'Lookalike Seed Eligible' ;
    rdfs:comment 'Indicates whether this segment is approved for use as a seed audience in lookalike modeling for paid user acquisition campaigns.' ;
    rdfs:domain ind:PlayerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ltvTier rdf:type rdf:Property ;
    rdfs:label 'Ltv Tier' ;
    rdfs:comment 'Lifetime value tier classification for players in this segment: whale (top spenders), high, medium, low, or unknown. Supports value-based targeting strategies.' ;
    rdfs:domain ind:PlayerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlModelReference rdf:type rdf:Property ;
    rdfs:label 'Ml Model Reference' ;
    rdfs:comment 'Reference identifier to the ML model used for segment generation, if applicable. Links to model registry for versioning and reproducibility.' ;
    rdfs:domain ind:PlayerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owningTeamContact rdf:type rdf:Property ;
    rdfs:label 'Owning Team Contact' ;
    rdfs:comment 'Primary email contact for the team responsible for this segment. Used for operational coordination and issue escalation.' ;
    rdfs:domain ind:PlayerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pciDssApplicable rdf:type rdf:Property ;
    rdfs:label 'Pci Dss Applicable' ;
    rdfs:comment 'Indicates whether this segment involves payment card data and must comply with PCI DSS requirements. Typically true for payer and whale segments.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:playerSegmentDescription rdf:type rdf:Property ;
    rdfs:label 'Player Segment Description' ;
    rdfs:comment 'Detailed business description of the segment purpose, targeting strategy, and intended use cases. Provides context for marketing teams and stakeholders.' ;
    rdfs:domain ind:PlayerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refreshFrequency rdf:type rdf:Property ;
    rdfs:label 'Refresh Frequency' ;
    rdfs:comment 'Cadence at which the segment is recalculated: real-time (streaming), hourly, daily, weekly, monthly, or on-demand (manual trigger).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suppressionListFlag rdf:type rdf:Property ;
    rdfs:label 'Suppression List Flag' ;
    rdfs:comment 'Indicates whether this segment is used as a suppression list to exclude players from targeting (e.g., churned players, high-value players to avoid cannibalization).' ;
    rdfs:domain ind:PlayerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'Total marketing spend attributed to acquiring this cohort. Used to calculate Cost Per Install (CPI) and Return on Ad Spend (ROAS). Expressed in the base currency (typically USD).' ;
    rdfs:domain ind:RetentionCohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cohortSegment rdf:type rdf:Property ;
    rdfs:label 'Cohort Segment' ;
    rdfs:comment 'Business-defined segment or classification for this cohort based on performance, strategic importance, or experimental grouping (e.g., high-value, test-group-A, organic-tier-1).' ;
    rdfs:domain ind:RetentionCohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cohortSize rdf:type rdf:Property ;
    rdfs:label 'Cohort Size' ;
    rdfs:comment 'Total number of unique players who installed the game on the install date and are included in this cohort.' ;
    rdfs:domain ind:RetentionCohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conversionToPayerRate rdf:type rdf:Property ;
    rdfs:label 'Conversion To Payer Rate' ;
    rdfs:comment 'Percentage of users in this cohort who converted from free players to paying users, calculated as paying_users_count divided by cohort_size. Expressed as a decimal (e.g., 0.0523 for 5.23%).' ;
    rdfs:domain ind:RetentionCohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:d1RetainedPlayers rdf:type rdf:Property ;
    rdfs:label 'D1 Retained Players' ;
    rdfs:comment 'Number of players from this cohort who returned to the game on Day 1 after install.' ;
    rdfs:domain ind:RetentionCohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:d30RetainedPlayers rdf:type rdf:Property ;
    rdfs:label 'D30 Retained Players' ;
    rdfs:comment 'Number of players from this cohort who returned to the game on Day 30 after install.' ;
    rdfs:domain ind:RetentionCohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:d60RetainedPlayers rdf:type rdf:Property ;
    rdfs:label 'D60 Retained Players' ;
    rdfs:comment 'Number of players from this cohort who returned to the game on Day 60 after install.' ;
    rdfs:domain ind:RetentionCohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:d60RetentionRate rdf:type rdf:Property ;
    rdfs:label 'D60 Retention Rate' ;
    rdfs:comment 'Percentage of players from this cohort who returned on Day 60, calculated as d60_retained_players divided by cohort_size. Expressed as a decimal (e.g., 0.0512 for 5.12%).' ;
    rdfs:domain ind:RetentionCohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:d7RetainedPlayers rdf:type rdf:Property ;
    rdfs:label 'D7 Retained Players' ;
    rdfs:comment 'Number of players from this cohort who returned to the game on Day 7 after install.' ;
    rdfs:domain ind:RetentionCohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:d90RetainedPlayers rdf:type rdf:Property ;
    rdfs:label 'D90 Retained Players' ;
    rdfs:comment 'Number of players from this cohort who returned to the game on Day 90 after install.' ;
    rdfs:domain ind:RetentionCohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:d90RetentionRate rdf:type rdf:Property ;
    rdfs:label 'D90 Retention Rate' ;
    rdfs:comment 'Percentage of players from this cohort who returned on Day 90, calculated as d90_retained_players divided by cohort_size. Expressed as a decimal (e.g., 0.0345 for 3.45%).' ;
    rdfs:domain ind:RetentionCohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dauContribution rdf:type rdf:Property ;
    rdfs:label 'Dau Contribution' ;
    rdfs:comment 'Average number of daily active users contributed by this cohort over the measurement period, representing the cohorts ongoing engagement impact.' ;
    rdfs:domain ind:RetentionCohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:installDate rdf:type rdf:Property ;
    rdfs:label 'Install Date' ;
    rdfs:comment 'The calendar date on which players in this cohort first installed the game. This is the cohort anchor date used for retention calculations.' ;
    rdfs:domain ind:RetentionCohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementWindowDays rdf:type rdf:Property ;
    rdfs:label 'Measurement Window Days' ;
    rdfs:comment 'Number of days since install date for which retention and revenue metrics have been measured for this cohort. Used to determine data maturity and projection confidence.' ;
    rdfs:domain ind:RetentionCohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payingUsersCount rdf:type rdf:Property ;
    rdfs:label 'Paying Users Count' ;
    rdfs:comment 'Total number of users in this cohort who have made at least one in-app purchase or microtransaction.' ;
    rdfs:domain ind:RetentionCohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roas rdf:type rdf:Property ;
    rdfs:label 'Roas' ;
    rdfs:comment 'Return on ad spend for this cohort, calculated as total_revenue divided by acquisition_cost. Expressed as a ratio (e.g., 2.5000 means $2.50 revenue per $1.00 spent).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adImpressionId rdf:type rdf:Property ;
    rdfs:label 'Ad Impression Id' ;
    rdfs:comment 'Unique identifier for the ad impression event. Primary key for the ad impression transactional record.' ;
    rdfs:domain ind:AdImpression ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adPlacementId rdf:type rdf:Property ;
    rdfs:label 'Ad Placement Id' ;
    rdfs:comment 'Reference to the ad placement configuration that defines where and how the ad was displayed within the game. Links to the ad placement master entity.' ;
    rdfs:domain ind:Monetization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdPlacement .

ind:adUnitId rdf:type rdf:Property ;
    rdfs:label 'Ad Unit Id' ;
    rdfs:comment 'The unique identifier for the ad unit within the ad network. Used for tracking and reconciliation with ad network reporting.' ;
    rdfs:domain ind:Monetization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdUnit .

ind:adFormat rdf:type rdf:Property ;
    rdfs:label 'Ad Format' ;
    rdfs:comment 'The format or type of ad that was displayed. Defines the user experience and engagement model for the ad impression.' ;
    rdfs:domain ind:Monetization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adNetwork rdf:type rdf:Property ;
    rdfs:label 'Ad Network' ;
    rdfs:comment 'The advertising network or mediation platform that served the ad impression. Identifies the source of the ad inventory. [ENUM-REF-CANDIDATE: admob|unity_ads|ironsource|applovin|vungle|chartboost|facebook_audience_network|mopub|adcolony|tapjoy|direct — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AdImpression ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adSize rdf:type rdf:Property ;
    rdfs:label 'Ad Size' ;
    rdfs:comment 'The dimensions of the ad creative in pixels (e.g., 320x50, 728x90, fullscreen). Used for creative optimization and placement analysis.' ;
    rdfs:domain ind:AdImpression ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceModel rdf:type rdf:Property ;
    rdfs:label 'Device Model' ;
    rdfs:comment 'The specific model of the device on which the ad impression occurred (e.g., iPhone 14 Pro, Samsung Galaxy S23). Used for device-specific optimization.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceOs rdf:type rdf:Property ;
    rdfs:label 'Device Os' ;
    rdfs:comment 'The operating system of the device on which the ad impression occurred (e.g., iOS 16.2, Android 13, Windows 11).' ;
    rdfs:domain ind:AdImpression ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecpmRevenue rdf:type rdf:Property ;
    rdfs:label 'Ecpm Revenue' ;
    rdfs:comment 'The estimated revenue earned from this ad impression based on eCPM rates. Calculated as (revenue / impressions) * 1000. Used for hybrid LTV modeling.' ;
    rdfs:domain ind:AdImpression ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeRateToUsd rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate To Usd' ;
    rdfs:comment 'The exchange rate used to convert the revenue amount to USD for consolidated reporting. Rate at the time of impression.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fillRateFlag rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Flag' ;
    rdfs:comment 'Boolean flag indicating whether the ad request was successfully filled by the ad network. True if filled, False if no fill. Used for fill rate calculations.' ;
    rdfs:domain ind:AdImpression ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impressionDate rdf:type rdf:Property ;
    rdfs:label 'Impression Date' ;
    rdfs:comment 'The calendar date when the ad impression occurred. Used for daily aggregation and reporting of ad revenue.' ;
    rdfs:domain ind:AdImpression ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:impressionStatus rdf:type rdf:Property ;
    rdfs:label 'Impression Status' ;
    rdfs:comment 'The lifecycle status of the ad impression indicating whether it was successfully served, viewed, or encountered an error. [ENUM-REF-CANDIDATE: served|viewed|clicked|completed|skipped|error|timeout — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AdImpression ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFirstImpression rdf:type rdf:Property ;
    rdfs:label 'Is First Impression' ;
    rdfs:comment 'Boolean flag indicating whether this was the player\'s first ad impression in the game. True if first impression, False otherwise. Used for FTUE analysis.' ;
    rdfs:domain ind:AdImpression ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRewarded rdf:type rdf:Property ;
    rdfs:label 'Is Rewarded' ;
    rdfs:comment 'Boolean flag indicating whether this ad impression was a rewarded ad (player receives in-game reward for watching). True if rewarded, False if non-rewarded.' ;
    rdfs:domain ind:AdImpression ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediationWaterfallPosition rdf:type rdf:Property ;
    rdfs:label 'Mediation Waterfall Position' ;
    rdfs:comment 'The position in the ad mediation waterfall where this ad network was called. Used for mediation optimization and fill rate analysis.' ;
    rdfs:domain ind:AdImpression ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playerLevelAtImpression rdf:type rdf:Property ;
    rdfs:label 'Player Level At Impression' ;
    rdfs:comment 'The player\'s in-game level or progression tier at the time of the ad impression. Used for player segmentation and ad targeting analysis.' ;
    rdfs:domain ind:AdImpression ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Amount' ;
    rdfs:comment 'The actual revenue earned from this ad impression in the reporting currency. The net proceeds after ad network fees.' ;
    rdfs:domain ind:AdImpression ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Revenue Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the revenue amount (e.g., USD, EUR, JPY). Used for multi-currency revenue reporting.' ;
    rdfs:domain ind:AdImpression ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueUsd rdf:type rdf:Property ;
    rdfs:label 'Revenue Usd' ;
    rdfs:comment 'The revenue amount converted to USD using the exchange rate. Used for consolidated financial reporting and ARPDAU calculations.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rewardAmount rdf:type rdf:Property ;
    rdfs:label 'Reward Amount' ;
    rdfs:comment 'The quantity of the reward granted to the player (e.g., 100 coins, 1 extra life). Null if no reward granted.' ;
    rdfs:domain ind:Monetization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Reward Granted Flag' ;
    rdfs:comment 'Boolean flag indicating whether the in-game reward was successfully granted to the player after ad completion. True if reward granted, False if not granted.' ;
    rdfs:domain ind:AdImpression ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:viewabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Viewability Flag' ;
    rdfs:comment 'Boolean flag indicating whether the ad impression met viewability standards (e.g., 50% of pixels visible for 1 second). True if viewable, False otherwise.' ;
    rdfs:domain ind:AdImpression ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:watchCompletionPercentage rdf:type rdf:Property ;
    rdfs:label 'Watch Completion Percentage' ;
    rdfs:comment 'The percentage of the ad video that the player watched before closing or completing. Range 0.00 to 100.00. Critical for rewarded video completion tracking.' ;
    rdfs:domain ind:AdImpression ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nameLocalizationStringId rdf:type rdf:Property ;
    rdfs:label 'Name Localization String Id' ;
    rdfs:comment 'Foreign key linking to content.localization_string. Business justification: Ad placement UI text (reward descriptions, call-to-action) needs localization for international audiences. Essential for global ad monetization and player comprehension.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LocalizationString .

ind:primaryAdEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Ad Employee Id' ;
    rdfs:comment 'Identifier of the user or system that created this ad placement record.' ;
    rdfs:domain ind:AdPlacement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:rewardAssetId rdf:type rdf:Property ;
    rdfs:label 'Reward Asset Id' ;
    rdfs:comment 'Foreign key linking to content.asset. Business justification: Rewarded video ads grant cosmetic assets (skins, emotes) as player incentives. Links ad placement to specific reward content for entitlement delivery and ad performance tracking.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:adNetworkPartner rdf:type rdf:Property ;
    rdfs:label 'Ad Network Partner' ;
    rdfs:comment 'Primary ad network partner serving ads to this placement (Unity Ads, ironSource, AdMob, AppLovin, Vungle, Chartboost).' ;
    rdfs:domain ind:AdPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ageGateMinimum rdf:type rdf:Property ;
    rdfs:label 'Age Gate Minimum' ;
    rdfs:comment 'Minimum age required for a player to be eligible to see this ad placement, enforced for COPPA and regional compliance.' ;
    rdfs:domain ind:AdPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageEcpmUsd rdf:type rdf:Property ;
    rdfs:label 'Average Ecpm Usd' ;
    rdfs:comment 'Average eCPM in USD achieved by this ad placement over its lifetime.' ;
    rdfs:domain ind:AdPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cooldownSeconds rdf:type rdf:Property ;
    rdfs:label 'Cooldown Seconds' ;
    rdfs:comment 'Minimum time in seconds that must elapse between consecutive displays of this ad placement to the same player.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:displayPriority rdf:type rdf:Property ;
    rdfs:label 'Display Priority' ;
    rdfs:comment 'Priority ranking for this ad placement when multiple placements are eligible at the same trigger context (lower number = higher priority).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ecpmFloorUsd rdf:type rdf:Property ;
    rdfs:label 'Ecpm Floor Usd' ;
    rdfs:comment 'Minimum eCPM floor price in USD that ad networks must meet to serve ads in this placement.' ;
    rdfs:domain ind:AdPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:excludePayingPlayers rdf:type rdf:Property ;
    rdfs:label 'Exclude Paying Players' ;
    rdfs:comment 'Flag indicating whether players who have made any in-app purchase should be excluded from seeing this ad placement.' ;
    rdfs:domain ind:AdPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fillRateTargetPct rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Target Pct' ;
    rdfs:comment 'Target fill rate percentage for this ad placement representing the desired proportion of ad requests that should be filled with ads.' ;
    rdfs:domain ind:AdPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frequencyCapPerDay rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap Per Day' ;
    rdfs:comment 'Maximum number of times this ad placement can be shown to a player within a 24-hour period.' ;
    rdfs:domain ind:AdPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyCapPerSession rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap Per Session' ;
    rdfs:comment 'Maximum number of times this ad placement can be shown to a player within a single game session.' ;
    rdfs:domain ind:AdPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geographicAvailability rdf:type rdf:Property ;
    rdfs:label 'Geographic Availability' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where this ad placement is available (e.g., USA,CAN,GBR).' ;
    rdfs:domain ind:Monetization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifetimeClicks rdf:type rdf:Property ;
    rdfs:label 'Lifetime Clicks' ;
    rdfs:comment 'Total cumulative number of ad clicks recorded for this placement since activation.' ;
    rdfs:domain ind:AdPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lifetimeImpressions rdf:type rdf:Property ;
    rdfs:label 'Lifetime Impressions' ;
    rdfs:comment 'Total cumulative number of ad impressions served through this placement since activation.' ;
    rdfs:domain ind:AdPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lifetimeRevenueUsd rdf:type rdf:Property ;
    rdfs:label 'Lifetime Revenue Usd' ;
    rdfs:comment 'Total cumulative ad revenue in USD generated by this placement since activation.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mediationEnabled rdf:type rdf:Property ;
    rdfs:label 'Mediation Enabled' ;
    rdfs:comment 'Indicates whether ad mediation is enabled for this placement to optimize fill rate and eCPM across multiple networks.' ;
    rdfs:domain ind:Monetization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumPlayerLevel rdf:type rdf:Property ;
    rdfs:label 'Minimum Player Level' ;
    rdfs:comment 'Minimum player level required to be eligible to see this ad placement.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:placementCode rdf:type rdf:Property ;
    rdfs:label 'Placement Code' ;
    rdfs:comment 'Unique business identifier code for the ad placement used across ad networks and internal systems.' ;
    rdfs:domain ind:AdPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementNotes rdf:type rdf:Property ;
    rdfs:label 'Placement Notes' ;
    rdfs:comment 'Internal notes and comments about this ad placement for operational reference and context.' ;
    rdfs:domain ind:AdPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementStatus rdf:type rdf:Property ;
    rdfs:label 'Placement Status' ;
    rdfs:comment 'Current lifecycle status of the ad placement indicating whether it is actively serving ads.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerSegmentEligibility rdf:type rdf:Property ;
    rdfs:label 'Player Segment Eligibility' ;
    rdfs:comment 'Comma-separated list of player segments eligible to see this ad placement (e.g., f2p_non_payer, low_ltv, new_user, churned_user).' ;
    rdfs:domain ind:AdPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerContext rdf:type rdf:Property ;
    rdfs:label 'Trigger Context' ;
    rdfs:comment 'Game event or player action that triggers the ad placement (e.g., between_levels, opt_in_reward, storefront_entry, session_start, game_over).' ;
    rdfs:domain ind:AdPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featuredRewardAssetId rdf:type rdf:Property ;
    rdfs:label 'Featured Reward Asset Id' ;
    rdfs:comment 'Foreign key linking to content.asset. Business justification: Battle passes feature hero cosmetic assets as tier rewards. Links reward content to pass definition for marketing materials, reward fulfillment, and player progression UI display.' ;
    rdfs:domain ind:BattlePass ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:containsLootBox rdf:type rdf:Property ;
    rdfs:label 'Contains Loot Box' ;
    rdfs:comment 'Indicates whether this battle pass includes any randomized reward mechanics (loot boxes or gacha elements). Critical for regulatory compliance disclosures under FTC, European Commission Digital Services Act, and PEGI/ESRB loot box disclosure requirements.' ;
    rdfs:domain ind:BattlePass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentEntitlements rdf:type rdf:Property ;
    rdfs:label 'Content Entitlements' ;
    rdfs:comment 'Comma-separated list or reference to DLC (Downloadable Content) packs, cosmetic bundles, or game content items included as flat entitlements with this pass (primarily for \'content_access\' and \'hybrid\' types). Supports entitlement management and player support.' ;
    rdfs:domain ind:BattlePass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationDays rdf:type rdf:Property ;
    rdfs:label 'Duration Days' ;
    rdfs:comment 'Total number of days the battle pass is active, derived from start and end dates. Used for season length planning and player engagement benchmarking.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freeTierCount rdf:type rdf:Property ;
    rdfs:label 'Free Tier Count' ;
    rdfs:comment 'Number of tiers accessible on the free track without purchasing the premium pass. Supports F2P (Free-to-Play) conversion funnel analysis by quantifying the free value proposition.' ;
    rdfs:domain ind:BattlePass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gdprDataProcessingNote rdf:type rdf:Property ;
    rdfs:label 'Gdpr Data Processing Note' ;
    rdfs:comment 'Free-text note documenting any GDPR-relevant data processing activities associated with this pass product (e.g., behavioral tracking for progression analytics). Supports GDPR Article 30 Records of Processing Activities.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasFreeTrack rdf:type rdf:Property ;
    rdfs:label 'Has Free Track' ;
    rdfs:comment 'Indicates whether this battle pass includes a free progression track accessible to all players without purchase. Core F2P design flag used in conversion funnel and monetization analysis.' ;
    rdfs:domain ind:BattlePass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasPremiumPlus rdf:type rdf:Property ;
    rdfs:label 'Has Premium Plus' ;
    rdfs:comment 'Indicates whether this pass offers a higher-tier premium upgrade (e.g., \'Battle Pass Bundle\' or \'Premium+\') that includes additional rewards or tier skips beyond the base premium pass.' ;
    rdfs:domain ind:BattlePass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCrossPlatform rdf:type rdf:Property ;
    rdfs:label 'Is Cross Platform' ;
    rdfs:comment 'Indicates whether progress and entitlements from this battle pass are shared across multiple platforms (cross-progression). Relevant for platform certification and player experience consistency.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jiraEpicKey rdf:type rdf:Property ;
    rdfs:label 'Jira Epic Key' ;
    rdfs:comment 'Jira Epic key linking this battle pass product definition to its corresponding live-ops planning epic in the project management system (e.g., \'LIVEOPS-421\'). Enables traceability from product definition to development and QA work.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:launchRegion rdf:type rdf:Property ;
    rdfs:label 'Launch Region' ;
    rdfs:comment 'Comma-separated ISO 3166-1 alpha-3 country codes identifying the geographic regions where this battle pass is available for sale. Supports regional pricing, compliance, and marketing segmentation.' ;
    rdfs:domain ind:BattlePass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxTierSkips rdf:type rdf:Property ;
    rdfs:label 'Max Tier Skips' ;
    rdfs:comment 'Maximum number of tiers a player may purchase to skip (advance instantly) within this battle pass. Governs the pay-to-progress ceiling and P2W (Pay-to-Win) mechanics compliance.' ;
    rdfs:domain ind:BattlePass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passCode rdf:type rdf:Property ;
    rdfs:label 'Pass Code' ;
    rdfs:comment 'Externally-known alphanumeric code or SKU that uniquely identifies this pass product across distribution platforms (e.g., Steamworks, console SDKs, app stores). Used in platform certification and store listings.' ;
    rdfs:domain ind:BattlePass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passStatus rdf:type rdf:Property ;
    rdfs:label 'Pass Status' ;
    rdfs:comment 'Current lifecycle state of the battle pass product definition. \'draft\' = in design; \'scheduled\' = approved and awaiting season start; \'active\' = currently purchasable and progressing; \'expired\' = season ended, no longer purchasable; \'retired\' = permanently removed from catalog.' ;
    rdfs:domain ind:BattlePass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passType rdf:type rdf:Property ;
    rdfs:label 'Pass Type' ;
    rdfs:comment 'Classification of the pass monetization model. \'progression_tiered\' = XP-gated tier unlock system; \'content_access\' = flat subscription-style content entitlement (season pass); \'hybrid\' = combines both tier progression and flat content access.' ;
    rdfs:domain ind:BattlePass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformAvailability rdf:type rdf:Property ;
    rdfs:label 'Platform Availability' ;
    rdfs:comment 'Comma-separated list of platforms on which this battle pass is available for purchase (e.g., \'PC,PS5,XBOX,MOBILE,SWITCH\'). Drives platform-specific store listing and certification via Steamworks/Console SDKs. [ENUM-REF-CANDIDATE: PC|PS5|XBOX|MOBILE|SWITCH|STADIA — promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumPlusPriceUsd rdf:type rdf:Property ;
    rdfs:label 'Premium Plus Price Usd' ;
    rdfs:comment 'Retail price in USD for the premium-plus or bundle upgrade tier of the battle pass, if applicable. Null when has_premium_plus is false.' ;
    rdfs:domain ind:BattlePass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:premiumPriceUsd rdf:type rdf:Property ;
    rdfs:label 'Premium Price Usd' ;
    rdfs:comment 'Base retail price of the premium battle pass in US Dollars. The principal quantitative monetary value of this pass product. Used for ARPU, ARPPU, and revenue forecasting.' ;
    rdfs:domain ind:BattlePass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:premiumPriceVirtualCurrency rdf:type rdf:Property ;
    rdfs:label 'Premium Price Virtual Currency' ;
    rdfs:comment 'Price of the premium battle pass denominated in the game\'s primary virtual currency (e.g., V-Bucks, Coins). Supports virtual economy pricing analysis and IAP (In-App Purchase) conversion tracking.' ;
    rdfs:domain ind:BattlePass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:premiumTierCount rdf:type rdf:Property ;
    rdfs:label 'Premium Tier Count' ;
    rdfs:comment 'Number of tiers exclusively accessible on the premium (paid) track. Represents the incremental value proposition of the premium pass purchase.' ;
    rdfs:domain ind:BattlePass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rewardScheduleRef rdf:type rdf:Property ;
    rdfs:label 'Reward Schedule Ref' ;
    rdfs:comment 'Reference identifier or document path pointing to the reward schedule definition for this battle pass (e.g., a Jira Epic key, Perforce asset path, or content management system ID). Links to the detailed tier-by-tier reward manifest.' ;
    rdfs:domain ind:BattlePass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonLabel rdf:type rdf:Property ;
    rdfs:label 'Season Label' ;
    rdfs:comment 'Branded or thematic label for the season associated with this pass (e.g., \'Season of the Void\', \'Chapter 4 Season 2\'). Used in marketing and player-facing UI.' ;
    rdfs:domain ind:BattlePass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonNumber rdf:type rdf:Property ;
    rdfs:label 'Season Number' ;
    rdfs:comment 'Ordinal number of the game season associated with this pass (e.g., Season 7). Used for chronological ordering and player-facing season labeling.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:softLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Soft Launch Date' ;
    rdfs:comment 'Date on which the battle pass was made available in a limited set of markets or platforms prior to full global launch. Used for staged rollout tracking and pre-launch performance analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierCount rdf:type rdf:Property ;
    rdfs:label 'Tier Count' ;
    rdfs:comment 'Total number of progression tiers available in this battle pass. Applicable to \'progression_tiered\' and \'hybrid\' pass types. Null for pure \'content_access\' passes.' ;
    rdfs:domain ind:BattlePass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierSkipPriceUsd rdf:type rdf:Property ;
    rdfs:label 'Tier Skip Price Usd' ;
    rdfs:comment 'Price in USD to purchase a single tier skip within this battle pass. Used for MTX (Microtransaction) revenue modeling and P2W analysis.' ;
    rdfs:domain ind:BattlePass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upgradePathCode rdf:type rdf:Property ;
    rdfs:label 'Upgrade Path Code' ;
    rdfs:comment 'Code identifying the upgrade path available for this pass (e.g., free-to-premium, premium-to-premium-plus). Defines the upsell funnel structure for conversion rate analysis.' ;
    rdfs:domain ind:BattlePass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:virtualCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Virtual Currency Code' ;
    rdfs:comment 'Code identifying the in-game virtual currency used for the virtual currency price (e.g., \'VBUCKS\', \'COINS\', \'GEMS\'). Required for multi-currency virtual economy management.' ;
    rdfs:domain ind:BattlePass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:xpPerTier rdf:type rdf:Property ;
    rdfs:label 'Xp Per Tier' ;
    rdfs:comment 'Amount of XP (Experience Points) required to advance one tier in the battle pass progression system. Governs the grind curve and player engagement pacing.' ;
    rdfs:domain ind:BattlePass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryBattlePlayerAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Battle Player Account Id' ;
    rdfs:comment 'Reference to the player who owns this battle pass entitlement. Core party reference linking entitlement to the player account.' ;
    rdfs:domain ind:BattlePassEntitlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerAccount .

ind:ageGateVerified rdf:type rdf:Property ;
    rdfs:label 'Age Gate Verified' ;
    rdfs:comment 'Indicates whether the player passed the required age verification check prior to purchasing this battle pass. Required for COPPA compliance for players in applicable jurisdictions.' ;
    rdfs:domain ind:BattlePassEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentTier rdf:type rdf:Property ;
    rdfs:label 'Current Tier' ;
    rdfs:comment 'The highest tier the player has currently unlocked on the battle pass, spanning both free and premium tracks. Used for reward grant eligibility checks at runtime.' ;
    rdfs:domain ind:BattlePassEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentXp rdf:type rdf:Property ;
    rdfs:label 'Current Xp' ;
    rdfs:comment 'The player\'s current accumulated experience points (XP) within this battle pass season. XP determines tier progression and is the primary progression currency.' ;
    rdfs:domain ind:BattlePassEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:entitlementReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Entitlement Reference Code' ;
    rdfs:comment 'Externally-visible alphanumeric code uniquely identifying this entitlement record. Used in player support, receipts, and entitlement enforcement lookups.' ;
    rdfs:domain ind:BattlePassEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freeTierUnlocked rdf:type rdf:Property ;
    rdfs:label 'Free Tier Unlocked' ;
    rdfs:comment 'The highest tier unlocked on the free reward track. Tracked separately from premium tier to support free-vs-paid conversion analytics and reward grant logic.' ;
    rdfs:domain ind:BattlePassEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isCompleted rdf:type rdf:Property ;
    rdfs:label 'Is Completed' ;
    rdfs:comment 'Indicates whether the player has reached the maximum tier and fully completed the battle pass. Used for completion reward grants and engagement analytics.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGifted rdf:type rdf:Property ;
    rdfs:label 'Is Gifted' ;
    rdfs:comment 'Indicates whether this battle pass entitlement was received as a gift from another player rather than self-purchased. Supports gifting revenue segmentation.' ;
    rdfs:domain ind:BattlePassEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPremiumActive rdf:type rdf:Property ;
    rdfs:label 'Is Premium Active' ;
    rdfs:comment 'Indicates whether the player has activated the premium battle pass track. True means the player paid for premium access; False means free track only. Core entitlement enforcement flag.' ;
    rdfs:domain ind:BattlePassEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastProgressionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Progression Timestamp' ;
    rdfs:comment 'The most recent timestamp at which the player earned XP or advanced a tier on this battle pass. Used for engagement monitoring, lapsed-player identification, and re-engagement campaign targeting.' ;
    rdfs:domain ind:BattlePassEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxTier rdf:type rdf:Property ;
    rdfs:label 'Max Tier' ;
    rdfs:comment 'The total number of tiers available in this battle pass. Used to calculate completion percentage and determine if the player has fully completed the pass.' ;
    rdfs:domain ind:BattlePassEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netPurchaseAmount rdf:type rdf:Property ;
    rdfs:label 'Net Purchase Amount' ;
    rdfs:comment 'The net real-money amount charged to the player after discounts (purchase_price_amount minus discount_amount). Used for revenue recognition and ARPU/ARPPU reporting.' ;
    rdfs:domain ind:BattlePassEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentalConsentObtained rdf:type rdf:Property ;
    rdfs:label 'Parental Consent Obtained' ;
    rdfs:comment 'Indicates whether verifiable parental consent was obtained before granting this battle pass entitlement to a minor player. Mandatory for COPPA-regulated accounts.' ;
    rdfs:domain ind:BattlePassEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:playerLevelAtPurchase rdf:type rdf:Property ;
    rdfs:label 'Player Level At Purchase' ;
    rdfs:comment 'The player\'s account level at the time of battle pass premium track purchase. Used for conversion funnel segmentation and LTV modeling by player maturity cohort.' ;
    rdfs:domain ind:Licensing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:premiumTierUnlocked rdf:type rdf:Property ;
    rdfs:label 'Premium Tier Unlocked' ;
    rdfs:comment 'The highest tier unlocked on the premium reward track. Null or zero if the player has not activated the premium track. Drives premium reward grant eligibility.' ;
    rdfs:domain ind:BattlePassEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:purchasePriceAmount rdf:type rdf:Property ;
    rdfs:label 'Purchase Price Amount' ;
    rdfs:comment 'The gross real-money price paid by the player to activate the premium battle pass track, in the currency indicated by currency_code. Null for free-track-only entitlements.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rewardsClaimedCount rdf:type rdf:Property ;
    rdfs:label 'Rewards Claimed Count' ;
    rdfs:comment 'The total number of individual tier rewards the player has claimed from this battle pass entitlement. Used to measure reward engagement and identify players who earn but do not claim.' ;
    rdfs:domain ind:BattlePassEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierSkipSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Tier Skip Spend Amount' ;
    rdfs:comment 'Total real-money or virtual currency equivalent amount spent on tier skips for this entitlement. Contributes to ARPPU and LTV calculations for the monetization domain.' ;
    rdfs:domain ind:BattlePassEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierSkipsPurchased rdf:type rdf:Property ;
    rdfs:label 'Tier Skips Purchased' ;
    rdfs:comment 'The total number of tier skip purchases made by the player on this battle pass entitlement. Each skip advances the player one tier without earning XP. Key microtransaction (MTX) revenue signal.' ;
    rdfs:domain ind:BattlePassEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trackType rdf:type rdf:Property ;
    rdfs:label 'Track Type' ;
    rdfs:comment 'Indicates which reward track(s) the player has access to: free (default), premium (paid upgrade), or premium_plus (deluxe tier with bonus rewards). Drives reward grant eligibility at runtime.' ;
    rdfs:domain ind:BattlePassEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unclaimedRewardsCount rdf:type rdf:Property ;
    rdfs:label 'Unclaimed Rewards Count' ;
    rdfs:comment 'The number of rewards the player has unlocked but not yet claimed from this battle pass. High unclaimed counts may indicate engagement drop-off and trigger re-engagement nudges.' ;
    rdfs:domain ind:BattlePassEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:virtualCurrencyCost rdf:type rdf:Property ;
    rdfs:label 'Virtual Currency Cost' ;
    rdfs:comment 'The amount of in-game virtual currency (e.g., V-Bucks, Coins, Gems) spent to purchase the premium battle pass track, if applicable. Null for real-money-only purchases.' ;
    rdfs:domain ind:Licensing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:xpToNextTier rdf:type rdf:Property ;
    rdfs:label 'Xp To Next Tier' ;
    rdfs:comment 'The remaining XP required for the player to advance to the next battle pass tier. Supports real-time progression display and engagement nudge triggers.' ;
    rdfs:domain ind:BattlePassEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDlcPlayerAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Dlc Player Account Id' ;
    rdfs:comment 'Reference to the player who owns this DLC entitlement.' ;
    rdfs:domain ind:DlcEntitlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerAccount .

ind:seasonPassId rdf:type rdf:Property ;
    rdfs:label 'Season Pass Id' ;
    rdfs:comment 'Reference to the season pass if this DLC was granted through season pass ownership. Null if not from a season pass.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BattlePass .

ind:storefrontTransactionId rdf:type rdf:Property ;
    rdfs:label 'Storefront Transaction Id' ;
    rdfs:comment 'External transaction identifier from the platform storefront (Steam, Epic, PlayStation Store, Xbox Store, App Store, Google Play).' ;
    rdfs:domain ind:Monetization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorefrontTransaction .

ind:acquisitionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acquisition Timestamp' ;
    rdfs:comment 'Date and time when the player acquired this DLC entitlement. The principal business event timestamp for this transaction.' ;
    rdfs:domain ind:DlcEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downloadCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Download Completed Timestamp' ;
    rdfs:comment 'Date and time when the DLC content download was completed. Null if not yet completed.' ;
    rdfs:domain ind:DlcEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downloadStatus rdf:type rdf:Property ;
    rdfs:label 'Download Status' ;
    rdfs:comment 'Current status of the DLC content download to the players device.' ;
    rdfs:domain ind:DlcEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Entitlement Source System' ;
    rdfs:comment 'Name of the source system that originated this entitlement record (Steamworks, Epic Games Store, PlayStation Network, Xbox Live, etc.).' ;
    rdfs:domain ind:DlcEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstActivationTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Activation Timestamp' ;
    rdfs:comment 'Date and time when the player first activated or used the DLC content in-game.' ;
    rdfs:domain ind:DlcEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isRevoked rdf:type rdf:Property ;
    rdfs:label 'Is Revoked' ;
    rdfs:comment 'Boolean flag indicating whether this entitlement has been revoked due to refund, fraud, or policy violation.' ;
    rdfs:domain ind:DlcEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTransferable rdf:type rdf:Property ;
    rdfs:label 'Is Transferable' ;
    rdfs:comment 'Boolean flag indicating whether this entitlement can be transferred to another player account.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenseKeyToken rdf:type rdf:Property ;
    rdfs:label 'License Key Token' ;
    rdfs:comment 'Unique license key or token that grants access to the DLC content. Used for DRM validation.' ;
    rdfs:domain ind:DlcEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Purchase Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the purchase transaction.' ;
    rdfs:domain ind:DlcEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Revocation Timestamp' ;
    rdfs:comment 'Date and time when the entitlement was revoked. Null if not revoked.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:economyConfigId rdf:type rdf:Property ;
    rdfs:label 'Economy Config Id' ;
    rdfs:comment 'Unique identifier for the virtual economy configuration record. Primary key.' ;
    rdfs:domain ind:Licensing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EconomyConfig .

ind:baseEarnRatePrimary rdf:type rdf:Property ;
    rdfs:label 'Base Earn Rate Primary' ;
    rdfs:comment 'Default rate at which players earn primary currency per unit of gameplay activity (e.g., per match, per hour, per quest completion).' ;
    rdfs:domain ind:EconomyConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseEarnRateSecondary rdf:type rdf:Property ;
    rdfs:label 'Base Earn Rate Secondary' ;
    rdfs:comment 'Default rate at which players earn secondary currency per unit of gameplay activity. Typically lower than primary currency earn rate.' ;
    rdfs:domain ind:EconomyConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:configCode rdf:type rdf:Property ;
    rdfs:label 'Config Code' ;
    rdfs:comment 'Unique business identifier code for this economy configuration, used for external reference and integration.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configName rdf:type rdf:Property ;
    rdfs:label 'Config Name' ;
    rdfs:comment 'Human-readable name for this economy configuration (e.g., \'Season 5 Premium Economy\', \'Launch Week Economy\').' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configNotes rdf:type rdf:Property ;
    rdfs:label 'Config Notes' ;
    rdfs:comment 'Free-text notes documenting the business rationale, design decisions, or special considerations for this economy configuration.' ;
    rdfs:domain ind:EconomyConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configStatus rdf:type rdf:Property ;
    rdfs:label 'Config Status' ;
    rdfs:comment 'Current lifecycle status of this economy configuration. Draft configurations are under development, active configurations are live in-game, suspended configurations are temporarily disabled, and archived configurations are historical records.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configVersion rdf:type rdf:Property ;
    rdfs:label 'Config Version' ;
    rdfs:comment 'Semantic version number of this economy configuration (e.g., 1.0.0, 2.1.3). Used for tracking configuration changes and rollbacks.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionFeePct rdf:type rdf:Property ;
    rdfs:label 'Conversion Fee Pct' ;
    rdfs:comment 'Percentage fee charged when players convert between primary and secondary currencies. Creates friction and currency sink.' ;
    rdfs:domain ind:EconomyConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currencyExpiryDays rdf:type rdf:Property ;
    rdfs:label 'Currency Expiry Days' ;
    rdfs:comment 'Number of days after which unspent currency expires and is removed from player accounts. Only applicable when currency_expiry_enabled is true.' ;
    rdfs:domain ind:EconomyConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currencyExpiryEnabled rdf:type rdf:Property ;
    rdfs:label 'Currency Expiry Enabled' ;
    rdfs:comment 'Indicates whether currency balances have expiration dates. When true, unspent currency may expire after a defined period.' ;
    rdfs:domain ind:EconomyConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dailyEarnCapPrimary rdf:type rdf:Property ;
    rdfs:label 'Daily Earn Cap Primary' ;
    rdfs:comment 'Maximum amount of primary currency a player can earn in a single day through gameplay. Prevents exploitation and maintains economy health.' ;
    rdfs:domain ind:EconomyConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dailyEarnCapSecondary rdf:type rdf:Property ;
    rdfs:label 'Daily Earn Cap Secondary' ;
    rdfs:comment 'Maximum amount of secondary currency a player can earn in a single day through gameplay. Typically lower than primary currency cap.' ;
    rdfs:domain ind:EconomyConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deflationThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Deflation Threshold Pct' ;
    rdfs:comment 'Maximum acceptable deflation rate (as percentage) before automated controls trigger. Measured as rate of currency sink exceeding earn rate.' ;
    rdfs:domain ind:EconomyConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:economyHealthScoreMin rdf:type rdf:Property ;
    rdfs:label 'Economy Health Score Min' ;
    rdfs:comment 'Minimum acceptable economy health score (0-100 scale) before alerts are triggered. Health score measures balance between earn and sink rates, inflation, and player engagement.' ;
    rdfs:domain ind:EconomyConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:economyHealthScoreTarget rdf:type rdf:Property ;
    rdfs:label 'Economy Health Score Target' ;
    rdfs:comment 'Target economy health score (0-100 scale) that represents optimal economy balance. Used for monitoring and automated adjustment decisions.' ;
    rdfs:domain ind:EconomyConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeRatePrimaryToSecondary rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Primary To Secondary' ;
    rdfs:comment 'Conversion rate from primary currency to secondary currency (e.g., 100 gold = 1 gem would be 0.01). Used for in-game currency conversion mechanics.' ;
    rdfs:domain ind:EconomyConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeRateSecondaryToPrimary rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Secondary To Primary' ;
    rdfs:comment 'Conversion rate from secondary currency to primary currency. May differ from inverse of primary-to-secondary rate to create conversion friction.' ;
    rdfs:domain ind:EconomyConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inflationControlEnabled rdf:type rdf:Property ;
    rdfs:label 'Inflation Control Enabled' ;
    rdfs:comment 'Indicates whether automated inflation control mechanisms are active for this economy configuration. When true, system may dynamically adjust earn/sink rates.' ;
    rdfs:domain ind:EconomyConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inflationThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Inflation Threshold Pct' ;
    rdfs:comment 'Maximum acceptable inflation rate (as percentage) before automated controls trigger. Measured as rate of currency supply growth exceeding sink rate.' ;
    rdfs:domain ind:EconomyConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxBalanceCapPrimary rdf:type rdf:Property ;
    rdfs:label 'Max Balance Cap Primary' ;
    rdfs:comment 'Maximum amount of primary currency a single player account can hold. Prevents hoarding and maintains economy balance.' ;
    rdfs:domain ind:EconomyConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxBalanceCapSecondary rdf:type rdf:Property ;
    rdfs:label 'Max Balance Cap Secondary' ;
    rdfs:comment 'Maximum amount of secondary currency a single player account can hold. Typically higher than primary currency cap for premium currency.' ;
    rdfs:domain ind:EconomyConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Primary Currency Code' ;
    rdfs:comment 'Code identifying the primary virtual currency governed by this configuration (e.g., \'GOLD\', \'GEMS\', \'VBUCKS\').' ;
    rdfs:domain ind:EconomyConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:realMoneyToPrimaryRate rdf:type rdf:Property ;
    rdfs:label 'Real Money To Primary Rate' ;
    rdfs:comment 'Conversion rate from real-world currency (USD) to primary virtual currency for IAP (In-App Purchase) transactions. Used for monetization calculations.' ;
    rdfs:domain ind:EconomyConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:realMoneyToSecondaryRate rdf:type rdf:Property ;
    rdfs:label 'Real Money To Secondary Rate' ;
    rdfs:comment 'Conversion rate from real-world currency (USD) to secondary virtual currency for IAP transactions. Typically more favorable than primary currency rate.' ;
    rdfs:domain ind:EconomyConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:secondaryCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Secondary Currency Code' ;
    rdfs:comment 'Code identifying the secondary or premium virtual currency governed by this configuration. Null if only one currency is used.' ;
    rdfs:domain ind:EconomyConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sinkRateTargetPrimary rdf:type rdf:Property ;
    rdfs:label 'Sink Rate Target Primary' ;
    rdfs:comment 'Target rate at which primary currency should be removed from the economy through player spending (e.g., per player per day). Used for economy health monitoring.' ;
    rdfs:domain ind:EconomyConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sinkRateTargetSecondary rdf:type rdf:Property ;
    rdfs:label 'Sink Rate Target Secondary' ;
    rdfs:comment 'Target rate at which secondary currency should be removed from the economy through player spending. Used for economy health monitoring.' ;
    rdfs:domain ind:EconomyConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ageGateRequired rdf:type rdf:Property ;
    rdfs:label 'Age Gate Required' ;
    rdfs:comment 'Indicates whether age verification is required before accessing this gacha pool due to regional regulations.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseDropRateR rdf:type rdf:Property ;
    rdfs:label 'Base Drop Rate R' ;
    rdfs:comment 'Base probability of obtaining an R (common rarity) item per pull, expressed as decimal (e.g., 0.9430 = 94.3%).' ;
    rdfs:domain ind:GachaPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseDropRateSr rdf:type rdf:Property ;
    rdfs:label 'Base Drop Rate Sr' ;
    rdfs:comment 'Base probability of obtaining an SR (high rarity) item per pull, expressed as decimal (e.g., 0.0510 = 5.1%).' ;
    rdfs:domain ind:GachaPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseDropRateSsr rdf:type rdf:Property ;
    rdfs:label 'Base Drop Rate Ssr' ;
    rdfs:comment 'Base probability of obtaining an SSR (highest rarity) item per pull, expressed as decimal (e.g., 0.0060 = 0.6%).' ;
    rdfs:domain ind:GachaPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collaborationPartner rdf:type rdf:Property ;
    rdfs:label 'Collaboration Partner' ;
    rdfs:comment 'Name of external IP (Intellectual Property) or brand partner if this is a collaboration gacha pool.' ;
    rdfs:domain ind:GachaPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerMultiPull rdf:type rdf:Property ;
    rdfs:label 'Cost Per Multi Pull' ;
    rdfs:comment 'Amount of currency required for a multi-pull (typically 10-pull) from this pool, often discounted.' ;
    rdfs:domain ind:GachaPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerSinglePull rdf:type rdf:Property ;
    rdfs:label 'Cost Per Single Pull' ;
    rdfs:comment 'Amount of currency required for a single gacha pull from this pool.' ;
    rdfs:domain ind:GachaPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:duplicateConversionEnabled rdf:type rdf:Property ;
    rdfs:label 'Duplicate Conversion Enabled' ;
    rdfs:comment 'Indicates whether duplicate items from this pool are automatically converted to alternative currency or resources.' ;
    rdfs:domain ind:GachaPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:duplicateConversionRate rdf:type rdf:Property ;
    rdfs:label 'Duplicate Conversion Rate' ;
    rdfs:comment 'Amount of alternative currency or resource awarded per duplicate item, if conversion is enabled.' ;
    rdfs:domain ind:GachaPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:featuredItemBoostRate rdf:type rdf:Property ;
    rdfs:label 'Featured Item Boost Rate' ;
    rdfs:comment 'Probability multiplier applied to featured items in this pool (e.g., 0.5000 represents 50% rate-up).' ;
    rdfs:domain ind:GachaPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hardPityThreshold rdf:type rdf:Property ;
    rdfs:label 'Hard Pity Threshold' ;
    rdfs:comment 'Maximum number of pulls after which a guaranteed high-rarity item is awarded.' ;
    rdfs:domain ind:GachaPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxPullsPerPlayer rdf:type rdf:Property ;
    rdfs:label 'Max Pulls Per Player' ;
    rdfs:comment 'Maximum number of pulls a single player can perform on this pool during its active window. Nullable for unlimited.' ;
    rdfs:domain ind:GachaPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:multiPullQuantity rdf:type rdf:Property ;
    rdfs:label 'Multi Pull Quantity' ;
    rdfs:comment 'Number of items granted in a single multi-pull transaction (typically 10).' ;
    rdfs:domain ind:GachaPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pityCounterShared rdf:type rdf:Property ;
    rdfs:label 'Pity Counter Shared' ;
    rdfs:comment 'Indicates whether the pity counter for this pool is shared with other pools or independent.' ;
    rdfs:domain ind:GachaPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:poolActiveEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pool Active End Timestamp' ;
    rdfs:comment 'Date and time when this gacha pool is no longer available to players. Nullable for permanent pools.' ;
    rdfs:domain ind:GachaPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:poolActiveStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pool Active Start Timestamp' ;
    rdfs:comment 'Date and time when this gacha pool becomes available to players.' ;
    rdfs:domain ind:GachaPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:poolDisplayOrder rdf:type rdf:Property ;
    rdfs:label 'Pool Display Order' ;
    rdfs:comment 'Sort order for displaying this gacha pool in the game UI, lower numbers appear first.' ;
    rdfs:domain ind:GachaPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:poolTheme rdf:type rdf:Property ;
    rdfs:label 'Pool Theme' ;
    rdfs:comment 'Thematic classification of the gacha pool (e.g., \'Fantasy\', \'Sci-Fi\', \'Holiday\', \'Collaboration\').' ;
    rdfs:domain ind:GachaPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolType rdf:type rdf:Property ;
    rdfs:label 'Pool Type' ;
    rdfs:comment 'Classification of the gacha pool indicating its business purpose and availability pattern.' ;
    rdfs:domain ind:GachaPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolVersion rdf:type rdf:Property ;
    rdfs:label 'Pool Version' ;
    rdfs:comment 'Version number of this gacha pool configuration, incremented when drop rates or items are modified.' ;
    rdfs:domain ind:GachaPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regionAvailability rdf:type rdf:Property ;
    rdfs:label 'Region Availability' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where this gacha pool is available (e.g., \'USA,JPN,KOR\'). [ENUM-REF-CANDIDATE: promote to reference product if more than 6 regions]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDisclosureText rdf:type rdf:Property ;
    rdfs:label 'Regulatory Disclosure Text' ;
    rdfs:comment 'Full legal disclosure text displayed to players regarding drop rates and probabilities, required by regional regulations.' ;
    rdfs:domain ind:GachaPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:softPityThreshold rdf:type rdf:Property ;
    rdfs:label 'Soft Pity Threshold' ;
    rdfs:comment 'Number of pulls after which drop rates for high-rarity items begin to increase incrementally.' ;
    rdfs:domain ind:GachaPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPullsLifetime rdf:type rdf:Property ;
    rdfs:label 'Total Pulls Lifetime' ;
    rdfs:comment 'Cumulative count of all pulls performed on this gacha pool since inception, for analytics and reporting.' ;
    rdfs:domain ind:GachaPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalRevenueLifetime rdf:type rdf:Property ;
    rdfs:label 'Total Revenue Lifetime' ;
    rdfs:comment 'Cumulative revenue generated by this gacha pool since inception, in base currency (USD).' ;
    rdfs:domain ind:GachaPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ageGateVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Age Gate Verified Flag' ;
    rdfs:comment 'Indicates whether the player passed age verification requirements for gacha participation in their jurisdiction. True if verified, false otherwise.' ;
    rdfs:domain ind:GachaPull ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bonusItemsGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Bonus Items Granted Flag' ;
    rdfs:comment 'Indicates whether additional bonus items were granted alongside the primary outcome (e.g., first-time bonuses, promotional extras). True if bonuses granted.' ;
    rdfs:domain ind:GachaPull ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conversionCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Conversion Currency Amount' ;
    rdfs:comment 'Amount of conversion currency (e.g., duplicate shards, exchange tokens) granted if the outcome was a duplicate. Null if not a duplicate.' ;
    rdfs:domain ind:GachaPull ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currencyAmount rdf:type rdf:Property ;
    rdfs:label 'Currency Amount' ;
    rdfs:comment 'Amount of virtual currency spent on this gacha pull. Denominated in the currency_type specified.' ;
    rdfs:domain ind:GachaPull ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disclosedDropRatePct rdf:type rdf:Property ;
    rdfs:label 'Disclosed Drop Rate Pct' ;
    rdfs:comment 'The publicly disclosed drop rate percentage for the rarity tier of the outcome item at the time of pull. Required for regulatory compliance in multiple jurisdictions.' ;
    rdfs:domain ind:GachaPull ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:duplicateFlag rdf:type rdf:Property ;
    rdfs:label 'Duplicate Flag' ;
    rdfs:comment 'Indicates whether the outcome item was a duplicate of an item the player already owned. True if duplicate, false if new acquisition.' ;
    rdfs:domain ind:GachaPull ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lifetimeGachaSpendUsd rdf:type rdf:Property ;
    rdfs:label 'Lifetime Gacha Spend Usd' ;
    rdfs:comment 'Cumulative real-money equivalent amount the player has spent on gacha pulls across all time, up to and including this transaction. Used for whale segmentation and LTV analysis.' ;
    rdfs:domain ind:GachaPull ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outcomeItemQuantity rdf:type rdf:Property ;
    rdfs:label 'Outcome Item Quantity' ;
    rdfs:comment 'Quantity of the primary outcome item granted to the player. Typically 1 for character/weapon pulls, may be higher for consumables.' ;
    rdfs:domain ind:GachaPull ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outcomeRarityTier rdf:type rdf:Property ;
    rdfs:label 'Outcome Rarity Tier' ;
    rdfs:comment 'Rarity classification of the primary item granted: common, uncommon, rare, epic, legendary, or mythic. Determines drop rate and player value perception.' ;
    rdfs:domain ind:GachaPull ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pityCounterAfter rdf:type rdf:Property ;
    rdfs:label 'Pity Counter After' ;
    rdfs:comment 'Value of the players pity counter immediately after this pull was executed. Reset to zero if pity was triggered.' ;
    rdfs:domain ind:GachaPull ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pityCounterBefore rdf:type rdf:Property ;
    rdfs:label 'Pity Counter Before' ;
    rdfs:comment 'Value of the players pity counter immediately before this pull was executed. Tracks cumulative pulls without a guaranteed drop.' ;
    rdfs:domain ind:GachaPull ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pityTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Pity Triggered Flag' ;
    rdfs:comment 'Indicates whether the pity mechanism was triggered for this pull, guaranteeing a high-rarity item. True if pity activated, false otherwise.' ;
    rdfs:domain ind:GachaPull ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:playerLevelAtPull rdf:type rdf:Property ;
    rdfs:label 'Player Level At Pull' ;
    rdfs:comment 'The players in-game level at the time this gacha pull was executed. Used for progression-based analytics and monetization funnel analysis.' ;
    rdfs:domain ind:GachaPull ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pullQuantity rdf:type rdf:Property ;
    rdfs:label 'Pull Quantity' ;
    rdfs:comment 'Number of items pulled in this single transaction. Typically 1 for single pulls, 10 for multi-pulls.' ;
    rdfs:domain ind:GachaPull ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pullTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pull Timestamp' ;
    rdfs:comment 'The exact date and time when the gacha pull was executed by the player. Primary business event timestamp for this transaction.' ;
    rdfs:domain ind:GachaPull ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pullType rdf:type rdf:Property ;
    rdfs:label 'Pull Type' ;
    rdfs:comment 'Type of gacha pull executed: single pull, multi-pull (10x), free pull, premium pull, or discounted pull. Affects cost and pity mechanics.' ;
    rdfs:domain ind:GachaPull ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:realMoneyEquivalentUsd rdf:type rdf:Property ;
    rdfs:label 'Real Money Equivalent Usd' ;
    rdfs:comment 'Equivalent real-world monetary value of the currency spent, converted to USD. Used for revenue recognition and ARPU calculations.' ;
    rdfs:domain ind:GachaPull ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundFlag rdf:type rdf:Property ;
    rdfs:label 'Refund Flag' ;
    rdfs:comment 'Indicates whether the currency spent on this gacha pull was subsequently refunded to the player. True if refunded, false otherwise.' ;
    rdfs:domain ind:GachaPull ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grantedAssetId rdf:type rdf:Property ;
    rdfs:label 'Granted Asset Id' ;
    rdfs:comment 'Foreign key linking to content.asset. Business justification: Direct asset purchases (character skins, weapon skins) via IAP require linking transaction to granted content for entitlement tracking, refund processing, and inventory management.' ;
    rdfs:domain ind:IapTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:bonusVirtualCurrency rdf:type rdf:Property ;
    rdfs:label 'Bonus Virtual Currency' ;
    rdfs:comment 'Additional virtual currency awarded as a promotional bonus on top of the base virtual_currency_awarded (e.g., first-purchase bonus, limited-time offer bonus). Null when no bonus applies. Supports offer effectiveness analysis.' ;
    rdfs:domain ind:IapTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coppaVerified rdf:type rdf:Property ;
    rdfs:label 'Coppa Verified' ;
    rdfs:comment 'Indicates whether the player\'s age was verified as meeting the minimum age requirement (13+ in the US) prior to this IAP transaction, per COPPA compliance requirements. True = age verification passed. Critical for regulatory compliance and audit trails involving minor players.' ;
    rdfs:domain ind:IapTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discountRate rdf:type rdf:Property ;
    rdfs:label 'Discount Rate' ;
    rdfs:comment 'The percentage discount applied to the gross price for this transaction (expressed as a decimal, e.g., 0.20 for 20% off). Derived from the offer campaign. Zero when no discount was applied. Supports offer ROI and conversion rate analysis.' ;
    rdfs:domain ind:IapTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entitlementGranted rdf:type rdf:Property ;
    rdfs:label 'Entitlement Granted' ;
    rdfs:comment 'Indicates whether the purchased item or virtual currency has been successfully delivered and credited to the player\'s account. True = entitlement fulfilled; False = pending or failed delivery. Critical for player support and dispute resolution.' ;
    rdfs:domain ind:IapTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entitlementGrantedAt rdf:type rdf:Property ;
    rdfs:label 'Entitlement Granted At' ;
    rdfs:comment 'Timestamp when the purchased item or virtual currency was successfully delivered to the player\'s account. Enables latency measurement between payment confirmation and entitlement fulfillment. Null if entitlement has not yet been granted.' ;
    rdfs:domain ind:IapTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'The full retail price charged to the player before any platform fees, taxes, or discounts are applied. Expressed in the transaction currency. Part of MONETARY_TRIPLET category per TRANSACTION_HEADER role. Used as the basis for gross revenue reporting.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isF2pConversion rdf:type rdf:Property ;
    rdfs:label 'Is F2p Conversion' ;
    rdfs:comment 'Indicates whether this IAP transaction represents the player\'s first-ever purchase, converting them from a Free-to-Play (F2P) non-payer to a paying player. True = first purchase / F2P conversion event. Critical for F2P conversion rate KPI and funnel analysis.' ;
    rdfs:domain ind:IapTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWhale rdf:type rdf:Property ;
    rdfs:label 'Is Whale' ;
    rdfs:comment 'Indicates whether the purchasing player was classified as a \'whale\' (high-spending player segment) at the time of this transaction, based on the company\'s LTV and spend segmentation model. Supports whale retention analysis and high-value player monetization reporting.' ;
    rdfs:domain ind:IapTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemType rdf:type rdf:Property ;
    rdfs:label 'Item Type' ;
    rdfs:comment 'Classification of the purchased item by monetization category. Drives revenue mix reporting, P2W analysis, and regulatory compliance (e.g., loot box disclosure requirements). [ENUM-REF-CANDIDATE: virtual_currency|dlc|battle_pass|loot_box|cosmetic|subscription|season_pass|consumable|durable — promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lootBoxRegulatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Loot Box Regulatory Flag' ;
    rdfs:comment 'Indicates whether this IAP transaction involved a loot box or gacha mechanic subject to regulatory disclosure requirements (e.g., ESRB loot box labeling, Belgium/Netherlands gambling regulations). True = disclosure was presented to the player prior to purchase. Required for regulatory compliance reporting.' ;
    rdfs:domain ind:IapTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netProceedsAmount rdf:type rdf:Property ;
    rdfs:label 'Net Proceeds Amount' ;
    rdfs:comment 'The net revenue amount received by the publisher after deducting platform fees, taxes, and discounts from the gross amount. Part of MONETARY_TRIPLET net total component. Primary metric for ARPU and ARPPU net revenue calculations.' ;
    rdfs:domain ind:IapTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchasedAt rdf:type rdf:Property ;
    rdfs:label 'Purchased At' ;
    rdfs:comment 'The precise real-world timestamp when the player initiated and confirmed the IAP purchase event on the storefront. BUSINESS_EVENT_TIMESTAMP category per TRANSACTION_HEADER role. Stored in ISO 8601 format with timezone offset. Primary time dimension for ARPU, ARPPU, and DAP calculations.' ;
    rdfs:domain ind:IapTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receiptToken rdf:type rdf:Property ;
    rdfs:label 'Receipt Token' ;
    rdfs:comment 'Cryptographic receipt or validation token issued by the platform storefront to verify the authenticity of the IAP transaction (e.g., Apple App Store receipt, Google Play purchase token). Used for server-side receipt validation to prevent fraud and unauthorized entitlement grants.' ;
    rdfs:domain ind:IapTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundEligibleUntil rdf:type rdf:Property ;
    rdfs:label 'Refund Eligible Until' ;
    rdfs:comment 'The timestamp until which the player is eligible to request a refund for this IAP transaction, per platform policy and applicable consumer protection regulations. After this timestamp, refund requests may be declined. Null if the item is non-refundable.' ;
    rdfs:domain ind:IapTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:refundedAt rdf:type rdf:Property ;
    rdfs:label 'Refunded At' ;
    rdfs:comment 'Timestamp when a refund was processed for this IAP transaction. Null if no refund has been issued. Used for refund rate tracking, revenue reversal accounting, and chargeback analysis.' ;
    rdfs:domain ind:IapTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportingCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Amount' ;
    rdfs:comment 'Net proceeds amount converted to the company\'s functional reporting currency (USD) using the exchange_rate at transaction time. Enables standardized global revenue aggregation for ARPU, ARPPU, and LTV calculations.' ;
    rdfs:domain ind:IapTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storefrontTransactionRef rdf:type rdf:Property ;
    rdfs:label 'Storefront Transaction Ref' ;
    rdfs:comment 'The externally-known transaction identifier issued by the platform storefront (e.g., Apple App Store order ID, Google Play order ID, Steam transaction ID, PlayStation Store transaction ID). BUSINESS_IDENTIFIER category per TRANSACTION_HEADER role. Used for receipt validation, dispute resolution, and platform reconciliation.' ;
    rdfs:domain ind:IapTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current lifecycle state of the IAP transaction. LIFECYCLE_STATUS category per TRANSACTION_HEADER role. \'completed\' = payment confirmed and entitlement granted; \'pending\' = awaiting payment confirmation; \'failed\' = payment declined or error; \'refunded\' = reversal processed; \'disputed\' = chargeback or player dispute raised; \'cancelled\' = voided before completion.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:virtualCurrencyAwarded rdf:type rdf:Property ;
    rdfs:label 'Virtual Currency Awarded' ;
    rdfs:comment 'The amount of in-game virtual currency (e.g., gems, coins, gold) credited to the player\'s account as a result of this IAP. Null for non-currency item purchases. Essential for virtual economy balance tracking and sink/source analysis.' ;
    rdfs:domain ind:IapTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:displayAssetId rdf:type rdf:Property ;
    rdfs:label 'Display Asset Id' ;
    rdfs:comment 'Foreign key linking to content.asset. Business justification: MTX catalog items require visual assets (icons, 3D models, preview images) for storefront display. Essential for store UI rendering and player purchase decisions in live game economy.' ;
    rdfs:domain ind:MtxCatalog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:ageRestrictionMinimum rdf:type rdf:Property ;
    rdfs:label 'Age Restriction Minimum' ;
    rdfs:comment 'Minimum player age in years required to purchase this MTX offering, derived from content_rating_esrb and content_rating_pegi classifications. Enforced at checkout for COPPA compliance (under-13 restrictions in USA) and GDPR child data protection requirements in EU (under-16 in some jurisdictions).' ;
    rdfs:domain ind:MtxCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:basePriceUsd rdf:type rdf:Property ;
    rdfs:label 'Base Price Usd' ;
    rdfs:comment 'Canonical base retail price of the MTX offering denominated in US Dollars (USD). Serves as the reference price from which regional overrides and promotional discounts are derived. Used in ARPU, ARPPU, and LTV calculations. Maps to MASTER_RESOURCE category: MEASUREMENT_OR_VALUE. Source of truth for SAP S/4HANA FI revenue recognition.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bundleParentSkuCode rdf:type rdf:Property ;
    rdfs:label 'Bundle Parent Sku Code' ;
    rdfs:comment 'SKU code of the parent bundle offering if this item is a component of a larger bundle package. Null for standalone items. Enables bundle composition analysis, bundle vs. individual item revenue attribution, and bundle discount effectiveness reporting.' ;
    rdfs:domain ind:MtxCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRatingEsrb rdf:type rdf:Property ;
    rdfs:label 'Content Rating Esrb' ;
    rdfs:comment 'ESRB content rating applicable to this MTX offering, restricting purchase eligibility for underage players in North American markets. Critical for COPPA compliance — items rated M or AO must enforce age-gate purchase restrictions. Sourced from ESRB rating submission records.' ;
    rdfs:domain ind:MtxCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRatingPegi rdf:type rdf:Property ;
    rdfs:label 'Content Rating Pegi' ;
    rdfs:comment 'PEGI content rating applicable to this MTX offering for European markets. Restricts purchase eligibility for underage players in EU/EEA jurisdictions. Items with PEGI 18 rating require age verification enforcement per GDPR and national consumer protection laws.' ;
    rdfs:domain ind:MtxCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyRoundingPolicy rdf:type rdf:Property ;
    rdfs:label 'Currency Rounding Policy' ;
    rdfs:comment 'Defines the mathematical rounding rule applied when converting base_price_usd to regional currencies or when applying promotional discounts that result in fractional currency amounts. Ensures consistent pricing presentation across storefronts and compliance with local consumer protection pricing laws.' ;
    rdfs:domain ind:MtxCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmProtectionType rdf:type rdf:Property ;
    rdfs:label 'Drm Protection Type' ;
    rdfs:comment 'Type of Digital Rights Management (DRM) protection applied to this MTX offering to prevent unauthorized duplication or transfer of entitlements. \'platform_native\' = Steam/PSN/Xbox DRM; \'entitlement_server\' = proprietary server-side entitlement validation; \'none\' = no DRM (e.g., promo codes).' ;
    rdfs:domain ind:MtxCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dropRateDisclosed rdf:type rdf:Property ;
    rdfs:label 'Drop Rate Disclosed' ;
    rdfs:comment 'Indicates whether the probability/drop rate for randomized rewards within this MTX offering (e.g., loot box, gacha pull) has been publicly disclosed to players. Required for compliance with ESRB loot box disclosure policy, Chinese Ministry of Culture gacha regulations, and Apple App Store Review Guidelines Section 3.1.1.' ;
    rdfs:domain ind:MtxCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Calendar date on which this MTX catalog entry becomes available for purchase on storefronts. Defines the start of the offering\'s active pricing window. Used in time-series revenue analysis, seasonal campaign planning, and live operations (GaaS) scheduling.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntilDate rdf:type rdf:Property ;
    rdfs:label 'Effective Until Date' ;
    rdfs:comment 'Calendar date on which this MTX catalog entry is no longer available for purchase. Null indicates the offering has no planned end date (evergreen). Drives storefront availability logic, seasonal item retirement workflows, and battle pass expiry enforcement.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:imageAssetPath rdf:type rdf:Property ;
    rdfs:label 'Image Asset Path' ;
    rdfs:comment 'CDN-relative path or URI to the primary promotional image asset for this MTX offering as displayed in the in-game store (e.g., \'/assets/mtx/skins/dragon_pack_thumb.png\'). Managed via Perforce Helix Core digital asset management. Used by storefront rendering pipeline.' ;
    rdfs:domain ind:MtxCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGiftable rdf:type rdf:Property ;
    rdfs:label 'Is Giftable' ;
    rdfs:comment 'Indicates whether this MTX offering can be purchased by one player and gifted to another player. Relevant for viral K-Factor mechanics and social gifting features. False for account-bound items, consumables with immediate activation, or items restricted by platform gifting policies.' ;
    rdfs:domain ind:MtxCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPromoCodeRedeemable rdf:type rdf:Property ;
    rdfs:label 'Is Promo Code Redeemable' ;
    rdfs:comment 'Indicates whether this MTX offering can be obtained via promotional or gift code redemption (distinct from direct purchase). Supports marketing campaign attribution in AppsFlyer/Adjust and tracks promo code distribution economics separately from paid IAP revenue.' ;
    rdfs:domain ind:MtxCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSaleEligible rdf:type rdf:Property ;
    rdfs:label 'Is Sale Eligible' ;
    rdfs:comment 'Indicates whether this MTX offering is eligible to be included in promotional sale events (e.g., seasonal sales, platform-wide discount events). False for items with fixed pricing agreements (e.g., certain DLC with publisher pricing floors) or newly released items under launch price protection windows.' ;
    rdfs:domain ind:MtxCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemDescription rdf:type rdf:Property ;
    rdfs:label 'Item Description' ;
    rdfs:comment 'Detailed player-facing description of the MTX offering explaining its contents, benefits, and any restrictions. Used in storefront listings, player support knowledge base (Zendesk), and community management communications. Must comply with FTC truth-in-advertising standards.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localizationKey rdf:type rdf:Property ;
    rdfs:label 'Localization Key' ;
    rdfs:comment 'Unique string key used to look up localized display_name and item_description translations in the game\'s localization system (e.g., \'mtx.skin.dragon.name\'). Enables multi-language storefront support across global markets without duplicating catalog entries per locale.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxPurchaseLimit rdf:type rdf:Property ;
    rdfs:label 'Max Purchase Limit' ;
    rdfs:comment 'Maximum number of times a single player account can purchase this MTX offering (e.g., limited edition items capped at 1 per account, or promotional packs capped at 3). Null indicates unlimited purchases. Enforced at transaction time to prevent abuse and maintain virtual economy balance.' ;
    rdfs:domain ind:MtxCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:platformFeePct rdf:type rdf:Property ;
    rdfs:label 'Platform Fee Pct' ;
    rdfs:comment 'Percentage of the retail price retained by the distribution platform (e.g., Steam 30%, Epic Games Store 12%, Apple App Store 30%, Google Play 15-30%) as a marketplace commission. Used in net revenue calculations, ARPPU analysis, and SAP S/4HANA CO profitability reporting. Expressed as a percentage (e.g., 30.00 = 30%).' ;
    rdfs:domain ind:MtxCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceEur rdf:type rdf:Property ;
    rdfs:label 'Price Eur' ;
    rdfs:comment 'Regional retail price override for the European market denominated in Euros (EUR). Accounts for VAT obligations, PEGI market requirements, and purchasing power parity adjustments. Null indicates base_price_usd converted at current exchange rate applies.' ;
    rdfs:domain ind:MtxCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceGbp rdf:type rdf:Property ;
    rdfs:label 'Price Gbp' ;
    rdfs:comment 'Regional retail price override for the United Kingdom market denominated in British Pounds Sterling (GBP). Reflects UK post-Brexit pricing strategy and VAT requirements. Null indicates base_price_usd converted at current exchange rate applies.' ;
    rdfs:domain ind:MtxCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceJpy rdf:type rdf:Property ;
    rdfs:label 'Price Jpy' ;
    rdfs:comment 'Regional retail price override for the Japanese market denominated in Japanese Yen (JPY). JPY has no decimal subdivision; stored as whole yen. Reflects CERO market requirements and local consumer pricing norms. Null indicates base_price_usd converted at current exchange rate applies.' ;
    rdfs:domain ind:MtxCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceKrw rdf:type rdf:Property ;
    rdfs:label 'Price Krw' ;
    rdfs:comment 'Regional retail price override for the South Korean market denominated in Korean Won (KRW). KRW has no decimal subdivision; stored as whole won. Reflects GRAC rating market requirements and local pricing strategy. Null indicates base_price_usd converted at current exchange rate applies.' ;
    rdfs:domain ind:MtxCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promoDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Promo Discount Pct' ;
    rdfs:comment 'Current or default promotional discount percentage applied to the base price during sale events (e.g., 25.00 = 25% off). Drives sale pricing calculations in the storefront. Null or 0 indicates no active promotional discount. Used in conversion rate analysis and F2P monetization funnel reporting.' ;
    rdfs:domain ind:MtxCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promoDiscountType rdf:type rdf:Property ;
    rdfs:label 'Promo Discount Type' ;
    rdfs:comment 'Defines the mechanism by which the promotional discount is applied: \'percentage\' = percentage reduction from base price; \'fixed_amount\' = fixed currency amount deducted; \'bundle_override\' = price is overridden by a bundle-level price; \'free\' = item is granted at no charge (e.g., F2P promotional giveaway).' ;
    rdfs:domain ind:MtxCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityInBundle rdf:type rdf:Property ;
    rdfs:label 'Quantity In Bundle' ;
    rdfs:comment 'Number of units of this item included when purchased as part of a bundle or currency pack (e.g., a \'1000 Gold Pack\' has quantity_in_bundle = 1000 for the gold currency item). Null or 1 for single-unit items. Supports virtual economy sink analysis and bundle value proposition reporting.' ;
    rdfs:domain ind:MtxCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueRecognitionCode rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Code' ;
    rdfs:comment 'SAP S/4HANA FI revenue recognition classification code governing how and when revenue from this MTX offering is recognized (e.g., immediate recognition for consumables, deferred recognition for battle passes/subscriptions over the service period). Ensures compliance with ASC 606 / IFRS 15 revenue recognition standards.' ;
    rdfs:domain ind:MtxCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Tax Category Code' ;
    rdfs:comment 'Tax classification code used in SAP S/4HANA FI for VAT/GST/sales tax determination on this MTX offering. Different item types (DLC, virtual currency, subscription) may attract different tax treatment across jurisdictions. Drives automated tax calculation in the payment processing pipeline.' ;
    rdfs:domain ind:MtxCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:virtualCurrencyType rdf:type rdf:Property ;
    rdfs:label 'Virtual Currency Type' ;
    rdfs:comment 'The specific in-game virtual currency denomination used for virtual_currency_cost (e.g., \'gold\', \'gems\', \'credits\', \'tokens\'). Null if item is real-money only. Supports multi-currency virtual economy modeling and sink/source balance reporting in GameAnalytics/Amplitude.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featuredDlcBundleId rdf:type rdf:Property ;
    rdfs:label 'Featured Dlc Bundle Id' ;
    rdfs:comment 'Foreign key linking to title.dlc_bundle. Business justification: Offer campaigns promote DLC bundles (e.g., Season Pass launch campaign). Business needs to track featured bundles for storefront merchandising, campaign ROI measurement, and marketing attribution. Cri' ;
    rdfs:domain ind:Licensing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DlcBundle .

ind:messageLocalizationStringId rdf:type rdf:Property ;
    rdfs:label 'Message Localization String Id' ;
    rdfs:comment 'Foreign key linking to content.localization_string. Business justification: Campaign messaging requires localization for regional targeting and compliance. Links offer to translated marketing copy for multi-region deployment and A/B testing.' ;
    rdfs:domain ind:Licensing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LocalizationString .

ind:parentCampaignOfferCampaignId rdf:type rdf:Property ;
    rdfs:label 'Parent Campaign Offer Campaign Id' ;
    rdfs:comment 'Reference to the parent campaign if this is a recurring instance or variant. Null if this is a standalone campaign.' ;
    rdfs:domain ind:OfferCampaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OfferCampaign .

ind:primaryOfferEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Offer Employee Id' ;
    rdfs:comment 'Reference to the internal user or system account that created this campaign record.' ;
    rdfs:domain ind:OfferCampaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryOfferApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Offer Approved By User Employee Id' ;
    rdfs:comment 'Reference to the internal user who approved this campaign for launch. Null if not yet approved.' ;
    rdfs:domain ind:OfferCampaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:campaignBudget rdf:type rdf:Property ;
    rdfs:label 'Campaign Budget' ;
    rdfs:comment 'Allocated budget for this campaign including discounts, bonuses, and promotional costs. Null if no budget cap.' ;
    rdfs:domain ind:OfferCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Campaign End Timestamp' ;
    rdfs:comment 'Date and time when the offer campaign expires and is no longer available to players.' ;
    rdfs:domain ind:OfferCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:campaignNotes rdf:type rdf:Property ;
    rdfs:label 'Campaign Notes' ;
    rdfs:comment 'Free-text notes or comments about the campaign for internal reference and collaboration.' ;
    rdfs:domain ind:OfferCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Campaign Start Timestamp' ;
    rdfs:comment 'Date and time when the offer campaign becomes active and visible to players.' ;
    rdfs:domain ind:OfferCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Status' ;
    rdfs:comment 'Status of regulatory and legal compliance review for this campaign (e.g., COPPA, gambling regulations, consumer protection).' ;
    rdfs:domain ind:OfferCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayImageUrl rdf:type rdf:Property ;
    rdfs:label 'Display Image Url' ;
    rdfs:comment 'URL to the promotional image or banner asset used to display this offer in-game.' ;
    rdfs:domain ind:OfferCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleSkuList rdf:type rdf:Property ;
    rdfs:label 'Eligible Sku List' ;
    rdfs:comment 'Comma-separated list of SKU identifiers eligible for this offer campaign. Empty if all SKUs are eligible.' ;
    rdfs:domain ind:Licensing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoRestrictionList rdf:type rdf:Property ;
    rdfs:label 'Geo Restriction List' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where this offer is available. Empty indicates global availability.' ;
    rdfs:domain ind:OfferCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impressionCap rdf:type rdf:Property ;
    rdfs:label 'Impression Cap' ;
    rdfs:comment 'Maximum number of times this offer can be displayed to eligible players. Null indicates no cap.' ;
    rdfs:domain ind:OfferCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offerType rdf:type rdf:Property ;
    rdfs:label 'Offer Type' ;
    rdfs:comment 'Classification of the offer campaign type based on its monetization strategy and target behavior.' ;
    rdfs:domain ind:OfferCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Priority ranking for display when multiple campaigns are eligible for the same player. Lower numbers indicate higher priority.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redemptionCap rdf:type rdf:Property ;
    rdfs:label 'Redemption Cap' ;
    rdfs:comment 'Maximum number of times this offer can be redeemed across all players. Null indicates no cap.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redemptionCapPerPlayer rdf:type rdf:Property ;
    rdfs:label 'Redemption Cap Per Player' ;
    rdfs:comment 'Maximum number of times a single player can redeem this offer. Null indicates no per-player limit.' ;
    rdfs:domain ind:OfferCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetDauMin rdf:type rdf:Property ;
    rdfs:label 'Target Dau Min' ;
    rdfs:comment 'Minimum DAU threshold for player eligibility. Players with DAU below this value are excluded. Null indicates no minimum.' ;
    rdfs:domain ind:OfferCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetDaysSinceLastPurchase rdf:type rdf:Property ;
    rdfs:label 'Target Days Since Last Purchase' ;
    rdfs:comment 'Number of days since player\'s last purchase to qualify for this offer (used for lapsed player targeting). Null indicates no recency requirement.' ;
    rdfs:domain ind:OfferCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetLtvMin rdf:type rdf:Property ;
    rdfs:label 'Target Ltv Min' ;
    rdfs:comment 'Minimum player lifetime value threshold for campaign eligibility. Null indicates no minimum LTV requirement.' ;
    rdfs:domain ind:OfferCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPlayerSegment rdf:type rdf:Property ;
    rdfs:label 'Target Player Segment' ;
    rdfs:comment 'Player spending tier or behavioral segment targeted by this campaign. F2P (Free-to-Play) = non-payers; Minnow = low spenders; Dolphin = moderate spenders; Whale = high spenders.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalImpressions rdf:type rdf:Property ;
    rdfs:label 'Total Impressions' ;
    rdfs:comment 'Cumulative count of how many times this offer has been displayed to players since campaign start.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalRedemptions rdf:type rdf:Property ;
    rdfs:label 'Total Redemptions' ;
    rdfs:comment 'Cumulative count of how many times this offer has been redeemed by players since campaign start.' ;
    rdfs:domain ind:Licensing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalRevenueGenerated rdf:type rdf:Property ;
    rdfs:label 'Total Revenue Generated' ;
    rdfs:comment 'Cumulative revenue generated from all redemptions of this offer campaign in the campaign\'s currency.' ;
    rdfs:domain ind:Licensing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageTransactionValue rdf:type rdf:Property ;
    rdfs:label 'Average Transaction Value' ;
    rdfs:comment 'Average value per IAP transaction in USD. Calculated as total_iap_spend divided by total_transaction_count. Used to identify whale spending patterns.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:combinedLtvScore rdf:type rdf:Property ;
    rdfs:label 'Combined Ltv Score' ;
    rdfs:comment 'Hybrid LTV score combining IAP spend and ad revenue to represent total player value in USD. Calculated as total_iap_spend + total_ad_revenue. Used for unified player value ranking.' ;
    rdfs:domain ind:PlayerLtvSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conversionProbabilityScore rdf:type rdf:Property ;
    rdfs:label 'Conversion Probability Score' ;
    rdfs:comment 'Machine learning predicted probability that a F2P player will make their first purchase in the next 30 days, ranging from 0.0000 (no chance) to 1.0000 (certain conversion). Null for players who have already made a purchase.' ;
    rdfs:domain ind:PlayerLtvSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysInCurrentSegment rdf:type rdf:Property ;
    rdfs:label 'Days In Current Segment' ;
    rdfs:comment 'Number of days the player has been in the current LTV segment. Calculated as current date minus segment_assignment_date. Used for segment stability analysis.' ;
    rdfs:domain ind:PlayerLtvSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysSinceLastPurchase rdf:type rdf:Property ;
    rdfs:label 'Days Since Last Purchase' ;
    rdfs:comment 'Number of days since the players last IAP transaction. Calculated as current date minus last_purchase_date. Null for F2P players. Used for churn prediction and reactivation campaigns.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firstPurchaseDate rdf:type rdf:Property ;
    rdfs:label 'First Purchase Date' ;
    rdfs:comment 'Date of the players first IAP transaction. Null for F2P players who have never made a purchase. Used to calculate payer tenure and conversion funnel metrics.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isDap rdf:type rdf:Property ;
    rdfs:label 'Is Dap' ;
    rdfs:comment 'Boolean flag indicating whether the player is a daily active payer (made at least one IAP transaction in the last 24 hours). True = DAP, False = not DAP.' ;
    rdfs:domain ind:PlayerLtvSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:largestSingleTransaction rdf:type rdf:Property ;
    rdfs:label 'Largest Single Transaction' ;
    rdfs:comment 'The highest single IAP transaction amount the player has ever made, in USD. Used to identify whale potential and spending ceiling.' ;
    rdfs:domain ind:PlayerLtvSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPurchaseDate rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Date' ;
    rdfs:comment 'Date of the players most recent IAP transaction. Null for F2P players. Used to identify lapsed payers and calculate recency metrics.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:predictedLtv30d rdf:type rdf:Property ;
    rdfs:label 'Predicted Ltv 30d' ;
    rdfs:comment 'Machine learning predicted LTV for the next 30 days, in USD. Used for player acquisition ROI optimization and marketing budget allocation.' ;
    rdfs:domain ind:PlayerLtvSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:predictedLtv90d rdf:type rdf:Property ;
    rdfs:label 'Predicted Ltv 90d' ;
    rdfs:comment 'Machine learning predicted LTV for the next 90 days, in USD. Used for cohort analysis and long-term player value forecasting.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredPaymentMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Payment Method' ;
    rdfs:comment 'The payment method the player uses most frequently for IAP transactions. Used for payment optimization and fraud detection. [ENUM-REF-CANDIDATE: credit_card|debit_card|paypal|apple_pay|google_pay|carrier_billing|gift_card|cryptocurrency — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousSegmentLabel rdf:type rdf:Property ;
    rdfs:label 'Previous Segment Label' ;
    rdfs:comment 'The LTV segment label the player held immediately before the current assignment. Used to track player progression and churn patterns. New Player indicates first-time segmentation. [ENUM-REF-CANDIDATE: whale|dolphin|minnow|f2p|at_risk_whale|lapsed_payer|new_player — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PlayerLtvSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentAssignmentDate rdf:type rdf:Property ;
    rdfs:label 'Segment Assignment Date' ;
    rdfs:comment 'Date when the player was assigned to the current LTV segment. Used to track segment tenure and transition history.' ;
    rdfs:domain ind:PlayerLtvSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:segmentChangeReason rdf:type rdf:Property ;
    rdfs:label 'Segment Change Reason' ;
    rdfs:comment 'Business reason for the most recent segment transition. Spend Increase = player moved up tier, Spend Decrease = player moved down tier, Inactivity = player became inactive, Reactivation = lapsed player returned, First Purchase = F2P converted to payer, Churn = player stopped spending, Periodic Refresh = scheduled recalculation. [ENUM-REF-CANDIDATE: spend_increase|spend_decrease|inactivity|reactivation|first_purchase|churn|periodic_refresh — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PlayerLtvSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAdImpressions rdf:type rdf:Property ;
    rdfs:label 'Total Ad Impressions' ;
    rdfs:comment 'Cumulative number of ad impressions served to the player across all games. Used to calculate ad engagement and eCPM metrics.' ;
    rdfs:domain ind:PlayerLtvSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalAdRevenue rdf:type rdf:Property ;
    rdfs:label 'Total Ad Revenue' ;
    rdfs:comment 'Cumulative lifetime ad revenue generated by the player through ad impressions, rewarded video views, and interstitial ads, in USD. Critical for F2P monetization models.' ;
    rdfs:domain ind:PlayerLtvSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalIapSpend rdf:type rdf:Property ;
    rdfs:label 'Total Iap Spend' ;
    rdfs:comment 'Cumulative lifetime spend on in-app purchases (IAP) by the player across all games and platforms, in USD. Includes microtransactions, DLC, battle passes, and subscription fees.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRewardedAdViews rdf:type rdf:Property ;
    rdfs:label 'Total Rewarded Ad Views' ;
    rdfs:comment 'Cumulative number of rewarded video ads the player has watched to completion. Indicates player willingness to engage with ads for in-game rewards.' ;
    rdfs:domain ind:PlayerLtvSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoRenewalEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Enabled' ;
    rdfs:comment 'Indicates whether the subscription will automatically renew at the end of the current billing period. True means the subscription will renew unless cancelled. False means the subscription will expire at period end.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingCycleCount rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle Count' ;
    rdfs:comment 'The number of billing cycles that have been completed for this subscription. Used for retention cohort analysis and subscription age segmentation.' ;
    rdfs:domain ind:PlayerSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentBillingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Current Billing Period End' ;
    rdfs:comment 'The end date of the current billing cycle. The next renewal or cancellation will occur on or before this date.' ;
    rdfs:domain ind:PlayerSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentBillingPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Current Billing Period Start' ;
    rdfs:comment 'The start date of the current billing cycle. Used to calculate prorated charges, usage windows, and renewal timing.' ;
    rdfs:domain ind:PlayerSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discountApplied rdf:type rdf:Property ;
    rdfs:label 'Discount Applied' ;
    rdfs:comment 'Indicates whether a promotional discount or coupon was applied to this subscription. Used for promotion effectiveness analysis and revenue attribution.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementActive rdf:type rdf:Property ;
    rdfs:label 'Entitlement Active' ;
    rdfs:comment 'Indicates whether the player currently has access to the subscription entitlements. May be false even if subscription status is active, due to payment failures or grace period expiration.' ;
    rdfs:domain ind:PlayerSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprConsentGiven rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Given' ;
    rdfs:comment 'Indicates whether the player has provided explicit consent for data processing under GDPR requirements. Required for players in EU jurisdictions.' ;
    rdfs:domain ind:PlayerSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPaymentFailureDate rdf:type rdf:Property ;
    rdfs:label 'Last Payment Failure Date' ;
    rdfs:comment 'The date of the most recent payment failure. Null if no payment failures have occurred. Used for dunning workflow triggers and grace period calculation.' ;
    rdfs:domain ind:PlayerSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifetimeRevenue rdf:type rdf:Property ;
    rdfs:label 'Lifetime Revenue' ;
    rdfs:comment 'The total revenue generated from this subscription since inception, including all billing cycles. Used for LTV (Lifetime Value) calculation and whale segmentation.' ;
    rdfs:domain ind:PlayerSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentFailureCount rdf:type rdf:Property ;
    rdfs:label 'Payment Failure Count' ;
    rdfs:comment 'The number of times payment processing has failed for this subscription. Used for involuntary churn risk scoring and dunning campaign targeting.' ;
    rdfs:domain ind:PlayerSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentMethodToken rdf:type rdf:Property ;
    rdfs:label 'Payment Method Token' ;
    rdfs:comment 'Tokenized reference to the payment method used for recurring billing. The token is provided by the payment processor and does not contain actual card numbers, ensuring PCI DSS (Payment Card Industry Data Security Standard) compliance.' ;
    rdfs:domain ind:PlayerSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionEndDate rdf:type rdf:Property ;
    rdfs:label 'Subscription End Date' ;
    rdfs:comment 'The date when the subscription is scheduled to end or did end. Null for active subscriptions with auto-renewal enabled. Populated for cancelled or expired subscriptions.' ;
    rdfs:domain ind:PlayerSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subscriptionPrice rdf:type rdf:Property ;
    rdfs:label 'Subscription Price' ;
    rdfs:comment 'The recurring price charged for the subscription per billing cycle. Stored in the currency specified in the currency_code field. Used for ARPU (Average Revenue Per User) and ARPPU (Average Revenue Per Paying User) calculations.' ;
    rdfs:domain ind:PlayerSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subscriptionSource rdf:type rdf:Property ;
    rdfs:label 'Subscription Source' ;
    rdfs:comment 'Indicates how this subscription originated. New player indicates first subscription at account creation. Existing player upgrade indicates conversion from free-to-play. Reactivation indicates return of a previously churned subscriber. Cross-sell indicates purchase of an additional subscription product.' ;
    rdfs:domain ind:PlayerSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionStartDate rdf:type rdf:Property ;
    rdfs:label 'Subscription Start Date' ;
    rdfs:comment 'The date when the subscription became active and entitlements were first granted to the player. Used to calculate subscription age and LTV (Lifetime Value).' ;
    rdfs:domain ind:PlayerSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trialStartDate rdf:type rdf:Property ;
    rdfs:label 'Trial Start Date' ;
    rdfs:comment 'The date when the trial period began. Null if no trial was used for this subscription.' ;
    rdfs:domain ind:PlayerSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trialUsed rdf:type rdf:Property ;
    rdfs:label 'Trial Used' ;
    rdfs:comment 'Indicates whether the player has used a trial period for this subscription plan. Used to enforce one-trial-per-player business rules and prevent trial abuse.' ;
    rdfs:domain ind:PlayerSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pricePointId rdf:type rdf:Property ;
    rdfs:label 'Price Point Id' ;
    rdfs:comment 'Unique identifier for the price point record. Primary key.' ;
    rdfs:domain ind:PricePoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPriceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Price Employee Id' ;
    rdfs:comment 'Reference to the internal user or role who approved this price point for publication.' ;
    rdfs:domain ind:PricePoint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryPriceUpdatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Price Updated By User Employee Id' ;
    rdfs:comment 'Reference to the internal user who last updated this price point record.' ;
    rdfs:domain ind:PricePoint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bonusCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Currency Amount' ;
    rdfs:comment 'Additional bonus virtual currency awarded on top of the base amount (used for promotional bundles or first-time purchase incentives).' ;
    rdfs:domain ind:PricePoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conversionOptimizationVariant rdf:type rdf:Property ;
    rdfs:label 'Conversion Optimization Variant' ;
    rdfs:comment 'A/B test or conversion optimization variant identifier for this price point, used to track performance of different pricing strategies.' ;
    rdfs:domain ind:PricePoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultForTier rdf:type rdf:Property ;
    rdfs:label 'Is Default For Tier' ;
    rdfs:comment 'Indicates whether this price point is the default or recommended option for its tier level across regions (True) or a regional variant (False).' ;
    rdfs:domain ind:PricePoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPromotional rdf:type rdf:Property ;
    rdfs:label 'Is Promotional' ;
    rdfs:comment 'Indicates whether this price point is part of a limited-time promotional campaign (True) or a standard catalog price (False).' ;
    rdfs:domain ind:PricePoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localPriceAmount rdf:type rdf:Property ;
    rdfs:label 'Local Price Amount' ;
    rdfs:comment 'Price amount in the local currency for the target market or region.' ;
    rdfs:domain ind:PricePoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumPlayerAge rdf:type rdf:Property ;
    rdfs:label 'Minimum Player Age' ;
    rdfs:comment 'Minimum age required to purchase this price point, enforced for regulatory compliance (e.g., 13, 16, 18).' ;
    rdfs:domain ind:PricePoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netProceedsPercentage rdf:type rdf:Property ;
    rdfs:label 'Net Proceeds Percentage' ;
    rdfs:comment 'Percentage of the transaction that the publisher receives after platform fees (e.g., 70.00 for 70%).' ;
    rdfs:domain ind:PricePoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalPriceUsd rdf:type rdf:Property ;
    rdfs:label 'Original Price Usd' ;
    rdfs:comment 'Original non-discounted price in USD, used for displaying savings to players during promotions.' ;
    rdfs:domain ind:PricePoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformSku rdf:type rdf:Property ;
    rdfs:label 'Platform Sku' ;
    rdfs:comment 'Platform-specific SKU or product identifier used by the storefront API for transaction processing.' ;
    rdfs:domain ind:PricePoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceDisplayFormat rdf:type rdf:Property ;
    rdfs:label 'Price Display Format' ;
    rdfs:comment 'Localized format string for displaying the price to players (e.g., $0.99, €0,99, ¥120), respecting regional conventions.' ;
    rdfs:domain ind:PricePoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricePointCode rdf:type rdf:Property ;
    rdfs:label 'Price Point Code' ;
    rdfs:comment 'Business identifier code for the price point, used for external reference and integration with platform storefronts.' ;
    rdfs:domain ind:PricePoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricePointDescription rdf:type rdf:Property ;
    rdfs:label 'Price Point Description' ;
    rdfs:comment 'Internal notes or description of the price point, including business rationale, target segment, or special conditions.' ;
    rdfs:domain ind:PricePoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricePointName rdf:type rdf:Property ;
    rdfs:label 'Price Point Name' ;
    rdfs:comment 'Human-readable display name for the price point shown to players in storefronts.' ;
    rdfs:domain ind:PricePoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricePointStatus rdf:type rdf:Property ;
    rdfs:label 'Price Point Status' ;
    rdfs:comment 'Current lifecycle status of the price point: active (live and available), inactive (not currently offered), pending (awaiting platform approval), deprecated (phased out), suspended (temporarily disabled).' ;
    rdfs:domain ind:PricePoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricePointType rdf:type rdf:Property ;
    rdfs:label 'Price Point Type' ;
    rdfs:comment 'Classification of the price point: standard (regular catalog price), promotional (temporary discount), dynamic (algorithmically adjusted), regional (geo-specific), premium (high-value tier), introductory (first-time buyer).' ;
    rdfs:domain ind:PricePoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceRoundingRule rdf:type rdf:Property ;
    rdfs:label 'Price Rounding Rule' ;
    rdfs:comment 'Rounding convention applied to the local price (e.g., nearest_99 for psychological pricing ending in .99, platform_standard for platform-mandated rounding).' ;
    rdfs:domain ind:PricePoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxInclusiveFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Inclusive Flag' ;
    rdfs:comment 'Indicates whether the price includes applicable taxes (True) or taxes are added at checkout (False).' ;
    rdfs:domain ind:PricePoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tierLabel rdf:type rdf:Property ;
    rdfs:label 'Tier Label' ;
    rdfs:comment 'Platform-specific tier label or identifier (e.g., Apple Tier 1, Google Play Tier A).' ;
    rdfs:domain ind:PricePoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Vat Rate Percentage' ;
    rdfs:comment 'Applicable VAT or sales tax rate percentage for this price point in the target region (e.g., 20.00 for 20% VAT in UK).' ;
    rdfs:domain ind:PricePoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:virtualCurrencyEquivalent rdf:type rdf:Property ;
    rdfs:label 'Virtual Currency Equivalent' ;
    rdfs:comment 'Amount of virtual currency (e.g., coins, gems, credits) that this price point grants to the player upon purchase.' ;
    rdfs:domain ind:PricePoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Promotion Approved By User Employee Id' ;
    rdfs:comment 'Identifier of the business user who approved this promotion for activation. Required for governance and compliance with promotional pricing policies.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:promotionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Promotion Employee Id' ;
    rdfs:comment 'Identifier of the business user or system account that created this promotion record. Used for audit and accountability.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:promotionModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Promotion Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the business user or system account that last modified this promotion record. Used for audit and accountability.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:maxDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Max Discount Amount' ;
    rdfs:comment 'Cap on the total discount value that can be applied to a single transaction. Prevents excessive discounts on high-value purchases.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minPurchaseAmount rdf:type rdf:Property ;
    rdfs:label 'Min Purchase Amount' ;
    rdfs:comment 'Minimum transaction value required to qualify for the promotion. Nullable if no minimum threshold applies.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionCode rdf:type rdf:Property ;
    rdfs:label 'Promotion Code' ;
    rdfs:comment 'Unique business identifier code for the promotion used in marketing materials and player-facing interfaces. Externally visible promotion reference.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionName rdf:type rdf:Property ;
    rdfs:label 'Promotion Name' ;
    rdfs:comment 'Human-readable display name of the promotional event shown to players in storefront and marketing channels.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionStatus rdf:type rdf:Property ;
    rdfs:label 'Promotion Status' ;
    rdfs:comment 'Current lifecycle state of the promotion indicating whether it is in planning, running, or concluded.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionType rdf:type rdf:Property ;
    rdfs:label 'Promotion Type' ;
    rdfs:comment 'Classification of the promotional event type indicating the nature and structure of the offer.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionLimitPerPlayer rdf:type rdf:Property ;
    rdfs:label 'Redemption Limit Per Player' ;
    rdfs:comment 'Maximum number of times a single player can use this promotion. Nullable for unlimited redemptions.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiresFirstPurchase rdf:type rdf:Property ;
    rdfs:label 'Requires First Purchase' ;
    rdfs:comment 'Indicates whether this promotion is exclusively available to players making their first in-app purchase (F2P conversion incentive).' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stackableWithOtherPromos rdf:type rdf:Property ;
    rdfs:label 'Stackable With Other Promos' ;
    rdfs:comment 'Indicates whether this promotion can be combined with other active promotions in a single transaction.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalDiscountGiven rdf:type rdf:Property ;
    rdfs:label 'Total Discount Given' ;
    rdfs:comment 'Cumulative monetary value of all discounts applied through this promotion. Represents the revenue foregone to drive conversion.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRedemptionCap rdf:type rdf:Property ;
    rdfs:label 'Total Redemption Cap' ;
    rdfs:comment 'Maximum number of total redemptions allowed across all players before the promotion automatically ends. Nullable for uncapped promotions.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingCycle rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle' ;
    rdfs:comment 'Recurring billing frequency for the subscription plan. Defines how often the player is charged.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCycleLength rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle Length' ;
    rdfs:comment 'Number of billing periods in the subscription cycle (e.g., 1 for monthly, 12 for annual). Used for prorated calculations and renewal scheduling.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancellationPolicy rdf:type rdf:Property ;
    rdfs:label 'Cancellation Policy' ;
    rdfs:comment 'Policy governing when subscription benefits terminate after cancellation and whether refunds are issued. Critical for churn rate analysis and player retention.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cloudGamingEnabled rdf:type rdf:Property ;
    rdfs:label 'Cloud Gaming Enabled' ;
    rdfs:comment 'Indicates whether subscription includes cloud gaming streaming capability, allowing gameplay without local hardware requirements.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusiveContentAccess rdf:type rdf:Property ;
    rdfs:label 'Exclusive Content Access' ;
    rdfs:comment 'Indicates whether subscribers receive access to exclusive game content, DLC, or early releases not available to non-subscribers.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gameLibraryAccess rdf:type rdf:Property ;
    rdfs:label 'Game Library Access' ;
    rdfs:comment 'Level of access to game catalog or library granted by subscription. Defines which game titles subscribers can play without additional purchase.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxConcurrentDevices rdf:type rdf:Property ;
    rdfs:label 'Max Concurrent Devices' ;
    rdfs:comment 'Maximum number of devices that can simultaneously use the subscription. Used for family plans and multi-device access control.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:multiplayerAccess rdf:type rdf:Property ;
    rdfs:label 'Multiplayer Access' ;
    rdfs:comment 'Indicates whether subscription is required for online multiplayer gameplay (PvP, MMO, co-op). Common requirement for console platform subscriptions.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Externally-known unique business identifier for the subscription plan (e.g., PREMIUM_MONTHLY, GAMEPASS_ANNUAL). Used in platform APIs, billing systems, and player-facing interfaces.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceAmount rdf:type rdf:Property ;
    rdfs:label 'Price Amount' ;
    rdfs:comment 'Base recurring price charged per billing cycle before taxes, discounts, or promotional adjustments. Used for ARPU and ARPPU calculations.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productFamily rdf:type rdf:Property ;
    rdfs:label 'Product Family' ;
    rdfs:comment 'Grouping of related subscription plans for reporting and analytics (e.g., Premium Tier, Game Pass Family, VIP Club). Used for portfolio analysis and cross-sell strategies.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundEligible rdf:type rdf:Property ;
    rdfs:label 'Refund Eligible' ;
    rdfs:comment 'Indicates whether subscription purchases are eligible for refund per platform policies and consumer protection regulations.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subscriptionPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Subscription Plan Status' ;
    rdfs:comment 'Current lifecycle status of the subscription plan. Active plans are available for new subscriptions; deprecated plans are closed to new subscribers but honor existing subscriptions.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialPriceAmount rdf:type rdf:Property ;
    rdfs:label 'Trial Price Amount' ;
    rdfs:comment 'Discounted price charged during trial period. Typically zero for free trials or reduced for promotional trials.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:virtualCurrencyGrant rdf:type rdf:Property ;
    rdfs:label 'Virtual Currency Grant' ;
    rdfs:comment 'Amount of in-game virtual currency (coins, gems, credits) granted to subscribers each billing cycle. Zero indicates no currency stipend. Key component of subscription LTV calculation.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountCloseDate rdf:type rdf:Property ;
    rdfs:label 'Account Close Date' ;
    rdfs:comment 'Calendar date on which this virtual currency account was permanently closed or deactivated. Null for active accounts. Populated upon player account deletion, GDPR erasure request, or game title sunset.' ;
    rdfs:domain ind:VirtualCurrencyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountCode rdf:type rdf:Property ;
    rdfs:label 'Account Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the virtual currency account, used in player-facing support, reconciliation, and audit workflows. Distinct from the surrogate primary key.' ;
    rdfs:domain ind:VirtualCurrencyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountOpenDate rdf:type rdf:Property ;
    rdfs:label 'Account Open Date' ;
    rdfs:comment 'Calendar date on which this virtual currency account was first created, typically coinciding with the player\'s first login or registration for the associated game title. Used as the effective start date for the account lifecycle.' ;
    rdfs:domain ind:VirtualCurrencyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:balanceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Balance Expiry Date' ;
    rdfs:comment 'Date on which the current virtual currency balance (or a portion thereof) expires if unused. Applicable for event coins, promotional currencies, and time-limited battle pass tokens. Null for non-expiring currencies.' ;
    rdfs:domain ind:VirtualCurrencyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conversionStatus rdf:type rdf:Property ;
    rdfs:label 'Conversion Status' ;
    rdfs:comment 'Tracks whether the player has ever converted from Free-to-Play (F2P) to a paying user via IAP on this account. Supports F2P conversion funnel analytics and re-engagement campaign targeting.' ;
    rdfs:domain ind:VirtualCurrencyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyName rdf:type rdf:Property ;
    rdfs:label 'Currency Name' ;
    rdfs:comment 'Human-readable display name of the virtual currency as shown to players in-game (e.g., \'Gems\', \'Gold Coins\', \'Battle Tokens\'). Used for player-facing UI and reporting.' ;
    rdfs:domain ind:Licensing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentBalance rdf:type rdf:Property ;
    rdfs:label 'Current Balance' ;
    rdfs:comment 'The real-time current balance of virtual currency units held in this account. This is the authoritative SSOT for the player\'s wallet state and must be reconcilable against the virtual_currency_ledger. Stored with 4 decimal places to support fractional currency economies.' ;
    rdfs:domain ind:VirtualCurrencyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataResidencyRegion rdf:type rdf:Property ;
    rdfs:label 'Data Residency Region' ;
    rdfs:comment 'Geographic region where this account\'s data must be stored and processed to comply with data sovereignty and residency regulations (e.g., GDPR requires EU data to remain in EU). Drives lakehouse partition and storage routing decisions.' ;
    rdfs:domain ind:VirtualCurrencyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earnCapDaily rdf:type rdf:Property ;
    rdfs:label 'Earn Cap Daily' ;
    rdfs:comment 'Maximum virtual currency units that can be credited to this account within a single calendar day from gameplay rewards. Prevents exploit-based economy inflation and bot farming abuse.' ;
    rdfs:domain ind:VirtualCurrencyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gdprErasureRequested rdf:type rdf:Property ;
    rdfs:label 'Gdpr Erasure Requested' ;
    rdfs:comment 'Indicates whether a GDPR Right to Erasure (Right to be Forgotten) request has been submitted for the player associated with this account. When True, the account must be scheduled for anonymization or deletion per GDPR Article 17 timelines.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPurchasable rdf:type rdf:Property ;
    rdfs:label 'Is Purchasable' ;
    rdfs:comment 'Indicates whether this currency type can be acquired via real-money IAP. True for hard currencies; typically false for soft currencies earned through gameplay.' ;
    rdfs:domain ind:VirtualCurrencyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRefundable rdf:type rdf:Property ;
    rdfs:label 'Is Refundable' ;
    rdfs:comment 'Indicates whether the virtual currency in this account is eligible for real-money refund upon player request or chargeback. Governs refund policy enforcement and PCI DSS chargeback handling.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastEarnTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Earn Timestamp' ;
    rdfs:comment 'Timestamp of the most recent credit (earn) event on this account, whether from IAP, gameplay reward, or promotion. Supports earn-vs-spend behavioral segmentation.' ;
    rdfs:domain ind:VirtualCurrencyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastSpendTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Spend Timestamp' ;
    rdfs:comment 'Timestamp of the most recent debit (spend) event on this account. Used to identify high-frequency spenders (whales), compute time-to-first-purchase, and support MTX funnel analytics.' ;
    rdfs:domain ind:VirtualCurrencyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastTransactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Timestamp' ;
    rdfs:comment 'Timestamp of the most recent credit or debit transaction applied to this virtual currency account. Used for dormancy detection, churn analysis, and D1/D7/D30 retention reporting.' ;
    rdfs:domain ind:VirtualCurrencyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lifetimeEarned rdf:type rdf:Property ;
    rdfs:label 'Lifetime Earned' ;
    rdfs:comment 'Cumulative total of all virtual currency units ever credited to this account since inception, including IAP purchases, gameplay rewards, promotions, and refunds. Used for LTV analysis and whale segmentation.' ;
    rdfs:domain ind:VirtualCurrencyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifetimeSpent rdf:type rdf:Property ;
    rdfs:label 'Lifetime Spent' ;
    rdfs:comment 'Cumulative total of all virtual currency units ever debited from this account since inception, including MTX purchases, gacha pulls, DLC unlocks, and cosmetic purchases. Used for ARPPU and conversion rate analytics.' ;
    rdfs:domain ind:VirtualCurrencyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxBalanceCap rdf:type rdf:Property ;
    rdfs:label 'Max Balance Cap' ;
    rdfs:comment 'Maximum virtual currency units allowed to be held in this account at any point in time. Enforces economy balance controls and prevents hoarding that could destabilize the virtual economy.' ;
    rdfs:domain ind:VirtualCurrencyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minorAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Minor Account Flag' ;
    rdfs:comment 'Indicates whether the account holder is classified as a minor (under 18, or under 13 for COPPA jurisdictions). Drives spend cap enforcement, parental consent requirements, and loot box/gacha access restrictions.' ;
    rdfs:domain ind:VirtualCurrencyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentalControlFlag rdf:type rdf:Property ;
    rdfs:label 'Parental Control Flag' ;
    rdfs:comment 'Indicates whether parental controls are active on this account, restricting IAP and spend capabilities. Required for COPPA compliance for accounts associated with minor players.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pendingBalance rdf:type rdf:Property ;
    rdfs:label 'Pending Balance' ;
    rdfs:comment 'Virtual currency units that have been credited but are not yet available for spending, typically due to IAP payment processing delays, chargeback hold periods, or promotional vesting schedules.' ;
    rdfs:domain ind:VirtualCurrencyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordVersion rdf:type rdf:Property ;
    rdfs:label 'Record Version' ;
    rdfs:comment 'Monotonically incrementing version counter for this virtual currency account record, incremented on each update. Supports optimistic concurrency control and Silver Layer SCD (Slowly Changing Dimension) tracking.' ;
    rdfs:domain ind:VirtualCurrencyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reservedBalance rdf:type rdf:Property ;
    rdfs:label 'Reserved Balance' ;
    rdfs:comment 'Virtual currency units currently locked/reserved for in-progress transactions (e.g., a gacha pull in flight, a marketplace listing, or an auction bid). Prevents double-spend scenarios in concurrent transaction environments.' ;
    rdfs:domain ind:VirtualCurrencyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spendCapDaily rdf:type rdf:Property ;
    rdfs:label 'Spend Cap Daily' ;
    rdfs:comment 'Maximum virtual currency units that can be spent from this account within a single calendar day. Used for responsible gaming controls, fraud prevention, and COPPA-compliant spending limits for minor accounts.' ;
    rdfs:domain ind:VirtualCurrencyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalIapPurchaseCount rdf:type rdf:Property ;
    rdfs:label 'Total Iap Purchase Count' ;
    rdfs:comment 'Cumulative count of real-money In-App Purchase (IAP) transactions that have credited this virtual currency account since inception. Used for purchase frequency analysis and whale identification.' ;
    rdfs:domain ind:VirtualCurrencyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:virtualCurrencyLedgerId rdf:type rdf:Property ;
    rdfs:label 'Virtual Currency Ledger Id' ;
    rdfs:comment 'Unique surrogate primary key for each immutable ledger entry recording a virtual currency credit or debit event for a player account.' ;
    rdfs:domain ind:VirtualCurrencyLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reversalReferenceVirtualCurrencyLedgerId rdf:type rdf:Property ;
    rdfs:label 'Reversal Reference Virtual Currency Ledger Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the original ledger entry that this entry reverses, or to the reversal entry that corrects this entry. Null for non-reversal entries. Enables full audit chain reconstruction for refunds and administrative corrections.' ;
    rdfs:domain ind:VirtualCurrencyLedger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VirtualCurrencyLedger .

ind:balanceAfter rdf:type rdf:Property ;
    rdfs:label 'Balance After' ;
    rdfs:comment 'The player\'s running virtual currency balance for this currency code immediately after this ledger entry was applied. The authoritative post-transaction balance used for reconciliation and fraud detection.' ;
    rdfs:domain ind:VirtualCurrencyLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balanceBefore rdf:type rdf:Property ;
    rdfs:label 'Balance Before' ;
    rdfs:comment 'The player\'s virtual currency balance for this currency code immediately before this ledger entry was applied. Enables full audit trail reconstruction and balance reconciliation.' ;
    rdfs:domain ind:VirtualCurrencyLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Amount' ;
    rdfs:comment 'The additional virtual currency units granted as a promotional bonus on top of the base delta_amount for this credit entry (e.g., \'Buy 1000 gems, get 200 free\'). Null or zero for non-promotional entries. Enables bonus economy impact analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deltaAmount rdf:type rdf:Property ;
    rdfs:label 'Delta Amount' ;
    rdfs:comment 'The absolute change in virtual currency units for this ledger entry. Always a positive value; the entry_type field determines whether this is an addition or subtraction. Enables precise virtual economy flow analysis.' ;
    rdfs:domain ind:VirtualCurrencyLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entryReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Entry Reference Code' ;
    rdfs:comment 'Externally-known unique business identifier for this ledger entry, used for audit trail reconciliation, player support lookups, and cross-system tracing. Sourced from the originating transaction system.' ;
    rdfs:domain ind:VirtualCurrencyLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryType rdf:type rdf:Property ;
    rdfs:label 'Entry Type' ;
    rdfs:comment 'Indicates whether this ledger entry is a credit (addition of virtual currency to the player account) or a debit (deduction of virtual currency from the player account). Fundamental to double-entry virtual economy accounting.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isReversal rdf:type rdf:Property ;
    rdfs:label 'Is Reversal' ;
    rdfs:comment 'Indicates whether this ledger entry is a reversal of a previously posted entry (True) or an original transaction (False). Used to filter reversals from net economy flow calculations and to identify correction patterns.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ledgerEntryStatus rdf:type rdf:Property ;
    rdfs:label 'Ledger Entry Status' ;
    rdfs:comment 'Current lifecycle state of this ledger entry. Posted entries are confirmed and applied to the player balance. Reversed entries have been corrected by a corresponding offsetting entry. Pending entries are awaiting confirmation. Failed entries did not complete. Voided entries were cancelled before posting.' ;
    rdfs:domain ind:VirtualCurrencyLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerLevelAtTransaction rdf:type rdf:Property ;
    rdfs:label 'Player Level At Transaction' ;
    rdfs:comment 'The player\'s in-game progression level at the time this virtual currency transaction occurred. Enables economy analysis segmented by player progression stage, supporting game balance tuning and monetization funnel optimization.' ;
    rdfs:domain ind:VirtualCurrencyLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:realMoneyAmount rdf:type rdf:Property ;
    rdfs:label 'Real Money Amount' ;
    rdfs:comment 'The real-world fiat currency amount paid by the player to fund this virtual currency credit, applicable only for IAP-sourced entries. Used for ARPU, ARPPU, and LTV calculations and for revenue reconciliation against payment processor records.' ;
    rdfs:domain ind:VirtualCurrencyLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:realMoneyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Real Money Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter fiat currency code of the real-money amount paid for this IAP-funded virtual currency credit (e.g., USD, EUR, GBP). Null for non-IAP entries. Required for multi-currency revenue reporting and FX reconciliation.' ;
    rdfs:domain ind:VirtualCurrencyLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionSource rdf:type rdf:Property ;
    rdfs:label 'Transaction Source' ;
    rdfs:comment 'The originating business event or mechanism that triggered this ledger entry. Classifies the economic source of every credit or debit for virtual economy analytics, monetization reporting, and fraud detection. [ENUM-REF-CANDIDATE: iap|reward|quest_completion|gacha_spend|battle_pass_grant|daily_login|achievement|refund|admin_adjustment|season_pass|dlc_grant — promote to reference product]' ;
    rdfs:domain ind:VirtualCurrencyLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionSourceCategory rdf:type rdf:Property ;
    rdfs:label 'Transaction Source Category' ;
    rdfs:comment 'High-level grouping of the transaction source for roll-up analytics and reporting. Monetization covers IAP and real-money-funded events; gameplay_reward covers quest, achievement, and daily login grants; promotional covers battle pass and season pass grants; administrative covers manual adjustments; refund covers reversals.' ;
    rdfs:domain ind:VirtualCurrencyLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'The precise real-world date and time (UTC) at which the virtual currency credit or debit event occurred in the game system. This is the principal business event time, distinct from the record ingestion timestamp. Conforms to yyyy-MM-ddTHH:mm:ss.SSSXXX format.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:virtualToRealRatio rdf:type rdf:Property ;
    rdfs:label 'Virtual To Real Ratio' ;
    rdfs:comment 'The conversion ratio between virtual currency units and real-world fiat currency at the time of this transaction (e.g., 100 gems = $0.99 USD). Captures the effective price per virtual currency unit for economy valuation and regulatory disclosure.' ;
    rdfs:domain ind:VirtualCurrencyLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetServerFleetId rdf:type rdf:Property ;
    rdfs:label 'Target Server Fleet Id' ;
    rdfs:comment 'Foreign key linking to infrastructure.server_fleet. Business justification: Build submissions target specific server fleets for deployment. Essential for build deployment pipeline, tracking which fleet version a build is deployed to, and coordinating build releases with infra' ;
    rdfs:domain ind:BuildSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServerFleet .

ind:buildHash rdf:type rdf:Property ;
    rdfs:label 'Build Hash' ;
    rdfs:comment 'Cryptographic hash (SHA-256 or MD5) of the build package for integrity verification and tamper detection.' ;
    rdfs:domain ind:BuildSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildPipelineCode rdf:type rdf:Property ;
    rdfs:label 'Build Pipeline Code' ;
    rdfs:comment 'Identifier of the CI/CD (Continuous Integration/Continuous Deployment) pipeline job or workflow that generated this build. Used for traceability to source control and build automation.' ;
    rdfs:domain ind:BuildSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Build Size Bytes' ;
    rdfs:comment 'Total size of the build package in bytes. Used for storage planning, bandwidth estimation, and platform size limit compliance.' ;
    rdfs:domain ind:BuildSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:buildType rdf:type rdf:Property ;
    rdfs:label 'Build Type' ;
    rdfs:comment 'Classification of the build based on its stage in the development and release lifecycle. [ENUM-REF-CANDIDATE: debug|alpha|beta|release_candidate|gold_master|patch|hotfix — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmType rdf:type rdf:Property ;
    rdfs:label 'Drm Type' ;
    rdfs:comment 'Type of Digital Rights Management (DRM) protection applied to the build to prevent piracy and unauthorized distribution.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGoldMaster rdf:type rdf:Property ;
    rdfs:label 'Is Gold Master' ;
    rdfs:comment 'Indicates whether this build is the final gold master version approved for commercial release. True if this is the gold master build.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumOsVersion rdf:type rdf:Property ;
    rdfs:label 'Minimum Os Version' ;
    rdfs:comment 'Minimum operating system version required to run this build. Used for platform compatibility checks and player device targeting.' ;
    rdfs:domain ind:Platform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Packaging Completed Timestamp' ;
    rdfs:comment 'Date and time when the build packaging process completed successfully. Null if packaging failed or is still in progress.' ;
    rdfs:domain ind:BuildSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packagingStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Packaging Started Timestamp' ;
    rdfs:comment 'Date and time when the build packaging process began. Used for pipeline performance tracking.' ;
    rdfs:domain ind:BuildSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:releaseNotes rdf:type rdf:Property ;
    rdfs:label 'Release Notes' ;
    rdfs:comment 'Detailed description of changes, new features, bug fixes, and known issues included in this build. Submitted to platform holders and used for player communication.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresDayOnePatch rdf:type rdf:Property ;
    rdfs:label 'Requires Day One Patch' ;
    rdfs:comment 'Indicates whether this gold master build requires a mandatory day-one patch to be playable. True if a day-one patch is planned.' ;
    rdfs:domain ind:BuildSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceCommitHash rdf:type rdf:Property ;
    rdfs:label 'Source Commit Hash' ;
    rdfs:comment 'Git or Perforce commit hash/changelist number from which this build was compiled. Enables traceability to exact source code version.' ;
    rdfs:domain ind:BuildSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionNotes rdf:type rdf:Property ;
    rdfs:label 'Submission Notes' ;
    rdfs:comment 'Internal notes and instructions for the platform certification team. May include testing instructions, known edge cases, or special configuration requirements.' ;
    rdfs:domain ind:Platform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uploadCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Upload Completed Timestamp' ;
    rdfs:comment 'Date and time when the build upload to the platform partner portal completed successfully. Null if upload failed or is still in progress.' ;
    rdfs:domain ind:BuildSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:uploadStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Upload Started Timestamp' ;
    rdfs:comment 'Date and time when the build upload to the platform partner portal began.' ;
    rdfs:domain ind:BuildSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:validationCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validation Completed Timestamp' ;
    rdfs:comment 'Date and time when automated platform validation checks completed. Null if validation failed or is still in progress.' ;
    rdfs:domain ind:BuildSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:validationStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validation Started Timestamp' ;
    rdfs:comment 'Date and time when automated platform validation checks began (file integrity, metadata compliance, technical requirements).' ;
    rdfs:domain ind:BuildSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:certificationCertificateId rdf:type rdf:Property ;
    rdfs:label 'Certification Certificate Id' ;
    rdfs:comment 'Unique identifier of the official certification certificate issued by the platform holder upon successful certification approval. This certificate ID is required for commercial distribution and may be referenced in platform storefronts and distribution systems. Null if certification has not been granted.' ;
    rdfs:domain ind:Platform ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CertificationCertificate .

ind:testGameServerId rdf:type rdf:Property ;
    rdfs:label 'Test Game Server Id' ;
    rdfs:comment 'Foreign key linking to infrastructure.game_server. Business justification: Certification testing for multiplayer/online features requires specific test game servers. Critical for tracking which server environment was used for cert validation, reproducing cert failures, and e' ;
    rdfs:domain ind:PlatformCertSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GameServer .

ind:accessibilityFeaturesIncluded rdf:type rdf:Property ;
    rdfs:label 'Accessibility Features Included' ;
    rdfs:comment 'Boolean flag indicating whether this build includes accessibility features such as colorblind modes, subtitle options, controller remapping, or assistive technology support. Platform holders increasingly require or incentivize accessibility compliance.' ;
    rdfs:domain ind:PlatformCertSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationOutcome rdf:type rdf:Property ;
    rdfs:label 'Certification Outcome' ;
    rdfs:comment 'Final outcome of the platform holder certification review for the current review cycle. Pass indicates full certification approval, fail indicates rejection requiring resubmission, conditional pass indicates approval with minor required fixes, pending indicates review in progress, and not reviewed indicates submission not yet evaluated.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossPlatformCompatible rdf:type rdf:Property ;
    rdfs:label 'Cross Platform Compatible' ;
    rdfs:comment 'Boolean flag indicating whether this build supports cross-platform play or cross-platform progression with other platform versions of the game. True indicates cross-platform features are enabled and certified, false indicates platform-exclusive build.' ;
    rdfs:domain ind:Platform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:failureCategories rdf:type rdf:Property ;
    rdfs:label 'Failure Categories' ;
    rdfs:comment 'Comma-separated list of TRC/TCR failure categories or violation codes identified by the platform holder during certification review. Categories may include performance issues, stability problems, UI/UX violations, accessibility failures, content policy violations, or technical requirement breaches. Used for root cause analysis and quality improvement.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureCount rdf:type rdf:Property ;
    rdfs:label 'Failure Count' ;
    rdfs:comment 'Total number of certification failures or rejections for this submission across all review cycles. Increments with each failed review, used to track submission quality and identify problematic builds requiring significant rework.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inAppPurchasesEnabled rdf:type rdf:Property ;
    rdfs:label 'In App Purchases Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this build includes in-app purchase or microtransaction functionality. True indicates IAP features are present and must comply with platform holder commerce policies and PCI DSS requirements, false indicates no monetization features.' ;
    rdfs:domain ind:PlatformCertSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:multiplayerEnabled rdf:type rdf:Property ;
    rdfs:label 'Multiplayer Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this build includes online multiplayer functionality. True indicates multiplayer features are present and must pass platform holder online service certification requirements, false indicates single-player only build.' ;
    rdfs:domain ind:PlatformCertSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformReviewerNotes rdf:type rdf:Property ;
    rdfs:label 'Platform Reviewer Notes' ;
    rdfs:comment 'Detailed notes and feedback provided by the platform holder certification reviewers. May include specific issues identified, recommendations for improvement, clarifications on TRC/TCR interpretation, and guidance for resubmission. Confidential business communication between platform holder and developer.' ;
    rdfs:domain ind:PlatformCertSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformSdkVersion rdf:type rdf:Property ;
    rdfs:label 'Platform Sdk Version' ;
    rdfs:comment 'Version of the platform SDK used to build and compile the submitted game build. Platform holders require builds to be compiled with approved SDK versions, and this field tracks SDK compliance for certification purposes.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Resubmission Deadline' ;
    rdfs:comment 'Date by which a corrected build must be resubmitted following a certification failure. Platform holders typically impose deadlines to maintain release schedules and certification queue management. Null if submission passed or no deadline was set.' ;
    rdfs:domain ind:PlatformCertSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Review Completion Date' ;
    rdfs:comment 'Date when the platform holder completed certification review and issued the final outcome (pass, fail, or conditional pass). Used to calculate total review cycle time and track platform holder SLA performance.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Start Date' ;
    rdfs:comment 'Date when the platform holder began active certification review of the submitted build. May differ from submission date if there is a queue or validation period. Used to calculate actual review duration.' ;
    rdfs:domain ind:Platform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Target Release Date' ;
    rdfs:comment 'Planned commercial release date for the game title or update associated with this certification submission. Used for release planning, marketing coordination, and certification timeline management. May be adjusted based on certification outcomes.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverDetails rdf:type rdf:Property ;
    rdfs:label 'Waiver Details' ;
    rdfs:comment 'Detailed description of any waivers or exceptions granted by the platform holder, including the specific TRC/TCR requirements waived, justification for the waiver, and any conditions or limitations imposed. Null if no waiver was granted.' ;
    rdfs:domain ind:PlatformCertSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverGranted rdf:type rdf:Property ;
    rdfs:label 'Waiver Granted' ;
    rdfs:comment 'Boolean flag indicating whether the platform holder granted a waiver or exception for one or more TRC/TCR requirements that the build did not fully meet. True indicates a waiver was granted allowing certification despite non-compliance, false indicates no waivers were needed or granted.' ;
    rdfs:domain ind:PlatformCertSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orgUnitId rdf:type rdf:Property ;
    rdfs:label 'Org Unit Id' ;
    rdfs:comment 'Reference to the platform holder entity (Sony, Microsoft, Nintendo, Apple, Google) that issued this certification checklist.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:supersededByChecklistCertificationChecklistId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Checklist Certification Checklist Id' ;
    rdfs:comment 'Reference to the newer certification checklist version that supersedes this one. Null if this is the current active version.' ;
    rdfs:domain ind:CertificationChecklist ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CertificationChecklist .

ind:accessibilityRequirementsFlag rdf:type rdf:Property ;
    rdfs:label 'Accessibility Requirements Flag' ;
    rdfs:comment 'Indicates whether this checklist includes accessibility requirements (e.g., colorblind modes, subtitle support, controller remapping).' ;
    rdfs:domain ind:CertificationChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:advisoryRequirementCount rdf:type rdf:Property ;
    rdfs:label 'Advisory Requirement Count' ;
    rdfs:comment 'The number of requirements in this checklist that are classified as advisory or recommended but not mandatory.' ;
    rdfs:domain ind:CertificationChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageRatingRequirementsFlag rdf:type rdf:Property ;
    rdfs:label 'Age Rating Requirements Flag' ;
    rdfs:comment 'Indicates whether this checklist includes requirements related to age rating compliance (ESRB, PEGI, CERO, etc.).' ;
    rdfs:domain ind:CertificationChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:averageReviewDurationDays rdf:type rdf:Property ;
    rdfs:label 'Average Review Duration Days' ;
    rdfs:comment 'The typical number of business days the platform holder takes to review a certification submission against this checklist.' ;
    rdfs:domain ind:CertificationChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:categoryTaxonomy rdf:type rdf:Property ;
    rdfs:label 'Category Taxonomy' ;
    rdfs:comment 'The hierarchical categorization scheme used to organize requirements in this checklist (e.g., Audio, Video, Network, Save Data, Accessibility, Age Rating, Performance, Security). Stored as a structured taxonomy reference.' ;
    rdfs:domain ind:CertificationChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationChecklistStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Checklist Status' ;
    rdfs:comment 'Current lifecycle status of the certification checklist: Draft (under development), Active (in use), Deprecated (phasing out), Superseded (replaced by newer version), Archived (historical record only).' ;
    rdfs:domain ind:CertificationChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Certification Fee Amount' ;
    rdfs:comment 'The fee charged by the platform holder for certification review against this checklist, if applicable. Null if no fee is charged.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Certification Fee Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the certification fee (e.g., USD, EUR, JPY).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistCode rdf:type rdf:Property ;
    rdfs:label 'Checklist Code' ;
    rdfs:comment 'The official code or identifier assigned by the platform holder to this checklist version (e.g., PS5-TRC-2024-Q1, XBOX-TCR-V3.2).' ;
    rdfs:domain ind:CertificationChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistName rdf:type rdf:Property ;
    rdfs:label 'Checklist Name' ;
    rdfs:comment 'Human-readable name of the certification checklist (e.g., PlayStation 5 Technical Requirements Checklist Q1 2024).' ;
    rdfs:domain ind:CertificationChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistType rdf:type rdf:Property ;
    rdfs:label 'Checklist Type' ;
    rdfs:comment 'The type of certification checklist: TRC (Technical Requirements Checklist), TCR (Technical Certification Requirements), Submission Guidelines, or Compliance Checklist.' ;
    rdfs:domain ind:CertificationChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionalRequirementCount rdf:type rdf:Property ;
    rdfs:label 'Conditional Requirement Count' ;
    rdfs:comment 'The number of requirements that are mandatory only under specific conditions (e.g., if game uses online features, if game targets specific age rating).' ;
    rdfs:domain ind:CertificationChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crossPlatformCompatibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Platform Compatibility Flag' ;
    rdfs:comment 'Indicates whether this checklist includes requirements for cross-platform play, cross-save, or cross-progression features.' ;
    rdfs:domain ind:CertificationChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmRequirementsFlag rdf:type rdf:Property ;
    rdfs:label 'Drm Requirements Flag' ;
    rdfs:comment 'Indicates whether this checklist includes specific DRM or entitlement system requirements that must be implemented.' ;
    rdfs:domain ind:CertificationChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mandatoryRequirementCount rdf:type rdf:Property ;
    rdfs:label 'Mandatory Requirement Count' ;
    rdfs:comment 'The number of requirements in this checklist that are classified as mandatory for certification approval.' ;
    rdfs:domain ind:CertificationChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:platformGeneration rdf:type rdf:Property ;
    rdfs:label 'Platform Generation' ;
    rdfs:comment 'The platform generation or hardware version this checklist applies to (e.g., PS5, Xbox Series X|S, Nintendo Switch 2, iOS 17, Android 14).' ;
    rdfs:domain ind:Platform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformHolderContact rdf:type rdf:Property ;
    rdfs:label 'Platform Holder Contact' ;
    rdfs:comment 'Primary contact information or support channel for questions about this checklist version (e.g., developer relations email, support portal URL).' ;
    rdfs:domain ind:CertificationChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privacyComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Privacy Compliance Flag' ;
    rdfs:comment 'Indicates whether this checklist includes privacy and data protection requirements (GDPR, COPPA, etc.).' ;
    rdfs:domain ind:CertificationChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resubmissionPolicy rdf:type rdf:Property ;
    rdfs:label 'Resubmission Policy' ;
    rdfs:comment 'Policy and guidelines for resubmitting a game build after a failed certification attempt, including any limitations or fees.' ;
    rdfs:domain ind:CertificationChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdkVersionMinimum rdf:type rdf:Property ;
    rdfs:label 'Sdk Version Minimum' ;
    rdfs:comment 'The minimum SDK version required to comply with this checklist (e.g., PS5 SDK 7.0, Xbox GDK June 2024).' ;
    rdfs:domain ind:CertificationChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdkVersionRecommended rdf:type rdf:Property ;
    rdfs:label 'Sdk Version Recommended' ;
    rdfs:comment 'The recommended SDK version for optimal compliance and feature support with this checklist.' ;
    rdfs:domain ind:CertificationChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionFormat rdf:type rdf:Property ;
    rdfs:label 'Submission Format' ;
    rdfs:comment 'The required format for submitting certification evidence against this checklist (e.g., Excel spreadsheet, online portal form, PDF report).' ;
    rdfs:domain ind:CertificationChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalRequirementCount rdf:type rdf:Property ;
    rdfs:label 'Total Requirement Count' ;
    rdfs:comment 'The total number of individual requirement line items contained in this checklist version.' ;
    rdfs:domain ind:CertificationChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waiverProcessDescription rdf:type rdf:Property ;
    rdfs:label 'Waiver Process Description' ;
    rdfs:comment 'Description of the process for requesting waivers or exceptions to specific requirements in this checklist, including eligibility criteria and approval workflow.' ;
    rdfs:domain ind:CertificationChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistRequirementId rdf:type rdf:Property ;
    rdfs:label 'Checklist Requirement Id' ;
    rdfs:comment 'Unique identifier for the certification checklist requirement line item.' ;
    rdfs:domain ind:ChecklistRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualEffortHours rdf:type rdf:Property ;
    rdfs:label 'Actual Effort Hours' ;
    rdfs:comment 'Actual number of hours spent on implementing, testing, or remediating this requirement.' ;
    rdfs:domain ind:ChecklistRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buildVersionTested rdf:type rdf:Property ;
    rdfs:label 'Build Version Tested' ;
    rdfs:comment 'Game build version or SDK version number that was tested for compliance with this requirement.' ;
    rdfs:domain ind:ChecklistRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistRequirementCategory rdf:type rdf:Property ;
    rdfs:label 'Checklist Requirement Category' ;
    rdfs:comment 'Functional category of the certification requirement. [ENUM-REF-CANDIDATE: audio|video|network|save_data|accessibility|age_rating|input|ui_ux|performance|stability|security|privacy|commerce|social|multiplayer|cloud_save|achievements|localization — promote to reference product]' ;
    rdfs:domain ind:ChecklistRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedEffortHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Effort Hours' ;
    rdfs:comment 'Estimated number of development or testing hours required to implement or verify compliance with this requirement.' ;
    rdfs:domain ind:ChecklistRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformHolderFeedback rdf:type rdf:Property ;
    rdfs:label 'Platform Holder Feedback' ;
    rdfs:comment 'Official feedback, comments, or clarifications provided by the platform holder certification team regarding this requirement during the submission review process.' ;
    rdfs:domain ind:ChecklistRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformHolderGuidance rdf:type rdf:Property ;
    rdfs:label 'Platform Holder Guidance' ;
    rdfs:comment 'Additional implementation guidance, clarifications, or notes provided by the platform holder (Sony, Microsoft, Nintendo, Valve, Epic, Apple, Google) to assist developers in meeting the requirement.' ;
    rdfs:domain ind:ChecklistRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementCode rdf:type rdf:Property ;
    rdfs:label 'Requirement Code' ;
    rdfs:comment 'The official platform holder requirement code identifier (e.g., XR-045, PS-1023A, NSW-0412). This is the externally-known unique identifier assigned by the platform holder.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementDescription rdf:type rdf:Property ;
    rdfs:label 'Requirement Description' ;
    rdfs:comment 'Detailed description of the certification requirement including expected behavior, implementation guidance, and compliance criteria as specified by the platform holder.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementTitle rdf:type rdf:Property ;
    rdfs:label 'Requirement Title' ;
    rdfs:comment 'Short descriptive title of the certification requirement as defined by the platform holder.' ;
    rdfs:domain ind:ChecklistRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementVersion rdf:type rdf:Property ;
    rdfs:label 'Requirement Version' ;
    rdfs:comment 'Version number of the requirement specification as platform holders periodically update their TRC/TCR guidelines.' ;
    rdfs:domain ind:ChecklistRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retestRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Retest Required Flag' ;
    rdfs:comment 'Indicates whether this requirement needs to be retested after remediation or code changes.' ;
    rdfs:domain ind:ChecklistRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Severity classification indicating whether the requirement is mandatory (must pass for certification), advisory (recommended but not blocking), or conditional (mandatory only under specific circumstances).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCaseReference rdf:type rdf:Property ;
    rdfs:label 'Test Case Reference' ;
    rdfs:comment 'Reference identifier to the associated QA test case or test plan used to verify compliance with this requirement during certification testing.' ;
    rdfs:domain ind:ChecklistRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Test Execution Date' ;
    rdfs:comment 'Date when compliance testing for this requirement was executed by the QA team.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testResultNotes rdf:type rdf:Property ;
    rdfs:label 'Test Result Notes' ;
    rdfs:comment 'Detailed notes from QA testing documenting test execution, observed behavior, pass/fail rationale, and any issues encountered during compliance verification.' ;
    rdfs:domain ind:ChecklistRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Waiver Approval Status' ;
    rdfs:comment 'Status of the waiver request as determined by the platform holder certification team.' ;
    rdfs:domain ind:ChecklistRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Eligible Flag' ;
    rdfs:comment 'Indicates whether this requirement is eligible for a waiver or exception request from the platform holder under specific circumstances.' ;
    rdfs:domain ind:ChecklistRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverRequestNotes rdf:type rdf:Property ;
    rdfs:label 'Waiver Request Notes' ;
    rdfs:comment 'Business justification and technical rationale submitted to the platform holder when requesting a waiver or exception for this requirement.' ;
    rdfs:domain ind:ChecklistRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiVersion rdf:type rdf:Property ;
    rdfs:label 'Api Version' ;
    rdfs:comment 'Version of the graphics or platform API used (e.g., DirectX 12, Vulkan 1.3, Metal 3).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Ar Support Flag' ;
    rdfs:comment 'Indicates whether the game supports AR features on this platform.' ;
    rdfs:domain ind:CompatibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Date' ;
    rdfs:comment 'Date when the compatibility profile received platform certification approval.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiry Date' ;
    rdfs:comment 'Date when the platform certification expires and requires renewal or recertification.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:colorblindModeFlag rdf:type rdf:Property ;
    rdfs:label 'Colorblind Mode Flag' ;
    rdfs:comment 'Indicates whether the game provides colorblind accessibility modes on this platform.' ;
    rdfs:domain ind:CompatibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controllerSupportTypes rdf:type rdf:Property ;
    rdfs:label 'Controller Support Types' ;
    rdfs:comment 'Comma-separated list of supported controller types (e.g., keyboard_mouse, gamepad, touch, motion_controls, adaptive_controller).' ;
    rdfs:domain ind:CompatibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossPlatformPlayFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Platform Play Flag' ;
    rdfs:comment 'Indicates whether the game supports cross-platform multiplayer with other platforms.' ;
    rdfs:domain ind:CompatibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossSaveFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Save Flag' ;
    rdfs:comment 'Indicates whether the game supports cross-platform save file synchronization.' ;
    rdfs:domain ind:CompatibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmSystem rdf:type rdf:Property ;
    rdfs:label 'Drm System' ;
    rdfs:comment 'Name of the DRM system used for entitlement and copy protection on this platform (e.g., Denuvo, Steam DRM, Epic Online Services).' ;
    rdfs:domain ind:Platform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endOfSupportDate rdf:type rdf:Property ;
    rdfs:label 'End Of Support Date' ;
    rdfs:comment 'Date when this compatibility profile will no longer be supported or maintained.' ;
    rdfs:domain ind:CompatibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hdrSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Hdr Support Flag' ;
    rdfs:comment 'Indicates whether the game supports HDR rendering on this platform.' ;
    rdfs:domain ind:CompatibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localMultiplayerFlag rdf:type rdf:Property ;
    rdfs:label 'Local Multiplayer Flag' ;
    rdfs:comment 'Indicates whether the game supports local split-screen or couch co-op multiplayer on this platform.' ;
    rdfs:domain ind:CompatibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxConcurrentPlayers rdf:type rdf:Property ;
    rdfs:label 'Max Concurrent Players' ;
    rdfs:comment 'Maximum number of concurrent players supported in a single multiplayer session on this platform.' ;
    rdfs:domain ind:CompatibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minCpuSpec rdf:type rdf:Property ;
    rdfs:label 'Min Cpu Spec' ;
    rdfs:comment 'Minimum CPU requirement for the game on this platform, including processor model and clock speed.' ;
    rdfs:domain ind:CompatibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minGpuSpec rdf:type rdf:Property ;
    rdfs:label 'Min Gpu Spec' ;
    rdfs:comment 'Minimum GPU requirement for the game on this platform, including graphics card model and VRAM.' ;
    rdfs:domain ind:CompatibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minRamGb rdf:type rdf:Property ;
    rdfs:label 'Min Ram Gb' ;
    rdfs:comment 'Minimum system RAM required in gigabytes to run the game on this platform.' ;
    rdfs:domain ind:CompatibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minStorageGb rdf:type rdf:Property ;
    rdfs:label 'Min Storage Gb' ;
    rdfs:comment 'Minimum disk storage space required in gigabytes to install and run the game.' ;
    rdfs:domain ind:CompatibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onlineMultiplayerFlag rdf:type rdf:Property ;
    rdfs:label 'Online Multiplayer Flag' ;
    rdfs:comment 'Indicates whether the game supports online multiplayer gameplay on this platform.' ;
    rdfs:domain ind:CompatibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceNotes rdf:type rdf:Property ;
    rdfs:label 'Performance Notes' ;
    rdfs:comment 'Additional notes regarding performance characteristics, known issues, or optimization details for this platform.' ;
    rdfs:domain ind:CompatibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileCode rdf:type rdf:Property ;
    rdfs:label 'Profile Code' ;
    rdfs:comment 'Business identifier code for the compatibility profile, typically combining game SKU and platform abbreviation.' ;
    rdfs:domain ind:CompatibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileName rdf:type rdf:Property ;
    rdfs:label 'Profile Name' ;
    rdfs:comment 'Human-readable name of the compatibility profile, typically including game title and platform.' ;
    rdfs:domain ind:CompatibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileVersion rdf:type rdf:Property ;
    rdfs:label 'Profile Version' ;
    rdfs:comment 'Semantic version number of the compatibility profile, incremented with each hardware or OS requirement update.' ;
    rdfs:domain ind:CompatibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rayTracingSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Ray Tracing Support Flag' ;
    rdfs:comment 'Indicates whether the game supports real-time ray tracing on this platform.' ;
    rdfs:domain ind:CompatibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recommendedCpuSpec rdf:type rdf:Property ;
    rdfs:label 'Recommended Cpu Spec' ;
    rdfs:comment 'Recommended CPU specification for optimal game performance on this platform.' ;
    rdfs:domain ind:CompatibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedGpuSpec rdf:type rdf:Property ;
    rdfs:label 'Recommended Gpu Spec' ;
    rdfs:comment 'Recommended GPU specification for optimal game performance and visual quality on this platform.' ;
    rdfs:domain ind:CompatibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedRamGb rdf:type rdf:Property ;
    rdfs:label 'Recommended Ram Gb' ;
    rdfs:comment 'Recommended system RAM in gigabytes for optimal game performance on this platform.' ;
    rdfs:domain ind:CompatibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedStorageGb rdf:type rdf:Property ;
    rdfs:label 'Recommended Storage Gb' ;
    rdfs:comment 'Recommended disk storage space in gigabytes for optimal game experience including DLC and updates.' ;
    rdfs:domain ind:CompatibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remappableControlsFlag rdf:type rdf:Property ;
    rdfs:label 'Remappable Controls Flag' ;
    rdfs:comment 'Indicates whether the game allows players to remap control inputs on this platform.' ;
    rdfs:domain ind:CompatibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subtitleSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Subtitle Support Flag' ;
    rdfs:comment 'Indicates whether the game provides subtitle accessibility features on this platform.' ;
    rdfs:domain ind:CompatibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportedOsVersions rdf:type rdf:Property ;
    rdfs:label 'Supported Os Versions' ;
    rdfs:comment 'Comma-separated list of supported operating system versions for this platform (e.g., Windows 10, Windows 11, macOS 12+, iOS 15+).' ;
    rdfs:domain ind:CompatibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedResolutions rdf:type rdf:Property ;
    rdfs:label 'Supported Resolutions' ;
    rdfs:comment 'Comma-separated list of supported display resolutions (e.g., 1080p, 1440p, 4K, 8K).' ;
    rdfs:domain ind:CompatibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetFrameRates rdf:type rdf:Property ;
    rdfs:label 'Target Frame Rates' ;
    rdfs:comment 'Comma-separated list of target frame rates per second supported (e.g., 30fps, 60fps, 120fps, 144fps).' ;
    rdfs:domain ind:CompatibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:textToSpeechFlag rdf:type rdf:Property ;
    rdfs:label 'Text To Speech Flag' ;
    rdfs:comment 'Indicates whether the game provides text-to-speech accessibility features on this platform.' ;
    rdfs:domain ind:CompatibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vrSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Vr Support Flag' ;
    rdfs:comment 'Indicates whether the game supports VR headsets and gameplay on this platform.' ;
    rdfs:domain ind:CompatibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformIntegrationId rdf:type rdf:Property ;
    rdfs:label 'Platform Integration Id' ;
    rdfs:comment 'Reference to the platform integration (console SDK, storefront, or mobile app store pipeline) where this compliance event originated.' ;
    rdfs:domain ind:ComplianceEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SdkIntegration .

ind:previousEventComplianceEventId rdf:type rdf:Property ;
    rdfs:label 'Previous Event Compliance Event Id' ;
    rdfs:comment 'Reference to the previous compliance event ID if this is a recurrence. Null if this is the first occurrence.' ;
    rdfs:domain ind:ComplianceEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceEvent .

ind:affectedPlatformCode rdf:type rdf:Property ;
    rdfs:label 'Affected Platform Code' ;
    rdfs:comment 'Code representing the gaming platform affected by this compliance event: PS5 (PlayStation 5), PS4 (PlayStation 4), XBSX (Xbox Series X/S), XBONE (Xbox One), NSW (Nintendo Switch), PC_STEAM (Steam), PC_EPIC (Epic Games Store), IOS (Apple App Store), ANDROID (Google Play). [ENUM-REF-CANDIDATE: PS5|PS4|XBSX|XBONE|NSW|PC_STEAM|PC_EPIC|IOS|ANDROID — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ComplianceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'Assigned Owner Email' ;
    rdfs:comment 'Email address of the individual or team responsible for managing and resolving this compliance event.' ;
    rdfs:domain ind:ComplianceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedOwnerName rdf:type rdf:Property ;
    rdfs:label 'Assigned Owner Name' ;
    rdfs:comment 'Full name of the individual or team lead assigned to manage this compliance event.' ;
    rdfs:domain ind:ComplianceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationThreadUrl rdf:type rdf:Property ;
    rdfs:label 'Communication Thread Url' ;
    rdfs:comment 'URL link to the email thread, ticketing system, or collaboration platform where communication regarding this compliance event is tracked (e.g., Jira ticket, Zendesk case, email thread).' ;
    rdfs:domain ind:ComplianceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Event Reference Number' ;
    rdfs:comment 'Externally-known unique reference number for this compliance event, typically assigned by the platform holder or regulatory body. Format: platform code (3 letters), date (8 digits YYYYMMDD), sequence (6 alphanumeric).' ;
    rdfs:domain ind:ComplianceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Penalty Amount' ;
    rdfs:comment 'Monetary penalty or fine imposed by the platform holder or regulatory body for this compliance violation. Null if no penalty was assessed.' ;
    rdfs:domain ind:ComplianceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialPenaltyCurrency rdf:type rdf:Property ;
    rdfs:label 'Financial Penalty Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the financial penalty amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:ComplianceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationReceivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Received Timestamp' ;
    rdfs:comment 'Date and time when the compliance event notification was received by the organization. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ComplianceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originatingEntity rdf:type rdf:Property ;
    rdfs:label 'Originating Entity' ;
    rdfs:comment 'Name of the platform holder, regulatory body, or certification authority that issued this compliance event (e.g., Sony Interactive Entertainment, Apple App Store Review, ESRB, FTC, European Commission).' ;
    rdfs:domain ind:ComplianceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingEntityType rdf:type rdf:Property ;
    rdfs:label 'Originating Entity Type' ;
    rdfs:comment 'Type of entity that originated the compliance event: platform_holder (console manufacturer or storefront operator), regulatory_body (government agency), certification_authority (rating board or standards organization), internal_audit (self-identified compliance issue).' ;
    rdfs:domain ind:ComplianceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformSuspensionFlag rdf:type rdf:Property ;
    rdfs:label 'Platform Suspension Flag' ;
    rdfs:comment 'Boolean flag indicating whether the platform SKU or game title was suspended or removed from the platform as a result of this compliance event. True if suspended, False otherwise.' ;
    rdfs:domain ind:ComplianceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policySectionReference rdf:type rdf:Property ;
    rdfs:label 'Policy Section Reference' ;
    rdfs:comment 'Reference to the specific section or clause of the platform policy, regulatory statute, or certification guideline that was violated or triggered this event.' ;
    rdfs:domain ind:ComplianceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationActionRequired rdf:type rdf:Property ;
    rdfs:label 'Remediation Action Required' ;
    rdfs:comment 'Description of the corrective action required to resolve the compliance event, as specified by the originating entity or determined by internal compliance team.' ;
    rdfs:domain ind:ComplianceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trcTcrReference rdf:type rdf:Property ;
    rdfs:label 'Trc Tcr Reference' ;
    rdfs:comment 'Reference to the specific TRC or TCR requirement violated or flagged in this compliance event. TRC applies to PlayStation, TCR applies to Xbox.' ;
    rdfs:domain ind:ComplianceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationDescription rdf:type rdf:Property ;
    rdfs:label 'Violation Description' ;
    rdfs:comment 'Detailed description of the compliance violation, policy breach, or regulatory issue identified by the originating entity.' ;
    rdfs:domain ind:ComplianceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingScope rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Scope' ;
    rdfs:comment 'Description of what player data is shared across platforms for this feature (e.g., player ID, progression data, inventory, friends list).' ;
    rdfs:domain ind:CrossplayFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementSyncEnabled rdf:type rdf:Property ;
    rdfs:label 'Entitlement Sync Enabled' ;
    rdfs:comment 'Indicates whether DRM (Digital Rights Management) entitlements and IAP (In-App Purchase) are synchronized across platforms for this feature (true/false).' ;
    rdfs:domain ind:CrossplayFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:featureCode rdf:type rdf:Property ;
    rdfs:label 'Feature Code' ;
    rdfs:comment 'Business identifier code for the cross-platform feature (e.g., XPLAY_PS5_PC, XSAVE_ALL).' ;
    rdfs:domain ind:CrossplayFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureType rdf:type rdf:Property ;
    rdfs:label 'Feature Type' ;
    rdfs:comment 'Type of cross-platform capability: cross-play (multiplayer across platforms), cross-save (save file portability), cross-progression (shared progression), or cross-purchase (buy once play anywhere).' ;
    rdfs:domain ind:CrossplayFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fpsParityEnforced rdf:type rdf:Property ;
    rdfs:label 'Fps Parity Enforced' ;
    rdfs:comment 'Indicates whether frame rate parity is enforced across platforms to ensure competitive fairness (true/false).' ;
    rdfs:domain ind:CrossplayFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:friendListIntegration rdf:type rdf:Property ;
    rdfs:label 'Friend List Integration' ;
    rdfs:comment 'Type of friend list integration across platforms: none (no cross-platform friends), platform-native (each platform\'s own list), unified social graph (single cross-platform friends list), or hybrid (both).' ;
    rdfs:domain ind:CrossplayFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputMethodBalancingEnabled rdf:type rdf:Property ;
    rdfs:label 'Input Method Balancing Enabled' ;
    rdfs:comment 'Indicates whether matchmaking or gameplay balancing accounts for input method differences (controller vs keyboard/mouse) across platforms (true/false).' ;
    rdfs:domain ind:CrossplayFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchmakingPoolUnified rdf:type rdf:Property ;
    rdfs:label 'Matchmaking Pool Unified' ;
    rdfs:comment 'Indicates whether players from all supported platforms share a unified matchmaking pool for PvP (Player versus Player) or co-op gameplay (true/false).' ;
    rdfs:domain ind:CrossplayFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partySystemSupported rdf:type rdf:Property ;
    rdfs:label 'Party System Supported' ;
    rdfs:comment 'Indicates whether players can form cross-platform parties or squads before entering matchmaking (true/false).' ;
    rdfs:domain ind:CrossplayFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformHolderApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Platform Holder Approval Status' ;
    rdfs:comment 'Approval status from the platform holder (Sony, Microsoft, Nintendo, Valve, Epic) for this cross-platform feature.' ;
    rdfs:domain ind:CrossplayFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformIconDisplayEnabled rdf:type rdf:Property ;
    rdfs:label 'Platform Icon Display Enabled' ;
    rdfs:comment 'Indicates whether player platform icons are displayed in-game to identify which platform each player is using (true/false).' ;
    rdfs:domain ind:CrossplayFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformRevenueShareAgreement rdf:type rdf:Property ;
    rdfs:label 'Platform Revenue Share Agreement' ;
    rdfs:comment 'Description of revenue sharing terms with platform holders for cross-platform transactions (e.g., MTX (Microtransactions), IAP (In-App Purchase)).' ;
    rdfs:domain ind:CrossplayFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerAdoptionRatePct rdf:type rdf:Property ;
    rdfs:label 'Player Adoption Rate Pct' ;
    rdfs:comment 'Percentage of eligible players who have opted into or are actively using this cross-platform feature.' ;
    rdfs:domain ind:CrossplayFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:playerConsentRequired rdf:type rdf:Property ;
    rdfs:label 'Player Consent Required' ;
    rdfs:comment 'Indicates whether explicit player consent is required before enabling this cross-platform feature (true/false).' ;
    rdfs:domain ind:CrossplayFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:playerOptInPolicy rdf:type rdf:Property ;
    rdfs:label 'Player Opt In Policy' ;
    rdfs:comment 'Policy governing whether players must opt-in or can opt-out of the cross-platform feature (mandatory, opt-in by default, opt-out by default, or player choice).' ;
    rdfs:domain ind:CrossplayFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relayServerRegion rdf:type rdf:Property ;
    rdfs:label 'Relay Server Region' ;
    rdfs:comment 'Geographic region or CDN (Content Delivery Network) zone hosting the relay server infrastructure for this cross-platform feature.' ;
    rdfs:domain ind:CrossplayFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedPlatformCombination rdf:type rdf:Property ;
    rdfs:label 'Supported Platform Combination' ;
    rdfs:comment 'Comma-separated list of platform codes that participate in this cross-platform feature (e.g., PS5,XBOX_SERIES_X,PC_STEAM).' ;
    rdfs:domain ind:CrossplayFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalImplementationApproach rdf:type rdf:Property ;
    rdfs:label 'Technical Implementation Approach' ;
    rdfs:comment 'Technical architecture used to implement the cross-platform feature (relay server for matchmaking, peer-to-peer for direct connection, cloud sync for save data, platform API for entitlements).' ;
    rdfs:domain ind:CrossplayFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:textChatSupported rdf:type rdf:Property ;
    rdfs:label 'Text Chat Supported' ;
    rdfs:comment 'Indicates whether text chat is supported across platforms for this cross-play feature (true/false).' ;
    rdfs:domain ind:CrossplayFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:voiceChatSupported rdf:type rdf:Property ;
    rdfs:label 'Voice Chat Supported' ;
    rdfs:comment 'Indicates whether voice chat is supported across platforms for this cross-play feature (true/false).' ;
    rdfs:domain ind:CrossplayFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountIdentifier rdf:type rdf:Property ;
    rdfs:label 'Account Identifier' ;
    rdfs:comment 'The externally-known unique account identifier or username assigned by the platform holder\'s developer portal (e.g., PlayStation DevNet account ID, Xbox Partner Center account ID, Steamworks partner account ID).' ;
    rdfs:domain ind:DeveloperAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountManagerEmail rdf:type rdf:Property ;
    rdfs:label 'Account Manager Email' ;
    rdfs:comment 'Email address of the platform holder\'s account manager for direct support and escalation.' ;
    rdfs:domain ind:DeveloperAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountManagerName rdf:type rdf:Property ;
    rdfs:label 'Account Manager Name' ;
    rdfs:comment 'Name of the platform holder\'s account manager or partner representative assigned to this developer account.' ;
    rdfs:domain ind:DeveloperAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiKey rdf:type rdf:Property ;
    rdfs:label 'Api Key' ;
    rdfs:comment 'The API key or access token issued to this developer account for programmatic access to platform services.' ;
    rdfs:domain ind:Platform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAddress rdf:type rdf:Property ;
    rdfs:label 'Business Address' ;
    rdfs:comment 'The registered business address of the developer or publisher organization.' ;
    rdfs:domain ind:DeveloperAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Access Flag' ;
    rdfs:comment 'Indicates whether the account has access to submit titles for platform certification and TRC (Technical Requirements Checklist) / TCR (Technical Certification Requirements) compliance review.' ;
    rdfs:domain ind:DeveloperAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossPlatformEnabled rdf:type rdf:Property ;
    rdfs:label 'Cross Platform Enabled' ;
    rdfs:comment 'Indicates whether the account is enabled for cross-platform development and deployment capabilities.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:devKitAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Dev Kit Access Flag' ;
    rdfs:comment 'Indicates whether the account has been granted access to order or receive development hardware kits.' ;
    rdfs:domain ind:DeveloperAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmEntitlementAccess rdf:type rdf:Property ;
    rdfs:label 'Drm Entitlement Access' ;
    rdfs:comment 'Indicates whether the account has access to DRM entitlement systems for managing digital rights and licenses.' ;
    rdfs:domain ind:DeveloperAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enrolledPrograms rdf:type rdf:Property ;
    rdfs:label 'Enrolled Programs' ;
    rdfs:comment 'Comma-separated list of platform-specific programs the account is enrolled in (e.g., dev kit access, early SDK (Software Development Kit) access, beta programs, ID@Xbox, PlayStation Indies).' ;
    rdfs:domain ind:DeveloperAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'The date when the developer account was first enrolled and approved by the platform holder.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrollment Status' ;
    rdfs:comment 'Current lifecycle status of the developer account enrollment with the platform holder.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastLoginTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Login Timestamp' ;
    rdfs:comment 'The timestamp of the most recent login to the developer portal by this account.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ndaExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Nda Expiry Date' ;
    rdfs:comment 'The date when the non-disclosure agreement expires and requires renewal.' ;
    rdfs:domain ind:DeveloperAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ndaSignedDate rdf:type rdf:Property ;
    rdfs:label 'Nda Signed Date' ;
    rdfs:comment 'The date when the developer signed the non-disclosure agreement required by the platform holder.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:portalUrl rdf:type rdf:Property ;
    rdfs:label 'Portal Url' ;
    rdfs:comment 'The web URL of the platform holder\'s developer portal where this account is managed.' ;
    rdfs:domain ind:DeveloperAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinstatementDate rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Date' ;
    rdfs:comment 'The date when a previously suspended account was reinstated to active status.' ;
    rdfs:domain ind:DeveloperAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueThresholdTier rdf:type rdf:Property ;
    rdfs:label 'Revenue Threshold Tier' ;
    rdfs:comment 'Revenue-based tier classification that may affect revenue share percentages, support priority, and program eligibility.' ;
    rdfs:domain ind:DeveloperAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdkAccessLevel rdf:type rdf:Property ;
    rdfs:label 'Sdk Access Level' ;
    rdfs:comment 'The level of SDK (Software Development Kit) access granted to the account, determining which SDK versions and features are available.' ;
    rdfs:domain ind:DeveloperAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Date' ;
    rdfs:comment 'The date when the account was suspended, if applicable.' ;
    rdfs:domain ind:DeveloperAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'The tax identification number (EIN, VAT, or equivalent) registered for this developer account for tax reporting purposes.' ;
    rdfs:domain ind:DeveloperAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:twoFactorAuthEnabled rdf:type rdf:Property ;
    rdfs:label 'Two Factor Auth Enabled' ;
    rdfs:comment 'Indicates whether two-factor authentication (2FA) is enabled for this developer account to enhance security.' ;
    rdfs:domain ind:DeveloperAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entitlementRuleId rdf:type rdf:Property ;
    rdfs:label 'Entitlement Rule Id' ;
    rdfs:comment 'Reference to the master entitlement rule definition that governs this grant. Links grant-level records to their governing rule-level configuration. Null for rule-level records themselves.' ;
    rdfs:domain ind:Platform ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EntitlementRule .

ind:platformIdentityId rdf:type rdf:Property ;
    rdfs:label 'Platform Identity Id' ;
    rdfs:comment 'The player\'s account identifier on the external platform (Steam ID, PSN ID, Xbox Live Gamertag, Epic Account ID, etc.). Used for platform-level entitlement verification.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlatformIdentity .

ind:allowedRegions rdf:type rdf:Property ;
    rdfs:label 'Allowed Regions' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where this entitlement is valid. Empty if region_lock_enabled is false. Example: USA,CAN,GBR,DEU.' ;
    rdfs:domain ind:DrmEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concurrentDeviceLimit rdf:type rdf:Property ;
    rdfs:label 'Concurrent Device Limit' ;
    rdfs:comment 'Maximum number of devices that can simultaneously use this entitlement. Applicable for multi-device license scope. Null for single-device or unlimited scope.' ;
    rdfs:domain ind:Platform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviceBindingCode rdf:type rdf:Property ;
    rdfs:label 'Device Binding Code' ;
    rdfs:comment 'Unique identifier of the device to which this entitlement is bound. Applicable for single-device license scope. May be device serial number, hardware fingerprint, or platform device ID.' ;
    rdfs:domain ind:DrmEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementNotes rdf:type rdf:Property ;
    rdfs:label 'Entitlement Notes' ;
    rdfs:comment 'Free-text field for additional notes, special conditions, or administrative comments related to this entitlement. Used for documenting exceptions, special grants, or support case references.' ;
    rdfs:domain ind:DrmEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryDurationDays rdf:type rdf:Property ;
    rdfs:label 'Expiry Duration Days' ;
    rdfs:comment 'Number of days from grant timestamp until entitlement expires. Applicable only when expiry_rule is duration_days. Null for other expiry rule types.' ;
    rdfs:domain ind:DrmEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expiryFixedDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Fixed Date' ;
    rdfs:comment 'Specific calendar date when entitlement expires. Applicable only when expiry_rule is fixed_date. Null for other expiry rule types.' ;
    rdfs:domain ind:DrmEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expiryRule rdf:type rdf:Property ;
    rdfs:label 'Expiry Rule' ;
    rdfs:comment 'Defines how entitlement expiration is calculated. Perpetual = never expires, Fixed-date = expires on specific date, Duration-days = expires N days after grant, Subscription-cycle = expires with subscription period.' ;
    rdfs:domain ind:DrmEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyShareEnabled rdf:type rdf:Property ;
    rdfs:label 'Family Share Enabled' ;
    rdfs:comment 'Indicates whether this entitlement can be shared with family group members as defined by the platform\'s family sharing feature. True = shareable, False = not shareable.' ;
    rdfs:domain ind:DrmEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grantChannel rdf:type rdf:Property ;
    rdfs:label 'Grant Channel' ;
    rdfs:comment 'The channel or method through which this entitlement was granted. Storefront-purchase = direct store purchase, Key-redemption = activation code, Promotional-grant = marketing campaign, Subscription-benefit = included in subscription, Bundle-inclusion = part of bundle purchase, Platform-plus = platform subscription service (PS Plus, Game Pass).' ;
    rdfs:domain ind:Platform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantExpiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Grant Expiry Timestamp' ;
    rdfs:comment 'The calculated date and time when this specific entitlement grant expires. Computed based on grant_timestamp and expiry_rule configuration. Null for perpetual entitlements.' ;
    rdfs:domain ind:DrmEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:grantSourceTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Grant Source Transaction Reference' ;
    rdfs:comment 'Reference identifier to the originating transaction that triggered this entitlement grant. May reference IAP transaction, subscription activation, promotional campaign, or key redemption event.' ;
    rdfs:domain ind:DrmEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantTimestamp rdf:type rdf:Property ;
    rdfs:label 'Grant Timestamp' ;
    rdfs:comment 'The exact date and time when this entitlement was granted to the player. Null for rule-level records, populated for grant-level records.' ;
    rdfs:domain ind:Platform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastVerificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Verification Timestamp' ;
    rdfs:comment 'The date and time when this entitlement was last verified with the platform DRM service. Used to enforce verification_required_interval_hours policy.' ;
    rdfs:domain ind:DrmEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:licenseScope rdf:type rdf:Property ;
    rdfs:label 'License Scope' ;
    rdfs:comment 'Defines the scope of device/account binding for this entitlement. Single-device = locked to one device, Multi-device = usable across multiple devices, Family-share = shareable within family group, Account-bound = tied to player account regardless of device.' ;
    rdfs:domain ind:DrmEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offlinePlayAllowed rdf:type rdf:Property ;
    rdfs:label 'Offline Play Allowed' ;
    rdfs:comment 'Indicates whether this entitlement permits offline gameplay without active internet connection. True = offline play enabled, False = requires online verification.' ;
    rdfs:domain ind:DrmEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regionLockEnabled rdf:type rdf:Property ;
    rdfs:label 'Region Lock Enabled' ;
    rdfs:comment 'Indicates whether geographic region restrictions apply to this entitlement. True = region-locked, False = globally accessible.' ;
    rdfs:domain ind:DrmEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revocationGracePeriodHours rdf:type rdf:Property ;
    rdfs:label 'Revocation Grace Period Hours' ;
    rdfs:comment 'Number of hours of continued access after revocation is triggered. Applicable only when revocation_policy is grace_period. Null for other policies.' ;
    rdfs:domain ind:DrmEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revocationPolicy rdf:type rdf:Property ;
    rdfs:label 'Revocation Policy' ;
    rdfs:comment 'Defines the policy for revoking this entitlement. Immediate = access removed instantly, Grace-period = access continues for defined period, Non-revocable = cannot be revoked once granted.' ;
    rdfs:domain ind:Platform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationStatus rdf:type rdf:Property ;
    rdfs:label 'Revocation Status' ;
    rdfs:comment 'Current status of this entitlement grant. Active = valid and usable, Revoked = access removed by admin/system, Suspended = temporarily disabled, Expired = past expiry timestamp.' ;
    rdfs:domain ind:DrmEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferAllowed rdf:type rdf:Property ;
    rdfs:label 'Transfer Allowed' ;
    rdfs:comment 'Indicates whether this entitlement can be transferred to another player account. True = transferable, False = non-transferable. Most digital entitlements are non-transferable per platform policies.' ;
    rdfs:domain ind:DrmEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verificationRequiredIntervalHours rdf:type rdf:Property ;
    rdfs:label 'Verification Required Interval Hours' ;
    rdfs:comment 'Number of hours between required online entitlement verification checks. Applicable for entitlements that allow offline play but require periodic online check-ins. Null for always-online or fully-offline entitlements.' ;
    rdfs:domain ind:DrmEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:entitlementGrantId rdf:type rdf:Property ;
    rdfs:label 'Entitlement Grant Id' ;
    rdfs:comment 'Unique identifier for the entitlement grant record. Primary key for this transactional record of DRM (Digital Rights Management) entitlement provisioning.' ;
    rdfs:domain ind:EntitlementGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bundleId rdf:type rdf:Property ;
    rdfs:label 'Bundle Id' ;
    rdfs:comment 'Reference to the product bundle if this entitlement was granted as part of a bundle purchase. Null for individual item grants.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DlcBundle .

ind:parentEntitlementEntitlementGrantId rdf:type rdf:Property ;
    rdfs:label 'Parent Entitlement Entitlement Grant Id' ;
    rdfs:comment 'Reference to a parent entitlement grant if this is a child or dependent entitlement (e.g., DLC requiring base game, season pass content unlock). Null for standalone entitlements.' ;
    rdfs:domain ind:EntitlementGrant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EntitlementGrant .

ind:currentActivations rdf:type rdf:Property ;
    rdfs:label 'Current Activations' ;
    rdfs:comment 'The current number of active device or account activations for this entitlement. Used to enforce max_activations limits and track concurrent usage.' ;
    rdfs:domain ind:EntitlementGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviceBindingEnabled rdf:type rdf:Property ;
    rdfs:label 'Device Binding Enabled' ;
    rdfs:comment 'Indicates whether this entitlement is bound to a specific device (true) or can be used across multiple devices (false). Enforces DRM device restrictions per platform TRC/TCR requirements.' ;
    rdfs:domain ind:EntitlementGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmToken rdf:type rdf:Property ;
    rdfs:label 'Drm Token' ;
    rdfs:comment 'The encrypted DRM token or license key used by the platform SDK to validate entitlement at runtime. Confidential credential for content protection.' ;
    rdfs:domain ind:EntitlementGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementDescription rdf:type rdf:Property ;
    rdfs:label 'Entitlement Description' ;
    rdfs:comment 'Detailed description of what the entitlement grants access to, including content items, features, or benefits. Used for player communication and support documentation.' ;
    rdfs:domain ind:EntitlementGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementName rdf:type rdf:Property ;
    rdfs:label 'Entitlement Name' ;
    rdfs:comment 'Human-readable name or title of the entitlement (e.g., \'Deluxe Edition\', \'Season 1 Pass\', \'Premium Currency Pack\'). Used for player-facing displays and support interactions.' ;
    rdfs:domain ind:EntitlementGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantNotes rdf:type rdf:Property ;
    rdfs:label 'Grant Notes' ;
    rdfs:comment 'Free-text notes or comments about the entitlement grant, typically used by customer support for manual grants or special circumstances. Used for audit documentation.' ;
    rdfs:domain ind:EntitlementGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Grant Source System' ;
    rdfs:comment 'The system or platform SDK that originated the entitlement grant (Steamworks API, Epic Online Services, PlayStation Network API, Xbox Live Services, Apple StoreKit, Google Play Billing). Used for audit trail and cross-platform reconciliation.' ;
    rdfs:domain ind:EntitlementGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantStatus rdf:type rdf:Property ;
    rdfs:label 'Grant Status' ;
    rdfs:comment 'Current lifecycle status of the entitlement grant: active (valid and usable), revoked (administratively withdrawn), expired (past validity period), pending (awaiting activation), suspended (temporarily disabled).' ;
    rdfs:domain ind:EntitlementGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxActivations rdf:type rdf:Property ;
    rdfs:label 'Max Activations' ;
    rdfs:comment 'The maximum number of devices or accounts that can activate this entitlement concurrently. Null indicates unlimited activations. Enforces platform TRC/TCR device limits.' ;
    rdfs:domain ind:Platform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Source Transaction Reference' ;
    rdfs:comment 'External reference identifier to the originating transaction (IAP receipt ID, promotional campaign ID, subscription order ID, support ticket ID) that triggered this entitlement grant.' ;
    rdfs:domain ind:EntitlementGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approved By User Employee Id' ;
    rdfs:comment 'Reference to the user who approved this patch for release. Governance and accountability.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:baseBuildSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Base Build Submission Id' ;
    rdfs:comment 'Foreign key linking to platform.build_submission. Business justification: A patch release is applied on top of a base build submission. Using label prefix \'base_\' to distinguish this from the patch\'s own build. The minimum_base_version_required string becomes redundant. N:1' ;
    rdfs:domain ind:PatchRelease ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BuildSubmission .

ind:patchAssetBundleId rdf:type rdf:Property ;
    rdfs:label 'Patch Asset Bundle Id' ;
    rdfs:comment 'Foreign key linking to content.asset_bundle. Business justification: Platform patches deploy specific asset bundles containing updated content. Live ops teams track which bundle is included in each platform patch for version control and player support.' ;
    rdfs:domain ind:PatchRelease ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetBundle .

ind:ageRatingImpact rdf:type rdf:Property ;
    rdfs:label 'Age Rating Impact' ;
    rdfs:comment 'Indicates whether this patch affects the games age rating: none (no impact), content_descriptor_added (new content descriptors required), rating_change_required (full re-rating needed). Compliance with ESRB, PEGI, CERO, USK, GRAC.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnDistributionUrl rdf:type rdf:Property ;
    rdfs:label 'Cdn Distribution Url' ;
    rdfs:comment 'Content Delivery Network URL for patch distribution. Confidential infrastructure endpoint.' ;
    rdfs:domain ind:PatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumSha256 rdf:type rdf:Property ;
    rdfs:label 'Checksum Sha256' ;
    rdfs:comment 'SHA-256 hash of the patch file for enhanced integrity verification and security validation.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containsMonetizationChanges rdf:type rdf:Property ;
    rdfs:label 'Contains Monetization Changes' ;
    rdfs:comment 'Indicates whether this patch includes changes to in-game monetization, microtransactions (MTX), or in-app purchases (IAP). May require additional platform review.' ;
    rdfs:domain ind:PatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:downloadPriority rdf:type rdf:Property ;
    rdfs:label 'Download Priority' ;
    rdfs:comment 'Priority level for patch download and installation: critical (immediate mandatory), high (recommended urgent), normal (standard update), low (optional enhancement).' ;
    rdfs:domain ind:PatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedInstallTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Install Time Minutes' ;
    rdfs:comment 'Estimated time in minutes for patch installation and verification. Helps set player expectations.' ;
    rdfs:domain ind:PatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:knownIssuesUrl rdf:type rdf:Property ;
    rdfs:label 'Known Issues Url' ;
    rdfs:comment 'URL to documentation of known issues in this patch. Transparency for player support.' ;
    rdfs:domain ind:PatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localizationLanguagesAdded rdf:type rdf:Property ;
    rdfs:label 'Localization Languages Added' ;
    rdfs:comment 'Comma-separated list of new language codes added in this patch (ISO 639-1 format). Expands market reach.' ;
    rdfs:domain ind:PatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patchNotesSummary rdf:type rdf:Property ;
    rdfs:label 'Patch Notes Summary' ;
    rdfs:comment 'High-level summary of changes included in this patch. Player-facing description of bug fixes, features, and improvements.' ;
    rdfs:domain ind:PatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patchSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Patch Size Bytes' ;
    rdfs:comment 'Total download size of the patch in bytes. Critical for player experience and bandwidth planning.' ;
    rdfs:domain ind:PatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:patchVersion rdf:type rdf:Property ;
    rdfs:label 'Patch Version' ;
    rdfs:comment 'Semantic version number of the patch (e.g., 1.2.3 or 1.2.3.4). Follows semantic versioning convention.' ;
    rdfs:domain ind:PatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privacyPolicyUpdated rdf:type rdf:Property ;
    rdfs:label 'Privacy Policy Updated' ;
    rdfs:comment 'Indicates whether this patch includes updates to the games privacy policy or data collection practices. Triggers consent requirements under GDPR and COPPA.' ;
    rdfs:domain ind:PatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releaseNotesUrl rdf:type rdf:Property ;
    rdfs:label 'Release Notes Url' ;
    rdfs:comment 'URL to the full detailed release notes for this patch. Player-facing documentation.' ;
    rdfs:domain ind:PatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rollbackAvailable rdf:type rdf:Property ;
    rdfs:label 'Rollback Available' ;
    rdfs:comment 'Indicates whether players can rollback to the previous version if issues occur. Platform-dependent capability.' ;
    rdfs:domain ind:PatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rolloutPercentage rdf:type rdf:Property ;
    rdfs:label 'Rollout Percentage' ;
    rdfs:comment 'Percentage of player base receiving the patch in staged rollout (0.00 to 100.00). Used for gradual deployment to monitor stability.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rolloutStrategy rdf:type rdf:Property ;
    rdfs:label 'Rollout Strategy' ;
    rdfs:comment 'Deployment strategy for the patch: full (immediate global release), staged (gradual percentage rollout), regional (specific geographic markets first), beta (limited test audience).' ;
    rdfs:domain ind:PatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trcChecklistVersion rdf:type rdf:Property ;
    rdfs:label 'Trc Checklist Version' ;
    rdfs:comment 'Version of the Technical Requirements Checklist used for certification. Platform-specific compliance document version.' ;
    rdfs:domain ind:Platform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heroImageAssetId rdf:type rdf:Property ;
    rdfs:label 'Hero Image Asset Id' ;
    rdfs:comment 'Foreign key linking to content.asset. Business justification: Storefront SKU listings require hero image assets for merchandising. Marketing teams manage asset references for each platform SKU\'s store presence. Real-world process: SKU listing creation workflow.' ;
    rdfs:domain ind:PlatformSku ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:asoKeywords rdf:type rdf:Property ;
    rdfs:label 'Aso Keywords' ;
    rdfs:comment 'Comma-separated list of search keywords and phrases optimized for storefront search algorithms and organic discoverability. Used for ASO strategy on mobile and PC storefronts.' ;
    rdfs:domain ind:Platform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Certification Approval Date' ;
    rdfs:comment 'Date when the platform approved the SKU after successful TRC/TCR certification, clearing it for release.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Certification Submission Date' ;
    rdfs:comment 'Date when the SKU build was submitted to the platform for TRC/TCR certification and compliance review.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drmEntitlementType rdf:type rdf:Property ;
    rdfs:label 'Drm Entitlement Type' ;
    rdfs:comment 'Type of DRM or entitlement system used to manage ownership and access rights (e.g., Steam DRM, Epic Games Services, PlayStation Network, Xbox Live, Nintendo Account, Apple ID, Google Play, DRM-Free, Proprietary). [ENUM-REF-CANDIDATE: steam|epic|psn|xbox_live|nintendo_account|apple_id|google_play|drm_free|proprietary — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PlatformSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:editionType rdf:type rdf:Property ;
    rdfs:label 'Edition Type' ;
    rdfs:comment 'The edition or tier of the game product (e.g., Standard, Deluxe, Gold, Ultimate, Collector\'s Edition, Game of the Year Edition, Complete Edition). [ENUM-REF-CANDIDATE: standard|deluxe|gold|ultimate|collectors|goty|complete|starter|premium — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureBullets rdf:type rdf:Property ;
    rdfs:label 'Feature Bullets' ;
    rdfs:comment 'Pipe-separated list of key feature bullet points highlighting gameplay mechanics, content offerings, and unique selling propositions (e.g., \'Single Player Campaign|Multiplayer Co-op|Cross-Platform Play|4K Graphics|Ray Tracing Support\').' ;
    rdfs:domain ind:Platform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genreTags rdf:type rdf:Property ;
    rdfs:label 'Genre Tags' ;
    rdfs:comment 'Comma-separated list of genre and gameplay tags for discoverability and filtering (e.g., FPS, Open World, Multiplayer, Co-op, PvP, PvE, Battle Royale, MOBA, MMO, Roguelike, Metroidvania).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hardwareGeneration rdf:type rdf:Property ;
    rdfs:label 'Hardware Generation' ;
    rdfs:comment 'Supported hardware generation or platform version (e.g., PlayStation 5, Xbox Series X|S, Nintendo Switch, PC, iOS 15+, Android 12+). Indicates minimum or target hardware compatibility.' ;
    rdfs:domain ind:PlatformSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEarlyAccess rdf:type rdf:Property ;
    rdfs:label 'Is Early Access' ;
    rdfs:comment 'Boolean flag indicating whether this SKU is released in early access or beta state, allowing players to purchase and play an unfinished version during development.' ;
    rdfs:domain ind:PlatformSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPreorderAvailable rdf:type rdf:Property ;
    rdfs:label 'Is Preorder Available' ;
    rdfs:comment 'Boolean flag indicating whether this SKU is available for pre-order purchase before the official release date. True if pre-orders are enabled, False otherwise.' ;
    rdfs:domain ind:PlatformSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localizationLanguage rdf:type rdf:Property ;
    rdfs:label 'Localization Language' ;
    rdfs:comment 'Primary language code (ISO 639-1) for this storefront listing\'s metadata and promotional content (e.g., en, es, fr, de, ja, ko, zh). Separate SKUs may exist for different language markets.' ;
    rdfs:domain ind:PlatformSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformProductIdentifier rdf:type rdf:Property ;
    rdfs:label 'Platform Product Identifier' ;
    rdfs:comment 'Platform-specific unique product identifier assigned by the storefront or console manufacturer (e.g., Steam AppID, PlayStation Content ID, Apple Bundle ID, Google Play Package Name, Epic Games Store Catalog Item ID).' ;
    rdfs:domain ind:PlatformSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingTier rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier' ;
    rdfs:comment 'Pricing tier or price point category assigned by the platform (e.g., $9.99, $19.99, $29.99, $39.99, $49.99, $59.99, $69.99, Free-to-Play). Used for storefront pricing strategy and regional pricing matrix.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionalAvailability rdf:type rdf:Property ;
    rdfs:label 'Regional Availability' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where this SKU is available for purchase and download (e.g., USA,CAN,GBR,DEU,FRA,JPN). Used for geo-restriction and regional distribution management.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenshotAssetUrls rdf:type rdf:Property ;
    rdfs:label 'Screenshot Asset Urls' ;
    rdfs:comment 'Comma-separated list of URLs or asset references pointing to promotional screenshots displayed on the storefront listing. Typically 5-10 high-resolution images showcasing gameplay and features.' ;
    rdfs:domain ind:PlatformSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storefrontCategory rdf:type rdf:Property ;
    rdfs:label 'Storefront Category' ;
    rdfs:comment 'Primary storefront category or section where this SKU is listed (e.g., Action, Adventure, RPG, Strategy, Sports, Simulation, Puzzle, Casual). Platform-specific taxonomy.' ;
    rdfs:domain ind:PlatformSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportsAchievements rdf:type rdf:Property ;
    rdfs:label 'Supports Achievements' ;
    rdfs:comment 'Boolean flag indicating whether this SKU implements platform achievements, trophies, or gamerscore functionality.' ;
    rdfs:domain ind:Platform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsCloudSaves rdf:type rdf:Property ;
    rdfs:label 'Supports Cloud Saves' ;
    rdfs:comment 'Boolean flag indicating whether this SKU supports cloud-based save game synchronization across devices through the platform\'s cloud storage service.' ;
    rdfs:domain ind:Platform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsCrossplay rdf:type rdf:Property ;
    rdfs:label 'Supports Crossplay' ;
    rdfs:comment 'Boolean flag indicating whether this SKU supports cross-platform multiplayer gameplay with players on other platforms. True if crossplay is enabled, False otherwise.' ;
    rdfs:domain ind:PlatformSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsLeaderboards rdf:type rdf:Property ;
    rdfs:label 'Supports Leaderboards' ;
    rdfs:comment 'Boolean flag indicating whether this SKU implements platform leaderboards for competitive score tracking and ranking.' ;
    rdfs:domain ind:PlatformSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trailerAssetUrls rdf:type rdf:Property ;
    rdfs:label 'Trailer Asset Urls' ;
    rdfs:comment 'Comma-separated list of URLs or asset references pointing to promotional video trailers displayed on the storefront listing. Includes launch trailers, gameplay trailers, and feature spotlights.' ;
    rdfs:domain ind:PlatformSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userReviewScore rdf:type rdf:Property ;
    rdfs:label 'User Review Score' ;
    rdfs:comment 'Aggregate user review score or rating displayed on the storefront (typically 0.00 to 5.00 or 0.00 to 10.00 scale depending on platform). Calculated from player reviews and ratings.' ;
    rdfs:domain ind:PlatformSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:basePrice rdf:type rdf:Property ;
    rdfs:label 'Base Price' ;
    rdfs:comment 'Standard retail price for the game title in the specified currency before any promotional discounts or adjustments.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bundleEligible rdf:type rdf:Property ;
    rdfs:label 'Bundle Eligible' ;
    rdfs:comment 'Indicates whether this pricing configuration can be included in promotional bundles or multi-game packages.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentType rdf:type rdf:Property ;
    rdfs:label 'Content Type' ;
    rdfs:comment 'Type of game content being priced. Base Game = full game, DLC (Downloadable Content) = add-on content, Season Pass = bundle of future DLC, Expansion = major content addition, Cosmetic = visual items, Currency = in-game virtual currency, Subscription = recurring access. [ENUM-REF-CANDIDATE: base_game|dlc|season_pass|expansion|cosmetic|currency|subscription — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossPlatformPricingGroup rdf:type rdf:Property ;
    rdfs:label 'Cross Platform Pricing Group' ;
    rdfs:comment 'Identifier for grouping pricing records that should maintain parity across multiple platforms (e.g., same price on Steam and Epic Games Store). Used for cross-platform pricing strategy enforcement.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumAdvertisedPrice rdf:type rdf:Property ;
    rdfs:label 'Minimum Advertised Price' ;
    rdfs:comment 'Minimum Advertised Price - the lowest price at which the game title can be advertised or promoted, as stipulated by publisher agreements or platform policies. Null if no MAP restriction applies.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformRevenueSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Platform Revenue Share Percentage' ;
    rdfs:comment 'Percentage of gross revenue retained by the platform holder (e.g., 30.00 for Steam\'s standard 30% cut, 12.00 for Epic Games Store\'s 12% cut). Used for net revenue calculation.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousBasePrice rdf:type rdf:Property ;
    rdfs:label 'Previous Base Price' ;
    rdfs:comment 'The base price that was in effect immediately before the current pricing configuration. Used for price history tracking and change analysis.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceChangeDate rdf:type rdf:Property ;
    rdfs:label 'Price Change Date' ;
    rdfs:comment 'Date when the most recent price change occurred. Null if this is the original pricing.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceChangeReason rdf:type rdf:Property ;
    rdfs:label 'Price Change Reason' ;
    rdfs:comment 'Business justification or reason code for the price change (e.g., seasonal promotion, competitive adjustment, currency fluctuation, content update, end-of-life discount).' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceLockEnabled rdf:type rdf:Property ;
    rdfs:label 'Price Lock Enabled' ;
    rdfs:comment 'Indicates whether the pricing is locked and cannot be changed without special authorization. Used for contractual price guarantees or regulatory compliance.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceLockReason rdf:type rdf:Property ;
    rdfs:label 'Price Lock Reason' ;
    rdfs:comment 'Explanation for why the pricing is locked (e.g., contractual obligation, pre-order guarantee, regulatory requirement). Null if price_lock_enabled is false.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingStatus rdf:type rdf:Property ;
    rdfs:label 'Pricing Status' ;
    rdfs:comment 'Current lifecycle status of the pricing configuration. Draft = being configured, Pending Approval = submitted for review, Approved = ready for activation, Active = currently in effect, Suspended = temporarily disabled, Archived = historical record.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Promotional Discount Percentage' ;
    rdfs:comment 'Percentage discount applied during the promotional period (e.g., 25.00 for 25% off). Null if no active promotion.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalEndDate rdf:type rdf:Property ;
    rdfs:label 'Promotional End Date' ;
    rdfs:comment 'Date when the promotional pricing expires and base price resumes. Null if no active promotion or open-ended promotion.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionalPrice rdf:type rdf:Property ;
    rdfs:label 'Promotional Price' ;
    rdfs:comment 'Discounted price during a promotional period. Null if no active promotion.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalStartDate rdf:type rdf:Property ;
    rdfs:label 'Promotional Start Date' ;
    rdfs:comment 'Date when the promotional pricing becomes effective. Null if no active promotion.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recommendedRetailPrice rdf:type rdf:Property ;
    rdfs:label 'Recommended Retail Price' ;
    rdfs:comment 'Recommended Retail Price - the suggested retail price set by the publisher. May differ from actual base price due to regional adjustments or retailer discretion.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regionalPricingStrategy rdf:type rdf:Property ;
    rdfs:label 'Regional Pricing Strategy' ;
    rdfs:comment 'Pricing strategy applied for this region. Standard = base conversion, Purchasing Power Parity = adjusted for local economic conditions, Competitive = matched to local market, Premium = higher tier positioning, Budget = value positioning.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxHandlingMethod rdf:type rdf:Property ;
    rdfs:label 'Tax Handling Method' ;
    rdfs:comment 'Indicates whether the displayed price includes tax (inclusive), excludes tax to be added at checkout (exclusive), or is tax-exempt.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Release Date' ;
    rdfs:comment 'Actual date when the game title was released and became available to players on this platform and storefront. Null until release occurs.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dayOnePatchRequired rdf:type rdf:Property ;
    rdfs:label 'Day One Patch Required' ;
    rdfs:comment 'Indicates whether a mandatory day-one patch is required for the release. True if a patch must be downloaded on launch day to enable full functionality.' ;
    rdfs:domain ind:ReleaseSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:delayReason rdf:type rdf:Property ;
    rdfs:label 'Delay Reason' ;
    rdfs:comment 'Explanation for any delay or rescheduling of the release. Captures business rationale such as quality issues, certification failures, market conditions, or strategic decisions.' ;
    rdfs:domain ind:ReleaseSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dlcAvailable rdf:type rdf:Property ;
    rdfs:label 'Dlc Available' ;
    rdfs:comment 'Indicates whether downloadable content is available at launch for this release. True if DLC, expansions, or season pass content is offered.' ;
    rdfs:domain ind:ReleaseSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:embargoLiftTimestamp rdf:type rdf:Property ;
    rdfs:label 'Embargo Lift Timestamp' ;
    rdfs:comment 'Date and time when media embargo restrictions are lifted and press/influencers can publish reviews and coverage. Critical for coordinating marketing and PR activities.' ;
    rdfs:domain ind:ReleaseSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:excludedRegions rdf:type rdf:Property ;
    rdfs:label 'Excluded Regions' ;
    rdfs:comment 'Geographic regions or markets explicitly excluded from this release due to regulatory, licensing, or business reasons. Comma-separated list of ISO 3166-1 alpha-3 country codes.' ;
    rdfs:domain ind:ReleaseSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:launchEdition rdf:type rdf:Property ;
    rdfs:label 'Launch Edition' ;
    rdfs:comment 'Edition or SKU variant for this release (e.g., Standard Edition, Deluxe Edition, Ultimate Edition, Collectors Edition). Defines content bundle and pricing tier.' ;
    rdfs:domain ind:ReleaseSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingGoliveDate rdf:type rdf:Property ;
    rdfs:label 'Marketing Golive Date' ;
    rdfs:comment 'Date when marketing campaigns and promotional activities are activated for this release. Coordinates advertising, social media, and promotional efforts.' ;
    rdfs:domain ind:ReleaseSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mtxEnabled rdf:type rdf:Property ;
    rdfs:label 'Mtx Enabled' ;
    rdfs:comment 'Indicates whether in-game microtransactions are enabled for this release. True if players can make in-app purchases for virtual goods, currency, or content.' ;
    rdfs:domain ind:ReleaseSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:physicalRelease rdf:type rdf:Property ;
    rdfs:label 'Physical Release' ;
    rdfs:comment 'Indicates whether a physical disc or cartridge version is available for this release. True if physical media is manufactured and distributed.' ;
    rdfs:domain ind:ReleaseSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Planned Release Date' ;
    rdfs:comment 'Originally planned date for the game title release on this platform and storefront. Used for initial launch planning and coordination.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:platformApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Platform Approval Status' ;
    rdfs:comment 'Current status of the platform holder certification and approval process. Tracks TRC/TCR compliance review and approval workflow. [ENUM-REF-CANDIDATE: not_submitted|submitted|under_review|approved|rejected|conditional_approval|resubmission_required — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReleaseSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preorderDiscountPercent rdf:type rdf:Property ;
    rdfs:label 'Preorder Discount Percent' ;
    rdfs:comment 'Percentage discount offered for pre-order purchases. Null if no pre-order discount is available.' ;
    rdfs:domain ind:ReleaseSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preorderStartDate rdf:type rdf:Property ;
    rdfs:label 'Preorder Start Date' ;
    rdfs:comment 'Date when pre-order sales begin on this platform and storefront. Enables early revenue capture and demand forecasting.' ;
    rdfs:domain ind:ReleaseSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceCurrency rdf:type rdf:Property ;
    rdfs:label 'Price Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the release price (e.g., USD, EUR, GBP, JPY).' ;
    rdfs:domain ind:ReleaseSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseCoordinatorName rdf:type rdf:Property ;
    rdfs:label 'Release Coordinator Name' ;
    rdfs:comment 'Name of the individual or team responsible for coordinating this release. Primary point of contact for release planning and execution.' ;
    rdfs:domain ind:ReleaseSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseIdentifier rdf:type rdf:Property ;
    rdfs:label 'Release Identifier' ;
    rdfs:comment 'Business identifier for this release event. May be a combination of game title code, platform code, and release wave identifier used for tracking and coordination.' ;
    rdfs:domain ind:ReleaseSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releasePrice rdf:type rdf:Property ;
    rdfs:label 'Release Price' ;
    rdfs:comment 'Standard retail price for the game at release on this platform and storefront. Expressed in the storefronts default currency.' ;
    rdfs:domain ind:ReleaseSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releaseRegionScope rdf:type rdf:Property ;
    rdfs:label 'Release Region Scope' ;
    rdfs:comment 'Geographic regions or markets included in this release. Comma-separated list of ISO 3166-1 alpha-3 country codes or region identifiers (e.g., USA,CAN,MEX or EMEA or APAC). Defines market availability.' ;
    rdfs:domain ind:ReleaseSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Release Timestamp' ;
    rdfs:comment 'Precise timestamp when the game title went live on the storefront. Captures exact moment of availability for time-zone-specific launches and coordinated global releases.' ;
    rdfs:domain ind:ReleaseSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Release Date' ;
    rdfs:comment 'Current scheduled date for the release after any adjustments or delays. This is the active target date for launch coordination.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:achievementsEnabled rdf:type rdf:Property ;
    rdfs:label 'Achievements Enabled' ;
    rdfs:comment 'Indicates whether the achievements feature is enabled in this SDK integration. True if achievements/trophies are implemented.' ;
    rdfs:domain ind:SdkIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:analyticsEnabled rdf:type rdf:Property ;
    rdfs:label 'Analytics Enabled' ;
    rdfs:comment 'Indicates whether SDK-provided analytics and telemetry collection is enabled. True if player behavior events are sent to platform analytics services.' ;
    rdfs:domain ind:SdkIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Compliance Status' ;
    rdfs:comment 'Current compliance status of this SDK integration against platform Technical Requirements Checklist (TRC) or Technical Certification Requirements (TCR). Compliant indicates all requirements met; non-compliant indicates failures; pending-review indicates submission under evaluation; conditionally-approved indicates approval with minor fixes required; not-submitted indicates not yet submitted for certification.' ;
    rdfs:domain ind:SdkIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cloudSavesEnabled rdf:type rdf:Property ;
    rdfs:label 'Cloud Saves Enabled' ;
    rdfs:comment 'Indicates whether cloud save synchronization is enabled in this SDK integration. True if player progress is backed up to platform cloud storage.' ;
    rdfs:domain ind:SdkIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossPlayEnabled rdf:type rdf:Property ;
    rdfs:label 'Cross Play Enabled' ;
    rdfs:comment 'Indicates whether cross-platform multiplayer (cross-play) is enabled in this SDK integration. True if players on different platforms can play together.' ;
    rdfs:domain ind:SdkIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deprecationNoticeDate rdf:type rdf:Property ;
    rdfs:label 'Deprecation Notice Date' ;
    rdfs:comment 'Date when the platform announced deprecation of this SDK version. Null if SDK is not deprecated.' ;
    rdfs:domain ind:SdkIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iapEnabled rdf:type rdf:Property ;
    rdfs:label 'Iap Enabled' ;
    rdfs:comment 'Indicates whether In-App Purchase (IAP) or microtransaction (MTX) functionality is enabled in this SDK integration. True if platform commerce APIs are integrated.' ;
    rdfs:domain ind:SdkIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:integrationDate rdf:type rdf:Property ;
    rdfs:label 'Integration Date' ;
    rdfs:comment 'Date when the SDK was first integrated into the game build.' ;
    rdfs:domain ind:SdkIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:integrationNotes rdf:type rdf:Property ;
    rdfs:label 'Integration Notes' ;
    rdfs:comment 'Free-text notes documenting integration-specific details, known issues, workarounds, or special configuration requirements for this SDK integration.' ;
    rdfs:domain ind:SdkIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationStatus rdf:type rdf:Property ;
    rdfs:label 'Integration Status' ;
    rdfs:comment 'Current lifecycle status of the SDK integration. Active indicates production-ready; deprecated indicates scheduled for replacement; pending-update indicates newer version available; in-development indicates integration in progress; failed indicates integration issues; sunset indicates SDK no longer supported.' ;
    rdfs:domain ind:SdkIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastValidationDate rdf:type rdf:Property ;
    rdfs:label 'Last Validation Date' ;
    rdfs:comment 'Date when this SDK integration was last validated for compliance and functionality. Used for tracking re-certification cycles.' ;
    rdfs:domain ind:SdkIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaderboardsEnabled rdf:type rdf:Property ;
    rdfs:label 'Leaderboards Enabled' ;
    rdfs:comment 'Indicates whether the leaderboards feature is enabled in this SDK integration. True if competitive leaderboards are implemented.' ;
    rdfs:domain ind:SdkIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchmakingEnabled rdf:type rdf:Property ;
    rdfs:label 'Matchmaking Enabled' ;
    rdfs:comment 'Indicates whether platform matchmaking services are enabled in this SDK integration. True if SDK-provided matchmaking is used.' ;
    rdfs:domain ind:SdkIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:migrationTargetSdkVersion rdf:type rdf:Property ;
    rdfs:label 'Migration Target Sdk Version' ;
    rdfs:comment 'Target SDK version to which this integration should be migrated when deprecated. Defines the deprecation migration path. Null if no migration required.' ;
    rdfs:domain ind:SdkIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumFirmwareVersion rdf:type rdf:Property ;
    rdfs:label 'Minimum Firmware Version' ;
    rdfs:comment 'Minimum console firmware version required for this SDK integration (applicable to console platforms). Used for certification submission validation.' ;
    rdfs:domain ind:SdkIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdkName rdf:type rdf:Property ;
    rdfs:label 'Sdk Name' ;
    rdfs:comment 'Name of the platform SDK integrated into the game build (e.g., Steamworks, PlayStation SDK, Xbox GDK, Nintendo SDK, Apple GameKit, Google Play Games Services). [ENUM-REF-CANDIDATE: Steamworks|PlayStation SDK|Xbox GDK|Nintendo SDK|Apple GameKit|Google Play Games Services|Epic Online Services|Unity Gaming Services|GameAnalytics SDK|AppsFlyer SDK — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SdkIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdkUpdateDeadline rdf:type rdf:Property ;
    rdfs:label 'Sdk Update Deadline' ;
    rdfs:comment 'Deadline date by which this SDK must be updated to a newer version to maintain platform compliance. Critical for avoiding deprecation and ensuring continued certification eligibility.' ;
    rdfs:domain ind:SdkIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:voiceChatEnabled rdf:type rdf:Property ;
    rdfs:label 'Voice Chat Enabled' ;
    rdfs:comment 'Indicates whether voice chat functionality is enabled in this SDK integration. True if in-game voice communication is supported.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ageRatingSystem rdf:type rdf:Property ;
    rdfs:label 'Age Rating System' ;
    rdfs:comment 'Primary age rating classification system required for games on this storefront: ESRB (North America), PEGI (Europe), USK (Germany), CERO (Japan), GRAC (South Korea), or IARC (International Age Rating Coalition for digital storefronts).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analyticsIntegration rdf:type rdf:Property ;
    rdfs:label 'Analytics Integration' ;
    rdfs:comment 'Native analytics and reporting platform provided by this storefront for tracking sales, player engagement, and performance metrics (e.g., Steamworks Analytics, App Store Analytics, Google Play Console).' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiEndpoint rdf:type rdf:Property ;
    rdfs:label 'Api Endpoint' ;
    rdfs:comment 'Base URL of the storefront\'s API for programmatic integration, build uploads, metadata management, and analytics retrieval.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationRequired rdf:type rdf:Property ;
    rdfs:label 'Certification Required' ;
    rdfs:comment 'Indicates whether game builds must pass formal platform certification (TRC/TCR compliance) before release. True for console storefronts, typically false for open PC storefronts.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentPolicyUrl rdf:type rdf:Property ;
    rdfs:label 'Content Policy Url' ;
    rdfs:comment 'Web URL of the storefront\'s content policy and submission guidelines that define acceptable game content, prohibited material, and editorial standards.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developerPortalUrl rdf:type rdf:Property ;
    rdfs:label 'Developer Portal Url' ;
    rdfs:comment 'Web URL of the developer portal or partner center for this storefront where game submissions, builds, and metadata are managed (e.g., Steamworks, Epic Dev Portal, App Store Connect, Google Play Console).' ;
    rdfs:domain ind:Platform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumBuildSizeGb rdf:type rdf:Property ;
    rdfs:label 'Maximum Build Size Gb' ;
    rdfs:comment 'Maximum game build package size in gigabytes accepted by this storefront. Null if no hard limit enforced.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumBuildSizeMb rdf:type rdf:Property ;
    rdfs:label 'Minimum Build Size Mb' ;
    rdfs:comment 'Minimum game build package size in megabytes accepted by this storefront. Null if no minimum enforced.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:platformHolderType rdf:type rdf:Property ;
    rdfs:label 'Platform Holder Type' ;
    rdfs:comment 'Classification of the platform holder operating this storefront: console OEM (Sony, Microsoft, Nintendo), PC storefront (Valve, Epic), mobile app store (Apple, Google), or cloud gaming platform.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundPolicyDays rdf:type rdf:Property ;
    rdfs:label 'Refund Policy Days' ;
    rdfs:comment 'Number of days within which players can request refunds for game purchases on this storefront (e.g., 14 for Steam, 14 for Epic). Null if no standard refund window.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storefrontName rdf:type rdf:Property ;
    rdfs:label 'Storefront Name' ;
    rdfs:comment 'Official business name of the digital distribution storefront (e.g., PlayStation Store, Xbox Marketplace, Steam, Epic Games Store, Apple App Store, Google Play).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storefrontStatus rdf:type rdf:Property ;
    rdfs:label 'Storefront Status' ;
    rdfs:comment 'Current operational status of the storefront: active (accepting submissions and sales), deprecated (legacy support only), sunset (end-of-life), beta (limited access), or coming soon (announced but not launched).' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedPaymentMethods rdf:type rdf:Property ;
    rdfs:label 'Supported Payment Methods' ;
    rdfs:comment 'Payment instruments accepted by this storefront (e.g., credit card, debit card, PayPal, platform wallet, gift card, carrier billing). Comma-separated list.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportsCrossPlatform rdf:type rdf:Property ;
    rdfs:label 'Supports Cross Platform' ;
    rdfs:comment 'Indicates whether this storefront supports cross-platform multiplayer, cross-save, or cross-buy features with other platforms.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsDlc rdf:type rdf:Property ;
    rdfs:label 'Supports Dlc' ;
    rdfs:comment 'Indicates whether this storefront supports distribution of downloadable content, expansions, and add-ons for base games.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsEarlyAccess rdf:type rdf:Property ;
    rdfs:label 'Supports Early Access' ;
    rdfs:comment 'Indicates whether this storefront supports early access or soft launch programs where games can be released in incomplete or beta state with player access.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsIap rdf:type rdf:Property ;
    rdfs:label 'Supports Iap' ;
    rdfs:comment 'Indicates whether this storefront supports in-app purchases and microtransactions within games. True for most mobile and modern console/PC storefronts.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsSubscriptions rdf:type rdf:Property ;
    rdfs:label 'Supports Subscriptions' ;
    rdfs:comment 'Indicates whether this storefront supports recurring subscription billing for games or services (e.g., Xbox Game Pass, PlayStation Plus, Apple Arcade).' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsUgc rdf:type rdf:Property ;
    rdfs:label 'Supports Ugc' ;
    rdfs:comment 'Indicates whether this storefront provides infrastructure for user-generated content distribution (e.g., Steam Workshop, console mod support).' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Tax Calculation Method' ;
    rdfs:comment 'Method by which sales tax or VAT is calculated and displayed: inclusive (tax included in displayed price), exclusive (tax added at checkout), or varies by region.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trcTcrVersion rdf:type rdf:Property ;
    rdfs:label 'Trc Tcr Version' ;
    rdfs:comment 'Version identifier of the platform\'s technical requirements checklist that games must comply with for certification (e.g., PlayStation TRC v5.2, Xbox TCR 2023-Q2). Null if certification not required.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iconAssetId rdf:type rdf:Property ;
    rdfs:label 'Icon Asset Id' ;
    rdfs:comment 'Foreign key linking to content.asset. Business justification: Storefront listings require icon assets for display. Marketing teams manage specific asset references for each listing. Replaces denormalized icon_asset_reference with proper FK for asset management w' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:aggregateReviewScore rdf:type rdf:Property ;
    rdfs:label 'Aggregate Review Score' ;
    rdfs:comment 'Average user review rating for this listing, typically on a scale of 0.00 to 5.00. Calculated by the storefront platform from user-submitted reviews.' ;
    rdfs:domain ind:StorefrontListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossPlatformPlay rdf:type rdf:Property ;
    rdfs:label 'Cross Platform Play' ;
    rdfs:comment 'Indicates whether the game supports cross-platform multiplayer (e.g., PlayStation players can play with Xbox players).' ;
    rdfs:domain ind:StorefrontListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:heroImageAssetReference rdf:type rdf:Property ;
    rdfs:label 'Hero Image Asset Reference' ;
    rdfs:comment 'Asset ID or URL referencing the large hero banner image displayed at the top of the listing page.' ;
    rdfs:domain ind:StorefrontListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inAppPurchases rdf:type rdf:Property ;
    rdfs:label 'In App Purchases' ;
    rdfs:comment 'Indicates whether the game offers in-app purchases or microtransactions (MTX). Required disclosure for mobile storefronts.' ;
    rdfs:domain ind:StorefrontListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Last Updated Date' ;
    rdfs:comment 'The date when the game or listing content was last updated on the storefront (e.g., patch release, content update, metadata refresh).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiplayerSupport rdf:type rdf:Property ;
    rdfs:label 'Multiplayer Support' ;
    rdfs:comment 'Indicates whether the game supports multiplayer gameplay (online or local).' ;
    rdfs:domain ind:StorefrontListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:screenshotAssetReferences rdf:type rdf:Property ;
    rdfs:label 'Screenshot Asset References' ;
    rdfs:comment 'Comma-separated list of asset IDs or URLs referencing the screenshot images displayed on the listing page. Order determines display sequence.' ;
    rdfs:domain ind:StorefrontListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termsOfServiceUrl rdf:type rdf:Property ;
    rdfs:label 'Terms Of Service Url' ;
    rdfs:comment 'URL to the games terms of service or end-user license agreement (EULA).' ;
    rdfs:domain ind:StorefrontListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trailerAssetReferences rdf:type rdf:Property ;
    rdfs:label 'Trailer Asset References' ;
    rdfs:comment 'Comma-separated list of asset IDs or URLs referencing the video trailers displayed on the listing page. Order determines display sequence.' ;
    rdfs:domain ind:StorefrontListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionResultId rdf:type rdf:Property ;
    rdfs:label 'Submission Result Id' ;
    rdfs:comment 'Unique identifier for the certification submission result record. Primary key.' ;
    rdfs:domain ind:SubmissionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appealDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Deadline Date' ;
    rdfs:comment 'Date by which the studio must submit a formal appeal if they wish to contest the certification result. Null if appeal is not eligible.' ;
    rdfs:domain ind:SubmissionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Appeal Eligible Flag' ;
    rdfs:comment 'Indicates whether the studio is eligible to appeal the certification result through the platform holders formal appeal process.' ;
    rdfs:domain ind:SubmissionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentPolicyFailureCount rdf:type rdf:Property ;
    rdfs:label 'Content Policy Failure Count' ;
    rdfs:comment 'Number of failures related to content rating compliance, inappropriate content, or platform content policy violations.' ;
    rdfs:domain ind:SubmissionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:criticalFailureCount rdf:type rdf:Property ;
    rdfs:label 'Critical Failure Count' ;
    rdfs:comment 'Number of critical severity failures that must be resolved before resubmission. Critical failures block certification approval.' ;
    rdfs:domain ind:SubmissionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:detailedFailureReportUrl rdf:type rdf:Property ;
    rdfs:label 'Detailed Failure Report Url' ;
    rdfs:comment 'URL or file path to the comprehensive failure report document provided by the platform holder, containing screenshots, logs, and reproduction steps.' ;
    rdfs:domain ind:SubmissionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executiveSummary rdf:type rdf:Property ;
    rdfs:label 'Executive Summary' ;
    rdfs:comment 'High-level summary of the certification result intended for studio leadership and project stakeholders.' ;
    rdfs:domain ind:SubmissionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastTrackResubmissionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Fast Track Resubmission Eligible Flag' ;
    rdfs:comment 'Indicates whether the submission qualifies for expedited fast-track resubmission review, typically for minor fixes only.' ;
    rdfs:domain ind:SubmissionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:functionalFailureCount rdf:type rdf:Property ;
    rdfs:label 'Functional Failure Count' ;
    rdfs:comment 'Number of failures related to game functionality, gameplay mechanics, or feature implementation.' ;
    rdfs:domain ind:SubmissionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:goldMasterApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Gold Master Approved Flag' ;
    rdfs:comment 'Indicates whether this result represents final gold master approval, authorizing the build for commercial distribution.' ;
    rdfs:domain ind:SubmissionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localizationFailureCount rdf:type rdf:Property ;
    rdfs:label 'Localization Failure Count' ;
    rdfs:comment 'Number of failures related to language translation, regional content adaptation, or cultural compliance.' ;
    rdfs:domain ind:SubmissionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:majorFailureCount rdf:type rdf:Property ;
    rdfs:label 'Major Failure Count' ;
    rdfs:comment 'Number of major severity failures identified. Major failures significantly impact user experience or platform compliance.' ;
    rdfs:domain ind:SubmissionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorFailureCount rdf:type rdf:Property ;
    rdfs:label 'Minor Failure Count' ;
    rdfs:comment 'Number of minor severity failures identified. Minor failures have limited impact and may be eligible for waivers.' ;
    rdfs:domain ind:SubmissionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:networkFailureCount rdf:type rdf:Property ;
    rdfs:label 'Network Failure Count' ;
    rdfs:comment 'Number of failures related to online connectivity, multiplayer functionality, or network error handling.' ;
    rdfs:domain ind:SubmissionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceFailureCount rdf:type rdf:Property ;
    rdfs:label 'Performance Failure Count' ;
    rdfs:comment 'Number of failures related to performance metrics such as frame rate (FPS), load times, or memory usage.' ;
    rdfs:domain ind:SubmissionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:platformHolderReviewerEmail rdf:type rdf:Property ;
    rdfs:label 'Platform Holder Reviewer Email' ;
    rdfs:comment 'Email address of the platform holder reviewer for follow-up communication regarding the certification result.' ;
    rdfs:domain ind:SubmissionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformHolderReviewerName rdf:type rdf:Property ;
    rdfs:label 'Platform Holder Reviewer Name' ;
    rdfs:comment 'Name of the platform holder certification reviewer who conducted the evaluation and issued the result.' ;
    rdfs:domain ind:SubmissionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Resubmission Deadline Date' ;
    rdfs:comment 'Date by which the studio must resubmit a corrected build if the result was fail or conditional pass. Null if result was pass.' ;
    rdfs:domain ind:SubmissionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resultNotificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Result Notification Sent Timestamp' ;
    rdfs:comment 'Timestamp when the platform holder sent the formal result notification to the studio via email or platform portal.' ;
    rdfs:domain ind:SubmissionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resultSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Result Sequence Number' ;
    rdfs:comment 'Sequential ordering of result records for a given submission across resubmission cycles. First submission is 1, first resubmission is 2, etc.' ;
    rdfs:domain ind:SubmissionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resultStatus rdf:type rdf:Property ;
    rdfs:label 'Result Status' ;
    rdfs:comment 'Current lifecycle status of the result record. Active indicates the current result, superseded indicates a newer result exists, appealed indicates under appeal review, archived indicates historical record.' ;
    rdfs:domain ind:SubmissionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultType rdf:type rdf:Property ;
    rdfs:label 'Result Type' ;
    rdfs:comment 'Outcome classification of the certification review. Pass indicates full approval, fail requires resubmission, conditional pass requires minor fixes, waiver granted allows exceptions, withdrawn indicates studio cancellation, cancelled indicates platform holder cancellation.' ;
    rdfs:domain ind:SubmissionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDurationHours rdf:type rdf:Property ;
    rdfs:label 'Review Duration Hours' ;
    rdfs:comment 'Total number of hours the platform holder spent conducting the certification review for this submission.' ;
    rdfs:domain ind:SubmissionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:studioAcknowledgedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Studio Acknowledged Timestamp' ;
    rdfs:comment 'Timestamp when the studio acknowledged receipt and review of the certification result.' ;
    rdfs:domain ind:SubmissionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:testEnvironmentConfiguration rdf:type rdf:Property ;
    rdfs:label 'Test Environment Configuration' ;
    rdfs:comment 'Description of the hardware, firmware, and software configuration used by the platform holder during certification testing.' ;
    rdfs:domain ind:SubmissionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFailureCount rdf:type rdf:Property ;
    rdfs:label 'Total Failure Count' ;
    rdfs:comment 'Total number of Technical Requirements Checklist (TRC) or Technical Certification Requirements (TCR) failures identified in this review cycle.' ;
    rdfs:domain ind:SubmissionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uiUxFailureCount rdf:type rdf:Property ;
    rdfs:label 'Ui Ux Failure Count' ;
    rdfs:comment 'Number of failures related to user interface design, navigation, accessibility, or user experience standards.' ;
    rdfs:domain ind:SubmissionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waiverGrantedCount rdf:type rdf:Property ;
    rdfs:label 'Waiver Granted Count' ;
    rdfs:comment 'Number of failures for which the platform holder granted waivers, allowing the submission to proceed despite non-compliance.' ;
    rdfs:domain ind:SubmissionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authenticationLogId rdf:type rdf:Property ;
    rdfs:label 'Authentication Log Id' ;
    rdfs:comment 'Unique identifier for the authentication event record. Primary key for the authentication log.' ;
    rdfs:domain ind:AuthenticationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountAgeDays rdf:type rdf:Property ;
    rdfs:label 'Account Age Days' ;
    rdfs:comment 'Age of the player account in days at the time of authentication. Used for fraud detection and player lifecycle analysis.' ;
    rdfs:domain ind:AuthenticationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageGatePassedFlag rdf:type rdf:Property ;
    rdfs:label 'Age Gate Passed Flag' ;
    rdfs:comment 'Indicates whether the player passed age verification requirements during authentication. Used for age-restricted content compliance.' ;
    rdfs:domain ind:AuthenticationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authenticationMethod rdf:type rdf:Property ;
    rdfs:label 'Authentication Method' ;
    rdfs:comment 'Method used to authenticate the player. Includes password-based, single sign-on, platform-specific tokens, biometric authentication, and third-party OAuth providers. [ENUM-REF-CANDIDATE: password|sso|platform_token|biometric|oauth|steam|epic|psn|xbox_live — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Player ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprRegionFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Region Flag' ;
    rdfs:comment 'Indicates whether the authentication originated from a GDPR-regulated region. Triggers additional data protection and consent workflows.' ;
    rdfs:domain ind:AuthenticationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loginAttemptCount rdf:type rdf:Property ;
    rdfs:label 'Login Attempt Count' ;
    rdfs:comment 'Number of consecutive failed login attempts before this event. Used for account lockout policies and brute force attack detection.' ;
    rdfs:domain ind:AuthenticationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loginDurationMs rdf:type rdf:Property ;
    rdfs:label 'Login Duration Ms' ;
    rdfs:comment 'Time taken to complete the authentication process in milliseconds. Used for performance monitoring and user experience optimization.' ;
    rdfs:domain ind:AuthenticationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mfaMethod rdf:type rdf:Property ;
    rdfs:label 'Mfa Method' ;
    rdfs:comment 'Multi-factor authentication method used if MFA was required for this authentication event. None if MFA was not triggered.' ;
    rdfs:domain ind:AuthenticationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mfaSuccessFlag rdf:type rdf:Property ;
    rdfs:label 'Mfa Success Flag' ;
    rdfs:comment 'Indicates whether multi-factor authentication was successfully completed. Null if MFA was not required.' ;
    rdfs:domain ind:AuthenticationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:previousLoginTimestamp rdf:type rdf:Property ;
    rdfs:label 'Previous Login Timestamp' ;
    rdfs:comment 'Timestamp of the players previous successful login. Used to calculate session gaps and detect unusual login patterns.' ;
    rdfs:domain ind:AuthenticationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:suspiciousActivityFlag rdf:type rdf:Property ;
    rdfs:label 'Suspicious Activity Flag' ;
    rdfs:comment 'Indicates whether the authentication event was flagged as potentially suspicious by fraud detection algorithms. Triggers security review workflows.' ;
    rdfs:domain ind:Player ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:banRecordId rdf:type rdf:Property ;
    rdfs:label 'Ban Record Id' ;
    rdfs:comment 'Unique identifier for the ban record. Primary key.' ;
    rdfs:domain ind:BanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appealResolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Appeal Resolution Notes' ;
    rdfs:comment 'Internal notes documenting the appeal review decision, evidence considered, and rationale for approval or denial.' ;
    rdfs:domain ind:BanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealReviewedBy rdf:type rdf:Property ;
    rdfs:label 'Appeal Reviewed By' ;
    rdfs:comment 'Identifier of the trust & safety agent who reviewed the appeal. Employee ID or agent identifier.' ;
    rdfs:domain ind:BanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealReviewedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Appeal Reviewed Timestamp' ;
    rdfs:comment 'Date and time when the appeal review was completed. Null if appeal has not been reviewed.' ;
    rdfs:domain ind:BanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:appealSubmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Appeal Submitted Flag' ;
    rdfs:comment 'Indicates whether the player has submitted an appeal for this ban. True if appeal exists, False otherwise.' ;
    rdfs:domain ind:BanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:automatedDetectionConfidence rdf:type rdf:Property ;
    rdfs:label 'Automated Detection Confidence' ;
    rdfs:comment 'Confidence score (0.00 to 100.00) from automated detection systems (anti-cheat, fraud detection) indicating certainty of the violation. Null for manual reviews.' ;
    rdfs:domain ind:BanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:banDurationDays rdf:type rdf:Property ;
    rdfs:label 'Ban Duration Days' ;
    rdfs:comment 'Duration of the ban in days. Null for permanent bans. Used for temporary suspensions and competitive cooldowns.' ;
    rdfs:domain ind:BanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:banReasonCategory rdf:type rdf:Property ;
    rdfs:label 'Ban Reason Category' ;
    rdfs:comment 'High-level category of the violation that triggered the ban: cheating/exploiting (use of unauthorized software, game exploits), harassment/toxicity (abusive behavior, hate speech), TOS violation (terms of service breach), payment fraud (chargeback fraud, stolen payment methods), COPPA violation (underage account without parental consent), account sharing (credential sharing, account trading).' ;
    rdfs:domain ind:BanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:banReasonDetail rdf:type rdf:Property ;
    rdfs:label 'Ban Reason Detail' ;
    rdfs:comment 'Detailed explanation of the specific violation or behavior that led to the enforcement action. May include evidence references, incident IDs, or rule citations.' ;
    rdfs:domain ind:BanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:banStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ban Start Timestamp' ;
    rdfs:comment 'Date and time when the ban was issued and enforcement began. Represents the principal business event timestamp for this enforcement action.' ;
    rdfs:domain ind:BanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Compliance Jurisdiction' ;
    rdfs:comment 'Regulatory jurisdiction governing this ban action (USA, EU, UK, JPN, KOR, CHN, AUS, CAN, BRA, GLOBAL). Determines applicable privacy laws (GDPR, COPPA, CCPA) and data retention policies. [ENUM-REF-CANDIDATE: USA|EU|UK|JPN|KOR|CHN|AUS|CAN|BRA|GLOBAL — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hardwareIdentifier rdf:type rdf:Property ;
    rdfs:label 'Hardware Identifier' ;
    rdfs:comment 'Device hardware identifier (HWID, MAC address, console serial) used for hardware-level bans. Enables enforcement across account changes on the same device.' ;
    rdfs:domain ind:BanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingSystem rdf:type rdf:Property ;
    rdfs:label 'Issuing System' ;
    rdfs:comment 'System or process that issued the ban: automated_anticheat (anti-cheat engine detection), manual_trust_safety (human moderator review), platform_enforcement (first-party platform action), community_report_system (player report threshold trigger), payment_fraud_detection (payment system fraud alert).' ;
    rdfs:domain ind:BanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Indicates whether the player was notified of the ban via email, in-game message, or platform notification. True if notification sent, False otherwise.' ;
    rdfs:domain ind:BanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:repeatOffenderFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Offender Flag' ;
    rdfs:comment 'Indicates whether this player has prior ban records. True if this is not the first ban, False if first offense. Used for escalation policies.' ;
    rdfs:domain ind:BanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentSnapshotId rdf:type rdf:Property ;
    rdfs:label 'Consent Snapshot Id' ;
    rdfs:comment 'Unique identifier for the consent snapshot record. Primary key.' ;
    rdfs:domain ind:ConsentSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consentDeviceId rdf:type rdf:Property ;
    rdfs:label 'Consent Device Id' ;
    rdfs:comment 'Device identifier (IDFA, GAID, console ID) from which consent was granted. Used for cross-platform consent tracking and device-level consent management.' ;
    rdfs:domain ind:ConsentSnapshot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Device .

ind:ageVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Age Verification Method' ;
    rdfs:comment 'The method used to verify the players age. Includes government ID check, credit card verification, third-party age verification service, self-declaration, parental verification, or not_verified if no verification performed.' ;
    rdfs:domain ind:ConsentSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ageVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Age Verification Status' ;
    rdfs:comment 'Status of age verification for age-gated content and COPPA/GDPR compliance. Verified indicates successful age check, pending indicates in-progress verification, failed indicates unsuccessful verification, not_required indicates no age gate applies, self_declared indicates player-provided age without verification.' ;
    rdfs:domain ind:ConsentSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analyticsTrackingAllowed rdf:type rdf:Property ;
    rdfs:label 'Analytics Tracking Allowed' ;
    rdfs:comment 'Indicates whether the player has consented to behavioral analytics tracking and telemetry collection. Used for GameAnalytics, Amplitude, and similar player behavior tracking platforms.' ;
    rdfs:domain ind:ConsentSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collectionMethod rdf:type rdf:Property ;
    rdfs:label 'Collection Method' ;
    rdfs:comment 'The channel or interface through which consent was collected. Includes in-game prompts, web portals, mobile apps, parental consent portals, customer support interactions, email, SMS, console SDK flows, and platform OAuth consent screens. [ENUM-REF-CANDIDATE: in_game_prompt|web_portal|mobile_app|parental_portal|customer_support|email|sms|console_sdk|platform_oauth — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsentSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionPlatform rdf:type rdf:Property ;
    rdfs:label 'Collection Platform' ;
    rdfs:comment 'The gaming platform on which consent was collected. Tracks platform-specific consent requirements and first-party platform certification compliance. [ENUM-REF-CANDIDATE: pc|console_playstation|console_xbox|console_nintendo|mobile_ios|mobile_android|web|vr|cloud_gaming — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsentSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentAuditTrail rdf:type rdf:Property ;
    rdfs:label 'Consent Audit Trail' ;
    rdfs:comment 'JSON or structured text containing the full audit trail of consent changes, including timestamps, user actions, system events, and regulatory compliance checkpoints. Provides complete consent lifecycle history.' ;
    rdfs:domain ind:ConsentSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentExpiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Expiry Timestamp' ;
    rdfs:comment 'Date and time when time-bound consent expires. Null for indefinite consent. Used for age-gated content re-verification and periodic consent refresh requirements.' ;
    rdfs:domain ind:ConsentSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consentGrantedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Granted Timestamp' ;
    rdfs:comment 'Date and time when the player granted consent. Critical for GDPR Article 7 proof-of-consent requirements and COPPA parental consent audit trails.' ;
    rdfs:domain ind:Player ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consentIpAddress rdf:type rdf:Property ;
    rdfs:label 'Consent Ip Address' ;
    rdfs:comment 'IP address from which consent was granted. Used for audit trail, fraud detection, and jurisdiction determination. May be considered PII in some jurisdictions.' ;
    rdfs:domain ind:ConsentSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentUserAgent rdf:type rdf:Property ;
    rdfs:label 'Consent User Agent' ;
    rdfs:comment 'Browser or application user agent string captured at the time of consent. Provides technical context for consent collection audit trail.' ;
    rdfs:domain ind:ConsentSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentWithdrawnTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Withdrawn Timestamp' ;
    rdfs:comment 'Date and time when the player withdrew consent. Null if consent has not been withdrawn. Required for GDPR right to withdraw consent tracking.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cookieConsentGranted rdf:type rdf:Property ;
    rdfs:label 'Cookie Consent Granted' ;
    rdfs:comment 'Indicates whether the player has consented to non-essential cookies and tracking technologies on web and mobile platforms. Required for GDPR and ePrivacy Directive compliance.' ;
    rdfs:domain ind:ConsentSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataPortabilityRequested rdf:type rdf:Property ;
    rdfs:label 'Data Portability Requested' ;
    rdfs:comment 'Indicates whether the player has requested a copy of their data under GDPR Article 20 right to data portability. True triggers data export workflows.' ;
    rdfs:domain ind:ConsentSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:erasureRequestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Erasure Request Timestamp' ;
    rdfs:comment 'Date and time when the player requested data erasure. Null if no erasure request has been made. Used to track compliance with GDPR 30-day response requirement.' ;
    rdfs:domain ind:ConsentSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:marketingOptIn rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In' ;
    rdfs:comment 'Indicates whether the player has opted in to receive marketing communications (email, SMS, push notifications). True indicates opt-in, false indicates opt-out.' ;
    rdfs:domain ind:ConsentSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentEmail rdf:type rdf:Property ;
    rdfs:label 'Parent Email' ;
    rdfs:comment 'Email address of the parent or legal guardian who provided consent for an underage player. Null for players not requiring parental consent.' ;
    rdfs:domain ind:ConsentSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentalVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Parental Verification Method' ;
    rdfs:comment 'The method used to verify parental consent for underage players. Includes FTC-approved COPPA verification methods: credit card verification, government ID check, video conference, signed consent form, toll-free call, email plus credit card. Not_applicable for players not requiring parental consent. [ENUM-REF-CANDIDATE: credit_card|government_id|video_conference|signed_form|toll_free_call|email_plus_credit_card|not_applicable — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsentSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portabilityRequestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Portability Request Timestamp' ;
    rdfs:comment 'Date and time when the player requested data portability. Null if no portability request has been made. Used to track compliance with GDPR 30-day response requirement.' ;
    rdfs:domain ind:ConsentSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rightToErasureRequested rdf:type rdf:Property ;
    rdfs:label 'Right To Erasure Requested' ;
    rdfs:comment 'Indicates whether the player has requested deletion of their data under GDPR Article 17 right to erasure or COPPA parental deletion rights. True triggers data deletion workflows.' ;
    rdfs:domain ind:ConsentSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformAccountId rdf:type rdf:Property ;
    rdfs:label 'Platform Account Id' ;
    rdfs:comment 'First-party platform account identifier (e.g., PlayStation Network ID, Xbox Live Gamertag, Steam ID) associated with this device.' ;
    rdfs:domain ind:Device ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerAccount .

ind:advertisingIdentifier rdf:type rdf:Property ;
    rdfs:label 'Advertising Identifier' ;
    rdfs:comment 'Platform-specific advertising identifier (IDFA for iOS, GAID for Android). Used for attribution tracking and ad targeting. May be reset by user.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:banExpiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ban Expiry Timestamp' ;
    rdfs:comment 'Timestamp when a temporary device ban expires. Null for permanent bans or unbanned devices. Used for automated ban lift processing.' ;
    rdfs:domain ind:Device ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:banReason rdf:type rdf:Property ;
    rdfs:label 'Ban Reason' ;
    rdfs:comment 'Reason for device ban if device_status is banned. Null if device is not banned. Used for policy enforcement tracking and appeals processing.' ;
    rdfs:domain ind:Device ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:banTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ban Timestamp' ;
    rdfs:comment 'Timestamp when the device was banned. Null if device is not banned. Used for ban duration tracking and policy enforcement auditing.' ;
    rdfs:domain ind:Device ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Mobile network carrier name for mobile devices. Used for carrier billing integration and network performance analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpuArchitecture rdf:type rdf:Property ;
    rdfs:label 'Cpu Architecture' ;
    rdfs:comment 'Processor architecture of the device (e.g., x86_64, ARM64). Used for build compatibility and performance optimization.' ;
    rdfs:domain ind:Device ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceStatus rdf:type rdf:Property ;
    rdfs:label 'Device Status' ;
    rdfs:comment 'Current lifecycle status of the device in the platform. Banned status enforces hardware bans for policy violations.' ;
    rdfs:domain ind:Device ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fingerprintHash rdf:type rdf:Property ;
    rdfs:label 'Fingerprint Hash' ;
    rdfs:comment 'Cryptographic hash of the device fingerprint used for fraud detection and device identification. Enables detection of multiple accounts per device and device spoofing.' ;
    rdfs:domain ind:Device ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstSeenTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Seen Timestamp' ;
    rdfs:comment 'Timestamp when this device was first registered or detected in the platform. Used for device age analysis and fraud detection.' ;
    rdfs:domain ind:Device ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ipAddressLastKnown rdf:type rdf:Property ;
    rdfs:label 'Ip Address Last Known' ;
    rdfs:comment 'Most recent IP address observed from this device. Used for geolocation, fraud detection, and regional content delivery.' ;
    rdfs:domain ind:Device ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEmulator rdf:type rdf:Property ;
    rdfs:label 'Is Emulator' ;
    rdfs:comment 'Indicates whether the device is detected as an emulator or virtual device. True if emulator, False otherwise. Used for fraud detection and policy enforcement.' ;
    rdfs:domain ind:Device ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryDevice rdf:type rdf:Property ;
    rdfs:label 'Is Primary Device' ;
    rdfs:comment 'Indicates whether this is the player\'s primary device for game access and notifications. True if primary, False otherwise.' ;
    rdfs:domain ind:Device ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRootedOrJailbroken rdf:type rdf:Property ;
    rdfs:label 'Is Rooted Or Jailbroken' ;
    rdfs:comment 'Indicates whether the device has been rooted (Android) or jailbroken (iOS). True if modified, False otherwise. Used for security risk assessment and anti-cheat enforcement.' ;
    rdfs:domain ind:Device ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastSeenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Seen Timestamp' ;
    rdfs:comment 'Timestamp of the most recent activity from this device. Used for device activity tracking and dormancy detection.' ;
    rdfs:domain ind:Device ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:macAddress rdf:type rdf:Property ;
    rdfs:label 'Mac Address' ;
    rdfs:comment 'Network hardware address of the device. Used for device identification and network-level fraud detection.' ;
    rdfs:domain ind:Device ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:make rdf:type rdf:Property ;
    rdfs:label 'Make' ;
    rdfs:comment 'Manufacturer or brand of the device (e.g., Sony, Microsoft, Apple, Samsung, Valve).' ;
    rdfs:domain ind:Device ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:model rdf:type rdf:Property ;
    rdfs:label 'Model' ;
    rdfs:comment 'Specific model identifier of the device (e.g., PlayStation 5, Xbox Series X, iPhone 14 Pro, Galaxy S23).' ;
    rdfs:domain ind:Device ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pushNotificationToken rdf:type rdf:Property ;
    rdfs:label 'Push Notification Token' ;
    rdfs:comment 'Platform-specific token used for routing push notifications to this device. Required for live operations and player engagement campaigns.' ;
    rdfs:domain ind:Device ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenResolution rdf:type rdf:Property ;
    rdfs:label 'Screen Resolution' ;
    rdfs:comment 'Display resolution of the device (e.g., 1920x1080, 3840x2160). Used for graphics quality settings and asset delivery optimization.' ;
    rdfs:domain ind:Device ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageCapacityGb rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Gb' ;
    rdfs:comment 'Total storage capacity of the device in gigabytes. Used for download size recommendations and storage management features.' ;
    rdfs:domain ind:Device ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timezoneOffset rdf:type rdf:Property ;
    rdfs:label 'Timezone Offset' ;
    rdfs:comment 'Timezone offset from UTC for the device\'s location (e.g., +00:00, -08:00). Used for scheduling live events and time-based content delivery.' ;
    rdfs:domain ind:Device ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalMemoryMb rdf:type rdf:Property ;
    rdfs:label 'Total Memory Mb' ;
    rdfs:comment 'Total system memory (RAM) available on the device in megabytes. Used for performance optimization and minimum spec enforcement.' ;
    rdfs:domain ind:Device ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trustScore rdf:type rdf:Property ;
    rdfs:label 'Trust Score' ;
    rdfs:comment 'Calculated trust score (0.00 to 100.00) indicating the device\'s trustworthiness based on behavior patterns, fraud signals, and usage history. Used for fraud detection and risk assessment.' ;
    rdfs:domain ind:Device ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engagementMetricId rdf:type rdf:Property ;
    rdfs:label 'Engagement Metric Id' ;
    rdfs:comment 'Unique identifier for the engagement metric record. Primary key for this operational engagement snapshot.' ;
    rdfs:domain ind:EngagementMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:achievementUnlockCount rdf:type rdf:Property ;
    rdfs:label 'Achievement Unlock Count' ;
    rdfs:comment 'Number of achievements or trophies the player unlocked during the metric period. Measures progression and goal-oriented engagement.' ;
    rdfs:domain ind:EngagementMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cohortIdentifier rdf:type rdf:Property ;
    rdfs:label 'Cohort Identifier' ;
    rdfs:comment 'Identifier for the player cohort to which this player belongs, typically based on registration date or acquisition campaign. Used for cohort-based retention and LTV analysis.' ;
    rdfs:domain ind:EngagementMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysSinceLastSession rdf:type rdf:Property ;
    rdfs:label 'Days Since Last Session' ;
    rdfs:comment 'Number of calendar days elapsed since the players most recent session prior to this metric date. Used for churn risk assessment and re-engagement targeting.' ;
    rdfs:domain ind:Player ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:engagementScore rdf:type rdf:Property ;
    rdfs:label 'Engagement Score' ;
    rdfs:comment 'Composite engagement score calculated from session frequency, playtime, and retention metrics. Normalized 0-100 scale for player segmentation and lifecycle management.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engagementTier rdf:type rdf:Property ;
    rdfs:label 'Engagement Tier' ;
    rdfs:comment 'Categorical segmentation of player engagement level. Whale = high-value highly engaged; Core = regular engaged; Casual = occasional; Dormant = at-risk; Churned = inactive; New = first-time.' ;
    rdfs:domain ind:Player ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstSessionDate rdf:type rdf:Property ;
    rdfs:label 'First Session Date' ;
    rdfs:comment 'The date of the players very first session across all platforms and titles. Anchors all retention calculations (D1, D7, D30).' ;
    rdfs:domain ind:EngagementMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ftueCompleted rdf:type rdf:Property ;
    rdfs:label 'Ftue Completed' ;
    rdfs:comment 'Boolean flag indicating whether the player has completed the First-Time User Experience tutorial or onboarding flow. Critical for retention analysis.' ;
    rdfs:domain ind:EngagementMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gameTitlesPlayedCount rdf:type rdf:Property ;
    rdfs:label 'Game Titles Played Count' ;
    rdfs:comment 'Number of distinct game titles the player engaged with during the metric period. Measures cross-title engagement for multi-game publishers.' ;
    rdfs:domain ind:EngagementMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inGameEventParticipationCount rdf:type rdf:Property ;
    rdfs:label 'In Game Event Participation Count' ;
    rdfs:comment 'Number of live in-game events (seasonal events, limited-time modes, tournaments) the player participated in during the metric period. Measures live-ops engagement.' ;
    rdfs:domain ind:EngagementMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isD1Retained rdf:type rdf:Property ;
    rdfs:label 'Is D1 Retained' ;
    rdfs:comment 'Boolean flag indicating whether the player returned on the day after their first session (D1 retention). Critical metric for First-Time User Experience (FTUE) effectiveness.' ;
    rdfs:domain ind:EngagementMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isD30Retained rdf:type rdf:Property ;
    rdfs:label 'Is D30 Retained' ;
    rdfs:comment 'Boolean flag indicating whether the player was active 30 days after their first session (D30 retention). Measures long-term player retention and game stickiness.' ;
    rdfs:domain ind:EngagementMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isD7Retained rdf:type rdf:Property ;
    rdfs:label 'Is D7 Retained' ;
    rdfs:comment 'Boolean flag indicating whether the player was active 7 days after their first session (D7 retention). Key indicator of early player lifecycle health.' ;
    rdfs:domain ind:EngagementMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDau rdf:type rdf:Property ;
    rdfs:label 'Is Dau' ;
    rdfs:comment 'Boolean flag indicating whether the player was active on this metric date. True if the player had at least one session during the day.' ;
    rdfs:domain ind:EngagementMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMau rdf:type rdf:Property ;
    rdfs:label 'Is Mau' ;
    rdfs:comment 'Boolean flag indicating whether the player was active during the month containing this metric date. True if the player had at least one session during the 30-day period.' ;
    rdfs:domain ind:EngagementMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWau rdf:type rdf:Property ;
    rdfs:label 'Is Wau' ;
    rdfs:comment 'Boolean flag indicating whether the player was active during the week containing this metric date. True if the player had at least one session during the 7-day period.' ;
    rdfs:domain ind:EngagementMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastSessionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Session Timestamp' ;
    rdfs:comment 'Timestamp of the players most recent session end as of this metric date. Used for real-time churn prediction and re-engagement workflows.' ;
    rdfs:domain ind:EngagementMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loginStreakDays rdf:type rdf:Property ;
    rdfs:label 'Login Streak Days' ;
    rdfs:comment 'Number of consecutive days the player has logged in as of this metric date. Used for streak-based rewards and engagement incentives.' ;
    rdfs:domain ind:EngagementMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:metricDate rdf:type rdf:Property ;
    rdfs:label 'Metric Date' ;
    rdfs:comment 'The calendar date for which this engagement metric snapshot was calculated. Represents the business event date for the engagement measurement period.' ;
    rdfs:domain ind:EngagementMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:metricGrain rdf:type rdf:Property ;
    rdfs:label 'Metric Grain' ;
    rdfs:comment 'The aggregation period for this engagement metric snapshot. Indicates whether this record represents daily, weekly, or monthly engagement data.' ;
    rdfs:domain ind:EngagementMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peakCcuContribution rdf:type rdf:Property ;
    rdfs:label 'Peak Ccu Contribution' ;
    rdfs:comment 'Boolean flag indicating whether the player was online during the peak concurrent user period for this metric date. Used for capacity planning and live-ops scheduling.' ;
    rdfs:domain ind:EngagementMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pveSessionCount rdf:type rdf:Property ;
    rdfs:label 'Pve Session Count' ;
    rdfs:comment 'Number of PvE cooperative or solo gameplay sessions the player completed during the metric period. Measures single-player or co-op engagement.' ;
    rdfs:domain ind:EngagementMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pvpMatchCount rdf:type rdf:Property ;
    rdfs:label 'Pvp Match Count' ;
    rdfs:comment 'Number of PvP competitive matches the player participated in during the metric period. Measures competitive engagement.' ;
    rdfs:domain ind:EngagementMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:socialInteractionCount rdf:type rdf:Property ;
    rdfs:label 'Social Interaction Count' ;
    rdfs:comment 'Number of social interactions (friend invites, guild joins, chat messages, co-op sessions) the player initiated during the metric period. Measures social engagement.' ;
    rdfs:domain ind:EngagementMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPlaytimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Playtime Minutes' ;
    rdfs:comment 'Cumulative playtime in minutes across all sessions during the metric period. Measures total player engagement duration.' ;
    rdfs:domain ind:Player ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ugcContributionCount rdf:type rdf:Property ;
    rdfs:label 'Ugc Contribution Count' ;
    rdfs:comment 'Number of user-generated content items (levels, mods, skins, replays) the player created or published during the metric period. Measures creative engagement.' ;
    rdfs:domain ind:EngagementMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ltvRecordId rdf:type rdf:Property ;
    rdfs:label 'Ltv Record Id' ;
    rdfs:comment 'Unique identifier for the LTV record. Primary key.' ;
    rdfs:domain ind:LtvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:arpuContribution rdf:type rdf:Property ;
    rdfs:label 'Arpu Contribution' ;
    rdfs:comment 'This player\'s contribution to the overall ARPU metric, calculated as total spend divided by days since registration. Used for cohort analysis and player value benchmarking.' ;
    rdfs:domain ind:LtvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationDate rdf:type rdf:Property ;
    rdfs:label 'Calculation Date' ;
    rdfs:comment 'The date on which this LTV calculation was performed. Represents the snapshot date for this LTV record.' ;
    rdfs:domain ind:LtvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cohortMonth rdf:type rdf:Property ;
    rdfs:label 'Cohort Month' ;
    rdfs:comment 'Year-month (YYYY-MM) when the player first registered. Used for cohort-based LTV analysis and retention tracking.' ;
    rdfs:domain ind:LtvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysSinceFirstPurchase rdf:type rdf:Property ;
    rdfs:label 'Days Since First Purchase' ;
    rdfs:comment 'Number of days elapsed between the player\'s first purchase date and the calculation date. Null for non-payers. Used for payer lifecycle analysis.' ;
    rdfs:domain ind:LtvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ltvSegment rdf:type rdf:Property ;
    rdfs:label 'Ltv Segment' ;
    rdfs:comment 'Business segment classification based on LTV predictions and engagement patterns. Used for targeted marketing campaigns and personalized offers.' ;
    rdfs:domain ind:LtvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerTier rdf:type rdf:Property ;
    rdfs:label 'Payer Tier' ;
    rdfs:comment 'Classification of the player into spending tiers based on cumulative spend thresholds. Whale: high-value spender (top 1-5%), Dolphin: moderate spender, Minnow: low-value spender, Non-payer: no purchases.' ;
    rdfs:domain ind:LtvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predictedLtv180d rdf:type rdf:Property ;
    rdfs:label 'Predicted Ltv 180d' ;
    rdfs:comment 'Predicted total revenue from this player over the next 180 days, calculated using the LTV model. Used for medium-term revenue forecasting and marketing ROI analysis.' ;
    rdfs:domain ind:LtvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:predictedLtv365d rdf:type rdf:Property ;
    rdfs:label 'Predicted Ltv 365d' ;
    rdfs:comment 'Predicted total revenue from this player over the next 365 days, calculated using the LTV model. Used for annual revenue forecasting and long-term player value assessment.' ;
    rdfs:domain ind:LtvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:realizedLtv rdf:type rdf:Property ;
    rdfs:label 'Realized Ltv' ;
    rdfs:comment 'Cumulative actual spend by this player from registration to the calculation date. Represents the historical revenue contribution of the player.' ;
    rdfs:domain ind:LtvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalIapCount rdf:type rdf:Property ;
    rdfs:label 'Total Iap Count' ;
    rdfs:comment 'Total number of In-App Purchase transactions made by this player from registration to calculation date. Used for purchase frequency analysis.' ;
    rdfs:domain ind:LtvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentalControlId rdf:type rdf:Property ;
    rdfs:label 'Parental Control Id' ;
    rdfs:comment 'Unique identifier for the parental control configuration record.' ;
    rdfs:domain ind:Player ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ParentalControl .

ind:childPlayerPlayerAccountId rdf:type rdf:Property ;
    rdfs:label 'Child Player Player Account Id' ;
    rdfs:comment 'Reference to the minor player account subject to this parental control configuration.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerAccount .

ind:primaryParentalPlayerAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Parental Player Account Id' ;
    rdfs:comment 'Reference to the parent or guardian player account who owns and manages this parental control configuration.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerAccount .

ind:tertiaryParentalCreatedByPlayerPlayerAccountId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Parental Created By Player Player Account Id' ;
    rdfs:comment 'Reference to the player account (parent or authorized administrator) who initially created this parental control configuration.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerAccount .

ind:autoExpireOnAgeFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Expire On Age Flag' ;
    rdfs:comment 'Indicates whether this parental control configuration should automatically expire when the child player reaches the age of majority in their jurisdiction.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chatEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Chat Enabled Flag' ;
    rdfs:comment 'Indicates whether the child player is allowed to use text chat features in games and platforms.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentRatingRestriction rdf:type rdf:Property ;
    rdfs:label 'Content Rating Restriction' ;
    rdfs:comment 'Maximum content rating level the child player is allowed to access, enforcing age-appropriate content restrictions based on ESRB, PEGI, CERO, or USK rating systems. [ENUM-REF-CANDIDATE: ESRB_E|ESRB_E10|ESRB_T|ESRB_M|ESRB_AO|PEGI_3|PEGI_7|PEGI_12|PEGI_16|PEGI_18|CERO_A|CERO_B|CERO_C|CERO_D|CERO_Z|USK_0|USK_6|USK_12|USK_16|USK_18 — promote to reference product]' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlStatus rdf:type rdf:Property ;
    rdfs:label 'Control Status' ;
    rdfs:comment 'Current lifecycle status of the parental control configuration indicating whether restrictions are actively enforced.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailyPlaytimeLimitMinutes rdf:type rdf:Property ;
    rdfs:label 'Daily Playtime Limit Minutes' ;
    rdfs:comment 'Maximum number of minutes the child player is allowed to play per calendar day.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dailySpendingLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Daily Spending Limit Amount' ;
    rdfs:comment 'Maximum amount the child player can spend on in-app purchases (IAP) and microtransactions (MTX) per calendar day.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataCollectionAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Data Collection Allowed Flag' ;
    rdfs:comment 'Indicates whether the platform is allowed to collect behavioral and analytics data from the child player account beyond what is strictly necessary for service provision.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enforcementMode rdf:type rdf:Property ;
    rdfs:label 'Enforcement Mode' ;
    rdfs:comment 'Mode of enforcement for parental control restrictions: strict (hard block), flexible (warnings with override), or advisory (informational only).' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:friendRequestsAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Friend Requests Allowed Flag' ;
    rdfs:comment 'Indicates whether the child player is allowed to send or receive friend requests and build social connections.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationSharingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Location Sharing Allowed Flag' ;
    rdfs:comment 'Indicates whether the child player is allowed to share their geographic location with other players or services.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingCommunicationsAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Communications Allowed Flag' ;
    rdfs:comment 'Indicates whether the child player is allowed to receive marketing communications, promotional offers, and advertising content.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monthlySpendingLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Monthly Spending Limit Amount' ;
    rdfs:comment 'Maximum amount the child player can spend on in-app purchases (IAP) and microtransactions (MTX) per calendar month.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:multiplayerAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Multiplayer Allowed Flag' ;
    rdfs:comment 'Indicates whether the child player is allowed to participate in multiplayer game modes including PvP (Player versus Player) and PvE (Player versus Environment).' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationEmail rdf:type rdf:Property ;
    rdfs:label 'Notification Email' ;
    rdfs:comment 'Email address where the parent receives notifications about the child player activity, spending, and policy violations.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationFrequency rdf:type rdf:Property ;
    rdfs:label 'Notification Frequency' ;
    rdfs:comment 'Frequency at which the parent receives activity and compliance notifications for the child player account.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overridePinHash rdf:type rdf:Property ;
    rdfs:label 'Override Pin Hash' ;
    rdfs:comment 'Hashed PIN code that allows the parent to temporarily override parental control restrictions for the child player session.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformIdentifier rdf:type rdf:Property ;
    rdfs:label 'Platform Identifier' ;
    rdfs:comment 'Specific platform identifier or SDK source where this parental control configuration originated (e.g., PlayStation Network, Xbox Live, Nintendo Switch Online, Steam, Epic Games Store, Apple App Store, Google Play).' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendingLimitCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Spending Limit Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for spending limits (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ugcAccessAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Ugc Access Allowed Flag' ;
    rdfs:comment 'Indicates whether the child player is allowed to view, create, or share user-generated content (UGC).' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weeklyPlaytimeLimitMinutes rdf:type rdf:Property ;
    rdfs:label 'Weekly Playtime Limit Minutes' ;
    rdfs:comment 'Maximum number of minutes the child player is allowed to play per calendar week.' ;
    rdfs:domain ind:ParentalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crossPlatformPlayEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Platform Play Enabled Flag' ;
    rdfs:comment 'Boolean indicator of whether the player has opted in to cross-platform play (crossplay) using this platform identity. True indicates the player allows matchmaking and interaction with players on other platforms; false indicates platform-exclusive play only.' ;
    rdfs:domain ind:PlatformIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalPlatformUserCode rdf:type rdf:Property ;
    rdfs:label 'External Platform User Code' ;
    rdfs:comment 'The unique user identifier assigned by the external platform (e.g., PSN ID, Xbox Gamertag, Steam ID, Epic Account ID). This is the authoritative identifier used by the platform provider to identify the player on their ecosystem.' ;
    rdfs:domain ind:PlatformIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastActivityTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Activity Timestamp' ;
    rdfs:comment 'The date and time when the player last used this platform identity to authenticate or play. Used for identity staleness detection and account security monitoring.' ;
    rdfs:domain ind:PlatformIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastVerifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Verified Timestamp' ;
    rdfs:comment 'The date and time when the platform identity linkage was most recently verified or re-authenticated. Used to track OAuth token refresh cycles and ensure the link remains valid.' ;
    rdfs:domain ind:PlatformIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:linkDeviceType rdf:type rdf:Property ;
    rdfs:label 'Link Device Type' ;
    rdfs:comment 'The type of device from which the platform identity linkage was performed. Used for device-based analytics and cross-device identity resolution.' ;
    rdfs:domain ind:PlatformIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkIpAddress rdf:type rdf:Property ;
    rdfs:label 'Link Ip Address' ;
    rdfs:comment 'The IP address from which the platform identity linkage request originated. Used for fraud detection, geolocation verification, and security auditing.' ;
    rdfs:domain ind:PlatformIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkMethod rdf:type rdf:Property ;
    rdfs:label 'Link Method' ;
    rdfs:comment 'The technical method or flow used to establish the platform identity linkage. OAuth indicates standard OAuth 2.0 authorization flow; sdk_native indicates platform SDK native sign-in; manual_entry indicates player manually entered credentials; platform_sso indicates single sign-on federation; account_merge indicates linkage created during account merge operation.' ;
    rdfs:domain ind:PlatformIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkSource rdf:type rdf:Property ;
    rdfs:label 'Link Source' ;
    rdfs:comment 'The application or channel through which the platform identity linkage was initiated. Game_client indicates in-game linking; web_portal indicates account management website; mobile_app indicates companion app; customer_support indicates manual linking by support agent; account_migration indicates bulk migration; platform_auto_link indicates automatic linkage by platform SDK.' ;
    rdfs:domain ind:PlatformIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkStatus rdf:type rdf:Property ;
    rdfs:label 'Link Status' ;
    rdfs:comment 'Current lifecycle status of the platform identity linkage. Active indicates the link is valid and operational; inactive indicates the player has disconnected the link; suspended indicates temporary restriction; revoked indicates permanent removal; pending_verification indicates awaiting platform OAuth confirmation; expired indicates the OAuth token or link has lapsed.' ;
    rdfs:domain ind:PlatformIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Linked Timestamp' ;
    rdfs:comment 'The date and time when the platform identity was first successfully linked to the player account. Represents the initial OAuth authorization or SDK linkage event.' ;
    rdfs:domain ind:PlatformIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:oauthAccessTokenHash rdf:type rdf:Property ;
    rdfs:label 'Oauth Access Token Hash' ;
    rdfs:comment 'One-way cryptographic hash of the OAuth 2.0 access token issued by the platform provider. Stored for audit and token rotation tracking; the actual token is stored in a secure vault. Hash enables token lifecycle management without exposing the credential.' ;
    rdfs:domain ind:PlatformIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oauthRefreshTokenHash rdf:type rdf:Property ;
    rdfs:label 'Oauth Refresh Token Hash' ;
    rdfs:comment 'One-way cryptographic hash of the OAuth 2.0 refresh token issued by the platform provider. Stored for audit and token rotation tracking; the actual token is stored in a secure vault.' ;
    rdfs:domain ind:PlatformIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformAccountCreationDate rdf:type rdf:Property ;
    rdfs:label 'Platform Account Creation Date' ;
    rdfs:comment 'The date when the player originally created their account on the external platform (e.g., when they first registered for PSN, Xbox Live, or Steam). Sourced from platform API profile data where available.' ;
    rdfs:domain ind:PlatformIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:platformAccountTier rdf:type rdf:Property ;
    rdfs:label 'Platform Account Tier' ;
    rdfs:comment 'The subscription or membership tier of the players account on the external platform (e.g., PlayStation Plus, Xbox Game Pass Ultimate, Nintendo Switch Online). Indicates premium service level and entitlements on the platform.' ;
    rdfs:domain ind:PlatformIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformAchievementCount rdf:type rdf:Property ;
    rdfs:label 'Platform Achievement Count' ;
    rdfs:comment 'The total number of achievements, trophies, or gamerscore points the player has earned on the external platform. Sourced from platform achievements API. Used for player engagement and skill segmentation.' ;
    rdfs:domain ind:PlatformIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:platformAgeVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Platform Age Verified Flag' ;
    rdfs:comment 'Boolean indicator of whether the players age has been verified by the external platform provider. True indicates the platform has confirmed the player meets age requirements; false indicates unverified. Critical for COPPA and GDPR compliance.' ;
    rdfs:domain ind:PlatformIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformCommunicationConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Platform Communication Consent Flag' ;
    rdfs:comment 'Boolean indicator of whether the player has granted consent for the game publisher to communicate with them via the external platform (e.g., platform notifications, messages). True indicates consent granted; false indicates opt-out.' ;
    rdfs:domain ind:PlatformIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformDataSharingConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Platform Data Sharing Consent Flag' ;
    rdfs:comment 'Boolean indicator of whether the player has granted consent for the game publisher to receive and process their platform profile data (e.g., friends list, achievements, playtime). True indicates consent granted; false indicates opt-out.' ;
    rdfs:domain ind:PlatformIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformDisplayName rdf:type rdf:Property ;
    rdfs:label 'Platform Display Name' ;
    rdfs:comment 'The human-readable display name or gamertag shown on the external platform (e.g., Xbox Gamertag, PSN Online ID, Steam Profile Name). This is the public-facing identity the player uses on that platform.' ;
    rdfs:domain ind:PlatformIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformEmailVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Platform Email Verified Flag' ;
    rdfs:comment 'Boolean indicator of whether the players email address has been verified by the external platform provider. True indicates the platform has confirmed email ownership; false indicates unverified. Used for trust scoring and fraud prevention.' ;
    rdfs:domain ind:PlatformIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformFriendCount rdf:type rdf:Property ;
    rdfs:label 'Platform Friend Count' ;
    rdfs:comment 'The total number of friends or connections the player has on the external platform. Sourced from platform social graph API. Used for social feature enablement and viral coefficient (K-Factor) analysis.' ;
    rdfs:domain ind:PlatformIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:platformLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Platform Language Code' ;
    rdfs:comment 'The two-letter ISO 639-1 language code representing the players preferred language setting on the external platform. Used for localized content delivery and communication.' ;
    rdfs:domain ind:PlatformIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformParentalControlFlag rdf:type rdf:Property ;
    rdfs:label 'Platform Parental Control Flag' ;
    rdfs:comment 'Boolean indicator of whether parental controls are enabled on the players external platform account. True indicates the account is subject to parental restrictions (e.g., content filtering, spending limits, communication restrictions); false indicates no parental controls.' ;
    rdfs:domain ind:PlatformIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformPrivacyLevel rdf:type rdf:Property ;
    rdfs:label 'Platform Privacy Level' ;
    rdfs:comment 'The privacy setting configured by the player on the external platform for their profile and activity visibility. Public allows all users to view; friends_only restricts to approved connections; private hides from all users.' ;
    rdfs:domain ind:PlatformIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformRegionCode rdf:type rdf:Property ;
    rdfs:label 'Platform Region Code' ;
    rdfs:comment 'The three-letter ISO 3166-1 alpha-3 country or region code associated with the players account on the external platform. Determines regional content availability, pricing, and compliance requirements (e.g., GDPR for EU, COPPA for USA).' ;
    rdfs:domain ind:PlatformIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformTotalPlaytimeHours rdf:type rdf:Property ;
    rdfs:label 'Platform Total Playtime Hours' ;
    rdfs:comment 'The cumulative total playtime (in hours) the player has logged on the external platform across all games. Sourced from platform activity API where available. Used for player engagement profiling and LTV (Lifetime Value) modeling.' ;
    rdfs:domain ind:PlatformIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryIdentityFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Identity Flag' ;
    rdfs:comment 'Boolean indicator of whether this platform identity is designated as the players primary or preferred identity for cross-platform features. True indicates this is the primary identity used for display name, friends list, and social features; false indicates a secondary linked identity.' ;
    rdfs:domain ind:PlatformIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tokenExpiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Token Expiry Timestamp' ;
    rdfs:comment 'The date and time when the current OAuth access token will expire and require refresh. Used to trigger proactive token renewal before expiration to maintain seamless cross-platform authentication.' ;
    rdfs:domain ind:PlatformIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:unlinkedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Unlinked Timestamp' ;
    rdfs:comment 'The date and time when the platform identity was disconnected or revoked by the player or system. Null if the link is still active.' ;
    rdfs:domain ind:PlatformIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:testAccountEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Test Account Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Gaming studios require employees (QA, designers, developers) to maintain test accounts for playtesting, bug reproduction, and compliance verification. Tracking which employee owns each test account is' ;
    rdfs:domain ind:PlayerAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accountLevel rdf:type rdf:Property ;
    rdfs:label 'Account Level' ;
    rdfs:comment 'Player\'s overall account progression level, earned through gameplay achievements and experience points. Used for matchmaking, content gating, and progression analytics.' ;
    rdfs:domain ind:PlayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:avatarUrl rdf:type rdf:Property ;
    rdfs:label 'Avatar Url' ;
    rdfs:comment 'URL pointing to the player\'s profile avatar image stored in the CDN (Content Delivery Network). Used for display in social features, leaderboards, and player profiles.' ;
    rdfs:domain ind:Player ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bio rdf:type rdf:Property ;
    rdfs:label 'Bio' ;
    rdfs:comment 'Player-written biography or description displayed on their public profile. Limited to 500 characters. Subject to content moderation policies.' ;
    rdfs:domain ind:Player ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creationSource rdf:type rdf:Property ;
    rdfs:label 'Creation Source' ;
    rdfs:comment 'Marketing attribution source indicating how the player discovered and registered for the game. Used for CPI (Cost Per Install), ROAS (Return on Ad Spend), and marketing campaign effectiveness analysis. [ENUM-REF-CANDIDATE: organic|paid_social|influencer|referral|cross_promotion|app_store|web_direct — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PlayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProcessingConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Data Processing Consent Flag' ;
    rdfs:comment 'Indicates whether the player has provided explicit consent for data processing activities beyond essential service delivery (analytics, personalization, third-party sharing). Required for GDPR compliance.' ;
    rdfs:domain ind:PlayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataProcessingConsentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Data Processing Consent Timestamp' ;
    rdfs:comment 'Date and time when the player provided data processing consent. Required for GDPR audit trails demonstrating lawful basis for processing.' ;
    rdfs:domain ind:PlayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary email address used for account registration, authentication, password recovery, and marketing communications. Must be unique and verified.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Email Verified Flag' ;
    rdfs:comment 'Indicates whether the player has verified their email address through the verification link sent during registration.' ;
    rdfs:domain ind:PlayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:experiencePoints rdf:type rdf:Property ;
    rdfs:label 'Experience Points' ;
    rdfs:comment 'Total experience points (XP) accumulated by the player through gameplay activities. Used to calculate account level progression and unlock rewards.' ;
    rdfs:domain ind:Player ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failedLoginAttempts rdf:type rdf:Property ;
    rdfs:label 'Failed Login Attempts' ;
    rdfs:comment 'Count of consecutive failed login attempts since the last successful login. Used for account lockout policies and fraud detection. Reset to zero upon successful authentication.' ;
    rdfs:domain ind:PlayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gdprRightToErasureRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Right To Erasure Requested Flag' ;
    rdfs:comment 'Indicates whether the player has submitted a GDPR Article 17 Right to Erasure (Right to be Forgotten) request. Triggers data deletion workflows while preserving legally required records.' ;
    rdfs:domain ind:PlayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genderIdentity rdf:type rdf:Property ;
    rdfs:label 'Gender Identity' ;
    rdfs:comment 'Self-reported gender identity of the player. Optional field used for demographic analytics and personalized content recommendations. Collected with explicit consent per GDPR and privacy regulations.' ;
    rdfs:domain ind:PlayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastProfileUpdateTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Profile Update Timestamp' ;
    rdfs:comment 'Date and time when the player last modified their profile information (display name, avatar, bio, or privacy settings). Used for audit trails and profile activity tracking.' ;
    rdfs:domain ind:PlayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:passwordLastChangedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Password Last Changed Timestamp' ;
    rdfs:comment 'Date and time when the player last changed their account password. Used for security audits, password expiration policies, and breach response.' ;
    rdfs:domain ind:PlayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:platformOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Platform Of Origin' ;
    rdfs:comment 'The platform through which the player originally registered their account. Used for platform-specific analytics, cross-platform progression tracking, and attribution analysis. [ENUM-REF-CANDIDATE: steam|psn|xbox_live|nintendo_switch|epic_games|mobile_ios|mobile_android|web — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PlayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'Two-letter ISO 639-1 language code representing the player\'s preferred language for UI, communications, and in-game content. Used for localization and content delivery.' ;
    rdfs:domain ind:Player ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileVisibility rdf:type rdf:Property ;
    rdfs:label 'Profile Visibility' ;
    rdfs:comment 'Privacy setting controlling who can view the player\'s profile information. Public profiles are visible to all; friends_only profiles are visible to approved connections; private profiles are visible only to the player.' ;
    rdfs:domain ind:Player ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reputationScore rdf:type rdf:Property ;
    rdfs:label 'Reputation Score' ;
    rdfs:comment 'Community reputation score based on player behavior, reports, commendations, and moderation actions. Used for matchmaking, trust scoring, and identifying toxic players. Negative scores indicate poor behavior.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionExpiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Suspension Expiry Timestamp' ;
    rdfs:comment 'Date and time when a temporary account suspension will automatically expire and the account will be reactivated. Null for permanent bans.' ;
    rdfs:domain ind:PlayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:suspensionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Suspension Timestamp' ;
    rdfs:comment 'Date and time when the account was suspended or banned. Used for suspension duration tracking and appeals processing.' ;
    rdfs:domain ind:PlayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:timezone rdf:type rdf:Property ;
    rdfs:label 'Timezone' ;
    rdfs:comment 'IANA timezone identifier (e.g., America/New_York, Europe/London, Asia/Tokyo) representing the player\'s local timezone. Used for scheduling live events, daily login rewards, and time-based game mechanics.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:twoFactorAuthEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Two Factor Auth Enabled Flag' ;
    rdfs:comment 'Indicates whether the player has enabled two-factor authentication (2FA) for enhanced account security. Recommended for high-value accounts and required for certain privileged operations.' ;
    rdfs:domain ind:PlayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:username rdf:type rdf:Property ;
    rdfs:label 'Username' ;
    rdfs:comment 'Unique username chosen by the player during registration. Used for login and public identification across platforms. Must be unique system-wide.' ;
    rdfs:domain ind:PlayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerLifecycleEventId rdf:type rdf:Property ;
    rdfs:label 'Player Lifecycle Event Id' ;
    rdfs:comment 'Unique identifier for the player lifecycle event record. Primary key for the immutable event log.' ;
    rdfs:domain ind:PlayerLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authenticationProvider rdf:type rdf:Property ;
    rdfs:label 'Authentication Provider' ;
    rdfs:comment 'The identity provider used for authentication (e.g., internal, Google, Facebook, Apple, Steam, Epic Games, Xbox Live, PlayStation Network).' ;
    rdfs:domain ind:PlayerLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coppaProtectedFlag rdf:type rdf:Property ;
    rdfs:label 'Coppa Protected Flag' ;
    rdfs:comment 'Boolean indicator (True/False) marking whether the player was subject to COPPA protections (under age 13 in the US) at the time of the event.' ;
    rdfs:domain ind:PlayerLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daysSincePreviousEvent rdf:type rdf:Property ;
    rdfs:label 'Days Since Previous Event' ;
    rdfs:comment 'The number of calendar days elapsed between this event and the previous event for this player. Used for retention and reactivation analysis.' ;
    rdfs:domain ind:PlayerLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventMetadataPayload rdf:type rdf:Property ;
    rdfs:label 'Event Metadata Payload' ;
    rdfs:comment 'JSON-formatted string containing additional event-specific metadata and context that does not fit into structured columns (e.g., custom event properties, extended attributes, diagnostic data).' ;
    rdfs:domain ind:PlayerLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Event Source System' ;
    rdfs:comment 'The name or identifier of the system that emitted or recorded this event (e.g., authentication service, Salesforce CRM, platform SDK, game client).' ;
    rdfs:domain ind:PlayerLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geolocationCity rdf:type rdf:Property ;
    rdfs:label 'Geolocation City' ;
    rdfs:comment 'The city derived from the IP address at the time of the event.' ;
    rdfs:domain ind:PlayerLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geolocationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Geolocation Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code derived from the IP address at the time of the event (e.g., USA, GBR, JPN).' ;
    rdfs:domain ind:PlayerLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geolocationRegion rdf:type rdf:Property ;
    rdfs:label 'Geolocation Region' ;
    rdfs:comment 'The region, state, or province derived from the IP address at the time of the event (e.g., California, Ontario, Bavaria).' ;
    rdfs:domain ind:PlayerLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousEventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Previous Event Timestamp' ;
    rdfs:comment 'The timestamp of the previous lifecycle or authentication event for this player, used to calculate time-between-events and detect anomalies.' ;
    rdfs:domain ind:PlayerLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:triggeringContext rdf:type rdf:Property ;
    rdfs:label 'Triggering Context' ;
    rdfs:comment 'Free-text description of the business context or user action that triggered this event (e.g., \'player completed tutorial level 5\', \'player clicked purchase button\', \'automated churn detection job\').' ;
    rdfs:domain ind:PlayerLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceId rdf:type rdf:Property ;
    rdfs:label 'Preference Id' ;
    rdfs:comment 'Unique identifier for the player preference record. Primary key.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferenceModifiedByUserPlayerAccountId rdf:type rdf:Property ;
    rdfs:label 'Preference Modified By User Player Account Id' ;
    rdfs:comment 'Reference to the player or support agent who last modified these preferences. Supports audit and compliance.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerAccount .

ind:preferencePlayerAccountId rdf:type rdf:Property ;
    rdfs:label 'Preference Player Account Id' ;
    rdfs:comment 'Reference to the player who owns these preferences. Links to the player master entity.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerAccount .

ind:audioLanguage rdf:type rdf:Property ;
    rdfs:label 'Audio Language' ;
    rdfs:comment 'ISO 639-2 three-letter language code for in-game voice-over and audio. Supports localization.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoUpdateEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Update Enabled' ;
    rdfs:comment 'Platform preference controlling whether game updates and patches are automatically downloaded and installed.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:colorblindMode rdf:type rdf:Property ;
    rdfs:label 'Colorblind Mode' ;
    rdfs:comment 'Accessibility setting for colorblind players. Adjusts in-game color palettes for improved visibility.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlScheme rdf:type rdf:Property ;
    rdfs:label 'Control Scheme' ;
    rdfs:comment 'Player-configured controller or keyboard/mouse input mapping scheme.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossplayEnabled rdf:type rdf:Property ;
    rdfs:label 'Crossplay Enabled' ;
    rdfs:comment 'Gameplay preference controlling whether the player can be matched with players on other platforms in multiplayer modes.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSharingAnalyticsEnabled rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Analytics Enabled' ;
    rdfs:comment 'Privacy setting controlling whether player gameplay data can be used for analytics and product improvement. GDPR consent for analytics processing.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSharingMarketingEnabled rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Marketing Enabled' ;
    rdfs:comment 'Privacy setting controlling whether player data can be used for targeted marketing and personalization. GDPR consent for marketing processing.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSharingThirdPartyEnabled rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Third Party Enabled' ;
    rdfs:comment 'Privacy setting controlling whether player data can be shared with third-party partners (e.g., ad networks, analytics providers). GDPR consent for third-party sharing.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:difficultyLevel rdf:type rdf:Property ;
    rdfs:label 'Difficulty Level' ;
    rdfs:comment 'Player-selected gameplay difficulty setting. Drives game balancing and challenge scaling.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailEnabled rdf:type rdf:Property ;
    rdfs:label 'Email Enabled' ;
    rdfs:comment 'Master toggle for all email communications. When false, no emails are sent regardless of category settings.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emailNewsletterEnabled rdf:type rdf:Property ;
    rdfs:label 'Email Newsletter Enabled' ;
    rdfs:comment 'Opt-in for email newsletters with game news, community highlights, and developer updates.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emailPromotionalEnabled rdf:type rdf:Property ;
    rdfs:label 'Email Promotional Enabled' ;
    rdfs:comment 'Opt-in for promotional emails about sales, offers, and special events. Marketing consent.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emailTransactionalEnabled rdf:type rdf:Property ;
    rdfs:label 'Email Transactional Enabled' ;
    rdfs:comment 'Opt-in for transactional emails such as purchase receipts, account security alerts, and service notifications. Typically cannot be disabled for operational reasons.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:friendDiscoveryEnabled rdf:type rdf:Property ;
    rdfs:label 'Friend Discovery Enabled' ;
    rdfs:comment 'Privacy setting controlling whether other players can find and send friend requests to this player.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchmakingRegion rdf:type rdf:Property ;
    rdfs:label 'Matchmaking Region' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the players preferred geographic region for multiplayer matchmaking. Affects latency and server selection.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceScope rdf:type rdf:Property ;
    rdfs:label 'Preference Scope' ;
    rdfs:comment 'The scope at which these preferences apply: account-wide, platform-specific, game-specific, or session-only.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceSource rdf:type rdf:Property ;
    rdfs:label 'Preference Source' ;
    rdfs:comment 'The system or channel through which these preferences were set. Supports audit and troubleshooting.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredStorefront rdf:type rdf:Property ;
    rdfs:label 'Preferred Storefront' ;
    rdfs:comment 'Players preferred digital storefront for purchases and content discovery. Drives personalization and cross-platform entitlement. [ENUM-REF-CANDIDATE: steam|epic|playstation|xbox|nintendo|mobile_ios|mobile_android|web — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profanityFilterEnabled rdf:type rdf:Property ;
    rdfs:label 'Profanity Filter Enabled' ;
    rdfs:comment 'Communication preference controlling whether profanity and offensive language are filtered in chat. Often required for COPPA compliance for child accounts.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pushGameUpdatesEnabled rdf:type rdf:Property ;
    rdfs:label 'Push Game Updates Enabled' ;
    rdfs:comment 'Opt-in for push notifications about game updates, patches, and new content releases.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pushNotificationEnabled rdf:type rdf:Property ;
    rdfs:label 'Push Notification Enabled' ;
    rdfs:comment 'Master toggle for all push notifications. When false, no push notifications are sent regardless of category settings.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pushPromotionalEnabled rdf:type rdf:Property ;
    rdfs:label 'Push Promotional Enabled' ;
    rdfs:comment 'Opt-in for push notifications about sales, offers, and promotional campaigns. Marketing consent.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pushSocialEnabled rdf:type rdf:Property ;
    rdfs:label 'Push Social Enabled' ;
    rdfs:comment 'Opt-in for push notifications about friend activity, guild events, and social interactions.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:smsEnabled rdf:type rdf:Property ;
    rdfs:label 'Sms Enabled' ;
    rdfs:comment 'Master toggle for SMS text message communications. When false, no SMS messages are sent.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:smsPromotionalEnabled rdf:type rdf:Property ;
    rdfs:label 'Sms Promotional Enabled' ;
    rdfs:comment 'Opt-in for promotional SMS messages about sales and offers. Marketing consent.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subtitleEnabled rdf:type rdf:Property ;
    rdfs:label 'Subtitle Enabled' ;
    rdfs:comment 'Indicates whether subtitles are enabled for this player. Accessibility feature.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subtitleLanguage rdf:type rdf:Property ;
    rdfs:label 'Subtitle Language' ;
    rdfs:comment 'ISO 639-2 three-letter language code for in-game subtitle display. Supports localization and accessibility.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:telemetryEnabled rdf:type rdf:Property ;
    rdfs:label 'Telemetry Enabled' ;
    rdfs:comment 'Privacy setting controlling whether detailed gameplay telemetry (performance metrics, crash reports, usage patterns) is collected. Distinct from analytics consent.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:textChatEnabled rdf:type rdf:Property ;
    rdfs:label 'Text Chat Enabled' ;
    rdfs:comment 'Communication preference controlling whether the player participates in in-game text chat.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profileId rdf:type rdf:Property ;
    rdfs:label 'Profile Id' ;
    rdfs:comment 'Unique identifier for the player profile. Primary key. Distinct from account_id (authentication layer) — this is the social and demographic identity layer.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessibilitySettings rdf:type rdf:Property ;
    rdfs:label 'Accessibility Settings' ;
    rdfs:comment 'JSON or delimited string capturing player\'s accessibility preferences (e.g., colorblind mode, subtitle size, controller remapping, audio cues). Used to personalize game experience for players with disabilities.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationLanguage rdf:type rdf:Property ;
    rdfs:label 'Communication Language' ;
    rdfs:comment 'Two-letter ISO 639-1 language code for player support and marketing communications. May differ from preferred_language (UI language). Used for customer service routing and localized campaigns.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRatingPreference rdf:type rdf:Property ;
    rdfs:label 'Content Rating Preference' ;
    rdfs:comment 'Player\'s preferred ESRB (Entertainment Software Rating Board) content rating level for game recommendations and parental controls. Values: E (Everyone), E10 (Everyone 10+), T (Teen), M (Mature 17+), AO (Adults Only 18+).' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailVerified rdf:type rdf:Property ;
    rdfs:label 'Email Verified' ;
    rdfs:comment 'Boolean flag indicating whether the player\'s email address has been verified through a confirmation link or code. Required for account recovery and secure communications.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalProfileCode rdf:type rdf:Property ;
    rdfs:label 'External Profile Code' ;
    rdfs:comment 'Unique identifier from the source system (e.g., Salesforce Contact ID, Steam ID, Epic Account ID). Used for cross-system reconciliation and data lineage tracking.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprErasureCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Gdpr Erasure Completed Timestamp' ;
    rdfs:comment 'Timestamp when GDPR erasure request was completed and PII (Personally Identifiable Information) was anonymized or deleted. Null if no erasure has been performed. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:phoneVerified rdf:type rdf:Property ;
    rdfs:label 'Phone Verified' ;
    rdfs:comment 'Boolean flag indicating whether the player\'s phone number has been verified through SMS or voice call. Used for two-factor authentication (2FA) and account security.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformPreference rdf:type rdf:Property ;
    rdfs:label 'Platform Preference' ;
    rdfs:comment 'Player\'s preferred gaming platform. Used for personalized content recommendations, platform-specific events, and cross-platform analytics. Values: console, pc, mobile, vr (Virtual Reality), cross_platform.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the player\'s location. Used for regional analytics, tax compliance, and geo-targeted marketing. May be required for payment processing.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current lifecycle status of the player profile. Values: active (normal operation), suspended (temporary restriction), banned (permanent restriction), deleted (soft-deleted per GDPR right-to-erasure), pending_verification (awaiting age/identity verification).' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referredByCode rdf:type rdf:Property ;
    rdfs:label 'Referred By Code' ;
    rdfs:comment 'Referral code of the player who referred this player. Used for attribution tracking, referral reward distribution, and viral growth analysis.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vipTier rdf:type rdf:Property ;
    rdfs:label 'Vip Tier' ;
    rdfs:comment 'Player\'s VIP tier based on spending, engagement, or loyalty. Used for tiered rewards, exclusive content access, and premium support. Values: none, bronze, silver, gold, platinum, diamond.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Unique identifier for the player segment. Primary key.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentSegmentId rdf:type rdf:Property ;
    rdfs:label 'Parent Segment Id' ;
    rdfs:comment 'Reference to a parent segment if this segment is a sub-segment or refinement of a broader segment. Null for top-level segments. Enables hierarchical segment taxonomies.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:ageRangeMax rdf:type rdf:Property ;
    rdfs:label 'Age Range Max' ;
    rdfs:comment 'Maximum age for demographic age-based segments. Null for open-ended or non-age segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageRangeMin rdf:type rdf:Property ;
    rdfs:label 'Age Range Min' ;
    rdfs:comment 'Minimum age for demographic age-based segments. Null for non-age segments. Used for COPPA compliance and age-gated content targeting.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:churnRiskScoreMax rdf:type rdf:Property ;
    rdfs:label 'Churn Risk Score Max' ;
    rdfs:comment 'Maximum churn risk probability score (0.0000 to 1.0000) for churn-risk segments. Null for non-churn segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:churnRiskScoreMin rdf:type rdf:Property ;
    rdfs:label 'Churn Risk Score Min' ;
    rdfs:comment 'Minimum churn risk probability score (0.0000 to 1.0000) for churn-risk segments. Null for non-churn segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coppaSafe rdf:type rdf:Property ;
    rdfs:label 'Coppa Safe' ;
    rdfs:comment 'Indicates whether this segment is safe for targeting players under 13 years old per COPPA requirements (True) or restricted to 13+ audiences (False).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geoFilter rdf:type rdf:Property ;
    rdfs:label 'Geo Filter' ;
    rdfs:comment 'Geographic restriction for this segment using ISO 3166-1 alpha-3 country codes (e.g., \'USA\', \'JPN\', \'DEU\') or region codes. Null for global segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isStandardSegment rdf:type rdf:Property ;
    rdfs:label 'Is Standard Segment' ;
    rdfs:comment 'Indicates whether this is a standard, enterprise-wide segment (True) used across all games and teams, or a custom segment (False) created for specific campaigns or experiments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxLtvThreshold rdf:type rdf:Property ;
    rdfs:label 'Max Ltv Threshold' ;
    rdfs:comment 'Maximum LTV value for segment membership, applicable to LTV-based segments (e.g., Minnow tier upper bound). Null for open-ended or non-LTV segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minLtvThreshold rdf:type rdf:Property ;
    rdfs:label 'Min Ltv Threshold' ;
    rdfs:comment 'Minimum LTV value required for segment membership, applicable to LTV-based segments (e.g., Whale tier). Null for non-LTV segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retentionDayThreshold rdf:type rdf:Property ;
    rdfs:label 'Retention Day Threshold' ;
    rdfs:comment 'Day number used for retention-based segments (e.g., 1 for D1 retained, 7 for D7 retained, 30 for D30 retained). Null for non-retention segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spendTier rdf:type rdf:Property ;
    rdfs:label 'Spend Tier' ;
    rdfs:comment 'Monetization tier classification for spend-based segments: whale (high spenders), dolphin (medium spenders), minnow (low spenders), non_payer (F2P only). Null for non-spend segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetUseCase rdf:type rdf:Property ;
    rdfs:label 'Target Use Case' ;
    rdfs:comment 'Primary business use case for this segment (e.g., \'Live-ops event targeting\', \'Personalized offers\', \'Churn prevention campaign\', \'A/B test cohort\', \'Retention analysis\').' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentMembershipId rdf:type rdf:Property ;
    rdfs:label 'Segment Membership Id' ;
    rdfs:comment 'Unique identifier for the segment membership record. Primary key for tracking individual player-segment associations over time.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketingPlayerSegmentId rdf:type rdf:Property ;
    rdfs:label 'Marketing Player Segment Id' ;
    rdfs:comment 'Foreign key linking to marketing.player_segment. Business justification: Segment_membership assigns players to marketing-defined segments for CRM campaigns, email/push targeting, and lifecycle marketing automation. Marketing.player_segment represents marketing team\'s segme' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerSegment .

ind:primarySegmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Segment Id' ;
    rdfs:comment 'Reference to the segment definition that this player is assigned to. Links to the segment configuration and rules.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:exclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusion Flag' ;
    rdfs:comment 'Boolean flag indicating whether this player should be excluded from segment-targeted campaigns despite meeting segment criteria. True indicates exclusion (e.g., VIP player, employee account, test account, player request). Used to override automated segment assignments for special cases.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusionReason rdf:type rdf:Property ;
    rdfs:label 'Exclusion Reason' ;
    rdfs:comment 'Free-text explanation for why the player is excluded from segment-targeted activities when exclusion_flag is True. Examples include VIP status, employee account, test account, player opt-out request, regulatory restriction. Null when exclusion_flag is False.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCurrent rdf:type rdf:Property ;
    rdfs:label 'Is Current' ;
    rdfs:comment 'Boolean flag indicating whether this is the current active segment membership record for this player-segment combination. True for active memberships, False for historical records. Enables efficient queries for current segment state without date filtering.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ltvEstimate rdf:type rdf:Property ;
    rdfs:label 'Ltv Estimate' ;
    rdfs:comment 'Estimated lifetime value of the player in USD at the time of segment assignment. Captured as a snapshot to track how LTV estimates evolve as players move between segments. Used for high-value player identification and retention investment decisions.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:segmentEntryEvent rdf:type rdf:Property ;
    rdfs:label 'Segment Entry Event' ;
    rdfs:comment 'The specific player behavior, transaction, or milestone event that triggered entry into this segment. Examples include first_purchase, 7_day_inactive, level_50_reached, high_spender_threshold_crossed. Provides behavioral context for segment transitions.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentExitEvent rdf:type rdf:Property ;
    rdfs:label 'Segment Exit Event' ;
    rdfs:comment 'The specific player behavior, transaction, or milestone event that triggered exit from this segment. Examples include returned_to_active, subscription_cancelled, moved_to_whale_segment. Null for active memberships. Tracks segment transition patterns.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentTenureDays rdf:type rdf:Property ;
    rdfs:label 'Segment Tenure Days' ;
    rdfs:comment 'Number of days the player has been continuously assigned to this segment. Calculated as the difference between current date and effective_start_date. Used to identify long-term segment residents and track segment stability.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSpendToDate rdf:type rdf:Property ;
    rdfs:label 'Total Spend To Date' ;
    rdfs:comment 'Cumulative amount in USD that the player has spent across all in-app purchases, microtransactions, and subscriptions at the time of segment assignment. Snapshot value used for spend-based segmentation (whale, dolphin, minnow, free-to-play).' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tester Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: QA and development teams conduct playtesting sessions that must be distinguished from organic player sessions for analytics accuracy. Linking sessions to the testing employee enables bug attribution, ' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ccuBucket rdf:type rdf:Property ;
    rdfs:label 'Ccu Bucket' ;
    rdfs:comment 'The concurrent user count bucket at the time this session started. CCU represents the number of players actively playing at the same time. Used for server capacity planning and peak load analysis.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disconnectReason rdf:type rdf:Property ;
    rdfs:label 'Disconnect Reason' ;
    rdfs:comment 'The reason the session ended. Normal indicates player-initiated logout. Other values indicate technical or administrative disconnections. Used for quality assurance and player experience analysis. [ENUM-REF-CANDIDATE: normal|timeout|crash|network_error|kicked|banned|server_shutdown — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventCount rdf:type rdf:Property ;
    rdfs:label 'Event Count' ;
    rdfs:comment 'Total number of tracked in-game events (achievements, level completions, item pickups, etc.) that occurred during this session. Used for engagement depth analysis.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isTutorialCompleted rdf:type rdf:Property ;
    rdfs:label 'Is Tutorial Completed' ;
    rdfs:comment 'Boolean flag indicating whether the player completed the tutorial during this session. Used for onboarding funnel analysis.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchmakingWaitSeconds rdf:type rdf:Property ;
    rdfs:label 'Matchmaking Wait Seconds' ;
    rdfs:comment 'The time in seconds the player waited in matchmaking queue before the session started. Null for non-matchmaking sessions. Used for matchmaking efficiency analysis.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mtxTransactionCount rdf:type rdf:Property ;
    rdfs:label 'Mtx Transaction Count' ;
    rdfs:comment 'The number of microtransaction purchases made during this session. Used for conversion rate and monetization funnel analysis.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityScore rdf:type rdf:Property ;
    rdfs:label 'Quality Score' ;
    rdfs:comment 'A composite quality score (0-100) calculated from FPS, latency, and other technical metrics. Used to assess overall session experience quality.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sessionType rdf:type rdf:Property ;
    rdfs:label 'Session Type' ;
    rdfs:comment 'The gameplay mode or type of session. FTUE (First-Time User Experience) indicates onboarding sessions. PvP (Player versus Player) and PvE (Player versus Environment) indicate competitive modes. [ENUM-REF-CANDIDATE: matchmaking|solo|co-op|pvp|pve|tutorial|ftue|practice|ranked|casual — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:titleProgressId rdf:type rdf:Property ;
    rdfs:label 'Title Progress Id' ;
    rdfs:comment 'Unique identifier for the player\'s progress record within a specific game title. Primary key.' ;
    rdfs:domain ind:TitleProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastCheckpointId rdf:type rdf:Property ;
    rdfs:label 'Last Checkpoint Id' ;
    rdfs:comment 'Identifier of the last checkpoint or save point reached by the player in this game title. Used for player support and progress recovery.' ;
    rdfs:domain ind:TitleProgress ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Checkpoint .

ind:achievementCount rdf:type rdf:Property ;
    rdfs:label 'Achievement Count' ;
    rdfs:comment 'Total number of achievements or trophies unlocked by the player in this game title.' ;
    rdfs:domain ind:TitleProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:battlePassTier rdf:type rdf:Property ;
    rdfs:label 'Battle Pass Tier' ;
    rdfs:comment 'Current tier or level achieved in the active battle pass for this game title. Null if no battle pass is active.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:characterClass rdf:type rdf:Property ;
    rdfs:label 'Character Class' ;
    rdfs:comment 'Primary character class or role the player uses in this game title (e.g., Warrior, Mage, Support). Null for titles without class systems.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionPercentage rdf:type rdf:Property ;
    rdfs:label 'Completion Percentage' ;
    rdfs:comment 'Percentage of game content completed by the player (0.00 to 100.00). Includes story missions, side quests, collectibles, and achievements.' ;
    rdfs:domain ind:TitleProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentLevel rdf:type rdf:Property ;
    rdfs:label 'Current Level' ;
    rdfs:comment 'The player\'s current level or rank within the game title. Represents progression milestone achieved.' ;
    rdfs:domain ind:TitleProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:d1RetentionFlag rdf:type rdf:Property ;
    rdfs:label 'D1 Retention Flag' ;
    rdfs:comment 'Boolean flag indicating whether the player returned to play on Day 1 after first session. Critical early retention metric.' ;
    rdfs:domain ind:TitleProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:d30RetentionFlag rdf:type rdf:Property ;
    rdfs:label 'D30 Retention Flag' ;
    rdfs:comment 'Boolean flag indicating whether the player returned to play on Day 30 after first session. Long-term retention indicator.' ;
    rdfs:domain ind:TitleProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:d7RetentionFlag rdf:type rdf:Property ;
    rdfs:label 'D7 Retention Flag' ;
    rdfs:comment 'Boolean flag indicating whether the player returned to play on Day 7 after first session. Key retention milestone.' ;
    rdfs:domain ind:TitleProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:difficultySetting rdf:type rdf:Property ;
    rdfs:label 'Difficulty Setting' ;
    rdfs:comment 'Current difficulty level selected by the player for this game title. Used for personalization and challenge balancing.' ;
    rdfs:domain ind:TitleProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstPlayedTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Played Timestamp' ;
    rdfs:comment 'Timestamp when the player first started playing this game title. Used for cohort analysis and FTUE (First-Time User Experience) tracking.' ;
    rdfs:domain ind:TitleProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:highestRankAchieved rdf:type rdf:Property ;
    rdfs:label 'Highest Rank Achieved' ;
    rdfs:comment 'The highest competitive rank or tier the player has achieved in this game title (e.g., Diamond, Master, Legend). Free-form text to accommodate various ranking systems.' ;
    rdfs:domain ind:TitleProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inGameCurrencyBalance rdf:type rdf:Property ;
    rdfs:label 'In Game Currency Balance' ;
    rdfs:comment 'Current balance of the primary in-game virtual currency for this player in this title. Used for virtual economy management.' ;
    rdfs:domain ind:TitleProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'Preferred language for in-game content and UI for this player in this title. ISO 639-1 two-letter language code.' ;
    rdfs:domain ind:TitleProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPlayedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Played Timestamp' ;
    rdfs:comment 'Timestamp of the player\'s most recent session in this game title. Critical for churn prediction and re-engagement campaigns.' ;
    rdfs:domain ind:TitleProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastPurchaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Timestamp' ;
    rdfs:comment 'Timestamp of the player\'s most recent in-game purchase or microtransaction in this title. Used for monetization analysis.' ;
    rdfs:domain ind:TitleProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:parentalControlsEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Parental Controls Enabled Flag' ;
    rdfs:comment 'Boolean flag indicating whether parental controls are active for this player in this game title. Required for COPPA compliance.' ;
    rdfs:domain ind:TitleProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:playstyleClassification rdf:type rdf:Property ;
    rdfs:label 'Playstyle Classification' ;
    rdfs:comment 'Classification of the player\'s dominant playstyle in this title: PvP (Player versus Player), PvE (Player versus Environment), casual, competitive, mixed, or explorer. Used for personalization and matchmaking.' ;
    rdfs:domain ind:TitleProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumCurrencyBalance rdf:type rdf:Property ;
    rdfs:label 'Premium Currency Balance' ;
    rdfs:comment 'Current balance of premium (purchasable) virtual currency for this player in this title. Used for MTX (Microtransactions) tracking.' ;
    rdfs:domain ind:TitleProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:progressStatus rdf:type rdf:Property ;
    rdfs:label 'Progress Status' ;
    rdfs:comment 'Current lifecycle status of the player\'s progress in this title. Indicates whether the player is actively playing, has completed, or has abandoned the title.' ;
    rdfs:domain ind:TitleProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalLosses rdf:type rdf:Property ;
    rdfs:label 'Total Losses' ;
    rdfs:comment 'Total number of competitive matches or games lost by the player in this title. Used for win-rate calculations and skill assessment.' ;
    rdfs:domain ind:TitleProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalMtxSpend rdf:type rdf:Property ;
    rdfs:label 'Total Mtx Spend' ;
    rdfs:comment 'Total amount spent by the player on microtransactions (MTX) in this game title. Used for ARPPU (Average Revenue Per Paying User) and LTV (Lifetime Value) calculations.' ;
    rdfs:domain ind:TitleProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPlaytimeHours rdf:type rdf:Property ;
    rdfs:label 'Total Playtime Hours' ;
    rdfs:comment 'Total number of hours the player has spent playing this game title. Key engagement metric for GaaS (Game as a Service) operations.' ;
    rdfs:domain ind:TitleProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWins rdf:type rdf:Property ;
    rdfs:label 'Total Wins' ;
    rdfs:comment 'Total number of competitive matches or games won by the player in this title. Used for win-rate calculations and skill assessment.' ;
    rdfs:domain ind:TitleProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tutorialCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Tutorial Completed Flag' ;
    rdfs:comment 'Boolean flag indicating whether the player has completed the tutorial or FTUE (First-Time User Experience) for this game title.' ;
    rdfs:domain ind:TitleProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentPatchId rdf:type rdf:Property ;
    rdfs:label 'Content Patch Id' ;
    rdfs:comment 'Foreign key linking to content.patch. Business justification: Certification findings on patch submissions (patch fails TRC, hotfix requires expedited certification). Patch-level certification tracking enables submission planning and deployment blocking.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Patch .

ind:primaryCertEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Cert Employee Id' ;
    rdfs:comment 'Reference to the internal team member or QA engineer assigned as the accountable owner responsible for resolving or formally accepting risk on this finding.' ;
    rdfs:domain ind:CertFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedFeatureArea rdf:type rdf:Property ;
    rdfs:label 'Affected Feature Area' ;
    rdfs:comment 'The game system, feature, or functional area where the finding manifests (e.g., online multiplayer, trophy/achievement system, DLC entitlement, save/load, UI/UX, audio, crash/stability, FTUE). Used for defect trend analysis and QA resource allocation.' ;
    rdfs:domain ind:CertFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCategory rdf:type rdf:Property ;
    rdfs:label 'Compliance Category' ;
    rdfs:comment 'The regulatory or platform compliance framework category under which this finding is classified. Determines the applicable governing body and reporting obligations. [ENUM-REF-CANDIDATE: trc|tcr|esrb|pegi|usk|cero|grac|gdpr|coppa|pci_dss|app_store|internal_gate — promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingDate rdf:type rdf:Property ;
    rdfs:label 'Finding Date' ;
    rdfs:comment 'The calendar date on which this certification finding was formally identified and logged, either by a first-party platform reviewer or by an internal QA release gate evaluation. Principal business event date for this transaction.' ;
    rdfs:domain ind:CertFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:findingType rdf:type rdf:Property ;
    rdfs:label 'Finding Type' ;
    rdfs:comment 'Categorical classification of the finding origin: cert_failure (first-party platform rejection), release_gate_failure (internal quality gate block), waived_exception (formally risk-accepted defect), advisory (non-blocking platform note), regression (previously passing requirement now failing).' ;
    rdfs:domain ind:CertFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixBuildVersion rdf:type rdf:Property ;
    rdfs:label 'Fix Build Version' ;
    rdfs:comment 'The game build version string in which the fix for this finding was implemented and verified. Null until the finding is resolved. Enables traceability between defect resolution and specific Perforce Helix Core changelists.' ;
    rdfs:domain ind:CertFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBlocker rdf:type rdf:Property ;
    rdfs:label 'Is Blocker' ;
    rdfs:comment 'Indicates whether this finding is classified as a hard release blocker that must be resolved or formally waived before the title can proceed to launch. True = blocks release; False = non-blocking. Drives release readiness gate logic.' ;
    rdfs:domain ind:CertFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegression rdf:type rdf:Property ;
    rdfs:label 'Is Regression' ;
    rdfs:comment 'Indicates whether this finding represents a regression — a requirement or behavior that previously passed certification or a quality gate but has failed in the current build. True = regression; False = new finding. Critical for root-cause analysis of build pipeline quality.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceMetricThreshold rdf:type rdf:Property ;
    rdfs:label 'Performance Metric Threshold' ;
    rdfs:comment 'The minimum or maximum required threshold value for the performance metric as defined by the platform certification standard or internal quality gate (e.g., minimum 30 FPS, maximum 5 seconds load time). Null for non-performance findings.' ;
    rdfs:domain ind:CertFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceMetricType rdf:type rdf:Property ;
    rdfs:label 'Performance Metric Type' ;
    rdfs:comment 'For performance-related findings, identifies the specific performance metric that failed the certification or quality gate threshold (e.g., FPS below minimum, load time exceeding limit, crash rate above threshold). \'none\' for non-performance findings.' ;
    rdfs:domain ind:CertFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceMetricValue rdf:type rdf:Property ;
    rdfs:label 'Performance Metric Value' ;
    rdfs:comment 'The observed numeric value of the performance metric at the time the finding was identified (e.g., 24.3 FPS, 8.7 seconds load time, 0.023 crash rate). Null for non-performance findings. Paired with performance_metric_type for full context.' ;
    rdfs:domain ind:CertFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformReviewerRef rdf:type rdf:Property ;
    rdfs:label 'Platform Reviewer Ref' ;
    rdfs:comment 'The first-party platform holder\'s internal case or reviewer reference number associated with this finding (e.g., Sony Lotcheck case ID, Microsoft CERT ticket number). Enables direct correspondence tracking with platform certification teams.' ;
    rdfs:domain ind:CertFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postLaunchMonitoring rdf:type rdf:Property ;
    rdfs:label 'Post Launch Monitoring' ;
    rdfs:comment 'Formal description of the post-launch monitoring plan committed to as a condition of waiver approval, specifying metrics to be tracked (e.g., crash rate thresholds, player complaint volume, telemetry alerts) and the monitoring duration. Required for all approved waivers.' ;
    rdfs:domain ind:CertFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privacyImpact rdf:type rdf:Property ;
    rdfs:label 'Privacy Impact' ;
    rdfs:comment 'Indicates whether this finding has potential impact on player data privacy compliance (GDPR, COPPA). True = finding may expose a privacy risk; False = no privacy impact. Triggers mandatory escalation to the Data Protection Officer when True.' ;
    rdfs:domain ind:CertFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reproductionRate rdf:type rdf:Property ;
    rdfs:label 'Reproduction Rate' ;
    rdfs:comment 'Qualitative frequency with which the finding can be reproduced following the documented reproduction steps: always (100%), frequent (>50%), intermittent (10-50%), rare (<10%), unable_to_reproduce. Informs severity assessment and fix prioritization.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reproductionSteps rdf:type rdf:Property ;
    rdfs:label 'Reproduction Steps' ;
    rdfs:comment 'Step-by-step instructions required to reliably reproduce the finding on the specified platform and build version. Critical for engineering triage, fix verification, and regression testing. Sourced from Jira defect records.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedDate rdf:type rdf:Property ;
    rdfs:label 'Resolved Date' ;
    rdfs:comment 'The calendar date on which the finding was formally resolved, verified as fixed, or cleared by the platform holder. Null for open or in-progress findings. Used to calculate time-to-resolution KPIs and release gate compliance.' ;
    rdfs:domain ind:CertFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskAssessment rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment' ;
    rdfs:comment 'Formal risk level assigned to this finding as part of the waiver governance process, reflecting the potential player impact, regulatory exposure, or commercial risk if the finding ships unresolved: low, medium, high, critical. Informs waiver approval authority level.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionRound rdf:type rdf:Property ;
    rdfs:label 'Submission Round' ;
    rdfs:comment 'The sequential certification submission attempt number (1, 2, 3…) during which this finding was raised. Tracks how many resubmission cycles a title has undergone, a key KPI for release efficiency and QA process maturity.' ;
    rdfs:domain ind:CertFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waiverApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved Date' ;
    rdfs:comment 'The calendar date on which the waiver approver formally granted approval for the risk-acceptance waiver. Null when waiver is pending, denied, or not applicable.' ;
    rdfs:domain ind:CertFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Expiry Date' ;
    rdfs:comment 'The calendar date on which the approved waiver expires, after which the finding must be re-evaluated, fixed, or a new waiver requested. Enforces time-bounded risk acceptance and prevents indefinite deferral of quality issues.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverJustification rdf:type rdf:Property ;
    rdfs:label 'Waiver Justification' ;
    rdfs:comment 'Formal written justification provided by the resolution owner explaining why the finding cannot be fixed prior to release and why the associated risk is acceptable. Required field for all waiver requests; subject to audit by release governance committees.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverRequestedDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Requested Date' ;
    rdfs:comment 'The calendar date on which a formal risk-acceptance waiver was requested for this finding, initiating the waiver governance workflow. Null when no waiver has been requested.' ;
    rdfs:domain ind:CertFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverStatus rdf:type rdf:Property ;
    rdfs:label 'Waiver Status' ;
    rdfs:comment 'Current lifecycle state of the waiver governance process for this finding: not_requested, pending (submitted, awaiting approval), approved, denied, expired (approval period lapsed), withdrawn (requester cancelled). SSOT for waiver compliance reporting.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceTestResultId rdf:type rdf:Property ;
    rdfs:label 'Compliance Test Result Id' ;
    rdfs:comment 'Unique surrogate identifier for each compliance test result record. Primary key for the compliance_test_result data product in the quality domain.' ;
    rdfs:domain ind:ComplianceTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentRatingId rdf:type rdf:Property ;
    rdfs:label 'Content Rating Id' ;
    rdfs:comment 'Foreign key linking to title.content_rating. Business justification: Compliance test results must link to official content rating records (ESRB, PEGI) for audit trails and rating authority submissions. Required for regulatory compliance documentation and rating re-eval' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContentRating .

ind:requirementId rdf:type rdf:Property ;
    rdfs:label 'Requirement Id' ;
    rdfs:comment 'The specific requirement, clause, or control identifier within the compliance framework being tested (e.g., GDPR Article 13, PCI DSS Requirement 6.4, WCAG 2.1 SC 1.4.3). Provides granular traceability to the exact regulatory obligation tested.' ;
    rdfs:domain ind:ComplianceTestResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChecklistRequirement .

ind:automatedTestFlag rdf:type rdf:Property ;
    rdfs:label 'Automated Test Flag' ;
    rdfs:comment 'Indicates whether this compliance test was executed via an automated testing tool or pipeline (True) versus manual testing by a QA analyst (False). Supports test coverage analysis and CI/CD pipeline integration reporting.' ;
    rdfs:domain ind:ComplianceTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceFramework rdf:type rdf:Property ;
    rdfs:label 'Compliance Framework' ;
    rdfs:comment 'The regulatory or standards framework under which this test was conducted. Identifies the governing body or standard being validated, such as age rating bodies (ESRB, PEGI, USK, CERO, GRAC), data privacy (GDPR, COPPA), payment security (PCI DSS), accessibility (WCAG), or information security (ISO 27001, SOC 2). [ENUM-REF-CANDIDATE: ESRB|PEGI|USK|CERO|GRAC|GDPR|COPPA|PCI_DSS|WCAG|ISO27001|SOC2|APPLE_APP_STORE|GOOGLE_PLAY — promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentDescriptorFlags rdf:type rdf:Property ;
    rdfs:label 'Content Descriptor Flags' ;
    rdfs:comment 'Comma-separated list of content descriptor flags identified during age rating compliance testing (e.g., Violence, Blood, Language, Gambling, In-Game Purchases, User Interaction). Required for ESRB, PEGI, and other rating body submissions. Null for non-age-rating tests.' ;
    rdfs:domain ind:ComplianceTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceType rdf:type rdf:Property ;
    rdfs:label 'Evidence Type' ;
    rdfs:comment 'Classification of the compliance evidence artifact type. Indicates whether the evidence is a screenshot, video recording, log file, formal test report, document, or automated scan output. Supports evidence management and audit readiness.' ;
    rdfs:domain ind:ComplianceTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkVersion rdf:type rdf:Property ;
    rdfs:label 'Framework Version' ;
    rdfs:comment 'The specific version or edition of the compliance framework applied during testing (e.g., WCAG 2.1, PCI DSS v4.0, GDPR 2018). Ensures test results are traceable to the exact standard revision in force at the time of testing.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privacyDataCategory rdf:type rdf:Property ;
    rdfs:label 'Privacy Data Category' ;
    rdfs:comment 'Classification of the personal data category involved in this privacy compliance test. Populated for GDPR and COPPA tests to identify whether the test covers general personal data, children\'s data (under 13/16), payment data, behavioral/analytics data, or biometric data. Null for non-privacy frameworks.' ;
    rdfs:domain ind:ComplianceTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseGateBlocking rdf:type rdf:Property ;
    rdfs:label 'Release Gate Blocking' ;
    rdfs:comment 'Indicates whether this compliance test result (specifically a fail or unresolved finding) is currently blocking the release gate for the associated game title and platform. True means the title cannot proceed to platform submission or launch until this finding is resolved.' ;
    rdfs:domain ind:ComplianceTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationNotes rdf:type rdf:Property ;
    rdfs:label 'Remediation Notes' ;
    rdfs:comment 'Free-text notes documenting the remediation approach, actions taken, or rationale for waiver. Provides context for re-test verification and audit review.' ;
    rdfs:domain ind:ComplianceTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultCode rdf:type rdf:Property ;
    rdfs:label 'Result Code' ;
    rdfs:comment 'Externally referenceable business identifier for this compliance test result record, formatted as CTR-YYYYMMDD-XXXXXX. Used in audit trails, platform submissions, and legal correspondence.' ;
    rdfs:domain ind:ComplianceTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retestDate rdf:type rdf:Property ;
    rdfs:label 'Retest Date' ;
    rdfs:comment 'The date on which the compliance retest was or is scheduled to be performed following remediation. Null if retest has not yet been scheduled or is not required.' ;
    rdfs:domain ind:ComplianceTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retestRequired rdf:type rdf:Property ;
    rdfs:label 'Retest Required' ;
    rdfs:comment 'Indicates whether this compliance finding requires a formal retest after remediation before the release gate can be cleared. True for all fail and conditional_pass results that are not waived.' ;
    rdfs:domain ind:ComplianceTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retestResultStatus rdf:type rdf:Property ;
    rdfs:label 'Retest Result Status' ;
    rdfs:comment 'Outcome of the compliance retest performed after remediation. Null if no retest has been conducted. Pass confirms the finding is resolved; fail indicates the remediation was insufficient and further action is required.' ;
    rdfs:domain ind:ComplianceTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signOffDate rdf:type rdf:Property ;
    rdfs:label 'Sign Off Date' ;
    rdfs:comment 'The date on which the compliance test result was formally signed off by the QA lead or compliance officer. Required for platform submission packages and regulatory audit evidence.' ;
    rdfs:domain ind:ComplianceTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signOffStatus rdf:type rdf:Property ;
    rdfs:label 'Sign Off Status' ;
    rdfs:comment 'Approval status of the compliance test result by the designated QA lead or compliance officer. Pending indicates awaiting review; approved indicates the result has been formally accepted; rejected indicates the result requires rework; escalated indicates the finding has been raised to senior management or legal.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCategory rdf:type rdf:Property ;
    rdfs:label 'Test Category' ;
    rdfs:comment 'High-level category classifying the type of compliance test performed. Supports filtering and dashboard segmentation across age rating (ESRB/PEGI/USK/CERO/GRAC), data privacy (GDPR/COPPA), payment security (PCI DSS), accessibility (WCAG), platform certification (TRC/TCR), and content compliance testing.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testDate rdf:type rdf:Property ;
    rdfs:label 'Test Date' ;
    rdfs:comment 'The calendar date on which the compliance test was executed. Principal real-world event date for this compliance test result, used for audit trail and regulatory submission timelines.' ;
    rdfs:domain ind:ComplianceTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testEnvironment rdf:type rdf:Property ;
    rdfs:label 'Test Environment' ;
    rdfs:comment 'The environment in which the compliance test was executed. Cert (certification) environment is the standard for platform submission compliance tests; staging is used for pre-cert validation; production tests may be required for live service compliance audits.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testResultStatus rdf:type rdf:Property ;
    rdfs:label 'Test Result Status' ;
    rdfs:comment 'Outcome of the compliance test execution. Pass indicates full compliance; fail indicates a violation requiring remediation; conditional_pass indicates compliance with noted caveats; not_applicable indicates the requirement does not apply to this title/platform; blocked indicates testing could not be completed; in_review indicates result is pending sign-off.' ;
    rdfs:domain ind:ComplianceTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testTimestamp rdf:type rdf:Property ;
    rdfs:label 'Test Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone offset) at which the compliance test was executed. Provides sub-day precision for audit logs and automated testing pipelines.' ;
    rdfs:domain ind:ComplianceTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:testTool rdf:type rdf:Property ;
    rdfs:label 'Test Tool' ;
    rdfs:comment 'Name and version of the tool or framework used to execute this compliance test (e.g., OWASP ZAP 2.14, axe-core 4.7, custom PCI scanner, manual). Supports reproducibility and audit evidence quality assessment.' ;
    rdfs:domain ind:ComplianceTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testerName rdf:type rdf:Property ;
    rdfs:label 'Tester Name' ;
    rdfs:comment 'Full name of the QA tester or compliance analyst who executed this compliance test. Retained for audit trail readability without requiring a join to the employee table.' ;
    rdfs:domain ind:ComplianceTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wcagLevel rdf:type rdf:Property ;
    rdfs:label 'Wcag Level' ;
    rdfs:comment 'The WCAG conformance level targeted by this accessibility compliance test (A, AA, or AAA). Populated only for WCAG accessibility tests. Null for non-accessibility frameworks. AA is the standard target for most gaming platforms.' ;
    rdfs:domain ind:ComplianceTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crashReportId rdf:type rdf:Property ;
    rdfs:label 'Crash Report Id' ;
    rdfs:comment 'Unique system-generated identifier for each crash report record in the quality domain. Primary key for the crash_report data product.' ;
    rdfs:domain ind:CrashReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedToEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned To Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Crash triage workflow assigns reports to specific engineers for investigation and resolution. Essential for workload balancing, SLA tracking, and escalation management. Role-prefixed to distinguish fr' ;
    rdfs:domain ind:CrashReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:changelistId rdf:type rdf:Property ;
    rdfs:label 'Changelist Id' ;
    rdfs:comment 'Foreign key linking to studio.changelist. Business justification: Crash reports traced to specific code changes; studios track which changelist introduced crash for rollback decisions. Hotfix prioritization requires changelist-level crash attribution. Creating new c' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Changelist .

ind:playtestSessionId rdf:type rdf:Property ;
    rdfs:label 'Playtest Session Id' ;
    rdfs:comment 'Foreign key linking to quality.playtest_session. Business justification: Crashes can occur during playtest sessions. crash_report has environment (STRING) but no FK to playtest_session. Linking crashes to playtest sessions provides context for crash analysis. Cardinality: ' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlaytestSession .

ind:qualityTestExecutionId rdf:type rdf:Property ;
    rdfs:label 'Quality Test Execution Id' ;
    rdfs:comment 'Foreign key linking to quality.test_execution. Business justification: Crashes can occur during test execution. crash_report has environment (STRING) but no FK to test_execution. Linking crashes to the specific test execution provides traceability. Cardinality: N crash_r' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityTestExecution .

ind:uatSessionId rdf:type rdf:Property ;
    rdfs:label 'Uat Session Id' ;
    rdfs:comment 'Foreign key linking to quality.uat_session. Business justification: Crashes can occur during UAT sessions. crash_report has environment (STRING) but no FK to uat_session. Linking crashes to UAT sessions provides context for acceptance testing issues. Cardinality: N cr' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UatSession .

ind:affectedGameComponent rdf:type rdf:Property ;
    rdfs:label 'Affected Game Component' ;
    rdfs:comment 'The high-level game system or feature area where the crash occurred (e.g., Rendering, Physics, Networking, UI, Audio, AI/NPC, Matchmaking, In-App Purchase). Used for component-level crash rate dashboards and sprint planning in Jira.' ;
    rdfs:domain ind:CrashReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedSessionCount rdf:type rdf:Property ;
    rdfs:label 'Affected Session Count' ;
    rdfs:comment 'The number of distinct game sessions impacted by this crash signature. Distinct from occurrence_count; a single session may produce multiple crash events. Used for session-level crash rate calculation.' ;
    rdfs:domain ind:CrashReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cpuModel rdf:type rdf:Property ;
    rdfs:label 'Cpu Model' ;
    rdfs:comment 'The CPU model identifier on the device where the crash occurred (e.g., Apple M3, Snapdragon 8 Gen 3, Intel Core i9-14900K). Used for CPU-specific crash pattern analysis and performance testing correlation.' ;
    rdfs:domain ind:CrashReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crashSignatureHash rdf:type rdf:Property ;
    rdfs:label 'Crash Signature Hash' ;
    rdfs:comment 'SHA-256 hash of the normalized crash stack trace, used as a unique fingerprint to group and deduplicate crash reports with the same root cause. Enables crash clustering, frequency analysis, and regression detection across builds.' ;
    rdfs:domain ind:CrashReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crashTimestamp rdf:type rdf:Property ;
    rdfs:label 'Crash Timestamp' ;
    rdfs:comment 'The precise date and time (UTC) when the crash event occurred on the device. This is the principal real-world event time used for crash rate trending, session correlation, and stability regression detection.' ;
    rdfs:domain ind:CrashReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:crashType rdf:type rdf:Property ;
    rdfs:label 'Crash Type' ;
    rdfs:comment 'Classification of the crash event by failure mode. Hard crash = process termination; Soft crash = handled exception with recovery; ANR (Application Not Responding) = UI thread timeout; Freeze = unresponsive state without termination; Out of Memory = memory allocation failure; Watchdog Timeout = system-level process kill. [ENUM-REF-CANDIDATE: hard_crash|soft_crash|anr|freeze|out_of_memory|watchdog_timeout — promote to reference product]' ;
    rdfs:domain ind:CrashReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceManufacturer rdf:type rdf:Property ;
    rdfs:label 'Device Manufacturer' ;
    rdfs:comment 'The manufacturer of the hardware device on which the crash occurred (e.g., Apple, Samsung, Sony, Microsoft). Enables manufacturer-level crash rate analysis for hardware compatibility reporting.' ;
    rdfs:domain ind:CrashReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faultingModule rdf:type rdf:Property ;
    rdfs:label 'Faulting Module' ;
    rdfs:comment 'The name of the game engine module, DLL, or shared library where the crash originated (e.g., UnrealEngine-Core, libgame.so, GameplayAbilitySystem). Used to attribute crashes to specific engine or game code components.' ;
    rdfs:domain ind:CrashReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fpsAtCrash rdf:type rdf:Property ;
    rdfs:label 'Fps At Crash' ;
    rdfs:comment 'The Frames Per Second (FPS) rendering rate recorded immediately before the crash event. Used to correlate performance degradation with crash onset and identify freeze/ANR patterns linked to frame rate drops.' ;
    rdfs:domain ind:CrashReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCertificationBlocker rdf:type rdf:Property ;
    rdfs:label 'Is Certification Blocker' ;
    rdfs:comment 'Indicates whether this crash is classified as a blocker for platform certification submission (TRC/TCR compliance). Certification blockers must be resolved before a Gold Master build can be submitted to first-party platform holders.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mapLevelName rdf:type rdf:Property ;
    rdfs:label 'Map Level Name' ;
    rdfs:comment 'The name of the in-game map, level, or scene that was loaded at the time of the crash. Used to identify level-specific asset loading or streaming issues contributing to crashes.' ;
    rdfs:domain ind:CrashReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memoryUsageMb rdf:type rdf:Property ;
    rdfs:label 'Memory Usage Mb' ;
    rdfs:comment 'Total memory consumption (in megabytes) of the game process at the moment of the crash. Key quantitative metric for diagnosing out-of-memory crashes and validating memory budget compliance against platform Technical Requirements Checklist (TRC).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkCondition rdf:type rdf:Property ;
    rdfs:label 'Network Condition' ;
    rdfs:comment 'The network connectivity state of the device at the time of the crash. Used to isolate network-dependent crashes in online multiplayer (MMO, PvP) and Game-as-a-Service (GaaS) live operations contexts.' ;
    rdfs:domain ind:CrashReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occurrenceCount rdf:type rdf:Property ;
    rdfs:label 'Occurrence Count' ;
    rdfs:comment 'The number of times this specific crash signature (crash_signature_hash) has been observed across all sessions within the reporting window. Used for crash rate trending and identifying high-frequency stability regressions.' ;
    rdfs:domain ind:CrashReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ramGb rdf:type rdf:Property ;
    rdfs:label 'Ram Gb' ;
    rdfs:comment 'Total RAM (in gigabytes) available on the device at the time of the crash. Used to identify out-of-memory crash patterns and minimum hardware specification compliance.' ;
    rdfs:domain ind:CrashReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportedBy rdf:type rdf:Property ;
    rdfs:label 'Reported By' ;
    rdfs:comment 'The username or identifier of the QA tester, automated crash reporter system, or live operations monitoring agent that first reported this crash. Distinguishes manual QA reports from automated telemetry ingestion.' ;
    rdfs:domain ind:CrashReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reproductionFrequency rdf:type rdf:Property ;
    rdfs:label 'Reproduction Frequency' ;
    rdfs:comment 'QA-assessed reproducibility of the crash: Always = 100% reproducible; Often = >50% of attempts; Sometimes = 10-50%; Rarely = <10%; Once = single occurrence, not reproduced. Informs defect prioritization and release quality gate decisions.' ;
    rdfs:domain ind:CrashReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedInBuildVersion rdf:type rdf:Property ;
    rdfs:label 'Resolved In Build Version' ;
    rdfs:comment 'The build version string in which the crash was confirmed as fixed. Enables fix verification tracking and regression detection if the crash reappears in subsequent builds.' ;
    rdfs:domain ind:CrashReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stackTraceSummary rdf:type rdf:Property ;
    rdfs:label 'Stack Trace Summary' ;
    rdfs:comment 'Truncated or summarized top-of-stack trace text identifying the faulting module, function, and line number. Provides human-readable crash context for QA engineers without storing the full raw stack trace in the Silver layer.' ;
    rdfs:domain ind:CrashReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assigneeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assignee Employee Id' ;
    rdfs:comment 'Reference to the developer or QA engineer currently assigned to investigate or resolve this defect. Maps to Jira \'Assignee\' field. Used for workload balancing and fix accountability tracking.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:defectEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Defect Employee Id' ;
    rdfs:comment 'Reference to the workforce member (QA tester, playtester, UAT participant, or live ops analyst) who originally reported this defect. Supports reporter workload analysis and QA team performance metrics.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reporterPlayerAccountId rdf:type rdf:Property ;
    rdfs:label 'Reporter Player Account Id' ;
    rdfs:comment 'Foreign key linking to player.player_account. Business justification: Player-reported bugs (via in-game reporting tools, community forums, support tickets) must track the reporting player for follow-up communication, bug bounty/reputation systems (rewarding quality repo' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerAccount .

ind:sprintId rdf:type rdf:Property ;
    rdfs:label 'Sprint Id' ;
    rdfs:comment 'Reference to the Jira sprint in which this defect is currently assigned or was resolved. Enables sprint-level defect density and velocity analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sprint .

ind:testCaseId rdf:type rdf:Property ;
    rdfs:label 'Test Case Id' ;
    rdfs:comment 'Reference to the QA test case that first identified this defect. Enables traceability from defect back to test coverage and supports test effectiveness analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestCase .

ind:affectedComponent rdf:type rdf:Property ;
    rdfs:label 'Affected Component' ;
    rdfs:comment 'The specific game system, module, or subsystem where the defect manifests (e.g., rendering engine, physics, UI/HUD, matchmaking, in-game store, audio, save system, network layer, NPC AI). Maps to the Jira \'Component\' field.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedPlatform rdf:type rdf:Property ;
    rdfs:label 'Affected Platform' ;
    rdfs:comment 'The target platform(s) on which the defect is reproducible (e.g., PC, PlayStation 5, Xbox Series X, Nintendo Switch, iOS, Android). Critical for platform certification readiness and TRC/TCR compliance tracking. [ENUM-REF-CANDIDATE: PC|PS5|PS4|XSX|XB1|Switch|iOS|Android|Stadia|VR — promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectDescription rdf:type rdf:Property ;
    rdfs:label 'Defect Description' ;
    rdfs:comment 'Full narrative description of the defect including observed behavior, expected behavior, and any additional context provided by the reporter. Sourced from the Jira issue description field.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectStatus rdf:type rdf:Property ;
    rdfs:label 'Defect Status' ;
    rdfs:comment 'Current workflow lifecycle state of the defect. Drives triage, assignment, and release gate decisions. Maps to Jira issue status. Serves as the LIFECYCLE_STATUS for this transaction. [ENUM-REF-CANDIDATE: open|in_progress|resolved|closed|reopened|deferred|wont_fix|duplicate — promote to reference product]' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectType rdf:type rdf:Property ;
    rdfs:label 'Defect Type' ;
    rdfs:comment 'Classification of the defect by its nature. Functional = incorrect game logic; Performance = FPS drops, load time, memory; Visual = rendering/LOD/UI artifact; Crash = application termination; Regression = previously fixed issue reintroduced; Localization = text/audio translation issue; Compliance = ESRB/PEGI/platform TRC violation; Security = vulnerability or exploit. [ENUM-REF-CANDIDATE: functional|performance|visual|crash|regression|localization|compliance|security|audio|network — promote to reference product]' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryPhase rdf:type rdf:Property ;
    rdfs:label 'Discovery Phase' ;
    rdfs:comment 'The development or operational phase during which the defect was discovered. Drives cost-of-quality analysis — defects found in live operations are significantly more expensive to remediate than those found in QA. [ENUM-REF-CANDIDATE: qa|playtesting|uat|live_ops|certification|alpha|beta|pre_production — promote to reference product]' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixVersion rdf:type rdf:Property ;
    rdfs:label 'Fix Version' ;
    rdfs:comment 'The planned or actual game build version in which this defect is targeted to be resolved. Set during triage and updated as sprint planning evolves. Maps to Jira \'Fix Version/s\' field.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasWaiver rdf:type rdf:Property ;
    rdfs:label 'Has Waiver' ;
    rdfs:comment 'Indicates whether a formal risk-acceptance waiver has been granted for this defect, allowing the game to ship with the known issue. True = waiver approved. Critical for release governance and post-launch accountability.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEscalated rdf:type rdf:Property ;
    rdfs:label 'Is Escalated' ;
    rdfs:comment 'Indicates whether this defect has been escalated beyond the standard triage process, typically due to severity, compliance impact, or executive visibility. True = escalated. Triggers additional reporting and stakeholder notification workflows.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:linkedJiraIssueKeys rdf:type rdf:Property ;
    rdfs:label 'Linked Jira Issue Keys' ;
    rdfs:comment 'Comma-separated list of related Jira issue keys (e.g., duplicate of, blocks, is blocked by, relates to). Preserves the Jira issue link graph in denormalized form for Silver layer analytics without requiring a separate junction table at this stage.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regressionIntroducedVersion rdf:type rdf:Property ;
    rdfs:label 'Regression Introduced Version' ;
    rdfs:comment 'The build version in which the regression was reintroduced, if is_regression is True. Used to identify the offending code change or asset update via Perforce Helix Core history. Null if not a regression.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reported Timestamp' ;
    rdfs:comment 'The date and time when the defect was first reported and logged in Jira. Serves as the BUSINESS_EVENT_TIMESTAMP for this transaction. Used to calculate defect age, SLA compliance, and time-to-triage metrics.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reproducibility rdf:type rdf:Property ;
    rdfs:label 'Reproducibility' ;
    rdfs:comment 'Indicates how consistently the defect can be reproduced following the documented reproduction steps. Always = 100% reproducible; Intermittent = occurs sometimes; Rare = very infrequent; Unable to Reproduce = cannot be replicated. Affects triage priority and fix confidence.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triageDate rdf:type rdf:Property ;
    rdfs:label 'Triage Date' ;
    rdfs:comment 'The date on which the defect was formally triaged by the QA lead and development team. Captures the most recent triage event date. Used to measure time-to-triage SLA compliance.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:triageOutcome rdf:type rdf:Property ;
    rdfs:label 'Triage Outcome' ;
    rdfs:comment 'The formal decision reached during the most recent triage session. Accepted = will be fixed; Deferred = moved to a future release; Rejected = not a valid defect; Duplicate = already tracked under another issue; Won\'t Fix = known issue accepted as-is.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triageParticipants rdf:type rdf:Property ;
    rdfs:label 'Triage Participants' ;
    rdfs:comment 'Comma-separated list of workforce member names or IDs who participated in the triage session. Provides accountability and audit trail for triage decisions. Stored as a denormalized string for Silver layer simplicity.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprover rdf:type rdf:Property ;
    rdfs:label 'Waiver Approver' ;
    rdfs:comment 'Name or identifier of the authorized individual (e.g., QA Director, Studio Head, Legal) who approved the non-certification waiver. Provides accountability for risk-acceptance decisions.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectTriageId rdf:type rdf:Property ;
    rdfs:label 'Defect Triage Id' ;
    rdfs:comment 'Unique surrogate identifier for the defect triage event record in the quality domain Silver layer.' ;
    rdfs:domain ind:DefectTriage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDefectEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Defect Employee Id' ;
    rdfs:comment 'Reference to the employee or QA lead who chaired the triage session and is accountable for the triage outcome decision. Maps to the workforce/employee entity.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryDefectReporterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Defect Reporter Employee Id' ;
    rdfs:comment 'Reference to the QA tester, player support agent, or community manager who originally reported the defect. Maps to the workforce/employee entity. Corresponds to the Jira \'Reporter\' field.' ;
    rdfs:domain ind:DefectTriage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedGameArea rdf:type rdf:Property ;
    rdfs:label 'Affected Game Area' ;
    rdfs:comment 'The functional area or system of the game affected by the defect (e.g., \'FTUE\', \'PvP Matchmaking\', \'In-Game Store/MTX\', \'NPC AI\', \'Audio\', \'UI/HUD\', \'Save System\'). Sourced from Jira component field. Enables area-level defect density analysis.' ;
    rdfs:domain ind:DefectTriage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedGameVersion rdf:type rdf:Property ;
    rdfs:label 'Affected Game Version' ;
    rdfs:comment 'The game build version string in which the defect was first observed (e.g., 1.4.2.1087). Aligns with the version label tracked in Perforce Helix Core and Jira fix version fields.' ;
    rdfs:domain ind:DefectTriage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Risk Flag' ;
    rdfs:comment 'Indicates whether this defect poses a risk to platform certification submission (TRC/TCR compliance for console platforms such as PlayStation, Xbox, or Nintendo). True = certification risk identified during triage.' ;
    rdfs:domain ind:DefectTriage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:duplicateOfJiraKey rdf:type rdf:Property ;
    rdfs:label 'Duplicate Of Jira Key' ;
    rdfs:comment 'When triage_outcome is \'duplicate\', this field records the Jira issue key of the canonical (master) defect that this issue duplicates. Enables duplicate chain analysis and defect deduplication reporting.' ;
    rdfs:domain ind:DefectTriage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedFixEffort rdf:type rdf:Property ;
    rdfs:label 'Estimated Fix Effort' ;
    rdfs:comment 'T-shirt size estimate of the engineering effort required to resolve the defect, as assessed during triage. Used for sprint capacity planning in Jira and release schedule risk assessment.' ;
    rdfs:domain ind:DefectTriage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liveOpsImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Live Ops Impact Flag' ;
    rdfs:comment 'Indicates whether the defect affects live service operations such as GaaS event scheduling, in-game store/MTX transactions, matchmaking, or DAU/MAU tracking. True = live ops team must be notified. Critical for games operating under a Game-as-a-Service (GaaS) model.' ;
    rdfs:domain ind:DefectTriage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monetizationImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Monetization Impact Flag' ;
    rdfs:comment 'Indicates whether the defect directly impacts in-game monetization flows including IAP, MTX, virtual currency, or the in-game store. True = revenue risk; requires immediate escalation to monetization and finance teams.' ;
    rdfs:domain ind:DefectTriage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:playerFacingFlag rdf:type rdf:Property ;
    rdfs:label 'Player Facing Flag' ;
    rdfs:comment 'Indicates whether the defect is visible or impactful to end players (True) versus being an internal/backend-only issue (False). Influences prioritization, player communication decisions, and NPS/CSAT risk assessment.' ;
    rdfs:domain ind:DefectTriage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postTriagePriority rdf:type rdf:Property ;
    rdfs:label 'Post Triage Priority' ;
    rdfs:comment 'The official fix priority assigned during triage, reflecting urgency relative to release schedule and business impact. \'blocker\' indicates the defect must be resolved before any release can proceed; used to drive sprint backlog ordering in Jira.' ;
    rdfs:domain ind:DefectTriage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postTriageSeverity rdf:type rdf:Property ;
    rdfs:label 'Post Triage Severity' ;
    rdfs:comment 'The official defect severity level confirmed or reassigned by the triage panel after deliberation. Severity reflects the impact of the defect on game functionality, player experience, or platform certification compliance (e.g., critical = game-breaking crash or TRC/TCR failure).' ;
    rdfs:domain ind:DefectTriage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preTriageSeverity rdf:type rdf:Property ;
    rdfs:label 'Pre Triage Severity' ;
    rdfs:comment 'The defect severity level assigned by the reporter or QA engineer prior to the formal triage session. Captured to enable comparison with post-triage severity and measure triage calibration accuracy.' ;
    rdfs:domain ind:DefectTriage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseGateImpact rdf:type rdf:Property ;
    rdfs:label 'Release Gate Impact' ;
    rdfs:comment 'Classification of how this defect impacts the release quality gate decision. \'blocks_release\' means the defect must be fixed before any release; \'blocks_certification\' means it prevents platform submission; \'watch_list\' means it is monitored but does not block; \'no_impact\' means it does not affect release readiness.' ;
    rdfs:domain ind:DefectTriage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetFixSprint rdf:type rdf:Property ;
    rdfs:label 'Target Fix Sprint' ;
    rdfs:comment 'The Jira sprint name or identifier to which the defect fix has been assigned during triage (e.g., \'Sprint 42 - Gold Candidate\'). Enables sprint-level defect burn-down reporting.' ;
    rdfs:domain ind:DefectTriage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetFixVersion rdf:type rdf:Property ;
    rdfs:label 'Target Fix Version' ;
    rdfs:comment 'The planned game release version in which the defect fix is scheduled to be delivered, as assigned during triage. Drives sprint planning in Jira and release readiness gate tracking.' ;
    rdfs:domain ind:DefectTriage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triageNotes rdf:type rdf:Property ;
    rdfs:label 'Triage Notes' ;
    rdfs:comment 'Free-text notes recorded during the triage session capturing discussion context, decision rationale, open questions, or conditions attached to the triage outcome. Sourced from Jira comment or triage meeting minutes.' ;
    rdfs:domain ind:DefectTriage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triageParticipantCount rdf:type rdf:Property ;
    rdfs:label 'Triage Participant Count' ;
    rdfs:comment 'The number of stakeholders who participated in the triage session for this defect (e.g., QA lead, producer, engineer, platform compliance officer). Supports governance and quorum validation for triage decisions.' ;
    rdfs:domain ind:DefectTriage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:triageParticipantRoles rdf:type rdf:Property ;
    rdfs:label 'Triage Participant Roles' ;
    rdfs:comment 'Comma-separated list of functional roles represented in the triage session (e.g., \'QA Lead, Producer, Platform Engineer, Compliance Officer\'). Captures governance breadth without storing individual PII.' ;
    rdfs:domain ind:DefectTriage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triageSlaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Triage Sla Breach Flag' ;
    rdfs:comment 'Indicates whether the triage event occurred outside the defined SLA window for the defect\'s severity level (e.g., critical defects must be triaged within 4 hours). True = SLA was breached. Supports QA process compliance reporting.' ;
    rdfs:domain ind:DefectTriage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:triageStatus rdf:type rdf:Property ;
    rdfs:label 'Triage Status' ;
    rdfs:comment 'Current lifecycle state of the triage event itself. \'pending\' indicates triage is scheduled but not yet conducted; \'in_progress\' indicates the triage session is active; \'completed\' indicates a final disposition has been recorded; \'cancelled\' indicates the triage was abandoned.' ;
    rdfs:domain ind:DefectTriage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triageTimestamp rdf:type rdf:Property ;
    rdfs:label 'Triage Timestamp' ;
    rdfs:comment 'The precise date and time (ISO 8601 with timezone offset) at which the triage decision was recorded in Jira. Distinct from triage_date which captures day-level scheduling; this field captures the exact workflow transition moment.' ;
    rdfs:domain ind:DefectTriage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:workaroundAvailable rdf:type rdf:Property ;
    rdfs:label 'Workaround Available' ;
    rdfs:comment 'Indicates whether a player-facing or operational workaround exists for the defect, as determined during triage. True = a workaround has been identified and documented, which may influence deferral decisions.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workaroundDescription rdf:type rdf:Property ;
    rdfs:label 'Workaround Description' ;
    rdfs:comment 'Free-text description of the available workaround for the defect. Populated only when workaround_available is True. Used by player support (Zendesk) and community management teams to communicate interim guidance.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectWaiverId rdf:type rdf:Property ;
    rdfs:label 'Defect Waiver Id' ;
    rdfs:comment 'Unique system-generated identifier for each defect waiver record. Primary key for the defect_waiver data product in the quality domain.' ;
    rdfs:domain ind:DefectWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalConditions rdf:type rdf:Property ;
    rdfs:label 'Approval Conditions' ;
    rdfs:comment 'Any conditions or stipulations attached to the waiver approval by the approver (e.g., mandatory hotfix within 30 days, player communication required, specific monitoring thresholds must be met). Null for unconditional approvals or rejected waivers.' ;
    rdfs:domain ind:DefectWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coppaComplianceImpact rdf:type rdf:Property ;
    rdfs:label 'Coppa Compliance Impact' ;
    rdfs:comment 'Indicates whether the waived defect could impact COPPA compliance, particularly for games with under-13 player populations. True requires legal review before waiver approval.' ;
    rdfs:domain ind:DefectWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationThreshold rdf:type rdf:Property ;
    rdfs:label 'Escalation Threshold' ;
    rdfs:comment 'Defined threshold value for the monitoring KPI that, if exceeded post-launch, triggers mandatory escalation and emergency patch consideration (e.g., crash rate > 0.5%, support tickets > 500/day). Expressed as a string to accommodate varied metric formats.' ;
    rdfs:domain ind:DefectWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esrbComplianceImpact rdf:type rdf:Property ;
    rdfs:label 'Esrb Compliance Impact' ;
    rdfs:comment 'Indicates whether the waived defect has any potential impact on ESRB rating compliance (e.g., unintended content exposure, age-gating bypass). True requires ESRB notification review before waiver approval.' ;
    rdfs:domain ind:DefectWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fixTargetDate rdf:type rdf:Property ;
    rdfs:label 'Fix Target Date' ;
    rdfs:comment 'Planned calendar date by which the waived defect is committed to be resolved in a post-launch patch or update. Used to track remediation SLA compliance and waiver expiry alignment.' ;
    rdfs:domain ind:DefectWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fixTargetVersion rdf:type rdf:Property ;
    rdfs:label 'Fix Target Version' ;
    rdfs:comment 'The planned game build version or patch release in which the waived defect is scheduled to be resolved post-launch. Establishes the post-launch remediation commitment tied to the waiver approval.' ;
    rdfs:domain ind:DefectWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprComplianceImpact rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliance Impact' ;
    rdfs:comment 'Indicates whether the waived defect could impact GDPR compliance, such as data exposure, consent mechanism failure, or player data handling issues. True requires Data Protection Officer review before waiver approval.' ;
    rdfs:domain ind:DefectWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCertBlocking rdf:type rdf:Property ;
    rdfs:label 'Is Cert Blocking' ;
    rdfs:comment 'Indicates whether the waived defect was originally classified as a platform certification blocker (TRC/TCR blocking finding). True signals that platform holder approval or exception was required in addition to internal waiver approval.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monitoringKpi rdf:type rdf:Property ;
    rdfs:label 'Monitoring Kpi' ;
    rdfs:comment 'Specific KPI or telemetry metric used to monitor the waived defect post-launch (e.g., crash rate threshold, defect reproduction rate per session, support ticket volume). Triggers escalation if breached.' ;
    rdfs:domain ind:DefectWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pegiComplianceImpact rdf:type rdf:Property ;
    rdfs:label 'Pegi Compliance Impact' ;
    rdfs:comment 'Indicates whether the waived defect has any potential impact on PEGI rating compliance in European markets. True requires PEGI authority review before waiver approval.' ;
    rdfs:domain ind:DefectWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformHolderAcknowledgment rdf:type rdf:Property ;
    rdfs:label 'Platform Holder Acknowledgment' ;
    rdfs:comment 'Indicates whether the relevant platform holder (Sony, Microsoft, Nintendo, Apple, Google) has formally acknowledged or accepted the certification finding waiver. Required for cert-blocking issues before release approval.' ;
    rdfs:domain ind:DefectWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:playerImpactScope rdf:type rdf:Property ;
    rdfs:label 'Player Impact Scope' ;
    rdfs:comment 'Estimated breadth of player population affected by the waived defect. Informs risk level and post-launch monitoring intensity. Ranges from all players (systemic issue) to single player (isolated edge case).' ;
    rdfs:domain ind:DefectWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postLaunchMonitoringPlan rdf:type rdf:Property ;
    rdfs:label 'Post Launch Monitoring Plan' ;
    rdfs:comment 'Description of the monitoring commitment made as a condition of waiver approval. Specifies telemetry signals, crash reporting thresholds, player support ticket triggers, and escalation criteria that will be tracked post-launch via GameAnalytics/Amplitude and Zendesk.' ;
    rdfs:domain ind:DefectWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseVersion rdf:type rdf:Property ;
    rdfs:label 'Release Version' ;
    rdfs:comment 'The planned release version (e.g., v1.0.0, v2.3.1) in which the waived defect will ship to players. Used to scope the waiver to a specific product release and track post-launch remediation.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reproductionRatePct rdf:type rdf:Property ;
    rdfs:label 'Reproduction Rate Pct' ;
    rdfs:comment 'Percentage rate at which the defect can be reproduced under standard test conditions (0.00–100.00). Low reproduction rates strengthen the waiver justification; high rates require stronger risk mitigation commitments.' ;
    rdfs:domain ind:DefectWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'Calendar date on which the defect waiver was formally submitted by the requestor. Marks the start of the waiver review process and is used to measure approval cycle time.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverCategory rdf:type rdf:Property ;
    rdfs:label 'Waiver Category' ;
    rdfs:comment 'Functional area of the game affected by the waived defect. Used for trend analysis and quality reporting across release gates. [ENUM-REF-CANDIDATE: gameplay|audio|visual|performance|stability|ui_ux|network|security|accessibility|localization|monetization — promote to reference product]' ;
    rdfs:domain ind:DefectWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverCode rdf:type rdf:Property ;
    rdfs:label 'Waiver Code' ;
    rdfs:comment 'Human-readable, externally referenceable unique code for this waiver (e.g., WVR-2024-0042). Used in Jira comments, release notes, and certification submissions to cross-reference the formal waiver document.' ;
    rdfs:domain ind:DefectWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverType rdf:type rdf:Property ;
    rdfs:label 'Waiver Type' ;
    rdfs:comment 'Classification of the waiver by the nature of the quality exception being accepted. Distinguishes between defect waivers, platform certification finding waivers (TRC/TCR), performance benchmark waivers, compliance waivers, and regression waivers. [ENUM-REF-CANDIDATE: defect_waiver|cert_finding_waiver|performance_waiver|compliance_waiver|regression_waiver|uat_waiver — promote to reference product]' ;
    rdfs:domain ind:DefectWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perfTestRunId rdf:type rdf:Property ;
    rdfs:label 'Perf Test Run Id' ;
    rdfs:comment 'Unique surrogate identifier for each performance test run record. Primary key for the perf_test_run data product in the quality domain.' ;
    rdfs:domain ind:PerfTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Executed By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Performance test execution requires tracking which QA engineer ran the test for accountability, scheduling conflict resolution, and expertise matching. Critical for capacity planning and SLA complianc' ;
    rdfs:domain ind:PerfTestRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:stabilityBenchmarkId rdf:type rdf:Property ;
    rdfs:label 'Stability Benchmark Id' ;
    rdfs:comment 'Foreign key linking to quality.stability_benchmark. Business justification: Performance test runs validate against stability benchmarks. perf_test_run has fps_benchmark_threshold and memory_budget_mb but no FK to stability_benchmark. Benchmarks define approved thresholds. Car' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StabilityBenchmark .

ind:avgCpuUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'Avg Cpu Utilization Pct' ;
    rdfs:comment 'Mean CPU utilization percentage recorded across all active cores during the test run. Used to assess CPU headroom, identify bottlenecks, and validate that the build does not exceed platform CPU budget thresholds.' ;
    rdfs:domain ind:PerfTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgFps rdf:type rdf:Property ;
    rdfs:label 'Avg Fps' ;
    rdfs:comment 'The mean Frames Per Second (FPS) recorded across the full duration of the test run. Primary rendering performance KPI used in release gate pass/fail evaluation and regression comparison.' ;
    rdfs:domain ind:PerfTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgFrameTimeMs rdf:type rdf:Property ;
    rdfs:label 'Avg Frame Time Ms' ;
    rdfs:comment 'The mean time in milliseconds to render a single frame during the test run. Complements FPS metrics by providing a direct measure of rendering latency. Target thresholds vary by platform (e.g., 16.67ms for 60 FPS, 33.33ms for 30 FPS).' ;
    rdfs:domain ind:PerfTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgGpuUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'Avg Gpu Utilization Pct' ;
    rdfs:comment 'Mean GPU utilization percentage recorded during the test run. Used to assess GPU headroom and rendering pipeline efficiency. High GPU utilization with low FPS indicates a GPU bottleneck.' ;
    rdfs:domain ind:PerfTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgMemoryUsageMb rdf:type rdf:Property ;
    rdfs:label 'Avg Memory Usage Mb' ;
    rdfs:comment 'Mean RAM consumption in megabytes across the full duration of the test run. Used alongside peak memory to assess memory stability and detect memory leaks during soak tests.' ;
    rdfs:domain ind:PerfTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgNetworkLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Avg Network Latency Ms' ;
    rdfs:comment 'Mean round-trip network latency in milliseconds measured during the test run. Relevant for online multiplayer (PvP, MMO, GaaS) titles. High latency degrades player experience and is a key quality gate metric for live service games.' ;
    rdfs:domain ind:PerfTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ccuAchieved rdf:type rdf:Property ;
    rdfs:label 'Ccu Achieved' ;
    rdfs:comment 'The actual number of Concurrent Users (CCU) successfully simulated or observed during the test run. For CCU/PCU simulation scenarios, this represents the peak concurrent load achieved before performance degradation or failure. Key metric for GaaS live operations capacity planning.' ;
    rdfs:domain ind:PerfTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ccuTarget rdf:type rdf:Property ;
    rdfs:label 'Ccu Target' ;
    rdfs:comment 'The target number of Concurrent Users (CCU) defined for this test run scenario. Compared against ccu_achieved to determine if the build meets the required concurrency capacity for release.' ;
    rdfs:domain ind:PerfTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certReadinessStatus rdf:type rdf:Property ;
    rdfs:label 'Cert Readiness Status' ;
    rdfs:comment 'Assessment of whether this build\'s performance results meet platform certification requirements (TRC/TCR). \'not_assessed\' = certification review not yet performed; \'ready\' = performance meets all TRC/TCR thresholds; \'not_ready\' = performance fails one or more TRC/TCR requirements; \'waiver_pending\' = exception waiver submitted to platform holder.' ;
    rdfs:domain ind:PerfTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gameModeTested rdf:type rdf:Property ;
    rdfs:label 'Game Mode Tested' ;
    rdfs:comment 'The specific game mode or scenario exercised during the performance test (e.g., \'PvP_Arena_64Player\', \'PvE_OpenWorld\', \'MainMenu\', \'FTUE_Tutorial\', \'MMO_Hub_Zone\'). Enables performance comparison across game modes.' ;
    rdfs:domain ind:PerfTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hardwareConfigProfile rdf:type rdf:Property ;
    rdfs:label 'Hardware Config Profile' ;
    rdfs:comment 'Label or identifier of the hardware configuration profile used during the test run (e.g., \'PS5-Standard\', \'PC-MinSpec\', \'PC-RecommendedSpec\', \'iOS-iPhone14\'). Captures the device/hardware tier to contextualize performance results.' ;
    rdfs:domain ind:PerfTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minFps rdf:type rdf:Property ;
    rdfs:label 'Min Fps' ;
    rdfs:comment 'The lowest Frames Per Second (FPS) value recorded during the test run. Critical for identifying frame rate drops, stutters, and worst-case rendering performance that impact player experience.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallResult rdf:type rdf:Property ;
    rdfs:label 'Overall Result' ;
    rdfs:comment 'The overall pass/fail determination for this performance test run against all defined benchmarks. \'pass\' = all benchmarks met; \'fail\' = one or more benchmarks not met; \'conditional_pass\' = passed with documented exceptions approved by QA lead; \'inconclusive\' = run completed but results are insufficient for a determination.' ;
    rdfs:domain ind:PerfTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:p99FrameTimeMs rdf:type rdf:Property ;
    rdfs:label 'P99 Frame Time Ms' ;
    rdfs:comment 'The 99th percentile frame time in milliseconds, representing worst-case frame rendering latency excluding the top 1% of outliers. Used to detect hitching and micro-stutter patterns that degrade player experience even when average FPS appears acceptable.' ;
    rdfs:domain ind:PerfTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakCpuUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'Peak Cpu Utilization Pct' ;
    rdfs:comment 'Maximum CPU utilization percentage observed at any point during the test run. Identifies CPU spike events that may cause frame drops or game freezes under peak load conditions.' ;
    rdfs:domain ind:PerfTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakFps rdf:type rdf:Property ;
    rdfs:label 'Peak Fps' ;
    rdfs:comment 'The highest Frames Per Second (FPS) value recorded during the test run. Used to assess maximum rendering throughput and identify performance ceiling for the build on the target platform.' ;
    rdfs:domain ind:PerfTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakGpuUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'Peak Gpu Utilization Pct' ;
    rdfs:comment 'Maximum GPU utilization percentage observed at any point during the test run. Identifies GPU saturation events that may cause rendering bottlenecks or thermal throttling on target hardware.' ;
    rdfs:domain ind:PerfTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakMemoryUsageMb rdf:type rdf:Property ;
    rdfs:label 'Peak Memory Usage Mb' ;
    rdfs:comment 'Maximum RAM consumption in megabytes observed during the test run. Critical for platform certification compliance — console and mobile platforms enforce strict memory budgets (e.g., TRC/TCR memory limits). Exceeding this threshold is a certification blocker.' ;
    rdfs:domain ind:PerfTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakNetworkLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Peak Network Latency Ms' ;
    rdfs:comment 'Maximum round-trip network latency in milliseconds observed during the test run. Identifies worst-case latency spikes that may cause rubber-banding, desync, or disconnection events in online multiplayer scenarios.' ;
    rdfs:domain ind:PerfTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorBuildVersion rdf:type rdf:Property ;
    rdfs:label 'Prior Build Version' ;
    rdfs:comment 'The build version used as the regression baseline for comparison in this test run. Populated when is_regression evaluation is performed. Enables direct traceability to the specific prior build whose metrics were used as the performance baseline.' ;
    rdfs:domain ind:PerfTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regressionDeltaFps rdf:type rdf:Property ;
    rdfs:label 'Regression Delta Fps' ;
    rdfs:comment 'The difference in average FPS between this build and the prior build baseline (current avg_fps minus prior avg_fps). Negative values indicate FPS regression. Null when no prior baseline exists or regression comparison was not performed.' ;
    rdfs:domain ind:PerfTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releaseGateApproved rdf:type rdf:Property ;
    rdfs:label 'Release Gate Approved' ;
    rdfs:comment 'Indicates whether this performance test run result has been reviewed and approved as part of the release quality gate process. True = approved by QA lead/release manager; False = not yet approved or approval denied. Required before build promotion to certification or production.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:runNotes rdf:type rdf:Property ;
    rdfs:label 'Run Notes' ;
    rdfs:comment 'Free-text field for QA engineers to document observations, anomalies, environmental conditions, or context relevant to this test run (e.g., \'Server under maintenance during run\', \'Thermal throttling observed on device\'). Supports qualitative analysis alongside quantitative metrics.' ;
    rdfs:domain ind:PerfTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Run Reference Code' ;
    rdfs:comment 'Externally-known, human-readable unique code assigned to this performance test run (e.g., PTR-FTUE-20240315-0042). Used in Jira tickets, QA reports, and release gate documentation to reference a specific run.' ;
    rdfs:domain ind:PerfTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run Timestamp' ;
    rdfs:comment 'The precise date and time (ISO 8601 with timezone offset) at which the performance test run was initiated. This is the principal business event timestamp for this transaction record.' ;
    rdfs:domain ind:PerfTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:testDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Test Duration Seconds' ;
    rdfs:comment 'Total elapsed time in seconds from test run start to completion or abort. Used to validate that soak tests ran for the required duration and to normalize performance metrics across runs of different lengths.' ;
    rdfs:domain ind:PerfTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testScenarioType rdf:type rdf:Property ;
    rdfs:label 'Test Scenario Type' ;
    rdfs:comment 'Classification of the performance test scenario executed. \'load_test\' = normal expected load; \'stress_test\' = beyond normal capacity; \'soak_test\' = sustained load over time; \'fps_benchmark\' = Frames Per Second (FPS) measurement; \'latency_test\' = network latency measurement; \'ccu_simulation\' = Concurrent Users (CCU)/Peak Concurrent Users (PCU) simulation.' ;
    rdfs:domain ind:PerfTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playtestFeedbackId rdf:type rdf:Property ;
    rdfs:label 'Playtest Feedback Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual playtest feedback record captured during a playtesting session. Primary key for this entity. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:PlaytestFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessibilityConcern rdf:type rdf:Property ;
    rdfs:label 'Accessibility Concern' ;
    rdfs:comment 'Indicates whether this feedback item identifies an accessibility issue (e.g., colorblind mode, subtitle readability, motor accessibility). Supports compliance with accessibility standards and inclusive design commitments.' ;
    rdfs:domain ind:PlaytestFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actionedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actioned Timestamp' ;
    rdfs:comment 'The date and time when this feedback item was first actioned (triaged, assigned, or converted to a Jira issue) by the QA team. Used to measure triage cycle time and QA team responsiveness.' ;
    rdfs:domain ind:PlaytestFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:feedbackReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Feedback Reference Code' ;
    rdfs:comment 'Human-readable, externally referenceable business identifier for this feedback item (e.g., PF-20240101). Used in QA reports, stakeholder communications, and cross-system traceability. Distinct from the surrogate PK.' ;
    rdfs:domain ind:PlaytestFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackSourceType rdf:type rdf:Property ;
    rdfs:label 'Feedback Source Type' ;
    rdfs:comment 'The method or channel through which the feedback was collected during the playtesting session (e.g., written form, verbal debrief, in-game feedback tool, structured survey, facilitator observation).' ;
    rdfs:domain ind:PlaytestFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackText rdf:type rdf:Property ;
    rdfs:label 'Feedback Text' ;
    rdfs:comment 'The raw, verbatim feedback text as provided by the playtesting participant. Captures unstructured qualitative input for NLP analysis, sentiment classification, and QA team review. Classified confidential as it may contain unreleased game content details.' ;
    rdfs:domain ind:PlaytestFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackTimestamp rdf:type rdf:Property ;
    rdfs:label 'Feedback Timestamp' ;
    rdfs:comment 'The precise date and time (ISO 8601 with timezone) when this feedback item was recorded during the playtesting session. The principal business event timestamp for this transaction record.' ;
    rdfs:domain ind:PlaytestFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fpsAtEvent rdf:type rdf:Property ;
    rdfs:label 'Fps At Event' ;
    rdfs:comment 'The measured Frames Per Second (FPS) recorded on the test device at the moment the feedback event occurred. Key performance metric for identifying frame rate drops correlated with player experience complaints.' ;
    rdfs:domain ind:PlaytestFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gameComponent rdf:type rdf:Property ;
    rdfs:label 'Game Component' ;
    rdfs:comment 'The specific game system, feature, or module associated with this feedback item (e.g., inventory_system, matchmaking, character_controller, hud, tutorial_flow). Maps to development team ownership for routing and accountability.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActioned rdf:type rdf:Property ;
    rdfs:label 'Is Actioned' ;
    rdfs:comment 'Indicates whether this feedback item has been reviewed and actioned by the development or QA team (e.g., converted to a Jira ticket, acknowledged, or formally deferred). Core operational flag for feedback triage workflow management.' ;
    rdfs:domain ind:PlaytestFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFtueRelated rdf:type rdf:Property ;
    rdfs:label 'Is Ftue Related' ;
    rdfs:comment 'Indicates whether this feedback item is specifically related to the First-Time User Experience (FTUE) flow. FTUE feedback is prioritized for pre-launch analysis as it directly impacts Day 1 (D1) retention metrics.' ;
    rdfs:domain ind:PlaytestFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReleaseBlocker rdf:type rdf:Property ;
    rdfs:label 'Is Release Blocker' ;
    rdfs:comment 'Indicates whether this feedback item has been classified as a release blocker that must be resolved before the game can pass the release quality gate. Directly feeds into the release readiness dashboard.' ;
    rdfs:domain ind:PlaytestFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:levelOrArea rdf:type rdf:Property ;
    rdfs:label 'Level Or Area' ;
    rdfs:comment 'The specific game level, map, zone, or area within the game where the feedback event occurred (e.g., level_01_tutorial, zone_darkwood_forest, hub_main_menu). Enables spatial analysis of player experience issues.' ;
    rdfs:domain ind:PlaytestFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneTarget rdf:type rdf:Property ;
    rdfs:label 'Milestone Target' ;
    rdfs:comment 'The release milestone by which this feedback item must be resolved (e.g., Alpha, Beta, Gold Master, Day-One Patch). Directly supports release quality gate management and Gold Master readiness tracking.' ;
    rdfs:domain ind:PlaytestFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantSkillLevel rdf:type rdf:Property ;
    rdfs:label 'Participant Skill Level' ;
    rdfs:comment 'Self-reported or assessed skill level of the playtesting participant. Enables difficulty calibration analysis by correlating feedback sentiment and severity with player skill level, particularly for difficulty tuning.' ;
    rdfs:domain ind:PlaytestFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityRating rdf:type rdf:Property ;
    rdfs:label 'Priority Rating' ;
    rdfs:comment 'Business priority assigned to this feedback item by the QA lead or product owner, indicating urgency of resolution relative to the release schedule. Distinct from severity: a cosmetic bug may be low severity but high priority near launch.' ;
    rdfs:domain ind:PlaytestFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaAnalystNotes rdf:type rdf:Property ;
    rdfs:label 'Qa Analyst Notes' ;
    rdfs:comment 'Internal notes added by the QA analyst during triage or review of this feedback item. May include reproduction steps, environmental context, or cross-reference to related defects. Confidential internal working notes.' ;
    rdfs:domain ind:PlaytestFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentiment rdf:type rdf:Property ;
    rdfs:label 'Sentiment' ;
    rdfs:comment 'Sentiment classification of the feedback item as determined by QA analyst review or automated NLP processing. Indicates the emotional tone of the participant\'s response to the game experience.' ;
    rdfs:domain ind:PlaytestFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionElapsedMinutes rdf:type rdf:Property ;
    rdfs:label 'Session Elapsed Minutes' ;
    rdfs:comment 'The elapsed time in minutes from the start of the playtesting session to the moment this feedback item was recorded. Enables temporal analysis of when in a session players encounter issues, particularly for First-Time User Experience (FTUE) analysis.' ;
    rdfs:domain ind:PlaytestFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sprintTarget rdf:type rdf:Property ;
    rdfs:label 'Sprint Target' ;
    rdfs:comment 'The Jira sprint identifier in which the resolution of this feedback item is planned (e.g., Sprint_42). Enables sprint-level quality planning and velocity tracking for QA-driven development work.' ;
    rdfs:domain ind:PlaytestFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suggestedFix rdf:type rdf:Property ;
    rdfs:label 'Suggested Fix' ;
    rdfs:comment 'Optional free-text field capturing the participant\'s or QA analyst\'s suggested resolution or improvement for the identified issue. Provides actionable input to the development team during sprint planning.' ;
    rdfs:domain ind:PlaytestFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testType rdf:type rdf:Property ;
    rdfs:label 'Test Type' ;
    rdfs:comment 'Classification of the type of playtesting activity during which this feedback was collected. Distinguishes internal QA, external beta, User Acceptance Testing (UAT), focus groups, alpha testing, and platform certification testing.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantPlayerAccountId rdf:type rdf:Property ;
    rdfs:label 'Participant Player Account Id' ;
    rdfs:comment 'Foreign key linking to player.player_account. Business justification: Playtest sessions recruit specific player accounts (often from targeted segments like high-engagement or VIP players) to participate in closed alpha/beta tests. Recruitment tracking, NDA enforcement, ' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerAccount .

ind:accessibilityEvaluated rdf:type rdf:Property ;
    rdfs:label 'Accessibility Evaluated' ;
    rdfs:comment 'Indicates whether accessibility features (e.g., colorblind modes, subtitle options, motor accessibility controls) were formally evaluated during this session. Supports compliance with platform holder accessibility requirements and IGDA accessibility guidelines.' ;
    rdfs:domain ind:PlaytestSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:avgFpsRecorded rdf:type rdf:Property ;
    rdfs:label 'Avg Fps Recorded' ;
    rdfs:comment 'Average frames per second (FPS) measured across the session when performance_evaluated is true. A primary technical quality metric for game stability and player experience. Compared against platform-specific FPS targets (e.g., 30 FPS, 60 FPS).' ;
    rdfs:domain ind:PlaytestSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bugsLoggedCount rdf:type rdf:Property ;
    rdfs:label 'Bugs Logged Count' ;
    rdfs:comment 'Total number of defects and bugs formally logged in Jira as a direct result of this playtesting session. Provides a quantitative measure of session productivity and build quality.' ;
    rdfs:domain ind:PlaytestSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:buildLabel rdf:type rdf:Property ;
    rdfs:label 'Build Label' ;
    rdfs:comment 'Human-readable label or codename assigned to the game build in Perforce Helix Core (e.g., \'Alpha-Sprint-42\', \'RC1-Candidate\', \'Gold-Master-Candidate\'). Complements build_version with a descriptive milestone identifier used in QA communications.' ;
    rdfs:domain ind:PlaytestSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationReadinessStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Readiness Status' ;
    rdfs:comment 'Assessment of the build\'s readiness for submission to platform holder certification (TRC/TCR compliance for PlayStation, Xbox, Nintendo, Apple, Google). Distinct from general release readiness — specifically tracks platform certification gate status.' ;
    rdfs:domain ind:PlaytestSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentCollected rdf:type rdf:Property ;
    rdfs:label 'Consent Collected' ;
    rdfs:comment 'Indicates whether informed consent was collected from all participants prior to the session, including consent for data recording, observation, and use of feedback. Mandatory for GDPR and COPPA compliance when participant data is collected.' ;
    rdfs:domain ind:PlaytestSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crashCount rdf:type rdf:Property ;
    rdfs:label 'Crash Count' ;
    rdfs:comment 'Total number of game crashes or critical application failures observed across all participants during the session. A key stability metric for release readiness gates and platform certification (TRC/TCR) compliance.' ;
    rdfs:domain ind:PlaytestSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:criticalBugsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Bugs Count' ;
    rdfs:comment 'Number of bugs logged from this session classified as Critical or Blocker severity in Jira. Critical bugs are blockers for release and are tracked separately for executive QA dashboards and release quality gates.' ;
    rdfs:domain ind:PlaytestSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:esrbContentFlags rdf:type rdf:Property ;
    rdfs:label 'Esrb Content Flags' ;
    rdfs:comment 'Content descriptors or flags identified during the session that are relevant to ESRB (Entertainment Software Rating Board) or PEGI content rating compliance (e.g., \'Violence\', \'Language\', \'In-Game Purchases\'). Supports rating submission accuracy and regulatory compliance.' ;
    rdfs:domain ind:PlaytestSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftueEvaluated rdf:type rdf:Property ;
    rdfs:label 'Ftue Evaluated' ;
    rdfs:comment 'Indicates whether the First-Time User Experience (FTUE) flow was a specific evaluation objective of this playtesting session. FTUE quality is a critical KPI for player acquisition and D1 retention.' ;
    rdfs:domain ind:PlaytestSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:funRating rdf:type rdf:Property ;
    rdfs:label 'Fun Rating' ;
    rdfs:comment 'Participant-reported fun/enjoyment rating for the game experience, typically on a 1–10 scale collected via post-session survey. A game-industry-specific satisfaction metric distinct from CSAT, capturing the core entertainment value proposition.' ;
    rdfs:domain ind:PlaytestSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:keyFindingsSummary rdf:type rdf:Property ;
    rdfs:label 'Key Findings Summary' ;
    rdfs:comment 'Structured narrative summary of the most significant findings, observations, and insights from the playtesting session. Authored by the facilitator and reviewed by the QA lead. This is the primary qualitative output of the session record.' ;
    rdfs:domain ind:PlaytestSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Indicates whether the playtesting session was conducted on-site at a studio facility, fully remote (participants at home), hybrid, or at a third-party testing lab. Affects logistics, data collection methods, and NDA compliance requirements.' ;
    rdfs:domain ind:PlaytestSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minorParticipantsPresent rdf:type rdf:Property ;
    rdfs:label 'Minor Participants Present' ;
    rdfs:comment 'Indicates whether any participants under the age of 18 (or 13 for COPPA) were present in the session. Triggers enhanced data protection protocols, parental consent requirements, and COPPA compliance procedures.' ;
    rdfs:domain ind:PlaytestSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ndaRequired rdf:type rdf:Property ;
    rdfs:label 'Nda Required' ;
    rdfs:comment 'Indicates whether participants in this session were required to sign a Non-Disclosure Agreement (NDA) prior to participation. Relevant for pre-release builds and external/focus group sessions where IP protection is required.' ;
    rdfs:domain ind:PlaytestSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:participantCountActual rdf:type rdf:Property ;
    rdfs:label 'Participant Count Actual' ;
    rdfs:comment 'Number of participants who actually attended and completed the playtesting session. Compared against participant_count_planned to assess session execution quality and statistical validity of findings.' ;
    rdfs:domain ind:PlaytestSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:participantCountPlanned rdf:type rdf:Property ;
    rdfs:label 'Participant Count Planned' ;
    rdfs:comment 'Number of participants originally scheduled to attend the playtesting session. Used to measure session fill rate and plan QA resource capacity.' ;
    rdfs:domain ind:PlaytestSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceEvaluated rdf:type rdf:Property ;
    rdfs:label 'Performance Evaluated' ;
    rdfs:comment 'Indicates whether performance metrics (FPS, load times, memory usage) were formally measured and evaluated during this playtesting session. Distinguishes performance-focused sessions from pure gameplay/usability sessions.' ;
    rdfs:domain ind:PlaytestSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recommendations rdf:type rdf:Property ;
    rdfs:label 'Recommendations' ;
    rdfs:comment 'Actionable recommendations generated from the session findings, intended for the development team. Includes suggested design changes, bug fix priorities, and areas requiring follow-up testing. Feeds into Jira backlog grooming.' ;
    rdfs:domain ind:PlaytestSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseReadinessFlag rdf:type rdf:Property ;
    rdfs:label 'Release Readiness Flag' ;
    rdfs:comment 'Boolean indicator set by the QA facilitator or lead indicating whether the build tested in this session meets the quality gate criteria for progression to the next release milestone (e.g., Alpha to Beta, RC to Gold Master). A critical input to the release quality gate process.' ;
    rdfs:domain ind:PlaytestSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'Calendar date on which the playtesting session is planned to occur. Used for QA scheduling, resource allocation, and milestone tracking against the game development roadmap.' ;
    rdfs:domain ind:PlaytestSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sessionCode rdf:type rdf:Property ;
    rdfs:label 'Session Code' ;
    rdfs:comment 'Human-readable, externally-known business identifier for the playtesting session (e.g., PLT-2024-000123). Used in Jira tickets, QA reports, and cross-team communications to reference a specific session without exposing the surrogate key.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionObjectives rdf:type rdf:Property ;
    rdfs:label 'Session Objectives' ;
    rdfs:comment 'Structured description of the primary goals and test objectives for this playtesting session (e.g., evaluate FTUE flow, test PvP balance, assess accessibility features, validate performance on target hardware). Sourced from the Jira epic or QA test plan.' ;
    rdfs:domain ind:PlaytestSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionRecordingUrl rdf:type rdf:Property ;
    rdfs:label 'Session Recording Url' ;
    rdfs:comment 'Secure URL to the recorded video or screen capture of the playtesting session stored in the digital asset management system. Confidential as it may contain unreleased game footage and participant interactions. Access controlled per IP protection policy.' ;
    rdfs:domain ind:PlaytestSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usabilityIssuesCount rdf:type rdf:Property ;
    rdfs:label 'Usability Issues Count' ;
    rdfs:comment 'Number of distinct usability issues identified during the session, separate from technical bugs. Usability issues relate to UI/UX clarity, control intuitiveness, and player comprehension failures that impact player experience without being code defects.' ;
    rdfs:domain ind:PlaytestSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryReleaseEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Release Employee Id' ;
    rdfs:comment 'Reference to the employee or team lead who owns and is accountable for this release gate checkpoint and its outcome.' ;
    rdfs:domain ind:ReleaseGate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualFps rdf:type rdf:Property ;
    rdfs:label 'Actual Fps' ;
    rdfs:comment 'The measured Frames Per Second (FPS) achieved by the build under review during performance testing, compared against target_fps to determine benchmark compliance.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualReviewDate rdf:type rdf:Property ;
    rdfs:label 'Actual Review Date' ;
    rdfs:comment 'The date on which the release gate review was actually conducted. Compared against target_review_date to measure schedule adherence.' ;
    rdfs:domain ind:ReleaseGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blockingDefectCriticalCount rdf:type rdf:Property ;
    rdfs:label 'Blocking Defect Critical Count' ;
    rdfs:comment 'Count of open Critical severity defects that are blocking release at the time of this gate review. Critical defects are showstoppers that prevent the game from functioning.' ;
    rdfs:domain ind:ReleaseGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockingDefectMajorCount rdf:type rdf:Property ;
    rdfs:label 'Blocking Defect Major Count' ;
    rdfs:comment 'Count of open Major severity defects that are blocking release at the time of this gate review. Major defects significantly impair gameplay or platform compliance.' ;
    rdfs:domain ind:ReleaseGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockingDefectMinorCount rdf:type rdf:Property ;
    rdfs:label 'Blocking Defect Minor Count' ;
    rdfs:comment 'Count of open Minor severity defects flagged as blocking at the time of this gate review.' ;
    rdfs:domain ind:ReleaseGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conditionResolutionDueDate rdf:type rdf:Property ;
    rdfs:label 'Condition Resolution Due Date' ;
    rdfs:comment 'The deadline by which all conditional approval conditions must be resolved and verified. Applicable only when gate disposition is Conditional Approve.' ;
    rdfs:domain ind:ReleaseGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conditionalApprovalConditions rdf:type rdf:Property ;
    rdfs:label 'Conditional Approval Conditions' ;
    rdfs:comment 'Textual description of the mandatory conditions that must be fulfilled when the gate disposition is Conditional Approve. Null when disposition is not conditional.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coppaComplianceVerified rdf:type rdf:Property ;
    rdfs:label 'Coppa Compliance Verified' ;
    rdfs:comment 'Indicates whether COPPA compliance requirements for children\'s privacy protection have been verified for this build at this gate. Required for titles accessible to players under 13 in the US.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criteriaEvaluatedCount rdf:type rdf:Property ;
    rdfs:label 'Criteria Evaluated Count' ;
    rdfs:comment 'Total number of release readiness criteria evaluated during this gate review, providing a completeness measure for the review process.' ;
    rdfs:domain ind:ReleaseGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:criteriaFailedCount rdf:type rdf:Property ;
    rdfs:label 'Criteria Failed Count' ;
    rdfs:comment 'Number of release readiness criteria that received a failing outcome during this gate review, directly informing the gate disposition decision.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:criteriaPassedCount rdf:type rdf:Property ;
    rdfs:label 'Criteria Passed Count' ;
    rdfs:comment 'Number of release readiness criteria that received a passing outcome during this gate review.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispositionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disposition Timestamp' ;
    rdfs:comment 'The exact date and time when the final gate disposition decision was recorded, providing an authoritative audit timestamp for the release readiness decision.' ;
    rdfs:domain ind:ReleaseGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:escalationItemCount rdf:type rdf:Property ;
    rdfs:label 'Escalation Item Count' ;
    rdfs:comment 'Number of items escalated to senior leadership or executive stakeholders during this gate review for decision-making beyond the gate owner\'s authority.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationNotes rdf:type rdf:Property ;
    rdfs:label 'Escalation Notes' ;
    rdfs:comment 'Free-text description of escalation items raised during the gate review, capturing the nature of the escalation and any decisions made by senior stakeholders.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esrbRatingConfirmed rdf:type rdf:Property ;
    rdfs:label 'Esrb Rating Confirmed' ;
    rdfs:comment 'Indicates whether the ESRB content rating has been confirmed and is consistent with the build under review at this gate. Required for North American distribution.' ;
    rdfs:domain ind:ReleaseGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gateName rdf:type rdf:Property ;
    rdfs:label 'Gate Name' ;
    rdfs:comment 'Human-readable name of the release quality gate checkpoint (e.g., \'Alpha Gate\', \'Beta Gate\', \'Gold Master Gate\', \'Day-1 Patch Gate\').' ;
    rdfs:domain ind:ReleaseGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateNotes rdf:type rdf:Property ;
    rdfs:label 'Gate Notes' ;
    rdfs:comment 'Free-text field capturing additional context, observations, or commentary from the gate review session not captured in structured fields.' ;
    rdfs:domain ind:ReleaseGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateStatus rdf:type rdf:Property ;
    rdfs:label 'Gate Status' ;
    rdfs:comment 'Current lifecycle status of the release gate review. Scheduled: gate is planned but not yet started. In Review: active review in progress. Approved: gate passed and release is cleared. Rejected: gate failed and release is blocked. Conditional Approved: gate passed with conditions that must be resolved. Cancelled: gate was voided.' ;
    rdfs:domain ind:ReleaseGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateType rdf:type rdf:Property ;
    rdfs:label 'Gate Type' ;
    rdfs:comment 'Classification of the release gate stage in the game release pipeline. Alpha indicates early feature-complete review; Beta indicates pre-launch stability review; Gold Master (GM) indicates final ship-ready certification; Patch Release and Hotfix indicate post-launch update gates; RC indicates Release Candidate. [ENUM-REF-CANDIDATE: alpha|beta|gold_master|patch_release|hotfix|rc|uat|certification — promote to reference product]' ;
    rdfs:domain ind:ReleaseGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprComplianceVerified rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliance Verified' ;
    rdfs:comment 'Indicates whether GDPR compliance requirements (data privacy, consent mechanisms, data subject rights) have been verified for this build at this gate. Required for EU distribution.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jiraProjectKey rdf:type rdf:Property ;
    rdfs:label 'Jira Project Key' ;
    rdfs:comment 'The Jira project key associated with this release gate, enabling traceability to the Jira release planning board and sprint backlog.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReviewTargetDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Target Date' ;
    rdfs:comment 'The planned date for the next review iteration of this gate, applicable when the current disposition is Reject or Conditional Approve and a re-review is required.' ;
    rdfs:domain ind:ReleaseGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pciDssComplianceVerified rdf:type rdf:Property ;
    rdfs:label 'Pci Dss Compliance Verified' ;
    rdfs:comment 'Indicates whether PCI DSS compliance for in-game payment processing and In-App Purchase (IAP) flows has been verified at this gate. Required for titles with real-money transactions.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pegiRatingConfirmed rdf:type rdf:Property ;
    rdfs:label 'Pegi Rating Confirmed' ;
    rdfs:comment 'Indicates whether the PEGI content rating has been confirmed and is consistent with the build under review at this gate. Required for European distribution.' ;
    rdfs:domain ind:ReleaseGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceBenchmarkMet rdf:type rdf:Property ;
    rdfs:label 'Performance Benchmark Met' ;
    rdfs:comment 'Indicates whether the build met all defined performance benchmarks (e.g., target Frames Per Second (FPS), load times, memory usage) at the time of this gate review.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewIterationNumber rdf:type rdf:Property ;
    rdfs:label 'Review Iteration Number' ;
    rdfs:comment 'Sequential iteration count for this gate review, supporting multiple review cycles per gate (e.g., iteration 1 = initial review, iteration 2 = re-review after defect remediation).' ;
    rdfs:domain ind:ReleaseGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewParticipants rdf:type rdf:Property ;
    rdfs:label 'Review Participants' ;
    rdfs:comment 'Comma-separated list of employee identifiers or names of stakeholders who participated in the gate review session, forming part of the review event audit trail.' ;
    rdfs:domain ind:ReleaseGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stabilityCrashRate rdf:type rdf:Property ;
    rdfs:label 'Stability Crash Rate' ;
    rdfs:comment 'The measured crash rate (crashes per session or per hour of play) for the build under review, used as a key stability benchmark for release readiness decisions.' ;
    rdfs:domain ind:ReleaseGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetReviewDate rdf:type rdf:Property ;
    rdfs:label 'Target Review Date' ;
    rdfs:comment 'The planned date on which the release gate review is scheduled to occur, used for release milestone tracking and project planning.' ;
    rdfs:domain ind:ReleaseGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trcComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Trc Compliance Status' ;
    rdfs:comment 'Indicates whether the build has passed the platform manufacturer\'s Technical Requirements Checklist (TRC) or Technical Certification Requirements (TCR) at the time of this gate. Compliant: all TRC/TCR items passed. Non-Compliant: one or more TRC/TCR items failed. Waived: non-compliance formally accepted. Not Applicable: TRC/TCR not required for this gate type.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waivedDefectCount rdf:type rdf:Property ;
    rdfs:label 'Waived Defect Count' ;
    rdfs:comment 'Number of defects that were formally waived (accepted risk) during this gate review, allowing the gate to proceed despite known issues.' ;
    rdfs:domain ind:ReleaseGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:releaseGateReviewId rdf:type rdf:Property ;
    rdfs:label 'Release Gate Review Id' ;
    rdfs:comment 'Unique surrogate identifier for each formal release gate review event. Primary key for this transactional record. Entity role: TRANSACTION_HEADER — captures a discrete quality gate decision event with its own lifecycle.' ;
    rdfs:domain ind:ReleaseGateReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentRatingBody rdf:type rdf:Property ;
    rdfs:label 'Content Rating Body' ;
    rdfs:comment 'The regulatory body that issued or is processing the content rating for this release (e.g., ESRB, PEGI, USK, CERO, GRAC). Relevant to the target market(s) for this release. [ENUM-REF-CANDIDATE: ESRB|PEGI|USK|CERO|GRAC|IARC — promote to reference product]' ;
    rdfs:domain ind:ReleaseGateReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRatingStatus rdf:type rdf:Property ;
    rdfs:label 'Content Rating Status' ;
    rdfs:comment 'Status of the game\'s content rating submission and approval with applicable rating bodies (ESRB, PEGI, USK, CERO, GRAC) at the time of this gate review. A valid content rating is typically a hard gate requirement for commercial release.' ;
    rdfs:domain ind:ReleaseGateReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crashRatePct rdf:type rdf:Property ;
    rdfs:label 'Crash Rate Pct' ;
    rdfs:comment 'The measured crash rate of the build as a percentage of sessions, recorded at the time of this gate review. A key stability benchmark used to assess release readiness. Typically sourced from QA playtesting telemetry or GameAnalytics/Amplitude crash reporting.' ;
    rdfs:domain ind:ReleaseGateReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criteriaWaivedCount rdf:type rdf:Property ;
    rdfs:label 'Criteria Waived Count' ;
    rdfs:comment 'The number of release gate criteria items that were formally waived (bypassed with documented justification) during this review. Waivers require explicit stakeholder sign-off and are tracked for audit and compliance purposes.' ;
    rdfs:domain ind:ReleaseGateReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectWaiverCount rdf:type rdf:Property ;
    rdfs:label 'Defect Waiver Count' ;
    rdfs:comment 'The total number of individual defect waivers formally approved during this gate review session. Each waiver represents a documented risk acceptance decision allowing a known defect to ship.' ;
    rdfs:domain ind:ReleaseGateReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:jiraReleaseTicket rdf:type rdf:Property ;
    rdfs:label 'Jira Release Ticket' ;
    rdfs:comment 'The Jira issue key (e.g., REL-4821) for the release epic or release planning ticket associated with this gate review. Provides traceability back to the Jira project management system of record for release planning.' ;
    rdfs:domain ind:ReleaseGateReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openCriticalDefectCount rdf:type rdf:Property ;
    rdfs:label 'Open Critical Defect Count' ;
    rdfs:comment 'The number of open critical-severity (P0/P1) defects in Jira at the time of this gate review. Critical defects are typically blocking for release approval and must be resolved or waived before gate passage.' ;
    rdfs:domain ind:ReleaseGateReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openMajorDefectCount rdf:type rdf:Property ;
    rdfs:label 'Open Major Defect Count' ;
    rdfs:comment 'The number of open major-severity (P2) defects in Jira at the time of this gate review. Major defects may be conditionally waived with documented risk acceptance.' ;
    rdfs:domain ind:ReleaseGateReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openMinorDefectCount rdf:type rdf:Property ;
    rdfs:label 'Open Minor Defect Count' ;
    rdfs:comment 'The number of open minor-severity (P3/P4) defects in Jira at the time of this gate review. Minor defects are typically tracked but do not block gate passage.' ;
    rdfs:domain ind:ReleaseGateReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:platformCertReadiness rdf:type rdf:Property ;
    rdfs:label 'Platform Cert Readiness' ;
    rdfs:comment 'Assessment of the build\'s readiness for submission to first-party platform certification (e.g., Sony TRC, Microsoft TCR, Nintendo Lot Check). Tracks whether the build meets all Technical Requirements Checklist (TRC) / Technical Certification Requirements (TCR) criteria required by the platform holder.' ;
    rdfs:domain ind:ReleaseGateReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendation rdf:type rdf:Property ;
    rdfs:label 'Recommendation' ;
    rdfs:comment 'The formal recommendation issued by the review lead at the conclusion of this gate review session. Approve indicates the build is cleared to proceed; reject indicates the build must be remediated and re-reviewed; conditional_approve indicates approval is granted subject to documented conditions being met.' ;
    rdfs:domain ind:ReleaseGateReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regressionSuitePassPct rdf:type rdf:Property ;
    rdfs:label 'Regression Suite Pass Pct' ;
    rdfs:comment 'The percentage of automated regression test suite cases that passed for this build at the time of the gate review. Sourced from CI/CD (Continuous Integration/Continuous Deployment) pipeline test results. A key quality gate metric.' ;
    rdfs:domain ind:ReleaseGateReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releaseTargetDate rdf:type rdf:Property ;
    rdfs:label 'Release Target Date' ;
    rdfs:comment 'The planned commercial release date for the game title at the time of this gate review. Used to assess schedule risk and urgency of gate decisions. May differ from the actual release date if the gate results in a delay.' ;
    rdfs:domain ind:ReleaseGateReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewCode rdf:type rdf:Property ;
    rdfs:label 'Review Code' ;
    rdfs:comment 'Externally-known business identifier for this release gate review event, used in Jira, release management communications, and audit documentation (e.g., RGR-TITLE01-20240315). Aligns with Jira release planning ticket references.' ;
    rdfs:domain ind:ReleaseGateReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledReviewDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Review Date' ;
    rdfs:comment 'The originally planned calendar date for this release gate review, as recorded in Jira release planning. Used to measure schedule adherence and release milestone tracking against planned dates.' ;
    rdfs:domain ind:ReleaseGateReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalCriteriaEvaluated rdf:type rdf:Property ;
    rdfs:label 'Total Criteria Evaluated' ;
    rdfs:comment 'The total count of release gate criteria items formally evaluated during this review session. Used to measure review scope and completeness of the gate assessment.' ;
    rdfs:domain ind:ReleaseGateReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uatCompletionPct rdf:type rdf:Property ;
    rdfs:label 'Uat Completion Pct' ;
    rdfs:comment 'The percentage of User Acceptance Testing (UAT) test cases that have been executed and closed at the time of this gate review. A key gate criterion indicating test coverage completeness before release.' ;
    rdfs:domain ind:ReleaseGateReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supersededByStabilityBenchmarkId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Stability Benchmark Id' ;
    rdfs:comment 'Reference to the newer stability_benchmark record that replaced this one when it was superseded. Enables version chain traceability. Null if this benchmark is the current active version.' ;
    rdfs:domain ind:StabilityBenchmark ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StabilityBenchmark .

ind:appliesToBuildType rdf:type rdf:Property ;
    rdfs:label 'Applies To Build Type' ;
    rdfs:comment 'Specifies which build lifecycle stage(s) this benchmark applies to. \'gold_master\' = final release build; \'release_candidate\' = near-final candidate; \'beta\' = public/closed beta; \'alpha\' = early development; \'live_patch\' = post-launch update; \'all\' = applies universally.' ;
    rdfs:domain ind:StabilityBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkCode rdf:type rdf:Property ;
    rdfs:label 'Benchmark Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this benchmark within QA tooling and Jira project tracking (e.g., \'SB-PC-ULTRA-2024-V2\'). Used as the business identifier in cross-system references.' ;
    rdfs:domain ind:StabilityBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkName rdf:type rdf:Property ;
    rdfs:label 'Benchmark Name' ;
    rdfs:comment 'Human-readable name identifying this benchmark record (e.g., \'PC Ultra Settings Gold Master Benchmark v2.1\', \'PS5 Launch Stability Baseline\'). Serves as the primary identity label for QA teams and stakeholders.' ;
    rdfs:domain ind:StabilityBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkStatus rdf:type rdf:Property ;
    rdfs:label 'Benchmark Status' ;
    rdfs:comment 'Current lifecycle state of the benchmark record. \'draft\' = under construction; \'pending_approval\' = awaiting sign-off; \'active\' = approved and in use as the reference standard; \'superseded\' = replaced by a newer version; \'retired\' = no longer applicable.' ;
    rdfs:domain ind:StabilityBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkType rdf:type rdf:Property ;
    rdfs:label 'Benchmark Type' ;
    rdfs:comment 'Classification of the benchmark by its primary quality concern. \'performance\' = FPS/frame time/load time targets; \'stability\' = crash rate/memory targets; \'compliance\' = platform TRC/TCR requirements; \'certification\' = first-party certification readiness; \'regression\' = baseline for regression detection.' ;
    rdfs:domain ind:StabilityBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkVersion rdf:type rdf:Property ;
    rdfs:label 'Benchmark Version' ;
    rdfs:comment 'Semantic version number of this benchmark definition (e.g., \'1.0\', \'2.3\', \'1.0.1\'). Incremented when threshold values or scope are revised. Enables traceability of which version was active at any point in time.' ;
    rdfs:domain ind:StabilityBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'The date from which this benchmark version is binding and must be used as the reference standard for evaluating performance test runs. May differ from approval_date if a future effective date was specified.' ;
    rdfs:domain ind:StabilityBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'The date on which this benchmark version ceases to be the active reference standard, typically when superseded by a newer version. Null indicates the benchmark is open-ended and currently active.' ;
    rdfs:domain ind:StabilityBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:graphicsQualityPreset rdf:type rdf:Property ;
    rdfs:label 'Graphics Quality Preset' ;
    rdfs:comment 'Graphics quality setting level at which this benchmark was defined and must be evaluated (e.g., \'ultra\', \'high\', \'medium\', \'low\', \'platform_default\'). PC titles may have multiple benchmarks per quality tier.' ;
    rdfs:domain ind:StabilityBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hardwareConfig rdf:type rdf:Property ;
    rdfs:label 'Hardware Config' ;
    rdfs:comment 'Description of the reference hardware configuration used to establish this benchmark (e.g., \'PS5 Retail Unit\', \'PC - Intel i7-12700K / RTX 3080 / 16GB RAM\', \'iPhone 14 Pro\'). Ensures benchmark thresholds are interpreted in the correct hardware context.' ;
    rdfs:domain ind:StabilityBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Is Certification Required' ;
    rdfs:comment 'Indicates whether passing this benchmark is a mandatory prerequisite for first-party platform certification submission (e.g., Sony TRC, Microsoft TCR, Nintendo Lot Check). True = certification gate; False = internal quality gate only.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReleaseGate rdf:type rdf:Property ;
    rdfs:label 'Is Release Gate' ;
    rdfs:comment 'Indicates whether this benchmark constitutes a hard release quality gate that must be passed before a build can be promoted to Gold Master or submitted for distribution. True = blocking gate; False = advisory/informational benchmark.' ;
    rdfs:domain ind:StabilityBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxCpuUsagePct rdf:type rdf:Property ;
    rdfs:label 'Max Cpu Usage Pct' ;
    rdfs:comment 'Maximum acceptable CPU utilization percentage during standard gameplay scenarios. Sustained CPU usage above this threshold may cause frame drops, audio glitches, or instability on target hardware.' ;
    rdfs:domain ind:StabilityBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxCrashRatePct rdf:type rdf:Property ;
    rdfs:label 'Max Crash Rate Pct' ;
    rdfs:comment 'Maximum acceptable crash rate expressed as a percentage of sessions (e.g., 0.5000 = 0.5%). Builds exceeding this threshold fail the stability gate and are blocked from release. A key Quality Assurance (QA) release readiness criterion.' ;
    rdfs:domain ind:StabilityBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxDiskIoMbps rdf:type rdf:Property ;
    rdfs:label 'Max Disk Io Mbps' ;
    rdfs:comment 'Maximum acceptable disk read/write throughput in megabytes per second during asset streaming and level loading. Critical for open-world titles and platforms with SSD-based streaming architectures (e.g., PS5 SSD).' ;
    rdfs:domain ind:StabilityBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxFrameTimeMs rdf:type rdf:Property ;
    rdfs:label 'Max Frame Time Ms' ;
    rdfs:comment 'Maximum allowable frame render time in milliseconds. Exceeding this threshold indicates frame drops or hitches that degrade player experience. Complementary to FPS as it captures frame time variance (e.g., 33.33ms for 30 FPS target).' ;
    rdfs:domain ind:StabilityBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxGpuUsagePct rdf:type rdf:Property ;
    rdfs:label 'Max Gpu Usage Pct' ;
    rdfs:comment 'Maximum acceptable GPU utilization percentage during standard gameplay scenarios. Sustained GPU usage above this threshold may indicate rendering inefficiency or thermal throttling risk on target hardware.' ;
    rdfs:domain ind:StabilityBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxHangRatePct rdf:type rdf:Property ;
    rdfs:label 'Max Hang Rate Pct' ;
    rdfs:comment 'Maximum acceptable application hang or freeze rate expressed as a percentage of sessions. Hangs are distinct from crashes and represent unresponsive states that require player intervention. A key stability Quality Assurance (QA) gate.' ;
    rdfs:domain ind:StabilityBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxLoadTimeSec rdf:type rdf:Property ;
    rdfs:label 'Max Load Time Sec' ;
    rdfs:comment 'Maximum acceptable level load or initial boot time in seconds as defined by the Service Level Agreement (SLA). Exceeding this threshold constitutes a performance failure. Applies to the primary load scenario (e.g., main menu to gameplay).' ;
    rdfs:domain ind:StabilityBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxMemoryUsageMb rdf:type rdf:Property ;
    rdfs:label 'Max Memory Usage Mb' ;
    rdfs:comment 'Maximum allowable RAM consumption in megabytes during gameplay. Builds exceeding this ceiling risk out-of-memory crashes on target hardware. Platform-specific as console and mobile hardware have fixed memory budgets.' ;
    rdfs:domain ind:StabilityBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxNetworkLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Max Network Latency Ms' ;
    rdfs:comment 'Maximum acceptable network round-trip latency in milliseconds for online/multiplayer game modes. Exceeding this ceiling degrades Player versus Player (PvP) and Massively Multiplayer Online (MMO) gameplay quality. Not applicable for offline-only titles.' ;
    rdfs:domain ind:StabilityBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxTextureMemoryMb rdf:type rdf:Property ;
    rdfs:label 'Max Texture Memory Mb' ;
    rdfs:comment 'Maximum allowable VRAM/texture memory consumption in megabytes. Exceeding this ceiling causes texture pop-in, Level of Detail (LOD) degradation, or out-of-memory crashes on GPU-constrained platforms.' ;
    rdfs:domain ind:StabilityBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementDurationSec rdf:type rdf:Property ;
    rdfs:label 'Measurement Duration Sec' ;
    rdfs:comment 'Duration in seconds over which performance metrics must be sustained to satisfy the benchmark. Ensures thresholds are evaluated over a representative gameplay window rather than a momentary snapshot (e.g., 300 seconds = 5-minute sustained test).' ;
    rdfs:domain ind:StabilityBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentileThreshold rdf:type rdf:Property ;
    rdfs:label 'Percentile Threshold' ;
    rdfs:comment 'Statistical percentile at which FPS and frame time thresholds must be met (e.g., 95.00 = 95th percentile, meaning 95% of frames must meet the FPS floor). Distinguishes between average-case and worst-case performance requirements.' ;
    rdfs:domain ind:StabilityBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolution rdf:type rdf:Property ;
    rdfs:label 'Resolution' ;
    rdfs:comment 'Target display resolution at which this benchmark applies (e.g., \'1920x1080\', \'2560x1440\', \'3840x2160\', \'1080p\', \'4K\'). Performance thresholds vary significantly by resolution, particularly for GPU-bound scenarios.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testScenario rdf:type rdf:Property ;
    rdfs:label 'Test Scenario' ;
    rdfs:comment 'Description of the specific gameplay scenario or test case used to measure performance against this benchmark (e.g., \'Open World Stress Test - 100 NPCs\', \'PvP Match - 64 Players\', \'Main Menu to Gameplay Load\'). Ensures reproducibility of benchmark conditions.' ;
    rdfs:domain ind:StabilityBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testSuiteId rdf:type rdf:Property ;
    rdfs:label 'Test Suite Id' ;
    rdfs:comment 'Foreign key linking to quality.test_suite. Business justification: test_case currently has test_suite as STRING (denormalized). Normalizing by adding test_suite_id FK to test_suite master reference table. The test_suite STRING column becomes redundant as suite_name c' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestSuite .

ind:automationFramework rdf:type rdf:Property ;
    rdfs:label 'Automation Framework' ;
    rdfs:comment 'Name of the automated testing framework or tool used to execute this test case when is_automated is True (e.g., \'Selenium\', \'Appium\', \'Unity Test Framework\', \'Unreal Automation Tool\', \'pytest\', \'Robot Framework\'). Null when the test case is manual.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automationScriptPath rdf:type rdf:Property ;
    rdfs:label 'Automation Script Path' ;
    rdfs:comment 'File path or repository reference (Perforce Helix Core depot path or Git URL) to the automation script that implements this test case. Enables traceability between the test case catalog and the version-controlled test code.' ;
    rdfs:domain ind:TestCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildVersionIntroduced rdf:type rdf:Property ;
    rdfs:label 'Build Version Introduced' ;
    rdfs:comment 'The game build version or software version in which this test case was first introduced into the test library (e.g., \'1.0.0\', \'2.3.1-beta\'). Enables historical analysis of test coverage growth across build versions.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationStandard rdf:type rdf:Property ;
    rdfs:label 'Certification Standard' ;
    rdfs:comment 'The regulatory or platform certification standard that this test case validates compliance against. TRC/TCR are console manufacturer technical requirements; ESRB/PEGI/USK/CERO/GRAC are content rating body requirements; GDPR/COPPA are data privacy regulations; PCI DSS covers payment processing; WCAG covers accessibility. None indicates a non-compliance test case. [ENUM-REF-CANDIDATE: TRC|TCR|ESRB|PEGI|USK|CERO|GRAC|GDPR|COPPA|PCI_DSS|WCAG|none — promote to reference product]' ;
    rdfs:domain ind:TestCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectCount rdf:type rdf:Property ;
    rdfs:label 'Defect Count' ;
    rdfs:comment 'The total number of active defects (Jira bugs) currently linked to this test case. Provides a quick indicator of the test case\'s defect discovery effectiveness and the current quality health of the associated game component. Not a calculated aggregate — sourced directly from Jira linkage metadata.' ;
    rdfs:domain ind:TestCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedExecutionMins rdf:type rdf:Property ;
    rdfs:label 'Estimated Execution Mins' ;
    rdfs:comment 'The estimated time in minutes required to execute this test case manually or via automation. Used for test planning, sprint capacity estimation, and QA resource allocation. Supports release timeline forecasting.' ;
    rdfs:domain ind:TestCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executionEnvironment rdf:type rdf:Property ;
    rdfs:label 'Execution Environment' ;
    rdfs:comment 'The target environment in which this test case is designed to be executed. Dev is the development sandbox; QA is the dedicated testing environment; staging mirrors production for pre-release validation; cert is the platform certification environment; production is for live-service monitoring tests.' ;
    rdfs:domain ind:TestCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedResult rdf:type rdf:Property ;
    rdfs:label 'Expected Result' ;
    rdfs:comment 'The precise, observable outcome that must occur for the test case to be considered passed. Defines the acceptance criterion against which actual test execution results are compared. Essential for pass/fail determination in both manual and automated QA runs.' ;
    rdfs:domain ind:TestCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRegressionCandidate rdf:type rdf:Property ;
    rdfs:label 'Is Regression Candidate' ;
    rdfs:comment 'Indicates whether this test case should be included in the standard regression test pack (True) for every build or patch release. Regression candidates are high-value tests that protect core game functionality and are executed as part of every CI/CD pipeline run.' ;
    rdfs:domain ind:TestCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastExecutionResult rdf:type rdf:Property ;
    rdfs:label 'Last Execution Result' ;
    rdfs:comment 'The outcome of the most recent execution of this test case. Pass indicates the expected result was achieved; fail indicates a defect was found; blocked indicates execution was prevented by a dependency or environment issue; skipped indicates intentional exclusion; not_run indicates no execution has occurred yet.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPassedBuild rdf:type rdf:Property ;
    rdfs:label 'Last Passed Build' ;
    rdfs:comment 'The most recent game build version in which this test case achieved a pass result. Used to identify stale or flaky tests and to assess the current health of test coverage relative to the active build.' ;
    rdfs:domain ind:TestCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passRatePct rdf:type rdf:Property ;
    rdfs:label 'Pass Rate Pct' ;
    rdfs:comment 'The historical pass rate of this test case expressed as a percentage (0.00–100.00), calculated as the ratio of pass executions to total executions over the test case\'s lifetime. Identifies flaky or consistently failing tests for prioritized maintenance. Sourced from execution history aggregation in the QA system.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformApplicability rdf:type rdf:Property ;
    rdfs:label 'Platform Applicability' ;
    rdfs:comment 'Comma-separated list of target platforms for which this test case is applicable (e.g., \'PC,PS5,Xbox Series X,iOS,Android,Switch\'). Determines which platform-specific test runs should include this test case. Aligns with Steamworks, Console SDKs, and mobile store certification requirements.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preconditions rdf:type rdf:Property ;
    rdfs:label 'Preconditions' ;
    rdfs:comment 'Describes the required system state, environment configuration, player account state, or data setup that must exist before the test case can be executed (e.g., \'Player must be logged in with a level 10 character and have 500 in-game currency\'). Critical for reproducibility and automation setup.' ;
    rdfs:domain ind:TestCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseMilestone rdf:type rdf:Property ;
    rdfs:label 'Release Milestone' ;
    rdfs:comment 'The game release milestone or sprint to which this test case is associated (e.g., \'Alpha\', \'Beta\', \'Gold Master\', \'Patch 1.2\', \'DLC Drop 3\'). Links test coverage to the release planning lifecycle and quality gate checkpoints.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementReference rdf:type rdf:Property ;
    rdfs:label 'Requirement Reference' ;
    rdfs:comment 'Identifier or reference to the business or technical requirement that this test case validates (e.g., a Jira story key, a GDD section reference, or a platform TRC/TCR requirement ID). Ensures full traceability from requirements through test coverage to defects.' ;
    rdfs:domain ind:TestCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCaseDescription rdf:type rdf:Property ;
    rdfs:label 'Test Case Description' ;
    rdfs:comment 'Detailed narrative describing the purpose, scope, and intent of the test case. Provides context for QA engineers and stakeholders on what business functionality or technical behavior is being validated.' ;
    rdfs:domain ind:TestCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCaseName rdf:type rdf:Property ;
    rdfs:label 'Test Case Name' ;
    rdfs:comment 'Human-readable title of the test case that clearly identifies the scenario being validated (e.g., \'Verify player inventory persists after server restart\'). Used as the primary display label in QA dashboards and test reports.' ;
    rdfs:domain ind:TestCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testSteps rdf:type rdf:Property ;
    rdfs:label 'Test Steps' ;
    rdfs:comment 'Step-by-step instructions for executing the test case, written in a numbered or structured format. Each step describes a discrete action the tester or automation script must perform. Sourced from Jira test management fields and serves as the authoritative execution guide.' ;
    rdfs:domain ind:TestCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCycleId rdf:type rdf:Property ;
    rdfs:label 'Test Cycle Id' ;
    rdfs:comment 'Unique surrogate identifier for the test cycle record. Primary key for the test_cycle data product in the quality domain.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestCycle .

ind:jiraSprintId rdf:type rdf:Property ;
    rdfs:label 'Jira Sprint Id' ;
    rdfs:comment 'The Jira sprint identifier associated with this test cycle, linking QA execution to the development sprint cadence. Enables sprint-level quality reporting and velocity correlation.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sprint .

ind:abortReason rdf:type rdf:Property ;
    rdfs:label 'Abort Reason' ;
    rdfs:comment 'Free-text description of the reason this test cycle was aborted before completion (e.g., \'Critical P1 blocker in build rendering all test cases invalid — new build required\'). Populated only when status = \'aborted\'. Supports root cause analysis and process improvement.' ;
    rdfs:domain ind:TestCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualPassRatePct rdf:type rdf:Property ;
    rdfs:label 'Actual Pass Rate Pct' ;
    rdfs:comment 'The actual pass rate percentage achieved in this test cycle, calculated as (test_cases_passed / test_cases_executed) * 100. Compared against pass_rate_threshold_pct to determine release gate pass/fail status.' ;
    rdfs:domain ind:TestCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleName rdf:type rdf:Property ;
    rdfs:label 'Cycle Name' ;
    rdfs:comment 'Human-readable name or title of the test cycle (e.g., \'Sprint 42 QA Regression\', \'Platform Certification Cycle — PS5 v2.1.0\', \'UAT Cycle — Season 3 Launch\'). Used for identification in dashboards and reports.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleObjective rdf:type rdf:Property ;
    rdfs:label 'Cycle Objective' ;
    rdfs:comment 'Free-text description of the primary business and quality objectives for this test cycle (e.g., \'Validate all P1/P2 regression scenarios for Season 3 content drop prior to live ops deployment\'). Provides context for stakeholders reviewing cycle results.' ;
    rdfs:domain ind:TestCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleType rdf:type rdf:Property ;
    rdfs:label 'Cycle Type' ;
    rdfs:comment 'Classification of the test cycle by its testing methodology and purpose. Drives which test suites, entry/exit criteria, and reporting templates apply. [ENUM-REF-CANDIDATE: regression|certification|uat|smoke|performance|compliance|playtesting — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectCountP1 rdf:type rdf:Property ;
    rdfs:label 'Defect Count P1' ;
    rdfs:comment 'Number of open or total P1 (Critical/Blocker) severity defects identified during this test cycle. P1 defects represent game-breaking issues that prevent core functionality and are hard blockers for release. Tracked separately per severity for release gate assessment.' ;
    rdfs:domain ind:TestCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectCountP2 rdf:type rdf:Property ;
    rdfs:label 'Defect Count P2' ;
    rdfs:comment 'Number of open or total P2 (Major) severity defects identified during this test cycle. P2 defects represent significant functional issues that degrade player experience but have workarounds. Tracked for release gate threshold evaluation.' ;
    rdfs:domain ind:TestCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectCountP3 rdf:type rdf:Property ;
    rdfs:label 'Defect Count P3' ;
    rdfs:comment 'Number of open or total P3 (Minor) severity defects identified during this test cycle. P3 defects represent low-impact issues that do not block release but are tracked for quality trending and backlog management.' ;
    rdfs:domain ind:TestCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:entryCriteria rdf:type rdf:Property ;
    rdfs:label 'Entry Criteria' ;
    rdfs:comment 'Defined conditions that must be met before the test cycle can begin execution (e.g., \'Build deployed to QA environment, smoke test passed, all P0 blockers resolved\'). Enforces quality gates at cycle initiation.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitCriteria rdf:type rdf:Property ;
    rdfs:label 'Exit Criteria' ;
    rdfs:comment 'Defined conditions that must be satisfied for the test cycle to be declared complete and eligible for release gate sign-off (e.g., \'95% pass rate, zero open P1 defects, all certification test cases executed\'). Drives release readiness decisions.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateWaiverJustification rdf:type rdf:Property ;
    rdfs:label 'Gate Waiver Justification' ;
    rdfs:comment 'Documented business justification for overriding a failed release gate (populated only when release_gate_status = \'waived\'). Records the rationale, risk acceptance, and authorizing stakeholder for audit and compliance purposes.' ;
    rdfs:domain ind:TestCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGoldMasterCandidate rdf:type rdf:Property ;
    rdfs:label 'Is Gold Master Candidate' ;
    rdfs:comment 'Indicates whether the build under test in this cycle is a Gold Master (GM) candidate — the final release-ready build submitted for platform certification and manufacturing. Flags cycles that are part of the final pre-launch quality gate process.' ;
    rdfs:domain ind:TestCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegressionBaseline rdf:type rdf:Property ;
    rdfs:label 'Is Regression Baseline' ;
    rdfs:comment 'Indicates whether this test cycle has been designated as the official regression baseline for the associated game title and build version. Baseline cycles serve as the reference point for future regression comparisons and stability benchmarking.' ;
    rdfs:domain ind:TestCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jiraCycleKey rdf:type rdf:Property ;
    rdfs:label 'Jira Cycle Key' ;
    rdfs:comment 'The externally-known Jira issue or sprint key that uniquely identifies this test cycle in the Jira project management system (e.g., QA-1042). Serves as the cross-system business identifier linking the test cycle to its Jira sprint or epic.' ;
    rdfs:domain ind:TestCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passRateThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Pass Rate Threshold Pct' ;
    rdfs:comment 'The minimum required pass rate percentage (e.g., 95.00) that must be achieved for this test cycle to satisfy the release quality gate. Defined at cycle planning time based on cycle type and platform requirements.' ;
    rdfs:domain ind:TestCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qaTeamSize rdf:type rdf:Property ;
    rdfs:label 'Qa Team Size' ;
    rdfs:comment 'Number of QA testers assigned to execute this test cycle. Used for capacity planning, workload distribution analysis, and QA resource utilization reporting.' ;
    rdfs:domain ind:TestCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:releaseGateStatus rdf:type rdf:Property ;
    rdfs:label 'Release Gate Status' ;
    rdfs:comment 'The outcome of the release quality gate assessment for this test cycle. \'pending\' = gate evaluation not yet performed; \'passed\' = all exit criteria and thresholds met; \'failed\' = one or more exit criteria not met; \'waived\' = gate failure acknowledged and overridden by authorized stakeholder with documented justification.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetBuildVersion rdf:type rdf:Property ;
    rdfs:label 'Target Build Version' ;
    rdfs:comment 'The specific game build version (e.g., \'2.1.0.4521\') that this test cycle is scoped to test. Aligns with the build label in Perforce Helix Core version control. Critical for traceability between defects and the build under test.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCasesBlocked rdf:type rdf:Property ;
    rdfs:label 'Test Cases Blocked' ;
    rdfs:comment 'Number of test cases that could not be executed due to a blocking defect, environment issue, or dependency. Blocked cases are excluded from pass rate calculations and flagged for root cause analysis.' ;
    rdfs:domain ind:TestCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testCasesExecuted rdf:type rdf:Property ;
    rdfs:label 'Test Cases Executed' ;
    rdfs:comment 'Number of test cases that have been executed (run) within this test cycle as of the latest update. Tracks execution progress against the total assigned scope.' ;
    rdfs:domain ind:TestCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testCasesFailed rdf:type rdf:Property ;
    rdfs:label 'Test Cases Failed' ;
    rdfs:comment 'Number of executed test cases that have resulted in a failure within this test cycle. Drives defect creation workflows and release gate blocking decisions.' ;
    rdfs:domain ind:TestCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testCasesPassed rdf:type rdf:Property ;
    rdfs:label 'Test Cases Passed' ;
    rdfs:comment 'Number of executed test cases that have achieved a passing result within this test cycle. Used as the numerator for pass rate calculation and release gate assessment.' ;
    rdfs:domain ind:TestCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testCycleStatus rdf:type rdf:Property ;
    rdfs:label 'Test Cycle Status' ;
    rdfs:comment 'Current lifecycle state of the test cycle. Drives workflow routing, reporting visibility, and release gate eligibility. \'planned\' = scheduled but not started; \'active\' = execution in progress; \'completed\' = all test cases executed and results recorded; \'aborted\' = terminated before completion; \'on_hold\' = paused pending external dependency.' ;
    rdfs:domain ind:TestCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalTestCases rdf:type rdf:Property ;
    rdfs:label 'Total Test Cases' ;
    rdfs:comment 'Total number of test cases assigned to this test cycle at the time of planning. Represents the full scope of testing work planned for the cycle. Used for capacity planning and pass rate denominator calculations.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentExecutionQualityTestExecutionId rdf:type rdf:Property ;
    rdfs:label 'Parent Execution Quality Test Execution Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the original execution record when this record represents a rerun or re-execution. Enables lineage tracking of execution attempts within a test cycle.' ;
    rdfs:domain ind:QualityTestExecution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityTestExecution .

ind:testerPlayerAccountId rdf:type rdf:Property ;
    rdfs:label 'Tester Player Account Id' ;
    rdfs:comment 'Foreign key linking to player.player_account. Business justification: When players participate in beta testing or crowdsourced QA programs (increasingly common in gaming), test executions performed by players (not employees) need player_account link for access control (' ;
    rdfs:domain ind:QualityTestExecution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerAccount .

ind:actualResultNotes rdf:type rdf:Property ;
    rdfs:label 'Actual Result Notes' ;
    rdfs:comment 'Free-text description of the actual observed outcome during test execution, contrasted against the expected result defined in the test case. Primary evidence field for defect reproduction and release gate review.' ;
    rdfs:domain ind:QualityTestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automationRunReference rdf:type rdf:Property ;
    rdfs:label 'Automation Run Reference' ;
    rdfs:comment 'External identifier of the CI/CD pipeline run or automated test job that triggered this execution (e.g., Jenkins build number, GitHub Actions run ID). Enables traceability from execution record back to the pipeline run.' ;
    rdfs:domain ind:QualityTestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crashOccurred rdf:type rdf:Property ;
    rdfs:label 'Crash Occurred' ;
    rdfs:comment 'Indicates whether the game application crashed during this test execution (True). A crash is a certification-blocking event on all first-party platforms and triggers mandatory defect creation and escalation.' ;
    rdfs:domain ind:QualityTestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evidenceAttachmentUrl rdf:type rdf:Property ;
    rdfs:label 'Evidence Attachment Url' ;
    rdfs:comment 'URL or path to supporting evidence artefacts for this execution such as screenshots, video captures, log files, or crash dumps stored in the asset management system. Required for defect reproduction and certification submission packages.' ;
    rdfs:domain ind:QualityTestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionDurationSec rdf:type rdf:Property ;
    rdfs:label 'Execution Duration Sec' ;
    rdfs:comment 'Total elapsed time in seconds from execution start to completion. Used for performance benchmarking of test suites, identifying slow automated tests, and estimating QA cycle time for release planning.' ;
    rdfs:domain ind:QualityTestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Execution End Timestamp' ;
    rdfs:comment 'The date and time at which this test execution was completed or terminated. Used in conjunction with execution_timestamp to derive execution duration for performance benchmarking.' ;
    rdfs:domain ind:QualityTestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:executionKey rdf:type rdf:Property ;
    rdfs:label 'Execution Key' ;
    rdfs:comment 'Human-readable, externally referenceable identifier for this execution record (e.g., QE-0001234). Used in QA reports, release notes, and cross-team communication as the business-facing execution reference.' ;
    rdfs:domain ind:QualityTestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionStatus rdf:type rdf:Property ;
    rdfs:label 'Execution Status' ;
    rdfs:comment 'Current outcome or lifecycle state of this test execution. \'pass\' indicates all assertions met; \'fail\' indicates one or more assertions failed; \'blocked\' indicates a prerequisite prevented execution; \'skipped\' indicates intentional omission; \'not_run\' indicates pending execution; \'in_progress\' indicates active execution.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Execution Timestamp' ;
    rdfs:comment 'The precise date and time at which this test execution was initiated. Represents the real-world business event time and is the primary temporal anchor for release gate evidence and QA audit trails.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:executionType rdf:type rdf:Property ;
    rdfs:label 'Execution Type' ;
    rdfs:comment 'Indicates whether this execution was performed manually by a QA engineer or playtester, executed by an automated test framework (e.g., CI/CD pipeline), or a hybrid semi-automated approach requiring human validation steps.' ;
    rdfs:domain ind:QualityTestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fpsObserved rdf:type rdf:Property ;
    rdfs:label 'Fps Observed' ;
    rdfs:comment 'Frames per second (FPS) recorded during this execution, applicable to performance and stability test cases. Used to validate performance benchmarks against target FPS thresholds defined in release quality gates.' ;
    rdfs:domain ind:QualityTestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rerunCount rdf:type rdf:Property ;
    rdfs:label 'Rerun Count' ;
    rdfs:comment 'Number of times this specific test case has been re-executed within the same test cycle or plan. A high rerun count on a failing test indicates a persistent defect or flaky automated test requiring investigation.' ;
    rdfs:domain ind:QualityTestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stepsExecutedCount rdf:type rdf:Property ;
    rdfs:label 'Steps Executed Count' ;
    rdfs:comment 'Number of individual test steps executed within this test case run. Used to identify partial executions (e.g., blocked mid-step) and to calculate step-level pass rates for detailed QA reporting.' ;
    rdfs:domain ind:QualityTestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stepsPassedCount rdf:type rdf:Property ;
    rdfs:label 'Steps Passed Count' ;
    rdfs:comment 'Number of individual test steps within this execution that produced a passing result. Enables granular step-level pass rate calculation alongside steps_executed_count.' ;
    rdfs:domain ind:QualityTestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:titleReleaseId rdf:type rdf:Property ;
    rdfs:label 'Title Release Id' ;
    rdfs:comment 'Foreign key linking to title.title_release. Business justification: Test plans validate specific releases for go/no-go decisions. Release-level test coverage tracking is required for launch readiness reviews and post-launch defect attribution. Replaces string release_' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TitleRelease .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'The actual date on which test execution commenced. Compared against planned_start_date to measure QA schedule adherence and identify planning variance.' ;
    rdfs:domain ind:TestPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certSubmissionReady rdf:type rdf:Property ;
    rdfs:label 'Cert Submission Ready' ;
    rdfs:comment 'Indicates whether the game build has passed all platform certification readiness checks within this test plan and is cleared for submission to first-party certification (e.g., Sony, Microsoft, Nintendo, Apple, Google). Sourced from Steamworks/Console SDK certification checklists.' ;
    rdfs:domain ind:TestPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentCycleBuildVersion rdf:type rdf:Property ;
    rdfs:label 'Current Cycle Build Version' ;
    rdfs:comment 'The specific game build version being tested in the current active cycle. May differ from target_build_version if a hotfix build was submitted mid-cycle. Sourced from Perforce Helix Core.' ;
    rdfs:domain ind:TestPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentCycleNumber rdf:type rdf:Property ;
    rdfs:label 'Current Cycle Number' ;
    rdfs:comment 'The ordinal number of the currently active or most recently completed test cycle within this plan (e.g., 1 = first cycle, 2 = re-test cycle). Tracks iteration progression.' ;
    rdfs:domain ind:TestPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentCycleStatus rdf:type rdf:Property ;
    rdfs:label 'Current Cycle Status' ;
    rdfs:comment 'Execution status of the currently active test cycle. Values: planned (not yet started), active (execution in progress), completed (cycle finished), aborted (cycle terminated early due to blocking defects or build failure).' ;
    rdfs:domain ind:TestPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCount rdf:type rdf:Property ;
    rdfs:label 'Cycle Count' ;
    rdfs:comment 'Total number of test execution cycles (iterations) defined under this test plan. Each cycle targets a specific build and has its own start/end dates, pass/fail results, and defect counts.' ;
    rdfs:domain ind:TestPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectCountCritical rdf:type rdf:Property ;
    rdfs:label 'Defect Count Critical' ;
    rdfs:comment 'Number of open or unresolved defects classified as Critical (P1) severity in the current cycle. Critical defects are showstoppers that block release. Sourced from Jira bug tracking.' ;
    rdfs:domain ind:TestPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectCountMajor rdf:type rdf:Property ;
    rdfs:label 'Defect Count Major' ;
    rdfs:comment 'Number of open or unresolved defects classified as Major (P2) severity in the current cycle. Major defects significantly impact gameplay or platform certification. Sourced from Jira bug tracking.' ;
    rdfs:domain ind:TestPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectCountMinor rdf:type rdf:Property ;
    rdfs:label 'Defect Count Minor' ;
    rdfs:comment 'Number of open or unresolved defects classified as Minor (P3) severity in the current cycle. Minor defects have limited gameplay impact and may be deferred post-launch. Sourced from Jira bug tracking.' ;
    rdfs:domain ind:TestPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectCountTrivial rdf:type rdf:Property ;
    rdfs:label 'Defect Count Trivial' ;
    rdfs:comment 'Number of open or unresolved defects classified as Trivial (P4) severity in the current cycle. Cosmetic or negligible issues typically deferred to a future patch. Sourced from Jira bug tracking.' ;
    rdfs:domain ind:TestPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:esrbComplianceVerified rdf:type rdf:Property ;
    rdfs:label 'Esrb Compliance Verified' ;
    rdfs:comment 'Indicates whether the game content tested in this plan has been verified as compliant with ESRB rating requirements for North American distribution. Required for all titles targeting North American retail and digital storefronts.' ;
    rdfs:domain ind:TestPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:objectives rdf:type rdf:Property ;
    rdfs:label 'Objectives' ;
    rdfs:comment 'Stated quality objectives for this test plan (e.g., \'Validate all critical gameplay paths on PS5 prior to Gold Master submission\'). Drives prioritization of test cases and defect triage decisions.' ;
    rdfs:domain ind:TestPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Pass Threshold Pct' ;
    rdfs:comment 'Minimum required pass rate (as a percentage, e.g., 95.00) for this test plan to satisfy its exit criteria and unlock the associated release gate. Defined at plan authoring time.' ;
    rdfs:domain ind:TestPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pegiComplianceVerified rdf:type rdf:Property ;
    rdfs:label 'Pegi Compliance Verified' ;
    rdfs:comment 'Indicates whether the game content tested in this plan has been verified as compliant with PEGI rating requirements for European distribution. Required for all titles targeting European storefronts.' ;
    rdfs:domain ind:TestPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceFpsTarget rdf:type rdf:Property ;
    rdfs:label 'Performance Fps Target' ;
    rdfs:comment 'The minimum acceptable frames per second (FPS) performance benchmark that the game build must sustain during performance testing within this plan (e.g., 60.00 FPS for console, 30.00 FPS for mobile). Drives performance test pass/fail determination.' ;
    rdfs:domain ind:TestPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle state of the test plan. Controls workflow transitions and visibility in release gate dashboards. Values: draft (being authored), active (execution in progress), on_hold (paused), completed (all cycles finished), cancelled (abandoned).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaTeamName rdf:type rdf:Property ;
    rdfs:label 'Qa Team Name' ;
    rdfs:comment 'Name of the QA team or squad assigned to execute this test plan (e.g., \'Console Cert Team\', \'Mobile QA Squad\', \'Performance Lab\'). Supports capacity planning and team-level reporting.' ;
    rdfs:domain ind:TestPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Narrative description of what is in scope and out of scope for this test plan. Captures game features, systems, and platforms explicitly included or excluded from testing coverage.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalTestCaseCount rdf:type rdf:Property ;
    rdfs:label 'Total Test Case Count' ;
    rdfs:comment 'Total number of test cases included in this test plan across all test suites. Baseline denominator for pass rate, coverage, and execution progress calculations.' ;
    rdfs:domain ind:TestPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceptanceCriteriaDefinedCount rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria Defined Count' ;
    rdfs:comment 'Total number of acceptance criteria defined for this UAT session prior to execution. Establishes the baseline scope of quality gates that must be evaluated.' ;
    rdfs:domain ind:UatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceptanceCriteriaMetCount rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria Met Count' ;
    rdfs:comment 'Number of defined acceptance criteria that were fully satisfied during the UAT session. Used to calculate pass rate and inform the UAT decision.' ;
    rdfs:domain ind:UatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conditionalAcceptanceNotes rdf:type rdf:Property ;
    rdfs:label 'Conditional Acceptance Notes' ;
    rdfs:comment 'Free-text notes documenting the conditions, remediation commitments, or waivers associated with a conditionally_accepted UAT decision. Null when decision is accepted or rejected outright.' ;
    rdfs:domain ind:UatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRatingComplianceChecked rdf:type rdf:Property ;
    rdfs:label 'Content Rating Compliance Checked' ;
    rdfs:comment 'Indicates whether content rating compliance (ESRB, PEGI, USK, CERO, GRAC) was verified as part of this UAT session. Required for release readiness in regulated markets.' ;
    rdfs:domain ind:UatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coppaComplianceChecked rdf:type rdf:Property ;
    rdfs:label 'Coppa Compliance Checked' ;
    rdfs:comment 'Indicates whether COPPA compliance requirements (parental consent, age-gating, data collection restrictions for under-13 players) were validated during this UAT session. Required for titles with potential child audiences in North America.' ;
    rdfs:domain ind:UatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentType rdf:type rdf:Property ;
    rdfs:label 'Environment Type' ;
    rdfs:comment 'The deployment environment in which the UAT session was conducted: dev (development environment), staging (pre-production staging), cert (platform certification environment), production (live environment for soft launch UAT).' ;
    rdfs:domain ind:UatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftueValidated rdf:type rdf:Property ;
    rdfs:label 'Ftue Validated' ;
    rdfs:comment 'Indicates whether the First-Time User Experience (FTUE) flow was specifically validated during this UAT session. FTUE quality is a critical retention driver and is tracked separately from general test coverage.' ;
    rdfs:domain ind:UatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprComplianceChecked rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliance Checked' ;
    rdfs:comment 'Indicates whether GDPR data protection requirements (consent flows, data subject rights, privacy notices) were validated during this UAT session. Mandatory for releases targeting EU markets.' ;
    rdfs:domain ind:UatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outstandingIssuesCount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Issues Count' ;
    rdfs:comment 'Number of defects or issues identified during the UAT session that remain unresolved at the time of the UAT decision. Key input to the conditional acceptance or rejection determination.' ;
    rdfs:domain ind:UatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:participantGroupName rdf:type rdf:Property ;
    rdfs:label 'Participant Group Name' ;
    rdfs:comment 'Name or label of the participant cohort involved in the UAT session (e.g., \'Internal QA Team\', \'Partner Studio Beta Group\', \'Community Beta Cohort A\'). Identifies the testing audience for segmentation and reporting.' ;
    rdfs:domain ind:UatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantGroupType rdf:type rdf:Property ;
    rdfs:label 'Participant Group Type' ;
    rdfs:comment 'Classification of the participant group by relationship to the studio: internal (employees/contractors), external_partner (publisher or co-dev partners), beta_community (registered community testers), press (media/influencer preview), first_party (console manufacturer certification team). Serves as the PARTY_REFERENCE classification for this TRANSACTION_HEADER.' ;
    rdfs:domain ind:UatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceBenchmarksMet rdf:type rdf:Property ;
    rdfs:label 'Performance Benchmarks Met' ;
    rdfs:comment 'Indicates whether the game build met defined performance benchmarks (e.g., target FPS, load times, memory usage) during the UAT session. Performance failures are a common cause of conditional acceptance.' ;
    rdfs:domain ind:UatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformCertificationScope rdf:type rdf:Property ;
    rdfs:label 'Platform Certification Scope' ;
    rdfs:comment 'Indicates whether this UAT session includes platform certification readiness testing and which certification framework applies: trc (Technical Requirements Checklist — PlayStation), tcr (Technical Certification Requirements — Xbox), lotcheck (Nintendo), app_store_review (Apple), google_play_review (Google), not_applicable (no certification scope). [ENUM-REF-CANDIDATE: trc|tcr|lotcheck|app_store_review|google_play_review|not_applicable — promote to reference product]' ;
    rdfs:domain ind:UatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regressionScope rdf:type rdf:Property ;
    rdfs:label 'Regression Scope' ;
    rdfs:comment 'Scope of regression testing included in this UAT session: full (complete regression suite), partial (targeted regression on changed areas), smoke (basic sanity checks only), none (no regression testing performed).' ;
    rdfs:domain ind:UatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionName rdf:type rdf:Property ;
    rdfs:label 'Session Name' ;
    rdfs:comment 'Human-readable name or title assigned to the UAT session (e.g., \'Title X Closed Beta UAT — PC Build 2.4.1\'). Used for identification in reports and dashboards.' ;
    rdfs:domain ind:UatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionNotes rdf:type rdf:Property ;
    rdfs:label 'Session Notes' ;
    rdfs:comment 'General free-text notes or observations recorded by the QA lead or session facilitator during or after the UAT session. Captures qualitative context not represented in structured fields.' ;
    rdfs:domain ind:UatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signOffAuthority rdf:type rdf:Property ;
    rdfs:label 'Sign Off Authority' ;
    rdfs:comment 'Name or role title of the individual or body with authority to formally approve the UAT decision (e.g., \'QA Director\', \'Executive Producer\', \'Platform Certification Lead\'). Serves as the PARTY_REFERENCE for the authorizing party on this TRANSACTION_HEADER.' ;
    rdfs:domain ind:UatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCasesBlockedCount rdf:type rdf:Property ;
    rdfs:label 'Test Cases Blocked Count' ;
    rdfs:comment 'Number of test cases that could not be executed due to blocking defects or environmental issues. Indicates incomplete coverage and may affect the validity of the UAT decision.' ;
    rdfs:domain ind:UatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testCasesFailedCount rdf:type rdf:Property ;
    rdfs:label 'Test Cases Failed Count' ;
    rdfs:comment 'Number of test cases that failed during the UAT session. Drives defect triage prioritization and re-test planning.' ;
    rdfs:domain ind:UatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testCasesPassedCount rdf:type rdf:Property ;
    rdfs:label 'Test Cases Passed Count' ;
    rdfs:comment 'Number of test cases that passed successfully during the UAT session. Used alongside total_test_cases_count to compute the test pass rate.' ;
    rdfs:domain ind:UatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalTestCasesCount rdf:type rdf:Property ;
    rdfs:label 'Total Test Cases Count' ;
    rdfs:comment 'Total number of test cases executed during the UAT session. Provides the denominator for pass/fail rate calculations and coverage reporting.' ;
    rdfs:domain ind:UatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uatDecision rdf:type rdf:Property ;
    rdfs:label 'Uat Decision' ;
    rdfs:comment 'Formal outcome decision of the UAT session: accepted (all criteria met, cleared for release), conditionally_accepted (minor outstanding issues with agreed remediation plan), rejected (critical issues prevent release), pending (decision not yet rendered).' ;
    rdfs:domain ind:UatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uatType rdf:type rdf:Property ;
    rdfs:label 'Uat Type' ;
    rdfs:comment 'Classification of the UAT session by participant scope and release phase: internal_uat (internal stakeholders only), closed_beta (invited external participants), open_beta (broad external access), soft_launch_uat (limited geographic or platform release validation).' ;
    rdfs:domain ind:UatSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryBacklogEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Backlog Employee Id' ;
    rdfs:comment 'Reference to the team member (developer, artist, designer, QA engineer) currently assigned to work on this backlog item. Maps to PARTY_REFERENCE category for TRANSACTION_HEADER role. Core field for capacity planning and workload distribution.' ;
    rdfs:domain ind:BacklogItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acceptanceCriteria rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria' ;
    rdfs:comment 'Structured definition-of-done criteria that must be satisfied for this backlog item to be accepted by the product owner or QA team. Sourced from Jira custom field. Drives UAT sign-off and release gate decisions.' ;
    rdfs:domain ind:Studio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedVersion rdf:type rdf:Property ;
    rdfs:label 'Affected Version' ;
    rdfs:comment 'The game build version in which a defect or regression was first observed. Applicable primarily to Bug issue types. Supports root-cause analysis and regression tracking across release branches.' ;
    rdfs:domain ind:BacklogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backlogItemDescription rdf:type rdf:Property ;
    rdfs:label 'Backlog Item Description' ;
    rdfs:comment 'Full narrative description of the backlog item including acceptance criteria, technical notes, and business context. Sourced from the Jira description field; may include references to design documents or Perforce changelists.' ;
    rdfs:domain ind:BacklogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockerReason rdf:type rdf:Property ;
    rdfs:label 'Blocker Reason' ;
    rdfs:comment 'Free-text description of the impediment or dependency causing this backlog item to be blocked. Populated when is_blocked is True. Used by Scrum Masters and producers to track and resolve impediments.' ;
    rdfs:domain ind:BacklogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Indicates whether this backlog item is associated with a regulatory or platform compliance requirement (e.g., GDPR data handling, COPPA age-gating, ESRB rating descriptor implementation, PCI DSS payment flow, TRC/TCR certification). Compliance-flagged items receive elevated priority and mandatory QA sign-off.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:component rdf:type rdf:Property ;
    rdfs:label 'Component' ;
    rdfs:comment 'The game system or technical component this backlog item relates to (e.g., \'Rendering\', \'Networking\', \'UI/UX\', \'Audio\', \'Physics\', \'Monetization\', \'FTUE\'). Maps to Jira Components field. Enables component-level defect density and velocity analysis.' ;
    rdfs:domain ind:BacklogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epicKey rdf:type rdf:Property ;
    rdfs:label 'Epic Key' ;
    rdfs:comment 'Reference to the parent epic that groups this backlog item under a larger feature or initiative. Enables roll-up reporting of story points and progress at the epic level.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaasLiveOpsFlag rdf:type rdf:Property ;
    rdfs:label 'Gaas Live Ops Flag' ;
    rdfs:comment 'Indicates whether this backlog item is part of the GaaS live operations cadence (e.g., seasonal content update, live event, hotfix, balance patch). GaaS-flagged items follow an expedited review and deployment pipeline distinct from standard release cycles.' ;
    rdfs:domain ind:Studio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBlocked rdf:type rdf:Property ;
    rdfs:label 'Is Blocked' ;
    rdfs:comment 'Indicates whether this backlog item is currently blocked by a dependency, external factor, or unresolved impediment. Blocked items are escalated in daily stand-ups and producer dashboards to prevent sprint velocity degradation.' ;
    rdfs:domain ind:BacklogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueKey rdf:type rdf:Property ;
    rdfs:label 'Issue Key' ;
    rdfs:comment 'The externally-known Jira issue key (e.g., GAME-1234) that uniquely identifies this backlog item within the project. Used by developers, producers, and QA to reference work items across tools and communications. Maps to BUSINESS_IDENTIFIER category for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:BacklogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueType rdf:type rdf:Property ;
    rdfs:label 'Issue Type' ;
    rdfs:comment 'Classification of the work item within the Agile/Scrum taxonomy. Drives workflow routing, estimation norms, and reporting segmentation. In Kanban or waterfall studios this maps to the equivalent work unit type (ticket, task, work order). [ENUM-REF-CANDIDATE: Epic|Story|Task|Sub-task|Bug|Spike|Tech Debt|Change Request|Improvement — promote to reference product]' ;
    rdfs:domain ind:BacklogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labels rdf:type rdf:Property ;
    rdfs:label 'Labels' ;
    rdfs:comment 'Comma-separated free-text labels applied to the backlog item for cross-cutting classification (e.g., \'GaaS\', \'MTX\', \'GDPR\', \'TRC\', \'performance\', \'accessibility\'). Sourced from Jira Labels field. Supports ad-hoc filtering and compliance tagging.' ;
    rdfs:domain ind:BacklogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalEstimateHours rdf:type rdf:Property ;
    rdfs:label 'Original Estimate Hours' ;
    rdfs:comment 'Initial time estimate in hours logged in Jira at the time of issue creation or sprint planning. Used alongside story points for studios that track both relative and absolute effort estimates.' ;
    rdfs:domain ind:BacklogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sprintCommittedDate rdf:type rdf:Property ;
    rdfs:label 'Sprint Committed Date' ;
    rdfs:comment 'The date on which this backlog item was committed to a sprint during sprint planning. Distinguishes items that were planned from the start of the sprint versus those added mid-sprint (scope creep indicator).' ;
    rdfs:domain ind:BacklogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:storyPoints rdf:type rdf:Property ;
    rdfs:label 'Story Points' ;
    rdfs:comment 'Relative effort estimate assigned to this backlog item using the Fibonacci or T-shirt sizing scale. Core input for sprint velocity calculation and producer capacity planning. Null for items not yet estimated (e.g., items in the icebox).' ;
    rdfs:domain ind:BacklogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:summary rdf:type rdf:Property ;
    rdfs:label 'Summary' ;
    rdfs:comment 'Short, human-readable title of the backlog item as entered in Jira (e.g., \'Implement loot box drop-rate display per ESRB guidelines\'). The primary label used in sprint boards, backlogs, and producer dashboards.' ;
    rdfs:domain ind:BacklogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeSpentHours rdf:type rdf:Property ;
    rdfs:label 'Time Spent Hours' ;
    rdfs:comment 'Actual hours logged against this backlog item via Jira work logs. Compared against original_estimate_hours to measure estimation accuracy and identify scope creep. Feeds into SAP S/4HANA project cost accounting.' ;
    rdfs:domain ind:BacklogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uatSignOffDate rdf:type rdf:Property ;
    rdfs:label 'Uat Sign Off Date' ;
    rdfs:comment 'The date on which the product owner or designated stakeholder completed UAT and formally accepted this backlog item. Distinct from QA sign-off; represents business acceptance rather than technical verification.' ;
    rdfs:domain ind:Studio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:repoId rdf:type rdf:Property ;
    rdfs:label 'Repo Id' ;
    rdfs:comment 'Foreign key linking to studio.repo. Business justification: Builds are generated from code in a specific Perforce repository. The build table does not have a repo_id FK. Adding repo_id FK provides proper referential integrity. No columns to remove - branch_nam' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Repo .

ind:agent rdf:type rdf:Property ;
    rdfs:label 'Agent' ;
    rdfs:comment 'Identifier of the build farm agent or machine that executed this build (e.g., \'build-agent-ps5-03\'). Used for build farm health monitoring, agent utilization analysis, and diagnosing machine-specific build failures.' ;
    rdfs:domain ind:Build ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:artifactSizeMb rdf:type rdf:Property ;
    rdfs:label 'Artifact Size Mb' ;
    rdfs:comment 'Total size of the build artifact package in megabytes. Used to monitor build bloat, enforce platform submission size limits (e.g., console disc capacity, mobile store limits), and track storage consumption trends.' ;
    rdfs:domain ind:Build ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:artifactStoragePath rdf:type rdf:Property ;
    rdfs:label 'Artifact Storage Path' ;
    rdfs:comment 'Fully qualified path or URI to the build artifact package in the artifact repository or cloud storage (e.g., \'s3://builds-bucket/game-title/2.4.1/ps5/shipping/\'). Used by QA, release engineering, and platform submission workflows to locate the build package.' ;
    rdfs:domain ind:Build ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dlcIdentifier rdf:type rdf:Property ;
    rdfs:label 'Dlc Identifier' ;
    rdfs:comment 'Identifier of the specific DLC or content pack this build packages, if applicable. Null for base game builds. Enables tracking of DLC build pipelines separately from the base game build pipeline.' ;
    rdfs:domain ind:Build ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineType rdf:type rdf:Property ;
    rdfs:label 'Engine Type' ;
    rdfs:comment 'The game engine used to compile this build. Determines the toolchain, build configuration options, and platform support matrix applicable to this build.' ;
    rdfs:domain ind:Build ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineVersion rdf:type rdf:Property ;
    rdfs:label 'Engine Version' ;
    rdfs:comment 'The specific version of the game engine used to produce this build (e.g., \'5.3.2\' for Unreal Engine 5.3.2 or \'2022.3.10f1\' for Unity). Critical for reproducing builds, diagnosing engine-specific bugs, and managing engine upgrade cycles.' ;
    rdfs:domain ind:Studio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureMessage rdf:type rdf:Property ;
    rdfs:label 'Failure Message' ;
    rdfs:comment 'A concise summary of the primary error or failure reason reported by the CI/CD pipeline for a failed build. Null for successful builds. Supports rapid triage by build engineers without requiring access to full pipeline logs.' ;
    rdfs:domain ind:Build ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureStage rdf:type rdf:Property ;
    rdfs:label 'Failure Stage' ;
    rdfs:comment 'The pipeline stage at which this build failed, if applicable (e.g., \'compile\', \'link\', \'package\', \'cook\', \'sign\', \'upload\', \'test\', \'deploy\'). Null for successful builds. Enables root-cause categorization of build failures for engineering productivity analysis. [ENUM-REF-CANDIDATE: compile|link|package|cook|sign|upload|test|deploy — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Build ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaasLiveUpdate rdf:type rdf:Property ;
    rdfs:label 'Gaas Live Update' ;
    rdfs:comment 'Indicates whether this build is a live operations update (patch, hotfix, content drop) for a GaaS title rather than a full game build. Distinguishes live service cadence builds from full release builds for operational reporting.' ;
    rdfs:domain ind:Build ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAutomatedTrigger rdf:type rdf:Property ;
    rdfs:label 'Is Automated Trigger' ;
    rdfs:comment 'Indicates whether this build was triggered automatically by the CI/CD system (e.g., on Perforce changelist submit, scheduled nightly build) as opposed to being manually triggered by a user. Supports build frequency analysis and pipeline automation coverage metrics.' ;
    rdfs:domain ind:Build ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReleaseCandidate rdf:type rdf:Property ;
    rdfs:label 'Is Release Candidate' ;
    rdfs:comment 'Indicates whether this build has been promoted to Release Candidate status, meaning it is a candidate for Gold Master designation pending final QA sign-off and platform certification. Distinct from Gold Master — an RC may still fail certification.' ;
    rdfs:domain ind:Build ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jiraReleaseVersion rdf:type rdf:Property ;
    rdfs:label 'Jira Release Version' ;
    rdfs:comment 'The Jira fix version or release label associated with this build (e.g., \'v2.4.0-RC1\'). Enables traceability between build artifacts and the set of Jira issues resolved in this release.' ;
    rdfs:domain ind:Build ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineJobName rdf:type rdf:Property ;
    rdfs:label 'Pipeline Job Name' ;
    rdfs:comment 'Name of the CI/CD pipeline job or workflow definition that produced this build (e.g., \'nightly-shipping-ps5\', \'pr-validation-pc\'). Enables filtering and aggregation of build metrics by pipeline configuration.' ;
    rdfs:domain ind:Build ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineRunReference rdf:type rdf:Property ;
    rdfs:label 'Pipeline Run Reference' ;
    rdfs:comment 'External identifier of the specific pipeline execution run in the CI/CD system (e.g., Jenkins build ID, TeamCity build ID). Enables deep-linking back to the originating pipeline run for log retrieval and debugging.' ;
    rdfs:domain ind:Build ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queuedDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Queued Duration Seconds' ;
    rdfs:comment 'Time in seconds the build spent waiting in the CI/CD queue before execution began. Distinguishes queue wait time from active compilation time for build farm capacity analysis.' ;
    rdfs:domain ind:Build ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:triggeredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Triggered Timestamp' ;
    rdfs:comment 'The exact date and time (UTC) when the build was triggered in the CI/CD pipeline. The principal business event timestamp for this build record, used for build frequency analysis, release cadence reporting, and SLA tracking.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:submitterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Submitter Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Code authorship tracking for performance reviews, IP ownership audits, and defect root cause analysis requires linking changesets to employee records. The submitter_username and submitter_display_name' ;
    rdfs:domain ind:Changelist ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bugSeverity rdf:type rdf:Property ;
    rdfs:label 'Bug Severity' ;
    rdfs:comment 'The severity level of the bug resolved by this changelist, as classified in Jira. Populated only when the changelist is a bug fix (linked_bug_id is not null). Enables analysis of critical bug fix velocity and release readiness.' ;
    rdfs:domain ind:Changelist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeCategory rdf:type rdf:Property ;
    rdfs:label 'Change Category' ;
    rdfs:comment 'Classification of the primary content type of the changelist. Distinguishes code changes from art/audio asset submissions, configuration changes, shader updates, build scripts, documentation, or test files. Enables domain-specific change volume analysis. [ENUM-REF-CANDIDATE: code|art_asset|audio|config|shader|build_script|documentation|test — promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeStatus rdf:type rdf:Property ;
    rdfs:label 'Change Status' ;
    rdfs:comment 'Current lifecycle state of the changelist as tracked by Perforce Helix Core. \'pending\' = opened but not yet submitted; \'submitted\' = committed to the depot; \'shelved\' = files stored on the server without committing (used for code review and CI gating).' ;
    rdfs:domain ind:Changelist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cicdPipelineStatus rdf:type rdf:Property ;
    rdfs:label 'Cicd Pipeline Status' ;
    rdfs:comment 'The outcome of the CI/CD pipeline run triggered by this changelist. \'passed\' = all gates cleared; \'failed\' = one or more gates failed (build break, test failure); \'pending\' = pipeline in progress; \'skipped\' = no pipeline configured; \'cancelled\' = run aborted.' ;
    rdfs:domain ind:Changelist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clDescription rdf:type rdf:Property ;
    rdfs:label 'Cl Description' ;
    rdfs:comment 'Free-text description entered by the submitter summarizing the purpose of the changelist (e.g., \'Fix crash in NPC pathfinding on Level 3\', \'Add LOD meshes for environment assets\'). Primary human-readable context for the change.' ;
    rdfs:domain ind:Changelist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clNumber rdf:type rdf:Property ;
    rdfs:label 'Cl Number' ;
    rdfs:comment 'The native Perforce Helix Core changelist number — the externally-known, monotonically increasing integer identifier assigned by the Perforce server at submission time. Used by engineers and build systems to reference a specific code or asset snapshot.' ;
    rdfs:domain ind:Changelist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fileCount rdf:type rdf:Property ;
    rdfs:label 'File Count' ;
    rdfs:comment 'Total number of files (code, assets, configs, shaders, etc.) included in this changelist. Used for change size analysis, risk assessment, and build impact estimation.' ;
    rdfs:domain ind:Studio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gameArea rdf:type rdf:Property ;
    rdfs:label 'Game Area' ;
    rdfs:comment 'The game system or area affected by this changelist (e.g., \'Combat\', \'UI\', \'Networking\', \'AI/NPC\', \'Audio\', \'Rendering\', \'Physics\', \'FTUE\'). Derived from the depot path or Jira issue component. Enables area-level change density and bug correlation analysis.' ;
    rdfs:domain ind:Changelist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGaasLiveOp rdf:type rdf:Property ;
    rdfs:label 'Is Gaas Live Op' ;
    rdfs:comment 'Indicates whether this changelist is associated with a GaaS (Game as a Service) live operations update (e.g., seasonal content drop, live event patch, balance update) rather than a standard development sprint. Enables separation of live ops cadence from core development velocity.' ;
    rdfs:domain ind:Changelist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHotfix rdf:type rdf:Property ;
    rdfs:label 'Is Hotfix' ;
    rdfs:comment 'Indicates whether this changelist is classified as a hotfix — an urgent, out-of-cycle fix submitted to a release or live branch to address a critical production issue. Hotfixes bypass normal sprint cadence and require expedited QA and cert processes.' ;
    rdfs:domain ind:Changelist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jiraIssueType rdf:type rdf:Property ;
    rdfs:label 'Jira Issue Type' ;
    rdfs:comment 'The type of the linked Jira issue (Story, Bug, Task, Epic, Sub-task, Improvement). Enables analysis of what proportion of changelists are bug fixes vs. feature work vs. technical debt.' ;
    rdfs:domain ind:Changelist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linesAdded rdf:type rdf:Property ;
    rdfs:label 'Lines Added' ;
    rdfs:comment 'Number of lines of code or text added across all files in this changelist. Used for developer productivity metrics and code churn analysis. Applicable to text/code files; may be zero for binary asset-only changelists.' ;
    rdfs:domain ind:Changelist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:linesDeleted rdf:type rdf:Property ;
    rdfs:label 'Lines Deleted' ;
    rdfs:comment 'Number of lines of code or text deleted across all files in this changelist. Used alongside lines_added for code churn and refactoring analysis.' ;
    rdfs:domain ind:Changelist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:perforceServerReference rdf:type rdf:Property ;
    rdfs:label 'Perforce Server Reference' ;
    rdfs:comment 'The identifier of the Perforce Helix Core server instance from which this changelist originates. Relevant for studios operating multiple Perforce servers (e.g., per-studio, per-region, or edge servers). Enables multi-server federation and data lineage.' ;
    rdfs:domain ind:Changelist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Qa Validation Status' ;
    rdfs:comment 'The Quality Assurance (QA) validation outcome for this changelist, indicating whether the change has been verified by the QA team. \'not_required\' = change type exempt from QA gate; \'pending\' = awaiting QA; \'passed\' = QA approved; \'failed\' = QA identified issues.' ;
    rdfs:domain ind:Changelist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revertsClNumber rdf:type rdf:Property ;
    rdfs:label 'Reverts Cl Number' ;
    rdfs:comment 'If this changelist is a revert of a previous submission, this field stores the original Perforce CL number that was reverted. Enables revert chain analysis and build stability tracking. Null if this is not a revert.' ;
    rdfs:domain ind:Changelist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewApprovedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Approved Timestamp' ;
    rdfs:comment 'The date and time (UTC) when the code or asset review for this changelist was approved. Used to measure review cycle time and enforce pre-submit review gates.' ;
    rdfs:domain ind:Changelist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewerUsername rdf:type rdf:Property ;
    rdfs:label 'Reviewer Username' ;
    rdfs:comment 'The Perforce/Swarm username of the primary code or asset reviewer assigned to this changelist. Used for review workload analysis and accountability tracking.' ;
    rdfs:domain ind:Changelist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelvedForReview rdf:type rdf:Property ;
    rdfs:label 'Shelved For Review' ;
    rdfs:comment 'Indicates whether this changelist was shelved specifically to facilitate a pre-submit code or asset review (as opposed to being shelved for backup or work-in-progress purposes). Used to track review-gated submission workflows.' ;
    rdfs:domain ind:Changelist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceBranch rdf:type rdf:Property ;
    rdfs:label 'Source Branch' ;
    rdfs:comment 'The source branch or stream from which this changelist was integrated or merged (e.g., //GameTitle/dev integrated into //GameTitle/main). Populated for integration changelists. Enables branch merge history and integration tracking.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:streamName rdf:type rdf:Property ;
    rdfs:label 'Stream Name' ;
    rdfs:comment 'The Perforce stream (e.g., //GameTitle/main, //GameTitle/dev, //GameTitle/release/1.5) to which this changelist belongs. Streams represent branching strategy and are critical for build pipeline routing and release management.' ;
    rdfs:domain ind:Changelist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submitTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submit Timestamp' ;
    rdfs:comment 'The exact date and time (UTC) at which the changelist was submitted to the Perforce depot. This is the principal real-world business event timestamp for this transaction. Null for pending or shelved changelists.' ;
    rdfs:domain ind:Changelist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalFileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Total File Size Bytes' ;
    rdfs:comment 'The aggregate size in bytes of all files included in this changelist. Used for depot storage impact analysis, CDN pre-warming estimation for patches, and identifying large binary asset submissions that may impact build times.' ;
    rdfs:domain ind:Changelist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workspaceName rdf:type rdf:Property ;
    rdfs:label 'Workspace Name' ;
    rdfs:comment 'The Perforce client workspace name from which the changelist was submitted. Identifies the developer\'s local workspace configuration and maps to a specific machine/environment.' ;
    rdfs:domain ind:Changelist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualShipDate rdf:type rdf:Property ;
    rdfs:label 'Actual Ship Date' ;
    rdfs:comment 'Actual date the game title or update was released to players. Compared against target_ship_date to measure schedule adherence. Populated upon post-launch phase entry.' ;
    rdfs:domain ind:DevProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Cert Approval Date' ;
    rdfs:comment 'Date on which the platform certification submission was approved by the first-party platform holder. Null until certification is granted. Drives final release scheduling.' ;
    rdfs:domain ind:Studio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Cert Submission Date' ;
    rdfs:comment 'Date on which the build was submitted to first-party platform holders (e.g., Sony, Microsoft, Nintendo) for Technical Requirements Checklist (TRC) / Technical Certification Requirements (TCR) review via Steamworks or Console SDKs.' ;
    rdfs:domain ind:Studio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cicdPipelineUrl rdf:type rdf:Property ;
    rdfs:label 'Cicd Pipeline Url' ;
    rdfs:comment 'URL or identifier of the Continuous Integration/Continuous Deployment (CI/CD) build pipeline associated with this project. Used for build automation, release gate management, and deployment tracking.' ;
    rdfs:domain ind:Studio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coppaApplicable rdf:type rdf:Property ;
    rdfs:label 'Coppa Applicable' ;
    rdfs:comment 'Indicates whether this project is subject to Children\'s Online Privacy Protection Act (COPPA) compliance requirements due to targeting players under 13 years of age. Triggers additional data privacy controls and parental consent workflows.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalBugCount rdf:type rdf:Property ;
    rdfs:label 'Critical Bug Count' ;
    rdfs:comment 'Current count of critical or blocker severity defect tickets in Jira for this project. A non-zero value typically blocks Gold Master (GM) approval and first-party certification submission.' ;
    rdfs:domain ind:Studio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentSprintNumber rdf:type rdf:Property ;
    rdfs:label 'Current Sprint Number' ;
    rdfs:comment 'The sequential number of the currently active sprint for this development project as tracked in Jira. Used for progress reporting and velocity analysis.' ;
    rdfs:domain ind:DevProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:developmentMethodology rdf:type rdf:Property ;
    rdfs:label 'Development Methodology' ;
    rdfs:comment 'Software development methodology adopted for this project. Determines sprint cadence, backlog management approach, and release planning structure within Jira.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gameEngine rdf:type rdf:Property ;
    rdfs:label 'Game Engine' ;
    rdfs:comment 'Primary game engine technology used for development. Determines asset pipeline, rendering, physics, and scripting toolchain. Sourced from project configuration in Unity or Unreal Engine.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasMtx rdf:type rdf:Property ;
    rdfs:label 'Has Mtx' ;
    rdfs:comment 'Indicates whether this project includes in-game Microtransactions (MTX) or In-App Purchases (IAP) as part of its monetization model. Triggers additional regulatory review requirements under FTC consumer protection and COPPA compliance for titles targeting minors.' ;
    rdfs:domain ind:DevProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasUgc rdf:type rdf:Property ;
    rdfs:label 'Has Ugc' ;
    rdfs:comment 'Indicates whether this project includes User-Generated Content (UGC) features. Triggers content moderation requirements, GDPR data processing obligations, and compliance review under the European Commission Digital Services Act.' ;
    rdfs:domain ind:DevProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:headcountAllocated rdf:type rdf:Property ;
    rdfs:label 'Headcount Allocated' ;
    rdfs:comment 'Number of full-time equivalent (FTE) staff allocated to this development project at the current point in time. Used for resource planning and capacity management.' ;
    rdfs:domain ind:DevProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isGaasTitle rdf:type rdf:Property ;
    rdfs:label 'Is Gaas Title' ;
    rdfs:comment 'Indicates whether this project is operating under a Game-as-a-Service (GaaS) live operations model with ongoing post-launch content updates and live service management. Drives live ops cadence planning and resource allocation.' ;
    rdfs:domain ind:DevProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milestoneCompletionPct rdf:type rdf:Property ;
    rdfs:label 'Milestone Completion Pct' ;
    rdfs:comment 'Percentage of project milestones completed relative to total planned milestones, as tracked in Jira. Provides a high-level progress indicator for executive reporting and stakeholder updates.' ;
    rdfs:domain ind:DevProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openBugCount rdf:type rdf:Property ;
    rdfs:label 'Open Bug Count' ;
    rdfs:comment 'Current count of open defect tickets in Jira for this project across all severity levels. Key Quality Assurance (QA) health indicator used in milestone readiness reviews.' ;
    rdfs:domain ind:DevProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectPhase rdf:type rdf:Property ;
    rdfs:label 'Project Phase' ;
    rdfs:comment 'Current phase in the game development lifecycle. Values: pre_production, production, alpha, beta, gold_master (Gold Master (GM) — final build approved for manufacturing/distribution), post_launch. Sourced from Jira project status and milestone tracking.' ;
    rdfs:domain ind:Studio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectStatus rdf:type rdf:Property ;
    rdfs:label 'Project Status' ;
    rdfs:comment 'Current operational lifecycle status of the development project. Distinct from project_phase (which tracks development stage); this field tracks the administrative state of the project record.' ;
    rdfs:domain ind:DevProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sprintCadenceWeeks rdf:type rdf:Property ;
    rdfs:label 'Sprint Cadence Weeks' ;
    rdfs:comment 'Duration of each sprint in weeks as configured in Jira for Scrum or Agile projects (typically 1, 2, or 3 weeks). Drives sprint planning, backlog grooming, and velocity tracking.' ;
    rdfs:domain ind:DevProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetShipDate rdf:type rdf:Property ;
    rdfs:label 'Target Ship Date' ;
    rdfs:comment 'Planned release or ship date for the game title or update produced by this project. Used for milestone planning, first-party certification scheduling, and marketing campaign alignment.' ;
    rdfs:domain ind:DevProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engineConfigId rdf:type rdf:Property ;
    rdfs:label 'Engine Config Id' ;
    rdfs:comment 'Unique surrogate identifier for the engine configuration record. Primary key for this entity.' ;
    rdfs:domain ind:EngineConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approved By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Engine configuration approval workflows for platform certification and build pipeline stability require tracking which technical lead or architect authorized each config version. The approved_by text ' ;
    rdfs:domain ind:EngineConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:animationSystem rdf:type rdf:Property ;
    rdfs:label 'Animation System' ;
    rdfs:comment 'Animation system module enabled in this engine configuration, e.g., Unity Animator/Mecanim, Unreal Control Rig, Unreal Sequencer, or a custom animation pipeline. Affects character fidelity, memory budget, and asset pipeline tooling.' ;
    rdfs:domain ind:EngineConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiBackend rdf:type rdf:Property ;
    rdfs:label 'Api Backend' ;
    rdfs:comment 'Graphics API (Application Programming Interface) backend configured for this engine, e.g., DirectX 12, Vulkan, Metal (Apple), GNM/AGC (PlayStation). Determines platform compatibility, driver requirements, and rendering feature availability. [ENUM-REF-CANDIDATE: DirectX12|DirectX11|Vulkan|Metal|OpenGL|GNM|AGC — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EngineConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioMiddleware rdf:type rdf:Property ;
    rdfs:label 'Audio Middleware' ;
    rdfs:comment 'Audio middleware or engine audio module enabled in this configuration, e.g., FMOD Studio, Wwise, Unity Audio, Unreal Audio Engine. Determines spatial audio capabilities, memory budget for audio assets, and platform audio certification requirements.' ;
    rdfs:domain ind:EngineConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configDescription rdf:type rdf:Property ;
    rdfs:label 'Config Description' ;
    rdfs:comment 'Free-text description of the purpose, scope, and notable settings of this engine configuration record. Provides context for build engineers, QA teams, and technical directors reviewing configuration history.' ;
    rdfs:domain ind:EngineConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drawCallBudget rdf:type rdf:Property ;
    rdfs:label 'Draw Call Budget' ;
    rdfs:comment 'Maximum allowed GPU draw calls per frame defined in this engine configuration. A key rendering performance budget threshold used to enforce LOD, batching, and culling strategies during QA and build pipeline validation.' ;
    rdfs:domain ind:EngineConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drmSolution rdf:type rdf:Property ;
    rdfs:label 'Drm Solution' ;
    rdfs:comment 'Digital Rights Management (DRM) solution integrated in this engine configuration\'s shipping build, e.g., Denuvo, Steam DRM, Epic Games Store DRM, or platform-native DRM (PlayStation, Xbox). Affects build pipeline steps, certification requirements, and performance overhead.' ;
    rdfs:domain ind:EngineConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enginePlatform rdf:type rdf:Property ;
    rdfs:label 'Engine Platform' ;
    rdfs:comment 'The game engine platform used for this project configuration, e.g., Unity, Unreal Engine, or a proprietary in-house engine. Drives build pipeline toolchain selection and SDK compatibility requirements.' ;
    rdfs:domain ind:EngineConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaasLiveOpsEnabled rdf:type rdf:Property ;
    rdfs:label 'Gaas Live Ops Enabled' ;
    rdfs:comment 'Indicates whether this engine configuration includes live operations (GaaS) modules such as hot-patch delivery, remote config, live event scripting, or over-the-air asset streaming. Relevant for GaaS titles requiring post-launch content updates without full re-certification.' ;
    rdfs:domain ind:Studio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTemplate rdf:type rdf:Property ;
    rdfs:label 'Is Template' ;
    rdfs:comment 'Indicates whether this engine configuration record is a reusable template that can be applied across multiple projects. Template configs are maintained centrally and referenced by project-specific configs to enforce studio-wide engine standards.' ;
    rdfs:domain ind:EngineConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jiraConfigTicket rdf:type rdf:Property ;
    rdfs:label 'Jira Config Ticket' ;
    rdfs:comment 'Jira ticket key associated with the change request or epic that introduced or last modified this engine configuration, e.g., \'ALPHA-1042\'. Provides traceability between configuration changes and sprint/backlog items in the project management system.' ;
    rdfs:domain ind:EngineConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lodConfigEnabled rdf:type rdf:Property ;
    rdfs:label 'Lod Config Enabled' ;
    rdfs:comment 'Indicates whether Level of Detail (LOD) mesh reduction and streaming is enabled in this engine configuration. LOD management is critical for maintaining target FPS across hardware tiers and reducing GPU draw call budgets.' ;
    rdfs:domain ind:EngineConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lodLevels rdf:type rdf:Property ;
    rdfs:label 'Lod Levels' ;
    rdfs:comment 'Number of LOD levels configured for mesh assets in this engine configuration, e.g., 3 or 4 levels. Higher LOD level counts improve performance on lower-end hardware but increase asset pipeline complexity and storage requirements.' ;
    rdfs:domain ind:EngineConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minOsVersion rdf:type rdf:Property ;
    rdfs:label 'Min Os Version' ;
    rdfs:comment 'Minimum operating system or firmware version required to run a build produced from this engine configuration, e.g., \'iOS 15.0\', \'Android 10\', \'Windows 10 21H2\'. Drives app store metadata, platform certification eligibility, and player hardware requirement disclosures.' ;
    rdfs:domain ind:EngineConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkingSdk rdf:type rdf:Property ;
    rdfs:label 'Networking Sdk' ;
    rdfs:comment 'Networking SDK or middleware module enabled in this configuration, e.g., \'Photon\', \'Mirror\', \'Unity Netcode for GameObjects\', \'Unreal Online Subsystem\', \'EOS (Epic Online Services)\', \'PlayFab\'. Determines multiplayer architecture and CCU/PCU scalability characteristics.' ;
    rdfs:domain ind:EngineConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicsEngine rdf:type rdf:Property ;
    rdfs:label 'Physics Engine' ;
    rdfs:comment 'Physics simulation engine module enabled in this configuration, e.g., PhysX (Unity/Unreal legacy), Chaos (Unreal 5+), Havok, or a custom physics solution. Affects simulation fidelity, CPU budget, and platform compatibility.' ;
    rdfs:domain ind:EngineConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renderingPipeline rdf:type rdf:Property ;
    rdfs:label 'Rendering Pipeline' ;
    rdfs:comment 'The rendering pipeline module enabled for this engine configuration, e.g., Unity URP (Universal Render Pipeline), Unity HDRP (High Definition Render Pipeline), Unreal Lumen/Nanite, or a custom deferred/forward renderer. Determines visual fidelity capabilities and GPU performance budget. [ENUM-REF-CANDIDATE: URP|HDRP|Built-In|Lumen|Nanite|Custom|Deferred|Forward — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EngineConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scriptingBackend rdf:type rdf:Property ;
    rdfs:label 'Scripting Backend' ;
    rdfs:comment 'Scripting backend or language runtime used in this engine configuration, e.g., Unity Mono, Unity IL2CPP, Unreal Blueprints, Unreal C++. Affects build times, runtime performance, platform compatibility, and DRM/obfuscation capabilities.' ;
    rdfs:domain ind:EngineConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdkVersions rdf:type rdf:Property ;
    rdfs:label 'Sdk Versions' ;
    rdfs:comment 'JSON-serialized or comma-delimited map of platform SDK versions included in this engine configuration, e.g., \'PS5SDK:10.0.0,GDK:221000,iOS:17.0\'. Required for platform certification (TRC/TCR) compliance verification and first-party submission readiness.' ;
    rdfs:domain ind:EngineConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shaderModelVersion rdf:type rdf:Property ;
    rdfs:label 'Shader Model Version' ;
    rdfs:comment 'DirectX Shader Model version targeted by this engine configuration, e.g., \'SM5\', \'SM6\'. Determines GPU feature set availability (ray tracing, mesh shaders) and minimum hardware requirements for platform certification.' ;
    rdfs:domain ind:EngineConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateSourceReference rdf:type rdf:Property ;
    rdfs:label 'Template Source Reference' ;
    rdfs:comment 'Reference to the parent template engine configuration from which this project-specific configuration was derived. Null if this record is itself a template or was created from scratch. Enables template lineage tracking and bulk template update propagation.' ;
    rdfs:domain ind:EngineConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:textureBudgetMb rdf:type rdf:Property ;
    rdfs:label 'Texture Budget Mb' ;
    rdfs:comment 'Maximum allowed GPU texture memory in megabytes (MB) for this engine configuration. Enforced during asset pipeline validation and QA performance benchmarking to prevent VRAM overflow on target platform hardware.' ;
    rdfs:domain ind:EngineConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentStudioGameStudioId rdf:type rdf:Property ;
    rdfs:label 'Parent Studio Game Studio Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent studio entity when this studio is a subsidiary, satellite office, or acquired label operating under a parent studio umbrella. Null for top-level independent studios. Enables hierarchical studio organisation modelling for consolidated reporting and M&A tracking.' ;
    rdfs:domain ind:GameStudio ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GameStudio .

ind:activeProjectCount rdf:type rdf:Property ;
    rdfs:label 'Active Project Count' ;
    rdfs:comment 'Number of active game development projects currently assigned to this studio. Sourced from Jira project tracking. Used for capacity planning, resource allocation decisions, and studio workload management. This is a point-in-time operational field, not a calculated aggregate — it reflects the current count as maintained in the source system.' ;
    rdfs:domain ind:GameStudio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cicdPipelineEnabled rdf:type rdf:Property ;
    rdfs:label 'Cicd Pipeline Enabled' ;
    rdfs:comment 'Indicates whether the studio\'s production pipeline is integrated with the enterprise CI/CD (Continuous Integration/Continuous Deployment) release gate infrastructure. True if automated build, test, and deployment pipelines are active for this studio\'s projects. Drives release governance and gold master certification workflows.' ;
    rdfs:domain ind:GameStudio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractTier rdf:type rdf:Property ;
    rdfs:label 'Contract Tier' ;
    rdfs:comment 'Classification of the studio\'s contractual relationship tier with the publishing organisation. Strategic partners receive preferential terms, dedicated producer support, and co-marketing; preferred partners have established multi-title agreements; standard partners operate under standard development agreements; transactional partners are engaged for specific work-for-hire deliverables. Drives commercial terms, SLA commitments, and resource allocation priority.' ;
    rdfs:domain ind:GameStudio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmAccountReference rdf:type rdf:Property ;
    rdfs:label 'Crm Account Reference' ;
    rdfs:comment 'External account identifier for this studio in Salesforce CRM. Used to link studio master data to CRM account records for partner relationship management, campaign tracking, and case management. Enables cross-system reconciliation between the enterprise data lakehouse and Salesforce.' ;
    rdfs:domain ind:GameStudio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProcessingAgreement rdf:type rdf:Property ;
    rdfs:label 'Data Processing Agreement' ;
    rdfs:comment 'Indicates whether a Data Processing Agreement (DPA) has been executed with this studio as required under GDPR Article 28 for studios that process personal data of EU players on behalf of the publisher. True if a valid DPA is in place. Critical for GDPR compliance and data protection audit trails.' ;
    rdfs:domain ind:GameStudio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enginePrimary rdf:type rdf:Property ;
    rdfs:label 'Engine Primary' ;
    rdfs:comment 'Primary game engine technology used by the studio for production. Drives toolchain compatibility assessment, CI/CD pipeline configuration, asset pipeline standards, and engine licensing cost allocation. Unity and Unreal Engine are the primary operational systems of record for game development.' ;
    rdfs:domain ind:GameStudio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpVendorReference rdf:type rdf:Property ;
    rdfs:label 'Erp Vendor Reference' ;
    rdfs:comment 'Vendor master identifier for this studio in SAP S/4HANA. Used for purchase order processing, accounts payable, contract milestone payments, and financial reporting. Enables reconciliation between studio master data and ERP financial transactions.' ;
    rdfs:domain ind:GameStudio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esrbRegistered rdf:type rdf:Property ;
    rdfs:label 'Esrb Registered' ;
    rdfs:comment 'Indicates whether the studio is registered with the ESRB (Entertainment Software Rating Board) for North American content rating submissions. Required for all studios publishing titles on North American console and PC platforms. Drives rating submission workflow eligibility.' ;
    rdfs:domain ind:GameStudio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gaasCapable rdf:type rdf:Property ;
    rdfs:label 'Gaas Capable' ;
    rdfs:comment 'Indicates whether the studio has demonstrated capability to support live operations and Game-as-a-Service (GaaS) post-launch cadence, including live events, seasonal content drops, balance patches, and in-game monetisation updates. True if the studio has shipped or is actively supporting a GaaS title.' ;
    rdfs:domain ind:GameStudio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:headcountRange rdf:type rdf:Property ;
    rdfs:label 'Headcount Range' ;
    rdfs:comment 'Approximate employee headcount band for the studio. Used for capacity planning, resource allocation sizing, and vendor risk tiering. Expressed as a range rather than exact count to accommodate external studios where precise headcount is not contractually disclosed.' ;
    rdfs:domain ind:GameStudio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hqCity rdf:type rdf:Property ;
    rdfs:label 'Hq City' ;
    rdfs:comment 'City name of the studio\'s primary headquarters. Used for geographic reporting, time zone determination for sprint ceremonies, and partner directory listings.' ;
    rdfs:domain ind:GameStudio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hqStateProvince rdf:type rdf:Property ;
    rdfs:label 'Hq State Province' ;
    rdfs:comment 'State or province of the studio\'s primary headquarters. Used for sub-national regulatory compliance, tax jurisdiction, and geographic segmentation in partner reporting.' ;
    rdfs:domain ind:GameStudio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipOwnershipModel rdf:type rdf:Property ;
    rdfs:label 'Ip Ownership Model' ;
    rdfs:comment 'Defines the intellectual property ownership arrangement for titles developed by this studio. Publisher-owned means all IP vests in the publishing entity; studio-owned means the studio retains IP with a publishing licence granted; co-owned means shared IP rights; licensed_in means the studio develops under a third-party IP licence; licensed_out means the studio\'s IP is licensed to the publisher. Critical for legal, finance, and M&A due diligence.' ;
    rdfs:domain ind:GameStudio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso27001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso27001 Certified' ;
    rdfs:comment 'Indicates whether the studio holds a current ISO/IEC 27001 Information Security Management System certification. Used for vendor risk tiering, security due diligence, and determining whether enhanced security controls are required in the development agreement.' ;
    rdfs:domain ind:GameStudio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pciDssCompliant rdf:type rdf:Property ;
    rdfs:label 'Pci Dss Compliant' ;
    rdfs:comment 'Indicates whether the studio is PCI DSS (Payment Card Industry Data Security Standard) compliant. Required for studios that handle in-app purchase (IAP) payment flows or store payment card data. Drives payment processing eligibility and monetisation integration approvals.' ;
    rdfs:domain ind:GameStudio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pegiRegistered rdf:type rdf:Property ;
    rdfs:label 'Pegi Registered' ;
    rdfs:comment 'Indicates whether the studio is registered with PEGI (Pan European Game Information) for European content rating submissions. Required for studios publishing titles in European markets. Drives rating submission workflow eligibility and Digital Services Act compliance.' ;
    rdfs:domain ind:GameStudio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformFocus rdf:type rdf:Property ;
    rdfs:label 'Platform Focus' ;
    rdfs:comment 'Primary target platform(s) for which the studio develops games. Console includes PlayStation, Xbox, Nintendo; PC includes Steam and Epic Games Store; mobile includes iOS and Android; cross_platform spans multiple platforms; VR/AR (Virtual Reality/Augmented Reality) includes Meta Quest and PSVR; cloud includes streaming platforms. Used for platform certification routing (TRC/TCR) and Steamworks/Console SDK capability assessment.' ;
    rdfs:domain ind:GameStudio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaEmbedded rdf:type rdf:Property ;
    rdfs:label 'Qa Embedded' ;
    rdfs:comment 'Indicates whether the studio has an embedded Quality Assurance (QA) and playtesting function operating within its production pipeline. True if the studio runs internal QA cycles; False if QA is fully outsourced or handled by the publisher. Drives QA resource allocation and test plan ownership in the quality domain.' ;
    rdfs:domain ind:GameStudio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueSharePct rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Pct' ;
    rdfs:comment 'Contractually agreed revenue share percentage payable to the studio from net game revenues. Expressed as a percentage (e.g., 25.00 for 25%). Used for royalty calculation, financial forecasting, and P&L attribution in SAP S/4HANA CO module.' ;
    rdfs:domain ind:GameStudio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soc2Compliant rdf:type rdf:Property ;
    rdfs:label 'Soc2 Compliant' ;
    rdfs:comment 'Indicates whether the studio has achieved SOC 2 (Service Organization Controls Type 2) compliance for cloud-hosted development infrastructure and services. Used for vendor security risk assessment, particularly for studios operating cloud build pipelines or hosting player-facing services.' ;
    rdfs:domain ind:GameStudio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialization rdf:type rdf:Property ;
    rdfs:label 'Specialization' ;
    rdfs:comment 'Primary production specialization of the studio indicating the game tier or platform focus. AAA studios produce high-budget console/PC titles; indie studios produce lower-budget creative titles; mobile studios focus on iOS/Android; VR/AR (Virtual Reality/Augmented Reality) studios focus on immersive platforms; casual studios produce mass-market titles; mid-core studios target engaged but non-hardcore audiences; esports studios build competitive titles; engine_tech studios focus on game engine tooling. Drives project assignment eligibility and capability matching. [ENUM-REF-CANDIDATE: aaa|indie|mobile|vr_ar|casual|mid_core|esports|engine_tech — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:titlesShippedCount rdf:type rdf:Property ;
    rdfs:label 'Titles Shipped Count' ;
    rdfs:comment 'Total number of commercially released game titles shipped by this studio across all platforms and publishing relationships. Used as a proxy for studio experience and production maturity in partner evaluation and project assignment decisions.' ;
    rdfs:domain ind:GameStudio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vcsDepotPath rdf:type rdf:Property ;
    rdfs:label 'Vcs Depot Path' ;
    rdfs:comment 'Root depot path in Perforce Helix Core assigned to this studio for version control and digital asset management. Used to scope code reviews, build triggers, and access control policies. Enables traceability from studio entity to source code and asset repositories.' ;
    rdfs:domain ind:GameStudio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liveOpsCycleId rdf:type rdf:Property ;
    rdfs:label 'Live Ops Cycle Id' ;
    rdfs:comment 'Primary key for live_ops_cycle' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LiveOpsCycle .

ind:actualDevHours rdf:type rdf:Property ;
    rdfs:label 'Actual Dev Hours' ;
    rdfs:comment 'Actual development effort in person-hours consumed to produce this live ops cycle. Compared against estimated_dev_hours to measure estimation accuracy and inform future sprint planning.' ;
    rdfs:domain ind:LiveOpsCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cicdPipelineRunReference rdf:type rdf:Property ;
    rdfs:label 'Cicd Pipeline Run Reference' ;
    rdfs:comment 'Identifier of the CI/CD pipeline run that produced and validated the deployable build for this cycle. Enables traceability from the live ops cycle to the automated build, test, and deployment pipeline execution.' ;
    rdfs:domain ind:LiveOpsCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentScopeSummary rdf:type rdf:Property ;
    rdfs:label 'Content Scope Summary' ;
    rdfs:comment 'Free-text summary of the content included in this live ops cycle (e.g., new maps, characters, weapons, story chapters, balance changes, bug fixes). Sourced from the live ops calendar or Jira epic descriptions. Used for player communication and internal scope tracking.' ;
    rdfs:domain ind:LiveOpsCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalBugCountAtRelease rdf:type rdf:Property ;
    rdfs:label 'Critical Bug Count At Release' ;
    rdfs:comment 'Number of critical-severity bugs open at the time of release for this cycle. A non-zero value may indicate a waived release gate. Used for post-release incident risk assessment and QA process improvement.' ;
    rdfs:domain ind:LiveOpsCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cycleCode rdf:type rdf:Property ;
    rdfs:label 'Cycle Code' ;
    rdfs:comment 'Short alphanumeric business identifier for the cycle used in Jira release planning, build pipelines, and internal tracking (e.g., \'S04\', \'PATCH-2.3\', \'EVT-WINTER-2024\'). Externally known code referenced across production tools.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentRegion rdf:type rdf:Property ;
    rdfs:label 'Deployment Region' ;
    rdfs:comment 'Geographic region or rollout scope for this cycle deployment (e.g., \'GLOBAL\', \'NA\', \'EU\', \'APAC\', or specific country codes for soft-launch or staged rollouts). Supports regional compliance and staggered deployment strategies.' ;
    rdfs:domain ind:LiveOpsCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esrbContentDescriptor rdf:type rdf:Property ;
    rdfs:label 'Esrb Content Descriptor' ;
    rdfs:comment 'ESRB content descriptor applicable to new content introduced in this cycle (e.g., \'Violence\', \'In-Game Purchases\', \'Users Interact\'). Required for compliance with ESRB rating maintenance obligations when new content changes the rating profile of the game.' ;
    rdfs:domain ind:LiveOpsCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDevHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Dev Hours' ;
    rdfs:comment 'Total estimated development effort in person-hours allocated to produce this live ops cycle. Used for resource planning, sprint capacity management, and post-cycle retrospective analysis of estimation accuracy.' ;
    rdfs:domain ind:LiveOpsCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hasBattlePass rdf:type rdf:Property ;
    rdfs:label 'Has Battle Pass' ;
    rdfs:comment 'Indicates whether this cycle includes a battle pass product offering. Distinct from the general MTX tie-in flag as battle passes have specific revenue recognition, player engagement, and retention analytics implications.' ;
    rdfs:domain ind:LiveOpsCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasMtxTieIn rdf:type rdf:Property ;
    rdfs:label 'Has Mtx Tie In' ;
    rdfs:comment 'Indicates whether this live ops cycle includes a direct microtransaction (MTX) monetization component such as a battle pass, limited-time store bundle, or premium currency event. True = monetization tie-in present; False = no direct MTX component.' ;
    rdfs:domain ind:LiveOpsCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLimitedTime rdf:type rdf:Property ;
    rdfs:label 'Is Limited Time' ;
    rdfs:comment 'Indicates whether this cycle is a time-bounded limited-time event (LTE) with a hard end date after which content is no longer accessible. Drives urgency-based player communication and FOMO-driven engagement strategies.' ;
    rdfs:domain ind:LiveOpsCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jiraReleaseKey rdf:type rdf:Property ;
    rdfs:label 'Jira Release Key' ;
    rdfs:comment 'The Jira release/version identifier associated with this live ops cycle in the project management system (e.g., Jira Fix Version ID). Enables traceability from the live ops cycle back to the Jira backlog, epics, and sprint planning artifacts.' ;
    rdfs:domain ind:Studio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openBugCountAtRelease rdf:type rdf:Property ;
    rdfs:label 'Open Bug Count At Release' ;
    rdfs:comment 'Number of open (unresolved) bugs in Jira at the time this cycle was released to production. Captures the known-issues baseline at deployment, used for post-release quality tracking and player support readiness.' ;
    rdfs:domain ind:LiveOpsCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:patchNotesUrl rdf:type rdf:Property ;
    rdfs:label 'Patch Notes Url' ;
    rdfs:comment 'URL to the published patch notes or release notes document for this cycle. Used by community management, player support (Zendesk), and analytics teams to correlate player behavior changes with specific content updates.' ;
    rdfs:domain ind:LiveOpsCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pegiContentDescriptor rdf:type rdf:Property ;
    rdfs:label 'Pegi Content Descriptor' ;
    rdfs:comment 'PEGI content descriptor applicable to new content introduced in this cycle for European markets. Required for compliance with PEGI rating maintenance obligations when live content updates affect the game\'s rating classification.' ;
    rdfs:domain ind:LiveOpsCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perforceLabel rdf:type rdf:Property ;
    rdfs:label 'Perforce Label' ;
    rdfs:comment 'The Perforce Helix Core label or changelist snapshot associated with the build deployed for this cycle. Provides version control traceability for the exact codebase and asset state shipped.' ;
    rdfs:domain ind:LiveOpsCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerCommsPlanRef rdf:type rdf:Property ;
    rdfs:label 'Player Comms Plan Ref' ;
    rdfs:comment 'Reference identifier or URL pointing to the player communication plan document for this cycle (e.g., patch notes document ID, community blog post URL, CRM campaign reference). Links production planning to community management and marketing execution.' ;
    rdfs:domain ind:LiveOpsCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rollbackVersion rdf:type rdf:Property ;
    rdfs:label 'Rollback Version' ;
    rdfs:comment 'The build version to which the game would be rolled back if this cycle deployment fails or causes critical issues. Defined as part of the deployment risk management plan for each live ops cycle.' ;
    rdfs:domain ind:LiveOpsCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sprintCount rdf:type rdf:Property ;
    rdfs:label 'Sprint Count' ;
    rdfs:comment 'Number of Jira sprints consumed to develop and deliver this live ops cycle. Used for production cadence analysis and GaaS live operations velocity benchmarking.' ;
    rdfs:domain ind:LiveOpsCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signOffOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Sign Off Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Milestone approval workflows require tracking which employee is accountable for sign-off to enforce greenlight gates, publisher deliverables, and certification submissions. The sign_off_owner text fie' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualDate rdf:type rdf:Property ;
    rdfs:label 'Actual Date' ;
    rdfs:comment 'The actual calendar date on which the milestone was achieved and accepted. Null if the milestone has not yet been completed. Used to calculate schedule variance against planned and revised dates.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blockerCount rdf:type rdf:Property ;
    rdfs:label 'Blocker Count' ;
    rdfs:comment 'The number of open blocking issues (P0/P1 bugs or critical dependencies) preventing milestone completion at the time of last update. Sourced from Jira bug tracking. A non-zero value typically prevents sign-off and triggers escalation.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliverablesChecklistUrl rdf:type rdf:Property ;
    rdfs:label 'Deliverables Checklist Url' ;
    rdfs:comment 'URL or deep-link reference to the associated deliverables checklist document for this milestone (e.g., a Confluence page, Shotgrid task list, or Jira epic). Captures the list of required artifacts and acceptance criteria for milestone completion.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverablesCompleted rdf:type rdf:Property ;
    rdfs:label 'Deliverables Completed' ;
    rdfs:comment 'The number of deliverable items in the milestone checklist that have been completed and accepted at the time of last update. Used with deliverables_total for progress tracking.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliverablesTotal rdf:type rdf:Property ;
    rdfs:label 'Deliverables Total' ;
    rdfs:comment 'The total number of discrete deliverable items defined in the milestone checklist. Used alongside deliverables_completed to calculate completion percentage for progress reporting.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isGreenlightGate rdf:type rdf:Property ;
    rdfs:label 'Is Greenlight Gate' ;
    rdfs:comment 'Boolean flag indicating whether this milestone serves as a greenlight decision point requiring executive or publisher approval to proceed to the next production phase. Greenlight gates are critical for go/no-go decisions.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPublisherFacing rdf:type rdf:Property ;
    rdfs:label 'Is Publisher Facing' ;
    rdfs:comment 'Boolean flag indicating whether this milestone is a contractual publisher-facing delivery gate (True) or an internal studio milestone (False). Publisher-facing milestones trigger formal reporting and may have contractual payment implications.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSignedOff rdf:type rdf:Property ;
    rdfs:label 'Is Signed Off' ;
    rdfs:comment 'Boolean flag indicating whether the milestone has received formal sign-off approval. True when sign-off is complete; False when pending. Enables quick filtering for release gate dashboards.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milestoneDescription rdf:type rdf:Property ;
    rdfs:label 'Milestone Description' ;
    rdfs:comment 'Free-text description of the milestone scope, acceptance criteria, and key deliverables as defined in the production plan. Provides context for publisher reporting and greenlight decision-making.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneName rdf:type rdf:Property ;
    rdfs:label 'Milestone Name' ;
    rdfs:comment 'Human-readable name of the production milestone as defined in the studio production plan or Jira release (e.g., \'Alpha Build\', \'Gold Master\', \'First Playable\'). Serves as the primary identity label for the milestone.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Milestone Status' ;
    rdfs:comment 'Current lifecycle state of the milestone within the production workflow. Tracks progression from not started through in-progress, at-risk, missed, completed, and final sign-off. Used for release planning dashboards and publisher reporting.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneType rdf:type rdf:Property ;
    rdfs:label 'Milestone Type' ;
    rdfs:comment 'Categorical classification of the milestone representing its role in the game development lifecycle delivery gate. Standard types include concept approval, pre-production sign-off, vertical slice, first playable, alpha, beta, content complete, gold master (GM), and first-party submission. [ENUM-REF-CANDIDATE: concept_approval|pre_production|vertical_slice|first_playable|alpha|beta|content_complete|gold_master|first_party_submission — promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openIssueCount rdf:type rdf:Property ;
    rdfs:label 'Open Issue Count' ;
    rdfs:comment 'Total number of open Jira issues (across all severities) associated with this milestone at the time of last update. Provides a broad health indicator for milestone readiness.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phase rdf:type rdf:Property ;
    rdfs:label 'Phase' ;
    rdfs:comment 'The high-level production phase to which this milestone belongs. Segments milestones into pre-production, production, post-production, and live operations (GaaS) phases for portfolio-level reporting.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDate rdf:type rdf:Property ;
    rdfs:label 'Planned Date' ;
    rdfs:comment 'The originally scheduled calendar date by which this milestone was planned to be achieved, as defined in the production schedule. Used for schedule variance analysis and publisher reporting.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qaSignOffStatus rdf:type rdf:Property ;
    rdfs:label 'Qa Sign Off Status' ;
    rdfs:comment 'The Quality Assurance (QA) team\'s sign-off status for this milestone, indicating whether the build has passed QA acceptance criteria. Distinct from the overall milestone sign-off which may involve additional stakeholders.' ;
    rdfs:domain ind:Studio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedDate rdf:type rdf:Property ;
    rdfs:label 'Revised Date' ;
    rdfs:comment 'The most recently revised target date for milestone completion, reflecting any approved schedule changes or re-planning events. Distinct from the original planned date to support schedule slip tracking.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskNotes rdf:type rdf:Property ;
    rdfs:label 'Risk Notes' ;
    rdfs:comment 'Free-text field capturing the primary risk factors or blockers threatening on-time milestone delivery. Populated by the production manager or project lead during milestone reviews.' ;
    rdfs:domain ind:Studio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleVarianceDays rdf:type rdf:Property ;
    rdfs:label 'Schedule Variance Days' ;
    rdfs:comment 'The number of calendar days by which the actual completion date deviated from the planned date. Positive values indicate lateness; negative values indicate early delivery. Sourced from production management tooling and used for publisher reporting and greenlight decisions.' ;
    rdfs:domain ind:Studio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uatStatus rdf:type rdf:Property ;
    rdfs:label 'Uat Status' ;
    rdfs:comment 'The User Acceptance Testing (UAT) status for this milestone, reflecting whether the build has been validated by the publisher or internal stakeholders against acceptance criteria. UAT sign-off is typically required before milestone payment release.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnershipId rdf:type rdf:Property ;
    rdfs:label 'Partnership Id' ;
    rdfs:comment 'Primary key for partnership' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partnershipGameStudioId rdf:type rdf:Property ;
    rdfs:label 'Partnership Game Studio Id' ;
    rdfs:comment 'Reference to the internal publishing studio entity (Gaming) that is the publishing party in this partnership agreement.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GameStudio .

ind:partnershipPartnerStudioGameStudioId rdf:type rdf:Property ;
    rdfs:label 'Partnership Partner Studio Game Studio Id' ;
    rdfs:comment 'Reference to the external or co-development studio entity that is the counterpart in this partnership agreement.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GameStudio .

ind:publisherLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Publisher Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to finance.legal_entity. Business justification: Publisher partnerships are contracts between legal entities. Required for intercompany accounting, contract liability tracking, consolidation elimination, and royalty payment processing.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:advanceRecoupableUsd rdf:type rdf:Property ;
    rdfs:label 'Advance Recoupable Usd' ;
    rdfs:comment 'The upfront advance payment made to the partner studio that is recoupable against future royalty earnings. Common in publisher-developer agreements. Tracked in SAP S/4HANA for recoupment accounting.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Contract Document Url' ;
    rdfs:comment 'Secure URL or document management system reference pointing to the executed partnership agreement document stored in Agiloft/Ironclad or the enterprise document repository. Provides traceability to the source legal instrument.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esrbComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Esrb Compliance Required' ;
    rdfs:comment 'Indicates whether the partner studio is contractually obligated to comply with Entertainment Software Rating Board (ESRB) content rating requirements for North American distribution of the associated title.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusivityType rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Type' ;
    rdfs:comment 'Defines whether the partner studio is bound by exclusivity obligations under this partnership. Exclusive: studio works only with Gaming during the term; Non-Exclusive: studio may work with other publishers; Platform Exclusive: exclusivity limited to specific platforms; Genre Exclusive: exclusivity within a specific game genre; None: no exclusivity clause.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaasSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Gaas Support Flag' ;
    rdfs:comment 'Indicates whether the partnership scope includes ongoing live operations and Game as a Service (GaaS) support activities (e.g., seasonal content, live events, balance patches) beyond the initial ship date.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gamingRevenueSharePct rdf:type rdf:Property ;
    rdfs:label 'Gaming Revenue Share Pct' ;
    rdfs:comment 'The percentage of net revenue retained by Gaming (the publisher) under the agreed revenue share model. Expressed as a decimal percentage (e.g., 70.00 = 70%). Applicable when revenue_share_model is royalty_percentage, profit_share, or hybrid.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gdprDataProcessingAgreement rdf:type rdf:Property ;
    rdfs:label 'Gdpr Data Processing Agreement' ;
    rdfs:comment 'Indicates whether a General Data Protection Regulation (GDPR)-compliant Data Processing Agreement (DPA) has been executed with the partner studio, required when the partner processes EU player personal data.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governingLawCountry rdf:type rdf:Property ;
    rdfs:label 'Governing Law Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction whose laws govern the partnership agreement (e.g., USA, GBR, DEU). Determines applicable regulatory and legal frameworks for dispute resolution.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipOwnershipArrangement rdf:type rdf:Property ;
    rdfs:label 'Ip Ownership Arrangement' ;
    rdfs:comment 'Defines which party holds Intellectual Property (IP) rights for assets created under this partnership. Critical for downstream licensing, sequel rights, and asset reuse decisions. Distinct from the licensing domain — this captures only the studio-to-studio IP ownership metadata.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneCount rdf:type rdf:Property ;
    rdfs:label 'Milestone Count' ;
    rdfs:comment 'Total number of contractually defined delivery milestones specified in the partnership agreement. Used for milestone-based payment tracking and project governance alignment with Jira.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milestonesCompleted rdf:type rdf:Property ;
    rdfs:label 'Milestones Completed' ;
    rdfs:comment 'Number of contractual milestones that have been formally accepted and signed off by Gaming as of the last update. Enables tracking of partnership delivery progress and payment eligibility.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mtxRevenueRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Mtx Revenue Rights Flag' ;
    rdfs:comment 'Indicates whether the partner studio has contractual rights to a share of Microtransaction (MTX) and In-App Purchase (IAP) revenues generated by the title. Relevant for GaaS titles with ongoing monetization.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ndaExecutedFlag rdf:type rdf:Property ;
    rdfs:label 'Nda Executed Flag' ;
    rdfs:comment 'Indicates whether a Non-Disclosure Agreement (NDA) has been fully executed between Gaming and the partner studio prior to or concurrent with the partnership agreement.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnerPrimaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Partner Primary Contact Email' ;
    rdfs:comment 'Business email address of the primary contact at the partner studio. Used for formal communications and contract notifications. Sourced from Salesforce CRM.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerPrimaryContactName rdf:type rdf:Property ;
    rdfs:label 'Partner Primary Contact Name' ;
    rdfs:comment 'Full name of the primary business contact at the partner studio for this partnership. Used for communication and escalation. Sourced from Salesforce CRM contact records.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerRevenueSharePct rdf:type rdf:Property ;
    rdfs:label 'Partner Revenue Share Pct' ;
    rdfs:comment 'The percentage of net revenue allocated to the partner studio under the agreed revenue share model. Should sum to 100% with gaming_revenue_share_pct for royalty/profit-share models.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerStudioCountry rdf:type rdf:Property ;
    rdfs:label 'Partner Studio Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the partner studio\'s primary place of business. Used for regulatory compliance scoping (GDPR, COPPA), tax withholding determination, and geographic reporting.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pegiComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Pegi Compliance Required' ;
    rdfs:comment 'Indicates whether the partner studio is contractually obligated to comply with Pan European Game Information (PEGI) content rating requirements for European distribution.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalContractValueUsd rdf:type rdf:Property ;
    rdfs:label 'Total Contract Value Usd' ;
    rdfs:comment 'The total committed financial value of the partnership agreement in US Dollars (USD), as stated in the executed contract. Includes all milestone payments, advances, and guaranteed minimums. Sourced from Agiloft/Ironclad and reconciled in SAP S/4HANA.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ugcRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Ugc Rights Flag' ;
    rdfs:comment 'Indicates whether the partnership agreement grants or restricts User-Generated Content (UGC) creation rights for the partner studio or end players on the associated title.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:projectBudgetAllocationId rdf:type rdf:Property ;
    rdfs:label 'Project Budget Allocation Id' ;
    rdfs:comment 'Unique surrogate identifier for each budget allocation record assigned to a development project. Primary key for this entity. Entity role: TRANSACTION_HEADER — represents a discrete approved funding event with its own lifecycle (draft → approved → active → closed/revised).' ;
    rdfs:domain ind:ProjectBudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorAllocationProjectBudgetAllocationId rdf:type rdf:Property ;
    rdfs:label 'Prior Allocation Project Budget Allocation Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the previous version of this budget allocation when allocation_type is reallocation, supplemental, or carryover. Enables full revision chain traceability and budget change history reconstruction.' ;
    rdfs:domain ind:ProjectBudgetAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProjectBudgetAllocation .

ind:actualAmountSpent rdf:type rdf:Property ;
    rdfs:label 'Actual Amount Spent' ;
    rdfs:comment 'The actual expenditure recorded against this budget allocation to date, sourced from the finance domain general ledger reconciliation. Used to compute variance and burn rate. Distinct from allocated_amount (planned) — supports TARGET vs ACTUAL analysis for producer decision-making.' ;
    rdfs:domain ind:ProjectBudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Allocation Reference Code' ;
    rdfs:comment 'Externally-known human-readable identifier for this budget allocation record, used in finance reconciliation, producer communications, and GL cross-referencing. Format: BA-{PROJECT_CODE}-{FISCAL_YEAR}-{SEQUENCE}. Sourced from the studio production budgeting tool (e.g., Forecast/Productive).' ;
    rdfs:domain ind:ProjectBudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationType rdf:type rdf:Property ;
    rdfs:label 'Allocation Type' ;
    rdfs:comment 'Classifies the nature of this budget allocation event: initial (first approved budget for the phase/category), supplemental (additional funding approved mid-cycle), reallocation (transfer from another category), contingency (reserve funding), carryover (unspent funds rolled from prior period). Supports budget history and change management tracking.' ;
    rdfs:domain ind:ProjectBudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetConsumedUsd rdf:type rdf:Property ;
    rdfs:label 'Budget Consumed Usd' ;
    rdfs:comment 'Total budget expenditure recorded against this project to date in US Dollars (USD), sourced from SAP S/4HANA actual cost postings. Used for budget burn rate analysis and financial reporting. [Moved from dev_project: This attribute tracks total budget expenditure for the project, which should be calculated by summing actual consumption across all budget allocations. It is a derived metric that aggregates allocation-level actuals. Storing it on dev_project creates redundancy and potential inconsistency with allocation-level variance tracking.]' ;
    rdfs:domain ind:ProjectBudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financeSignOffDate rdf:type rdf:Property ;
    rdfs:label 'Finance Sign Off Date' ;
    rdfs:comment 'The date on which the Finance domain provided its formal sign-off for this budget allocation, applicable when requires_finance_sign_off is True. Completes the dual-approval governance requirement for high-value or cross-domain allocations.' ;
    rdfs:domain ind:ProjectBudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:headcountFunded rdf:type rdf:Property ;
    rdfs:label 'Headcount Funded' ;
    rdfs:comment 'The number of full-time equivalent (FTE) or contractor headcount positions funded by this budget allocation when budget_category is personnel. Enables workforce planning alignment with budget and supports resource allocation decisions by producers.' ;
    rdfs:domain ind:ProjectBudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isContingencyReserve rdf:type rdf:Property ;
    rdfs:label 'Is Contingency Reserve' ;
    rdfs:comment 'Indicates whether this budget allocation represents a contingency reserve (risk buffer) rather than planned operational spend. True = contingency reserve held for unforeseen project risks; False = planned operational allocation. Supports risk-adjusted budget reporting.' ;
    rdfs:domain ind:ProjectBudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outsourceVendorName rdf:type rdf:Property ;
    rdfs:label 'Outsource Vendor Name' ;
    rdfs:comment 'Name of the external vendor, third-party studio, or outsourcing partner associated with this allocation when budget_category is outsourcing. Provides producer visibility into which external partner the funds are designated for. Nullable for non-outsourcing categories.' ;
    rdfs:domain ind:ProjectBudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingAmount rdf:type rdf:Property ;
    rdfs:label 'Remaining Amount' ;
    rdfs:comment 'The uncommitted balance remaining in this allocation (allocated_amount minus actual_amount_spent). Provides the studio-facing operational view of available spend for the period and category. Supports real-time producer budget management and re-forecasting decisions.' ;
    rdfs:domain ind:ProjectBudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiresFinanceSignOff rdf:type rdf:Property ;
    rdfs:label 'Requires Finance Sign Off' ;
    rdfs:comment 'Indicates whether this budget allocation requires additional sign-off from the Finance domain (beyond the studio approver) due to amount thresholds, allocation type, or governance policy. Drives workflow routing in the approval process.' ;
    rdfs:domain ind:ProjectBudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemRef rdf:type rdf:Property ;
    rdfs:label 'Source System Ref' ;
    rdfs:comment 'The native record identifier from the originating studio production budgeting tool (e.g., Forecast.app budget line ID, Productive.io budget entry ID). Enables traceability and reconciliation back to the source system of record for audit and data lineage purposes.' ;
    rdfs:domain ind:ProjectBudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Total Budget Usd' ;
    rdfs:comment 'Total approved development budget for this project in US Dollars (USD), as recorded in SAP S/4HANA Project System. Includes all labor, licensing, tooling, and infrastructure costs allocated to the project. [Moved from dev_project: This attribute represents the total approved budget for the project, which is actually the SUM of all allocation_amount values across all budget allocations for this project. It is a derived/aggregated value that should be calculated from the association table, not stored redundantly on dev_project. Keeping it on dev_project creates a synchronization risk where total_budget_usd could become inconsistent with the sum of allocations.]' ;
    rdfs:domain ind:ProjectBudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variancePct rdf:type rdf:Property ;
    rdfs:label 'Variance Pct' ;
    rdfs:comment 'The percentage difference between the allocated budget amount and the actual amount spent, expressed as a signed decimal (positive = over budget, negative = under budget). Sourced from the studio production budgeting tool reconciliation. Key KPI for producer budget health monitoring and finance reporting.' ;
    rdfs:domain ind:ProjectBudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wbsElementCode rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Code' ;
    rdfs:comment 'The Work Breakdown Structure element code from SAP S/4HANA Project System (PS) that this allocation is associated with. Provides granular project cost tracking at the deliverable or milestone level, enabling detailed budget-to-actual analysis by work package.' ;
    rdfs:domain ind:ProjectBudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessControlTier rdf:type rdf:Property ;
    rdfs:label 'Access Control Tier' ;
    rdfs:comment 'Data classification and access control level applied to this depot. \'public\' allows broad read access; \'internal\' restricts to all studio employees; \'restricted\' limits to project team members only; \'confidential\' applies to IP-sensitive or pre-announcement titles requiring NDA-level access.' ;
    rdfs:domain ind:Repo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeWorkspaceCount rdf:type rdf:Property ;
    rdfs:label 'Active Workspace Count' ;
    rdfs:comment 'Number of currently active Perforce client workspaces (p4 clients) mapped to this depot. Indicates the size of the active development team and server load contribution.' ;
    rdfs:domain ind:Repo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backupPolicy rdf:type rdf:Property ;
    rdfs:label 'Backup Policy' ;
    rdfs:comment 'The backup frequency policy applied to this depot\'s data. Determines recovery point objective (RPO) for disaster recovery. \'continuous\' applies to commit servers with journal replication; \'daily\' and \'hourly\' apply to checkpoint-based backups.' ;
    rdfs:domain ind:Repo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchCount rdf:type rdf:Property ;
    rdfs:label 'Branch Count' ;
    rdfs:comment 'Total number of active streams or branches currently configured in this depot. High branch counts may indicate complex release management or technical debt requiring stream consolidation.' ;
    rdfs:domain ind:Repo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:buildSystem rdf:type rdf:Property ;
    rdfs:label 'Build System' ;
    rdfs:comment 'The CI/CD build automation system integrated with this depot for automated compilation, packaging, and deployment of game builds. Determines the toolchain for build pipeline management. [ENUM-REF-CANDIDATE: Jenkins|TeamCity|Buildkite|GitHub Actions|Azure DevOps|Custom|None — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Repo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changelistCount rdf:type rdf:Property ;
    rdfs:label 'Changelist Count' ;
    rdfs:comment 'Total number of submitted changelists in this depot. A changelist in Perforce is the atomic unit of work (equivalent to a commit), and this count reflects overall development activity volume.' ;
    rdfs:domain ind:Repo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ciCdPipelineEnabled rdf:type rdf:Property ;
    rdfs:label 'Ci Cd Pipeline Enabled' ;
    rdfs:comment 'Indicates whether a Continuous Integration/Continuous Deployment (CI/CD) pipeline is actively configured and running against this depot\'s mainline stream. Enables automated build, test, and release gate enforcement.' ;
    rdfs:domain ind:Repo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:depotDescription rdf:type rdf:Property ;
    rdfs:label 'Depot Description' ;
    rdfs:comment 'Free-text business description of the depot\'s purpose, scope, and contents (e.g., \'Main source depot for Project Titan — PC and console builds including all engine customizations\').' ;
    rdfs:domain ind:Repo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depotName rdf:type rdf:Property ;
    rdfs:label 'Depot Name' ;
    rdfs:comment 'The canonical Perforce depot name as it appears in the server, prefixed with \'//\' per Helix Core naming conventions (e.g., //GameTitle_Main). Acts as the human-readable business identifier for the repository.' ;
    rdfs:domain ind:Repo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depotType rdf:type rdf:Property ;
    rdfs:label 'Depot Type' ;
    rdfs:comment 'Perforce depot storage type that determines how files are stored and accessed. \'local\' stores files on the server filesystem; \'stream\' enables stream-based branching topology; \'remote\' proxies to another Perforce server; \'spec\' stores form specifications; \'archive\' holds archived revisions; \'unload\' holds unloaded workspaces/labels; \'graph\' stores Git-compatible repos. [ENUM-REF-CANDIDATE: local|stream|remote|spec|archive|unload|graph — promote to reference product]' ;
    rdfs:domain ind:Repo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusiveCheckoutEnabled rdf:type rdf:Property ;
    rdfs:label 'Exclusive Checkout Enabled' ;
    rdfs:comment 'Indicates whether exclusive file locking (exclusive checkout) is enforced for binary assets in this depot, preventing simultaneous edits to non-mergeable files such as art assets, audio files, and level files.' ;
    rdfs:domain ind:Repo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprApplicable rdf:type rdf:Property ;
    rdfs:label 'Gdpr Applicable' ;
    rdfs:comment 'Indicates whether this depot may contain personal data subject to GDPR obligations (e.g., developer PII in commit metadata, playtester feedback files). Triggers data protection impact assessment (DPIA) requirements.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goldMasterBranch rdf:type rdf:Property ;
    rdfs:label 'Gold Master Branch' ;
    rdfs:comment 'The stream or branch path designated as the Gold Master (GM) release candidate branch for this depot (e.g., \'//GameTitle_Main/release/gm\'). The Gold Master is the final approved build submitted for first-party certification.' ;
    rdfs:domain ind:Repo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipClassification rdf:type rdf:Property ;
    rdfs:label 'Ip Classification' ;
    rdfs:comment 'Classification of the intellectual property (IP) contained in this depot. \'core_ip\' covers proprietary game engine and title source; \'licensed_ip\' covers content under third-party IP licenses; \'third_party\' covers externally sourced middleware; \'tools\' and \'pipeline\' cover internal tooling. Drives access control and legal review requirements. [ENUM-REF-CANDIDATE: core_ip|licensed_ip|third_party|middleware|tools|pipeline|none — promote to reference product]' ;
    rdfs:domain ind:Repo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastSubmitTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Submit Timestamp' ;
    rdfs:comment 'Timestamp of the most recent changelist submission to this depot. Indicates recency of active development; depots with no recent submissions may be candidates for archival.' ;
    rdfs:domain ind:Repo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lfsEnabled rdf:type rdf:Property ;
    rdfs:label 'Lfs Enabled' ;
    rdfs:comment 'Indicates whether Perforce Large File System (LFS) or equivalent binary asset management is enabled for this depot. Critical for game development depots containing large binary assets (textures, audio, video, compiled shaders).' ;
    rdfs:domain ind:Repo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mainlineStreamPath rdf:type rdf:Property ;
    rdfs:label 'Mainline Stream Path' ;
    rdfs:comment 'The depot-relative path of the mainline (trunk) stream, which is the authoritative integration target for all development work (e.g., //GameTitle_Main/mainline). Null for non-stream depots.' ;
    rdfs:domain ind:Repo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obliterateProtection rdf:type rdf:Property ;
    rdfs:label 'Obliterate Protection' ;
    rdfs:comment 'Indicates whether the depot is protected against the p4 obliterate command, which permanently deletes file history. Enabled for depots containing IP-critical or compliance-relevant source history.' ;
    rdfs:domain ind:Repo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:replicationRole rdf:type rdf:Property ;
    rdfs:label 'Replication Role' ;
    rdfs:comment 'The role of the server hosting this depot within the Perforce replication topology. \'commit\' is the authoritative write server; \'edge\' is a distributed edge server for remote studios; \'replica\' is a read-only mirror; \'standby\' is a failover replica; \'none\' applies to standalone servers.' ;
    rdfs:domain ind:Repo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repoStatus rdf:type rdf:Property ;
    rdfs:label 'Repo Status' ;
    rdfs:comment 'Current lifecycle state of the Perforce depot. \'active\' indicates ongoing development use; \'archived\' means the project is complete and the depot is read-only; \'deprecated\' marks depots scheduled for deletion; \'suspended\' indicates temporarily locked depots; \'initializing\' covers newly provisioned depots being configured.' ;
    rdfs:domain ind:Repo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPolicyYears rdf:type rdf:Property ;
    rdfs:label 'Retention Policy Years' ;
    rdfs:comment 'Number of years that file history and changelists in this depot must be retained per the studio\'s data governance and IP protection policy. Informs archival scheduling and storage cost forecasting.' ;
    rdfs:domain ind:Repo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rootPath rdf:type rdf:Property ;
    rdfs:label 'Root Path' ;
    rdfs:comment 'Server-side filesystem root path where the depot\'s files are physically stored on the Perforce server (e.g., /perforce/depots/GameTitle_Main). Critical for storage management and disaster recovery planning.' ;
    rdfs:domain ind:Repo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serverAddress rdf:type rdf:Property ;
    rdfs:label 'Server Address' ;
    rdfs:comment 'Network address (host:port) of the Perforce server hosting this depot (e.g., \'ssl:p4.studio.gaming.com:1666\'). Required for client workspace configuration and CI/CD pipeline connectivity.' ;
    rdfs:domain ind:Repo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serverReference rdf:type rdf:Property ;
    rdfs:label 'Server Reference' ;
    rdfs:comment 'Identifier of the Perforce Helix Core server instance hosting this depot (e.g., \'p4-studio-us-east-01\'). Supports multi-server topologies including edge servers, replicas, and commit servers.' ;
    rdfs:domain ind:Repo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemDepotReference rdf:type rdf:Property ;
    rdfs:label 'Source System Depot Reference' ;
    rdfs:comment 'The native depot identifier as assigned by the Perforce Helix Core server (typically the depot name without \'//\' prefix or the internal depot counter value). Enables reconciliation between the lakehouse Silver Layer record and the operational Perforce system of record.' ;
    rdfs:domain ind:Repo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageQuotaGb rdf:type rdf:Property ;
    rdfs:label 'Storage Quota Gb' ;
    rdfs:comment 'Maximum allocated storage capacity for this depot in gigabytes, as provisioned by the infrastructure team. Used for capacity planning and chargeback to the owning studio or project.' ;
    rdfs:domain ind:Repo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageUsedGb rdf:type rdf:Property ;
    rdfs:label 'Storage Used Gb' ;
    rdfs:comment 'Current actual storage consumed by this depot in gigabytes, as reported by the Perforce server at the last sync. Enables quota utilization monitoring and proactive capacity management.' ;
    rdfs:domain ind:Repo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:streamStructure rdf:type rdf:Property ;
    rdfs:label 'Stream Structure' ;
    rdfs:comment 'Describes the branching/stream topology configured for this depot. \'mainline_only\' has a single trunk; \'mainline_release\' adds release branches; \'mainline_dev_release\' includes dev, mainline, and release streams; \'full_hierarchy\' includes feature, dev, mainline, release, and hotfix streams; \'none\' applies to non-stream depots.' ;
    rdfs:domain ind:Repo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typemapApplied rdf:type rdf:Property ;
    rdfs:label 'Typemap Applied' ;
    rdfs:comment 'Indicates whether a Perforce typemap (file type mapping configuration) has been applied to this depot to correctly handle binary vs. text files, exclusive checkout locks, and compression settings for game assets.' ;
    rdfs:domain ind:Repo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resourceAllocationId rdf:type rdf:Property ;
    rdfs:label 'Resource Allocation Id' ;
    rdfs:comment 'Unique surrogate identifier for each resource allocation record in the studio domain. Primary key for the resource_allocation data product. Entity role: TRANSACTION_HEADER — represents a discrete business event (a team member assigned to a project for a defined period) with its own lifecycle.' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryResourceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Resource Employee Id' ;
    rdfs:comment 'Reference to the workforce domain employee record for the team member being allocated. Identity and personal data are owned by the workforce domain; this field is the cross-domain join key. Aligns with SAP S/4HANA HR module personnel number.' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryResourceReplacementEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Resource Replacement Employee Id' ;
    rdfs:comment 'Reference to the workforce domain employee record of the team member who replaced this allocation when it was released or cancelled. Supports continuity planning and backfill tracking.' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allocatedRole rdf:type rdf:Property ;
    rdfs:label 'Allocated Role' ;
    rdfs:comment 'The functional role the team member is performing on this project during the allocation period (e.g., Lead Engineer, Senior Artist, Technical Designer, Producer, QA Analyst, Gameplay Programmer). Distinct from the employee\'s HR job title — captures the project-specific role. [ENUM-REF-CANDIDATE: engineer|artist|designer|producer|qa_analyst|programmer|animator|technical_artist|audio_engineer|narrative_designer|devops_engineer|project_manager — promote to reference product]' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationCode rdf:type rdf:Property ;
    rdfs:label 'Allocation Code' ;
    rdfs:comment 'Externally-known business identifier for this allocation record, used in resource management tools (Shotgrid, Float, Productive) and studio production spreadsheets. Enables traceability back to the source system record.' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationPct rdf:type rdf:Property ;
    rdfs:label 'Allocation Pct' ;
    rdfs:comment 'The fraction of the team member\'s full-time equivalent (FTE) capacity committed to this project during the allocation period, expressed as a percentage (0.00–100.00). A value of 50.00 means the person is half-time on this project. Enables FTE burn-down forecasting and over-allocation detection.' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationSource rdf:type rdf:Property ;
    rdfs:label 'Allocation Source' ;
    rdfs:comment 'The operational system of record from which this allocation was sourced (e.g., Shotgrid, Float, Productive, or a studio production spreadsheet). Supports data lineage tracking and ETL reconciliation in the Silver layer. [ENUM-REF-CANDIDATE: shotgrid|float|productive|spreadsheet|jira|manual|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cicdPipelineAccess rdf:type rdf:Property ;
    rdfs:label 'Cicd Pipeline Access' ;
    rdfs:comment 'Indicates whether the allocated team member has been granted access to the project\'s CI/CD pipeline (True) or not (False). Relevant for DevOps and engineering allocations; supports access governance and release gate compliance.' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dailyRateUsd rdf:type rdf:Property ;
    rdfs:label 'Daily Rate Usd' ;
    rdfs:comment 'The daily cost rate in US Dollars for this allocation, representing the blended or contracted daily cost of the team member\'s time. Used for project budget burn-down forecasting and cost-to-complete calculations. Stored as confidential business data.' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fteHoursPerDay rdf:type rdf:Property ;
    rdfs:label 'Fte Hours Per Day' ;
    rdfs:comment 'The number of working hours per day this allocation represents, derived from the studio\'s standard working day and the allocation percentage. Stored explicitly to support scheduling tools that operate in hours rather than percentages.' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBillable rdf:type rdf:Property ;
    rdfs:label 'Is Billable' ;
    rdfs:comment 'Indicates whether this allocation is billable to an external client or publisher (True) or is an internal cost centre allocation (False). Relevant for third-party studio engagements and co-development arrangements where costs are recharged.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isContractor rdf:type rdf:Property ;
    rdfs:label 'Is Contractor' ;
    rdfs:comment 'Indicates whether the allocated team member is an external contractor or freelancer (True) rather than a full-time employee (False). Affects cost modelling, compliance obligations, and workforce reporting.' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRemote rdf:type rdf:Property ;
    rdfs:label 'Is Remote' ;
    rdfs:comment 'Indicates whether the team member is working remotely (True) or on-site at a studio location (False) for this allocation. Relevant for studio capacity planning, collaboration tooling, and compliance with remote work policies.' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overtimeApproved rdf:type rdf:Property ;
    rdfs:label 'Overtime Approved' ;
    rdfs:comment 'Indicates whether overtime hours have been formally approved for this allocation (True) or not (False). Relevant for crunch period management, labour compliance, and cost forecasting during intensive production phases such as gold master preparation.' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:perforceDepotAccess rdf:type rdf:Property ;
    rdfs:label 'Perforce Depot Access' ;
    rdfs:comment 'Indicates whether the allocated team member has been granted access to the project\'s Perforce Helix Core depot (True) or not (False). Supports version control access governance and onboarding/offboarding workflows.' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryTool rdf:type rdf:Property ;
    rdfs:label 'Primary Tool' ;
    rdfs:comment 'The primary game development tool or engine the team member is using in this allocation. Supports tooling-based capacity planning and ensures the right skill set is matched to the project\'s technology stack. [ENUM-REF-CANDIDATE: unity|unreal_engine|perforce|maya|blender|photoshop|houdini|fmod|wwise|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDate rdf:type rdf:Property ;
    rdfs:label 'Requested Date' ;
    rdfs:comment 'The date on which the resource allocation was originally requested by the project team or producer. Enables measurement of resource request lead times and planning efficiency.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:roleDiscipline rdf:type rdf:Property ;
    rdfs:label 'Role Discipline' ;
    rdfs:comment 'High-level discipline grouping for the allocated role, used for capacity planning dashboards and cross-studio resource balancing. Enables aggregation across specific role titles within a discipline (e.g., all \'engineering\' roles regardless of seniority). [ENUM-REF-CANDIDATE: engineering|art|design|production|qa|audio|narrative|devops|marketing|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seniorityLevel rdf:type rdf:Property ;
    rdfs:label 'Seniority Level' ;
    rdfs:comment 'Seniority tier of the team member in the context of this allocation. Used for capacity planning, cost modelling, and ensuring appropriate skill levels are assigned to project phases.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillTags rdf:type rdf:Property ;
    rdfs:label 'Skill Tags' ;
    rdfs:comment 'Comma-separated list of skill or technology tags associated with this allocation (e.g., \'Unreal Engine 5, C++, Gameplay Systems, Multiplayer Networking\'). Sourced from the resource management tool\'s skill taxonomy. Enables skill-based resource search and gap analysis. Stored as a delimited string per Silver layer conventions (no ARRAY type).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAllocatedDays rdf:type rdf:Property ;
    rdfs:label 'Total Allocated Days' ;
    rdfs:comment 'The total number of working days this team member is allocated to the project across the full allocation period, accounting for the allocation percentage. Calculated at source system ingestion and stored for reporting efficiency. Supports capacity burn-down forecasting.' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workLocationCountry rdf:type rdf:Property ;
    rdfs:label 'Work Location Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the country where the team member is physically working during this allocation. Used for cross-border compliance, GDPR data residency considerations, and international studio cost reporting.' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrumMasterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Scrum Master Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Sprint ceremonies and retrospectives require tracking the assigned Scrum Master employee for accountability, capacity planning, and agile methodology compliance. The scrum_master text field denormaliz' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:addedStoryPoints rdf:type rdf:Property ;
    rdfs:label 'Added Story Points' ;
    rdfs:comment 'Story points added to the sprint scope after sprint planning commenced (scope creep). Tracks mid-sprint additions that affect velocity accuracy and predictability.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockersCount rdf:type rdf:Property ;
    rdfs:label 'Blockers Count' ;
    rdfs:comment 'Number of active impediments or blockers logged against this sprint in Jira. High blocker counts are a leading indicator of sprint failure and are tracked for escalation and retrospective analysis.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:boardReference rdf:type rdf:Property ;
    rdfs:label 'Board Reference' ;
    rdfs:comment 'Identifier of the Jira Scrum board to which this sprint belongs. A board typically maps to a single game development project or studio team.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bugIssues rdf:type rdf:Property ;
    rdfs:label 'Bug Issues' ;
    rdfs:comment 'Number of Jira issues classified as bugs within the sprint. Tracks QA debt and defect injection rate, which is critical for game quality assurance and release gate readiness.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:committedStoryPoints rdf:type rdf:Property ;
    rdfs:label 'Committed Story Points' ;
    rdfs:comment 'Total story points committed to the sprint at sprint planning. Represents the team\'s planned velocity and capacity for the sprint. Core input for velocity tracking and capacity planning.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completedDate rdf:type rdf:Property ;
    rdfs:label 'Completed Date' ;
    rdfs:comment 'Actual date the sprint was closed or completed in Jira. May differ from end_date when sprints are extended or closed early. Null for active or future sprints.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completedIssues rdf:type rdf:Property ;
    rdfs:label 'Completed Issues' ;
    rdfs:comment 'Number of Jira issues resolved or closed within the sprint. Used alongside completed_story_points to assess sprint throughput and team delivery rate.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completedStoryPoints rdf:type rdf:Property ;
    rdfs:label 'Completed Story Points' ;
    rdfs:comment 'Total story points for issues marked as \'Done\' by the end of the sprint. Represents actual velocity delivered. Used for sprint-over-sprint velocity trending and team performance analysis.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:goal rdf:type rdf:Property ;
    rdfs:label 'Goal' ;
    rdfs:comment 'Textual description of the primary objective or deliverable targeted for this sprint, as defined by the Scrum team in Jira. Supports retrospective analysis and milestone alignment.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:health rdf:type rdf:Property ;
    rdfs:label 'Health' ;
    rdfs:comment 'Qualitative health indicator for the sprint as assessed by the Scrum Master or project manager. \'on_track\' indicates delivery is proceeding as planned; \'at_risk\' indicates potential blockers; \'off_track\' indicates significant impediments to goal achievement.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incompleteIssues rdf:type rdf:Property ;
    rdfs:label 'Incomplete Issues' ;
    rdfs:comment 'Number of Jira issues not completed by sprint end. Carried-over issues impact the next sprint\'s planning and are a key indicator of sprint health and scope management.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isGaasSprint rdf:type rdf:Property ;
    rdfs:label 'Is Gaas Sprint' ;
    rdfs:comment 'Indicates whether this sprint is part of a live operations (GaaS) cadence rather than a pre-launch development cycle. Enables segmentation of live-ops velocity from core development velocity in analytics.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jiraSprintKey rdf:type rdf:Property ;
    rdfs:label 'Jira Sprint Key' ;
    rdfs:comment 'Native sprint identifier assigned by Jira. Used to trace the record back to the operational source system (Jira Software) for reconciliation and lineage purposes.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qaSignOff rdf:type rdf:Property ;
    rdfs:label 'Qa Sign Off' ;
    rdfs:comment 'Indicates whether the Quality Assurance team has formally signed off on the sprint deliverables. A prerequisite for release gate passage and first-party platform certification submission.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:removedStoryPoints rdf:type rdf:Property ;
    rdfs:label 'Removed Story Points' ;
    rdfs:comment 'Story points removed from the sprint scope after sprint planning commenced. Tracks descoping decisions that affect velocity accuracy and sprint health.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retrospectiveNotes rdf:type rdf:Property ;
    rdfs:label 'Retrospective Notes' ;
    rdfs:comment 'Free-text summary of key findings, action items, and process improvement decisions captured during the sprint retrospective. Supports continuous improvement tracking and GaaS cadence optimization.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sprintName rdf:type rdf:Property ;
    rdfs:label 'Sprint Name' ;
    rdfs:comment 'Human-readable name of the sprint as defined in Jira (e.g., \'Alpha-Sprint-14\', \'LiveOps-Week-22\'). Used for display in dashboards, velocity reports, and GaaS cadence tracking.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sprintNumber rdf:type rdf:Property ;
    rdfs:label 'Sprint Number' ;
    rdfs:comment 'Sequential ordinal number of the sprint within its project or board. Enables sprint-over-sprint velocity trending and milestone progression analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sprintState rdf:type rdf:Property ;
    rdfs:label 'Sprint State' ;
    rdfs:comment 'Current lifecycle state of the sprint as reported by Jira. \'active\' indicates the sprint is in progress; \'closed\' indicates it has been completed; \'future\' indicates it is planned but not yet started.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sprintType rdf:type rdf:Property ;
    rdfs:label 'Sprint Type' ;
    rdfs:comment 'Classification of the sprint by its primary purpose within the game development lifecycle. \'development\' covers feature work; \'live_ops\' covers GaaS live operations cadence; \'qa\' covers Quality Assurance cycles; \'hardening\' covers stability and bug-fix sprints; \'release\' covers gold master and launch preparation; \'spike\' covers research or proof-of-concept work.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamCapacityPoints rdf:type rdf:Property ;
    rdfs:label 'Team Capacity Points' ;
    rdfs:comment 'Total story point capacity available to the team for this sprint, accounting for planned absences, holidays, and part-time allocations. Used to assess commitment accuracy and identify over- or under-commitment patterns.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:teamSize rdf:type rdf:Property ;
    rdfs:label 'Team Size' ;
    rdfs:comment 'Number of active team members participating in this sprint. Supports per-capita velocity normalization and resource allocation analysis across studios.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalIssues rdf:type rdf:Property ;
    rdfs:label 'Total Issues' ;
    rdfs:comment 'Total number of Jira issues (stories, tasks, bugs, sub-tasks) included in the sprint at any point. Provides a count-based complement to story-point-based velocity metrics.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uatSignOff rdf:type rdf:Property ;
    rdfs:label 'Uat Sign Off' ;
    rdfs:comment 'Indicates whether User Acceptance Testing (UAT) has been completed and signed off for this sprint\'s deliverables. Required for release gate approval and production deployment authorization.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorWorkPackageId rdf:type rdf:Property ;
    rdfs:label 'Vendor Work Package Id' ;
    rdfs:comment 'Unique identifier for the vendor work package record. Primary key.' ;
    rdfs:domain ind:VendorWorkPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'Actual date on which the vendor delivered the work package to the internal studio.' ;
    rdfs:domain ind:VendorWorkPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractedAmount rdf:type rdf:Property ;
    rdfs:label 'Contracted Amount' ;
    rdfs:comment 'Total contracted or agreed-upon cost for this vendor work package in the specified currency.' ;
    rdfs:domain ind:VendorWorkPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costAllocationReference rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Reference' ;
    rdfs:comment 'Reference code or identifier linking this work package to the project budget allocation or purchase order for cost tracking.' ;
    rdfs:domain ind:VendorWorkPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableType rdf:type rdf:Property ;
    rdfs:label 'Deliverable Type' ;
    rdfs:comment 'Category of deliverable being outsourced: art assets, audio, animation, level design, porting, QA (Quality Assurance), programming, VFX (Visual Effects), cinematics, or localization. [ENUM-REF-CANDIDATE: art-assets|audio|animation|level-design|porting|qa|programming|vfx|cinematics|localization — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VendorWorkPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMilestoneDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Milestone Date' ;
    rdfs:comment 'Planned or contractual date by which the vendor is expected to deliver the work package.' ;
    rdfs:domain ind:VendorWorkPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ndaExecuted rdf:type rdf:Property ;
    rdfs:label 'Nda Executed' ;
    rdfs:comment 'Boolean flag indicating whether a Non-Disclosure Agreement has been executed with the vendor for this work package.' ;
    rdfs:domain ind:VendorWorkPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packageCode rdf:type rdf:Property ;
    rdfs:label 'Package Code' ;
    rdfs:comment 'Unique business identifier or reference code for the work package, used for tracking and invoicing.' ;
    rdfs:domain ind:VendorWorkPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageName rdf:type rdf:Property ;
    rdfs:label 'Package Name' ;
    rdfs:comment 'Human-readable name or title of the vendor work package, identifying the deliverable scope.' ;
    rdfs:domain ind:VendorWorkPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageStatus rdf:type rdf:Property ;
    rdfs:label 'Package Status' ;
    rdfs:comment 'Current lifecycle status of the vendor work package: scoped, in-progress, delivered, accepted, rejected, on-hold, or cancelled. [ENUM-REF-CANDIDATE: scoped|in-progress|delivered|accepted|rejected|on-hold|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VendorWorkPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uatSignOffStatus rdf:type rdf:Property ;
    rdfs:label 'Uat Sign Off Status' ;
    rdfs:comment 'User acceptance testing sign-off status indicating whether the deliverable has passed UAT (User Acceptance Testing) review: pending, in-review, approved, rejected, or not-required.' ;
    rdfs:domain ind:VendorWorkPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContactEmail rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Email' ;
    rdfs:comment 'Email address of the primary vendor contact for communication and coordination on this work package.' ;
    rdfs:domain ind:VendorWorkPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContactName rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Name' ;
    rdfs:comment 'Name of the primary contact person at the vendor studio responsible for this work package.' ;
    rdfs:domain ind:VendorWorkPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prerequisiteAchievementId rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Achievement Id' ;
    rdfs:comment 'Reference to another achievement that must be unlocked before this achievement becomes available, creating achievement chains or progression paths.' ;
    rdfs:domain ind:Achievement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Achievement .

ind:achievementCode rdf:type rdf:Property ;
    rdfs:label 'Achievement Code' ;
    rdfs:comment 'Internal unique code or identifier used by developers to reference this achievement in game logic and telemetry systems.' ;
    rdfs:domain ind:Achievement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:achievementName rdf:type rdf:Property ;
    rdfs:label 'Achievement Name' ;
    rdfs:comment 'The display name of the achievement shown to players in-game and on platform storefronts.' ;
    rdfs:domain ind:Achievement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:achievementStatus rdf:type rdf:Property ;
    rdfs:label 'Achievement Status' ;
    rdfs:comment 'Current lifecycle status of the achievement: active (live and unlockable), inactive (temporarily disabled), deprecated (removed from game), planned (in development), testing (QA phase).' ;
    rdfs:domain ind:Achievement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:achievementType rdf:type rdf:Property ;
    rdfs:label 'Achievement Type' ;
    rdfs:comment 'Classification of the achievement based on gameplay context: story milestones, challenge completion, collection tasks, progression markers, hidden secrets, multiplayer feats, time-limited events, or seasonal content. [ENUM-REF-CANDIDATE: story|challenge|collection|progression|secret|multiplayer|time_limited|seasonal — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Achievement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:descriptionLong rdf:type rdf:Property ;
    rdfs:label 'Description Long' ;
    rdfs:comment 'Detailed description of the achievement including unlock criteria, context, and any special conditions or tips for players.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:descriptionShort rdf:type rdf:Property ;
    rdfs:label 'Description Short' ;
    rdfs:comment 'Brief description of the achievement displayed in achievement lists and notifications, typically one sentence.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayOrder rdf:type rdf:Property ;
    rdfs:label 'Display Order' ;
    rdfs:comment 'The sort order for displaying this achievement in achievement lists, allowing developers to control the presentation sequence.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:epicAchievementCode rdf:type rdf:Property ;
    rdfs:label 'Epic Achievement Code' ;
    rdfs:comment 'The platform-specific unique identifier for this achievement in the Epic Games Store achievement system.' ;
    rdfs:domain ind:Achievement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHidden rdf:type rdf:Property ;
    rdfs:label 'Is Hidden' ;
    rdfs:comment 'Indicates whether the achievement details are hidden from players until unlocked, typically used for story spoilers or secret content.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPlatinumTrophy rdf:type rdf:Property ;
    rdfs:label 'Is Platinum Trophy' ;
    rdfs:comment 'Indicates whether this achievement is a platinum trophy (PlayStation-specific) awarded for completing all other trophies in the game.' ;
    rdfs:domain ind:Achievement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSecret rdf:type rdf:Property ;
    rdfs:label 'Is Secret' ;
    rdfs:comment 'Indicates whether the achievement is classified as a secret achievement, requiring players to discover unlock conditions without explicit guidance.' ;
    rdfs:domain ind:Achievement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTimeLimited rdf:type rdf:Property ;
    rdfs:label 'Is Time Limited' ;
    rdfs:comment 'Indicates whether this achievement is only available for a limited time period, such as seasonal events or promotional campaigns.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localizationRequired rdf:type rdf:Property ;
    rdfs:label 'Localization Required' ;
    rdfs:comment 'Indicates whether this achievement requires localization for international markets, including translated names, descriptions, and culturally adapted content.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:playstationTrophyCode rdf:type rdf:Property ;
    rdfs:label 'Playstation Trophy Code' ;
    rdfs:comment 'The platform-specific unique identifier for this achievement in the PlayStation Network trophy system.' ;
    rdfs:domain ind:Achievement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playstationTrophyType rdf:type rdf:Property ;
    rdfs:label 'Playstation Trophy Type' ;
    rdfs:comment 'The trophy tier classification for PlayStation platform: bronze (common), silver (uncommon), gold (rare), or platinum (complete all trophies).' ;
    rdfs:domain ind:Achievement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointValue rdf:type rdf:Property ;
    rdfs:label 'Point Value' ;
    rdfs:comment 'The point or score value awarded to the player upon unlocking this achievement, used for gamerscore or trophy level calculations.' ;
    rdfs:domain ind:Achievement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rarityTier rdf:type rdf:Property ;
    rdfs:label 'Rarity Tier' ;
    rdfs:comment 'The rarity classification of the achievement based on difficulty and expected unlock rate: common (easy), uncommon (moderate), rare (challenging), epic (very difficult), legendary (extremely rare).' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardDescription rdf:type rdf:Property ;
    rdfs:label 'Reward Description' ;
    rdfs:comment 'Description of the in-game reward or benefit the player receives for unlocking this achievement, if applicable.' ;
    rdfs:domain ind:Achievement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:steamAchievementCode rdf:type rdf:Property ;
    rdfs:label 'Steam Achievement Code' ;
    rdfs:comment 'The platform-specific unique identifier for this achievement in the Steam achievement system.' ;
    rdfs:domain ind:Achievement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeLimitEnd rdf:type rdf:Property ;
    rdfs:label 'Time Limit End' ;
    rdfs:comment 'The timestamp when this time-limited achievement is no longer available for unlock, after which it becomes unobtainable.' ;
    rdfs:domain ind:Achievement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:timeLimitStart rdf:type rdf:Property ;
    rdfs:label 'Time Limit Start' ;
    rdfs:comment 'The timestamp when this time-limited achievement becomes available for unlock, used for seasonal or event-based achievements.' ;
    rdfs:domain ind:Achievement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:unlockCriteria rdf:type rdf:Property ;
    rdfs:label 'Unlock Criteria' ;
    rdfs:comment 'Technical specification of the conditions required to unlock this achievement, including gameplay actions, thresholds, and dependencies.' ;
    rdfs:domain ind:Achievement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unlockPercentage rdf:type rdf:Property ;
    rdfs:label 'Unlock Percentage' ;
    rdfs:comment 'The percentage of players who have unlocked this achievement across the entire player base, used to measure actual rarity and difficulty.' ;
    rdfs:domain ind:Achievement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:xboxAchievementCode rdf:type rdf:Property ;
    rdfs:label 'Xbox Achievement Code' ;
    rdfs:comment 'The platform-specific unique identifier for this achievement in the Xbox Live achievement system.' ;
    rdfs:domain ind:Achievement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:xboxGamerscore rdf:type rdf:Property ;
    rdfs:label 'Xbox Gamerscore' ;
    rdfs:comment 'The gamerscore value for this achievement on Xbox platform, contributing to the player\'s overall Xbox gamerscore total.' ;
    rdfs:domain ind:Achievement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:binarySizeMb rdf:type rdf:Property ;
    rdfs:label 'Binary Size Mb' ;
    rdfs:comment 'The total size of the compiled build artifact in megabytes. Critical for platform certification requirements, download optimization, and storage planning.' ;
    rdfs:domain ind:BuildArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buildTimestamp rdf:type rdf:Property ;
    rdfs:label 'Build Timestamp' ;
    rdfs:comment 'The exact date and time when this build artifact was compiled by the CI/CD pipeline. The principal business event timestamp for this entity.' ;
    rdfs:domain ind:BuildArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:certApprovedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cert Approved Timestamp' ;
    rdfs:comment 'The date and time when this build received platform certification approval. Null if not yet approved or if certification was rejected.' ;
    rdfs:domain ind:BuildArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deltaPatchSizeMb rdf:type rdf:Property ;
    rdfs:label 'Delta Patch Size Mb' ;
    rdfs:comment 'The size of the incremental patch from the previous build version in megabytes. Used for optimizing player download experience and CDN (Content Delivery Network) bandwidth planning.' ;
    rdfs:domain ind:BuildArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:includesMtx rdf:type rdf:Property ;
    rdfs:label 'Includes Mtx' ;
    rdfs:comment 'Indicates whether this build includes in-game microtransaction functionality. Affects content rating disclosures and regulatory compliance (COPPA, consumer protection laws).' ;
    rdfs:domain ind:BuildArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includesUgc rdf:type rdf:Property ;
    rdfs:label 'Includes Ugc' ;
    rdfs:comment 'Indicates whether this build supports user-generated content features. Affects content moderation requirements and platform certification criteria.' ;
    rdfs:domain ind:BuildArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMandatoryUpdate rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory Update' ;
    rdfs:comment 'Indicates whether players are required to download and install this build to continue playing. True for critical security patches and breaking changes; false for optional content updates.' ;
    rdfs:domain ind:BuildArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRollbackAvailable rdf:type rdf:Property ;
    rdfs:label 'Is Rollback Available' ;
    rdfs:comment 'Indicates whether this build can be rolled back to a previous version in case of critical issues. False for builds with irreversible database migrations or economy changes.' ;
    rdfs:domain ind:BuildArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxCcuSupported rdf:type rdf:Property ;
    rdfs:label 'Max Ccu Supported' ;
    rdfs:comment 'The maximum number of concurrent users this build is designed and tested to support. Critical for infrastructure capacity planning and live operations scaling.' ;
    rdfs:domain ind:BuildArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:multiplayerMode rdf:type rdf:Property ;
    rdfs:label 'Multiplayer Mode' ;
    rdfs:comment 'The multiplayer capability of this build. Determines server infrastructure requirements, network testing scope, and platform certification paths.' ;
    rdfs:domain ind:BuildArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patchNotes rdf:type rdf:Property ;
    rdfs:label 'Patch Notes' ;
    rdfs:comment 'Player-facing release notes describing new features, bug fixes, balance changes, and known issues in this build. Published to community channels and in-game news feeds.' ;
    rdfs:domain ind:BuildArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineReference rdf:type rdf:Property ;
    rdfs:label 'Pipeline Reference' ;
    rdfs:comment 'The identifier or URL of the CI/CD (Continuous Integration/Continuous Deployment) pipeline job that produced this build. Links to build logs, test results, and automation history.' ;
    rdfs:domain ind:BuildArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:semanticVersion rdf:type rdf:Property ;
    rdfs:label 'Semantic Version' ;
    rdfs:comment 'The semantic version string following the major.minor.patch format (e.g., 2.5.1 or 1.0.0-beta). Used for player-facing version identification and compatibility tracking.' ;
    rdfs:domain ind:BuildArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceChangelist rdf:type rdf:Property ;
    rdfs:label 'Source Changelist' ;
    rdfs:comment 'The specific changelist or commit identifier in the version control system that was used to produce this build. Provides exact source code traceability.' ;
    rdfs:domain ind:BuildArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationUri rdf:type rdf:Property ;
    rdfs:label 'Storage Location Uri' ;
    rdfs:comment 'The cloud storage or CDN URI where this build artifact binary is stored. Used for deployment automation and distribution. Confidential to prevent unauthorized access.' ;
    rdfs:domain ind:BuildArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedForCertTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted For Cert Timestamp' ;
    rdfs:comment 'The date and time when this build was submitted to the platform holder for TRC/TCR certification review. Null if not yet submitted.' ;
    rdfs:domain ind:BuildArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:appealDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Date' ;
    rdfs:comment 'The date when an appeal was filed with the rating authority, if applicable.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Resolution Date' ;
    rdfs:comment 'The date when the rating authority resolved the appeal and issued a final decision.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'The unique certification or registration number issued by the rating authority upon approval. Used for official documentation and compliance verification.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceOfficer rdf:type rdf:Property ;
    rdfs:label 'Compliance Officer' ;
    rdfs:comment 'Name or identifier of the internal compliance officer or legal team member responsible for managing this rating submission and ensuring regulatory adherence.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalCertificateUrl rdf:type rdf:Property ;
    rdfs:label 'Digital Certificate Url' ;
    rdfs:comment 'URL or file path to the digital certificate or official documentation issued by the rating authority as proof of certification.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inGamePurchasesFlag rdf:type rdf:Property ;
    rdfs:label 'In Game Purchases Flag' ;
    rdfs:comment 'Boolean flag indicating whether the game includes in-app purchases (IAP), microtransactions (MTX), or other monetization features that must be disclosed to consumers and rating authorities.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lootBoxDisclosure rdf:type rdf:Property ;
    rdfs:label 'Loot Box Disclosure' ;
    rdfs:comment 'Boolean flag indicating whether the game contains loot boxes, gacha mechanics, or randomized in-game purchases that require consumer disclosure under emerging regulations.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onlineNoticeRequired rdf:type rdf:Property ;
    rdfs:label 'Online Notice Required' ;
    rdfs:comment 'Boolean flag indicating whether the game requires an online privacy notice or additional disclosure due to online features, user-generated content (UGC), or data collection practices. Required for COPPA (Children\'s Online Privacy Protection Act) and GDPR (General Data Protection Regulation) compliance.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publisherContactEmail rdf:type rdf:Property ;
    rdfs:label 'Publisher Contact Email' ;
    rdfs:comment 'The email address of the publisher representative who submitted the rating application and serves as the primary contact for the rating authority.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingArtworkUrl rdf:type rdf:Property ;
    rdfs:label 'Rating Artwork Url' ;
    rdfs:comment 'URL or file path to the official rating logo or artwork provided by the rating authority for use on game packaging, marketing materials, and digital storefronts.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Rating Fee Amount' ;
    rdfs:comment 'The fee charged by the rating authority for processing and certifying the content rating. Fee structures vary by authority, game budget, and platform.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratingFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Rating Fee Currency' ;
    rdfs:comment 'The currency in which the rating fee was charged. Uses ISO 4217 3-letter currency codes.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingStatus rdf:type rdf:Property ;
    rdfs:label 'Rating Status' ;
    rdfs:comment 'Current lifecycle status of the content rating application or certification. Tracks the rating from initial submission through approval or rejection. [ENUM-REF-CANDIDATE: pending|submitted|under_review|approved|rejected|expired|revoked|appealed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingType rdf:type rdf:Property ;
    rdfs:label 'Rating Type' ;
    rdfs:comment 'The type of rating submission. Initial rating for new game releases, re-rating for content changes, update for patches, DLC (Downloadable Content) or expansion for additional content packages.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingValue rdf:type rdf:Property ;
    rdfs:label 'Rating Value' ;
    rdfs:comment 'The age rating or classification assigned by the rating authority. Examples: E (Everyone), T (Teen), M (Mature) for ESRB; PEGI 3, PEGI 7, PEGI 12, PEGI 16, PEGI 18 for PEGI; A (All Ages), B (12+), C (15+), D (17+), Z (18+) for CERO. Format varies by authority.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratingVersion rdf:type rdf:Property ;
    rdfs:label 'Rating Version' ;
    rdfs:comment 'Version identifier for the game build or content package that was rated. Links the rating to a specific game version or SKU (Stock Keeping Unit) to ensure compliance tracking.' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionScope rdf:type rdf:Property ;
    rdfs:label 'Region Scope' ;
    rdfs:comment 'Geographic region or jurisdiction where this content rating is valid and recognized. Examples: USA, CAN (Canada), EUR (Europe), JPN (Japan), KOR (South Korea), AUS (Australia). Uses 3-letter country codes.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developerNotes rdf:type rdf:Property ;
    rdfs:label 'Developer Notes' ;
    rdfs:comment 'Internal notes from the development team regarding design decisions, technical constraints, or known issues. Confidential business information not shared with players.' ;
    rdfs:domain ind:DlcBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dlcType rdf:type rdf:Property ;
    rdfs:label 'Dlc Type' ;
    rdfs:comment 'Classification of the DLC bundle by content type. Determines the nature of the content offering and its business model.' ;
    rdfs:domain ind:DlcBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endOfSaleDate rdf:type rdf:Property ;
    rdfs:label 'End Of Sale Date' ;
    rdfs:comment 'The date when the DLC bundle will no longer be available for purchase. Nullable for evergreen content. Used for limited-time offers and seasonal content.' ;
    rdfs:domain ind:DlcBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entitlementCount rdf:type rdf:Property ;
    rdfs:label 'Entitlement Count' ;
    rdfs:comment 'Number of individual entitlements (items, skins, maps, missions) included in this DLC bundle. Used for value communication and inventory management.' ;
    rdfs:domain ind:DlcBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:entitlementSummary rdf:type rdf:Property ;
    rdfs:label 'Entitlement Summary' ;
    rdfs:comment 'High-level summary of what content the player receives (e.g., \'5 new maps, 10 character skins, 1 story mission\'). Used for marketing and player communication.' ;
    rdfs:domain ind:DlcBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivePlatform rdf:type rdf:Property ;
    rdfs:label 'Exclusive Platform' ;
    rdfs:comment 'The platform name if this DLC is platform-exclusive. Nullable for multi-platform releases. Used for tracking exclusivity agreements and first-party partnerships.' ;
    rdfs:domain ind:DlcBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityEndDate rdf:type rdf:Property ;
    rdfs:label 'Exclusivity End Date' ;
    rdfs:comment 'The date when platform exclusivity expires and the DLC becomes available on other platforms. Nullable for permanent exclusives. Used for release planning.' ;
    rdfs:domain ind:DlcBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:includedInEdition rdf:type rdf:Property ;
    rdfs:label 'Included In Edition' ;
    rdfs:comment 'Comma-separated list of game editions (Deluxe, Ultimate, Gold) that include this DLC bundle at no additional cost. Used for bundling and upsell strategies.' ;
    rdfs:domain ind:DlcBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFree rdf:type rdf:Property ;
    rdfs:label 'Is Free' ;
    rdfs:comment 'Indicates whether the DLC bundle is offered at no cost to players. True for free updates, promotional content, and community goodwill releases.' ;
    rdfs:domain ind:DlcBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPlatformExclusive rdf:type rdf:Property ;
    rdfs:label 'Is Platform Exclusive' ;
    rdfs:comment 'Indicates whether this DLC bundle is exclusive to a specific platform (e.g., PlayStation-exclusive content). Used for partnership agreements and marketing.' ;
    rdfs:domain ind:DlcBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPreOrderBonus rdf:type rdf:Property ;
    rdfs:label 'Is Pre Order Bonus' ;
    rdfs:comment 'Indicates whether this DLC bundle was offered as a pre-order incentive for the base game or another DLC. Used for marketing attribution and exclusivity tracking.' ;
    rdfs:domain ind:DlcBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresBaseGame rdf:type rdf:Property ;
    rdfs:label 'Requires Base Game' ;
    rdfs:comment 'Indicates whether the player must own the base game title to access this DLC. False for standalone expansions that can be played independently.' ;
    rdfs:domain ind:DlcBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storefrontImageUrl rdf:type rdf:Property ;
    rdfs:label 'Storefront Image Url' ;
    rdfs:comment 'URL to the primary storefront thumbnail or hero image for the DLC bundle. Used across digital storefronts and in-game menus.' ;
    rdfs:domain ind:DlcBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trailerUrl rdf:type rdf:Property ;
    rdfs:label 'Trailer Url' ;
    rdfs:comment 'URL to the official promotional trailer or gameplay video for the DLC bundle. Used in storefront listings and marketing materials.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genreClassificationId rdf:type rdf:Property ;
    rdfs:label 'Genre Classification Id' ;
    rdfs:comment 'Foreign key linking to title.genre_classification. Business justification: Franchises have a primary genre identity (e.g., Call of Duty = Shooter, FIFA = Sports). Currently franchise.primary_genre is a STRING. Adding primary_genre_id FK to genre_classification normalizes fra' ;
    rdfs:domain ind:Title ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GenreClassification .

ind:activeTitlesCount rdf:type rdf:Property ;
    rdfs:label 'Active Titles Count' ;
    rdfs:comment 'The number of titles within the franchise that are currently active in market (available for purchase, receiving live operations support, or in active development). Used for portfolio health monitoring.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandGuidelinesUrl rdf:type rdf:Property ;
    rdfs:label 'Brand Guidelines Url' ;
    rdfs:comment 'URL or document reference to the official brand guidelines, style guide, and usage policies for the franchise IP. Used by marketing, licensing, and external partners.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossMediaComicsFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Media Comics Flag' ;
    rdfs:comment 'Indicates whether the franchise has been extended into comics, graphic novels, or manga. True if published comic content exists.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossMediaFilmFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Media Film Flag' ;
    rdfs:comment 'Indicates whether the franchise has been adapted into film or streaming media. True if film/TV adaptations exist or are in production.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossMediaMerchandiseFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Media Merchandise Flag' ;
    rdfs:comment 'Indicates whether the franchise has licensed merchandise programs (toys, apparel, collectibles). True if merchandise licensing agreements are active.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossMediaThemeParkFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Media Theme Park Flag' ;
    rdfs:comment 'Indicates whether the franchise has been adapted into theme park attractions, experiences, or location-based entertainment. True if theme park partnerships exist.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossMediaTvFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Media Tv Flag' ;
    rdfs:comment 'Indicates whether the franchise has been adapted into television series or episodic streaming content. True if TV adaptations exist or are in production.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:esportsEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Esports Enabled Flag' ;
    rdfs:comment 'Indicates whether the franchise supports competitive esports leagues, tournaments, or organized competitive play. True if official esports programs exist.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:franchiseCode rdf:type rdf:Property ;
    rdfs:label 'Franchise Code' ;
    rdfs:comment 'Short alphanumeric code used internally for franchise identification in systems, reporting, and SKU (Stock Keeping Unit) generation. Typically 3-10 uppercase characters.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseName rdf:type rdf:Property ;
    rdfs:label 'Franchise Name' ;
    rdfs:comment 'The official brand name of the game franchise or IP family (e.g., \'Call of Duty\', \'FIFA\', \'The Legend of Zelda\'). This is the primary business identifier used across all marketing, publishing, and distribution channels.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseStatus rdf:type rdf:Property ;
    rdfs:label 'Franchise Status' ;
    rdfs:comment 'Current lifecycle state of the franchise: active (currently publishing titles), dormant (no active development but IP retained), retired (end-of-life, no future titles planned), in_development (new franchise being established).' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseTier rdf:type rdf:Property ;
    rdfs:label 'Franchise Tier' ;
    rdfs:comment 'Strategic tier classification indicating investment level and market positioning: AAA flagship (highest budget, global reach), AA mid-tier (moderate budget, targeted markets), indie (small budget, niche audience), mobile-first (optimized for mobile platforms), experimental (proof-of-concept or emerging IP).' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inceptionYear rdf:type rdf:Property ;
    rdfs:label 'Inception Year' ;
    rdfs:comment 'The year the franchise was first established or the first title in the franchise was released. Used for franchise age calculations and historical analysis.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ipOwnerEntity rdf:type rdf:Property ;
    rdfs:label 'Ip Owner Entity' ;
    rdfs:comment 'Legal entity or organization that owns the intellectual property rights to the franchise. May be the publishing studio, parent company, or external licensor.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTitleReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Last Title Release Date' ;
    rdfs:comment 'The date the most recent title in the franchise was released. Used to assess franchise recency and activity level.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:localizationLanguagesSupported rdf:type rdf:Property ;
    rdfs:label 'Localization Languages Supported' ;
    rdfs:comment 'Comma-separated list of languages that titles in the franchise are typically localized into (e.g., \'English, Spanish, French, German, Japanese, Chinese\'). Used for localization planning and market reach analysis.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextPlannedReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Next Planned Release Date' ;
    rdfs:comment 'The anticipated release date for the next title in the franchise pipeline. Nullable if no future release is currently planned. Confidential for competitive reasons.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:secondaryGenre rdf:type rdf:Property ;
    rdfs:label 'Secondary Genre' ;
    rdfs:comment 'Optional secondary genre classification for franchises that blend multiple gameplay styles (e.g., action-RPG, sports-simulation). Nullable if franchise has single clear genre.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialMediaHandle rdf:type rdf:Property ;
    rdfs:label 'Social Media Handle' ;
    rdfs:comment 'The primary social media handle or username used across platforms (Twitter, Instagram, Facebook) for official franchise communications. Used for community management and brand monitoring.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicPriorityLevel rdf:type rdf:Property ;
    rdfs:label 'Strategic Priority Level' ;
    rdfs:comment 'Internal classification of the franchises strategic importance to the business portfolio: critical (flagship, highest investment), high (key growth driver), medium (stable contributor), low (maintenance mode), sunset (planned phase-out). Confidential strategic data.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudienceRating rdf:type rdf:Property ;
    rdfs:label 'Target Audience Rating' ;
    rdfs:comment 'The typical age rating classification for titles in this franchise based on ESRB (Entertainment Software Rating Board) or PEGI (Pan European Game Information) standards. Used for marketing and compliance planning. [ENUM-REF-CANDIDATE: ec|e|e10|t|m|ao|pegi_3|pegi_7|pegi_12|pegi_16|pegi_18 — promote to reference product]' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMarketRegions rdf:type rdf:Property ;
    rdfs:label 'Target Market Regions' ;
    rdfs:comment 'Comma-separated list of primary geographic markets or regions where the franchise is actively marketed and distributed (e.g., \'North America, Europe, Asia-Pacific\'). Used for regional strategy and localization planning.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalTitlesCount rdf:type rdf:Property ;
    rdfs:label 'Total Titles Count' ;
    rdfs:comment 'The cumulative number of game titles released under this franchise across all platforms and editions. Includes base games, expansions, and major DLC (Downloadable Content) releases that are tracked as separate SKUs.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ugcEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Ugc Enabled Flag' ;
    rdfs:comment 'Indicates whether titles in the franchise support user-generated content creation, modding, or community content tools. True if UGC features are available.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:universeDescription rdf:type rdf:Property ;
    rdfs:label 'Universe Description' ;
    rdfs:comment 'A narrative description of the shared fictional universe, lore, setting, or thematic elements that connect titles within the franchise. Used for creative alignment and marketing messaging.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationUsd rdf:type rdf:Property ;
    rdfs:label 'Valuation Usd' ;
    rdfs:comment 'The estimated market valuation of the franchise IP in US dollars. Used for portfolio management, investment decisions, and M&A (Mergers and Acquisitions) analysis. Confidential financial data.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseGameIncluded rdf:type rdf:Property ;
    rdfs:label 'Base Game Included' ;
    rdfs:comment 'Indicates whether this edition includes the full base game or is an add-on/expansion-only package.' ;
    rdfs:domain ind:GameEdition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bonusContentDescription rdf:type rdf:Property ;
    rdfs:label 'Bonus Content Description' ;
    rdfs:comment 'Detailed description of bonus digital or physical content included with this edition (e.g., artbook, soundtrack, in-game items, cosmetics, early access).' ;
    rdfs:domain ind:GameEdition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'The date when this edition was discontinued or removed from active sale, if applicable.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dlcBundleCount rdf:type rdf:Property ;
    rdfs:label 'Dlc Bundle Count' ;
    rdfs:comment 'Number of DLC content bundles included with this edition at time of purchase.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:earlyAccessDays rdf:type rdf:Property ;
    rdfs:label 'Early Access Days' ;
    rdfs:comment 'Number of days of early access to the game granted to purchasers of this edition before the standard launch date.' ;
    rdfs:domain ind:GameEdition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:editionCode rdf:type rdf:Property ;
    rdfs:label 'Edition Code' ;
    rdfs:comment 'Short alphanumeric code used internally and in systems to identify the edition (e.g., STD, DLX, ULT, COLL, GOTY).' ;
    rdfs:domain ind:GameEdition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:editionName rdf:type rdf:Property ;
    rdfs:label 'Edition Name' ;
    rdfs:comment 'The marketing name of the edition tier (e.g., Standard, Deluxe, Ultimate, Collectors, Game of the Year, Gold, Platinum, Limited, Special).' ;
    rdfs:domain ind:GameEdition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:editionTier rdf:type rdf:Property ;
    rdfs:label 'Edition Tier' ;
    rdfs:comment 'Hierarchical tier classification of the edition for pricing and content segmentation purposes.' ;
    rdfs:domain ind:GameEdition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gameEditionStatus rdf:type rdf:Property ;
    rdfs:label 'Game Edition Status' ;
    rdfs:comment 'Current lifecycle status of the edition indicating its availability and operational state.' ;
    rdfs:domain ind:GameEdition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDigital rdf:type rdf:Property ;
    rdfs:label 'Is Digital' ;
    rdfs:comment 'Indicates whether this edition is available as a digital download through online storefronts.' ;
    rdfs:domain ind:GameEdition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLimitedAvailability rdf:type rdf:Property ;
    rdfs:label 'Is Limited Availability' ;
    rdfs:comment 'Indicates whether this edition has limited production run or time-limited availability (e.g., pre-order exclusive, launch edition).' ;
    rdfs:domain ind:GameEdition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPhysical rdf:type rdf:Property ;
    rdfs:label 'Is Physical' ;
    rdfs:comment 'Indicates whether this edition includes physical components (disc, box, collectibles) or is digital-only.' ;
    rdfs:domain ind:GameEdition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPreOrderExclusive rdf:type rdf:Property ;
    rdfs:label 'Is Pre Order Exclusive' ;
    rdfs:comment 'Indicates whether this edition is only available through pre-order channels before official launch.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingDescription rdf:type rdf:Property ;
    rdfs:label 'Marketing Description' ;
    rdfs:comment 'Edition-level marketing copy describing the value proposition, target audience, and key selling points for promotional use.' ;
    rdfs:domain ind:GameEdition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msrpAmount rdf:type rdf:Property ;
    rdfs:label 'Msrp Amount' ;
    rdfs:comment 'The suggested retail price for this edition in the base currency, used as pricing guidance across regions and platforms.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:msrpCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Msrp Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the MSRP amount (e.g., USD, EUR, GBP, JPY).' ;
    rdfs:domain ind:GameEdition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalCollectiblesDescription rdf:type rdf:Property ;
    rdfs:label 'Physical Collectibles Description' ;
    rdfs:comment 'Description of physical collectible items included in collectors or special editions (e.g., statue, steelbook, map, poster, art cards).' ;
    rdfs:domain ind:GameEdition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preOrderEndDate rdf:type rdf:Property ;
    rdfs:label 'Pre Order End Date' ;
    rdfs:comment 'The date when pre-orders for this edition closed, typically at or near the launch date.' ;
    rdfs:domain ind:GameEdition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preOrderStartDate rdf:type rdf:Property ;
    rdfs:label 'Pre Order Start Date' ;
    rdfs:comment 'The date when pre-orders for this edition opened to customers.' ;
    rdfs:domain ind:GameEdition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seasonPassIncluded rdf:type rdf:Property ;
    rdfs:label 'Season Pass Included' ;
    rdfs:comment 'Indicates whether this edition includes a season pass granting access to future DLC (Downloadable Content) releases.' ;
    rdfs:domain ind:GameEdition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:skuTemplateFlag rdf:type rdf:Property ;
    rdfs:label 'Sku Template Flag' ;
    rdfs:comment 'Indicates whether this edition serves as a reusable template that multiple platform-specific and region-specific SKUs reference.' ;
    rdfs:domain ind:GameEdition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storefrontAvailability rdf:type rdf:Property ;
    rdfs:label 'Storefront Availability' ;
    rdfs:comment 'Comma-separated list of digital storefronts and retail channels where this edition is sold (e.g., Steam, Epic Games Store, PlayStation Store, Xbox Store, retail). [ENUM-REF-CANDIDATE: steam|epic_games_store|playstation_store|xbox_store|nintendo_eshop|gog|retail|direct — promote to reference product]' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitsProduced rdf:type rdf:Property ;
    rdfs:label 'Units Produced' ;
    rdfs:comment 'Total number of units manufactured or allocated for this edition, particularly relevant for limited and collectors editions.' ;
    rdfs:domain ind:GameEdition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageRatingOverride rdf:type rdf:Property ;
    rdfs:label 'Age Rating Override' ;
    rdfs:comment 'Optional age rating specific to this mode if it differs from the base game title rating (e.g., a mature-rated mode within a teen-rated game). References ESRB, PEGI, CERO standards.' ;
    rdfs:domain ind:GameMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:antiCheatRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Anti Cheat Required Flag' ;
    rdfs:comment 'Indicates whether anti-cheat software must be active to play this mode (True, typically for competitive modes) or if it is optional/disabled (False).' ;
    rdfs:domain ind:GameMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossPlaySupportedFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Play Supported Flag' ;
    rdfs:comment 'Indicates whether players on different platforms can play together in this mode (True) or if platform segregation is enforced (False).' ;
    rdfs:domain ind:GameMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossProgressionEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Progression Enabled Flag' ;
    rdfs:comment 'Indicates whether player progression and unlocks in this mode carry across platforms (True) or are platform-specific (False).' ;
    rdfs:domain ind:GameMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:esportsEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Esports Eligible Flag' ;
    rdfs:comment 'Indicates whether this mode is approved for competitive esports tournaments and league play (True) or is casual-only (False).' ;
    rdfs:domain ind:GameMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:friendlyFireEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Friendly Fire Enabled Flag' ;
    rdfs:comment 'Indicates whether players can damage their own teammates in this mode (True) or if friendly fire is disabled (False).' ;
    rdfs:domain ind:GameMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gameModeDescription rdf:type rdf:Property ;
    rdfs:label 'Game Mode Description' ;
    rdfs:comment 'Detailed text description of the game mode explaining its rules, objectives, and unique features. Used for player-facing UI and marketing materials.' ;
    rdfs:domain ind:GameMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gameModeStatus rdf:type rdf:Property ;
    rdfs:label 'Game Mode Status' ;
    rdfs:comment 'Current operational status of the game mode indicating availability to players and lifecycle stage. [ENUM-REF-CANDIDATE: active|inactive|beta|deprecated|seasonal|limited_time|maintenance — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GameMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gameplayCategory rdf:type rdf:Property ;
    rdfs:label 'Gameplay Category' ;
    rdfs:comment 'Specific gameplay category or sub-genre that defines the core mechanics and objectives of this mode (e.g., PvP, PvE, Battle Royale, Team Deathmatch). [ENUM-REF-CANDIDATE: campaign|pvp|pve|battle_royale|team_deathmatch|capture_flag|survival|sandbox|story|arena — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GameMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitedTimeEventFlag rdf:type rdf:Property ;
    rdfs:label 'Limited Time Event Flag' ;
    rdfs:comment 'Indicates whether this mode is a limited-time event (True) available only during specific promotional periods or a permanent fixture (False).' ;
    rdfs:domain ind:GameMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchmakingAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Matchmaking Algorithm' ;
    rdfs:comment 'The matchmaking algorithm or strategy used to pair players in this mode (e.g., skill-based, connection-based, ranked ELO). [ENUM-REF-CANDIDATE: skill_based|connection_based|hybrid|random|ranked_elo|glicko|trueskill — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GameMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchmakingEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Matchmaking Enabled Flag' ;
    rdfs:comment 'Indicates whether automated matchmaking is available for this mode (True) or if players must form custom lobbies (False).' ;
    rdfs:domain ind:GameMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxPlayerCount rdf:type rdf:Property ;
    rdfs:label 'Max Player Count' ;
    rdfs:comment 'The maximum number of players that can participate simultaneously in this game mode. Defines capacity limits for matchmaking and server allocation.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minPlayerCount rdf:type rdf:Property ;
    rdfs:label 'Min Player Count' ;
    rdfs:comment 'The minimum number of players required to start or participate in this game mode. Used for matchmaking and lobby requirements.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modeCode rdf:type rdf:Property ;
    rdfs:label 'Mode Code' ;
    rdfs:comment 'Internal system code or abbreviation for the game mode used in telemetry, analytics, and backend systems (e.g., SP_CAMPAIGN, MP_PVP, BR_SOLO).' ;
    rdfs:domain ind:GameMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modeName rdf:type rdf:Property ;
    rdfs:label 'Mode Name' ;
    rdfs:comment 'The official display name of the game mode as shown to players (e.g., Campaign, Multiplayer, Battle Royale, Ranked Competitive).' ;
    rdfs:domain ind:GameMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modeType rdf:type rdf:Property ;
    rdfs:label 'Mode Type' ;
    rdfs:comment 'High-level classification of the mode type indicating the primary gameplay structure and player interaction model. [ENUM-REF-CANDIDATE: single_player|multiplayer|co_op|competitive|casual|ranked|tutorial|practice — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GameMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monetizationEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Monetization Enabled Flag' ;
    rdfs:comment 'Indicates whether in-game purchases, microtransactions (MTX), or monetization features are available within this mode (True) or disabled (False).' ;
    rdfs:domain ind:GameMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onlineRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Online Required Flag' ;
    rdfs:comment 'Indicates whether an active internet connection is required to play this mode (True for online multiplayer) or if offline play is supported (False for single-player campaign).' ;
    rdfs:domain ind:GameMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:progressionEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Progression Enabled Flag' ;
    rdfs:comment 'Indicates whether player progression (XP, levels, unlocks) is tracked and awarded in this mode (True) or if it is a non-progression mode (False, as in practice modes).' ;
    rdfs:domain ind:GameMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rankedModeFlag rdf:type rdf:Property ;
    rdfs:label 'Ranked Mode Flag' ;
    rdfs:comment 'Indicates whether this mode is a competitive ranked mode with skill rating and leaderboard tracking (True) or casual unranked play (False).' ;
    rdfs:domain ind:GameMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:respawnEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Respawn Enabled Flag' ;
    rdfs:comment 'Indicates whether players can respawn after elimination in this mode (True) or if elimination is permanent for the session (False, as in Battle Royale).' ;
    rdfs:domain ind:GameMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rulesSummary rdf:type rdf:Property ;
    rdfs:label 'Rules Summary' ;
    rdfs:comment 'Concise summary of the core gameplay rules and win conditions for this mode. Used for quick reference and onboarding.' ;
    rdfs:domain ind:GameMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Flag' ;
    rdfs:comment 'Indicates whether this mode is tied to a specific game season or live ops cycle (True) or is a permanent mode (False).' ;
    rdfs:domain ind:GameMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sessionDurationMaxMinutes rdf:type rdf:Property ;
    rdfs:label 'Session Duration Max Minutes' ;
    rdfs:comment 'The typical maximum duration of a gameplay session in this mode, measured in minutes. Used for server resource planning and player engagement analytics.' ;
    rdfs:domain ind:GameMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sessionDurationMinMinutes rdf:type rdf:Property ;
    rdfs:label 'Session Duration Min Minutes' ;
    rdfs:comment 'The typical minimum duration of a gameplay session in this mode, measured in minutes. Used for player engagement analytics and session planning.' ;
    rdfs:domain ind:GameMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spectatorModeEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Spectator Mode Enabled Flag' ;
    rdfs:comment 'Indicates whether non-playing users can spectate live matches in this mode (True) or if spectating is disabled (False). Important for esports and streaming.' ;
    rdfs:domain ind:GameMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:teamBasedFlag rdf:type rdf:Property ;
    rdfs:label 'Team Based Flag' ;
    rdfs:comment 'Indicates whether this mode organizes players into teams (True) or is free-for-all individual play (False).' ;
    rdfs:domain ind:GameMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:textChatEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Text Chat Enabled Flag' ;
    rdfs:comment 'Indicates whether in-game text chat is enabled for this mode (True) or disabled (False). Relevant for player communication and moderation.' ;
    rdfs:domain ind:GameMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tutorialAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Tutorial Available Flag' ;
    rdfs:comment 'Indicates whether a dedicated tutorial or First-Time User Experience (FTUE) is available for this mode (True) or if players must learn through play (False).' ;
    rdfs:domain ind:GameMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessModel rdf:type rdf:Property ;
    rdfs:label 'Business Model' ;
    rdfs:comment 'The monetization model for the game title. F2P (Free-to-Play) indicates no upfront cost with in-game monetization; premium indicates upfront purchase; subscription indicates recurring access fee; hybrid combines multiple models.' ;
    rdfs:domain ind:GameTitle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coppaComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Coppa Compliance Required' ;
    rdfs:comment 'Flag indicating whether this game title is subject to COPPA compliance requirements due to targeting or attracting children under 13. True if COPPA applies; false otherwise. Drives data collection and parental consent requirements.' ;
    rdfs:domain ind:GameTitle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endOfLifeDate rdf:type rdf:Property ;
    rdfs:label 'End Of Life Date' ;
    rdfs:comment 'The date on which the game title reached end-of-life status with all support, servers, and distribution ceased. Used for historical reporting and compliance with data retention policies.' ;
    rdfs:domain ind:GameTitle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:epicCatalogItemCode rdf:type rdf:Property ;
    rdfs:label 'Epic Catalog Item Code' ;
    rdfs:comment 'The unique catalog item identifier assigned by Epic Games for distribution on the Epic Games Store. Used for sales tracking and platform integration.' ;
    rdfs:domain ind:GameTitle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gameModes rdf:type rdf:Property ;
    rdfs:label 'Game Modes' ;
    rdfs:comment 'Comma-separated list of gameplay modes supported by the title (e.g., campaign, multiplayer, co-op, battle royale, sandbox, competitive, casual). Used for feature marketing and player expectation setting.' ;
    rdfs:domain ind:GameTitle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprScope rdf:type rdf:Property ;
    rdfs:label 'Gdpr Scope' ;
    rdfs:comment 'Indicates whether this game title is subject to GDPR requirements based on player base and data processing activities. In-scope titles must comply with EU data protection regulations; out-of-scope titles do not process EU player data; partial indicates limited EU exposure.' ;
    rdfs:domain ind:GameTitle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasDlc rdf:type rdf:Property ;
    rdfs:label 'Has Dlc' ;
    rdfs:comment 'Flag indicating whether this game title has associated downloadable content (DLC) or expansion packs available for purchase. True if DLC exists; false otherwise.' ;
    rdfs:domain ind:GameTitle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasLootBoxes rdf:type rdf:Property ;
    rdfs:label 'Has Loot Boxes' ;
    rdfs:comment 'Flag indicating whether this game title includes loot boxes or randomized reward mechanics. True if loot boxes are present; false otherwise. Subject to regulatory scrutiny in multiple jurisdictions.' ;
    rdfs:domain ind:GameTitle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasMicrotransactions rdf:type rdf:Property ;
    rdfs:label 'Has Microtransactions' ;
    rdfs:comment 'Flag indicating whether this game title includes in-game microtransactions (MTX) for virtual goods, currency, or cosmetics. True if MTX are present; false otherwise. Critical for regulatory disclosure and player expectations.' ;
    rdfs:domain ind:GameTitle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initialReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Initial Release Date' ;
    rdfs:comment 'The date on which the game title was first released to the public on any platform. Used for lifecycle analytics, anniversary marketing, and historical reporting.' ;
    rdfs:domain ind:GameTitle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ipOwnershipEntity rdf:type rdf:Property ;
    rdfs:label 'Ip Ownership Entity' ;
    rdfs:comment 'The legal entity that owns the intellectual property rights for this game title. Critical for licensing, royalty calculations, and legal compliance.' ;
    rdfs:domain ind:GameTitle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCrossPlaySupported rdf:type rdf:Property ;
    rdfs:label 'Is Cross Play Supported' ;
    rdfs:comment 'Flag indicating whether players on different platforms can play together in the same session. True if cross-play is enabled; false otherwise. Key feature for player acquisition and retention.' ;
    rdfs:domain ind:GameTitle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEsportsTitle rdf:type rdf:Property ;
    rdfs:label 'Is Esports Title' ;
    rdfs:comment 'Flag indicating whether this game title is actively supported as an esports title with competitive leagues, tournaments, or official competitive infrastructure. True if esports-enabled; false otherwise.' ;
    rdfs:domain ind:GameTitle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGaas rdf:type rdf:Property ;
    rdfs:label 'Is Gaas' ;
    rdfs:comment 'Flag indicating whether this title operates as a Game as a Service (GaaS) with ongoing live operations, content updates, seasons, and continuous player engagement. True for live-service games; false for traditional release-and-done titles.' ;
    rdfs:domain ind:GameTitle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUgcEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Ugc Enabled' ;
    rdfs:comment 'Flag indicating whether this game title supports user-generated content (UGC) such as custom levels, mods, or in-game creations. True if UGC is enabled; false otherwise. Impacts moderation requirements and community engagement strategy.' ;
    rdfs:domain ind:GameTitle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latestReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Latest Release Date' ;
    rdfs:comment 'The date of the most recent major release, re-release, or remaster of the game title. Tracks ongoing release activity for titles with multiple platform launches or editions.' ;
    rdfs:domain ind:GameTitle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:officialTitleName rdf:type rdf:Property ;
    rdfs:label 'Official Title Name' ;
    rdfs:comment 'The official, publicly-facing name of the game title as it appears on storefronts, marketing materials, and platform certifications. This is the authoritative display name for the intellectual property.' ;
    rdfs:domain ind:GameTitle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officialWebsiteUrl rdf:type rdf:Property ;
    rdfs:label 'Official Website Url' ;
    rdfs:comment 'The URL of the official website for the game title. Used for player information, marketing campaigns, and community engagement.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onlineCapability rdf:type rdf:Property ;
    rdfs:label 'Online Capability' ;
    rdfs:comment 'Indicates whether the game requires an internet connection to play. Online-only titles require persistent connectivity; offline-only titles do not; hybrid titles support both modes.' ;
    rdfs:domain ind:GameTitle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedSunsetDate rdf:type rdf:Property ;
    rdfs:label 'Planned Sunset Date' ;
    rdfs:comment 'The planned date for sunsetting live operations or ending active support for the game title. Used for resource planning and player communication. Nullable for titles with indefinite support.' ;
    rdfs:domain ind:GameTitle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'The current status of this master catalog record. Active indicates the record is current and in use; inactive indicates temporarily disabled; archived indicates historical record retained for compliance; deleted indicates soft-deleted pending purge.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:steamAppCode rdf:type rdf:Property ;
    rdfs:label 'Steam App Code' ;
    rdfs:comment 'The unique application identifier assigned by Valve for distribution on the Steam platform. Used for sales tracking, API integration, and platform analytics.' ;
    rdfs:domain ind:GameTitle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAgeMax rdf:type rdf:Property ;
    rdfs:label 'Target Age Max' ;
    rdfs:comment 'The maximum age of the intended player demographic for marketing and design purposes. Used for player acquisition targeting and content design decisions.' ;
    rdfs:domain ind:GameTitle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetAgeMin rdf:type rdf:Property ;
    rdfs:label 'Target Age Min' ;
    rdfs:comment 'The minimum age of the intended player demographic for marketing and design purposes. May differ from regulatory ratings. Used for player acquisition targeting and content design decisions.' ;
    rdfs:domain ind:GameTitle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workingTitle rdf:type rdf:Property ;
    rdfs:label 'Working Title' ;
    rdfs:comment 'Internal codename or working title used during development before the official title name is finalized. Used for project tracking and confidentiality during pre-announcement phases.' ;
    rdfs:domain ind:GameTitle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentGenreGenreClassificationId rdf:type rdf:Property ;
    rdfs:label 'Parent Genre Genre Classification Id' ;
    rdfs:comment 'Reference to the parent genre classification for hierarchical taxonomy (e.g., Metroidvania sub-genre links to Action parent). Null for top-level primary genres.' ;
    rdfs:domain ind:GenreClassification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GenreClassification .

ind:artStyle rdf:type rdf:Property ;
    rdfs:label 'Art Style' ;
    rdfs:comment 'Visual art style classification (e.g., Realistic, Stylized, Pixel Art, Cel-Shaded, Low Poly, Photorealistic). Used for visual preference-based recommendation engines.' ;
    rdfs:domain ind:GenreClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cameraPerspective rdf:type rdf:Property ;
    rdfs:label 'Camera Perspective' ;
    rdfs:comment 'Primary camera viewpoint used in the game (e.g., first-person, third-person, top-down, isometric, side-scrolling). Important for player preference segmentation and storefront filtering. [ENUM-REF-CANDIDATE: first_person|third_person|top_down|isometric|side_scrolling|fixed_camera|mixed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenreClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complexityLevel rdf:type rdf:Property ;
    rdfs:label 'Complexity Level' ;
    rdfs:comment 'Gameplay complexity and learning curve classification (e.g., low, medium, high, expert). Used for player onboarding and FTUE design guidance.' ;
    rdfs:domain ind:GenreClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consoleStoreCategory rdf:type rdf:Property ;
    rdfs:label 'Console Store Category' ;
    rdfs:comment 'Corresponding console platform store category (PlayStation Store, Xbox Store, Nintendo eShop) for this genre. Used for first-party platform certification and storefront alignment.' ;
    rdfs:domain ind:GenreClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryPriority rdf:type rdf:Property ;
    rdfs:label 'Discovery Priority' ;
    rdfs:comment 'Numeric priority ranking (1=highest) for storefront discovery and featured placement. Used by merchandising and marketing teams for genre-based promotions.' ;
    rdfs:domain ind:GenreClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:epicStoreCategory rdf:type rdf:Property ;
    rdfs:label 'Epic Store Category' ;
    rdfs:comment 'Corresponding Epic Games Store category mapping for this genre. Used for Epic storefront categorization and discovery optimization.' ;
    rdfs:domain ind:GenreClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esrbRatingGuidance rdf:type rdf:Property ;
    rdfs:label 'Esrb Rating Guidance' ;
    rdfs:comment 'Typical ESRB (Entertainment Software Rating Board) rating associated with this genre (e.g., E, E10+, T, M, AO). Used for content planning and compliance guidance.' ;
    rdfs:domain ind:GenreClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gameplayTag rdf:type rdf:Property ;
    rdfs:label 'Gameplay Tag' ;
    rdfs:comment 'Descriptive gameplay mechanic or feature tag used for discovery and recommendation (e.g., Open World, Crafting, Permadeath, Procedural Generation, Co-op, Competitive).' ;
    rdfs:domain ind:GenreClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genreClassificationDescription rdf:type rdf:Property ;
    rdfs:label 'Genre Classification Description' ;
    rdfs:comment 'Detailed business description of the genre classification, including defining characteristics, typical gameplay mechanics, and examples. Used for internal training and external storefront descriptions.' ;
    rdfs:domain ind:GenreClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genreClassificationStatus rdf:type rdf:Property ;
    rdfs:label 'Genre Classification Status' ;
    rdfs:comment 'Current lifecycle status of this genre classification (e.g., active, deprecated, retired, proposed, under_review). Used for taxonomy governance and change management.' ;
    rdfs:domain ind:GenreClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genreCode rdf:type rdf:Property ;
    rdfs:label 'Genre Code' ;
    rdfs:comment 'Short alphanumeric code representing the genre classification (e.g., ACT, RPG, STR, SPT, SIM, PUZ, HOR). Used as a business identifier for storefront categorization and internal systems.' ;
    rdfs:domain ind:GenreClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genreName rdf:type rdf:Property ;
    rdfs:label 'Genre Name' ;
    rdfs:comment 'Human-readable name of the primary genre (e.g., Action, Role-Playing Game, Strategy, Sports, Simulation, Puzzle, Horror).' ;
    rdfs:domain ind:GenreClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genreType rdf:type rdf:Property ;
    rdfs:label 'Genre Type' ;
    rdfs:comment 'Classification level indicating whether this is a primary genre, sub-genre, hybrid classification, or gameplay tag.' ;
    rdfs:domain ind:GenreClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryStandardAlignment rdf:type rdf:Property ;
    rdfs:label 'Industry Standard Alignment' ;
    rdfs:comment 'Comma-separated list of industry standards and taxonomies this genre classification aligns with (e.g., IGDA, Steam, ESRB, PEGI, Metacritic). Used for cross-platform consistency and compliance.' ;
    rdfs:domain ind:GenreClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingSegment rdf:type rdf:Property ;
    rdfs:label 'Marketing Segment' ;
    rdfs:comment 'Marketing segmentation category for this genre (e.g., AAA Blockbuster, Indie Darling, Casual Mobile, Competitive Esports). Used for campaign targeting and player acquisition strategy.' ;
    rdfs:domain ind:GenreClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileStoreCategory rdf:type rdf:Property ;
    rdfs:label 'Mobile Store Category' ;
    rdfs:comment 'Corresponding mobile app store category (Apple App Store, Google Play) for this genre. Used for mobile ASO and storefront categorization.' ;
    rdfs:domain ind:GenreClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pegiRatingGuidance rdf:type rdf:Property ;
    rdfs:label 'Pegi Rating Guidance' ;
    rdfs:comment 'Typical PEGI (Pan European Game Information) rating associated with this genre (e.g., PEGI 3, PEGI 7, PEGI 12, PEGI 16, PEGI 18). Used for European market content planning and compliance.' ;
    rdfs:domain ind:GenreClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformAffinity rdf:type rdf:Property ;
    rdfs:label 'Platform Affinity' ;
    rdfs:comment 'Platform types where this genre typically performs well (e.g., Console, PC, Mobile, VR, AR, Cloud). Used for platform distribution strategy and SKU planning.' ;
    rdfs:domain ind:GenreClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerMode rdf:type rdf:Property ;
    rdfs:label 'Player Mode' ;
    rdfs:comment 'Supported player interaction modes (e.g., single-player, multiplayer, co-op, PvP, PvE, MMO, Battle Royale). Used for matchmaking categorization and marketing segmentation. [ENUM-REF-CANDIDATE: single_player|multiplayer|co_op|pvp|pve|mmo|battle_royale|mixed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenreClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationWeight rdf:type rdf:Property ;
    rdfs:label 'Recommendation Weight' ;
    rdfs:comment 'Numeric weight (0.00 to 100.00) used in recommendation engine algorithms to prioritize genre affinity matching. Higher weights indicate stronger genre preference signals.' ;
    rdfs:domain ind:GenreClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settingTheme rdf:type rdf:Property ;
    rdfs:label 'Setting Theme' ;
    rdfs:comment 'Narrative or world setting theme (e.g., Fantasy, Sci-Fi, Historical, Modern, Post-Apocalyptic, Cyberpunk, Medieval). Used for thematic discovery and content recommendation.' ;
    rdfs:domain ind:GenreClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:steamTagMapping rdf:type rdf:Property ;
    rdfs:label 'Steam Tag Mapping' ;
    rdfs:comment 'Comma-separated list of corresponding Steam store tags for this genre classification. Used for Steam storefront categorization and ASO (App Store Optimization).' ;
    rdfs:domain ind:GenreClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subGenreName rdf:type rdf:Property ;
    rdfs:label 'Sub Genre Name' ;
    rdfs:comment 'Specific sub-genre classification providing granular categorization (e.g., Metroidvania, Roguelike, MOBA, Battle Royale, Soulslike, Tactical RPG, 4X Strategy).' ;
    rdfs:domain ind:GenreClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxonomyVersion rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Version' ;
    rdfs:comment 'Version identifier for the genre classification taxonomy (e.g., v1.0, v2.1). Tracks evolution of genre definitions as industry trends emerge (e.g., Battle Royale emergence in 2017).' ;
    rdfs:domain ind:GenreClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalRetentionD1Pct rdf:type rdf:Property ;
    rdfs:label 'Typical Retention D1 Pct' ;
    rdfs:comment 'Industry benchmark Day 1 retention percentage for this genre. Used for performance benchmarking and KPI target setting.' ;
    rdfs:domain ind:GenreClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalRetentionD30Pct rdf:type rdf:Property ;
    rdfs:label 'Typical Retention D30 Pct' ;
    rdfs:comment 'Industry benchmark Day 30 retention percentage for this genre. Used for long-term engagement forecasting and LTV modeling.' ;
    rdfs:domain ind:GenreClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalRetentionD7Pct rdf:type rdf:Property ;
    rdfs:label 'Typical Retention D7 Pct' ;
    rdfs:comment 'Industry benchmark Day 7 retention percentage for this genre. Used for performance benchmarking and player lifecycle analysis.' ;
    rdfs:domain ind:GenreClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:versionEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Version Effective Date' ;
    rdfs:comment 'Date when this taxonomy version became effective. Used for historical genre classification analysis and trend tracking.' ;
    rdfs:domain ind:GenreClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:versionEndDate rdf:type rdf:Property ;
    rdfs:label 'Version End Date' ;
    rdfs:comment 'Date when this taxonomy version was superseded by a newer version. Null for the current active version. Used for temporal genre classification queries.' ;
    rdfs:domain ind:GenreClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaderboardId rdf:type rdf:Property ;
    rdfs:label 'Leaderboard Id' ;
    rdfs:comment 'Unique identifier for the leaderboard. Primary key.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Leaderboard .

ind:antiCheatEnabled rdf:type rdf:Property ;
    rdfs:label 'Anti Cheat Enabled' ;
    rdfs:comment 'Indicates whether anti-cheat validation is applied to leaderboard submissions.' ;
    rdfs:domain ind:Leaderboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:displayPercentile rdf:type rdf:Property ;
    rdfs:label 'Display Percentile' ;
    rdfs:comment 'Indicates whether player percentile ranking is displayed (e.g., top 5 percent).' ;
    rdfs:domain ind:Leaderboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:displayPlayerCount rdf:type rdf:Property ;
    rdfs:label 'Display Player Count' ;
    rdfs:comment 'Indicates whether the total number of ranked players is displayed on the leaderboard UI.' ;
    rdfs:domain ind:Leaderboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastResetTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Reset Timestamp' ;
    rdfs:comment 'Timestamp of the most recent leaderboard reset.' ;
    rdfs:domain ind:Leaderboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:leaderboardCode rdf:type rdf:Property ;
    rdfs:label 'Leaderboard Code' ;
    rdfs:comment 'Unique business identifier code for the leaderboard used in APIs and system integrations.' ;
    rdfs:domain ind:Leaderboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaderboardDescription rdf:type rdf:Property ;
    rdfs:label 'Leaderboard Description' ;
    rdfs:comment 'Detailed description of the leaderboard purpose, rules, and objectives displayed to players.' ;
    rdfs:domain ind:Leaderboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaderboardName rdf:type rdf:Property ;
    rdfs:label 'Leaderboard Name' ;
    rdfs:comment 'Human-readable name of the leaderboard displayed to players.' ;
    rdfs:domain ind:Leaderboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaderboardStatus rdf:type rdf:Property ;
    rdfs:label 'Leaderboard Status' ;
    rdfs:comment 'Current lifecycle status of the leaderboard.' ;
    rdfs:domain ind:Leaderboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaderboardType rdf:type rdf:Property ;
    rdfs:label 'Leaderboard Type' ;
    rdfs:comment 'Classification of the leaderboard scope (global, regional, friends-only, guild-based, seasonal, or event-specific).' ;
    rdfs:domain ind:Leaderboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manualReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Manual Review Required' ;
    rdfs:comment 'Indicates whether top scores require manual review before being posted to the leaderboard.' ;
    rdfs:domain ind:Leaderboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxRankDisplayed rdf:type rdf:Property ;
    rdfs:label 'Max Rank Displayed' ;
    rdfs:comment 'Maximum number of top-ranked players displayed on the leaderboard UI (e.g., top 100, top 1000).' ;
    rdfs:domain ind:Leaderboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minMatchesPlayed rdf:type rdf:Property ;
    rdfs:label 'Min Matches Played' ;
    rdfs:comment 'Minimum number of matches a player must complete to qualify for ranking (null if no minimum).' ;
    rdfs:domain ind:Leaderboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextResetTimestamp rdf:type rdf:Property ;
    rdfs:label 'Next Reset Timestamp' ;
    rdfs:comment 'Scheduled timestamp for the next leaderboard reset.' ;
    rdfs:domain ind:Leaderboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rankingAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Ranking Algorithm' ;
    rdfs:comment 'Algorithm used to calculate player rankings (Elo, Glicko, TrueSkill, raw points, fastest time, highest score).' ;
    rdfs:domain ind:Leaderboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rankingMetric rdf:type rdf:Property ;
    rdfs:label 'Ranking Metric' ;
    rdfs:comment 'The primary metric used for ranking (e.g., total kills, win rate, completion time, score, rating points).' ;
    rdfs:domain ind:Leaderboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resetCadence rdf:type rdf:Property ;
    rdfs:label 'Reset Cadence' ;
    rdfs:comment 'Frequency at which the leaderboard rankings are reset (never, daily, weekly, monthly, per season, or per event).' ;
    rdfs:domain ind:Leaderboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resetDayOfWeek rdf:type rdf:Property ;
    rdfs:label 'Reset Day Of Week' ;
    rdfs:comment 'Day of the week when weekly leaderboards reset (null for non-weekly cadences). [ENUM-REF-CANDIDATE: monday|tuesday|wednesday|thursday|friday|saturday|sunday — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Leaderboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resetTimeUtc rdf:type rdf:Property ;
    rdfs:label 'Reset Time Utc' ;
    rdfs:comment 'Time of day in UTC when the leaderboard resets (HH:mm format).' ;
    rdfs:domain ind:Leaderboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardDistributionFlag rdf:type rdf:Property ;
    rdfs:label 'Reward Distribution Flag' ;
    rdfs:comment 'Indicates whether rewards are distributed to top-ranked players (true) or if the leaderboard is purely for prestige (false).' ;
    rdfs:domain ind:Leaderboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rewardTierCount rdf:type rdf:Property ;
    rdfs:label 'Reward Tier Count' ;
    rdfs:comment 'Number of reward tiers defined for this leaderboard (e.g., top 10, top 100, top 1000).' ;
    rdfs:domain ind:Leaderboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tieBreakRule rdf:type rdf:Property ;
    rdfs:label 'Tie Break Rule' ;
    rdfs:comment 'Business rule for resolving ties in rankings (e.g., earliest submission time, secondary metric, shared rank).' ;
    rdfs:domain ind:Leaderboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localizationVersionId rdf:type rdf:Property ;
    rdfs:label 'Localization Version Id' ;
    rdfs:comment 'Unique identifier for the localization version record. Primary key.' ;
    rdfs:domain ind:LocalizationVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:audioDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Audio Duration Minutes' ;
    rdfs:comment 'Total duration in minutes of localized voice-over audio content for this language version. Used for production planning and vendor billing.' ;
    rdfs:domain ind:LocalizationVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:characterEncoding rdf:type rdf:Property ;
    rdfs:label 'Character Encoding' ;
    rdfs:comment 'Character encoding standard used for text assets in this localization (e.g., UTF-8, UTF-16, Shift_JIS for Japanese, GB2312 for Simplified Chinese, Big5 for Traditional Chinese).' ;
    rdfs:domain ind:LocalizationVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completenessPercentage rdf:type rdf:Property ;
    rdfs:label 'Completeness Percentage' ;
    rdfs:comment 'Percentage of localization work completed for this language and region, ranging from 0.00 to 100.00. Used to track localization progress and readiness.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentRatingCode rdf:type rdf:Property ;
    rdfs:label 'Content Rating Code' ;
    rdfs:comment 'The assigned content rating code for this localization version from the applicable regional rating board (e.g., ESRB: E, T, M; PEGI: 3, 7, 12, 16, 18; CERO: A, B, C, D, Z).' ;
    rdfs:domain ind:LocalizationVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRatingRequired rdf:type rdf:Property ;
    rdfs:label 'Content Rating Required' ;
    rdfs:comment 'Boolean flag indicating whether this localization version requires a separate content rating submission to regional rating boards (ESRB, PEGI, CERO, USK, GRAC) due to language-specific content differences.' ;
    rdfs:domain ind:LocalizationVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fontSupportVerified rdf:type rdf:Property ;
    rdfs:label 'Font Support Verified' ;
    rdfs:comment 'Boolean flag indicating whether the game engine and UI (User Interface) fonts have been verified to correctly render all characters required for this localization (critical for non-Latin scripts).' ;
    rdfs:domain ind:LocalizationVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includedInBaseSku rdf:type rdf:Property ;
    rdfs:label 'Included In Base Sku' ;
    rdfs:comment 'Boolean flag indicating whether this localization is included in the base SKU (Stock Keeping Unit) at no additional cost (True) or sold separately as a language pack or regional variant (False).' ;
    rdfs:domain ind:LocalizationVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Legal Compliance Status' ;
    rdfs:comment 'Status of legal compliance review for this localization version against regional regulations (GDPR, COPPA, local content laws, gambling regulations, data residency requirements).' ;
    rdfs:domain ind:LocalizationVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localeIdentifier rdf:type rdf:Property ;
    rdfs:label 'Locale Identifier' ;
    rdfs:comment 'Combined locale identifier in language_REGION format (e.g., en_US, fr_FR, de_DE, ja_JP, zh_CN, pt_BR, es_MX) for precise localization targeting.' ;
    rdfs:domain ind:LocalizationVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localizationCostUsd rdf:type rdf:Property ;
    rdfs:label 'Localization Cost Usd' ;
    rdfs:comment 'Total cost in USD (United States Dollar) for producing this localization version, including translation, voice acting, QA (Quality Assurance), and cultural adaptation.' ;
    rdfs:domain ind:LocalizationVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localizationScope rdf:type rdf:Property ;
    rdfs:label 'Localization Scope' ;
    rdfs:comment 'Defines the extent of localization coverage: full audio dub (voice acting), subtitles only, UI (User Interface) text only, partial localization, audio and subtitles, or text only.' ;
    rdfs:domain ind:LocalizationVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Platform Certification Required' ;
    rdfs:comment 'Boolean flag indicating whether this localization version requires separate platform certification (TRC/TCR - Technical Requirements Checklist/Technical Certification Requirements) for first-party console manufacturers or app stores.' ;
    rdfs:domain ind:LocalizationVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storefrontListingStatus rdf:type rdf:Property ;
    rdfs:label 'Storefront Listing Status' ;
    rdfs:comment 'Current status of this localization version on digital storefronts (Steam, Epic Games Store, PlayStation Store, Xbox Store, Nintendo eShop, App Store, Google Play).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtitleFormat rdf:type rdf:Property ;
    rdfs:label 'Subtitle Format' ;
    rdfs:comment 'Technical format used for subtitle files in this localization (e.g., SRT, VTT, ASS, SSA, proprietary engine format, or none if no subtitles).' ;
    rdfs:domain ind:LocalizationVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:textDirection rdf:type rdf:Property ;
    rdfs:label 'Text Direction' ;
    rdfs:comment 'Text rendering direction for this localization: left-to-right (ltr), right-to-left (rtl) for languages like Arabic and Hebrew, or top-to-bottom (ttb) for certain Asian scripts.' ;
    rdfs:domain ind:LocalizationVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:translationMemoryReference rdf:type rdf:Property ;
    rdfs:label 'Translation Memory Reference' ;
    rdfs:comment 'Reference identifier to the translation memory (TM) database or glossary used for this localization, enabling consistency across titles and updates.' ;
    rdfs:domain ind:LocalizationVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedByUser rdf:type rdf:Property ;
    rdfs:label 'Updated By User' ;
    rdfs:comment 'Username or identifier of the user or system that last updated this localization version record.' ;
    rdfs:domain ind:LocalizationVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voiceActorCredits rdf:type rdf:Property ;
    rdfs:label 'Voice Actor Credits' ;
    rdfs:comment 'Comma-separated or structured list of voice actors who performed localized audio dubbing for this language version. Used for credits and rights management.' ;
    rdfs:domain ind:LocalizationVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ageGateRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Age Gate Required Flag' ;
    rdfs:comment 'Indicates whether age verification is required before purchase or download of this SKU.' ;
    rdfs:domain ind:TitleSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ageRatingCode rdf:type rdf:Property ;
    rdfs:label 'Age Rating Code' ;
    rdfs:comment 'Age rating classification code assigned by the regional rating authority (e.g., ESRB: E, T, M; PEGI: 3, 7, 12, 16, 18; CERO: A, B, C, D, Z).' ;
    rdfs:domain ind:TitleSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilityEndDate rdf:type rdf:Property ;
    rdfs:label 'Availability End Date' ;
    rdfs:comment 'Date when this SKU will no longer be available for purchase. Null for indefinite availability.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilityStartDate rdf:type rdf:Property ;
    rdfs:label 'Availability Start Date' ;
    rdfs:comment 'Date when this SKU becomes available for sale, which may differ from the release date for pre-orders or soft launches.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleComponentFlag rdf:type rdf:Property ;
    rdfs:label 'Bundle Component Flag' ;
    rdfs:comment 'Indicates whether this SKU is part of a larger bundle offering and may not be sold separately.' ;
    rdfs:domain ind:TitleSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossBuyEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Buy Eligible Flag' ;
    rdfs:comment 'Indicates whether purchasing this SKU grants access to the same title on other platforms within the same ecosystem (e.g., PS4 to PS5 upgrade).' ;
    rdfs:domain ind:TitleSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distributionChannel rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel' ;
    rdfs:comment 'Primary distribution method for this SKU (digital download, physical media, subscription service, or bundle).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eanCode rdf:type rdf:Property ;
    rdfs:label 'Ean Code' ;
    rdfs:comment '13-digit European Article Number for physical SKU variants, used in international retail distribution.' ;
    rdfs:domain ind:TitleSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusiveFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusive Flag' ;
    rdfs:comment 'Indicates whether this SKU is exclusive to a specific platform, storefront, or region for a defined period.' ;
    rdfs:domain ind:TitleSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fileSizeGb rdf:type rdf:Property ;
    rdfs:label 'File Size Gb' ;
    rdfs:comment 'Total download or installation size of the SKU in gigabytes, applicable to digital distribution.' ;
    rdfs:domain ind:TitleSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageType rdf:type rdf:Property ;
    rdfs:label 'Package Type' ;
    rdfs:comment 'Physical or digital packaging format for this SKU (digital download, disc, cartridge, code-in-box, steelbook, collectors box).' ;
    rdfs:domain ind:TitleSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preOrderEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Pre Order Eligible Flag' ;
    rdfs:comment 'Indicates whether this SKU is available for pre-order before the official release date.' ;
    rdfs:domain ind:TitleSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionalFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Flag' ;
    rdfs:comment 'Indicates whether this SKU is currently part of an active promotional campaign or discount offer.' ;
    rdfs:domain ind:TitleSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:skuDescription rdf:type rdf:Property ;
    rdfs:label 'Sku Description' ;
    rdfs:comment 'Detailed marketing description of the SKU, including features, content, and value proposition for the specific edition and platform.' ;
    rdfs:domain ind:TitleSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuName rdf:type rdf:Property ;
    rdfs:label 'Sku Name' ;
    rdfs:comment 'Human-readable name of the SKU, typically including edition and platform information (e.g., \'Game Title - Deluxe Edition - PS5\').' ;
    rdfs:domain ind:TitleSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuStatus rdf:type rdf:Property ;
    rdfs:label 'Sku Status' ;
    rdfs:comment 'Current lifecycle status of the SKU (planned, pre-release, active, delisted, discontinued, sunset).' ;
    rdfs:domain ind:TitleSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upcCode rdf:type rdf:Property ;
    rdfs:label 'Upc Code' ;
    rdfs:comment '12-digit Universal Product Code for physical SKU variants, used for retail inventory and point-of-sale systems.' ;
    rdfs:domain ind:TitleSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryRightsId rdf:type rdf:Property ;
    rdfs:label 'Territory Rights Id' ;
    rdfs:comment 'Unique identifier for the territory rights record. Primary key.' ;
    rdfs:domain ind:TerritoryRights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelScope rdf:type rdf:Property ;
    rdfs:label 'Channel Scope' ;
    rdfs:comment 'Distribution channel scope covered by these rights: digital (online stores, downloads), physical (retail, disc), or both.' ;
    rdfs:domain ind:TerritoryRights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Contract Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for financial terms associated with these territory rights (e.g., USD, EUR, GBP, JPY).' ;
    rdfs:domain ind:TerritoryRights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstPartyApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'First Party Approval Required' ;
    rdfs:comment 'Indicates whether first-party platform holder approval (e.g., Sony, Microsoft, Nintendo) is required for distribution in this territory (True) or not (False).' ;
    rdfs:domain ind:TerritoryRights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageSupport rdf:type rdf:Property ;
    rdfs:label 'Language Support' ;
    rdfs:comment 'Comma-separated list of language codes (ISO 639-1) supported for this territory (e.g., en, fr, de, es, ja, zh). Used for localization compliance and storefront metadata.' ;
    rdfs:domain ind:TerritoryRights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Notes' ;
    rdfs:comment 'Free-text notes capturing territory-specific regulatory requirements, restrictions, or compliance obligations (e.g., GDPR for EU, COPPA for US, content restrictions, age verification requirements).' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsHolderEntity rdf:type rdf:Property ;
    rdfs:label 'Rights Holder Entity' ;
    rdfs:comment 'Legal entity name that holds the publishing or distribution rights for this title in this territory (e.g., publisher name, subsidiary, partner).' ;
    rdfs:domain ind:TerritoryRights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsType rdf:type rdf:Property ;
    rdfs:label 'Rights Type' ;
    rdfs:comment 'Type of rights granted: publish (full publishing rights), distribute (distribution only), co-publish (shared publishing), sub-license (licensed from another party), exclusive_distribution, non-exclusive_distribution.' ;
    rdfs:domain ind:TerritoryRights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subLicensingPermitted rdf:type rdf:Property ;
    rdfs:label 'Sub Licensing Permitted' ;
    rdfs:comment 'Indicates whether the rights holder is permitted to sub-license these rights to third parties (True) or not (False).' ;
    rdfs:domain ind:TerritoryRights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:territoryRightsStatus rdf:type rdf:Property ;
    rdfs:label 'Territory Rights Status' ;
    rdfs:comment 'Current lifecycle status of the territory rights record: active (in force), pending (awaiting activation), expired (past expiry date), terminated (cancelled before expiry), suspended (temporarily inactive), under_review (being evaluated).' ;
    rdfs:domain ind:TerritoryRights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:titleLifecycleEventId rdf:type rdf:Property ;
    rdfs:label 'Title Lifecycle Event Id' ;
    rdfs:comment 'Unique identifier for the title lifecycle event record. Primary key.' ;
    rdfs:domain ind:TitleLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:announcementUrl rdf:type rdf:Property ;
    rdfs:label 'Announcement Url' ;
    rdfs:comment 'The URL of the public announcement or press release for this lifecycle milestone, if applicable.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverRole rdf:type rdf:Property ;
    rdfs:label 'Approver Role' ;
    rdfs:comment 'The organizational role or title of the approving authority (e.g., Executive Producer, Studio Head, Publishing Director).' ;
    rdfs:domain ind:TitleLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvingAuthority rdf:type rdf:Property ;
    rdfs:label 'Approving Authority' ;
    rdfs:comment 'The name or identifier of the individual, role, or committee that approved or authorized this lifecycle milestone transition.' ;
    rdfs:domain ind:TitleLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataDeletionDate rdf:type rdf:Property ;
    rdfs:label 'Data Deletion Date' ;
    rdfs:comment 'For end-of-life events: the scheduled date on which player data will be permanently deleted from production systems.' ;
    rdfs:domain ind:TitleLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataRetentionPolicy rdf:type rdf:Property ;
    rdfs:label 'Data Retention Policy' ;
    rdfs:comment 'For end-of-life events: description of how player data will be retained, archived, or deleted following service termination.' ;
    rdfs:domain ind:TitleLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'The calendar date on which the lifecycle milestone event occurred.' ;
    rdfs:domain ind:TitleLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventMetadata rdf:type rdf:Property ;
    rdfs:label 'Event Metadata' ;
    rdfs:comment 'Additional structured or semi-structured metadata associated with this lifecycle event, such as key decisions, stakeholder notes, or external dependencies.' ;
    rdfs:domain ind:TitleLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPublicAnnouncement rdf:type rdf:Property ;
    rdfs:label 'Is Public Announcement' ;
    rdfs:comment 'Indicates whether this lifecycle milestone was publicly announced to players, media, or stakeholders.' ;
    rdfs:domain ind:TitleLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:playerNotificationMethod rdf:type rdf:Property ;
    rdfs:label 'Player Notification Method' ;
    rdfs:comment 'For end-of-life, server sunset, or delisting events: the method used to notify players (e.g., in-game message, email, website announcement, social media).' ;
    rdfs:domain ind:TitleLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundPolicy rdf:type rdf:Property ;
    rdfs:label 'Refund Policy' ;
    rdfs:comment 'For end-of-life or delisting events: description of the refund policy offered to players for in-game purchases, subscriptions, or DLC.' ;
    rdfs:domain ind:TitleLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceDays rdf:type rdf:Property ;
    rdfs:label 'Variance Days' ;
    rdfs:comment 'The number of days between the planned date and the actual date. Positive values indicate delays; negative values indicate early completion.' ;
    rdfs:domain ind:TitleLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentRatingAuthority rdf:type rdf:Property ;
    rdfs:label 'Content Rating Authority' ;
    rdfs:comment 'The governing body that issued the content rating for this release.' ;
    rdfs:domain ind:TitleRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlyAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Early Access Flag' ;
    rdfs:comment 'Indicates whether this release is part of an early access program allowing players to access the game before full launch.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:forcedUpdateFlag rdf:type rdf:Property ;
    rdfs:label 'Forced Update Flag' ;
    rdfs:comment 'Indicates whether players are required to update to this release version to continue playing.' ;
    rdfs:domain ind:TitleRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goLiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Go Live Timestamp' ;
    rdfs:comment 'Precise timestamp when the release was made available to players on the storefront.' ;
    rdfs:domain ind:TitleRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:goldMasterFlag rdf:type rdf:Property ;
    rdfs:label 'Gold Master Flag' ;
    rdfs:comment 'Indicates whether this release represents the gold master build approved for manufacturing or final distribution.' ;
    rdfs:domain ind:TitleRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patchSizeMb rdf:type rdf:Property ;
    rdfs:label 'Patch Size Mb' ;
    rdfs:comment 'Size of the release package or patch in megabytes that players must download.' ;
    rdfs:domain ind:TitleRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phasedRolloutFlag rdf:type rdf:Property ;
    rdfs:label 'Phased Rollout Flag' ;
    rdfs:comment 'Indicates whether this release is being deployed in phases to a subset of players before full rollout.' ;
    rdfs:domain ind:TitleRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Pre Order Flag' ;
    rdfs:comment 'Indicates whether this release is available for pre-order before the official launch date.' ;
    rdfs:domain ind:TitleRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releaseNumber rdf:type rdf:Property ;
    rdfs:label 'Release Number' ;
    rdfs:comment 'Business identifier for the release event, typically following semantic versioning or internal release numbering convention.' ;
    rdfs:domain ind:TitleRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Territory Restriction Flag' ;
    rdfs:comment 'Indicates whether this release has geographic or territorial restrictions applied.' ;
    rdfs:domain ind:TitleRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualDurationDays rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Days' ;
    rdfs:comment 'Actual duration of the season in days from start to end. Calculated after season conclusion for retrospective analysis.' ;
    rdfs:domain ind:TitleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:balancePatchVersion rdf:type rdf:Property ;
    rdfs:label 'Balance Patch Version' ;
    rdfs:comment 'Version number of the game balance patch deployed at season launch (e.g., \'2.4.0\', \'3.1.5\'). Used for tracking gameplay changes.' ;
    rdfs:domain ind:TitleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:battlePassIncluded rdf:type rdf:Property ;
    rdfs:label 'Battle Pass Included' ;
    rdfs:comment 'Indicates whether this season includes a battle pass progression system. True if battle pass is available; False if season has no battle pass.' ;
    rdfs:domain ind:TitleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competitiveSeasonFlag rdf:type rdf:Property ;
    rdfs:label 'Competitive Season Flag' ;
    rdfs:comment 'Indicates whether this season includes a competitive ranked mode or esports tournament cycle. True if competitive season is active.' ;
    rdfs:domain ind:TitleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:featuredContentDescription rdf:type rdf:Property ;
    rdfs:label 'Featured Content Description' ;
    rdfs:comment 'Detailed description of the headline content and features introduced in this season. Used for marketing materials and player communications.' ;
    rdfs:domain ind:TitleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freeToPlayContentFlag rdf:type rdf:Property ;
    rdfs:label 'Free To Play Content Flag' ;
    rdfs:comment 'Indicates whether this season includes free content available to all players without purchase. True if free content is included.' ;
    rdfs:domain ind:TitleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaderboardResetFlag rdf:type rdf:Property ;
    rdfs:label 'Leaderboard Reset Flag' ;
    rdfs:comment 'Indicates whether player leaderboards and rankings were reset at the start of this season. True if reset occurred.' ;
    rdfs:domain ind:TitleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:midSeasonUpdateFlag rdf:type rdf:Property ;
    rdfs:label 'Mid Season Update Flag' ;
    rdfs:comment 'Indicates whether a major mid-season content update or refresh was released. True if mid-season update occurred.' ;
    rdfs:domain ind:TitleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:narrativeSummary rdf:type rdf:Property ;
    rdfs:label 'Narrative Summary' ;
    rdfs:comment 'Summary of the story or narrative arc for this season. Used for lore tracking and community engagement.' ;
    rdfs:domain ind:TitleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newCharactersCount rdf:type rdf:Property ;
    rdfs:label 'New Characters Count' ;
    rdfs:comment 'Number of new playable characters, heroes, or operators introduced in this season. Key metric for content-driven games.' ;
    rdfs:domain ind:TitleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:newMapsCount rdf:type rdf:Property ;
    rdfs:label 'New Maps Count' ;
    rdfs:comment 'Number of new maps or levels introduced in this season. Used for content tracking and player communication.' ;
    rdfs:domain ind:TitleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:newModesCount rdf:type rdf:Property ;
    rdfs:label 'New Modes Count' ;
    rdfs:comment 'Number of new game modes introduced in this season (e.g., new PvP modes, limited-time events). Used for content tracking and marketing.' ;
    rdfs:domain ind:TitleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:newWeaponsCount rdf:type rdf:Property ;
    rdfs:label 'New Weapons Count' ;
    rdfs:comment 'Number of new weapons, items, or equipment introduced in this season. Used for balance tracking and content marketing.' ;
    rdfs:domain ind:TitleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passRequired rdf:type rdf:Property ;
    rdfs:label 'Pass Required' ;
    rdfs:comment 'Indicates whether players must own a season pass to access this season\'s content. True if season pass is mandatory; False if content is free or available via other means.' ;
    rdfs:domain ind:TitleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedDurationDays rdf:type rdf:Property ;
    rdfs:label 'Planned Duration Days' ;
    rdfs:comment 'Originally planned duration of the season in days. Used for performance analysis and comparing planned vs actual season length.' ;
    rdfs:domain ind:TitleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preSeasonEventFlag rdf:type rdf:Property ;
    rdfs:label 'Pre Season Event Flag' ;
    rdfs:comment 'Indicates whether a pre-season teaser event or content drop occurred before the official season launch. True if pre-season event was held.' ;
    rdfs:domain ind:TitleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetDau rdf:type rdf:Property ;
    rdfs:label 'Target Dau' ;
    rdfs:comment 'Target daily active user count goal for this season. Used for performance benchmarking and live operations planning.' ;
    rdfs:domain ind:TitleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetRevenueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Target Revenue Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the target revenue amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:TitleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:theme rdf:type rdf:Property ;
    rdfs:label 'Theme' ;
    rdfs:comment 'Narrative or visual theme of the season (e.g., \'Cyberpunk\', \'Medieval Fantasy\', \'Post-Apocalyptic\'). Guides content creation and marketing messaging.' ;
    rdfs:domain ind:TitleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:titleSeasonStatus rdf:type rdf:Property ;
    rdfs:label 'Title Season Status' ;
    rdfs:comment 'Current lifecycle status of the season. Upcoming: not yet launched; Active: currently live; Concluded: ended normally; Cancelled: terminated early; Extended: duration prolonged beyond original end date.' ;
    rdfs:domain ind:TitleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:absenceRecordId rdf:type rdf:Property ;
    rdfs:label 'Absence Record Id' ;
    rdfs:comment 'Unique identifier for the employee absence record. Primary key.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AbsenceRecord .

ind:primaryAbsenceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Absence Employee Id' ;
    rdfs:comment 'Identifier of the employee who took the absence. Links to the employee master record.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:absenceReason rdf:type rdf:Property ;
    rdfs:label 'Absence Reason' ;
    rdfs:comment 'Free-text description of the reason for the absence provided by the employee. May contain sensitive health or personal information. Confidential.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:absenceStatus rdf:type rdf:Property ;
    rdfs:label 'Absence Status' ;
    rdfs:comment 'Current approval and lifecycle status of the absence request: pending (awaiting approval), approved (approved by manager), rejected (denied), cancelled (withdrawn by employee), completed (employee has returned to work).' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:absenceTypeCode rdf:type rdf:Property ;
    rdfs:label 'Absence Type Code' ;
    rdfs:comment 'Type of leave taken: PTO (Paid Time Off), SICK (Sick Leave), PARENTAL (Parental Leave), FMLA (Family and Medical Leave Act), BEREAVEMENT (Bereavement Leave), CRUNCH_RECOVERY (Crunch Recovery Leave for post-release rest periods).' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualBalanceAfter rdf:type rdf:Property ;
    rdfs:label 'Accrual Balance After' ;
    rdfs:comment 'Employee\'s leave accrual balance (in days) after this absence was deducted. Used for leave entitlement tracking.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accrualBalanceBefore rdf:type rdf:Property ;
    rdfs:label 'Accrual Balance Before' ;
    rdfs:comment 'Employee\'s leave accrual balance (in days) before this absence was taken. Used for leave entitlement tracking.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessDaysCount rdf:type rdf:Property ;
    rdfs:label 'Business Days Count' ;
    rdfs:comment 'Number of business days (excluding weekends and holidays) covered by the absence. Used for capacity planning and sprint scheduling.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:impactOnSprint rdf:type rdf:Property ;
    rdfs:label 'Impact On Sprint' ;
    rdfs:comment 'Assessed impact of the absence on sprint delivery: none (no impact), low (minimal impact), medium (moderate impact requiring task reassignment), high (significant impact on sprint goals), critical (sprint goals at risk).' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFmlaQualified rdf:type rdf:Property ;
    rdfs:label 'Is Fmla Qualified' ;
    rdfs:comment 'Indicates whether the absence qualifies under FMLA regulations (True) or not (False). Used for compliance tracking.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPaid rdf:type rdf:Property ;
    rdfs:label 'Is Paid' ;
    rdfs:comment 'Indicates whether the absence is paid leave (True) or unpaid leave (False). Determines payroll impact.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStatutoryLeave rdf:type rdf:Property ;
    rdfs:label 'Is Statutory Leave' ;
    rdfs:comment 'Indicates whether the absence is mandated by statutory law (True) such as parental leave, sick leave, or bereavement leave under local labor laws, or discretionary (False).' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalCertificateReceived rdf:type rdf:Property ;
    rdfs:label 'Medical Certificate Received' ;
    rdfs:comment 'Indicates whether the required medical certificate has been received and verified (True) or not (False). Nullable if not required.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalCertificateRequired rdf:type rdf:Property ;
    rdfs:label 'Medical Certificate Required' ;
    rdfs:comment 'Indicates whether a medical certificate or doctors note is required for this absence (True) or not (False). Typically required for sick leave exceeding a threshold duration.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnToWorkDate rdf:type rdf:Property ;
    rdfs:label 'Return To Work Date' ;
    rdfs:comment 'Actual date the employee returned to work after the absence. Format: yyyy-MM-dd. Nullable if absence is ongoing or employee has not yet returned.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:benefitEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Benefit Enrollment Id' ;
    rdfs:comment 'Unique identifier for the benefit enrollment record. Primary key for the benefit enrollment entity.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benefitPlanId rdf:type rdf:Property ;
    rdfs:label 'Benefit Plan Id' ;
    rdfs:comment 'Unique identifier for the benefit plan being enrolled in. Links to the benefit plan catalog.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BenefitPlan .

ind:annualElectionAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Election Amount' ;
    rdfs:comment 'Total annual dollar amount elected by employee for benefits with annual limits such as Flexible Spending Accounts (FSA) or Health Savings Accounts (HSA). Represents annual contribution cap elected.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beneficiaryDesignation rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Designation' ;
    rdfs:comment 'Name or identifier of designated beneficiary for benefits with death benefit provisions such as life insurance or retirement accounts. Confidential employee election.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryRelationship rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Relationship' ;
    rdfs:comment 'Relationship of the designated beneficiary to the employee. Used for life insurance, retirement accounts, and other benefits with beneficiary designations. [ENUM-REF-CANDIDATE: spouse|child|parent|sibling|domestic_partner|other|estate — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cobraEligibleIndicator rdf:type rdf:Property ;
    rdfs:label 'Cobra Eligible Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this enrollment is eligible for COBRA continuation coverage upon termination of employment. True if eligible for continuation, false otherwise.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cobraEndDate rdf:type rdf:Property ;
    rdfs:label 'Cobra End Date' ;
    rdfs:comment 'Date when COBRA continuation coverage ends. Typically 18 or 36 months after qualifying event depending on circumstances. Null if COBRA is ongoing or not applicable.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cobraStartDate rdf:type rdf:Property ;
    rdfs:label 'Cobra Start Date' ;
    rdfs:comment 'Date when COBRA continuation coverage begins following a qualifying event such as employment termination. Null if COBRA has not been elected or is not applicable.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contributionElectionPercentage rdf:type rdf:Property ;
    rdfs:label 'Contribution Election Percentage' ;
    rdfs:comment 'Percentage of salary the employee elects to contribute to retirement or savings plans such as 401k or stock purchase plans. Null for non-contributory benefits.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contributionFrequency rdf:type rdf:Property ;
    rdfs:label 'Contribution Frequency' ;
    rdfs:comment 'Frequency at which benefit contributions are deducted from employee payroll and remitted to benefit provider. Aligns with payroll cycle.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageTier rdf:type rdf:Property ;
    rdfs:label 'Coverage Tier' ;
    rdfs:comment 'Level of coverage elected indicating who is covered under the benefit plan: employee only, employee plus spouse, employee plus children, or full family coverage.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependentCount rdf:type rdf:Property ;
    rdfs:label 'Dependent Count' ;
    rdfs:comment 'Number of dependents covered under this benefit enrollment. Zero for employee-only coverage, one or more for family coverage tiers.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:employeeContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employee Contribution Amount' ;
    rdfs:comment 'Dollar amount the employee contributes per pay period toward the benefit premium or cost. Represents employee share of benefit cost deducted from payroll.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employer Contribution Amount' ;
    rdfs:comment 'Dollar amount the employer contributes per pay period toward the benefit premium or cost. Represents employer subsidy or match for the benefit.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerMatchPercentage rdf:type rdf:Property ;
    rdfs:label 'Employer Match Percentage' ;
    rdfs:comment 'Percentage of employee contribution that the employer matches for retirement or savings plans. Represents employer matching formula for 401k or similar plans.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Effective Date' ;
    rdfs:comment 'Date when the benefit coverage begins and becomes active for the employee. Critical for determining coverage periods and premium calculations.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment End Date' ;
    rdfs:comment 'Date when the benefit coverage ends or is scheduled to end. Null for ongoing active enrollments. Populated upon termination, cancellation, or plan year end.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Number' ;
    rdfs:comment 'Business-facing unique enrollment confirmation number provided to employee for reference and tracking.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentPeriodType rdf:type rdf:Property ;
    rdfs:label 'Enrollment Period Type' ;
    rdfs:comment 'Type of enrollment period during which the election was made. Open enrollment is annual election window, new hire is initial enrollment upon joining, qualifying life event allows mid-year changes due to marriage/birth/etc, special enrollment covers other permitted election windows.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentSource rdf:type rdf:Property ;
    rdfs:label 'Enrollment Source' ;
    rdfs:comment 'Channel or method through which the benefit enrollment was submitted. Tracks whether employee self-enrolled via portal, HR entered on behalf, paper form was processed, or automatic enrollment occurred.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupNumber rdf:type rdf:Property ;
    rdfs:label 'Group Number' ;
    rdfs:comment 'Group policy number identifying the employer group under which this benefit is provided. Used by carriers to identify the employer plan sponsor.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planYearEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan Year End Date' ;
    rdfs:comment 'End date of the benefit plan year for this enrollment. Marks the conclusion of the annual benefit period and triggers renewal or re-enrollment processes.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planYearStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Year Start Date' ;
    rdfs:comment 'Start date of the benefit plan year for this enrollment. Defines the annual period for benefit coverage, contribution limits, and renewal cycles.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:policyNumber rdf:type rdf:Property ;
    rdfs:label 'Policy Number' ;
    rdfs:comment 'Insurance policy or contract number assigned by the carrier for this benefit enrollment. Used for claims processing and carrier coordination.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifyingEventDate rdf:type rdf:Property ;
    rdfs:label 'Qualifying Event Date' ;
    rdfs:comment 'Date when the qualifying life event occurred that permitted the enrollment or change. Used to validate eligibility for special enrollment period and determine coverage effective date rules.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualifyingEventType rdf:type rdf:Property ;
    rdfs:label 'Qualifying Event Type' ;
    rdfs:comment 'Type of qualifying life event that triggered a special enrollment period allowing mid-year benefit changes. Null or none if enrollment occurred during standard open enrollment or new hire period. [ENUM-REF-CANDIDATE: marriage|divorce|birth|adoption|death|employment_change|loss_of_coverage|none — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Total Premium Amount' ;
    rdfs:comment 'Total benefit premium or cost per pay period, combining both employee and employer contributions. Represents full cost of coverage.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vestingSchedule rdf:type rdf:Property ;
    rdfs:label 'Vesting Schedule' ;
    rdfs:comment 'Vesting schedule applied to employer contributions for retirement plans. Defines when employee gains ownership of employer-contributed funds. Immediate means fully vested, cliff means vesting occurs at specific year, graded means incremental vesting over years. [ENUM-REF-CANDIDATE: immediate|cliff_1yr|cliff_2yr|cliff_3yr|graded_3yr|graded_5yr|graded_6yr — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverIndicator rdf:type rdf:Property ;
    rdfs:label 'Waiver Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the employee actively waived or declined this benefit plan. True if waived, false if enrolled. Used to track voluntary declinations for compliance and reporting.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:candidateId rdf:type rdf:Property ;
    rdfs:label 'Candidate Id' ;
    rdfs:comment 'Unique identifier for the candidate record. Primary key for the candidate entity.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicationId rdf:type rdf:Property ;
    rdfs:label 'Application Id' ;
    rdfs:comment 'External application identifier assigned when candidate submits application. Business-facing reference number used in candidate communications and ATS tracking.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Application .

ind:candidateHiringManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Candidate Hiring Manager Employee Id' ;
    rdfs:comment 'Employee ID of the hiring manager for the target role. Used for interview coordination and hiring decision tracking.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:candidateRecruiterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Candidate Recruiter Employee Id' ;
    rdfs:comment 'Employee ID of the recruiter or talent acquisition specialist managing this candidate. Used for workload balancing and recruiter performance metrics.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:candidateReferrerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Candidate Referrer Employee Id' ;
    rdfs:comment 'Employee ID of the internal employee who referred this candidate. Used for employee referral bonus tracking and referral program effectiveness analysis. Null if candidate was not referred by an employee.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:recruitmentRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Recruitment Requisition Id' ;
    rdfs:comment 'Foreign key linking to workforce.recruitment_requisition. Business justification: Candidate applies to a specific recruitment requisition. This is the core relationship in the hiring pipeline. No columns removed as candidate has application-specific fields (application_date, applic' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecruitmentRequisition .

ind:applicationDate rdf:type rdf:Property ;
    rdfs:label 'Application Date' ;
    rdfs:comment 'Date when the candidate submitted their application. Used for time-to-hire metrics and recruitment funnel analysis.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicationStatus rdf:type rdf:Property ;
    rdfs:label 'Application Status' ;
    rdfs:comment 'Current stage of the candidate in the recruitment pipeline. Tracks progression from initial application through final hiring decision or rejection. [ENUM-REF-CANDIDATE: applied|screened|interviewed|offered|hired|rejected|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backgroundCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Background Check Status' ;
    rdfs:comment 'Status of pre-employment background check process. Required for compliance with industry security standards and child safety regulations (COPPA). Confidential screening data.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentEmployer rdf:type rdf:Property ;
    rdfs:label 'Current Employer' ;
    rdfs:comment 'Name of candidate\'s current employer. Used for conflict of interest checks and competitive intelligence. Confidential to protect candidate privacy during active employment.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentJobTitle rdf:type rdf:Property ;
    rdfs:label 'Current Job Title' ;
    rdfs:comment 'Candidate\'s current job title or most recent role. Used for seniority assessment and role mapping to internal job architecture.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discipline rdf:type rdf:Property ;
    rdfs:label 'Discipline' ;
    rdfs:comment 'Primary functional discipline or role category the candidate is applying for (e.g., Game Designer, Software Engineer, 3D Artist, Producer, QA Tester, Esports Coach, Community Manager). Aligns with studio skill matrices and workforce planning categories.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earliestStartDate rdf:type rdf:Property ;
    rdfs:label 'Earliest Start Date' ;
    rdfs:comment 'Earliest date the candidate can begin employment. Critical for sprint planning and project milestone staffing.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedSalaryAmount rdf:type rdf:Property ;
    rdfs:label 'Expected Salary Amount' ;
    rdfs:comment 'Candidate\'s expected annual salary or compensation. Used for budget alignment and offer preparation. Confidential financial information.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedSalaryCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Expected Salary Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for expected salary. Supports international recruitment and multi-currency compensation planning.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Legal first name of the candidate as provided in application. Used for formal communications and background checks.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentDate rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Date' ;
    rdfs:comment 'Date when GDPR consent was obtained from the candidate. Used for consent expiration tracking and data retention policy enforcement.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interviewCount rdf:type rdf:Property ;
    rdfs:label 'Interview Count' ;
    rdfs:comment 'Total number of interviews conducted with this candidate. Used for recruitment process efficiency analysis and candidate experience optimization.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isRemoteEligible rdf:type rdf:Property ;
    rdfs:label 'Is Remote Eligible' ;
    rdfs:comment 'Indicates whether the candidate is eligible and willing to work remotely. Supports distributed team planning and remote-first studio operations.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastInterviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Interview Date' ;
    rdfs:comment 'Date of the most recent interview with this candidate. Used for follow-up scheduling and recruitment velocity tracking.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Legal last name of the candidate as provided in application. Used for formal communications and background checks.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationCity rdf:type rdf:Property ;
    rdfs:label 'Location City' ;
    rdfs:comment 'City where the candidate currently resides. Used for relocation planning and remote work eligibility assessment.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Location Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for candidate\'s current location. Used for work authorization and visa requirement assessment.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerAcceptedDate rdf:type rdf:Property ;
    rdfs:label 'Offer Accepted Date' ;
    rdfs:comment 'Date when candidate accepted the employment offer. Triggers onboarding workflow and marks successful recruitment completion.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerExtendedDate rdf:type rdf:Property ;
    rdfs:label 'Offer Extended Date' ;
    rdfs:comment 'Date when employment offer was extended to the candidate. Used for offer acceptance rate analysis and time-to-hire metrics.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overallRating rdf:type rdf:Property ;
    rdfs:label 'Overall Rating' ;
    rdfs:comment 'Aggregate rating score from all interviewers, typically on a scale of 1.00 to 5.00. Used for candidate ranking and hiring decision support. Confidential evaluation data.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary contact phone number for candidate. Used for interview coordination and urgent recruitment communications.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioUrl rdf:type rdf:Property ;
    rdfs:label 'Portfolio Url' ;
    rdfs:comment 'Web link to candidate\'s professional portfolio, demo reel, GitHub repository, ArtStation profile, or other work samples. Critical for evaluating creative and technical talent in game development roles.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredGameEngine rdf:type rdf:Property ;
    rdfs:label 'Preferred Game Engine' ;
    rdfs:comment 'Game engine the candidate has primary expertise in. Critical for matching candidates to studio technology stacks and project requirements.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySkill rdf:type rdf:Property ;
    rdfs:label 'Primary Skill' ;
    rdfs:comment 'Candidate\'s primary technical or creative skill (e.g., Unity, Unreal Engine, C++, Character Animation, Level Design, Live Ops Management). Used for skill gap analysis and team composition planning.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresVisaSponsorship rdf:type rdf:Property ;
    rdfs:label 'Requires Visa Sponsorship' ;
    rdfs:comment 'Indicates whether the candidate requires work visa sponsorship for the target role location. Critical for immigration planning and hiring timeline estimation.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:secondarySkills rdf:type rdf:Property ;
    rdfs:label 'Secondary Skills' ;
    rdfs:comment 'Comma-separated list of additional skills and competencies. Supports cross-functional team placement and multi-disciplinary project staffing.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceChannel rdf:type rdf:Property ;
    rdfs:label 'Source Channel' ;
    rdfs:comment 'Channel through which the candidate was sourced. Tracks recruitment marketing effectiveness and talent pipeline origins. Esports talent pipeline represents candidates identified through competitive gaming and esports community engagement. [ENUM-REF-CANDIDATE: referral|job_board|campus|esports_talent_pipeline|linkedin|career_site|recruiter_outreach — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearsOfExperience rdf:type rdf:Property ;
    rdfs:label 'Years Of Experience' ;
    rdfs:comment 'Total years of relevant professional experience in the gaming industry or related fields. Used for seniority assessment and compensation benchmarking.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationId rdf:type rdf:Property ;
    rdfs:label 'Compensation Id' ;
    rdfs:comment 'Unique identifier for the compensation record. Primary key for the compensation data product.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Compensation .

ind:compensationApprovedByManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Compensation Approved By Manager Employee Id' ;
    rdfs:comment 'Employee ID of the manager who approved this compensation change. Links to employee master data for approval audit trail.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:compensationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Compensation Employee Id' ;
    rdfs:comment 'Unique identifier for the employee receiving this compensation. Links to the employee master data in the workforce domain.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:previousCompensationId rdf:type rdf:Property ;
    rdfs:label 'Previous Compensation Id' ;
    rdfs:comment 'Reference to the prior compensation record for this employee. Creates a historical chain of compensation changes for audit and analysis. Null for initial compensation record.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Compensation .

ind:allowanceAmount rdf:type rdf:Property ;
    rdfs:label 'Allowance Amount' ;
    rdfs:comment 'Total amount of additional allowances (housing, transportation, relocation, etc.) included in this compensation record. Business-confidential financial data.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allowanceType rdf:type rdf:Property ;
    rdfs:label 'Allowance Type' ;
    rdfs:comment 'Category of allowance provided to the employee. Distinguishes between housing, transportation, relocation, remote work stipends, and education allowances.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseSalaryAmount rdf:type rdf:Property ;
    rdfs:label 'Base Salary Amount' ;
    rdfs:comment 'Annual base salary amount for the employee. Excludes bonuses, equity, and other variable compensation. Business-confidential financial data.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusTargetAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Target Amount' ;
    rdfs:comment 'Target annual bonus amount for the employee based on performance objectives and company performance. Actual bonus may vary. Business-confidential financial data.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Bonus Target Percentage' ;
    rdfs:comment 'Target bonus expressed as a percentage of base salary. Used for calculating variable compensation eligibility. Business-confidential classification data.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeReason rdf:type rdf:Property ;
    rdfs:label 'Change Reason' ;
    rdfs:comment 'Business reason for this compensation change. Distinguishes between new hires, promotions, merit increases, market adjustments, cost-of-living adjustments, retention actions, demotions, and transfers. [ENUM-REF-CANDIDATE: new_hire|promotion|merit_increase|market_adjustment|cost_of_living|retention|demotion|transfer — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Percentage' ;
    rdfs:comment 'Commission rate as a percentage of sales or revenue for commission-eligible roles. Used to calculate variable compensation for sales and business development roles. Business-confidential classification data.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationType rdf:type rdf:Property ;
    rdfs:label 'Compensation Type' ;
    rdfs:comment 'Category of compensation payment. Distinguishes between base salary, performance bonus, equity grants, commissions, allowances, and overtime pay.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equityGrantQuantity rdf:type rdf:Property ;
    rdfs:label 'Equity Grant Quantity' ;
    rdfs:comment 'Number of equity units (stock options, RSUs, or shares) granted to the employee. Business-confidential financial data.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equityGrantType rdf:type rdf:Property ;
    rdfs:label 'Equity Grant Type' ;
    rdfs:comment 'Type of equity compensation granted. Includes stock options, Restricted Stock Units (RSUs), restricted stock, or performance shares. Business-confidential classification data.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equityVestingSchedule rdf:type rdf:Property ;
    rdfs:label 'Equity Vesting Schedule' ;
    rdfs:comment 'Vesting schedule for equity grants describing when equity becomes exercisable or transferable (e.g., 4-year vest with 1-year cliff, monthly vesting). Business-confidential terms.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'Job title or position associated with this compensation record at the time of the compensation event. Captures title for historical compensation analysis.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketBenchmarkPercentile rdf:type rdf:Property ;
    rdfs:label 'Market Benchmark Percentile' ;
    rdfs:comment 'Percentile position of this compensation relative to market benchmark data for the role and geography. Used for competitive compensation analysis. Business-confidential analytical data.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Overtime Eligible Flag' ;
    rdfs:comment 'Indicates whether the employee is eligible for overtime pay under labor regulations and company policy. True for non-exempt employees, false for exempt employees.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payEquityBand rdf:type rdf:Property ;
    rdfs:label 'Pay Equity Band' ;
    rdfs:comment 'Pay equity band or range assigned for pay equity analysis and compliance reporting. Used to ensure fair compensation practices across demographics. Business-confidential classification data.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payFrequency rdf:type rdf:Property ;
    rdfs:label 'Pay Frequency' ;
    rdfs:comment 'Frequency at which the employee receives compensation payments. Determines payroll cycle and payment schedule.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payGrade rdf:type rdf:Property ;
    rdfs:label 'Pay Grade' ;
    rdfs:comment 'Organizational pay grade or band assigned to this compensation record. Determines salary range and eligibility for benefits. Business-confidential classification data.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycle rdf:type rdf:Property ;
    rdfs:label 'Review Cycle' ;
    rdfs:comment 'Type of review cycle that triggered this compensation record. Distinguishes between regular annual reviews, promotions, market adjustments, and ad-hoc changes.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCompensationAmount rdf:type rdf:Property ;
    rdfs:label 'Total Compensation Amount' ;
    rdfs:comment 'Total annual compensation including base salary, target bonus, equity grant value, and allowances. Represents the full compensation package value. Business-confidential financial data.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractorId rdf:type rdf:Property ;
    rdfs:label 'Contractor Id' ;
    rdfs:comment 'Unique identifier for the contractor record. Primary key.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contractor .

ind:jobProfileId rdf:type rdf:Property ;
    rdfs:label 'Job Profile Id' ;
    rdfs:comment 'Foreign key linking to workforce.job_profile. Business justification: Contractor engagement is based on a job profile defining the role requirements and competencies. Skill_specialization on contractor is kept as it may be more specific than job_profile technical_skills' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobProfile .

ind:managerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Manager Employee Id' ;
    rdfs:comment 'Identifier of the full-time employee who serves as the contractor\'s direct manager or project lead.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:positionId rdf:type rdf:Property ;
    rdfs:label 'Position Id' ;
    rdfs:comment 'Foreign key linking to workforce.position. Business justification: Contractor can fill an authorized position when position.is_contractor_eligible = true. This links the contractor engagement to the formal headcount position they are filling. FK will be nullable (not' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:benefitsEligible rdf:type rdf:Property ;
    rdfs:label 'Benefits Eligible' ;
    rdfs:comment 'Indicates whether the contractor is eligible for any company benefits. Typically false for contractors, distinguishing them from employees.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clearanceLevel rdf:type rdf:Property ;
    rdfs:label 'Clearance Level' ;
    rdfs:comment 'Security clearance level granted to the contractor for access to confidential game development assets, source code, and unreleased content.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractValue rdf:type rdf:Property ;
    rdfs:label 'Contract Value' ;
    rdfs:comment 'Total monetary value of the contractor engagement for fixed-price or capped contracts.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractingAgencyName rdf:type rdf:Property ;
    rdfs:label 'Contracting Agency Name' ;
    rdfs:comment 'Name of the staffing agency or contracting firm providing the contractor, if applicable. Null for direct freelancers.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractorNumber rdf:type rdf:Property ;
    rdfs:label 'Contractor Number' ;
    rdfs:comment 'Business identifier for the contractor, typically assigned by HR or procurement systems. Format: CTR-########.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractorStatus rdf:type rdf:Property ;
    rdfs:label 'Contractor Status' ;
    rdfs:comment 'Current lifecycle status of the contractor engagement. Active contractors have system access and can be assigned to projects.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailyRate rdf:type rdf:Property ;
    rdfs:label 'Daily Rate' ;
    rdfs:comment 'Daily billing rate for the contractor in the contract currency. Used for day-rate engagements.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentIssued rdf:type rdf:Property ;
    rdfs:label 'Equipment Issued' ;
    rdfs:comment 'Indicates whether company equipment (laptop, development kit, peripherals) has been issued to the contractor.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'Full legal name of the contractor as it appears on contracts and tax documents.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hourlyRate rdf:type rdf:Property ;
    rdfs:label 'Hourly Rate' ;
    rdfs:comment 'Hourly billing rate for the contractor in the contract currency. Used for time-and-materials engagements.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onboardingCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Completed Date' ;
    rdfs:comment 'Date when the contractor completed all onboarding requirements including training, compliance certifications, and system access setup.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rehireEligible rdf:type rdf:Property ;
    rdfs:label 'Rehire Eligible' ;
    rdfs:comment 'Indicates whether the contractor is eligible for future re-engagement based on past performance and conduct.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remoteWorkLocation rdf:type rdf:Property ;
    rdfs:label 'Remote Work Location' ;
    rdfs:comment 'Geographic location from which the contractor performs work, if remote. Used for tax nexus and compliance tracking.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillSpecialization rdf:type rdf:Property ;
    rdfs:label 'Skill Specialization' ;
    rdfs:comment 'Primary skill area or discipline for which the contractor was engaged (e.g., 3D Artist, QA Tester, Level Designer, Gameplay Programmer, Audio Engineer, Localization Specialist).' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementOfWorkReference rdf:type rdf:Property ;
    rdfs:label 'Statement Of Work Reference' ;
    rdfs:comment 'Reference number or identifier for the statement of work document governing this contractor engagement.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemAccessProvisioned rdf:type rdf:Property ;
    rdfs:label 'System Access Provisioned' ;
    rdfs:comment 'Indicates whether the contractor has been granted access to required development systems, tools, and platforms (Perforce, Jira, game engines, SDKs).' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxClassification rdf:type rdf:Property ;
    rdfs:label 'Tax Classification' ;
    rdfs:comment 'Tax treatment classification for the contractor determining withholding and reporting obligations.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Id Number' ;
    rdfs:comment 'Tax identification number for the contractor (SSN, EIN, VAT number, or equivalent based on jurisdiction).' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeTrackingRequired rdf:type rdf:Property ;
    rdfs:label 'Time Tracking Required' ;
    rdfs:comment 'Indicates whether the contractor must submit timesheets for billing and project cost tracking purposes.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workCountryCode rdf:type rdf:Property ;
    rdfs:label 'Work Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code where the contractor performs work. Determines labor law compliance requirements.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disciplinaryCaseId rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Case Id' ;
    rdfs:comment 'Unique identifier for the disciplinary case record. Primary key.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDisciplinaryEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Disciplinary Employee Id' ;
    rdfs:comment 'Identifier of the employee who is the subject of the disciplinary case.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryDisciplinaryInvestigatingOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Disciplinary Investigating Officer Employee Id' ;
    rdfs:comment 'Identifier of the HR or legal professional conducting the formal investigation of the case.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quinaryDisciplinaryManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quinary Disciplinary Manager Employee Id' ;
    rdfs:comment 'Identifier of the direct manager of the employee subject to disciplinary action at the time of the incident.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryDisciplinaryHrBusinessPartnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Disciplinary Hr Business Partner Employee Id' ;
    rdfs:comment 'Identifier of the HR business partner assigned to manage and oversee this disciplinary case.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:appealFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Flag' ;
    rdfs:comment 'Indicates whether the employee filed a formal appeal of the disciplinary outcome. True if appeal was filed.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:caseStatus rdf:type rdf:Property ;
    rdfs:label 'Case Status' ;
    rdfs:comment 'Current lifecycle status of the disciplinary case in the HR workflow.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseSummary rdf:type rdf:Property ;
    rdfs:label 'Case Summary' ;
    rdfs:comment 'Detailed narrative summary of the disciplinary case including facts, context, and circumstances surrounding the incident.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseType rdf:type rdf:Property ;
    rdfs:label 'Case Type' ;
    rdfs:comment 'Classification of the disciplinary case indicating the nature of the issue being addressed.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date when the disciplinary case was formally closed in the HR system after all follow-up actions completed.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'Classification of the confidentiality requirements for this case determining access controls and disclosure restrictions.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionPlan rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan' ;
    rdfs:comment 'Detailed plan outlining specific corrective actions, performance improvement steps, or behavioral expectations required of the employee.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eeocReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Eeoc Reportable Flag' ;
    rdfs:comment 'Indicates whether this case must be reported to EEOC for compliance with federal employment discrimination reporting requirements. True if reportable.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Date' ;
    rdfs:comment 'Scheduled date for follow-up review or check-in to assess compliance with corrective action plan or monitor behavior.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incidentDate rdf:type rdf:Property ;
    rdfs:label 'Incident Date' ;
    rdfs:comment 'Date when the underlying incident or behavior that triggered the disciplinary case occurred.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationNotes rdf:type rdf:Property ;
    rdfs:label 'Investigation Notes' ;
    rdfs:comment 'Confidential notes and findings from the investigation process. Restricted access for HR and legal personnel only.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalHoldDate rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Date' ;
    rdfs:comment 'Date when the legal hold was placed on this case record. Null if no legal hold is active.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Flag' ;
    rdfs:comment 'Indicates whether this case is subject to legal hold for litigation, regulatory investigation, or legal proceedings. True if under legal hold.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openDate rdf:type rdf:Property ;
    rdfs:label 'Open Date' ;
    rdfs:comment 'Date when the disciplinary case was officially opened and entered into the HR system.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'Final outcome or disciplinary action taken as a result of the case resolution. [ENUM-REF-CANDIDATE: no_action|verbal_warning|written_warning|final_warning|suspension|demotion|termination|performance_improvement_plan|training_required — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeDescription rdf:type rdf:Property ;
    rdfs:label 'Outcome Description' ;
    rdfs:comment 'Detailed explanation of the outcome, including specific actions taken, conditions imposed, or remediation steps required.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyViolated rdf:type rdf:Property ;
    rdfs:label 'Policy Violated' ;
    rdfs:comment 'Reference to the specific company policy, code of conduct section, or workplace rule that was violated.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorCaseCount rdf:type rdf:Property ;
    rdfs:label 'Prior Case Count' ;
    rdfs:comment 'Number of prior disciplinary cases on record for this employee at the time this case was opened. Used for progressive discipline assessment.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:witnessEmployeeIds rdf:type rdf:Property ;
    rdfs:label 'Witness Employee Ids' ;
    rdfs:comment 'Comma-separated list of employee identifiers who witnessed the incident or provided testimony. Confidential for witness protection.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualSalary rdf:type rdf:Property ;
    rdfs:label 'Annual Salary' ;
    rdfs:comment 'Base annual salary for the employee in local currency. Used for payroll processing, compensation analysis, and budget planning. Excludes bonuses and equity.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationGrade rdf:type rdf:Property ;
    rdfs:label 'Compensation Grade' ;
    rdfs:comment 'Internal compensation band or grade level assigned to the employee. Used for salary benchmarking, promotion planning, and pay equity analysis.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'Organizational department to which the employee belongs (e.g., Game Development, Live Operations, Platform Engineering, Player Support). Used for cost center allocation and organizational reporting.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactName rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Name' ;
    rdfs:comment 'Full name of the employee\'s designated emergency contact person. Used for critical incident response and employee safety protocols.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Phone' ;
    rdfs:comment 'Phone number of the employee\'s designated emergency contact. Used for critical incident response and employee safety protocols.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentStatus rdf:type rdf:Property ;
    rdfs:label 'Employment Status' ;
    rdfs:comment 'Current lifecycle status of the employee within the organization. Determines access rights, payroll processing, and benefits eligibility.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentType rdf:type rdf:Property ;
    rdfs:label 'Employment Type' ;
    rdfs:comment 'Classification of employment arrangement. Determines benefits eligibility, work hour expectations, and compensation structure. Supports studio capacity planning for game development production scheduling.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'Date the employee officially started employment with the organization. Used for tenure calculations, benefits vesting, anniversary recognition, and retention analytics.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:igdaMember rdf:type rdf:Property ;
    rdfs:label 'Igda Member' ;
    rdfs:comment 'Indicates whether the employee is a member of the International Game Developers Association. Used for professional development tracking and industry engagement metrics.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nationalIdNumber rdf:type rdf:Property ;
    rdfs:label 'National Id Number' ;
    rdfs:comment 'Government-issued national identification number (e.g., Social Security Number in USA, National Insurance Number in UK). Used for tax reporting, payroll processing, and legal compliance.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeLocation rdf:type rdf:Property ;
    rdfs:label 'Office Location' ;
    rdfs:comment 'Physical office or campus location where the employee is based (e.g., Seattle HQ, Tokyo Studio, London Office). Used for facilities management, travel planning, and regional workforce analytics.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workLocation rdf:type rdf:Property ;
    rdfs:label 'Work Location' ;
    rdfs:comment 'Primary work arrangement indicating where the employee performs their duties. Used for facilities planning, collaboration tool provisioning, and workforce distribution analytics.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPermitExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Work Permit Expiry Date' ;
    rdfs:comment 'Expiration date of the employee\'s work permit or visa. Null for citizens and permanent residents. Used for proactive renewal management and compliance risk mitigation.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workPermitStatus rdf:type rdf:Property ;
    rdfs:label 'Work Permit Status' ;
    rdfs:comment 'Legal work authorization status for the employee in their work location country. Used for compliance tracking, visa renewal management, and international mobility planning.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountPlanId rdf:type rdf:Property ;
    rdfs:label 'Headcount Plan Id' ;
    rdfs:comment 'Unique identifier for the headcount plan record. Primary key for workforce capacity planning entries.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedFteArt rdf:type rdf:Property ;
    rdfs:label 'Approved Fte Art' ;
    rdfs:comment 'Approved headcount target for art discipline expressed in Full-Time Equivalent (FTE) units. Includes concept artists, 3D modelers, animators, VFX artists, and UI/UX designers.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedFteDesign rdf:type rdf:Property ;
    rdfs:label 'Approved Fte Design' ;
    rdfs:comment 'Approved headcount target for design discipline expressed in Full-Time Equivalent (FTE) units. Includes game designers, level designers, systems designers, narrative designers, and economy designers.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedFteEngineering rdf:type rdf:Property ;
    rdfs:label 'Approved Fte Engineering' ;
    rdfs:comment 'Approved headcount target for engineering discipline expressed in Full-Time Equivalent (FTE) units. Includes software engineers, technical artists, engine programmers, and technical designers.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedFteOther rdf:type rdf:Property ;
    rdfs:label 'Approved Fte Other' ;
    rdfs:comment 'Approved headcount target for other disciplines not categorized above (e.g., audio, localization, analytics, DevOps, IT support) expressed in Full-Time Equivalent (FTE) units.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedFteProduction rdf:type rdf:Property ;
    rdfs:label 'Approved Fte Production' ;
    rdfs:comment 'Approved headcount target for production discipline expressed in Full-Time Equivalent (FTE) units. Includes producers, project managers, scrum masters, and program managers.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedFteQa rdf:type rdf:Property ;
    rdfs:label 'Approved Fte Qa' ;
    rdfs:comment 'Approved headcount target for Quality Assurance (QA) discipline expressed in Full-Time Equivalent (FTE) units. Includes QA testers, automation engineers, and compliance testers.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedFteTotal rdf:type rdf:Property ;
    rdfs:label 'Approved Fte Total' ;
    rdfs:comment 'Total approved headcount target across all disciplines expressed in Full-Time Equivalent (FTE) units. Sum of all discipline-specific FTE targets.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityGapFte rdf:type rdf:Property ;
    rdfs:label 'Capacity Gap Fte' ;
    rdfs:comment 'The difference between approved FTE total and current filled FTE total. Positive values indicate unfilled capacity; negative values indicate over-staffing relative to plan.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractorFteActual rdf:type rdf:Property ;
    rdfs:label 'Contractor Fte Actual' ;
    rdfs:comment 'Current actual contractor and temporary workforce expressed in Full-Time Equivalent (FTE) units. Reflects engaged contractors as of the snapshot date.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractorFteBudget rdf:type rdf:Property ;
    rdfs:label 'Contractor Fte Budget' ;
    rdfs:comment 'Approved budget allocation for contractor and temporary workforce expressed in Full-Time Equivalent (FTE) units. Supports flexible capacity planning for project peaks and specialized skills.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentFilledFteArt rdf:type rdf:Property ;
    rdfs:label 'Current Filled Fte Art' ;
    rdfs:comment 'Current actual headcount for art discipline expressed in Full-Time Equivalent (FTE) units. Reflects filled positions as of the snapshot date.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentFilledFteDesign rdf:type rdf:Property ;
    rdfs:label 'Current Filled Fte Design' ;
    rdfs:comment 'Current actual headcount for design discipline expressed in Full-Time Equivalent (FTE) units. Reflects filled positions as of the snapshot date.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentFilledFteEngineering rdf:type rdf:Property ;
    rdfs:label 'Current Filled Fte Engineering' ;
    rdfs:comment 'Current actual headcount for engineering discipline expressed in Full-Time Equivalent (FTE) units. Reflects filled positions as of the snapshot date.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentFilledFteOther rdf:type rdf:Property ;
    rdfs:label 'Current Filled Fte Other' ;
    rdfs:comment 'Current actual headcount for other disciplines expressed in Full-Time Equivalent (FTE) units. Reflects filled positions as of the snapshot date.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentFilledFteProduction rdf:type rdf:Property ;
    rdfs:label 'Current Filled Fte Production' ;
    rdfs:comment 'Current actual headcount for production discipline expressed in Full-Time Equivalent (FTE) units. Reflects filled positions as of the snapshot date.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentFilledFteQa rdf:type rdf:Property ;
    rdfs:label 'Current Filled Fte Qa' ;
    rdfs:comment 'Current actual headcount for Quality Assurance (QA) discipline expressed in Full-Time Equivalent (FTE) units. Reflects filled positions as of the snapshot date.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentFilledFteTotal rdf:type rdf:Property ;
    rdfs:label 'Current Filled Fte Total' ;
    rdfs:comment 'Total current actual headcount across all disciplines expressed in Full-Time Equivalent (FTE) units. Sum of all discipline-specific filled FTE counts.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openRequisitionCountArt rdf:type rdf:Property ;
    rdfs:label 'Open Requisition Count Art' ;
    rdfs:comment 'Number of open job requisitions for art discipline. Represents active hiring demand.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openRequisitionCountDesign rdf:type rdf:Property ;
    rdfs:label 'Open Requisition Count Design' ;
    rdfs:comment 'Number of open job requisitions for design discipline. Represents active hiring demand.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openRequisitionCountEngineering rdf:type rdf:Property ;
    rdfs:label 'Open Requisition Count Engineering' ;
    rdfs:comment 'Number of open job requisitions for engineering discipline. Represents active hiring demand.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openRequisitionCountOther rdf:type rdf:Property ;
    rdfs:label 'Open Requisition Count Other' ;
    rdfs:comment 'Number of open job requisitions for other disciplines. Represents active hiring demand.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openRequisitionCountProduction rdf:type rdf:Property ;
    rdfs:label 'Open Requisition Count Production' ;
    rdfs:comment 'Number of open job requisitions for production discipline. Represents active hiring demand.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openRequisitionCountQa rdf:type rdf:Property ;
    rdfs:label 'Open Requisition Count Qa' ;
    rdfs:comment 'Number of open job requisitions for Quality Assurance (QA) discipline. Represents active hiring demand.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openRequisitionCountTotal rdf:type rdf:Property ;
    rdfs:label 'Open Requisition Count Total' ;
    rdfs:comment 'Total number of open job requisitions across all disciplines. Sum of all discipline-specific open requisition counts.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'Version number of this headcount plan. Increments with each revision to support change tracking and audit trail.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period End Date' ;
    rdfs:comment 'The end date of the planning period covered by this headcount plan.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period Start Date' ;
    rdfs:comment 'The start date of the planning period covered by this headcount plan.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningPeriodType rdf:type rdf:Property ;
    rdfs:label 'Planning Period Type' ;
    rdfs:comment 'The granularity or type of planning period this headcount plan covers: sprint (agile iteration), milestone (game development phase), quarter (business quarter), fiscal year, or annual.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizationRatePercent rdf:type rdf:Property ;
    rdfs:label 'Utilization Rate Percent' ;
    rdfs:comment 'Percentage of approved FTE capacity that is currently filled. Calculated as (current_filled_fte_total / approved_fte_total) * 100. Measures staffing efficiency and capacity utilization.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportsToJobProfileId rdf:type rdf:Property ;
    rdfs:label 'Reports To Job Profile Id' ;
    rdfs:comment 'Job profile identifier of the direct manager role for this position. Defines the standard reporting relationship in the organizational hierarchy.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobProfile .

ind:careerLevel rdf:type rdf:Property ;
    rdfs:label 'Career Level' ;
    rdfs:comment 'Seniority level within the career track. Defines experience expectations, scope of responsibility, and position in organizational hierarchy. [ENUM-REF-CANDIDATE: entry|junior|mid|senior|lead|principal|director|vp|c_level — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:careerTrack rdf:type rdf:Property ;
    rdfs:label 'Career Track' ;
    rdfs:comment 'Career progression path for this job profile. Individual Contributor focuses on technical or creative depth; Management focuses on people leadership; Executive focuses on strategic leadership.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coreCompetencies rdf:type rdf:Property ;
    rdfs:label 'Core Competencies' ;
    rdfs:comment 'Comma-separated list of essential skills, technical proficiencies, and behavioral competencies required for success in this job profile. Examples: C++ programming, Unreal Engine, 3D modeling, Agile methodology, player empathy, cross-functional collaboration.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flsaClassification rdf:type rdf:Property ;
    rdfs:label 'Flsa Classification' ;
    rdfs:comment 'US Fair Labor Standards Act classification determining overtime eligibility. Exempt employees are salaried and not eligible for overtime; non-exempt employees are eligible for overtime pay.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:igdaDisciplineClassification rdf:type rdf:Property ;
    rdfs:label 'Igda Discipline Classification' ;
    rdfs:comment 'IGDA-aligned discipline classification for standardized industry benchmarking and workforce reporting. Enables cross-studio and cross-company talent comparisons.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobCode rdf:type rdf:Property ;
    rdfs:label 'Job Code' ;
    rdfs:comment 'Standardized alphanumeric code uniquely identifying this job profile across all studios and corporate functions. Used for position requisition, compensation benchmarking, and HR system integration.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobDescription rdf:type rdf:Property ;
    rdfs:label 'Job Description' ;
    rdfs:comment 'Comprehensive narrative description of the job profile including purpose, key responsibilities, deliverables, and success criteria. Used for job postings, performance management, and organizational design.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobFamily rdf:type rdf:Property ;
    rdfs:label 'Job Family' ;
    rdfs:comment 'High-level functional grouping of the job role. Defines the primary discipline or business function to which this job belongs. [ENUM-REF-CANDIDATE: engineering|art|design|qa|production|esports_operations|community_management|marketing|finance|hr|legal|it|operations|executive — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobProfileStatus rdf:type rdf:Property ;
    rdfs:label 'Job Profile Status' ;
    rdfs:comment 'Current lifecycle status of the job profile. Active profiles are available for position creation; inactive profiles are retired; draft profiles are under development.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobSubFamily rdf:type rdf:Property ;
    rdfs:label 'Job Sub Family' ;
    rdfs:comment 'Specialized sub-category within the job family. Examples: Gameplay Engineering, Character Art, Level Design, Automation QA, Live Operations Production, Tournament Operations.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyResponsibilities rdf:type rdf:Property ;
    rdfs:label 'Key Responsibilities' ;
    rdfs:comment 'Structured list of primary duties and accountabilities for this job profile. Used for performance evaluation, role clarity, and workload planning.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'Date when this job profile was last reviewed and validated by HR and business leadership. Used for compliance audits and ensuring profile currency.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Minimum Education Level' ;
    rdfs:comment 'Minimum formal education level required for this job profile. Used for candidate screening and job posting requirements.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumYearsExperience rdf:type rdf:Property ;
    rdfs:label 'Minimum Years Experience' ;
    rdfs:comment 'Minimum number of years of relevant professional experience required for this job profile. Used for candidate screening and compensation benchmarking.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payGradeBand rdf:type rdf:Property ;
    rdfs:label 'Pay Grade Band' ;
    rdfs:comment 'Compensation band code defining the salary range for this job profile. Used for compensation benchmarking, budget planning, and offer letter generation.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalRequirements rdf:type rdf:Property ;
    rdfs:label 'Physical Requirements' ;
    rdfs:comment 'Description of physical demands and working conditions for this job profile. Examples: prolonged sitting, repetitive motion, ability to lift equipment, extended screen time. Used for ADA compliance and workplace accommodation planning.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCertifications rdf:type rdf:Property ;
    rdfs:label 'Preferred Certifications' ;
    rdfs:comment 'Comma-separated list of professional certifications or licenses that are preferred but not required. Used for candidate evaluation and professional development planning.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Preferred Education Level' ;
    rdfs:comment 'Preferred formal education level for optimal candidate fit. Used for candidate evaluation and talent pipeline development.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredYearsExperience rdf:type rdf:Property ;
    rdfs:label 'Preferred Years Experience' ;
    rdfs:comment 'Preferred number of years of relevant professional experience for optimal candidate fit. Used for candidate evaluation and talent pipeline development.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remoteWorkEligibility rdf:type rdf:Property ;
    rdfs:label 'Remote Work Eligibility' ;
    rdfs:comment 'Remote work policy applicable to this job profile. Defines whether the role can be performed remotely, requires hybrid presence, or must be on-site.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredCertifications rdf:type rdf:Property ;
    rdfs:label 'Required Certifications' ;
    rdfs:comment 'Comma-separated list of professional certifications or licenses required for this job profile. Examples: PMP, Certified Scrum Master, Unity Certified Developer, AWS Solutions Architect.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Security Clearance Required' ;
    rdfs:comment 'Indicates whether this job profile requires background checks or security clearance due to access to sensitive IP, financial data, or player data.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spanOfControlMax rdf:type rdf:Property ;
    rdfs:label 'Span Of Control Max' ;
    rdfs:comment 'Maximum number of direct reports expected for this job profile if it is a management role. Used for organizational design and capacity planning.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spanOfControlMin rdf:type rdf:Property ;
    rdfs:label 'Span Of Control Min' ;
    rdfs:comment 'Minimum number of direct reports expected for this job profile if it is a management role. Used for organizational design and capacity planning.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:technicalSkills rdf:type rdf:Property ;
    rdfs:label 'Technical Skills' ;
    rdfs:comment 'Comma-separated list of specific technical tools, platforms, programming languages, or software applications required for this job profile. Examples: Unity, Perforce, Jira, Maya, Substance Painter, Python, SQL.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelRequirementPercentage rdf:type rdf:Property ;
    rdfs:label 'Travel Requirement Percentage' ;
    rdfs:comment 'Expected percentage of work time requiring business travel. Used for candidate expectations, expense budgeting, and work-life balance planning.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:learningEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Learning Enrollment Id' ;
    rdfs:comment 'Unique identifier for the learning enrollment record. Primary key.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:courseId rdf:type rdf:Property ;
    rdfs:label 'Course Id' ;
    rdfs:comment 'Identifier of the course or certification program.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Course .

ind:primaryLearningEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Learning Employee Id' ;
    rdfs:comment 'Identifier of the employee or contractor enrolled in the learning program.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:attendancePercentage rdf:type rdf:Property ;
    rdfs:label 'Attendance Percentage' ;
    rdfs:comment 'Percentage of training sessions attended by the learner, applicable to instructor-led or scheduled courses.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationEarned rdf:type rdf:Property ;
    rdfs:label 'Certification Earned' ;
    rdfs:comment 'Name of the certification or credential earned upon successful completion (e.g., Unity Certified Developer, Unreal Engine Blueprint Professional).' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceuCredits rdf:type rdf:Property ;
    rdfs:label 'Ceu Credits' ;
    rdfs:comment 'Number of continuing education unit credits earned upon successful completion of the course.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completionStatus rdf:type rdf:Property ;
    rdfs:label 'Completion Status' ;
    rdfs:comment 'Outcome of the learning program (pass, fail, incomplete, in progress, not started).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'Total cost of the training program in the base currency. Includes tuition, materials, and any associated fees.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:courseName rdf:type rdf:Property ;
    rdfs:label 'Course Name' ;
    rdfs:comment 'Full name of the course or certification program (e.g., Unity Advanced Rendering, Unreal Engine Blueprint Scripting, GDPR Compliance Training).' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'Format in which the training is delivered (online, in-person, hybrid, self-paced, instructor-led, virtual classroom).' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentType rdf:type rdf:Property ;
    rdfs:label 'Enrollment Type' ;
    rdfs:comment 'Method by which the learner was enrolled (self-enrolled, manager-assigned, HR-assigned, system-assigned for mandatory training).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackComments rdf:type rdf:Property ;
    rdfs:label 'Feedback Comments' ;
    rdfs:comment 'Free-text comments provided by the learner about the course experience.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackRating rdf:type rdf:Property ;
    rdfs:label 'Feedback Rating' ;
    rdfs:comment 'Learner\'s rating of the course quality, typically on a scale of 1.00 to 5.00.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:instructorName rdf:type rdf:Property ;
    rdfs:label 'Instructor Name' ;
    rdfs:comment 'Name of the instructor or facilitator for instructor-led training. Null for self-paced courses.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:learningProvider rdf:type rdf:Property ;
    rdfs:label 'Learning Provider' ;
    rdfs:comment 'Name of the organization or platform providing the training (e.g., Unity Learn, Coursera, LinkedIn Learning, internal studio training).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passingScoreThreshold rdf:type rdf:Property ;
    rdfs:label 'Passing Score Threshold' ;
    rdfs:comment 'Minimum score required to pass the course or certification, typically as a percentage.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:score rdf:type rdf:Property ;
    rdfs:label 'Score' ;
    rdfs:comment 'Numeric score or grade achieved by the learner, typically as a percentage (0.00 to 100.00).' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingLocation rdf:type rdf:Property ;
    rdfs:label 'Training Location' ;
    rdfs:comment 'Physical or virtual location where the training is conducted (e.g., studio office, conference center, online platform URL).' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Date' ;
    rdfs:comment 'Date when the learner withdrew from the course. Null if not withdrawn.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:withdrawalReason rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Reason' ;
    rdfs:comment 'Reason provided for withdrawing from the course before completion. Null if not withdrawn.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Parent Org Unit Id' ;
    rdfs:comment 'Reference to the parent organizational unit in the hierarchy. Null for top-level units (e.g., corporate headquarters).' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:annualBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Budget Amount' ;
    rdfs:comment 'Total annual operating budget allocated to this organizational unit in the enterprise\'s base currency. Includes compensation, benefits, tools, and operational expenses. Used for financial planning and variance analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentHeadcount rdf:type rdf:Property ;
    rdfs:label 'Current Headcount' ;
    rdfs:comment 'Current number of active employees and contractors assigned to this organizational unit. Updated regularly for capacity planning and resource allocation.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headcountBudget rdf:type rdf:Property ;
    rdfs:label 'Headcount Budget' ;
    rdfs:comment 'Approved headcount capacity for this organizational unit. Used for workforce planning, hiring targets, and studio capacity analysis for game development production scheduling.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isRemoteFirst rdf:type rdf:Property ;
    rdfs:label 'Is Remote First' ;
    rdfs:comment 'Indicates whether this organizational unit operates primarily as a remote/distributed team (true) or requires physical presence at a studio location (false). Impacts workforce planning and collaboration tooling.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orgUnitDescription rdf:type rdf:Property ;
    rdfs:label 'Org Unit Description' ;
    rdfs:comment 'Detailed description of the organizational unit\'s purpose, responsibilities, and scope. Used for onboarding, organizational charts, and internal documentation.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryGameEngine rdf:type rdf:Property ;
    rdfs:label 'Primary Game Engine' ;
    rdfs:comment 'Primary game engine technology this organizational unit specializes in or uses for development. Null for non-development units. Used for skill matrix planning and technology stack reporting.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sprintLengthWeeks rdf:type rdf:Property ;
    rdfs:label 'Sprint Length Weeks' ;
    rdfs:comment 'Standard sprint or iteration length in weeks for agile teams. Null for non-agile units. Used for capacity planning and velocity tracking in Jira.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the organizational unit\'s primary location (e.g., \'America/Los_Angeles\', \'Europe/London\'). Used for scheduling, capacity planning, and cross-studio collaboration.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCode rdf:type rdf:Property ;
    rdfs:label 'Unit Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the organizational unit across the enterprise. Used in HR systems, financial reporting, and project management tools.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitName rdf:type rdf:Property ;
    rdfs:label 'Unit Name' ;
    rdfs:comment 'Full business name of the organizational unit (e.g., \'Core Engine Team\', \'Seattle Studio\', \'Live Operations Department\').' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitStatus rdf:type rdf:Property ;
    rdfs:label 'Unit Status' ;
    rdfs:comment 'Current lifecycle status of the organizational unit. Active = operational; Inactive = temporarily suspended; Planned = approved but not yet operational; Dissolved = permanently closed; Restructuring = undergoing organizational change.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitType rdf:type rdf:Property ;
    rdfs:label 'Unit Type' ;
    rdfs:comment 'Classification of the organizational unit within the hierarchy. Studio = top-level game development studio; Department = functional area within studio or corporate; Team = cross-functional group; Squad = agile delivery unit; Pod = small specialized group; Division = corporate business unit.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollRunId rdf:type rdf:Property ;
    rdfs:label 'Payroll Run Id' ;
    rdfs:comment 'Unique identifier for the payroll run execution event. Primary key.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayrollRun .

ind:payrollCalendarId rdf:type rdf:Property ;
    rdfs:label 'Payroll Calendar Id' ;
    rdfs:comment 'Identifier of the payroll calendar that defines the schedule of pay periods and payment dates for this run. Links to the master payroll calendar configuration.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayrollCalendar .

ind:reversalRunPayrollRunId rdf:type rdf:Property ;
    rdfs:label 'Reversal Run Payroll Run Id' ;
    rdfs:comment 'Reference to the payroll run that reverses this run if corrections or cancellations are needed. Null if this run has not been reversed.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayrollRun .

ind:checkDate rdf:type rdf:Property ;
    rdfs:label 'Check Date' ;
    rdfs:comment 'Date printed on physical checks or used as the effective date for electronic payments. May differ from payment_date for banking processing reasons.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:glDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Gl Document Number' ;
    rdfs:comment 'Document number of the GL posting created for this payroll run. Links payroll data to financial accounting records for reconciliation and audit.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payGroupCode rdf:type rdf:Property ;
    rdfs:label 'Pay Group Code' ;
    rdfs:comment 'Code identifying the pay group (e.g., salaried, hourly, contractors, executives) that this payroll run processes. Pay groups segment employees by payment frequency and rules.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period End Date' ;
    rdfs:comment 'End date of the pay period covered by this payroll run. Defines the close of the earnings and deductions calculation window.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period Start Date' ;
    rdfs:comment 'Start date of the pay period covered by this payroll run. Defines the beginning of the earnings and deductions calculation window.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethodSummary rdf:type rdf:Property ;
    rdfs:label 'Payment Method Summary' ;
    rdfs:comment 'Summary of payment methods used in this run (e.g., \'85% direct deposit, 10% check, 5% paycard\'). Provides high-level view of disbursement channels.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollArea rdf:type rdf:Property ;
    rdfs:label 'Payroll Area' ;
    rdfs:comment 'Organizational grouping that defines payroll processing frequency and rules (e.g., US-Monthly, UK-Weekly, CA-Biweekly). Combines geography and payment frequency.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollRunName rdf:type rdf:Property ;
    rdfs:label 'Payroll Run Name' ;
    rdfs:comment 'Descriptive name for this payroll run (e.g., \'January 2024 Salaried\', \'Q4 Bonus Run\', \'Off-Cycle Correction\'). Improves readability in reports and user interfaces.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postedBy rdf:type rdf:Property ;
    rdfs:label 'Posted By' ;
    rdfs:comment 'User ID or name of the person who posted this payroll run to the General Ledger. Part of audit trail for financial posting governance.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posted Timestamp' ;
    rdfs:comment 'Timestamp when this payroll run was posted to the General Ledger. Marks the point when payroll expenses became part of official financial records.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processingNotes rdf:type rdf:Property ;
    rdfs:label 'Processing Notes' ;
    rdfs:comment 'Free-text notes about special circumstances, exceptions, or issues encountered during this payroll run. Used for documentation and knowledge transfer.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runExecutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run Execution Timestamp' ;
    rdfs:comment 'Timestamp when the payroll run calculation was executed. Used for audit trails and troubleshooting processing issues.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runType rdf:type rdf:Property ;
    rdfs:label 'Run Type' ;
    rdfs:comment 'Type of payroll run execution: regular (scheduled periodic payroll), off-cycle (unscheduled mid-period run), bonus (special bonus payment run), correction (adjustment run), final (termination payroll), or advance (early payment).' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalEmployeeDeductions rdf:type rdf:Property ;
    rdfs:label 'Total Employee Deductions' ;
    rdfs:comment 'Sum of all employee-side deductions (income tax, social security, benefits, garnishments, 401k contributions) withheld from gross pay in this payroll run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalEmployeesProcessed rdf:type rdf:Property ;
    rdfs:label 'Total Employees Processed' ;
    rdfs:comment 'Count of employees included in this payroll run. Used for reconciliation and validation that all expected employees were paid.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalEmployerContributions rdf:type rdf:Property ;
    rdfs:label 'Total Employer Contributions' ;
    rdfs:comment 'Sum of all employer-side contributions (employer portion of social security, health insurance, retirement matching, payroll taxes) for this payroll run. Represents additional labor cost beyond gross pay.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalGrossPay rdf:type rdf:Property ;
    rdfs:label 'Total Gross Pay' ;
    rdfs:comment 'Sum of all gross earnings (base salary, overtime, bonuses, allowances) for all employees in this payroll run before any deductions. Key metric for labor cost reporting.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetPay rdf:type rdf:Property ;
    rdfs:label 'Total Net Pay' ;
    rdfs:comment 'Sum of all net pay (gross pay minus all deductions) for all employees in this payroll run. Represents the total cash disbursement amount.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTaxWithheld rdf:type rdf:Property ;
    rdfs:label 'Total Tax Withheld' ;
    rdfs:comment 'Sum of all tax withholdings (federal, state, local income tax, social security, Medicare) for all employees in this payroll run. Used for tax remittance and statutory reporting.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payslipId rdf:type rdf:Property ;
    rdfs:label 'Payslip Id' ;
    rdfs:comment 'Unique identifier for the payslip record. Primary key.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allowancesTotal rdf:type rdf:Property ;
    rdfs:label 'Allowances Total' ;
    rdfs:comment 'Sum of all allowances such as housing, transportation, meal, or other stipends provided to the employee.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankAccountLastFour rdf:type rdf:Property ;
    rdfs:label 'Bank Account Last Four' ;
    rdfs:comment 'Last four digits of the employee\'s bank account number used for direct deposit, for verification and audit purposes.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseSalary rdf:type rdf:Property ;
    rdfs:label 'Base Salary' ;
    rdfs:comment 'The regular base salary or wage amount earned by the employee during the pay period before any additions or deductions.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionAmount rdf:type rdf:Property ;
    rdfs:label 'Commission Amount' ;
    rdfs:comment 'Sales commission or incentive payment earned during the pay period.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dentalInsuranceDeduction rdf:type rdf:Property ;
    rdfs:label 'Dental Insurance Deduction' ;
    rdfs:comment 'Employee contribution toward dental insurance premiums deducted from gross pay.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employer401kMatch rdf:type rdf:Property ;
    rdfs:label 'Employer 401k Match' ;
    rdfs:comment 'Employer\'s matching contribution to the employee\'s 401(k) retirement plan for this pay period.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerHealthInsuranceContribution rdf:type rdf:Property ;
    rdfs:label 'Employer Health Insurance Contribution' ;
    rdfs:comment 'Employer\'s contribution toward the employee\'s health insurance premiums for this pay period.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerMedicareContribution rdf:type rdf:Property ;
    rdfs:label 'Employer Medicare Contribution' ;
    rdfs:comment 'Employer\'s matching contribution to Medicare tax for this pay period.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerSocialSecurityContribution rdf:type rdf:Property ;
    rdfs:label 'Employer Social Security Contribution' ;
    rdfs:comment 'Employer\'s matching contribution to social security tax for this pay period.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:federalTaxWithheld rdf:type rdf:Property ;
    rdfs:label 'Federal Tax Withheld' ;
    rdfs:comment 'Amount of federal income tax withheld from the employee\'s gross pay for the pay period.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:garnishmentDeduction rdf:type rdf:Property ;
    rdfs:label 'Garnishment Deduction' ;
    rdfs:comment 'Court-ordered wage garnishment amount deducted from gross pay for child support, alimony, tax levies, or other legal obligations.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:generatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Generated Timestamp' ;
    rdfs:comment 'The date and time when this payslip record was generated by the payroll system.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:grossPay rdf:type rdf:Property ;
    rdfs:label 'Gross Pay' ;
    rdfs:comment 'Total earnings before any deductions, calculated as the sum of base salary, overtime, bonuses, commissions, and allowances.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:healthInsuranceDeduction rdf:type rdf:Property ;
    rdfs:label 'Health Insurance Deduction' ;
    rdfs:comment 'Employee contribution toward health insurance premiums deducted from gross pay.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localTaxWithheld rdf:type rdf:Property ;
    rdfs:label 'Local Tax Withheld' ;
    rdfs:comment 'Amount of local or municipal income tax withheld from the employee\'s gross pay for the pay period.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medicareTax rdf:type rdf:Property ;
    rdfs:label 'Medicare Tax' ;
    rdfs:comment 'Employee portion of Medicare tax (FICA) withheld from gross pay.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPay rdf:type rdf:Property ;
    rdfs:label 'Net Pay' ;
    rdfs:comment 'The final take-home pay amount disbursed to the employee after all deductions, calculated as gross pay minus total deductions.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherDeductionsTotal rdf:type rdf:Property ;
    rdfs:label 'Other Deductions Total' ;
    rdfs:comment 'Sum of all other miscellaneous deductions not categorized above, such as union dues, charitable contributions, or loan repayments.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimePay rdf:type rdf:Property ;
    rdfs:label 'Overtime Pay' ;
    rdfs:comment 'Additional compensation for hours worked beyond the standard work schedule during the pay period.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payslipNumber rdf:type rdf:Property ;
    rdfs:label 'Payslip Number' ;
    rdfs:comment 'Human-readable unique payslip document number assigned by the payroll system for reference and audit purposes.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payslipStatus rdf:type rdf:Property ;
    rdfs:label 'Payslip Status' ;
    rdfs:comment 'Current lifecycle status of the payslip record indicating whether it is in draft, approved for payment, paid, voided, or corrected.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirement401kDeduction rdf:type rdf:Property ;
    rdfs:label 'Retirement 401k Deduction' ;
    rdfs:comment 'Employee contribution to 401(k) retirement plan deducted from gross pay on a pre-tax or post-tax basis.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialSecurityTax rdf:type rdf:Property ;
    rdfs:label 'Social Security Tax' ;
    rdfs:comment 'Employee portion of social security tax (FICA) withheld from gross pay.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stateTaxWithheld rdf:type rdf:Property ;
    rdfs:label 'State Tax Withheld' ;
    rdfs:comment 'Amount of state income tax withheld from the employee\'s gross pay for the pay period.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDeductions rdf:type rdf:Property ;
    rdfs:label 'Total Deductions' ;
    rdfs:comment 'Sum of all deductions including taxes, benefits, retirement contributions, garnishments, and other withholdings.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:visionInsuranceDeduction rdf:type rdf:Property ;
    rdfs:label 'Vision Insurance Deduction' ;
    rdfs:comment 'Employee contribution toward vision insurance premiums deducted from gross pay.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yearToDate401kContribution rdf:type rdf:Property ;
    rdfs:label 'Year To Date 401k Contribution' ;
    rdfs:comment 'Cumulative employee 401(k) contributions from the beginning of the calendar or fiscal year through the end of this pay period.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yearToDateFederalTax rdf:type rdf:Property ;
    rdfs:label 'Year To Date Federal Tax' ;
    rdfs:comment 'Cumulative federal income tax withheld from the employee\'s pay from the beginning of the calendar or fiscal year through the end of this pay period.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yearToDateGrossPay rdf:type rdf:Property ;
    rdfs:label 'Year To Date Gross Pay' ;
    rdfs:comment 'Cumulative gross pay earned by the employee from the beginning of the calendar or fiscal year through the end of this pay period.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yearToDateNetPay rdf:type rdf:Property ;
    rdfs:label 'Year To Date Net Pay' ;
    rdfs:comment 'Cumulative net pay received by the employee from the beginning of the calendar or fiscal year through the end of this pay period.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yearToDateStateTax rdf:type rdf:Property ;
    rdfs:label 'Year To Date State Tax' ;
    rdfs:comment 'Cumulative state income tax withheld from the employee\'s pay from the beginning of the calendar or fiscal year through the end of this pay period.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceReviewId rdf:type rdf:Property ;
    rdfs:label 'Performance Review Id' ;
    rdfs:comment 'Unique identifier for the performance review record. Primary key.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPerformanceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Performance Employee Id' ;
    rdfs:comment 'Identifier of the employee being reviewed (reviewee). Links to employee master data in SAP S/4HANA HR module.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reviewCycleId rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Id' ;
    rdfs:comment 'Identifier of the review cycle or period (e.g., annual review 2024, mid-year review Q2 2024). Links to review cycle configuration.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReviewCycle .

ind:calibrationCommitteeNotes rdf:type rdf:Property ;
    rdfs:label 'Calibration Committee Notes' ;
    rdfs:comment 'Confidential notes and rationale from the calibration committee regarding rating adjustments or validation. Used to ensure fairness and consistency in performance ratings across the organization.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationStatus rdf:type rdf:Property ;
    rdfs:label 'Calibration Status' ;
    rdfs:comment 'Status indicating whether the review has been through calibration committee review to ensure rating consistency across teams and studios. Values: not_calibrated (review not yet submitted to calibration), pending_calibration (awaiting calibration committee review), calibrated (reviewed and approved by calibration committee with no changes), calibration_adjusted (rating adjusted by calibration committee for consistency).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collaborationRating rdf:type rdf:Property ;
    rdfs:label 'Collaboration Rating' ;
    rdfs:comment 'Rating for collaboration, teamwork, and cross-functional communication skills. Critical for game development teams working in agile sprints and cross-discipline collaboration.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collaborationScore rdf:type rdf:Property ;
    rdfs:label 'Collaboration Score' ;
    rdfs:comment 'Numeric score for collaboration rating on a standardized scale (e.g., 1.00 to 5.00).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationIncreasePercentage rdf:type rdf:Property ;
    rdfs:label 'Compensation Increase Percentage' ;
    rdfs:comment 'Recommended percentage increase in base compensation based on performance rating (e.g., 5.50 represents a 5.5% salary increase). Confidential field used for compensation planning and budgeting.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationIncreaseRecommended rdf:type rdf:Property ;
    rdfs:label 'Compensation Increase Recommended' ;
    rdfs:comment 'Boolean flag indicating whether the reviewer recommends a compensation increase (salary raise, bonus, equity grant) based on performance. True if increase is recommended, False otherwise.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:developmentPlanRequired rdf:type rdf:Property ;
    rdfs:label 'Development Plan Required' ;
    rdfs:comment 'Boolean flag indicating whether a formal development plan or Performance Improvement Plan (PIP) is required based on the review outcome. True if development plan is required, False otherwise.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeeAcknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgement Date' ;
    rdfs:comment 'Date when the employee acknowledged receipt and review of their performance evaluation. Indicates the employee has been informed of the review outcome.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employeeAcknowledgementSignature rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgement Signature' ;
    rdfs:comment 'Digital signature or acknowledgement token confirming the employee has reviewed and acknowledged the performance review. Used for compliance and record-keeping.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeSelfAssessment rdf:type rdf:Property ;
    rdfs:label 'Employee Self Assessment' ;
    rdfs:comment 'Employee\'s self-assessment narrative describing their own performance, accomplishments, challenges, and development goals for the review period. Submitted prior to manager review.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalAchievementPercentage rdf:type rdf:Property ;
    rdfs:label 'Goal Achievement Percentage' ;
    rdfs:comment 'Percentage of individual goals and objectives (OKRs) achieved during the review period (e.g., 85.50 represents 85.5% goal achievement). Calculated from individual goal tracking aligned to game development milestones.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goalsMetCount rdf:type rdf:Property ;
    rdfs:label 'Goals Met Count' ;
    rdfs:comment 'Number of individual goals fully achieved during the review period.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:goalsTotalCount rdf:type rdf:Property ;
    rdfs:label 'Goals Total Count' ;
    rdfs:comment 'Total number of individual goals set for the employee during the review period.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:innovationRating rdf:type rdf:Property ;
    rdfs:label 'Innovation Rating' ;
    rdfs:comment 'Rating for innovation, creativity, and problem-solving abilities. Particularly important for game designers, artists, and engineers developing new gameplay mechanics and features.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:innovationScore rdf:type rdf:Property ;
    rdfs:label 'Innovation Score' ;
    rdfs:comment 'Numeric score for innovation rating on a standardized scale (e.g., 1.00 to 5.00).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadershipRating rdf:type rdf:Property ;
    rdfs:label 'Leadership Rating' ;
    rdfs:comment 'Rating for leadership capabilities including mentoring, decision-making, and team management. Applicable to lead developers, producers, directors, and managers. Set to not_applicable for individual contributor roles without leadership responsibilities.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadershipScore rdf:type rdf:Property ;
    rdfs:label 'Leadership Score' ;
    rdfs:comment 'Numeric score for leadership rating on a standardized scale (e.g., 1.00 to 5.00). Null if not applicable to role.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallRatingScore rdf:type rdf:Property ;
    rdfs:label 'Overall Rating Score' ;
    rdfs:comment 'Numeric score representing the overall performance rating on a standardized scale (e.g., 1.00 to 5.00, where 5.00 is outstanding). Used for compensation calculations and talent analytics.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionReadinessLevel rdf:type rdf:Property ;
    rdfs:label 'Promotion Readiness Level' ;
    rdfs:comment 'Assessment of the employee\'s readiness for promotion to the next level. Values: ready_now (ready for immediate promotion), ready_1_year (ready within 1 year with development), ready_2_years (ready within 2 years with development), not_ready (not ready for promotion), not_applicable (at terminal level or not applicable).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionRecommended rdf:type rdf:Property ;
    rdfs:label 'Promotion Recommended' ;
    rdfs:comment 'Boolean flag indicating whether the reviewer recommends the employee for promotion based on performance during the review period. True if promotion is recommended, False otherwise.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Review Approval Date' ;
    rdfs:comment 'Date when the performance review was approved by the calibration committee or senior management.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Review Period End Date' ;
    rdfs:comment 'End date of the performance period being evaluated (e.g., 2024-12-31 for annual review covering calendar year 2024).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Period Start Date' ;
    rdfs:comment 'Start date of the performance period being evaluated (e.g., 2024-01-01 for annual review covering calendar year 2024).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Review Submission Date' ;
    rdfs:comment 'Date when the reviewer submitted the completed performance review for approval.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewerComments rdf:type rdf:Property ;
    rdfs:label 'Reviewer Comments' ;
    rdfs:comment 'Detailed narrative comments from the reviewer summarizing the employee\'s performance, strengths, areas for improvement, and specific examples. Confidential feedback shared with the employee during the review discussion.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalCompetencyRating rdf:type rdf:Property ;
    rdfs:label 'Technical Competency Rating' ;
    rdfs:comment 'Rating for technical skills and competencies specific to the employee\'s role (e.g., programming, game design, art creation, engine proficiency). Aligned to IGDA competency frameworks for game development roles.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalCompetencyScore rdf:type rdf:Property ;
    rdfs:label 'Technical Competency Score' ;
    rdfs:comment 'Numeric score for technical competency rating on a standardized scale (e.g., 1.00 to 5.00).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportsToPositionId rdf:type rdf:Property ;
    rdfs:label 'Reports To Position Id' ;
    rdfs:comment 'Identifier of the position to which this position reports in the organizational hierarchy.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:educationRequirement rdf:type rdf:Property ;
    rdfs:label 'Education Requirement' ;
    rdfs:comment 'Minimum educational qualification required for the position (e.g., Bachelor\'s in Computer Science, portfolio-based for artists).' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fteAllocation rdf:type rdf:Property ;
    rdfs:label 'Fte Allocation' ;
    rdfs:comment 'Full-time equivalent allocation for the position. 1.0 represents full-time, 0.5 represents half-time. Used for headcount planning and capacity management.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBonusEligible rdf:type rdf:Property ;
    rdfs:label 'Is Bonus Eligible' ;
    rdfs:comment 'Indicates whether the position is eligible for performance-based bonus compensation.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isContractorEligible rdf:type rdf:Property ;
    rdfs:label 'Is Contractor Eligible' ;
    rdfs:comment 'Indicates whether the position can be filled by a contractor or contingent worker rather than a full-time employee.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEquityEligible rdf:type rdf:Property ;
    rdfs:label 'Is Equity Eligible' ;
    rdfs:comment 'Indicates whether the position is eligible for equity compensation (stock options, RSUs).' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobGrade rdf:type rdf:Property ;
    rdfs:label 'Job Grade' ;
    rdfs:comment 'Internal compensation grade level assigned to the position for salary band determination and career progression.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationCountry rdf:type rdf:Property ;
    rdfs:label 'Location Country' ;
    rdfs:comment 'Three-letter ISO country code where the position is based.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minYearsExperience rdf:type rdf:Property ;
    rdfs:label 'Min Years Experience' ;
    rdfs:comment 'Minimum number of years of relevant industry experience required for the position.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:positionCode rdf:type rdf:Property ;
    rdfs:label 'Position Code' ;
    rdfs:comment 'Business identifier for the position used in HR systems and organizational charts. Typically follows company-specific coding scheme.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionDescription rdf:type rdf:Property ;
    rdfs:label 'Position Description' ;
    rdfs:comment 'Detailed description of the position responsibilities, accountabilities, and key deliverables.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionStatus rdf:type rdf:Property ;
    rdfs:label 'Position Status' ;
    rdfs:comment 'Current lifecycle status of the position indicating whether it is available for hiring, currently occupied, or temporarily frozen.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryRangeMax rdf:type rdf:Property ;
    rdfs:label 'Salary Range Max' ;
    rdfs:comment 'Maximum annual salary for the position in local currency. Used for compensation planning and pay equity analysis.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salaryRangeMin rdf:type rdf:Property ;
    rdfs:label 'Salary Range Min' ;
    rdfs:comment 'Minimum annual salary for the position in local currency. Used for compensation planning and pay equity analysis.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:skillProfile rdf:type rdf:Property ;
    rdfs:label 'Skill Profile' ;
    rdfs:comment 'Required technical and functional skills for the position (e.g., Unity, Unreal Engine, C++, Maya, Substance Painter, Jira, Agile methodologies).' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryRecruitmentHiringManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Recruitment Hiring Manager Employee Id' ;
    rdfs:comment 'Employee identifier of the hiring manager who will supervise the new hire and is responsible for final candidate selection.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryRecruitmentApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Recruitment Approved By Employee Id' ;
    rdfs:comment 'Employee identifier of the HR or executive leader who granted final approval for this requisition.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:diversityHiringFlag rdf:type rdf:Property ;
    rdfs:label 'Diversity Hiring Flag' ;
    rdfs:comment 'Indicates whether this requisition is part of a diversity and inclusion hiring initiative. Supports diversity pipeline analytics.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:educationLevelRequired rdf:type rdf:Property ;
    rdfs:label 'Education Level Required' ;
    rdfs:comment 'Minimum educational qualification required for the position (e.g., Bachelor\'s Degree in Computer Science, equivalent industry experience).' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountType rdf:type rdf:Property ;
    rdfs:label 'Headcount Type' ;
    rdfs:comment 'Classification indicating whether this is a net-new position, a backfill for a departure, or a replacement for an internal transfer.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRelocationOffered rdf:type rdf:Property ;
    rdfs:label 'Is Relocation Offered' ;
    rdfs:comment 'Indicates whether the company will provide relocation assistance for candidates moving to the studio location.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVisaSponsorshipAvailable rdf:type rdf:Property ;
    rdfs:label 'Is Visa Sponsorship Available' ;
    rdfs:comment 'Indicates whether the company will sponsor work visas for international candidates. Critical for global talent acquisition.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfOpenings rdf:type rdf:Property ;
    rdfs:label 'Number Of Openings' ;
    rdfs:comment 'Quantity of positions to be filled under this single requisition. Supports bulk hiring for studio expansion or project ramp-up.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:positionLevel rdf:type rdf:Property ;
    rdfs:label 'Position Level' ;
    rdfs:comment 'Seniority level of the position within the organizational hierarchy. Used for compensation banding and career progression planning. [ENUM-REF-CANDIDATE: entry|mid|senior|lead|principal|director|executive — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionTitle rdf:type rdf:Property ;
    rdfs:label 'Position Title' ;
    rdfs:comment 'The official job title for the open position (e.g., Senior Game Designer, Lead Gameplay Programmer, Esports Operations Manager).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredSkills rdf:type rdf:Property ;
    rdfs:label 'Preferred Skills' ;
    rdfs:comment 'Comma-separated list of desirable but not mandatory skills that would enhance candidate fit for the role.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredSkills rdf:type rdf:Property ;
    rdfs:label 'Required Skills' ;
    rdfs:comment 'Comma-separated list of mandatory technical and functional skills for the position (e.g., Unity, Unreal Engine, C++, game design, esports operations).' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionCloseDate rdf:type rdf:Property ;
    rdfs:label 'Requisition Close Date' ;
    rdfs:comment 'Date when the requisition was closed (filled, cancelled, or withdrawn). End of the time-to-fill measurement period.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Requisition Number' ;
    rdfs:comment 'Business identifier for the requisition, externally visible and used for tracking and communication across HR systems and hiring managers.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionOpenDate rdf:type rdf:Property ;
    rdfs:label 'Requisition Open Date' ;
    rdfs:comment 'Date when the requisition was approved and opened for active candidate sourcing. Start of the time-to-fill measurement period.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Requisition Status' ;
    rdfs:comment 'Current lifecycle status of the requisition in the hiring workflow. Tracks progression from draft through approval to closure. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|open|on_hold|filled|cancelled|closed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Salary Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the salary range (e.g., USD, EUR, GBP). Supports multi-currency compensation for global studios.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingChannels rdf:type rdf:Property ;
    rdfs:label 'Sourcing Channels' ;
    rdfs:comment 'Comma-separated list of candidate sourcing channels approved for this requisition (e.g., job boards, referrals, campus recruiting, esports talent pipeline, LinkedIn, industry events).' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStartDate rdf:type rdf:Property ;
    rdfs:label 'Target Start Date' ;
    rdfs:comment 'Desired onboarding date for the new hire. Used for production scheduling and studio capacity planning.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:timeToFillDays rdf:type rdf:Property ;
    rdfs:label 'Time To Fill Days' ;
    rdfs:comment 'Calculated number of days from requisition open date to close date. Key performance indicator (KPI) for recruitment efficiency.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalCandidatesApplied rdf:type rdf:Property ;
    rdfs:label 'Total Candidates Applied' ;
    rdfs:comment 'Total number of candidates who submitted applications for this requisition. Used for source channel effectiveness analysis.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalCandidatesInterviewed rdf:type rdf:Property ;
    rdfs:label 'Total Candidates Interviewed' ;
    rdfs:comment 'Total number of candidates who progressed to interview stage. Used for funnel conversion analysis.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalOffersExtended rdf:type rdf:Property ;
    rdfs:label 'Total Offers Extended' ;
    rdfs:comment 'Total number of job offers extended to candidates for this requisition. Used for offer acceptance rate calculation.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:skillMatrixId rdf:type rdf:Property ;
    rdfs:label 'Skill Matrix Id' ;
    rdfs:comment 'Unique identifier for the skill matrix record. Primary key for the skill matrix data product.' ;
    rdfs:domain ind:SkillMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySkillEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Skill Employee Id' ;
    rdfs:comment 'Unique identifier for the employee or contractor whose skill is being tracked. Links to the workforce employee master data.' ;
    rdfs:domain ind:SkillMatrix ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:certificationName rdf:type rdf:Property ;
    rdfs:label 'Certification Name' ;
    rdfs:comment 'Name of the professional certification or credential earned for this skill, if applicable. Examples include Unity Certified Developer, Unreal Engine Certified Instructor, AWS Certified Solutions Architect, Certified Scrum Master (CSM), or platform-specific certifications.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationProvider rdf:type rdf:Property ;
    rdfs:label 'Certification Provider' ;
    rdfs:comment 'Organization or institution that issued the certification. Examples include Unity Technologies, Epic Games, Scrum Alliance, Microsoft, Amazon Web Services (AWS), or platform holders (Sony, Microsoft, Nintendo).' ;
    rdfs:domain ind:SkillMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceTrainingFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Training Flag' ;
    rdfs:comment 'Boolean indicator of whether this learning program is mandatory compliance training required by law, regulation, or company policy. True indicates mandatory compliance training (GDPR, COPPA, PCI DSS, harassment prevention, security awareness). False indicates non-compliance training. Critical for audit trail and regulatory reporting.' ;
    rdfs:domain ind:SkillMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUsedDate rdf:type rdf:Property ;
    rdfs:label 'Last Used Date' ;
    rdfs:comment 'Most recent date when the employee actively used this skill in a project, sprint, or work assignment. Used to identify skill currency and detect skill atrophy. Sourced from project management systems (Jira) or time tracking systems.' ;
    rdfs:domain ind:SkillMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:learningProgramName rdf:type rdf:Property ;
    rdfs:label 'Learning Program Name' ;
    rdfs:comment 'Name of the training course, workshop, or learning program the employee is enrolled in or has completed to develop this skill. Examples include internal onboarding programs, vendor training (Unity Learn, Unreal Online Learning), or third-party courses (Coursera, Udemy, LinkedIn Learning).' ;
    rdfs:domain ind:SkillMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:learningType rdf:type rdf:Property ;
    rdfs:label 'Learning Type' ;
    rdfs:comment 'Classification of the learning program purpose. Mandatory compliance indicates required training for regulatory or policy adherence (General Data Protection Regulation (GDPR), Childrens Online Privacy Protection Act (COPPA), Payment Card Industry Data Security Standard (PCI DSS), harassment prevention). Voluntary development indicates employee-initiated professional growth. Onboarding indicates new hire orientation. Upskilling indicates deepening existing skills. Reskilling indicates learning new skills for role transition.' ;
    rdfs:domain ind:SkillMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerAssessmentScore rdf:type rdf:Property ;
    rdfs:label 'Manager Assessment Score' ;
    rdfs:comment 'Managers rated proficiency score for this skill on a scale of 1 to 10. Provides objective assessment to complement self-assessment. Used for performance reviews, promotion decisions, and skill gap analysis.' ;
    rdfs:domain ind:SkillMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Next Assessment Date' ;
    rdfs:comment 'Scheduled date for the next skill proficiency assessment or review. Used to ensure regular skill validation and maintain skill inventory currency. Typically scheduled annually or bi-annually depending on skill criticality.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proficiencyLevel rdf:type rdf:Property ;
    rdfs:label 'Proficiency Level' ;
    rdfs:comment 'Current proficiency rating for the employee in this specific skill. Levels range from beginner (basic familiarity) to master (industry-recognized expert, can mentor others and define best practices).' ;
    rdfs:domain ind:SkillMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selfAssessmentScore rdf:type rdf:Property ;
    rdfs:label 'Self Assessment Score' ;
    rdfs:comment 'Employees self-rated proficiency score for this skill on a scale of 1 to 10. Used to compare self-perception with manager assessment and identify confidence gaps or Dunning-Kruger effects. Supports career development conversations.' ;
    rdfs:domain ind:SkillMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:skillCategory rdf:type rdf:Property ;
    rdfs:label 'Skill Category' ;
    rdfs:comment 'High-level classification of the skill domain. Categories include game engine proficiency, programming language, art discipline (3D modeling, animation, concept art), quality assurance (QA) methodology, platform software development kit (SDK) knowledge, and design discipline (level design, systems design, narrative design).' ;
    rdfs:domain ind:SkillMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillGapFlag rdf:type rdf:Property ;
    rdfs:label 'Skill Gap Flag' ;
    rdfs:comment 'Boolean indicator of whether this skill represents a gap between current proficiency and required proficiency for the employees role or career path. True indicates a development need. False indicates proficiency meets or exceeds requirements. Used to prioritize learning and development investments.' ;
    rdfs:domain ind:SkillMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:skillName rdf:type rdf:Property ;
    rdfs:label 'Skill Name' ;
    rdfs:comment 'Specific name of the skill or competency being assessed. Examples include Unity, Unreal Engine, C++, Python, High-Level Shading Language (HLSL), Maya, Blender, Substance Painter, Perforce, Jira, Agile QA, platform-specific SDKs (Steamworks, PlayStation SDK, Xbox GDK).' ;
    rdfs:domain ind:SkillMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillPriority rdf:type rdf:Property ;
    rdfs:label 'Skill Priority' ;
    rdfs:comment 'Business priority level assigned to this skill based on current and future project needs. Critical indicates the skill is essential for current production and in high demand. High indicates strong business need. Medium indicates moderate need. Low indicates nice-to-have or surplus capacity. Used for learning and development investment prioritization.' ;
    rdfs:domain ind:SkillMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillStatus rdf:type rdf:Property ;
    rdfs:label 'Skill Status' ;
    rdfs:comment 'Current lifecycle status of the skill in the employees capability portfolio. Active indicates the skill is currently used and maintained. Dormant indicates the skill is not currently used but remains valid. Deprecated indicates the skill is obsolete or no longer relevant to the business. Target indicates the skill is a development goal not yet achieved.' ;
    rdfs:domain ind:SkillMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetProficiencyLevel rdf:type rdf:Property ;
    rdfs:label 'Target Proficiency Level' ;
    rdfs:comment 'Desired proficiency level for this skill based on the employees role requirements or career development plan. Used to measure skill gap and track progress toward development goals.' ;
    rdfs:domain ind:SkillMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCost rdf:type rdf:Property ;
    rdfs:label 'Training Cost' ;
    rdfs:comment 'Total cost incurred for the learning program, including tuition, materials, and any associated fees. Denominated in the companys reporting currency. Used for learning and development budget tracking and return on investment (ROI) analysis.' ;
    rdfs:domain ind:SkillMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:studioCapacityPlanId rdf:type rdf:Property ;
    rdfs:label 'Studio Capacity Plan Id' ;
    rdfs:comment 'Unique identifier for the studio capacity plan record.' ;
    rdfs:domain ind:StudioCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryStudioApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Studio Approved By Employee Id' ;
    rdfs:comment 'Reference to the employee (typically studio head, HR director, or production director) who approved this capacity plan.' ;
    rdfs:domain ind:StudioCapacityPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allocatedFte rdf:type rdf:Property ;
    rdfs:label 'Allocated Fte' ;
    rdfs:comment 'The number of full-time equivalent staff allocated to the project or work stream during the planning period.' ;
    rdfs:domain ind:StudioCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableFte rdf:type rdf:Property ;
    rdfs:label 'Available Fte' ;
    rdfs:comment 'The total number of full-time equivalent staff available in the studio for this discipline and seniority band during the planning period, including existing headcount and approved hires.' ;
    rdfs:domain ind:StudioCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractorCount rdf:type rdf:Property ;
    rdfs:label 'Contractor Count' ;
    rdfs:comment 'The number of external contractors or temporary staff planned to supplement internal capacity during the planning period.' ;
    rdfs:domain ind:StudioCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractorFte rdf:type rdf:Property ;
    rdfs:label 'Contractor Fte' ;
    rdfs:comment 'The full-time equivalent capacity provided by contractors during the planning period, accounting for part-time and short-term engagements.' ;
    rdfs:domain ind:StudioCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandFte rdf:type rdf:Property ;
    rdfs:label 'Demand Fte' ;
    rdfs:comment 'The total FTE demand required by the project or studio operations during the planning period, based on project scope and production schedule.' ;
    rdfs:domain ind:StudioCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onsiteFte rdf:type rdf:Property ;
    rdfs:label 'Onsite Fte' ;
    rdfs:comment 'The number of FTE working onsite at the studio location during the planning period.' ;
    rdfs:domain ind:StudioCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remoteFte rdf:type rdf:Property ;
    rdfs:label 'Remote Fte' ;
    rdfs:comment 'The number of FTE working remotely during the planning period, supporting remote-first or hybrid workforce planning.' ;
    rdfs:domain ind:StudioCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seniorityBand rdf:type rdf:Property ;
    rdfs:label 'Seniority Band' ;
    rdfs:comment 'The seniority level of staff being planned: junior, mid-level, senior, lead, principal, or director.' ;
    rdfs:domain ind:StudioCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeEntryId rdf:type rdf:Property ;
    rdfs:label 'Time Entry Id' ;
    rdfs:comment 'Unique identifier for the time entry record. Primary key.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTimeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Time Employee Id' ;
    rdfs:comment 'Identifier of the employee or contractor who recorded this time entry. Links to workforce employee or contractor records.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'Specific type of work activity performed during worked time: development, QA (Quality Assurance), playtesting, live operations, design, art, audio, programming, meetings, training, or administrative tasks. Enables skill-based capacity analysis. [ENUM-REF-CANDIDATE: development|qa|playtesting|live_ops|design|art|audio|programming|meetings|training|admin — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billableFlag rdf:type rdf:Property ;
    rdfs:label 'Billable Flag' ;
    rdfs:comment 'Indicates whether the time entry is billable to an external client or internal project budget. True for billable time, false for non-billable overhead or administrative time.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Billing Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the billing rate (e.g., USD, EUR, GBP). Supports multi-currency project cost tracking.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingRate rdf:type rdf:Property ;
    rdfs:label 'Billing Rate' ;
    rdfs:comment 'Hourly billing rate applied to this time entry for project cost allocation or client invoicing. Confidential financial data used for revenue recognition and project profitability analysis.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entryNotes rdf:type rdf:Property ;
    rdfs:label 'Entry Notes' ;
    rdfs:comment 'Free-text notes or comments provided by the employee to describe the work performed, absence reason, or other relevant context. Supports detailed time tracking and audit documentation.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hoursWorked rdf:type rdf:Property ;
    rdfs:label 'Hours Worked' ;
    rdfs:comment 'Total hours worked on the entry date. Populated for worked_time and overtime entry types. Used for project cost allocation and capacity utilization tracking.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeHours rdf:type rdf:Property ;
    rdfs:label 'Overtime Hours' ;
    rdfs:comment 'Hours worked beyond standard work schedule. Critical for crunch period monitoring and overtime compliance tracking per labor regulations.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payrollPeriod rdf:type rdf:Property ;
    rdfs:label 'Payroll Period' ;
    rdfs:comment 'Payroll period identifier to which this time entry is assigned (e.g., 2024-01, 2024-W15). Links time entries to specific payroll cycles for compensation processing.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollProcessedFlag rdf:type rdf:Property ;
    rdfs:label 'Payroll Processed Flag' ;
    rdfs:comment 'Indicates whether this time entry has been processed in a payroll run. True once included in payroll, false for pending entries. Prevents duplicate payroll processing.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workforceEventId rdf:type rdf:Property ;
    rdfs:label 'Workforce Event Id' ;
    rdfs:comment 'Unique identifier for the workforce event record. Primary key for the workforce event entity.' ;
    rdfs:domain ind:WorkforceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alt5WorkforceApprovalLevel1EmployeeId rdf:type rdf:Property ;
    rdfs:label 'Alt5 Workforce Approval Level 1 Employee Id' ;
    rdfs:comment 'Identifier of the first-level approver in the approval chain for this workforce event. Null if approval is not required or not yet reached this level.' ;
    rdfs:domain ind:WorkforceEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:alt5WorkforceApprovalLevel2EmployeeId rdf:type rdf:Property ;
    rdfs:label 'Alt5 Workforce Approval Level 2 Employee Id' ;
    rdfs:comment 'Identifier of the second-level approver in the approval chain for this workforce event. Null if approval is not required or not yet reached this level.' ;
    rdfs:domain ind:WorkforceEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:alt5WorkforceFinalApproverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Alt5 Workforce Final Approver Employee Id' ;
    rdfs:comment 'Identifier of the final approver who authorized this workforce event for execution. Typically a senior leader or HR director for significant actions.' ;
    rdfs:domain ind:WorkforceEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:newCompensationId rdf:type rdf:Property ;
    rdfs:label 'New Compensation Id' ;
    rdfs:comment 'Foreign key linking to workforce.compensation. Business justification: Workforce event (promotion, transfer, compensation change) should reference the NEW compensation record created as a result of the event. This links the event to the compensation record it triggered. ' ;
    rdfs:domain ind:WorkforceEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Compensation .

ind:primaryWorkforceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Workforce Employee Id' ;
    rdfs:comment 'Identifier of the employee or contractor to whom this event applies. Links to the employee master record.' ;
    rdfs:domain ind:WorkforceEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryWorkforceGameStudioId rdf:type rdf:Property ;
    rdfs:label 'Primary Workforce Game Studio Id' ;
    rdfs:comment 'Identifier of the game studio the employee worked at before this event. Null for hire events. Tracks studio-to-studio transfers in multi-studio organizations.' ;
    rdfs:domain ind:WorkforceEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GameStudio .

ind:primaryWorkforcePreviousOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Primary Workforce Previous Org Unit Id' ;
    rdfs:comment 'Identifier of the organizational unit the employee belonged to before this event. Null for hire events. Used to track organizational movement history.' ;
    rdfs:domain ind:WorkforceEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:primaryWorkforcePreviousPositionId rdf:type rdf:Property ;
    rdfs:label 'Primary Workforce Previous Position Id' ;
    rdfs:comment 'Identifier of the position held by the employee before this event. Null for hire events. Captures the prior state for transfer, promotion, and role change events.' ;
    rdfs:domain ind:WorkforceEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:quaternaryWorkforceInitiatingManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Workforce Initiating Manager Employee Id' ;
    rdfs:comment 'Identifier of the manager who initiated or requested this workforce event. Captures the originator of the HR action for audit and approval tracking.' ;
    rdfs:domain ind:WorkforceEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quinaryWorkforceHrBusinessPartnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quinary Workforce Hr Business Partner Employee Id' ;
    rdfs:comment 'Identifier of the HR business partner responsible for processing and supporting this workforce event. Links to the HR professional managing the action.' ;
    rdfs:domain ind:WorkforceEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryWorkforceNewManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Workforce New Manager Employee Id' ;
    rdfs:comment 'Identifier of the manager the employee reports to after this event. Null for termination and retirement events. Captures new reporting relationship.' ;
    rdfs:domain ind:WorkforceEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalLevel1Date rdf:type rdf:Property ;
    rdfs:label 'Approval Level 1 Date' ;
    rdfs:comment 'Date on which the first-level approver approved this workforce event. Null if not yet approved at this level.' ;
    rdfs:domain ind:WorkforceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalLevel2Date rdf:type rdf:Property ;
    rdfs:label 'Approval Level 2 Date' ;
    rdfs:comment 'Date on which the second-level approver approved this workforce event. Null if not yet approved at this level.' ;
    rdfs:domain ind:WorkforceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compensationCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Compensation Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for compensation amounts. Applies to both previous and new compensation amounts.' ;
    rdfs:domain ind:WorkforceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Final Approval Date' ;
    rdfs:comment 'Date on which the final approver authorized this workforce event. Marks the completion of the approval workflow.' ;
    rdfs:domain ind:WorkforceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaveEndDate rdf:type rdf:Property ;
    rdfs:label 'Leave End Date' ;
    rdfs:comment 'Planned or actual date on which the leave of absence ends. Only populated for leave_of_absence and return_from_leave event types.' ;
    rdfs:domain ind:WorkforceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaveStartDate rdf:type rdf:Property ;
    rdfs:label 'Leave Start Date' ;
    rdfs:comment 'Date on which the leave of absence begins. Only populated for leave_of_absence event types.' ;
    rdfs:domain ind:WorkforceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaveType rdf:type rdf:Property ;
    rdfs:label 'Leave Type' ;
    rdfs:comment 'Type of leave of absence. Only populated for leave_of_absence event types. Categorizes the nature of the leave for compliance and benefits administration.' ;
    rdfs:domain ind:WorkforceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newCompensationAmount rdf:type rdf:Property ;
    rdfs:label 'New Compensation Amount' ;
    rdfs:comment 'Base compensation amount for the employee after this event. Null for termination and retirement events. Captures compensation changes resulting from the HR action.' ;
    rdfs:domain ind:WorkforceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newEmploymentType rdf:type rdf:Property ;
    rdfs:label 'New Employment Type' ;
    rdfs:comment 'Employment classification assigned to the employee after this event. Null for termination and retirement events. Captures employment type after the HR action.' ;
    rdfs:domain ind:WorkforceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newJobGrade rdf:type rdf:Property ;
    rdfs:label 'New Job Grade' ;
    rdfs:comment 'Job grade or level assigned to the employee after this event. Null for termination and retirement events. Captures grade changes for promotions and demotions.' ;
    rdfs:domain ind:WorkforceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newJobTitle rdf:type rdf:Property ;
    rdfs:label 'New Job Title' ;
    rdfs:comment 'Job title assigned to the employee after this event. Null for termination and retirement events. Captures the new role designation.' ;
    rdfs:domain ind:WorkforceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousCompensationAmount rdf:type rdf:Property ;
    rdfs:label 'Previous Compensation Amount' ;
    rdfs:comment 'Base compensation amount for the employee before this event. Null for hire events. Used to track compensation changes associated with promotions, demotions, and role changes.' ;
    rdfs:domain ind:WorkforceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousEmploymentType rdf:type rdf:Property ;
    rdfs:label 'Previous Employment Type' ;
    rdfs:comment 'Employment classification held by the employee before this event. Null for hire events. Tracks changes in employment status such as contractor to full-time conversion.' ;
    rdfs:domain ind:WorkforceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousJobGrade rdf:type rdf:Property ;
    rdfs:label 'Previous Job Grade' ;
    rdfs:comment 'Job grade or level held by the employee before this event. Null for hire events. Used to track career progression and compensation band changes.' ;
    rdfs:domain ind:WorkforceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousJobTitle rdf:type rdf:Property ;
    rdfs:label 'Previous Job Title' ;
    rdfs:comment 'Job title held by the employee before this event. Null for hire events. Provides human-readable context for role changes and promotions.' ;
    rdfs:domain ind:WorkforceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationType rdf:type rdf:Property ;
    rdfs:label 'Termination Type' ;
    rdfs:comment 'Classification of termination event. Only populated for termination and retirement event types. Distinguishes voluntary resignation from involuntary termination.' ;
    rdfs:domain ind:WorkforceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catalogOfferId rdf:type rdf:Property ;
    rdfs:label 'Catalog Offer Id' ;
    rdfs:comment 'Unique surrogate identifier for this catalog-offer association record. Primary key.' ;
    rdfs:domain ind:CatalogOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:abTestVariantAssignment rdf:type rdf:Property ;
    rdfs:label 'Ab Test Variant Assignment' ;
    rdfs:comment 'A/B test variant identifier for this specific catalog item within the campaign. Enables testing different item selections or pricing strategies within the same campaign framework. May differ from the campaign-level ab_test_variant when testing item-level variations.' ;
    rdfs:domain ind:CatalogOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addedToCampaignTimestamp rdf:type rdf:Property ;
    rdfs:label 'Added To Campaign Timestamp' ;
    rdfs:comment 'Date and time when this catalog item was added to the campaign. Supports dynamic campaign composition where items are added/removed during the campaign lifecycle.' ;
    rdfs:domain ind:CatalogOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:campaignSpecificDiscountValue rdf:type rdf:Property ;
    rdfs:label 'Campaign Specific Discount Value' ;
    rdfs:comment 'The discount or bonus value applied to this specific catalog item within this campaign. May override the catalog item\'s default promo_discount_pct for campaign-specific pricing strategies. Interpretation depends on the campaign\'s discount_type.' ;
    rdfs:domain ind:CatalogOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conversionRateForItem rdf:type rdf:Property ;
    rdfs:label 'Conversion Rate For Item' ;
    rdfs:comment 'Calculated conversion rate (redemption_count / impression_count) for this catalog item within this campaign. Tracks item-level performance to optimize future campaign composition.' ;
    rdfs:domain ind:CatalogOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:displayPriorityInCampaign rdf:type rdf:Property ;
    rdfs:label 'Display Priority In Campaign' ;
    rdfs:comment 'Ranking priority for displaying this catalog item within the campaign\'s offer UI. Lower numbers indicate higher priority. Used when campaigns feature multiple items and need to control presentation order.' ;
    rdfs:domain ind:CatalogOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:impressionCountForItem rdf:type rdf:Property ;
    rdfs:label 'Impression Count For Item' ;
    rdfs:comment 'Cumulative count of how many times this specific catalog item was displayed to players as part of this campaign. Used for campaign performance analytics and A/B testing evaluation.' ;
    rdfs:domain ind:CatalogOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isFeaturedItem rdf:type rdf:Property ;
    rdfs:label 'Is Featured Item' ;
    rdfs:comment 'Indicates whether this catalog item is featured or highlighted within the campaign\'s promotional materials. Featured items receive premium placement and visual emphasis.' ;
    rdfs:domain ind:CatalogOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:redemptionCountForItem rdf:type rdf:Property ;
    rdfs:label 'Redemption Count For Item' ;
    rdfs:comment 'Cumulative count of how many times this specific catalog item was purchased by players through this campaign. Core metric for campaign effectiveness and item performance within campaigns.' ;
    rdfs:domain ind:CatalogOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:removedFromCampaignTimestamp rdf:type rdf:Property ;
    rdfs:label 'Removed From Campaign Timestamp' ;
    rdfs:comment 'Date and time when this catalog item was removed from the campaign. Null if the item is still active in the campaign. Supports dynamic campaign management and performance-based item rotation.' ;
    rdfs:domain ind:CatalogOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:revenueGeneratedForItem rdf:type rdf:Property ;
    rdfs:label 'Revenue Generated For Item' ;
    rdfs:comment 'Total revenue generated from purchases of this catalog item through this campaign. Denominated in the campaign\'s currency_code. Used for ROI analysis and campaign optimization.' ;
    rdfs:domain ind:CatalogOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaderboardEntryId rdf:type rdf:Property ;
    rdfs:label 'Leaderboard Entry Id' ;
    rdfs:comment 'Unique identifier for this leaderboard entry. Primary key.' ;
    rdfs:domain ind:LeaderboardEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonId rdf:type rdf:Property ;
    rdfs:label 'Season Id' ;
    rdfs:comment 'Reference to the game season during which this leaderboard entry was achieved. Null for non-seasonal leaderboards. Critical for seasonal rewards and historical competitive tracking.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Gaming .

ind:entryStatus rdf:type rdf:Property ;
    rdfs:label 'Entry Status' ;
    rdfs:comment 'Current lifecycle status of this leaderboard entry. Active entries are displayed on the leaderboard. Under_review entries are pending anti-cheat validation. Disqualified entries are removed due to cheating. Expired entries are from past seasons/resets.' ;
    rdfs:domain ind:LeaderboardEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:percentile rdf:type rdf:Property ;
    rdfs:label 'Percentile' ;
    rdfs:comment 'The player\'s percentile ranking on this leaderboard (e.g., 95.5 means top 4.5%). Calculated based on total ranked players. Used for player feedback and competitive context.' ;
    rdfs:domain ind:LeaderboardEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rankTier rdf:type rdf:Property ;
    rdfs:label 'Rank Tier' ;
    rdfs:comment 'The competitive tier or bracket the player belongs to based on their rank position (e.g., top 10 = grandmaster, top 100 = master). Used for rewards distribution and player recognition.' ;
    rdfs:domain ind:LeaderboardEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scoreValue rdf:type rdf:Property ;
    rdfs:label 'Score Value' ;
    rdfs:comment 'The player\'s score or metric value that determines their rank on this leaderboard. Could be kills, win rate, completion time, points, etc., depending on the leaderboard\'s ranking_metric.' ;
    rdfs:domain ind:LeaderboardEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submissionCount rdf:type rdf:Property ;
    rdfs:label 'Submission Count' ;
    rdfs:comment 'Number of times the player has submitted a score to this leaderboard. Used to enforce min_matches_played eligibility criteria and track player engagement.' ;
    rdfs:domain ind:LeaderboardEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timestampAchieved rdf:type rdf:Property ;
    rdfs:label 'Timestamp Achieved' ;
    rdfs:comment 'Date and time when the player achieved this score or rank. Used for tie-breaking, historical tracking, and determining eligibility for time-bound rewards.' ;
    rdfs:domain ind:LeaderboardEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dlcPurchaseId rdf:type rdf:Property ;
    rdfs:label 'Dlc Purchase Id' ;
    rdfs:comment 'Unique identifier for this DLC purchase transaction. Primary key for the association.' ;
    rdfs:domain ind:DlcPurchase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activation Timestamp' ;
    rdfs:comment 'Date and time when the player first activated or downloaded the DLC content after purchase. Nullable if purchased but not yet activated. Used for engagement analytics and to distinguish purchased-but-unused content.' ;
    rdfs:domain ind:DlcPurchase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:purchasePricePaid rdf:type rdf:Property ;
    rdfs:label 'Purchase Price Paid' ;
    rdfs:comment 'The actual amount paid by the player for this DLC bundle at the time of purchase. May differ from base_price_usd due to regional pricing, discounts, sales, or promotional offers. Critical for revenue recognition and refund calculations.' ;
    rdfs:domain ind:DlcPurchase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processorEngagementId rdf:type rdf:Property ;
    rdfs:label 'Processor Engagement Id' ;
    rdfs:comment 'Unique identifier for this processor engagement record' ;
    rdfs:domain ind:ProcessorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'Timestamp when this processor engagement record was created in the system.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataTransferMechanism rdf:type rdf:Property ;
    rdfs:label 'Data Transfer Mechanism' ;
    rdfs:comment 'The legal mechanism used to safeguard international data transfers for this specific processor engagement (e.g., EU Commission Adequacy Decision, Standard Contractual Clauses 2021, Binding Corporate Rules). May differ from processor\'s general transfer mechanism based on activity-specific data flows.' ;
    rdfs:domain ind:ProcessorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataVolumeEstimate rdf:type rdf:Property ;
    rdfs:label 'Data Volume Estimate' ;
    rdfs:comment 'Estimated volume or scale of personal data shared with this processor for this processing activity (e.g., 1M player records monthly, 500GB telemetry data daily). Used for risk assessment.' ;
    rdfs:domain ind:ProcessorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyProcessors rdf:type rdf:Property ;
    rdfs:label 'Third Party Processors' ;
    rdfs:comment 'Comma-separated list of named third-party processors engaged for this processing activity (e.g., AWS, Google Cloud Platform, Unity Analytics, AppsFlyer). [Moved from processing_activity: This STRING attribute in processing_activity contains a comma-separated list of processor names, which is a denormalized representation of the M:N relationship. With the processor_engagement association table, this attribute becomes redundant and should be removed to eliminate data duplication and maintain referential integrity through proper foreign keys.]' ;
    rdfs:domain ind:ProcessorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuDeploymentId rdf:type rdf:Property ;
    rdfs:label 'Sku Deployment Id' ;
    rdfs:comment 'Unique identifier for this deployment record. Primary key.' ;
    rdfs:domain ind:SkuDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deploymentNotes rdf:type rdf:Property ;
    rdfs:label 'Deployment Notes' ;
    rdfs:comment 'Internal notes about this specific deployment, including special considerations, dependencies, or operational context.' ;
    rdfs:domain ind:SkuDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActiveBuild rdf:type rdf:Property ;
    rdfs:label 'Is Active Build' ;
    rdfs:comment 'Indicates whether this is the currently active build for this SKU. Explicitly identified in detection phase relationship data. Only one deployment per SKU should have this flag set to true at any time.' ;
    rdfs:domain ind:SkuDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phasedRolloutPercentage rdf:type rdf:Property ;
    rdfs:label 'Phased Rollout Percentage' ;
    rdfs:comment 'The percentage of users receiving this build in a phased rollout strategy. Explicitly identified in detection phase relationship data. Ranges from 0.00 to 100.00, enabling gradual deployment to mitigate risk.' ;
    rdfs:domain ind:SkuDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:policyApplicabilityId rdf:type rdf:Property ;
    rdfs:label 'Policy Applicability Id' ;
    rdfs:comment 'Unique identifier for this policy-jurisdiction applicability record. Primary key.' ;
    rdfs:domain ind:PolicyApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableTerritories rdf:type rdf:Property ;
    rdfs:label 'Applicable Territories' ;
    rdfs:comment 'Comma-separated list of jurisdiction codes or territory names where this policy is enforceable (e.g., USA, GBR, DEU, JPN, Global). [Moved from compliance_policy: This comma-separated list of jurisdiction codes in compliance_policy is a denormalized representation of the many-to-many relationship. With the policy_applicability association, this becomes redundant and should be derived via join rather than stored as a text list.]' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionSpecificAddendumUrl rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Specific Addendum Url' ;
    rdfs:comment 'URL or document reference to any jurisdiction-specific addendum, local language translation, or regulatory variation of the policy required for this jurisdiction.' ;
    rdfs:domain ind:PolicyApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localApprovalAuthority rdf:type rdf:Property ;
    rdfs:label 'Local Approval Authority' ;
    rdfs:comment 'Name or role of the local legal or compliance authority who approved this policy for deployment in this jurisdiction (e.g., EU Data Protection Officer, APAC General Counsel).' ;
    rdfs:domain ind:PolicyApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Local Approval Date' ;
    rdfs:comment 'Date when this policy was approved by local legal counsel or regional compliance authority for use in this jurisdiction.' ;
    rdfs:domain ind:PolicyApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:localRegulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Local Regulatory Reference' ;
    rdfs:comment 'Citation of the specific local law, regulation, or regulatory guidance that mandates or influences this policy in this jurisdiction (e.g., California CCPA, German JMStV, Chinese PIPL).' ;
    rdfs:domain ind:PolicyApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamAssetLicenseId rdf:type rdf:Property ;
    rdfs:label 'Team Asset License Id' ;
    rdfs:comment 'Unique identifier for this team-asset licensing relationship. Primary key.' ;
    rdfs:domain ind:TeamAssetLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licenseTerms rdf:type rdf:Property ;
    rdfs:label 'License Terms' ;
    rdfs:comment 'Legal terms and conditions governing the team\'s usage of this asset, including permitted contexts (competitive play, broadcast, social media), geographic restrictions, and exclusivity clauses. Sourced from detection phase relationship data.' ;
    rdfs:domain ind:TeamAssetLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logoAssetUrl rdf:type rdf:Property ;
    rdfs:label 'Logo Asset Url' ;
    rdfs:comment 'URL or reference path to the teams official logo asset stored in the content delivery network (CDN) or digital asset management system. Used for broadcasts, websites, and marketing materials. [Moved from esports_team: This attribute (logo_asset_url) in esports_team represents a specific team-asset relationship and should be modeled as a license record in the association. A team may have multiple logo variants (primary, alternate, sponsor co-branded) with different usage rights and approval dates. Moving this to the association allows tracking of multiple logo licenses with proper versioning and rights management.]' ;
    rdfs:domain ind:TeamAssetLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageContext rdf:type rdf:Property ;
    rdfs:label 'Usage Context' ;
    rdfs:comment 'Specific contexts where the team is permitted to use this asset (competitive play, broadcast, social media, merchandise, marketing). Enforces licensing restrictions.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRightsEndDate rdf:type rdf:Property ;
    rdfs:label 'Usage Rights End Date' ;
    rdfs:comment 'The date when the team\'s usage rights for this asset expire. Used to enforce license renewal workflows and prevent unauthorized usage. Sourced from detection phase relationship data.' ;
    rdfs:domain ind:TeamAssetLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:usageRightsStartDate rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Start Date' ;
    rdfs:comment 'The date when the team\'s usage rights for this asset become active. Critical for tournament eligibility and brand compliance. Sourced from detection phase relationship data.' ;
    rdfs:domain ind:TeamAssetLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:titleCertSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Title Cert Submission Id' ;
    rdfs:comment 'Primary key for title_cert_submission' ;
    rdfs:domain ind:TitleCertSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Cert Submission Id' ;
    rdfs:comment 'Unique identifier for this certification submission record. Primary key.' ;
    rdfs:domain ind:TitleCertSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlatformCertSubmission .

ind:assignedQaLead rdf:type rdf:Property ;
    rdfs:label 'Assigned Qa Lead' ;
    rdfs:comment 'The QA lead or certification specialist assigned to manage this submission and coordinate with the platform holder.' ;
    rdfs:domain ind:TitleCertSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Completion Date' ;
    rdfs:comment 'The estimated date by which certification is expected to be completed, based on platform holder review duration and remediation timelines.' ;
    rdfs:domain ind:TitleCertSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:platformHolderTicketReference rdf:type rdf:Property ;
    rdfs:label 'Platform Holder Ticket Reference' ;
    rdfs:comment 'The ticket or case ID assigned by the platform holder\'s certification portal for tracking this submission.' ;
    rdfs:domain ind:TitleCertSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionCount rdf:type rdf:Property ;
    rdfs:label 'Resubmission Count' ;
    rdfs:comment 'The number of times this game title has been resubmitted for certification against this checklist version after initial failure. Tracks remediation cycles.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waiverCount rdf:type rdf:Property ;
    rdfs:label 'Waiver Count' ;
    rdfs:comment 'The number of certification requirements for which waivers or exceptions were granted by the platform holder for this specific submission.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ipUsageId rdf:type rdf:Property ;
    rdfs:label 'Ip Usage Id' ;
    rdfs:comment 'Primary key uniquely identifying each title-IP usage relationship record' ;
    rdfs:domain ind:IpUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumGuaranteePaid rdf:type rdf:Property ;
    rdfs:label 'Minimum Guarantee Paid' ;
    rdfs:comment 'The minimum guarantee amount (in USD) paid specifically for this title-IP usage. Null if no MG applies or if using standard MG from licensed_ip.' ;
    rdfs:domain ind:IpUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueAttributed rdf:type rdf:Property ;
    rdfs:label 'Revenue Attributed' ;
    rdfs:comment 'The cumulative revenue (in USD) attributed to this specific IP usage within this game title. Used for royalty calculation and IP ROI analysis. This is relationship-specific because revenue attribution varies by title-IP combination.' ;
    rdfs:domain ind:IpUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyRate rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate' ;
    rdfs:comment 'The royalty rate (as decimal) negotiated specifically for this title-IP combination. May differ from the standard_royalty_rate in licensed_ip due to title-specific negotiations, volume discounts, or strategic partnerships.' ;
    rdfs:domain ind:IpUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:territoryOverride rdf:type rdf:Property ;
    rdfs:label 'Territory Override' ;
    rdfs:comment 'Comma-separated list of territories where this specific title-IP usage has different terms than the base licensed_ip territory_restrictions. Null if no override applies.' ;
    rdfs:domain ind:IpUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageStatus rdf:type rdf:Property ;
    rdfs:label 'Usage Status' ;
    rdfs:comment 'Current operational status of this IP usage relationship. Tracks lifecycle state for compliance and operational management.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studioContributionId rdf:type rdf:Property ;
    rdfs:label 'Studio Contribution Id' ;
    rdfs:comment 'Unique surrogate identifier for this title-studio contribution relationship. Primary key.' ;
    rdfs:domain ind:StudioContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetAllocatedUsd rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated Usd' ;
    rdfs:comment 'Total budget allocated in US dollars for this studio\'s work on this title. Used for financial planning and cost tracking. Sourced from financial planning system.' ;
    rdfs:domain ind:StudioContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contributionPercentage rdf:type rdf:Property ;
    rdfs:label 'Contribution Percentage' ;
    rdfs:comment 'Estimated percentage of total development effort contributed by this studio to this title. Used for resource allocation planning, budget distribution, and credit attribution. Sum across all studios for a title may exceed 100% for overlapping work. Sourced from project planning and financial systems.' ;
    rdfs:domain ind:StudioContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contributionStatus rdf:type rdf:Property ;
    rdfs:label 'Contribution Status' ;
    rdfs:comment 'Current lifecycle status of this studio\'s contribution to this title. Planned indicates future engagement; Active indicates ongoing work; On Hold indicates temporarily paused; Completed indicates work finished; Cancelled indicates engagement terminated before completion.' ;
    rdfs:domain ind:StudioContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developmentRole rdf:type rdf:Property ;
    rdfs:label 'Development Role' ;
    rdfs:comment 'The specific role this studio plays in the development of this title. Lead Developer owns primary development; Co-Developer shares core development; Art Outsourcing provides art assets; QA Support provides testing; Port Studio handles platform ports; Live Ops Support manages post-launch operations; DLC Developer creates downloadable content; Technical Support provides engineering assistance. Sourced from project management system and contract agreements.' ;
    rdfs:domain ind:StudioContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipRightsShare rdf:type rdf:Property ;
    rdfs:label 'Ip Rights Share' ;
    rdfs:comment 'Intellectual property ownership arrangement for this studio\'s contribution to this title. None indicates work-for-hire with no IP retention; Shared indicates co-ownership arrangement; Full indicates studio retains full IP (rare, typically only for licensed IP); Negotiated indicates custom arrangement defined in contract. Critical for legal and financial reporting.' ;
    rdfs:domain ind:StudioContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDeliverable rdf:type rdf:Property ;
    rdfs:label 'Primary Deliverable' ;
    rdfs:comment 'Description of the primary deliverable or scope of work for this studio on this title. Examples: \'Character models and animations\', \'PlayStation 5 port\', \'Season 3 content pack\', \'Multiplayer backend services\'. Provides human-readable context for the contribution.' ;
    rdfs:domain ind:StudioContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipComplianceObligationId rdf:type rdf:Property ;
    rdfs:label 'Ip Compliance Obligation Id' ;
    rdfs:comment 'Unique identifier for this IP-obligation compliance relationship record. Primary key.' ;
    rdfs:domain ind:IpComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditFindings rdf:type rdf:Property ;
    rdfs:label 'Audit Findings' ;
    rdfs:comment 'Summary of findings from the most recent audit of this IP-obligation pair. Documents specific compliance gaps, control weaknesses, or validation results.' ;
    rdfs:domain ind:IpComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Exemption Expiration Date' ;
    rdfs:comment 'Date when the exemption expires and the IP must achieve full compliance. NULL if no exemption or exemption is permanent.' ;
    rdfs:domain ind:IpComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exemptionGranted rdf:type rdf:Property ;
    rdfs:label 'Exemption Granted' ;
    rdfs:comment 'Indicates whether this IP asset has been granted an exemption from this obligation by the governing body or internal compliance authority.' ;
    rdfs:domain ind:IpComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationPlanUrl rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan Url' ;
    rdfs:comment 'URL or file path to the remediation plan document for addressing non-compliance of this IP with this obligation. NULL if compliant or no plan exists.' ;
    rdfs:domain ind:IpComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catalogPromotionEligibilityId rdf:type rdf:Property ;
    rdfs:label 'Catalog Promotion Eligibility Id' ;
    rdfs:comment 'Unique surrogate identifier for each catalog item-promotion eligibility record' ;
    rdfs:domain ind:CatalogPromotionEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addedToPromotionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Added To Promotion Timestamp' ;
    rdfs:comment 'Date and time when this catalog item was added to the promotion\'s eligible item list, supporting audit trail and promotional planning analysis' ;
    rdfs:domain ind:CatalogPromotionEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:displayOrderInPromotion rdf:type rdf:Property ;
    rdfs:label 'Display Order In Promotion' ;
    rdfs:comment 'Sequence number controlling the visual presentation order of this catalog item within the promotion\'s storefront display' ;
    rdfs:domain ind:CatalogPromotionEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Effective Discount Percentage' ;
    rdfs:comment 'The actual discount percentage applied to this specific catalog item within this promotion, which may differ from the promotion\'s default discount based on item-specific rules or overrides' ;
    rdfs:domain ind:CatalogPromotionEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:featuredFlag rdf:type rdf:Property ;
    rdfs:label 'Featured Flag' ;
    rdfs:comment 'Indicates whether this catalog item is designated as a featured or hero item within this promotion, receiving prominent placement in promotional materials' ;
    rdfs:domain ind:CatalogPromotionEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemSpecificRedemptionCount rdf:type rdf:Property ;
    rdfs:label 'Item Specific Redemption Count' ;
    rdfs:comment 'Cumulative count of how many times this specific catalog item was purchased using this specific promotion, enabling item-level promotional performance analysis' ;
    rdfs:domain ind:CatalogPromotionEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:itemSpecificRevenueGenerated rdf:type rdf:Property ;
    rdfs:label 'Item Specific Revenue Generated' ;
    rdfs:comment 'Total gross revenue generated from purchases of this catalog item through this promotion, tracking the revenue contribution of each item-promotion combination' ;
    rdfs:domain ind:CatalogPromotionEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionPriorityRank rdf:type rdf:Property ;
    rdfs:label 'Promotion Priority Rank' ;
    rdfs:comment 'Numeric ranking determining the display order and priority of this catalog item within the promotion\'s featured items list' ;
    rdfs:domain ind:CatalogPromotionEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:removedFromPromotionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Removed From Promotion Timestamp' ;
    rdfs:comment 'Date and time when this catalog item was removed from the promotion (if applicable), enabling tracking of promotional composition changes during the campaign lifecycle' ;
    rdfs:domain ind:CatalogPromotionEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:teamBrandLicenseId rdf:type rdf:Property ;
    rdfs:label 'Team Brand License Id' ;
    rdfs:comment 'Unique surrogate identifier for each team brand licensing agreement record' ;
    rdfs:domain ind:TeamBrandLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Code' ;
    rdfs:comment 'External reference to the legal contract document or master licensing agreement that governs the terms of this team brand license.' ;
    rdfs:domain ind:TeamBrandLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensingEndDate rdf:type rdf:Property ;
    rdfs:label 'Licensing End Date' ;
    rdfs:comment 'The expiration or termination date of the brand licensing agreement for this MTX item. Sales after this date do not accrue royalties unless the agreement is renewed.' ;
    rdfs:domain ind:TeamBrandLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licensingStartDate rdf:type rdf:Property ;
    rdfs:label 'Licensing Start Date' ;
    rdfs:comment 'The effective start date of the brand licensing agreement for this MTX item. Sales before this date do not accrue royalties to the team.' ;
    rdfs:domain ind:TeamBrandLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueShareAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Amount' ;
    rdfs:comment 'Cumulative revenue share amount (in USD) paid or owed to the esports team for this specific MTX item under this licensing agreement. Calculated as sales revenue × royalty_percentage.' ;
    rdfs:domain ind:TeamBrandLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyPercentage rdf:type rdf:Property ;
    rdfs:label 'Royalty Percentage' ;
    rdfs:comment 'The percentage of net revenue from this MTX item that is paid to the esports team as a royalty for licensing their brand. Varies by team tier, item type, and negotiated contract terms.' ;
    rdfs:domain ind:TeamBrandLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesCount rdf:type rdf:Property ;
    rdfs:label 'Sales Count' ;
    rdfs:comment 'Cumulative count of units sold for this specific MTX item attributed to this team brand license. Used for performance tracking and royalty calculation verification.' ;
    rdfs:domain ind:TeamBrandLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campaignExposureId rdf:type rdf:Property ;
    rdfs:label 'Campaign Exposure Id' ;
    rdfs:comment 'Unique identifier for each campaign exposure event. Primary key for the campaign_exposure association.' ;
    rdfs:domain ind:CampaignExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creativeId rdf:type rdf:Property ;
    rdfs:label 'Creative Id' ;
    rdfs:comment 'Identifier for the specific creative asset shown to the player during this exposure. Used for creative-level performance analysis and A/B testing.' ;
    rdfs:domain ind:CampaignExposure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdCreative .

ind:impressionId rdf:type rdf:Property ;
    rdfs:label 'Impression Id' ;
    rdfs:comment 'Unique identifier for the ad impression from the attribution partner (AppsFlyer, Adjust) or ad platform. Used for reconciliation with ad platform reporting and fraud detection.' ;
    rdfs:domain ind:CampaignExposure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdImpression .

ind:placementId rdf:type rdf:Property ;
    rdfs:label 'Placement Id' ;
    rdfs:comment 'Identifier for the ad placement or inventory position where the creative was shown. Used for placement-level performance optimization.' ;
    rdfs:domain ind:CampaignExposure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdPlacement .

ind:attributedFlag rdf:type rdf:Property ;
    rdfs:label 'Attributed Flag' ;
    rdfs:comment 'Indicates whether this exposure received attribution credit for a conversion under the current attribution model (last-touch, first-touch, linear, time-decay, or data-driven). Used for campaign ROI calculation and budget allocation decisions.' ;
    rdfs:domain ind:CampaignExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conversionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Conversion Timestamp' ;
    rdfs:comment 'Date and time when the player completed the target conversion action (install, registration, purchase, re-engagement) attributed to this exposure. Nullable if no conversion occurred within the attribution window. Used for conversion rate and time-to-conversion analysis.' ;
    rdfs:domain ind:CampaignExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exposureChannel rdf:type rdf:Property ;
    rdfs:label 'Exposure Channel' ;
    rdfs:comment 'The specific marketing channel through which the player was exposed to the campaign. Used for channel-level attribution and cross-channel journey analysis.' ;
    rdfs:domain ind:CampaignExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exposure Timestamp' ;
    rdfs:comment 'Date and time when the player was exposed to the campaign creative. Used for time-to-conversion analysis, multi-touch attribution sequencing, and frequency capping windows.' ;
    rdfs:domain ind:CampaignExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tournamentPromotionId rdf:type rdf:Property ;
    rdfs:label 'Tournament Promotion Id' ;
    rdfs:comment 'Unique identifier for this specific promotion-tournament activation record. Primary key.' ;
    rdfs:domain ind:TournamentPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activationStatus rdf:type rdf:Property ;
    rdfs:label 'Activation Status' ;
    rdfs:comment 'Current status of this promotion activation for this tournament: scheduled (not yet started), active (currently running), paused (temporarily disabled), completed (ended normally), cancelled (terminated early).' ;
    rdfs:domain ind:TournamentPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionCount rdf:type rdf:Property ;
    rdfs:label 'Conversion Count' ;
    rdfs:comment 'Number of times players redeemed this promotion during this specific tournament. Tournament-specific conversion metric.' ;
    rdfs:domain ind:TournamentPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueGenerated rdf:type rdf:Property ;
    rdfs:label 'Revenue Generated' ;
    rdfs:comment 'Total gross revenue generated from this promotion during this specific tournament. Tournament-specific revenue attribution for promotional ROI analysis.' ;
    rdfs:domain ind:TournamentPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:obligationApplicabilityId rdf:type rdf:Property ;
    rdfs:label 'Obligation Applicability Id' ;
    rdfs:comment 'Unique identifier for this obligation-jurisdiction applicability record. Primary key.' ;
    rdfs:domain ind:ObligationApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enforcementPriority rdf:type rdf:Property ;
    rdfs:label 'Enforcement Priority' ;
    rdfs:comment 'Priority level for enforcement of this obligation in this jurisdiction, reflecting local regulatory focus and risk assessment. Values: Critical, High, Medium, Low.' ;
    rdfs:domain ind:ObligationApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localComplianceOwner rdf:type rdf:Property ;
    rdfs:label 'Local Compliance Owner' ;
    rdfs:comment 'Name or identifier of the individual or team responsible for ensuring compliance with this obligation in this specific jurisdiction. May be a regional compliance manager.' ;
    rdfs:domain ind:ObligationApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localInterpretationNotes rdf:type rdf:Property ;
    rdfs:label 'Local Interpretation Notes' ;
    rdfs:comment 'Free-text notes capturing jurisdiction-specific interpretation, implementation guidance, or local nuances in how this obligation is enforced or applied in this jurisdiction.' ;
    rdfs:domain ind:ObligationApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Local Penalty Amount' ;
    rdfs:comment 'Maximum financial penalty amount in local currency for non-compliance with this obligation in this jurisdiction. May differ from the global maximum penalty due to local enforcement practices.' ;
    rdfs:domain ind:ObligationApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storefrontCampaignId rdf:type rdf:Property ;
    rdfs:label 'Storefront Campaign Id' ;
    rdfs:comment 'Unique identifier for this storefront-campaign placement record. Primary key.' ;
    rdfs:domain ind:StorefrontCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attributionLinkOverride rdf:type rdf:Property ;
    rdfs:label 'Attribution Link Override' ;
    rdfs:comment 'Storefront-specific attribution tracking URL or deep link that overrides the campaign-level attribution link to enable storefront-level performance tracking.' ;
    rdfs:domain ind:StorefrontCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coMarketingAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Co Marketing Agreement Flag' ;
    rdfs:comment 'Indicates whether a co-marketing agreement with the platform holder (Sony, Microsoft, Nintendo, Valve, etc.) is in place for this campaign on this storefront, which may include cost-sharing or featured placement.' ;
    rdfs:domain ind:StorefrontCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:featuredPlacementSecured rdf:type rdf:Property ;
    rdfs:label 'Featured Placement Secured' ;
    rdfs:comment 'Indicates whether featured or premium placement (homepage banner, featured carousel, etc.) has been secured for this campaign on this storefront.' ;
    rdfs:domain ind:StorefrontCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storefrontSpecificCreativeUrl rdf:type rdf:Property ;
    rdfs:label 'Storefront Specific Creative Url' ;
    rdfs:comment 'URL or reference to creative assets customized for this storefront, accounting for platform-specific requirements (aspect ratios, file formats, content policies).' ;
    rdfs:domain ind:StorefrontCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetingRules rdf:type rdf:Property ;
    rdfs:label 'Targeting Rules' ;
    rdfs:comment 'Platform-specific targeting configuration for this campaign on this storefront, such as device type filters, OS version requirements, or storefront-specific audience segments.' ;
    rdfs:domain ind:StorefrontCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeListingAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Creative Listing Assignment Id' ;
    rdfs:comment 'Unique identifier for this creative-listing assignment record. Primary key.' ;
    rdfs:domain ind:CreativeListingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:abTestGroup rdf:type rdf:Property ;
    rdfs:label 'Ab Test Group' ;
    rdfs:comment 'Identifier for the A/B test group or experiment this creative-listing pairing belongs to. Enables grouping of related test variants for performance comparison.' ;
    rdfs:domain ind:CreativeListingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeListingVariant rdf:type rdf:Property ;
    rdfs:label 'Creative Listing Variant' ;
    rdfs:comment 'Identifier for the specific listing variant being tested with this creative (e.g., VARIANT_A, VARIANT_B, CONTROL). Used to track which listing presentation is paired with which creative in A/B tests.' ;
    rdfs:domain ind:CreativeListingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impressionToListingViewRate rdf:type rdf:Property ;
    rdfs:label 'Impression To Listing View Rate' ;
    rdfs:comment 'Conversion rate from ad impression to storefront listing page view for this specific creative-listing pairing. Key performance metric for creative effectiveness in driving traffic.' ;
    rdfs:domain ind:CreativeListingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:listingViewToInstallRate rdf:type rdf:Property ;
    rdfs:label 'Listing View To Install Rate' ;
    rdfs:comment 'Conversion rate from listing page view to game install for this specific creative-listing pairing. Measures the combined effectiveness of creative messaging and listing presentation.' ;
    rdfs:domain ind:CreativeListingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testEndDate rdf:type rdf:Property ;
    rdfs:label 'Test End Date' ;
    rdfs:comment 'Date when this creative-listing assignment was deactivated or the test concluded. Null if the assignment is still active. Used to calculate test duration and finalize performance metrics.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testStartDate rdf:type rdf:Property ;
    rdfs:label 'Test Start Date' ;
    rdfs:comment 'Date when this creative-listing assignment was activated for testing or campaign deployment. Marks the beginning of performance tracking for this pairing.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalInstalls rdf:type rdf:Property ;
    rdfs:label 'Total Installs' ;
    rdfs:comment 'Total number of game installs attributed to this creative-listing pairing. Final conversion metric for UA campaign effectiveness.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalListingViews rdf:type rdf:Property ;
    rdfs:label 'Total Listing Views' ;
    rdfs:comment 'Total number of storefront listing page views attributed to this creative-listing pairing. Measures traffic driven by the creative to the specific listing.' ;
    rdfs:domain ind:CreativeListingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tournamentAssetUsageId rdf:type rdf:Property ;
    rdfs:label 'Tournament Asset Usage Id' ;
    rdfs:comment 'Unique identifier for this tournament asset usage record. Primary key.' ;
    rdfs:domain ind:TournamentAssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:displayDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Display Duration Seconds' ;
    rdfs:comment 'Duration in seconds that the asset is displayed or used during the tournament broadcast or event. Null for static assets without time constraints. Identified in detection phase.' ;
    rdfs:domain ind:TournamentAssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:placementLocation rdf:type rdf:Property ;
    rdfs:label 'Placement Location' ;
    rdfs:comment 'Physical or virtual location where the asset is placed (e.g., top-right overlay, center stage screen, pre-match intro, post-match recap). Identified in detection phase.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Rights Clearance Status' ;
    rdfs:comment 'Status of rights clearance for using this asset in this specific tournament context. Critical for legal compliance and sponsor contract fulfillment. Identified in detection phase.' ;
    rdfs:domain ind:TournamentAssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorAttribution rdf:type rdf:Property ;
    rdfs:label 'Sponsor Attribution' ;
    rdfs:comment 'Sponsor or brand associated with this asset usage, used for sponsor deliverable tracking and reporting. Null if not sponsor-related. Identified in detection phase.' ;
    rdfs:domain ind:TournamentAssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageTimestamp rdf:type rdf:Property ;
    rdfs:label 'Usage Timestamp' ;
    rdfs:comment 'Timestamp when the asset was deployed or first used in the tournament. Used for audit trail and sponsor reporting. Identified in detection phase.' ;
    rdfs:domain ind:TournamentAssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:experimentJurisdictionConfigurationId rdf:type rdf:Property ;
    rdfs:label 'Experiment Jurisdiction Configuration Id' ;
    rdfs:comment 'Unique identifier for this experiment-jurisdiction configuration record. Primary key.' ;
    rdfs:domain ind:ExperimentJurisdictionConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modifiedDate rdf:type rdf:Property ;
    rdfs:label 'Modified Date' ;
    rdfs:comment 'Timestamp when this experiment-jurisdiction configuration record was last modified.' ;
    rdfs:domain ind:ExperimentJurisdictionConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Status' ;
    rdfs:comment 'Current regulatory approval status for running this experiment in this jurisdiction. Critical for jurisdictions with loot box regulations (Belgium, Netherlands) or content restrictions that may affect experiment design.' ;
    rdfs:domain ind:ExperimentJurisdictionConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeTestAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Creative Test Assignment Id' ;
    rdfs:comment 'Unique identifier for this creative-to-experiment assignment record. Primary key.' ;
    rdfs:domain ind:CreativeTestAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedBy rdf:type rdf:Property ;
    rdfs:label 'Assigned By' ;
    rdfs:comment 'Name or identifier of the marketing team member who assigned this creative to this experiment variant. Used for accountability and workflow tracking.' ;
    rdfs:domain ind:CreativeTestAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Date' ;
    rdfs:comment 'Date when this creative was assigned to this experiment variant in the test management system. Distinct from test_start_date (when it began serving).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:impressionsAllocated rdf:type rdf:Property ;
    rdfs:label 'Impressions Allocated' ;
    rdfs:comment 'Number of ad impressions allocated to this creative within this experiment variant. Used for traffic allocation tracking and performance normalization.' ;
    rdfs:domain ind:CreativeTestAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isAbTestControl rdf:type rdf:Property ;
    rdfs:label 'Is Ab Test Control' ;
    rdfs:comment 'Boolean flag indicating whether this creative is the control variant in an A/B test. True if control, false if treatment or not part of a test. [Moved from ad_creative: This boolean flag indicates control status, but control designation is experiment-specific. The same creative can be control in one test and a treatment variant in another. This should be derived from variant_label in the association, not stored on the creative.]' ;
    rdfs:domain ind:CreativeTestAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:variantLabel rdf:type rdf:Property ;
    rdfs:label 'Variant Label' ;
    rdfs:comment 'The experiment variant identifier for this creative (e.g., control, variant_A, variant_B, treatment_1). Identifies which arm of the experiment this creative represents.' ;
    rdfs:domain ind:CreativeTestAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationTestRunId rdf:type rdf:Property ;
    rdfs:label 'Certification Test Run Id' ;
    rdfs:comment 'Unique identifier for this certification test run record. Primary key.' ;
    rdfs:domain ind:CertificationTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:advisoryFailureCount rdf:type rdf:Property ;
    rdfs:label 'Advisory Failure Count' ;
    rdfs:comment 'The number of advisory (non-blocking) requirements that failed in this test run.' ;
    rdfs:domain ind:CertificationTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mandatoryPassCount rdf:type rdf:Property ;
    rdfs:label 'Mandatory Pass Count' ;
    rdfs:comment 'The number of mandatory requirements that passed in this test run.' ;
    rdfs:domain ind:CertificationTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:platformSubmissionReference rdf:type rdf:Property ;
    rdfs:label 'Platform Submission Reference' ;
    rdfs:comment 'The external submission identifier or tracking number assigned by the platform holder for this certification test run.' ;
    rdfs:domain ind:CertificationTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionNumber rdf:type rdf:Property ;
    rdfs:label 'Resubmission Number' ;
    rdfs:comment 'The sequential resubmission attempt number for this build-checklist pairing (1 for first submission, 2 for first resubmission, etc.).' ;
    rdfs:domain ind:CertificationTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Test Completed Timestamp' ;
    rdfs:comment 'The exact date and time (UTC) when certification testing was completed for this build-checklist pairing.' ;
    rdfs:domain ind:CertificationTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:testStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Test Started Timestamp' ;
    rdfs:comment 'The exact date and time (UTC) when certification testing began for this build-checklist pairing.' ;
    rdfs:domain ind:CertificationTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceAllocationId rdf:type rdf:Property ;
    rdfs:label 'Compliance Allocation Id' ;
    rdfs:comment 'Unique identifier for this compliance allocation record. Primary key.' ;
    rdfs:domain ind:ComplianceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Effective Date' ;
    rdfs:comment 'Date when this compliance obligation was assigned to this cost center. Supports historical tracking of compliance responsibility changes.' ;
    rdfs:domain ind:ComplianceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationEndDate rdf:type rdf:Property ;
    rdfs:label 'Allocation End Date' ;
    rdfs:comment 'Date when this compliance obligation assignment to this cost center ends or ended. NULL for ongoing allocations. Supports organizational restructuring and compliance responsibility transfers.' ;
    rdfs:domain ind:ComplianceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Compliance Budget Amount' ;
    rdfs:comment 'Budget amount allocated by this cost center specifically for compliance activities related to this regulatory obligation. Represents the financial resources dedicated to meeting this specific obligation.' ;
    rdfs:domain ind:ComplianceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Assessment Date' ;
    rdfs:comment 'Date when this cost center was last assessed for compliance with this specific regulatory obligation. Supports audit trail and assessment frequency tracking.' ;
    rdfs:domain ind:ComplianceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsibleOfficer rdf:type rdf:Property ;
    rdfs:label 'Responsible Officer' ;
    rdfs:comment 'Name or identifier of the individual within this cost center who is responsible for ensuring compliance with this specific regulatory obligation. May differ from the cost center manager.' ;
    rdfs:domain ind:ComplianceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskMitigationPlan rdf:type rdf:Property ;
    rdfs:label 'Risk Mitigation Plan' ;
    rdfs:comment 'Description of the specific risk mitigation plan or compliance approach this cost center has implemented for this regulatory obligation. Captures cost center-specific compliance strategies.' ;
    rdfs:domain ind:ComplianceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignPromoDistributionId rdf:type rdf:Property ;
    rdfs:label 'Campaign Promo Distribution Id' ;
    rdfs:comment 'Unique identifier for this campaign-promo code distribution record. Primary key.' ;
    rdfs:domain ind:CampaignPromoDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetSegmentId rdf:type rdf:Property ;
    rdfs:label 'Target Segment Id' ;
    rdfs:comment 'The player segment targeted for this specific campaign-code pairing. Same code may target different segments when distributed through different campaigns (e.g., at-risk players in winback campaign, active players in upsell campaign).' ;
    rdfs:domain ind:CampaignPromoDistribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:actualDistributionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Distribution Timestamp' ;
    rdfs:comment 'The actual timestamp when this promo code was distributed through this campaign. Used for performance analysis and attribution.' ;
    rdfs:domain ind:CampaignPromoDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:distributionStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Status' ;
    rdfs:comment 'Current operational status of this campaign-code distribution. Allows independent lifecycle management of each campaign-code pairing.' ;
    rdfs:domain ind:CampaignPromoDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionCountFromCampaign rdf:type rdf:Property ;
    rdfs:label 'Redemption Count From Campaign' ;
    rdfs:comment 'The number of redemptions of this promo code that are attributed to this specific campaign distribution. Enables campaign ROI measurement and channel performance comparison.' ;
    rdfs:domain ind:CampaignPromoDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDiscountAttributedUsd rdf:type rdf:Property ;
    rdfs:label 'Total Discount Attributed Usd' ;
    rdfs:comment 'The cumulative discount amount in USD attributed to redemptions from this campaign-code distribution. Used for campaign cost tracking and ROI calculation.' ;
    rdfs:domain ind:CampaignPromoDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storefrontReleaseId rdf:type rdf:Property ;
    rdfs:label 'Storefront Release Id' ;
    rdfs:comment 'Unique surrogate identifier for each storefront release record. Primary key.' ;
    rdfs:domain ind:StorefrontRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:delistingDate rdf:type rdf:Property ;
    rdfs:label 'Delisting Date' ;
    rdfs:comment 'Date when this game was delisted or removed from this storefront, if applicable.' ;
    rdfs:domain ind:StorefrontRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:listingUrl rdf:type rdf:Property ;
    rdfs:label 'Listing Url' ;
    rdfs:comment 'The public URL of the game listing page on this storefront.' ;
    rdfs:domain ind:StorefrontRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueShareOverridePct rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Override Pct' ;
    rdfs:comment 'Project-specific revenue share percentage negotiated with this storefront, if different from the storefronts standard revenue_share_percentage. Null if using standard terms.' ;
    rdfs:domain ind:StorefrontRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storefrontSku rdf:type rdf:Property ;
    rdfs:label 'Storefront Sku' ;
    rdfs:comment 'The storefront-specific SKU or product identifier assigned by the platform holder for this game on this storefront.' ;
    rdfs:domain ind:StorefrontRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developerComplianceId rdf:type rdf:Property ;
    rdfs:label 'Developer Compliance Id' ;
    rdfs:comment 'Unique identifier for this developer account compliance record. Primary key.' ;
    rdfs:domain ind:DeveloperCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditDate rdf:type rdf:Property ;
    rdfs:label 'Audit Date' ;
    rdfs:comment 'Date of the most recent audit of this developer account\'s compliance with this specific regulatory obligation. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:DeveloperCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evidenceDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Evidence Document Url' ;
    rdfs:comment 'URL or file path to documentation evidencing this developer account\'s compliance with this regulatory obligation. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:DeveloperCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionReason rdf:type rdf:Property ;
    rdfs:label 'Exemption Reason' ;
    rdfs:comment 'Justification for why this developer account is exempt from this regulatory obligation, if applicable.' ;
    rdfs:domain ind:DeveloperCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleContact rdf:type rdf:Property ;
    rdfs:label 'Responsible Contact' ;
    rdfs:comment 'Name or identifier of the individual responsible for ensuring this developer account\'s compliance with this specific obligation. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:DeveloperCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectAllocationId rdf:type rdf:Property ;
    rdfs:label 'Project Allocation Id' ;
    rdfs:comment 'Unique identifier for this project allocation record. Primary key for the association.' ;
    rdfs:domain ind:ProjectAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billableRate rdf:type rdf:Property ;
    rdfs:label 'Billable Rate' ;
    rdfs:comment 'Hourly or daily rate used to calculate the capitalizable labor cost for this employee on this project. May differ from base salary due to overhead allocation, benefits loading, or transfer pricing between studios. Used in asset_under_construction_balance calculations.' ;
    rdfs:domain ind:ProjectAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalizationEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Capitalization Eligible Flag' ;
    rdfs:comment 'Boolean flag indicating whether this employee\'s work on this project qualifies for capitalization under GAAP/IFRS. Determined by project phase, role type, and accounting rules. Only eligible allocations contribute to asset_under_construction_balance.' ;
    rdfs:domain ind:ProjectAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:role rdf:type rdf:Property ;
    rdfs:label 'Role' ;
    rdfs:comment 'The specific role or function the employee performs on this capital project (e.g., lead_engineer, senior_artist, designer, producer). Used for project reporting, skill mix analysis, and determining capitalization eligibility by role type.' ;
    rdfs:domain ind:ProjectAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetApprovalId rdf:type rdf:Property ;
    rdfs:label 'Budget Approval Id' ;
    rdfs:comment 'Unique identifier for this budget approval authority record. Primary key.' ;
    rdfs:domain ind:BudgetApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned By Employee Id' ;
    rdfs:comment 'Employee ID of the finance leader or executive who assigned this approval authority. Required for SOX compliance audit trail.' ;
    rdfs:domain ind:BudgetApproval ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:revokedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Revoked By Employee Id' ;
    rdfs:comment 'Employee ID of the finance leader who revoked this approval authority. Required for SOX compliance audit trail.' ;
    rdfs:domain ind:BudgetApproval ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Level' ;
    rdfs:comment 'The hierarchical level of approval authority (L1=first-line, L2=manager, L3=director, L4=executive). Determines approval workflow sequence. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:BudgetApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRole rdf:type rdf:Property ;
    rdfs:label 'Approval Role' ;
    rdfs:comment 'The role this employee plays in the budget approval process. Determines approval sequence and authority level. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:BudgetApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedDate rdf:type rdf:Property ;
    rdfs:label 'Assigned Date' ;
    rdfs:comment 'The date when this approval authority was originally assigned to the employee. Supports audit trail and compliance reporting.' ;
    rdfs:domain ind:BudgetApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorityCurrency rdf:type rdf:Property ;
    rdfs:label 'Authority Currency' ;
    rdfs:comment 'The currency code for the spending authority limit. Supports multi-currency budget approval in global gaming operations.' ;
    rdfs:domain ind:BudgetApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delegationEndDate rdf:type rdf:Property ;
    rdfs:label 'Delegation End Date' ;
    rdfs:comment 'The date until which this employee\'s approval authority remains effective. Null for permanent authority assignments. Supports temporary delegation tracking. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:BudgetApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:delegationStartDate rdf:type rdf:Property ;
    rdfs:label 'Delegation Start Date' ;
    rdfs:comment 'The date from which this employee\'s approval authority becomes effective. Supports temporary delegation during vacations or organizational changes. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:BudgetApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revokedDate rdf:type rdf:Property ;
    rdfs:label 'Revoked Date' ;
    rdfs:comment 'The date when this approval authority was revoked. Null for active authorities. Supports compliance audit trail.' ;
    rdfs:domain ind:BudgetApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:spendingAuthorityLimit rdf:type rdf:Property ;
    rdfs:label 'Spending Authority Limit' ;
    rdfs:comment 'The maximum budget amount this employee can approve in their assigned role. Required for SOX compliance and financial controls. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:BudgetApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:teamEventParticipationId rdf:type rdf:Property ;
    rdfs:label 'Team Event Participation Id' ;
    rdfs:comment 'Unique identifier for this team-event participation record. Primary key.' ;
    rdfs:domain ind:TeamEventParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appearanceFee rdf:type rdf:Property ;
    rdfs:label 'Appearance Fee' ;
    rdfs:comment 'The monetary compensation paid to the team for participating in this specific community event. Varies by event, team popularity, and participation type. Identified in detection phase as compensation.' ;
    rdfs:domain ind:TeamEventParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attendanceCount rdf:type rdf:Property ;
    rdfs:label 'Attendance Count' ;
    rdfs:comment 'The number of team members (players, coaches, staff) who attended this specific community event on behalf of the team. Identified in detection phase as engagement metric.' ;
    rdfs:domain ind:TeamEventParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:confirmationDate rdf:type rdf:Property ;
    rdfs:label 'Confirmation Date' ;
    rdfs:comment 'The date when the team confirmed their participation in this community event.' ;
    rdfs:domain ind:TeamEventParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confirmationStatus rdf:type rdf:Property ;
    rdfs:label 'Confirmation Status' ;
    rdfs:comment 'Current status of the team\'s participation commitment for this event. Tracks the lifecycle from invitation through completion.' ;
    rdfs:domain ind:TeamEventParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventRole rdf:type rdf:Property ;
    rdfs:label 'Event Role' ;
    rdfs:comment 'The specific role or function the team fulfilled at this community event (e.g., \'Headliner\', \'Opening Act\', \'Panelist\', \'Demo Team\'). Identified in detection phase.' ;
    rdfs:domain ind:TeamEventParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invitationDate rdf:type rdf:Property ;
    rdfs:label 'Invitation Date' ;
    rdfs:comment 'The date when the team was invited to participate in this community event.' ;
    rdfs:domain ind:TeamEventParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:participationType rdf:type rdf:Property ;
    rdfs:label 'Participation Type' ;
    rdfs:comment 'Classification of how the team is participating in the community event. Drives expectations, compensation structure, and engagement requirements. Identified in detection phase.' ;
    rdfs:domain ind:TeamEventParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialMediaReach rdf:type rdf:Property ;
    rdfs:label 'Social Media Reach' ;
    rdfs:comment 'Total social media impressions generated by the team\'s participation in this specific community event across all platforms.' ;
    rdfs:domain ind:TeamEventParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:editionContentBundleId rdf:type rdf:Property ;
    rdfs:label 'Edition Content Bundle Id' ;
    rdfs:comment 'Unique identifier for this edition-DLC bundle inclusion record. Primary key.' ;
    rdfs:domain ind:EditionContentBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:editionContentBundleStatus rdf:type rdf:Property ;
    rdfs:label 'Edition Content Bundle Status' ;
    rdfs:comment 'Current status of this DLC bundle\'s inclusion in this edition (active, planned, deprecated, removed). Tracks the lifecycle of the bundling relationship independently from the edition or DLC lifecycle.' ;
    rdfs:domain ind:EditionContentBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inclusionDate rdf:type rdf:Property ;
    rdfs:label 'Inclusion Date' ;
    rdfs:comment 'The date when this DLC bundle was added to this edition\'s content offering. Tracks when the bundling relationship was established, important for edition updates and content roadmap management.' ;
    rdfs:domain ind:EditionContentBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isDefaultUnlocked rdf:type rdf:Property ;
    rdfs:label 'Is Default Unlocked' ;
    rdfs:comment 'Indicates whether this DLC bundle is automatically unlocked and available to the player upon edition purchase, or requires additional action to claim or unlock.' ;
    rdfs:domain ind:EditionContentBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unlockMethod rdf:type rdf:Property ;
    rdfs:label 'Unlock Method' ;
    rdfs:comment 'The mechanism by which the player gains access to this DLC bundle within this edition (e.g., automatic, manual_claim, code_redemption, time_gated, achievement_unlock). Defines the entitlement delivery method.' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modeMapAvailabilityId rdf:type rdf:Property ;
    rdfs:label 'Mode Map Availability Id' ;
    rdfs:comment 'Unique identifier for this mode-map availability configuration record. Primary key.' ;
    rdfs:domain ind:ModeMapAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modeMapAvailabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Mode Map Availability Status' ;
    rdfs:comment 'Current operational status of this mode-map pairing: active (live in matchmaking), disabled (temporarily removed), testing (QA/beta testing only), deprecated (scheduled for removal).' ;
    rdfs:domain ind:ModeMapAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playlistWeight rdf:type rdf:Property ;
    rdfs:label 'Playlist Weight' ;
    rdfs:comment 'Relative probability weight for this map to be selected within the mode\'s matchmaking pool. Higher weights increase selection frequency. Used to balance map variety and player preferences.' ;
    rdfs:domain ind:ModeMapAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rotationOrder rdf:type rdf:Property ;
    rdfs:label 'Rotation Order' ;
    rdfs:comment 'Sequence position of this map within the mode\'s playlist rotation schedule. Used by matchmaking systems to determine map selection order in automated rotation.' ;
    rdfs:domain ind:ModeMapAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:infrastructureTestExecutionId rdf:type rdf:Property ;
    rdfs:label 'Infrastructure Test Execution Id' ;
    rdfs:comment 'Primary key for infrastructure_test_execution' ;
    rdfs:domain ind:InfrastructureTestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testExecutionId rdf:type rdf:Property ;
    rdfs:label 'Test Execution Id' ;
    rdfs:comment 'Unique identifier for this test execution record. Primary key.' ;
    rdfs:domain ind:InfrastructureTestExecution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityTestExecution .

ind:executedBy rdf:type rdf:Property ;
    rdfs:label 'Executed By' ;
    rdfs:comment 'Name or identifier of the QA engineer or automated system that initiated this test execution.' ;
    rdfs:domain ind:InfrastructureTestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Execution Duration Seconds' ;
    rdfs:comment 'Duration in seconds that this test execution took to complete. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:InfrastructureTestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:jiraTestRunKey rdf:type rdf:Property ;
    rdfs:label 'Jira Test Run Key' ;
    rdfs:comment 'Reference to the Jira test run or test execution ticket that tracks this execution in the external system.' ;
    rdfs:domain ind:InfrastructureTestExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:titleCampaignId rdf:type rdf:Property ;
    rdfs:label 'Title Campaign Id' ;
    rdfs:comment 'Primary key for title_campaign' ;
    rdfs:domain ind:TitleCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Unique identifier for this influencer marketing campaign engagement. Primary key for the association.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketingCampaign .

ind:budget rdf:type rdf:Property ;
    rdfs:label 'Budget' ;
    rdfs:comment 'The budget allocated for this specific title-influencer campaign, which may differ from the influencers standard rate card based on campaign scope and deliverables.' ;
    rdfs:domain ind:TitleCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Content Approval Status' ;
    rdfs:comment 'The approval status of content submitted by the influencer for this campaign, tracking the review and approval workflow.' ;
    rdfs:domain ind:TitleCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverablesCount rdf:type rdf:Property ;
    rdfs:label 'Deliverables Count' ;
    rdfs:comment 'The number of content pieces or posts the influencer is contracted to deliver as part of this campaign. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:TitleCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalClicks rdf:type rdf:Property ;
    rdfs:label 'Total Clicks' ;
    rdfs:comment 'The total number of clicks on campaign links (store links, affiliate codes) generated by this influencer for this title.' ;
    rdfs:domain ind:TitleCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publishingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Publishing Agreement Id' ;
    rdfs:comment 'Unique identifier for this publishing agreement record. Primary key.' ;
    rdfs:domain ind:PublishingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumGuaranteeCurrency rdf:type rdf:Property ;
    rdfs:label 'Minimum Guarantee Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the minimum guarantee amount. Required if minimum_guarantee_amount is not null.' ;
    rdfs:domain ind:PublishingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishingRightsType rdf:type rdf:Property ;
    rdfs:label 'Publishing Rights Type' ;
    rdfs:comment 'Classification of the publishing rights granted under this agreement. EXCLUSIVE means only this entity can publish in the territory. NON_EXCLUSIVE allows multiple publishers. CO_PUBLISHING indicates shared publishing responsibilities. DISTRIBUTION_ONLY limits rights to distribution without marketing. FULL_RIGHTS includes all publishing, marketing, and distribution rights.' ;
    rdfs:domain ind:PublishingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobPolicyTrainingRequirementId rdf:type rdf:Property ;
    rdfs:label 'Job Policy Training Requirement Id' ;
    rdfs:comment 'Unique identifier for this job profile policy training requirement record. Primary key.' ;
    rdfs:domain ind:JobPolicyTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedByRole rdf:type rdf:Property ;
    rdfs:label 'Assigned By Role' ;
    rdfs:comment 'Role or title of the compliance officer or policy owner who assigned this training requirement to this job profile. Provides accountability for requirement decisions.' ;
    rdfs:domain ind:JobPolicyTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTrainingDate rdf:type rdf:Property ;
    rdfs:label 'Last Training Date' ;
    rdfs:comment 'Date when training on this policy was most recently completed by employees in this job profile. Used to calculate next training due date and identify overdue training obligations.' ;
    rdfs:domain ind:JobPolicyTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextTrainingDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Training Due Date' ;
    rdfs:comment 'Calculated date when the next training refresh is due for employees in this job profile for this policy. Derived from last_training_date plus training_frequency_months. Drives compliance dashboard alerts.' ;
    rdfs:domain ind:JobPolicyTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requirementEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Requirement Effective Date' ;
    rdfs:comment 'Date when this training requirement became active for this job profile and policy combination. Used to grandfather existing employees and apply requirements to new hires.' ;
    rdfs:domain ind:JobPolicyTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requirementStatus rdf:type rdf:Property ;
    rdfs:label 'Requirement Status' ;
    rdfs:comment 'Current lifecycle status of this training requirement. Active requirements are enforced in onboarding and recertification workflows. Suspended requirements are temporarily paused. Superseded requirements have been replaced by updated policy versions. Retired requirements are no longer applicable.' ;
    rdfs:domain ind:JobPolicyTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leagueInfluencerPartnershipId rdf:type rdf:Property ;
    rdfs:label 'League Influencer Partnership Id' ;
    rdfs:comment 'Primary key for league_influencer_partnership' ;
    rdfs:domain ind:LeagueInfluencerPartnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandSafetyGuidelines rdf:type rdf:Property ;
    rdfs:label 'Brand Safety Guidelines' ;
    rdfs:comment 'Specific brand safety and content guidelines the influencer must follow when creating content for this league.' ;
    rdfs:domain ind:LeagueInfluencerPartnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationAmount rdf:type rdf:Property ;
    rdfs:label 'Compensation Amount' ;
    rdfs:comment 'The total compensation amount paid to the influencer for this specific league partnership. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:LeagueInfluencerPartnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationCurrency rdf:type rdf:Property ;
    rdfs:label 'Compensation Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the compensation amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:LeagueInfluencerPartnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Content Approval Required' ;
    rdfs:comment 'Indicates whether the league/company requires pre-approval of influencer content before publication for this partnership.' ;
    rdfs:domain ind:LeagueInfluencerPartnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentDeliverables rdf:type rdf:Property ;
    rdfs:label 'Content Deliverables' ;
    rdfs:comment 'Description of the specific content obligations the influencer must deliver for this league (e.g., \'2 livestreams per week during season\', \'5 social posts per month\', \'opening ceremony coverage\'). Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:LeagueInfluencerPartnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnershipEndDate rdf:type rdf:Property ;
    rdfs:label 'Partnership End Date' ;
    rdfs:comment 'The date when this league-influencer partnership agreement expires or terminates. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partnershipStartDate rdf:type rdf:Property ;
    rdfs:label 'Partnership Start Date' ;
    rdfs:comment 'The date when this league-influencer partnership agreement becomes effective. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:Esports ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceMetricsTarget rdf:type rdf:Property ;
    rdfs:label 'Performance Metrics Target' ;
    rdfs:comment 'Specific performance targets or KPIs agreed for this partnership (e.g., \'minimum 50K views per stream\', \'engagement rate >5%\', \'drive 1000 installs\').' ;
    rdfs:domain ind:LeagueInfluencerPartnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Entity Registration Id' ;
    rdfs:comment 'Unique identifier for this legal entity jurisdictional registration record. Primary key.' ;
    rdfs:domain ind:EntityRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceOfficerContact rdf:type rdf:Property ;
    rdfs:label 'Compliance Officer Contact' ;
    rdfs:comment 'Internal compliance officer or contact responsible for managing this entity\'s compliance obligations in this jurisdiction.' ;
    rdfs:domain ind:EntityRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localEntityName rdf:type rdf:Property ;
    rdfs:label 'Local Entity Name' ;
    rdfs:comment 'The legal entity name as registered in this specific jurisdiction, which may differ from the global legal name due to local language requirements or regulatory naming conventions.' ;
    rdfs:domain ind:EntityRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationType rdf:type rdf:Property ;
    rdfs:label 'Registration Type' ;
    rdfs:comment 'Type of registration or authorization in this jurisdiction (e.g., full incorporation, branch office, foreign entity registration, gaming license, publishing license, data processing registration).' ;
    rdfs:domain ind:EntityRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityContact rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Contact' ;
    rdfs:comment 'Contact information (email or reference) for the specific regulatory authority or contact person managing this entity\'s registration in this jurisdiction. Explicitly identified in detection reasoning as relationship data.' ;
    rdfs:domain ind:EntityRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentId rdf:type rdf:Property ;
    rdfs:label 'Experiment Id' ;
    rdfs:comment 'Reference to the parent experiment or A/B test that this treatment arm belongs to.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AbExperiment .

ind:armCode rdf:type rdf:Property ;
    rdfs:label 'Arm Code' ;
    rdfs:comment 'Short alphanumeric code used to identify the treatment arm in logs and telemetry (e.g., \'CTRL\', \'VAR_A\', \'TEST_01\').' ;
    rdfs:domain ind:TreatmentArm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:armName rdf:type rdf:Property ;
    rdfs:label 'Arm Name' ;
    rdfs:comment 'Human-readable name or label for the treatment arm (e.g., \'Control\', \'Variant A\', \'High Reward Treatment\').' ;
    rdfs:domain ind:TreatmentArm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:armType rdf:type rdf:Property ;
    rdfs:label 'Arm Type' ;
    rdfs:comment 'Classification of the arm\'s role in the experiment: control (baseline), treatment (variant being tested), holdout (excluded from treatment), or baseline (reference group).' ;
    rdfs:domain ind:TreatmentArm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationJson rdf:type rdf:Property ;
    rdfs:label 'Configuration Json' ;
    rdfs:comment 'JSON-encoded configuration parameters defining the specific feature flags, game balance settings, UI changes, or other treatment variables applied to this arm.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:description rdf:type rdf:Property ;
    rdfs:label 'Description' ;
    rdfs:comment 'Detailed description of the treatment arm, including the specific changes, features, or interventions applied to players in this arm.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureFlagOverrides rdf:type rdf:Property ;
    rdfs:label 'Feature Flag Overrides' ;
    rdfs:comment 'Comma-separated list or JSON object of feature flags and their override values specific to this treatment arm.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gameBalanceParameters rdf:type rdf:Property ;
    rdfs:label 'Game Balance Parameters' ;
    rdfs:comment 'JSON or structured text defining game balance adjustments (e.g., difficulty scaling, reward multipliers, drop rates) applied in this treatment arm.' ;
    rdfs:domain ind:TreatmentArm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isWinner rdf:type rdf:Property ;
    rdfs:label 'Is Winner' ;
    rdfs:comment 'Boolean flag indicating whether this treatment arm was declared the winner of the experiment based on statistical analysis.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:playerSegmentFilter rdf:type rdf:Property ;
    rdfs:label 'Player Segment Filter' ;
    rdfs:comment 'Comma-separated list of player segments or cohorts this treatment arm targets (e.g., \'new_players\', \'high_spenders\', \'at_risk_churn\'). Empty if all segments.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryMetric rdf:type rdf:Property ;
    rdfs:label 'Primary Metric' ;
    rdfs:comment 'The key performance indicator (KPI) or metric used to evaluate the success of this treatment arm (e.g., \'day_7_retention\', \'average_revenue_per_user\', \'session_length\').' ;
    rdfs:domain ind:TreatmentArm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:randomizationSeed rdf:type rdf:Property ;
    rdfs:label 'Randomization Seed' ;
    rdfs:comment 'Seed value used for deterministic random assignment of players to this treatment arm, ensuring reproducibility.' ;
    rdfs:domain ind:TreatmentArm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:secondaryMetrics rdf:type rdf:Property ;
    rdfs:label 'Secondary Metrics' ;
    rdfs:comment 'Comma-separated list of additional metrics monitored for this treatment arm to assess broader impact and detect unintended consequences.' ;
    rdfs:domain ind:TreatmentArm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalSignificanceLevel rdf:type rdf:Property ;
    rdfs:label 'Statistical Significance Level' ;
    rdfs:comment 'The p-value or significance level achieved by this treatment arm in hypothesis testing (e.g., 0.0500 for 95% confidence).' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:status rdf:type rdf:Property ;
    rdfs:label 'Status' ;
    rdfs:comment 'Current lifecycle status of the treatment arm within the experiment.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSampleSize rdf:type rdf:Property ;
    rdfs:label 'Target Sample Size' ;
    rdfs:comment 'Planned number of players or sessions to be assigned to this treatment arm to achieve statistical significance.' ;
    rdfs:domain ind:TreatmentArm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentStepId rdf:type rdf:Property ;
    rdfs:label 'Current Step Id' ;
    rdfs:comment 'Reference to the funnel step where the player is currently positioned or last interacted. Null if funnel is completed or abandoned.' ;
    rdfs:domain ind:FunnelInstance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FunnelStep .

ind:variantId rdf:type rdf:Property ;
    rdfs:label 'Variant Id' ;
    rdfs:comment 'Reference to the specific experiment variant (control or treatment) this funnel instance was exposed to. Null if not part of an experiment.' ;
    rdfs:domain ind:FunnelInstance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AbTestVariant .

ind:abandonmentReason rdf:type rdf:Property ;
    rdfs:label 'Abandonment Reason' ;
    rdfs:comment 'Categorized reason for funnel abandonment: user_exit (player explicitly closed), timeout (inactivity threshold exceeded), technical_error (system failure), navigation_away (player navigated to different feature), session_end (session terminated), unknown (reason not captured).' ;
    rdfs:domain ind:FunnelInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:abandonmentStepId rdf:type rdf:Property ;
    rdfs:label 'Abandonment Step Id' ;
    rdfs:comment 'Reference to the funnel step where the player abandoned the funnel. Null if funnel was completed or is still in progress.' ;
    rdfs:domain ind:FunnelInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Completion Rate Percent' ;
    rdfs:comment 'Percentage of funnel steps completed by the player. Calculated as (steps_completed_count / total_steps_count) * 100.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conversionValueUsd rdf:type rdf:Property ;
    rdfs:label 'Conversion Value Usd' ;
    rdfs:comment 'Monetary value in USD associated with the conversion event if this funnel instance resulted in a monetization outcome. Null for non-monetization funnels.' ;
    rdfs:domain ind:FunnelInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entrySource rdf:type rdf:Property ;
    rdfs:label 'Entry Source' ;
    rdfs:comment 'Channel or source through which the player entered this funnel instance: organic (natural discovery), campaign (marketing campaign), referral (friend invite), push_notification, email, in_game_prompt, social_share, direct (typed URL or bookmark).' ;
    rdfs:domain ind:FunnelInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitStepId rdf:type rdf:Property ;
    rdfs:label 'Exit Step Id' ;
    rdfs:comment 'Reference to the funnel step where the player exited the funnel. Null if funnel is still in progress.' ;
    rdfs:domain ind:FunnelInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:funnelEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Funnel End Timestamp' ;
    rdfs:comment 'Timestamp when the player completed, abandoned, or otherwise exited the funnel. Null if funnel is still in progress.' ;
    rdfs:domain ind:FunnelInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:funnelInstanceCode rdf:type rdf:Property ;
    rdfs:label 'Funnel Instance Code' ;
    rdfs:comment 'Human-readable business identifier for the funnel instance. Format: FI-<alphanumeric>.' ;
    rdfs:domain ind:FunnelInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:funnelStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Funnel Start Timestamp' ;
    rdfs:comment 'Timestamp when the player initiated the first step of this funnel instance. Represents the real-world event time of funnel entry.' ;
    rdfs:domain ind:FunnelInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isAbandoned rdf:type rdf:Property ;
    rdfs:label 'Is Abandoned' ;
    rdfs:comment 'Boolean flag indicating whether the player abandoned the funnel before completion (exited without reaching final step).' ;
    rdfs:domain ind:FunnelInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isConverted rdf:type rdf:Property ;
    rdfs:label 'Is Converted' ;
    rdfs:comment 'Boolean flag indicating whether the funnel instance resulted in a successful conversion event (e.g., purchase, subscription, feature adoption) as defined by the funnel definition.' ;
    rdfs:domain ind:FunnelInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lifetimeSpendUsd rdf:type rdf:Property ;
    rdfs:label 'Lifetime Spend Usd' ;
    rdfs:comment 'Total cumulative amount in USD the player has spent across all transactions prior to this funnel instance.' ;
    rdfs:domain ind:FunnelInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stepsCompletedCount rdf:type rdf:Property ;
    rdfs:label 'Steps Completed Count' ;
    rdfs:comment 'Total number of funnel steps the player successfully completed in this instance.' ;
    rdfs:domain ind:FunnelInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timeToConversionSeconds rdf:type rdf:Property ;
    rdfs:label 'Time To Conversion Seconds' ;
    rdfs:comment 'Elapsed time in seconds from funnel start to the conversion event. Null if no conversion occurred.' ;
    rdfs:domain ind:FunnelInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalStepsCount rdf:type rdf:Property ;
    rdfs:label 'Total Steps Count' ;
    rdfs:comment 'Total number of steps defined in the funnel at the time this instance was initiated.' ;
    rdfs:domain ind:FunnelInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified this variant configuration.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:expectedImpactDescription rdf:type rdf:Property ;
    rdfs:label 'Expected Impact Description' ;
    rdfs:comment 'Hypothesis or expected impact of this variant on key performance indicators (KPIs), player behavior, or business metrics.' ;
    rdfs:domain ind:AbTestVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isControl rdf:type rdf:Property ;
    rdfs:label 'Is Control' ;
    rdfs:comment 'Boolean flag indicating whether this variant is the control group (baseline) for the experiment.' ;
    rdfs:domain ind:AbTestVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumPlayerLevel rdf:type rdf:Property ;
    rdfs:label 'Maximum Player Level' ;
    rdfs:comment 'Maximum player level or progression threshold for inclusion in this variant, enabling experiments targeted at specific progression ranges.' ;
    rdfs:domain ind:AbTestVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parameterOverrides rdf:type rdf:Property ;
    rdfs:label 'Parameter Overrides' ;
    rdfs:comment 'JSON or key-value structure defining game parameter overrides applied in this variant, such as difficulty settings, reward multipliers, or economy adjustments.' ;
    rdfs:domain ind:AbTestVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryMetricName rdf:type rdf:Property ;
    rdfs:label 'Primary Metric Name' ;
    rdfs:comment 'Name of the primary success metric being measured for this variant, such as \'retention_day_7\', \'average_revenue_per_user\', or \'session_duration\'.' ;
    rdfs:domain ind:AbTestVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSizeTarget rdf:type rdf:Property ;
    rdfs:label 'Sample Size Target' ;
    rdfs:comment 'Target number of players or events required in this variant to achieve statistical significance for the experiment.' ;
    rdfs:domain ind:AbTestVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:secondaryMetricNames rdf:type rdf:Property ;
    rdfs:label 'Secondary Metric Names' ;
    rdfs:comment 'Comma-separated list of secondary or guardrail metrics tracked for this variant to monitor unintended side effects or additional insights.' ;
    rdfs:domain ind:AbTestVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRegionCodes rdf:type rdf:Property ;
    rdfs:label 'Target Region Codes' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes or region identifiers where this variant is active, enabling geo-targeted experiments.' ;
    rdfs:domain ind:AbTestVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uiTreatmentCode rdf:type rdf:Property ;
    rdfs:label 'Ui Treatment Code' ;
    rdfs:comment 'Code or identifier for the UI treatment applied in this variant, referencing specific layouts, color schemes, or interaction patterns.' ;
    rdfs:domain ind:AbTestVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantDescription rdf:type rdf:Property ;
    rdfs:label 'Variant Description' ;
    rdfs:comment 'Detailed description of the variant configuration, including feature changes, parameter adjustments, or UI modifications being tested.' ;
    rdfs:domain ind:AbTestVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantKey rdf:type rdf:Property ;
    rdfs:label 'Variant Key' ;
    rdfs:comment 'Unique business identifier for the variant within the test, typically a short code such as \'control\', \'variant_a\', \'treatment_1\'.' ;
    rdfs:domain ind:AbTestVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantType rdf:type rdf:Property ;
    rdfs:label 'Variant Type' ;
    rdfs:comment 'Classification of the variant role within the experiment: control (baseline), treatment (experimental), baseline (reference), or challenger (alternative).' ;
    rdfs:domain ind:AbTestVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlModelVersionId rdf:type rdf:Property ;
    rdfs:label 'Ml Model Version Id' ;
    rdfs:comment 'Primary key for ml_model_version' ;
    rdfs:domain ind:MlModelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testDatasetId rdf:type rdf:Property ;
    rdfs:label 'Test Dataset Id' ;
    rdfs:comment 'Reference to the dataset used to test this model version after training.' ;
    rdfs:domain ind:MlModelVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dataset .

ind:trainingDatasetId rdf:type rdf:Property ;
    rdfs:label 'Training Dataset Id' ;
    rdfs:comment 'Reference to the dataset used to train this model version.' ;
    rdfs:domain ind:MlModelVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dataset .

ind:validationDatasetId rdf:type rdf:Property ;
    rdfs:label 'Validation Dataset Id' ;
    rdfs:comment 'Reference to the dataset used to validate this model version during training.' ;
    rdfs:domain ind:MlModelVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dataset .

ind:accuracyScore rdf:type rdf:Property ;
    rdfs:label 'Accuracy Score' ;
    rdfs:comment 'Accuracy metric score for this model version on the test dataset.' ;
    rdfs:domain ind:MlModelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:algorithmName rdf:type rdf:Property ;
    rdfs:label 'Algorithm Name' ;
    rdfs:comment 'Name of the machine learning algorithm or technique used for this model version.' ;
    rdfs:domain ind:MlModelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aucRocScore rdf:type rdf:Property ;
    rdfs:label 'Auc Roc Score' ;
    rdfs:comment 'Area under the ROC curve score for this model version on the test dataset.' ;
    rdfs:domain ind:MlModelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSize rdf:type rdf:Property ;
    rdfs:label 'Batch Size' ;
    rdfs:comment 'Number of samples processed in each training batch.' ;
    rdfs:domain ind:MlModelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:f1Score rdf:type rdf:Property ;
    rdfs:label 'F1 Score' ;
    rdfs:comment 'F1 score metric for this model version on the test dataset, representing the harmonic mean of precision and recall.' ;
    rdfs:domain ind:MlModelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frameworkName rdf:type rdf:Property ;
    rdfs:label 'Framework Name' ;
    rdfs:comment 'Name of the machine learning framework or library used to build this model version.' ;
    rdfs:domain ind:MlModelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hyperparametersJson rdf:type rdf:Property ;
    rdfs:label 'Hyperparameters Json' ;
    rdfs:comment 'JSON-encoded hyperparameters configuration used for training this model version.' ;
    rdfs:domain ind:MlModelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:learningRate rdf:type rdf:Property ;
    rdfs:label 'Learning Rate' ;
    rdfs:comment 'Learning rate hyperparameter used during model training.' ;
    rdfs:domain ind:MlModelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lossValue rdf:type rdf:Property ;
    rdfs:label 'Loss Value' ;
    rdfs:comment 'Final loss function value achieved by this model version during training.' ;
    rdfs:domain ind:MlModelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Model Size Bytes' ;
    rdfs:comment 'Size of the serialized model artifact measured in bytes.' ;
    rdfs:domain ind:MlModelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:precisionScore rdf:type rdf:Property ;
    rdfs:label 'Precision Score' ;
    rdfs:comment 'Precision metric score for this model version on the test dataset.' ;
    rdfs:domain ind:MlModelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recallScore rdf:type rdf:Property ;
    rdfs:label 'Recall Score' ;
    rdfs:comment 'Recall metric score for this model version on the test dataset.' ;
    rdfs:domain ind:MlModelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retirementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Retirement Timestamp' ;
    rdfs:comment 'Timestamp when this model version was retired or decommissioned from active use.' ;
    rdfs:domain ind:MlModelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:trainingDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Training Duration Seconds' ;
    rdfs:comment 'Total duration of the training process measured in seconds.' ;
    rdfs:domain ind:MlModelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingEpochs rdf:type rdf:Property ;
    rdfs:label 'Training Epochs' ;
    rdfs:comment 'Number of complete passes through the training dataset during model training.' ;
    rdfs:domain ind:MlModelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mlModelDeploymentId rdf:type rdf:Property ;
    rdfs:label 'Ml Model Deployment Id' ;
    rdfs:comment 'Primary key for ml_model_deployment' ;
    rdfs:domain ind:MlModelDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousDeploymentId rdf:type rdf:Property ;
    rdfs:label 'Previous Deployment Id' ;
    rdfs:comment 'Reference to the prior deployment version, enabling rollback and version tracking.' ;
    rdfs:domain ind:MlModelDeployment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MlModelDeployment .

ind:championChallengerRole rdf:type rdf:Property ;
    rdfs:label 'Champion Challenger Role' ;
    rdfs:comment 'Designation of this deployment within a champion-challenger testing framework.' ;
    rdfs:domain ind:MlModelDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:computeInstanceType rdf:type rdf:Property ;
    rdfs:label 'Compute Instance Type' ;
    rdfs:comment 'Specific compute instance configuration used for model serving, defining CPU, GPU, and memory resources.' ;
    rdfs:domain ind:MlModelDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:computePlatform rdf:type rdf:Property ;
    rdfs:label 'Compute Platform' ;
    rdfs:comment 'Infrastructure platform hosting the deployment, such as cloud provider or on-premise cluster.' ;
    rdfs:domain ind:MlModelDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentInstances rdf:type rdf:Property ;
    rdfs:label 'Current Instances' ;
    rdfs:comment 'Current number of active compute instances serving this deployment.' ;
    rdfs:domain ind:MlModelDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deactivationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deactivation Timestamp' ;
    rdfs:comment 'Date and time when the deployment was deactivated or retired from service.' ;
    rdfs:domain ind:MlModelDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deploymentConfiguration rdf:type rdf:Property ;
    rdfs:label 'Deployment Configuration' ;
    rdfs:comment 'JSON or YAML configuration defining deployment parameters, environment variables, and runtime settings.' ;
    rdfs:domain ind:MlModelDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentName rdf:type rdf:Property ;
    rdfs:label 'Deployment Name' ;
    rdfs:comment 'Human-readable name for this deployment instance, used for identification and tracking.' ;
    rdfs:domain ind:MlModelDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentVersion rdf:type rdf:Property ;
    rdfs:label 'Deployment Version' ;
    rdfs:comment 'Version identifier for this deployment, enabling tracking of deployment iterations and rollbacks.' ;
    rdfs:domain ind:MlModelDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointUrl rdf:type rdf:Property ;
    rdfs:label 'Endpoint Url' ;
    rdfs:comment 'API endpoint URL where the deployed model can be accessed for inference requests.' ;
    rdfs:domain ind:MlModelDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Error Rate Percentage' ;
    rdfs:comment 'Percentage of inference requests resulting in errors, critical metric for deployment reliability.' ;
    rdfs:domain ind:MlModelDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:featureFlags rdf:type rdf:Property ;
    rdfs:label 'Feature Flags' ;
    rdfs:comment 'JSON representation of feature toggles controlling deployment behavior and capabilities.' ;
    rdfs:domain ind:MlModelDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthStatus rdf:type rdf:Property ;
    rdfs:label 'Health Status' ;
    rdfs:comment 'Current health status of the deployment based on monitoring checks and performance metrics.' ;
    rdfs:domain ind:MlModelDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loggingLevel rdf:type rdf:Property ;
    rdfs:label 'Logging Level' ;
    rdfs:comment 'Verbosity level for deployment logs, controlling the detail of captured operational events.' ;
    rdfs:domain ind:MlModelDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxInstances rdf:type rdf:Property ;
    rdfs:label 'Max Instances' ;
    rdfs:comment 'Maximum number of compute instances allowed for this deployment during auto-scaling.' ;
    rdfs:domain ind:MlModelDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minInstances rdf:type rdf:Property ;
    rdfs:label 'Min Instances' ;
    rdfs:comment 'Minimum number of compute instances maintained for this deployment.' ;
    rdfs:domain ind:MlModelDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modelDriftDetected rdf:type rdf:Property ;
    rdfs:label 'Model Drift Detected' ;
    rdfs:comment 'Indicates whether statistical drift has been detected in model predictions or input data distribution.' ;
    rdfs:domain ind:MlModelDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rollbackEnabled rdf:type rdf:Property ;
    rdfs:label 'Rollback Enabled' ;
    rdfs:comment 'Indicates whether automatic rollback to previous deployment version is enabled if failure thresholds are exceeded.' ;
    rdfs:domain ind:MlModelDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scalingPolicy rdf:type rdf:Property ;
    rdfs:label 'Scaling Policy' ;
    rdfs:comment 'Strategy for scaling compute resources based on demand and load patterns.' ;
    rdfs:domain ind:MlModelDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:throughputRequestsPerSecond rdf:type rdf:Property ;
    rdfs:label 'Throughput Requests Per Second' ;
    rdfs:comment 'Number of inference requests processed per second, measuring deployment capacity.' ;
    rdfs:domain ind:MlModelDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trafficPercentage rdf:type rdf:Property ;
    rdfs:label 'Traffic Percentage' ;
    rdfs:comment 'Percentage of inference traffic routed to this deployment, used for canary and A/B testing strategies.' ;
    rdfs:domain ind:MlModelDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformHolderId rdf:type rdf:Property ;
    rdfs:label 'Platform Holder Id' ;
    rdfs:comment 'Reference to the platform holder (Steam, Epic, Sony, Microsoft, Apple, Google) for platform-specific dunning cycles that comply with first-party billing policies.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlatformHolder .

ind:autoUpdatePaymentMethod rdf:type rdf:Property ;
    rdfs:label 'Auto Update Payment Method' ;
    rdfs:comment 'Indicates whether this dunning cycle includes automatic payment method update attempts via account updater services (Visa Account Updater, Mastercard Automatic Billing Updater).' ;
    rdfs:domain ind:DunningCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancellationThreshold rdf:type rdf:Property ;
    rdfs:label 'Cancellation Threshold' ;
    rdfs:comment 'Number of failed attempts after which subscription or service is automatically cancelled if payment is not resolved.' ;
    rdfs:domain ind:DunningCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chargebackProtectionEnabled rdf:type rdf:Property ;
    rdfs:label 'Chargeback Protection Enabled' ;
    rdfs:comment 'Indicates whether this dunning cycle includes chargeback prevention measures such as pre-dispute notifications or representment workflows.' ;
    rdfs:domain ind:DunningCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationEnabled rdf:type rdf:Property ;
    rdfs:label 'Escalation Enabled' ;
    rdfs:comment 'Indicates whether failed payments in this cycle are escalated to collections, account management, or alternative recovery processes.' ;
    rdfs:domain ind:DunningCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hardDeclineAction rdf:type rdf:Property ;
    rdfs:label 'Hard Decline Action' ;
    rdfs:comment 'Action taken when a hard decline (permanent failure like stolen card, closed account) occurs: immediate suspension, notification only, request new payment method, or escalate to support.' ;
    rdfs:domain ind:DunningCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecoveryRateTarget rdf:type rdf:Property ;
    rdfs:label 'Revenue Recovery Rate Target' ;
    rdfs:comment 'Target percentage of failed payment revenue this dunning cycle aims to recover, used for performance measurement and optimization.' ;
    rdfs:domain ind:DunningCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:softDeclineRetryEnabled rdf:type rdf:Property ;
    rdfs:label 'Soft Decline Retry Enabled' ;
    rdfs:comment 'Indicates whether soft declines (temporary failures like insufficient funds, issuer timeout) trigger immediate retry attempts within this cycle.' ;
    rdfs:domain ind:DunningCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suspensionThreshold rdf:type rdf:Property ;
    rdfs:label 'Suspension Threshold' ;
    rdfs:comment 'Number of failed attempts after which account or subscription is automatically suspended pending payment resolution.' ;
    rdfs:domain ind:DunningCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditTrailEnabled rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Enabled' ;
    rdfs:comment 'Indicates whether detailed audit logging is enabled for this rule (true) or not (false). Required for high-severity rules and compliance purposes.' ;
    rdfs:domain ind:FraudRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:executionOrder rdf:type rdf:Property ;
    rdfs:label 'Execution Order' ;
    rdfs:comment 'Sequence order in which this rule is evaluated in the fraud detection pipeline. Lower numbers execute first. Used to optimize performance and dependency management.' ;
    rdfs:domain ind:FraudRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:falsePositiveRate rdf:type rdf:Property ;
    rdfs:label 'False Positive Rate' ;
    rdfs:comment 'Historical false positive rate (0.0000 to 1.0000) for this rule, calculated as the ratio of incorrectly flagged legitimate transactions to total flagged transactions. Used for rule tuning.' ;
    rdfs:domain ind:FraudRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isMachineLearningBased rdf:type rdf:Property ;
    rdfs:label 'Is Machine Learning Based' ;
    rdfs:comment 'Indicates whether this rule uses machine learning models (true) or deterministic logic (false) for fraud detection.' ;
    rdfs:domain ind:FraudRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastTunedDate rdf:type rdf:Property ;
    rdfs:label 'Last Tuned Date' ;
    rdfs:comment 'Date when the rule parameters (thresholds, weights, logic) were last adjusted based on performance analysis.' ;
    rdfs:domain ind:FraudRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethodFilter rdf:type rdf:Property ;
    rdfs:label 'Payment Method Filter' ;
    rdfs:comment 'Comma-separated list of payment method types (credit_card, debit_card, paypal, wallet, bank_transfer) to which this rule applies. Null indicates all payment methods.' ;
    rdfs:domain ind:FraudRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScoreWeight rdf:type rdf:Property ;
    rdfs:label 'Risk Score Weight' ;
    rdfs:comment 'Numeric weight (0.00 to 100.00) assigned to this rule in the composite fraud risk scoring model. Higher weights indicate greater fraud risk contribution.' ;
    rdfs:domain ind:FraudRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ruleCategory rdf:type rdf:Property ;
    rdfs:label 'Rule Category' ;
    rdfs:comment 'Business category of fraud the rule is designed to detect: payment fraud, account takeover, chargeback fraud, refund abuse, bonus abuse, or identity theft.' ;
    rdfs:domain ind:FraudRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Unique business identifier code for the fraud rule, used for external reference and system integration.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleLogicExpression rdf:type rdf:Property ;
    rdfs:label 'Rule Logic Expression' ;
    rdfs:comment 'Technical expression or pseudocode defining the rule logic. May reference transaction attributes, user behavior patterns, or external data sources. Confidential to prevent fraud circumvention.' ;
    rdfs:domain ind:FraudRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Human-readable name of the fraud detection rule.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleType rdf:type rdf:Property ;
    rdfs:label 'Rule Type' ;
    rdfs:comment 'Classification of the fraud rule by detection methodology: velocity-based, threshold-based, pattern matching, geolocation analysis, device fingerprinting, or behavioral analysis.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scope rdf:type rdf:Property ;
    rdfs:label 'Scope' ;
    rdfs:comment 'Application scope of the rule: global (all transactions), storefront-specific (Steam, Epic, console), region-specific, payment method-specific, or user segment-specific.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storefrontFilter rdf:type rdf:Property ;
    rdfs:label 'Storefront Filter' ;
    rdfs:comment 'Comma-separated list of storefront codes (Steam, Epic, PSN, Xbox, AppStore, GooglePlay) to which this rule applies. Null indicates all storefronts.' ;
    rdfs:domain ind:FraudRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Threshold Unit' ;
    rdfs:comment 'Unit of measurement for the threshold value: currency (USD, EUR), transaction count, percentage, or velocity rate (per hour, per day).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdValue rdf:type rdf:Property ;
    rdfs:label 'Threshold Value' ;
    rdfs:comment 'Numeric threshold value that triggers the rule. Interpretation depends on threshold_unit (e.g., dollar amount, transaction count, velocity rate).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeWindowMinutes rdf:type rdf:Property ;
    rdfs:label 'Time Window Minutes' ;
    rdfs:comment 'Time window in minutes over which the rule evaluates activity. Used for velocity and pattern-based rules (e.g., 5 transactions in 60 minutes).' ;
    rdfs:domain ind:FraudRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:truePositiveRate rdf:type rdf:Property ;
    rdfs:label 'True Positive Rate' ;
    rdfs:comment 'Historical true positive rate (0.0000 to 1.0000) for this rule, calculated as the ratio of correctly identified fraudulent transactions to total actual fraud cases. Measures rule effectiveness.' ;
    rdfs:domain ind:FraudRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentProviderId rdf:type rdf:Property ;
    rdfs:label 'Payment Provider Id' ;
    rdfs:comment 'Reference to the payment service provider or payment gateway that manages this bank account (e.g., Stripe, PayPal, Adyen).' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentProvider .

ind:accountHolderName rdf:type rdf:Property ;
    rdfs:label 'Account Holder Name' ;
    rdfs:comment 'The legal name of the individual or entity that holds the bank account, as registered with the financial institution.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankBranchName rdf:type rdf:Property ;
    rdfs:label 'Bank Branch Name' ;
    rdfs:comment 'The name of the specific branch where the account is registered, if applicable.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankCountryCode rdf:type rdf:Property ;
    rdfs:label 'Bank Country Code' ;
    rdfs:comment 'The ISO 3166-1 alpha-3 country code where the bank is domiciled (e.g., USA, GBR, DEU).' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'The name of the financial institution or bank where the account is held.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureReason rdf:type rdf:Property ;
    rdfs:label 'Closure Reason' ;
    rdfs:comment 'The reason why the bank account was closed or deactivated.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iban rdf:type rdf:Property ;
    rdfs:label 'Iban' ;
    rdfs:comment 'The International Bank Account Number used for international transactions, primarily in Europe and other regions. Up to 34 alphanumeric characters.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPayoutEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Payout Enabled' ;
    rdfs:comment 'Indicates whether this bank account is enabled for receiving payouts (e.g., tournament winnings, creator revenue share). True if enabled, False otherwise.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Indicates whether this is the primary bank account for the player for payouts and refunds. True if primary, False otherwise.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRefundEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Refund Enabled' ;
    rdfs:comment 'Indicates whether this bank account is enabled for receiving refunds. True if enabled, False otherwise.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentToken rdf:type rdf:Property ;
    rdfs:label 'Payment Token' ;
    rdfs:comment 'The tokenized representation of the bank account provided by the payment gateway (e.g., Stripe bank account token, PayPal billing agreement ID). Used for PCI DSS compliance to avoid storing raw account details.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pciComplianceLevel rdf:type rdf:Property ;
    rdfs:label 'Pci Compliance Level' ;
    rdfs:comment 'The PCI DSS compliance level applicable to this bank account record based on transaction volume and risk assessment.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'The routing transit number (RTN) or sort code used to identify the financial institution. Format varies by country (e.g., ABA routing number in USA, sort code in UK).' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swiftCode rdf:type rdf:Property ;
    rdfs:label 'Swift Code' ;
    rdfs:comment 'The SWIFT/BIC code identifying the bank for international wire transfers. 8 or 11 alphanumeric characters.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verified Timestamp' ;
    rdfs:comment 'The date and time when the bank account was successfully verified. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:batchGeneratedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Batch Generated Timestamp' ;
    rdfs:comment 'The date and time when the platform holder generated this settlement batch report.' ;
    rdfs:domain ind:SettlementBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Externally-known unique business identifier for the settlement batch, used for reconciliation with platform holders and payment processors.' ;
    rdfs:domain ind:SettlementBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchReceivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Batch Received Timestamp' ;
    rdfs:comment 'The date and time when the settlement batch was received and ingested into the billing system.' ;
    rdfs:domain ind:SettlementBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:batchStatus rdf:type rdf:Property ;
    rdfs:label 'Batch Status' ;
    rdfs:comment 'Current lifecycle status of the settlement batch in the payment processing workflow.' ;
    rdfs:domain ind:SettlementBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchType rdf:type rdf:Property ;
    rdfs:label 'Batch Type' ;
    rdfs:comment 'Classification of the settlement batch indicating the nature of transactions included.' ;
    rdfs:domain ind:SettlementBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netSettlementAmount rdf:type rdf:Property ;
    rdfs:label 'Net Settlement Amount' ;
    rdfs:comment 'Final net amount payable to the publisher after all fees, taxes, refunds, chargebacks, and adjustments have been applied.' ;
    rdfs:domain ind:SettlementBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformReportUrl rdf:type rdf:Property ;
    rdfs:label 'Platform Report Url' ;
    rdfs:comment 'Secure URL link to the original settlement report document provided by the platform holder, stored in document management system.' ;
    rdfs:domain ind:SettlementBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Timestamp' ;
    rdfs:comment 'The date and time when the settlement batch was successfully reconciled against internal transaction records.' ;
    rdfs:domain ind:SettlementBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:settlementDueDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Due Date' ;
    rdfs:comment 'The contractual date by which the platform holder is obligated to transfer the net settlement amount.' ;
    rdfs:domain ind:SettlementBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementPaidDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Paid Date' ;
    rdfs:comment 'The actual date when the net settlement amount was received in the publisher\'s bank account.' ;
    rdfs:domain ind:SettlementBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Period End Date' ;
    rdfs:comment 'The last date of the transaction period covered by this settlement batch.' ;
    rdfs:domain ind:SettlementBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Period Start Date' ;
    rdfs:comment 'The first date of the transaction period covered by this settlement batch.' ;
    rdfs:domain ind:SettlementBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transactionCount rdf:type rdf:Property ;
    rdfs:label 'Transaction Count' ;
    rdfs:comment 'Total number of individual transactions included in this settlement batch.' ;
    rdfs:domain ind:SettlementBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'The monetary difference between expected settlement amount and actual settlement amount, if a reconciliation discrepancy exists.' ;
    rdfs:domain ind:SettlementBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractId rdf:type rdf:Property ;
    rdfs:label 'Contract Id' ;
    rdfs:comment 'Reference to the parent contract or agreement that contains this performance obligation.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:parentObligationId rdf:type rdf:Property ;
    rdfs:label 'Parent Obligation Id' ;
    rdfs:comment 'Reference to a parent performance obligation if this is a child obligation (e.g., individual season pass content drops linked to the season pass purchase).' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformanceObligation .

ind:productId rdf:type rdf:Property ;
    rdfs:label 'Product Id' ;
    rdfs:comment 'Reference to the game, DLC, or virtual item product associated with this performance obligation.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Product .

ind:allocatedTransactionPrice rdf:type rdf:Property ;
    rdfs:label 'Allocated Transaction Price' ;
    rdfs:comment 'The portion of the total contract transaction price allocated to this specific performance obligation based on relative standalone selling prices.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDistinct rdf:type rdf:Property ;
    rdfs:label 'Is Distinct' ;
    rdfs:comment 'Indicates whether this performance obligation is distinct and separately identifiable from other promises in the contract per ASC 606 criteria.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMaterialRight rdf:type rdf:Property ;
    rdfs:label 'Is Material Right' ;
    rdfs:comment 'Indicates whether this performance obligation represents a material right granted to the customer (e.g., loyalty points, future purchase discounts) that must be accounted for separately.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remainingDeferredRevenue rdf:type rdf:Property ;
    rdfs:label 'Remaining Deferred Revenue' ;
    rdfs:comment 'Amount of allocated transaction price not yet recognized as revenue, representing future performance obligations.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognizedToDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognized To Date' ;
    rdfs:comment 'Cumulative amount of revenue recognized for this performance obligation as of the current reporting period.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:satisfactionDate rdf:type rdf:Property ;
    rdfs:label 'Satisfaction Date' ;
    rdfs:comment 'The actual date when the performance obligation was fully satisfied and control transferred to the customer.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:standaloneSellingPrice rdf:type rdf:Property ;
    rdfs:label 'Standalone Selling Price' ;
    rdfs:comment 'The price at which the entity would sell the promised good or service separately to a customer, used for transaction price allocation.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedByUserPlayerAccountId rdf:type rdf:Property ;
    rdfs:label 'Modified By User Player Account Id' ;
    rdfs:comment 'Reference to the administrator or moderator user who last modified this forum category.' ;
    rdfs:domain ind:ForumCategory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayerAccount .

ind:parentCategoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Category Id' ;
    rdfs:comment 'Reference to the parent forum category for hierarchical category structures. Null for top-level categories.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Community .

ind:activeThreads rdf:type rdf:Property ;
    rdfs:label 'Active Threads' ;
    rdfs:comment 'Current count of active, non-archived discussion threads in this forum category.' ;
    rdfs:domain ind:ForumCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allowedContentTypes rdf:type rdf:Property ;
    rdfs:label 'Allowed Content Types' ;
    rdfs:comment 'Comma-separated list of content types allowed in this category such as text, images, videos, polls, or attachments.' ;
    rdfs:domain ind:ForumCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoArchiveDays rdf:type rdf:Property ;
    rdfs:label 'Auto Archive Days' ;
    rdfs:comment 'Number of days of inactivity after which threads in this category are automatically archived. Null if auto-archiving is disabled.' ;
    rdfs:domain ind:ForumCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:code rdf:type rdf:Property ;
    rdfs:label 'Code' ;
    rdfs:comment 'Unique business identifier code for the forum category used for system integration and API references.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customCssClass rdf:type rdf:Property ;
    rdfs:label 'Custom Css Class' ;
    rdfs:comment 'Custom CSS class name applied to this forum category for specialized styling and theming in the user interface.' ;
    rdfs:domain ind:ForumCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCode rdf:type rdf:Property ;
    rdfs:label 'External Code' ;
    rdfs:comment 'Identifier used by external or legacy systems to reference this forum category for integration and migration purposes.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featuredPriority rdf:type rdf:Property ;
    rdfs:label 'Featured Priority' ;
    rdfs:comment 'Priority ranking for featuring this category on the homepage or community hub. Higher numbers indicate higher priority. Null if not featured.' ;
    rdfs:domain ind:ForumCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iconUrl rdf:type rdf:Property ;
    rdfs:label 'Icon Url' ;
    rdfs:comment 'URL path to the icon image representing this forum category in the user interface.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isReadOnly rdf:type rdf:Property ;
    rdfs:label 'Is Read Only' ;
    rdfs:comment 'Indicates whether this forum category is read-only, preventing new posts or replies from being created.' ;
    rdfs:domain ind:ForumCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxAttachmentSizeMb rdf:type rdf:Property ;
    rdfs:label 'Max Attachment Size Mb' ;
    rdfs:comment 'Maximum file size in megabytes allowed for attachments in posts within this forum category.' ;
    rdfs:domain ind:ForumCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:metaDescription rdf:type rdf:Property ;
    rdfs:label 'Meta Description' ;
    rdfs:comment 'HTML meta description tag content for search engine optimization of the forum category page.' ;
    rdfs:domain ind:ForumCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metaTitle rdf:type rdf:Property ;
    rdfs:label 'Meta Title' ;
    rdfs:comment 'HTML meta title tag content for search engine optimization of the forum category page.' ;
    rdfs:domain ind:ForumCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moderationLevel rdf:type rdf:Property ;
    rdfs:label 'Moderation Level' ;
    rdfs:comment 'The intensity level of content moderation applied to posts and discussions in this forum category.' ;
    rdfs:domain ind:ForumCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:name rdf:type rdf:Property ;
    rdfs:label 'Name' ;
    rdfs:comment 'The display name of the forum category as shown to players in the community forums.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postCooldownMinutes rdf:type rdf:Property ;
    rdfs:label 'Post Cooldown Minutes' ;
    rdfs:comment 'Minimum number of minutes a player must wait between consecutive posts in this forum category to prevent spam.' ;
    rdfs:domain ind:ForumCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPosts rdf:type rdf:Property ;
    rdfs:label 'Total Posts' ;
    rdfs:comment 'Cumulative count of all posts and replies made in this forum category since inception.' ;
    rdfs:domain ind:ForumCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalThreads rdf:type rdf:Property ;
    rdfs:label 'Total Threads' ;
    rdfs:comment 'Cumulative count of all discussion threads created in this forum category since inception.' ;
    rdfs:domain ind:ForumCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:type rdf:type rdf:Property ;
    rdfs:label 'Type' ;
    rdfs:comment 'Classification of the forum category by its primary purpose and content focus.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kbCategoryId rdf:type rdf:Property ;
    rdfs:label 'Kb Category Id' ;
    rdfs:comment 'Primary key for kb_category' ;
    rdfs:domain ind:KbCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:archivedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Archived By User Employee Id' ;
    rdfs:comment 'Reference to the user who archived this category. Null if category is not archived.' ;
    rdfs:domain ind:KbCategory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:articleCount rdf:type rdf:Property ;
    rdfs:label 'Article Count' ;
    rdfs:comment 'Total number of knowledge base articles currently assigned to this category.' ;
    rdfs:domain ind:KbCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bannerUrl rdf:type rdf:Property ;
    rdfs:label 'Banner Url' ;
    rdfs:comment 'URL path to the banner image displayed at the top of the category page.' ;
    rdfs:domain ind:KbCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'Unique business identifier code for the category used in external systems and reporting.' ;
    rdfs:domain ind:KbCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryName rdf:type rdf:Property ;
    rdfs:label 'Category Name' ;
    rdfs:comment 'Human-readable name of the knowledge base category.' ;
    rdfs:domain ind:KbCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryType rdf:type rdf:Property ;
    rdfs:label 'Category Type' ;
    rdfs:comment 'Classification of the knowledge base category by subject area.' ;
    rdfs:domain ind:KbCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalSystemCode rdf:type rdf:Property ;
    rdfs:label 'External System Code' ;
    rdfs:comment 'Identifier for this category in external support systems such as Zendesk or other knowledge management platforms.' ;
    rdfs:domain ind:KbCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalSystemName rdf:type rdf:Property ;
    rdfs:label 'External System Name' ;
    rdfs:comment 'Name of the external system where this category originates or is synchronized to.' ;
    rdfs:domain ind:KbCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gameTitleFilter rdf:type rdf:Property ;
    rdfs:label 'Game Title Filter' ;
    rdfs:comment 'Specific game title this category is associated with, or null for cross-game categories.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Path' ;
    rdfs:comment 'Full path from root to current category using category codes or IDs, delimited by forward slashes.' ;
    rdfs:domain ind:KbCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSearchable rdf:type rdf:Property ;
    rdfs:label 'Is Searchable' ;
    rdfs:comment 'Indicates whether articles in this category are included in knowledge base search results.' ;
    rdfs:domain ind:KbCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresAuthentication rdf:type rdf:Property ;
    rdfs:label 'Requires Authentication' ;
    rdfs:comment 'Indicates whether users must be logged in to access articles in this category.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:searchKeywords rdf:type rdf:Property ;
    rdfs:label 'Search Keywords' ;
    rdfs:comment 'Comma-separated list of keywords and tags to improve category discoverability in search.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seoDescription rdf:type rdf:Property ;
    rdfs:label 'Seo Description' ;
    rdfs:comment 'Meta description for search engine optimization and social media sharing.' ;
    rdfs:domain ind:KbCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seoTitle rdf:type rdf:Property ;
    rdfs:label 'Seo Title' ;
    rdfs:comment 'Optimized title for search engine indexing and display in search results.' ;
    rdfs:domain ind:KbCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sync Timestamp' ;
    rdfs:comment 'Date and time when this category was last synchronized with external support systems.' ;
    rdfs:domain ind:KbCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:visibilityScope rdf:type rdf:Property ;
    rdfs:label 'Visibility Scope' ;
    rdfs:comment 'Access level determining which user roles can view articles in this category.' ;
    rdfs:domain ind:KbCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kbSectionId rdf:type rdf:Property ;
    rdfs:label 'Kb Section Id' ;
    rdfs:comment 'Primary key for kb_section' ;
    rdfs:domain ind:KbSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replacementSectionId rdf:type rdf:Property ;
    rdfs:label 'Replacement Section Id' ;
    rdfs:comment 'Reference to the kb_section that replaces this deprecated section. Used to redirect players to current content.' ;
    rdfs:domain ind:KbSection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KbSection .

ind:reviewerUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reviewer User Employee Id' ;
    rdfs:comment 'Reference to the internal user who reviewed and approved this section for publication. Null if not yet reviewed.' ;
    rdfs:domain ind:KbSection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:canonicalUrl rdf:type rdf:Property ;
    rdfs:label 'Canonical Url' ;
    rdfs:comment 'Canonical URL path for this section in the public-facing knowledge base. Used for SEO and direct linking from external sources.' ;
    rdfs:domain ind:KbSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedReadTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Read Time Minutes' ;
    rdfs:comment 'Estimated time in minutes for a player to read and understand this section. Calculated based on word count and content complexity.' ;
    rdfs:domain ind:KbSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feedbackCommentCount rdf:type rdf:Property ;
    rdfs:label 'Feedback Comment Count' ;
    rdfs:comment 'Number of player feedback comments submitted for this section. Used to identify content requiring attention or clarification.' ;
    rdfs:domain ind:KbSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastReviewedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Timestamp' ;
    rdfs:comment 'Date and time when this section was last reviewed for accuracy and relevance. Used to schedule periodic content audits.' ;
    rdfs:domain ind:KbSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:linkedTicketCategory rdf:type rdf:Property ;
    rdfs:label 'Linked Ticket Category' ;
    rdfs:comment 'Support ticket category code that this section addresses. Used to suggest relevant KB articles during ticket creation and deflect support volume.' ;
    rdfs:domain ind:KbSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedSectionIds rdf:type rdf:Property ;
    rdfs:label 'Related Section Ids' ;
    rdfs:comment 'Comma-separated list of kb_section_id values for related sections. Used to provide cross-references and improve player navigation.' ;
    rdfs:domain ind:KbSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectionCode rdf:type rdf:Property ;
    rdfs:label 'Section Code' ;
    rdfs:comment 'Unique business identifier code for the section, used for cross-referencing and integration with support ticketing systems.' ;
    rdfs:domain ind:KbSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectionTitle rdf:type rdf:Property ;
    rdfs:label 'Section Title' ;
    rdfs:comment 'The human-readable title of the knowledge base section. Used for navigation and display in help documentation.' ;
    rdfs:domain ind:KbSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectionType rdf:type rdf:Property ;
    rdfs:label 'Section Type' ;
    rdfs:comment 'Classification of the section content type. Determines how the section is presented and indexed for player search.' ;
    rdfs:domain ind:KbSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seoMetaDescription rdf:type rdf:Property ;
    rdfs:label 'Seo Meta Description' ;
    rdfs:comment 'Meta description text for search engine optimization. Used when the knowledge base is publicly indexed by search engines.' ;
    rdfs:domain ind:KbSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoUrl rdf:type rdf:Property ;
    rdfs:label 'Video Url' ;
    rdfs:comment 'URL to an embedded video tutorial or demonstration related to this section content. Null if no video is associated.' ;
    rdfs:domain ind:KbSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visibilityLevel rdf:type rdf:Property ;
    rdfs:label 'Visibility Level' ;
    rdfs:comment 'Access control level determining which player segments can view this section. Used for tiered support content delivery.' ;
    rdfs:domain ind:KbSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:anonymousResponsesAllowed rdf:type rdf:Property ;
    rdfs:label 'Anonymous Responses Allowed' ;
    rdfs:comment 'Indicates whether players can submit responses anonymously without player identification.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:averageCsatScore rdf:type rdf:Property ;
    rdfs:label 'Average Csat Score' ;
    rdfs:comment 'Average Customer Satisfaction score calculated from survey responses (scale 1-5).' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageNpsScore rdf:type rdf:Property ;
    rdfs:label 'Average Nps Score' ;
    rdfs:comment 'Average Net Promoter Score calculated from survey responses (scale 0-10).' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:category rdf:type rdf:Property ;
    rdfs:label 'Category' ;
    rdfs:comment 'Business category of the survey focus area.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCompletionMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Completion Minutes' ;
    rdfs:comment 'Estimated time in minutes for a player to complete the survey.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalSurveyUrl rdf:type rdf:Property ;
    rdfs:label 'External Survey Url' ;
    rdfs:comment 'URL link to an external survey platform (e.g., SurveyMonkey, Qualtrics) if the survey is hosted externally.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveDescription rdf:type rdf:Property ;
    rdfs:label 'Incentive Description' ;
    rdfs:comment 'Description of the incentive offered for completing the survey (e.g., 100 gems, exclusive skin).' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveOffered rdf:type rdf:Property ;
    rdfs:label 'Incentive Offered' ;
    rdfs:comment 'Indicates whether an incentive (e.g., in-game currency, items) is offered for survey completion.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:integrationPlatform rdf:type rdf:Property ;
    rdfs:label 'Integration Platform' ;
    rdfs:comment 'Third-party platform integrated for survey distribution and response collection.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localizationAvailable rdf:type rdf:Property ;
    rdfs:label 'Localization Available' ;
    rdfs:comment 'Indicates whether the survey is available in multiple languages.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxResponsesTarget rdf:type rdf:Property ;
    rdfs:label 'Max Responses Target' ;
    rdfs:comment 'Target maximum number of responses to collect before closing the survey.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseCount rdf:type rdf:Property ;
    rdfs:label 'Response Count' ;
    rdfs:comment 'Current count of responses received for this survey.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseRequired rdf:type rdf:Property ;
    rdfs:label 'Response Required' ;
    rdfs:comment 'Indicates whether survey completion is mandatory for the player.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surveyCode rdf:type rdf:Property ;
    rdfs:label 'Survey Code' ;
    rdfs:comment 'Business-readable unique code for the survey (e.g., NPS_Q1_2024, CSAT_POST_MATCH).' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerEvent rdf:type rdf:Property ;
    rdfs:label 'Trigger Event' ;
    rdfs:comment 'The in-game or platform event that triggers the survey display (e.g., match_completion, level_up, support_ticket_closed).' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableRegulation rdf:type rdf:Property ;
    rdfs:label 'Applicable Regulation' ;
    rdfs:comment 'Primary data protection regulation governing this request: GDPR (EU General Data Protection Regulation), CCPA (California Consumer Privacy Act), LGPD (Brazilian General Data Protection Law), PIPEDA (Canadian Personal Information Protection), APPI (Japanese Act on Protection of Personal Information), UK_GDPR (UK GDPR).' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costRecoveryApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Recovery Applicable Flag' ;
    rdfs:comment 'Indicates whether the request is manifestly unfounded or excessive, allowing the organization to charge a reasonable fee for processing under GDPR Article 12.5.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataExportFilePath rdf:type rdf:Property ;
    rdfs:label 'Data Export File Path' ;
    rdfs:comment 'Secure file system path or cloud storage location where the exported personal data package is stored for delivery to the data subject (for access and portability requests).' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataExportFormat rdf:type rdf:Property ;
    rdfs:label 'Data Export Format' ;
    rdfs:comment 'Format in which personal data was exported and delivered to the data subject: JSON, CSV, XML, PDF, or other machine_readable format.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erasureExecutedFlag rdf:type rdf:Property ;
    rdfs:label 'Erasure Executed Flag' ;
    rdfs:comment 'Indicates whether personal data erasure (right to be forgotten) has been executed across all relevant systems for this request.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:erasureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Erasure Timestamp' ;
    rdfs:comment 'Date and time when personal data erasure was executed across all systems in response to a right to be forgotten request.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:extendedDueDate rdf:type rdf:Property ;
    rdfs:label 'Extended Due Date' ;
    rdfs:comment 'New deadline if an extension has been granted, typically up to 60 additional days under GDPR or 45 additional days under CCPA.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extensionGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Extension Granted Flag' ;
    rdfs:comment 'Indicates whether an extension to the standard response deadline has been granted due to complexity or volume of the request.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extensionReason rdf:type rdf:Property ;
    rdfs:label 'Extension Reason' ;
    rdfs:comment 'Justification for granting an extension to the standard response deadline, such as request complexity or high volume of concurrent requests.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeChargedAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Charged Amount' ;
    rdfs:comment 'Administrative fee charged to the data subject for processing a manifestly unfounded or excessive request, in the organization\'s base currency.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:identityVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Identity Verification Method' ;
    rdfs:comment 'Method used to verify the identity of the data subject requestor: account_credentials, government_id, knowledge_based (security questions), multi_factor (MFA), manual_review, not_verified.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityVerificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Identity Verification Timestamp' ;
    rdfs:comment 'Date and time when the requestor\'s identity was successfully verified.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:identityVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Identity Verified Flag' ;
    rdfs:comment 'Indicates whether the identity of the data subject requestor has been successfully verified through the required authentication process.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalHoldReason rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Reason' ;
    rdfs:comment 'Explanation of the legal basis for placing a hold on data erasure, such as pending litigation, regulatory investigation, or legal compliance obligation.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minorFlag rdf:type rdf:Property ;
    rdfs:label 'Minor Flag' ;
    rdfs:comment 'Indicates whether the data subject is a minor (under age of digital consent), requiring special handling under COPPA, GDPR Article 8, or other child protection regulations.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentalConsentVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Parental Consent Verified Flag' ;
    rdfs:comment 'Indicates whether parental or guardian consent has been verified for data subject requests submitted on behalf of minors.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordsRetrievedCount rdf:type rdf:Property ;
    rdfs:label 'Records Retrieved Count' ;
    rdfs:comment 'Total number of data records retrieved and reviewed to fulfill this data subject request.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Externally-visible unique business identifier for the data subject request, used in communications with the data subject and regulatory authorities.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestScopeDescription rdf:type rdf:Property ;
    rdfs:label 'Request Scope Description' ;
    rdfs:comment 'Detailed description of the scope of the data subject request, including specific data categories, time periods, or systems requested by the data subject.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current lifecycle status of the data subject request: submitted (initial receipt), under_review (compliance team reviewing), identity_verification (verifying requestor identity), in_progress (actively processing), completed (fulfilled), rejected (denied with justification), withdrawn (requestor cancelled).' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestType rdf:type rdf:Property ;
    rdfs:label 'Request Type' ;
    rdfs:comment 'Type of data subject request: access (right to access personal data), rectification (right to correct inaccurate data), erasure (right to be forgotten), portability (right to data portability), restriction (right to restrict processing), objection (right to object to processing).' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorEmail rdf:type rdf:Property ;
    rdfs:label 'Requestor Email' ;
    rdfs:comment 'Email address of the individual submitting the data subject request, used for communication and identity verification.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorName rdf:type rdf:Property ;
    rdfs:label 'Requestor Name' ;
    rdfs:comment 'Full legal name of the individual submitting the data subject request.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Response Delivery Method' ;
    rdfs:comment 'Method used to deliver the response to the data subject: email, secure_portal, postal_mail, in_app notification, or api (for automated integrations).' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemsAccessed rdf:type rdf:Property ;
    rdfs:label 'Systems Accessed' ;
    rdfs:comment 'Comma-separated list of internal systems and databases accessed to fulfill this data subject request (e.g., player_database, payment_system, analytics_platform, customer_support_crm).' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Third Party Notification Required Flag' ;
    rdfs:comment 'Indicates whether third-party data processors or recipients must be notified of this data subject request (e.g., for erasure or rectification requests).' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdPartyNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Third Party Notification Status' ;
    rdfs:comment 'Status of notifications sent to third-party data processors or recipients regarding this data subject request.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAuthorityId rdf:type rdf:Property ;
    rdfs:label 'Parent Authority Id' ;
    rdfs:comment 'Reference to the parent or superior regulatory authority if this authority operates under a hierarchical structure.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryAuthority .

ind:authorityCode rdf:type rdf:Property ;
    rdfs:label 'Authority Code' ;
    rdfs:comment 'Unique business identifier or abbreviation code for the regulatory authority used in external communications and filings.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityName rdf:type rdf:Property ;
    rdfs:label 'Authority Name' ;
    rdfs:comment 'Official legal name of the regulatory authority or governing body.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityStatus rdf:type rdf:Property ;
    rdfs:label 'Authority Status' ;
    rdfs:comment 'Current operational status of the regulatory authority in its lifecycle.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityType rdf:type rdf:Property ;
    rdfs:label 'Authority Type' ;
    rdfs:comment 'Classification of the regulatory authority by jurisdictional scope and governance level.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachNotificationSlaHours rdf:type rdf:Property ;
    rdfs:label 'Breach Notification Sla Hours' ;
    rdfs:comment 'Maximum number of hours allowed to notify this authority of a data breach incident.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Contact Address Line1' ;
    rdfs:comment 'First line of the physical mailing address for the regulatory authority headquarters.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Contact Address Line2' ;
    rdfs:comment 'Second line of the physical mailing address for the regulatory authority headquarters.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactCity rdf:type rdf:Property ;
    rdfs:label 'Contact City' ;
    rdfs:comment 'City where the regulatory authority headquarters is located.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactCountryCode rdf:type rdf:Property ;
    rdfs:label 'Contact Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the regulatory authority headquarters location.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPostalCode rdf:type rdf:Property ;
    rdfs:label 'Contact Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the regulatory authority headquarters address.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectRequestSlaDays rdf:type rdf:Property ;
    rdfs:label 'Data Subject Request Sla Days' ;
    rdfs:comment 'Maximum number of days allowed to respond to data subject access requests under this authority\'s regulations.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dissolvedDate rdf:type rdf:Property ;
    rdfs:label 'Dissolved Date' ;
    rdfs:comment 'Date when the regulatory authority was dissolved, merged, or ceased operations. Null if still active.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:esportsOversight rdf:type rdf:Property ;
    rdfs:label 'Esports Oversight' ;
    rdfs:comment 'Indicates whether this authority has regulatory oversight over esports competitions and leagues.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:establishedDate rdf:type rdf:Property ;
    rdfs:label 'Established Date' ;
    rdfs:comment 'Date when the regulatory authority was officially established or chartered.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingDeadlineDays rdf:type rdf:Property ;
    rdfs:label 'Filing Deadline Days' ;
    rdfs:comment 'Number of days after period end by which compliance filings must be submitted to this authority.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gamblingRegulationScope rdf:type rdf:Property ;
    rdfs:label 'Gambling Regulation Scope' ;
    rdfs:comment 'Extent to which this authority regulates gambling-like mechanics and real-money gaming activities.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionCountryCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Country Code' ;
    rdfs:comment 'Three-letter ISO country code representing the primary country jurisdiction of the regulatory authority.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionRegion rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Region' ;
    rdfs:comment 'State, province, or regional subdivision within the country where the authority has jurisdiction.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyEnforcementLevel rdf:type rdf:Property ;
    rdfs:label 'Penalty Enforcement Level' ;
    rdfs:comment 'Relative severity and enforcement rigor of penalties imposed by this authority for non-compliance.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactTitle rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Title' ;
    rdfs:comment 'Job title or role of the primary contact person at the regulatory authority.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDomain rdf:type rdf:Property ;
    rdfs:label 'Regulatory Domain' ;
    rdfs:comment 'Primary area of regulatory oversight and compliance focus for gaming operations.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthorityId rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_authority. Business justification: Regulatory directives are issued by regulatory authorities. Should FK to the regulatory_authority that issued the directive. Currently has issuing_authority (STRING); should normalize to FK.' ;
    rdfs:domain ind:RegulatoryDirective ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryAuthority .

ind:supersededByDirectiveId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Directive Id' ;
    rdfs:comment 'Reference to the regulatory_directive_id of the newer directive that supersedes this one, if applicable. Null if this directive is still current or has been repealed without replacement.' ;
    rdfs:domain ind:RegulatoryDirective ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryDirective .

ind:applicabilityScope rdf:type rdf:Property ;
    rdfs:label 'Applicability Scope' ;
    rdfs:comment 'Defines which gaming products or platforms are subject to this directive (all games, mobile only, console only, PC only, online multiplayer only, specific genres, or games with specific age ratings).' ;
    rdfs:domain ind:RegulatoryDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'Compliance Owner Email' ;
    rdfs:comment 'Corporate email address of the compliance owner for this directive, used for internal coordination and audit inquiries.' ;
    rdfs:domain ind:RegulatoryDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceOwnerName rdf:type rdf:Property ;
    rdfs:label 'Compliance Owner Name' ;
    rdfs:comment 'Full name of the individual designated as the compliance owner or subject matter expert for this directive within the organization.' ;
    rdfs:domain ind:RegulatoryDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compliancePriority rdf:type rdf:Property ;
    rdfs:label 'Compliance Priority' ;
    rdfs:comment 'Business priority level assigned to compliance with this directive based on risk exposure, penalty severity, and business impact (critical, high, medium, low).' ;
    rdfs:domain ind:RegulatoryDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRatingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Content Rating Required Flag' ;
    rdfs:comment 'Indicates whether this directive mandates obtaining an age/content rating from a classification board (e.g., ESRB, PEGI, USK) before distribution (True) or not (False).' ;
    rdfs:domain ind:RegulatoryDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSubjectRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Data Subject Rights Flag' ;
    rdfs:comment 'Indicates whether this directive grants specific rights to data subjects (e.g., GDPR right to access, right to erasure, COPPA parental consent) that must be operationalized (True) or not (False).' ;
    rdfs:domain ind:RegulatoryDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:directiveCode rdf:type rdf:Property ;
    rdfs:label 'Directive Code' ;
    rdfs:comment 'Unique business identifier code for the regulatory directive, used for external reference and reporting (e.g., GDPR-2016-679, COPPA-1998, ESRB-M17).' ;
    rdfs:domain ind:RegulatoryDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directiveDescription rdf:type rdf:Property ;
    rdfs:label 'Directive Description' ;
    rdfs:comment 'Detailed description of the regulatory directive, including its purpose, scope, and key requirements for gaming operations.' ;
    rdfs:domain ind:RegulatoryDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directiveName rdf:type rdf:Property ;
    rdfs:label 'Directive Name' ;
    rdfs:comment 'Full official name of the regulatory directive or legal requirement.' ;
    rdfs:domain ind:RegulatoryDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directiveStatus rdf:type rdf:Property ;
    rdfs:label 'Directive Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory directive indicating whether it is enforceable, pending implementation, superseded by newer regulation, repealed, under review, or in draft state.' ;
    rdfs:domain ind:RegulatoryDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directiveType rdf:type rdf:Property ;
    rdfs:label 'Directive Type' ;
    rdfs:comment 'Classification of the regulatory directive by its primary regulatory domain (privacy regulation, consumer protection, age rating, loot box disclosure, data localization, content restriction).' ;
    rdfs:domain ind:RegulatoryDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalPolicyDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Internal Policy Document Url' ;
    rdfs:comment 'Link to the internal compliance policy, procedure document, or knowledge base article that operationalizes this directive within the organization.' ;
    rdfs:domain ind:RegulatoryDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionLevel rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Level' ;
    rdfs:comment 'Administrative level at which the directive is enforced (international treaty, federal/national law, state/provincial regulation, or municipal ordinance).' ;
    rdfs:domain ind:RegulatoryDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalCitation rdf:type rdf:Property ;
    rdfs:label 'Legal Citation' ;
    rdfs:comment 'Official legal citation or reference number for the directive in the issuing jurisdiction\'s legal system (e.g., Regulation (EU) 2016/679, 15 U.S.C. §§ 6501–6506).' ;
    rdfs:domain ind:RegulatoryDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lootBoxDisclosureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Loot Box Disclosure Required Flag' ;
    rdfs:comment 'Indicates whether this directive requires disclosure of loot box, gacha, or randomized reward probabilities to players (True) or not (False).' ;
    rdfs:domain ind:RegulatoryDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:officialUrl rdf:type rdf:Property ;
    rdfs:label 'Official Url' ;
    rdfs:comment 'Web address linking to the official published text of the regulatory directive on the issuing authority\'s website.' ;
    rdfs:domain ind:RegulatoryDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltySeverity rdf:type rdf:Property ;
    rdfs:label 'Penalty Severity' ;
    rdfs:comment 'Classification of the enforcement penalty type for non-compliance (criminal prosecution, administrative fine, civil penalty, warning notice, or no specific penalty defined).' ;
    rdfs:domain ind:RegulatoryDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Reporting Required Flag' ;
    rdfs:comment 'Indicates whether this directive mandates periodic regulatory reporting to the issuing authority (True) or not (False).' ;
    rdfs:domain ind:RegulatoryDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleDepartment rdf:type rdf:Property ;
    rdfs:label 'Responsible Department' ;
    rdfs:comment 'Name of the internal business unit or department responsible for ensuring compliance with this directive (e.g., Legal, Compliance, Privacy Office, Product Management).' ;
    rdfs:domain ind:RegulatoryDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approver rdf:type rdf:Property ;
    rdfs:label 'Approver' ;
    rdfs:comment 'Name or identifier of the compliance officer or legal authority who approved this training module for deployment.' ;
    rdfs:domain ind:TrainingModule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentUrl rdf:type rdf:Property ;
    rdfs:label 'Assessment Url' ;
    rdfs:comment 'URL or file path to the assessment or quiz component of the training module.' ;
    rdfs:domain ind:TrainingModule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:author rdf:type rdf:Property ;
    rdfs:label 'Author' ;
    rdfs:comment 'Name or identifier of the individual or team responsible for creating the training module content.' ;
    rdfs:domain ind:TrainingModule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateTemplateCode rdf:type rdf:Property ;
    rdfs:label 'Certificate Template Code' ;
    rdfs:comment 'Identifier for the certificate template used to generate completion certificates for this training module.' ;
    rdfs:domain ind:TrainingModule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:learningObjectives rdf:type rdf:Property ;
    rdfs:label 'Learning Objectives' ;
    rdfs:comment 'Structured list of learning objectives and competencies that employees will achieve upon successful completion of the training module.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moduleCode rdf:type rdf:Property ;
    rdfs:label 'Module Code' ;
    rdfs:comment 'Externally-known unique code for the training module used in compliance tracking systems and regulatory reporting.' ;
    rdfs:domain ind:TrainingModule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moduleType rdf:type rdf:Property ;
    rdfs:label 'Module Type' ;
    rdfs:comment 'Categorical classification of the training module based on the compliance domain it addresses. [ENUM-REF-CANDIDATE: regulatory_compliance|data_privacy|age_rating|loot_box_disclosure|esrb_certification|gdpr_training|coppa_training|pegi_certification|audit_preparation|jurisdictional_reporting — promote to reference product]' ;
    rdfs:domain ind:TrainingModule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passingScorePercentage rdf:type rdf:Property ;
    rdfs:label 'Passing Score Percentage' ;
    rdfs:comment 'Minimum percentage score required to successfully complete the training module and meet compliance requirements.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prerequisites rdf:type rdf:Property ;
    rdfs:label 'Prerequisites' ;
    rdfs:comment 'Description of any prerequisite training modules or knowledge required before taking this module.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recertificationIntervalMonths rdf:type rdf:Property ;
    rdfs:label 'Recertification Interval Months' ;
    rdfs:comment 'Number of months between required recertification completions for this training module. Null if recertification is not required.' ;
    rdfs:domain ind:TrainingModule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Recertification Required' ;
    rdfs:comment 'Indicates whether employees must retake this training module periodically to maintain compliance certification.' ;
    rdfs:domain ind:TrainingModule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentSuiteId rdf:type rdf:Property ;
    rdfs:label 'Parent Suite Id' ;
    rdfs:comment 'Reference to a parent test suite if this suite is a sub-suite or component of a larger testing hierarchy.' ;
    rdfs:domain ind:TestSuite ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestSuite .

ind:automationLevel rdf:type rdf:Property ;
    rdfs:label 'Automation Level' ;
    rdfs:comment 'Degree of test automation within the suite indicating the balance between automated and manual test execution.' ;
    rdfs:domain ind:TestSuite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingForRelease rdf:type rdf:Property ;
    rdfs:label 'Blocking For Release' ;
    rdfs:comment 'Indicates whether failure of this test suite blocks game release or deployment to production.' ;
    rdfs:domain ind:TestSuite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:buildVersionTarget rdf:type rdf:Property ;
    rdfs:label 'Build Version Target' ;
    rdfs:comment 'Target game build version or version range that this test suite is designed to validate (e.g., \'1.2.0\', \'2.0.x\', \'Release Candidate 3\').' ;
    rdfs:domain ind:TestSuite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Minutes' ;
    rdfs:comment 'Expected time in minutes required to complete full execution of all tests in the suite.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executionFrequency rdf:type rdf:Property ;
    rdfs:label 'Execution Frequency' ;
    rdfs:comment 'Scheduled or triggered frequency at which this test suite should be executed in the QA pipeline.' ;
    rdfs:domain ind:TestSuite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Pass Threshold Percentage' ;
    rdfs:comment 'Minimum percentage of test cases that must pass for the suite execution to be considered successful and meet release quality gates.' ;
    rdfs:domain ind:TestSuite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:suiteCode rdf:type rdf:Property ;
    rdfs:label 'Suite Code' ;
    rdfs:comment 'Unique business identifier code for the test suite used across QA systems and reporting (e.g., \'TS-MP-001\', \'CERT-PS5-2024\').' ;
    rdfs:domain ind:TestSuite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suiteName rdf:type rdf:Property ;
    rdfs:label 'Suite Name' ;
    rdfs:comment 'Human-readable name of the test suite (e.g., \'Multiplayer Stress Test\', \'UI Regression Suite\', \'Platform Certification Suite\').' ;
    rdfs:domain ind:TestSuite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suiteStatus rdf:type rdf:Property ;
    rdfs:label 'Suite Status' ;
    rdfs:comment 'Current lifecycle status of the test suite indicating its operational state and availability for execution.' ;
    rdfs:domain ind:TestSuite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suiteType rdf:type rdf:Property ;
    rdfs:label 'Suite Type' ;
    rdfs:comment 'Classification of the test suite by testing methodology (functional, regression, performance, security, compliance, certification).' ;
    rdfs:domain ind:TestSuite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testFramework rdf:type rdf:Property ;
    rdfs:label 'Test Framework' ;
    rdfs:comment 'Testing framework or tool used to implement and execute the test suite (e.g., \'Selenium\', \'Unity Test Framework\', \'Unreal Automation Tool\', \'Custom Framework\').' ;
    rdfs:domain ind:TestSuite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testScope rdf:type rdf:Property ;
    rdfs:label 'Test Scope' ;
    rdfs:comment 'Specific game features, systems, or components covered by this test suite (e.g., \'Multiplayer Matchmaking\', \'In-Game Economy\', \'Graphics Rendering\', \'Audio System\').' ;
    rdfs:domain ind:TestSuite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approval User Employee Id' ;
    rdfs:comment 'Reference to the user who approved this content pack for deployment. Null if not yet approved.' ;
    rdfs:domain ind:ContentPack ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:titleId rdf:type rdf:Property ;
    rdfs:label 'Title Id' ;
    rdfs:comment 'Reference to the game title this content pack is associated with.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GameTitle .

ind:archiveDate rdf:type rdf:Property ;
    rdfs:label 'Archive Date' ;
    rdfs:comment 'Date when the content pack was archived and moved to long-term storage. Null for active or deprecated content packs.' ;
    rdfs:domain ind:ContentPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compressionAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Compression Algorithm' ;
    rdfs:comment 'Compression algorithm applied to the content pack for storage and distribution optimization.' ;
    rdfs:domain ind:ContentPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependencyPackIds rdf:type rdf:Property ;
    rdfs:label 'Dependency Pack Ids' ;
    rdfs:comment 'Comma-separated list of content pack IDs that this pack depends on for proper functionality. Null if no dependencies exist.' ;
    rdfs:domain ind:ContentPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorReportCount rdf:type rdf:Property ;
    rdfs:label 'Error Report Count' ;
    rdfs:comment 'Total number of error reports or bug reports associated with this content pack since deployment.' ;
    rdfs:domain ind:ContentPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventEndDate rdf:type rdf:Property ;
    rdfs:label 'Event End Date' ;
    rdfs:comment 'End date for live-ops event content availability, if applicable. Null for non-event or permanent content packs.' ;
    rdfs:domain ind:ContentPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventStartDate rdf:type rdf:Property ;
    rdfs:label 'Event Start Date' ;
    rdfs:comment 'Start date for live-ops event content availability, if applicable. Null for non-event content packs.' ;
    rdfs:domain ind:ContentPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:liveOpsEventFlag rdf:type rdf:Property ;
    rdfs:label 'Live Ops Event Flag' ;
    rdfs:comment 'Indicates whether this content pack is part of a live-ops event such as seasonal content, limited-time events, or special promotions.' ;
    rdfs:domain ind:ContentPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localizationLanguageCount rdf:type rdf:Property ;
    rdfs:label 'Localization Language Count' ;
    rdfs:comment 'Number of languages supported in this content pack for localization strings and audio.' ;
    rdfs:domain ind:ContentPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lodVariantFlag rdf:type rdf:Property ;
    rdfs:label 'Lod Variant Flag' ;
    rdfs:comment 'Indicates whether this content pack includes multiple LOD (Level of Detail) asset variants for performance optimization.' ;
    rdfs:domain ind:ContentPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packCode rdf:type rdf:Property ;
    rdfs:label 'Pack Code' ;
    rdfs:comment 'Externally-known unique business identifier for the content pack, used in game manifests and deployment pipelines.' ;
    rdfs:domain ind:ContentPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packName rdf:type rdf:Property ;
    rdfs:label 'Pack Name' ;
    rdfs:comment 'Human-readable name of the content pack displayed to developers and content teams.' ;
    rdfs:domain ind:ContentPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packStatus rdf:type rdf:Property ;
    rdfs:label 'Pack Status' ;
    rdfs:comment 'Current lifecycle status of the content pack in the asset pipeline workflow.' ;
    rdfs:domain ind:ContentPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packType rdf:type rdf:Property ;
    rdfs:label 'Pack Type' ;
    rdfs:comment 'Classification of the content pack by asset category: art assets, audio files, localization strings, level/map data, NPC definitions, or textures.' ;
    rdfs:domain ind:ContentPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityAssuranceStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Assurance Status' ;
    rdfs:comment 'Current quality assurance testing status of the content pack.' ;
    rdfs:domain ind:ContentPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSizeMb rdf:type rdf:Property ;
    rdfs:label 'Total Size Mb' ;
    rdfs:comment 'Total storage size of the content pack in megabytes, including all assets and metadata.' ;
    rdfs:domain ind:ContentPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ugcModerationRequired rdf:type rdf:Property ;
    rdfs:label 'Ugc Moderation Required' ;
    rdfs:comment 'Indicates whether this content pack contains user-generated content requiring moderation review before deployment.' ;
    rdfs:domain ind:ContentPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accessibilityCompliant rdf:type rdf:Property ;
    rdfs:label 'Accessibility Compliant' ;
    rdfs:comment 'Indicates whether the venue meets accessibility standards for individuals with disabilities.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address of the venue location.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address information such as suite, floor, or building number.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastInfrastructureTier rdf:type rdf:Property ;
    rdfs:label 'Broadcast Infrastructure Tier' ;
    rdfs:comment 'Classification of the venues broadcast and streaming infrastructure capabilities for esports events.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concessionAvailable rdf:type rdf:Property ;
    rdfs:label 'Concession Available' ;
    rdfs:comment 'Indicates whether food and beverage concessions are available at the venue.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiration Date' ;
    rdfs:comment 'Date when the current venue partnership or rental contract expires.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRenovationDate rdf:type rdf:Property ;
    rdfs:label 'Last Renovation Date' ;
    rdfs:comment 'Date of the most recent major renovation or upgrade to the venue facilities.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the venue location in decimal degrees.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the venue location in decimal degrees.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:merchandiseStoreAvailable rdf:type rdf:Property ;
