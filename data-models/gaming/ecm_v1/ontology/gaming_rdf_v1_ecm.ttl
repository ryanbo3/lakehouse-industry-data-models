ind:minRosterSize rdf:type rdf:Property ;
    rdfs:label 'Min Roster Size' ;
    rdfs:comment 'Minimum number of players each team must maintain on their roster after transfers are completed.' ;
    rdfs:domain ind:TransferWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openTimestamp rdf:type rdf:Property ;
    rdfs:label 'Open Timestamp' ;
    rdfs:comment 'Precise timestamp when the transfer window opens, including time zone information for global coordination.' ;
    rdfs:domain ind:TransferWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requiresLeagueApproval rdf:type rdf:Property ;
    rdfs:label 'Requires League Approval' ;
    rdfs:comment 'Indicates whether all transfers during this window must be reviewed and approved by league officials before becoming effective.' ;
    rdfs:domain ind:TransferWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salaryCapApplies rdf:type rdf:Property ;
