    rdfs:range xsd:string .

ind:transferWindowId rdf:type rdf:Property ;
    rdfs:label 'Transfer Window Id' ;
    rdfs:comment 'Primary key for transfer_window' ;
    rdfs:domain ind:TransferWindow ;
