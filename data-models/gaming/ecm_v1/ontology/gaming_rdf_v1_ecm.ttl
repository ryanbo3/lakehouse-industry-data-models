    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessUnit .

ind:sourceCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Source Cost Center Id' ;
    rdfs:comment 'The cost center from which costs are being allocated in this cycle.' ;
