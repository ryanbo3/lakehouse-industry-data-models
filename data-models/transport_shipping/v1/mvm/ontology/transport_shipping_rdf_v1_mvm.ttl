# RDFS Schema for Business: Transport Shipping

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ind: <http://datamodel.lakehouse.org/business/transport_shipping#> .

# --- Root Business Class ---
ind:Business rdf:type rdfs:Class ;
    rdfs:label 'Business' ;
    rdfs:comment 'Root class for all business entities' .

# --- Specific Business: Transport Shipping ---
ind:TransportShipping rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Business ;
    rdfs:label 'Transport Shipping' ;
    rdfs:comment 'Transport and Shipping is a global logistics industry providing express delivery, freight forwarding, supply chain management, and e-commerce fulfillment services that connect businesses and consumers across continents.' .

# --- Domain Classes ---
ind:Shipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:TransportShipping ;
    rdfs:label 'Shipment' ;
    rdfs:comment 'Core operational domain managing end-to-end shipment lifecycle from booking through delivery across express parcel, freight, and cross-border movements. Owns shipment identity, tracking events, POD/ePOD, ETA/ETD milestones, exception management, and AWB/BOL/HAWB/MAWB document references. Serves as the transactional backbone integrating TMS, FourKites visibility, and carrier execution data for D2D services.' .

ind:Customer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:TransportShipping ;
    rdfs:label 'Customer' ;
    rdfs:comment 'Single source of truth for all customer identity, account hierarchy, and relationship data across B2B enterprise accounts, B2C individual shippers, consignees, and 3PL/4PL partners. Manages customer profiles, account segmentation, contact management, SLA entitlements, service preferences, and CRM-sourced opportunity and service case data from Salesforce.' .

ind:Freight rdf:type rdfs:Class ;
    rdfs:subClassOf ind:TransportShipping ;
    rdfs:label 'Freight' ;
    rdfs:comment 'Manages freight forwarding operations and order lifecycle across air, ocean, road, and rail modes including FTL, LTL, FCL, LCL, and TEU-based container movements. Owns freight bookings, consolidations, load plans, carrier assignments, NVOCC arrangements, intermodal transfers, CFS and ICD operations, and mode-specific charge components such as BAF, GRI, and THC. Integrates with SAP TM and Oracle TMS.' .

ind:Warehouse rdf:type rdfs:Class ;
    rdfs:subClassOf ind:TransportShipping ;
    rdfs:label 'Warehouse' ;
    rdfs:comment 'Governs all warehouse and distribution center operations including inbound receiving, putaway, slotting optimization, inventory control, order picking, packing, and outbound dispatch. Owns SKU master, FIFO/LIFO inventory positions, ASN processing, WIP tracking, labor productivity metrics, and returns management. Powered by Manhattan WMS and supports e-commerce fulfillment and contract logistics.' .

ind:Fleet rdf:type rdfs:Class ;
    rdfs:subClassOf ind:TransportShipping ;
    rdfs:label 'Fleet' ;
    rdfs:comment 'Fleet and transport asset management covering the full lifecycle of owned and leased vehicles, aircraft, vessels, and containers. Owns asset master data, GPS telematics, RFID tagging, maintenance scheduling, fuel consumption, driver assignment, regulatory compliance (DOT, ICAO), CAPEX/OPEX asset tracking, and fleet utilization KPIs. Integrates with TMS for route execution and IoT sensor data for real-time visibility.' .

ind:Customs rdf:type rdfs:Class ;
    rdfs:subClassOf ind:TransportShipping ;
    rdfs:label 'Customs' ;
    rdfs:comment 'Manages end-to-end customs brokerage and trade compliance for cross-border shipments. Owns HS Code classification, import/export declarations, ISF and AMS filings, denied party screening, C-TPAT and AEO program compliance, duty and tax calculation, FTZ management, tariff management, and Incoterms-based liability determination. Powered by Descartes Customs GTM and aligned to WCO, WTO, and national customs authority requirements.' .

ind:Pricing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:TransportShipping ;
    rdfs:label 'Pricing' ;
    rdfs:comment 'SSOT for all tariff structures, rate cards, surcharge schedules, and dynamic pricing rules governing freight forwarding, express delivery, and contract logistics. Owns base rates, DIM weight calculations, fuel surcharges, GRI/BAF adjustments, THC, accessorial charges, Incoterms-based charge allocation (DDP, DAP, FOB, CIF, EXW), spot quote generation, and contract pricing. Feeds billing and contract domains for revenue recognition.' .

ind:Route rdf:type rdfs:Class ;
    rdfs:subClassOf ind:TransportShipping ;
    rdfs:label 'Route' ;
    rdfs:comment 'SSOT for network topology, lane definitions, hub-and-spoke configurations, and transport route planning across all modes and geographies. Owns origin-destination lane master, service corridors, transit time standards, last-mile delivery zones, carrier lane allocations, ETA/ETD management, and network optimization outputs from Blue Yonder. Supports predictive ETA calculation, load optimization, carrier selection, and FourKites real-time visibility integration.' .

ind:Fulfillment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:TransportShipping ;
    rdfs:label 'Fulfillment' ;
    rdfs:comment 'Manages e-commerce and D2D fulfillment execution including order orchestration, pick-pack-ship workflows, last-mile dispatch, carrier selection for parcel delivery, returns processing (RMA), advanced shipping notices (ASN), COD collections, and SLA breach tracking. Owns fulfillment orders, parcel manifests, delivery attempts, ePOD capture, and omnichannel integration via EDI and API channels with merchant e-commerce platforms.' .

ind:Contract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:TransportShipping ;
    rdfs:label 'Contract' ;
    rdfs:comment 'Contract and agreement management for customer service contracts, carrier agreements, 3PL/4PL partnerships, and vendor contracts. Manages SLA thresholds, OTD/OTIF KPI commitments, Incoterms (DDP, DAP, FOB, CIF, EXW), rate validity periods, volume commitments, penalty/incentive clauses, contract terms, renewals, and compliance tracking. Interfaces with pricing, billing, and customer domains.' .

ind:Claim rdf:type rdfs:Class ;
    rdfs:subClassOf ind:TransportShipping ;
    rdfs:label 'Claim' ;
    rdfs:comment 'Manages cargo insurance claims, loss and damage assessments, liability determinations, delay claims, and subrogation processes across all transport modes. Owns claim registration, cargo survey reports, settlement calculations, insurer correspondence, claim status lifecycle, and dangerous goods claims. Aligned to IMO, IATA Warsaw-Montreal Convention, and CMR Convention liability frameworks. Interfaces with billing for credit notes and finance for reserve accounting.' .

ind:Billing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:TransportShipping ;
    rdfs:label 'Billing' ;
    rdfs:comment 'SSOT for all revenue transactions, invoicing, freight audit and payment, payment processing, and accounts receivable across all service lines. Owns customer invoices, carrier payables, COD collections, credit notes, dispute resolution, charge-back management, and revenue recognition aligned to IFRS 15. Integrates with SAP S/4HANA Finance and Coupa for end-to-end procure-to-pay and order-to-cash cycles.' .

ind:Procurement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:TransportShipping ;
    rdfs:label 'Procurement' ;
    rdfs:comment 'Manages sourcing, supplier onboarding, purchase order lifecycle, carrier procurement, and spend management for operational and capital expenditures. Owns supplier master, RFQ/RFP processes, purchase orders, invoice matching, and contract compliance monitoring. Powered by Coupa and integrates with SAP S/4HANA Finance for budget control and with fleet and warehouse domains for asset procurement.' .

ind:Network rdf:type rdfs:Class ;
    rdfs:subClassOf ind:TransportShipping ;
    rdfs:label 'Network' ;
    rdfs:comment 'Manages partner network relationships including carrier profiles, agent networks, correspondent offices, interline agreements, and third-party logistics provider operational capabilities across all geographies and transport modes.' .

# --- Data Product Classes (Tables) ---
ind:CargoClaim rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Claim ;
    rdfs:label 'Cargo Claim' ;
    rdfs:comment 'Core master entity representing a registered cargo insurance or liability claim. Captures the full claim lifecycle from initial registration (claimant details, claimed amount, AWB/BOL references) through investigation, liability determination, settlement or rejection. Covers loss, damage, shortage, delay, contamination, and dangerous goods claims across all transport modes (air, ocean, road, rail). Includes incident event details (date, location, circumstances, transport mode) and claim type classification. Aligned to IMO, IATA Warsaw-Montreal Convention, CMR Convention, and Hague-Visby liability frameworks. Serves as the SSOT for all claim identity, status, valuation, and lifecycle data.' .

ind:ClaimEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Claim ;
    rdfs:label 'Claim Event' ;
    rdfs:comment 'Transactional record capturing the initiating loss or damage event that triggers a cargo claim. Records the incident date, location, transport mode, event type (loss, damage, shortage, delay, contamination, dangerous goods incident), and initial circumstances. Provides the factual basis for liability determination and insurer correspondence. One claim event may generate one or more cargo claims.' .

ind:CargoSurvey rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Claim ;
    rdfs:label 'Cargo Survey' ;
    rdfs:comment 'Master record for a cargo survey report commissioned to assess the nature, extent, and cause of cargo loss or damage. Captures surveyor identity, survey date and location, survey methodology, findings, estimated loss value, and liability attribution. Used as primary evidence in claim settlement calculations and insurer correspondence. Aligned to IATA and IMO cargo survey standards.' .

ind:LiabilityDetermination rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Claim ;
    rdfs:label 'Liability Determination' ;
    rdfs:comment 'Transactional record documenting the formal liability assessment for a cargo claim. Captures the applicable liability convention (Warsaw-Montreal, CMR, Hague-Visby, COGSA), liability limit per kg or per package, contributory negligence factors, carrier liability percentage, shipper/consignee liability percentage, and the legal basis for the determination. Drives settlement calculation and insurer correspondence.' .

ind:Settlement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Claim ;
    rdfs:label 'Settlement' ;
    rdfs:comment 'Transactional record capturing the financial settlement of a cargo claim. Records settlement amount, settlement currency, payment method, settlement date, credit note reference (linked to billing domain), reserve release amount, insurer recovery amount, and settlement acceptance status. Interfaces with SAP S/4HANA Finance for reserve accounting and billing for credit note issuance.' .

ind:StatusHistory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Claim ;
    rdfs:label 'Status History' ;
    rdfs:comment 'Lifecycle tracking entity recording every status transition of a cargo claim from registration through closure. Captures status code, transition timestamp, responsible party, reason code, and notes for each state change (e.g., Registered → Under Investigation → Survey Commissioned → Liability Determined → Settlement Offered → Settled/Rejected/Subrogated). Enables SLA monitoring and regulatory audit trails.' .

ind:ClaimDocument rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Claim ;
    rdfs:label 'Claim Document' ;
    rdfs:comment 'Master record cataloguing all documents and formal correspondence attached to a cargo claim file. Captures document type (AWB, BOL, commercial invoice, packing list, survey report, photos, ePOD, customs declaration, dangerous goods manifest, insurer correspondence, demand letters, settlement offers), document source, communication channel, sent/received timestamp, response status, upload timestamp, document status, and storage reference. Ensures claim file completeness for liability determination, insurer SLA compliance, and regulatory compliance under IATA, IMO, and WCO requirements.' .

ind:Reserve rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Claim ;
    rdfs:label 'Reserve' ;
    rdfs:comment 'Financial reserve record established for an open cargo claim representing estimated liability exposure on the balance sheet. Captures initial reserve amount, reserve currency, reserve establishment date, periodic reserve adjustments (increases/decreases with reason codes), reserve release date and amount upon settlement, and linkage to finance domain cost center and GL account. Required for IFRS 17/IAS 37 provisioning compliance, SOX-compliant financial reporting, and monthly reserve adequacy reviews. Interfaces with SAP S/4HANA Finance for automated reserve posting and release.' .

ind:Line rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Claim ;
    rdfs:label 'Line' ;
    rdfs:comment 'Line-item detail record within a cargo claim, representing individual damaged, lost, or short-shipped SKUs or cargo units. Captures SKU reference, commodity description, HS code, quantity claimed, unit value, total claimed value, currency, condition at origin, and condition at destination. Enables granular claim valuation and supports customs and trade compliance reporting under WCO requirements.' .

ind:ClaimParty rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Claim ;
    rdfs:label 'Claim Party' ;
    rdfs:comment 'Association entity linking all parties involved in a cargo claim to their respective roles and responsibilities. Captures party type (claimant, carrier, sub-carrier, insurer, underwriter, surveyor, legal counsel, customs authority, port operator, freight handler), party reference ID, contact details, notification status, response deadlines, and role-specific attributes. Enables multi-party claim management across complex intermodal and cross-border shipments where liability may be shared among multiple carriers and intermediaries.' .

ind:Policy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Claim ;
    rdfs:label 'Policy' ;
    rdfs:comment 'Reference entity defining the cargo insurance policy under which a claim is filed. Captures policy number, insurer name, policy type (all-risk, named perils, war risk), coverage limit, deductible amount, policy period, covered transport modes, and special conditions. Serves as the contractual basis for claim eligibility assessment and settlement calculation. Distinct from the contract domain which manages carrier and customer service contracts.' .

ind:CustomerAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Customer Account' ;
    rdfs:comment 'Master record for all customer accounts in the logistics network, covering B2B enterprise shippers, B2C individual senders, consignees, and 3PL/4PL partners. Sourced from Salesforce CRM Account object. Stores account identity, legal entity name, tax registration (VAT/GST/EIN), classification (B2B/B2C/3PL/4PL), industry vertical, credit status, account tier, onboarding date, account manager assignment, and operational flags such as DDP eligibility, AEO certification status, and active/suspended/closed lifecycle state.' .

ind:Contact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Contact' ;
    rdfs:comment 'Individual contact persons associated with customer accounts, including shipping coordinators, procurement managers, finance contacts, and authorized signatories. Sourced from Salesforce CRM Contact object. Captures full name, job title, department, communication preferences, language, time zone, and contact role (e.g., billing contact, operational contact, escalation contact).' .

ind:AccountHierarchy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Account Hierarchy' ;
    rdfs:comment 'Defines parent-child relationships within enterprise customer account structures, supporting multi-national corporate hierarchies, subsidiary relationships, and regional account groupings. Enables consolidated billing, group-level SLA management, and enterprise revenue roll-up across global accounts. Tracks hierarchy level, relationship type (parent/subsidiary/affiliate), effective dates, and consolidation flags.' .

ind:ShipperProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Shipper Profile' ;
    rdfs:comment 'Operational profile for customers acting as shippers (origin parties) in logistics transactions. Captures shipper-specific attributes including default origin addresses, preferred service modes (air/ocean/road/rail), FTL/LTL/FCL/LCL preferences, carrier preferences, packaging requirements, hazmat handling authorizations (IMDG/IATA DGR), IATA shipper codes, C-TPAT or AEO certification references, default Incoterms, COD preferences, special handling instructions (fragile, temperature-controlled), and notification preferences (SMS/email/EDI/webhook). Serves as the unified operational defaults profile for shipment booking automation and personalized service delivery.' .

ind:ConsigneeProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Consignee Profile' ;
    rdfs:comment 'Operational profile for parties designated as consignees (destination recipients) in logistics shipments. Stores consignee identity, delivery address preferences, customs clearance authorizations, import license numbers, preferred delivery windows, ePOD contact details, and special delivery instructions. Supports both recurring consignees (B2B) and one-time recipients (B2C last-mile). Distinct from shipper_profile as consignees have import-side compliance and delivery-side operational attributes.' .

ind:AddressBook rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Address Book' ;
    rdfs:comment 'Centralized repository of all customer-associated addresses including origin pickup locations, delivery destinations, billing addresses, and warehouse addresses. Supports address validation, geocoding coordinates, address type classification (residential/commercial/warehouse/port), and address lifecycle management. Used across shipment booking, last-mile delivery, and customs declarations to ensure address standardization.' .

ind:Segment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Market segmentation classification for customer accounts defining commercial tiers, revenue bands, and strategic groupings used for pricing, SLA assignment, and account management. Captures segment code, segment name, revenue threshold ranges, assigned account management model (strategic/commercial/digital), eligible service lines, and segment review cycle. Supports differentiated service delivery and targeted commercial strategies.' .

ind:SlaEntitlement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Sla Entitlement' ;
    rdfs:comment 'Defines service level entitlements and volume commitments granted to a customer account, specifying OTD targets, OTIF commitments, transit time guarantees, pickup cut-off times, claims resolution SLAs, escalation thresholds, and minimum volume thresholds (TEU, kg, shipment count) by service line or lane. Captures SLA tier, applicable service modes, performance measurement methodology, penalty/incentive clauses for under/over-performance, measurement periods, and effective date ranges. Distinct from contract domain SLA templates — this is the customer-specific instantiated entitlement.' .

ind:ServicePreference rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Service Preference' ;
    rdfs:comment 'Stores customer-level operational preferences governing how shipments are handled, routed, and communicated. Includes preferred transport modes, carrier preferences, packaging requirements, notification preferences (SMS/email/EDI), tracking visibility settings, default Incoterms, COD preferences, and special handling instructions (e.g., fragile, temperature-controlled, IMDG hazmat). Enables automated shipment booking defaults and personalized service delivery.' .

ind:ServiceCase rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Service Case' ;
    rdfs:comment 'Customer service case records sourced from Salesforce CRM capturing complaints, service failures, shipment inquiries, claims initiation requests, and general support interactions. Tracks case number, case type, priority, status, root cause category, resolution details, SLA breach flag, escalation history, and linked shipment or AWB references. Distinct from the claim domain which manages financial liability — this entity manages the customer service workflow.' .

ind:Onboarding rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Onboarding' ;
    rdfs:comment 'Tracks the end-to-end customer onboarding lifecycle from initial account creation through activation, including KYC/AML verification, credit assessment, system provisioning (TMS/WMS access, EDI setup), and training completion. Captures onboarding stage, assigned onboarding manager, checklist item statuses, go-live date, and onboarding channel (digital self-serve vs. managed). Ensures compliance with regulatory due diligence requirements.' .

ind:CreditProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Credit Profile' ;
    rdfs:comment 'Financial credit standing and payment terms for customer accounts, governing credit limit, payment terms (net 30/60/90), credit rating, credit hold status, outstanding balance thresholds, and currency of credit. Captures credit review dates, credit agency references, and approved credit limit history. Used by billing and finance domains to enforce payment controls and by operations to gate shipment release on credit-held accounts.' .

ind:PartnerRelationship rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Partner Relationship' ;
    rdfs:comment 'Defines formal logistics partnership relationships between customer accounts and third-party logistics providers (3PL/4PL), freight brokers, NVOCCs, customs brokers, and co-loading partners. Captures relationship type, partner role (subcontractor/agent/co-loader), authorized service scopes, geographic coverage, data sharing permissions, EDI/API connectivity status, performance rating, and relationship effective dates. Governs customer-side partner network topology for multi-party shipment orchestration.' .

ind:Lane rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Route ;
    rdfs:label 'Lane' ;
    rdfs:comment 'Master origin-destination lane definition representing a directional transport corridor between two network nodes (city, port, airport, ICD, CFS, or postal zone pair). Owns the canonical lane identifier used across SAP TM, Oracle TMS, and Blue Yonder for rate lookup, carrier selection, and network optimization. Captures lane type (express, freight, last-mile), transport mode (air, ocean, road, rail, multimodal), lane status, standard transit time, distance (km/miles), lane tier classification, applicable Incoterms, operational restrictions (embargo, DG prohibition, seasonal closure, capacity freeze), restriction effective dates, and restriction authority. SSOT for all O-D lane master data referenced by pricing, freight, and shipment domains.' .

ind:NetworkNode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Route ;
    rdfs:label 'Network Node' ;
    rdfs:comment 'Master record for every physical or logical node in the transport network including origin/destination hubs, gateways, sorting centers, warehouses, ICDs, CFSs, FTZs, ports, airports, and last-mile delivery depots. Captures node code, node type, IATA/UN LOCODE, geographic coordinates (lat/long), country, region, time zone, operating hours, handling capabilities (dangerous goods, temperature-controlled, oversized), and node status. Serves as the geographic backbone for hub-and-spoke topology and route planning in SAP TM and Blue Yonder.' .

ind:ServiceCorridor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Route ;
    rdfs:label 'Service Corridor' ;
    rdfs:comment 'Defines a named, multi-leg service corridor connecting a sequence of network nodes for a specific transport mode and service product (e.g., Express Air Asia-Pacific, Ocean FCL Trans-Pacific, Road FTL Europe). Captures corridor name, mode, service type, origin region, destination region, intermediate hub sequence, standard total transit time, frequency (daily/weekly), and operational status. Used by SAP TM for route planning and by Blue Yonder for network design optimization. Distinct from individual lanes — a corridor is a named multi-node path, a lane is a single O-D pair.' .

ind:CorridorLeg rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Route ;
    rdfs:label 'Corridor Leg' ;
    rdfs:comment 'Individual transport leg within a service corridor, representing a single node-to-node movement segment. Captures leg sequence number, origin node, destination node, transport mode, carrier type, leg distance, standard leg transit time (hours), cut-off time, departure frequency, and leg status. Enables multi-modal route decomposition for freight forwarding (air + road, ocean + rail) and supports load optimization in Oracle TMS. A corridor has one or more legs; each leg is independently trackable via FourKites.' .

ind:RouteDeliveryZone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Route ;
    rdfs:label 'Route Delivery Zone' ;
    rdfs:comment 'Geographic zone definition used for last-mile routing, service area delineation, postal zone mapping, and serviceability validation across all transport modes. Captures zone code, zone name, zone type (postal, administrative, custom, last-mile, service-area), country, state/province, city, postal code range, coverage polygon (GeoJSON), assigned hub node, standard transit time, surcharge applicability (remote area, residential), service restrictions (dangerous goods, oversized, COD), applicable service products, and zone status. SSOT for geographic coverage and serviceability master data referenced by pricing (surcharges), fulfillment (dispatch), SAP TM (zone-based routing), and carrier selection.' .

ind:TransitTimeStandard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Route ;
    rdfs:label 'Transit Time Standard' ;
    rdfs:comment 'Authoritative transit time standard for a lane, corridor, or service product combination. Captures origin node/zone, destination node/zone, service level (express, standard, economy), transport mode, standard transit days, standard transit hours, cut-off time, first-available-delivery time, day-of-week restrictions, and effective date range. Feeds SLA commitments in the contract domain, ETA calculation in FourKites, and carrier selection logic in SAP TM. Distinct from actual ETA events — this is the planned standard, not the real-time estimate.' .

ind:CarrierLaneAllocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Route ;
    rdfs:label 'Carrier Lane Allocation' ;
    rdfs:comment 'Defines the allocation of a specific carrier (airline, ocean carrier, road carrier, rail operator) to a lane or corridor leg, including contracted capacity, priority ranking, allocation percentage, mode of transport, service type, effective date range, and allocation status. Used by SAP TM carrier selection engine to determine preferred and backup carriers per lane. Supports tendering, spot booking, and capacity management. References carrier master in the procurement domain via FK (linked in a later step).' .

ind:Plan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Route ;
    rdfs:label 'Plan' ;
    rdfs:comment 'Operational route plan generated by SAP TM or Blue Yonder for a specific shipment or freight order, representing the planned sequence of nodes, legs, carriers, and timing for end-to-end movement. Captures plan reference number, planning source system, transport mode, total planned distance, total planned transit time, planned ETD, planned ETA, number of legs, optimization objective (cost/time/CO2e), plan status (draft, confirmed, executed, cancelled), and plan version. Transactional — a new plan is created per shipment or freight order planning event.' .

ind:PlanLeg rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Route ;
    rdfs:label 'Plan Leg' ;
    rdfs:comment 'Individual leg detail within an operational route plan, capturing the planned execution of a single corridor leg for a specific shipment or freight order. Captures leg sequence, origin node, destination node, carrier, vehicle/vessel/flight reference, planned departure datetime, planned arrival datetime, planned leg transit hours, actual departure datetime, actual arrival datetime, leg status (planned, in-transit, completed, delayed), and delay reason code. Enables leg-level tracking integration with FourKites and exception management in Oracle TMS.' .

ind:EtaEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Route ;
    rdfs:label 'Eta Event' ;
    rdfs:comment 'Real-time and predictive ETA/ETD event record generated by FourKites or SAP TM for a shipment leg or route plan. Captures event timestamp, event source (FourKites, carrier EDI, GPS, manual), shipment reference, leg reference, original planned ETA, current predicted ETA, ETA variance (hours), ETD actual, location at time of event (lat/long, node), prediction confidence score, exception flag, and exception type (delay, early, on-time). SSOT for all ETA updates consumed by customer visibility portals, exception management, and OTD/OTIF KPI calculation.' .

ind:HubSpokeConfig rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Route ;
    rdfs:label 'Hub Spoke Config' ;
    rdfs:comment 'Configuration record defining the hub-and-spoke topology for a specific network region or service product. Captures hub node, spoke nodes list, service product scope (express, freight, e-commerce), transport mode, maximum spoke-to-hub transit time, consolidation frequency, minimum volume threshold for direct lane bypass, effective date range, and configuration status. Managed in SAP TM and Blue Yonder for network design. Distinct from service_corridor (which defines named multi-leg paths) — this defines the structural hub-spoke relationship.' .

ind:LanePerformance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Route ;
    rdfs:label 'Lane Performance' ;
    rdfs:comment 'Operational performance record for a lane over a defined measurement period, capturing actual vs. planned transit time, OTD rate, OTIF rate, average delay hours, shipment volume, exception count, carrier performance score, and CO2e per shipment for that lane. Sourced from FourKites actuals and Oracle TMS freight audit data. Used for lane-level SLA monitoring, carrier scorecard inputs, and network optimization trigger analysis. This is an operational measurement record, not an analytics aggregate — each row represents a lane-period measurement.' .

ind:CarrierSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Route ;
    rdfs:label 'Carrier Schedule' ;
    rdfs:comment 'Published carrier schedule for a specific lane or corridor leg, capturing carrier reference, service name, origin node, destination node, transport mode, vessel/flight/train service identifier, departure day(s) of week, departure time, arrival day(s) of week, arrival time, frequency, transit time (hours), capacity (TEU/kg/CBM), cut-off time (cargo receipt deadline), effective date range, and schedule status. Sourced from carrier EDI feeds and used by SAP TM for departure planning and Oracle TMS for load optimization.' .

ind:FreightOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Freight ;
    rdfs:label 'Freight Order' ;
    rdfs:comment 'Core master entity representing a freight forwarding order across all transport modes (air, ocean, road, rail). Captures the full order lifecycle from booking acceptance through final delivery, including mode type (FTL, LTL, FCL, LCL), service level, origin/destination locations, commodity details, weight, volume (CBM), dimensional weight, incoterms reference, special handling requirements, and current order status. Acts as the primary anchor entity linking transport documents, charges, milestones, and exceptions. Sourced from SAP TM freight order management module.' .

ind:Booking rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Freight ;
    rdfs:label 'Booking' ;
    rdfs:comment 'Transactional record of a freight booking request submitted by a shipper or freight forwarder. Captures booking reference number, requested pickup and delivery dates, ETD, ETA, carrier nomination, space reservation confirmation, booking channel (EDI, API, manual), booking status, and acceptance/rejection details. Represents the commercial commitment to move cargo before a freight order is fully executed. Integrates with Oracle TMS shipment execution module.' .

ind:AirWaybill rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Freight ;
    rdfs:label 'Air Waybill' ;
    rdfs:comment 'Master document for air freight shipments serving as the contract of carriage between shipper and airline/freight forwarder. Stores MAWB and HAWB numbers, IATA airline codes, origin and destination airport codes, flight details, commodity description, HS codes, declared value, chargeable weight, freight charges, special handling codes (e.g., DGR, PER, VAL), and consignee/shipper details. Governed by IATA regulations. Sourced from SAP TM air freight module.' .

ind:BillOfLading rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Freight ;
    rdfs:label 'Bill Of Lading' ;
    rdfs:comment 'Master document for ocean freight shipments serving as the contract of carriage, receipt of goods, and document of title. Stores MBL and HBL numbers, vessel name, voyage number, port of loading (POL), port of discharge (POD), place of delivery, container numbers, seal numbers, commodity description, number of packages, gross weight, CBM, freight terms (prepaid/collect), and NVOCC details. Governed by FMC and IMO regulations. Sourced from SAP TM ocean freight module.' .

ind:Consolidation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Freight ;
    rdfs:label 'Consolidation' ;
    rdfs:comment 'Represents an LCL or groupage consolidation where multiple shippers\' cargo is grouped into a single FCL container or air ULD for cost-efficient transport. Captures consolidation reference, mode (ocean LCL, air groupage), origin and destination CFS facilities, consolidation status, cargo cut-off date/time, departure date, total CBM utilized, total weight, number of constituent shipments, and assigned carrier. Central to NVOCC co-loading operations and CFS management workflows.' .

ind:LoadPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Freight ;
    rdfs:label 'Load Plan' ;
    rdfs:comment 'Operational plan defining how cargo is loaded onto a transport unit (vessel, aircraft, truck, railcar). Captures load plan reference, transport unit identifier, planned vs actual load sequence, cargo placement instructions, weight distribution, center of gravity calculations, hazmat segregation requirements, load status, and planner details. Integrates with Oracle TMS load optimization module. Critical for FTL road and ocean vessel operations.' .

ind:FreightCarrierAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Freight ;
    rdfs:label 'Freight Carrier Assignment' ;
    rdfs:comment 'Records the assignment of a carrier (airline, ocean carrier, road haulier, rail operator) to a specific freight order or consolidation. Captures carrier SCAC/IATA code, service type, assigned lane, contracted rate reference, assignment date, confirmation status, carrier booking reference, and any carrier-specific instructions. Supports carrier selection logic from SAP TM and freight audit in Oracle TMS. Distinct from the contract domain which owns the carrier agreement terms.' .

ind:FreightLeg rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Freight ;
    rdfs:label 'Freight Leg' ;
    rdfs:comment 'Represents an individual transport segment within a multi-leg or intermodal freight movement, including intermodal transfer details at interchange points. Each leg captures mode of transport, origin and destination nodes (port, airport, ICD, CFS, warehouse), carrier for that segment, ETD/ETA, actual departure/arrival timestamps, leg sequence number, transport document reference, leg status, and transfer metadata (transfer type, dwell time, handling charges) when transitioning between modes. Enables end-to-end intermodal tracking, transfer management, and dwell time SLA monitoring across air, ocean, road, and rail.' .

ind:IntermodalTransfer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Freight ;
    rdfs:label 'Intermodal Transfer' ;
    rdfs:comment 'Captures the physical transfer of cargo between transport modes at interchange points such as ICDs, CFSs, rail terminals, and port facilities. Records transfer location, transfer type (ocean-to-rail, air-to-road, etc.), inbound and outbound leg references, transfer date/time, dwell time, handling charges, transfer status, and any exceptions or delays encountered during the transfer. Supports cross-modal visibility and dwell time SLA monitoring.' .

ind:FreightCharge rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Freight ;
    rdfs:label 'Freight Charge' ;
    rdfs:comment 'Itemized charge component associated with a freight order or shipment, capturing mode-specific surcharges and base freight costs. Stores charge type (BAF, GRI, THC, fuel surcharge, peak season surcharge, port congestion surcharge, documentation fee), charge basis (per TEU, per kg, per CBM, flat), currency, amount, applicable date range, and whether the charge is billable to shipper or payable to carrier. Integrates with SAP TM charge calculation and billing domain. Distinct from the billing domain invoice which aggregates charges.' .

ind:Milestone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Freight ;
    rdfs:label 'Milestone' ;
    rdfs:comment 'Event-based tracking record capturing key milestones in the freight order lifecycle such as booking confirmed, cargo received at origin, customs cleared, vessel departed, vessel arrived, cargo available for delivery, and POD received. Each milestone stores event code, event description, planned and actual timestamps, location, responsible party, data source (EDI, FourKites, manual), and exception flag. Integrates with FourKites real-time visibility platform for predictive ETA updates.' .

ind:Exception rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Freight ;
    rdfs:label 'Exception' ;
    rdfs:comment 'Operational record capturing exceptions, disruptions, and deviations in freight order execution. Stores exception type (delay, damage, missing cargo, carrier rollover, port congestion, customs hold, documentation error), severity level, detection timestamp, detection source, impacted freight order and leg, root cause, resolution action, resolution timestamp, and SLA breach flag. Feeds into OTD and OTIF KPI tracking and customer exception notifications.' .

ind:Facility rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Warehouse ;
    rdfs:label 'Facility' ;
    rdfs:comment 'Master record for each warehouse and distribution center operated by Transport Shipping. Captures physical facility attributes including location, type (DC, CFS, ICD, FTZ, cross-dock), total floor area in CBM, dock door count, temperature zones, WMS instance identifier, operating hours, capacity thresholds, and certifications (C-TPAT, AEO, ISO 9001). SSOT for warehouse identity referenced across all warehouse domain products.' .

ind:StorageLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Warehouse ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Granular storage location and zone master within a facility representing every bin, slot, rack, bay, aisle, floor position, and logical zone managed by Manhattan WMS. Tracks location code, zone assignment, zone type (receiving, bulk, pick-face, staging, dispatch, cold-chain, hazmat, quarantine, returns, VAS), aisle, rack, level, bin, location type, weight/volume capacity, temperature class, hazmat suitability, automation type, and current occupancy status. After merge with zone, also carries zone-level attributes (floor area, height, temperature range). Enables slotting optimization, directed putaway, and compliance segregation.' .

ind:Sku rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Warehouse ;
    rdfs:label 'Sku' ;
    rdfs:comment 'Stock Keeping Unit master — the authoritative product catalog for all items stored and handled within warehouse operations. Captures SKU code, description, product category, unit of measure, dimensions (length, width, height), weight, DIM weight factor, hazmat class (IMDG/ICAO), temperature requirement, country of origin, HS Code reference, FIFO/LIFO indicator, shelf life days, barcode/RFID identifiers, and storage class. SSOT for item identity within the warehouse domain.' .

ind:InventoryPosition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Warehouse ;
    rdfs:label 'Inventory Position' ;
    rdfs:comment 'Real-time and point-in-time inventory position record for each SKU at each storage location within a facility. Tracks on-hand quantity, available quantity, reserved quantity, quarantine quantity, damaged quantity, lot number, serial number, expiry date, receipt date, FIFO/LIFO sequence number, inventory status (available, hold, damaged, expired), and last cycle count date. Core operational record powering WMS inventory control and order fulfillment allocation.' .

ind:Asn rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Warehouse ;
    rdfs:label 'Asn' ;
    rdfs:comment 'Advanced Shipping Notice — inbound shipment notification received from suppliers, carriers, or origin facilities prior to physical arrival at the warehouse. Captures ASN number, origin party, expected arrival date/time, carrier reference, transport mode, total carton count, total pallet count, total weight, total CBM, associated purchase order references, and ASN status (pending, partially received, fully received, cancelled). Drives receiving dock scheduling and labor planning in Manhattan WMS.' .

ind:AsnLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Warehouse ;
    rdfs:label 'Asn Line' ;
    rdfs:comment 'Line-level detail of an Advanced Shipping Notice representing each SKU expected on an inbound delivery. Captures ASN line number, SKU reference, expected quantity, unit of measure, lot number, expiry date, country of origin, HS Code, and line status. Enables granular receiving reconciliation and discrepancy tracking against actual received quantities.' .

ind:InboundReceipt rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Warehouse ;
    rdfs:label 'Inbound Receipt' ;
    rdfs:comment 'Physical receiving event record capturing the actual arrival and unloading of goods at a warehouse dock. Records receipt number, dock door assigned, carrier/driver details, vehicle registration, arrival timestamp, unloading start/end timestamps, total cartons received, total pallets received, total weight received, total CBM received, receipt status (in-progress, completed, exception), and discrepancy flag. Links to ASN for variance analysis and GR (Goods Receipt) reconciliation.' .

ind:InboundReceiptLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Warehouse ;
    rdfs:label 'Inbound Receipt Line' ;
    rdfs:comment 'Line-level record of each SKU actually received during an inbound receipt event. Captures receipt line number, SKU, received quantity, damaged quantity, rejected quantity, lot number, serial number, expiry date, condition code, putaway status, and variance quantity versus ASN line. Drives inventory position updates and discrepancy reporting for supplier claims.' .

ind:PutawayTask rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Warehouse ;
    rdfs:label 'Putaway Task' ;
    rdfs:comment 'Directed putaway task generated by Manhattan WMS for each received unit or pallet, instructing warehouse operatives to move goods from the receiving staging area to a designated storage location. Captures task number, task type (standard, cross-dock, replenishment), assigned operative, source location, destination location, SKU, quantity, priority, creation timestamp, assignment timestamp, completion timestamp, and task status (open, assigned, in-progress, completed, cancelled). Feeds labor productivity measurement.' .

ind:PickWave rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Warehouse ;
    rdfs:label 'Pick Wave' ;
    rdfs:comment 'Order picking and packing wave — a batch of outbound orders grouped and released together for coordinated pick-and-pack execution in the warehouse. Captures wave number, wave type (single-order, multi-order, zone, cluster, batch), release timestamp, planned/actual completion timestamps, total order count, total line count, total unit count, assigned zone, wave status, picker count, and associated packing station assignments. After merge with pack_order, also tracks carton/pallet consolidation, packed weight/CBM, packaging materials, and pack completion. Core orchestration entity for outbound fulfillment throughput.' .

ind:PickTask rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Warehouse ;
    rdfs:label 'Pick Task' ;
    rdfs:comment 'Individual picking task assigned to a warehouse operative within a pick wave, directing them to retrieve a specific SKU quantity from a storage location. Captures task number, wave reference, order line reference, operative assigned, source location, SKU, requested quantity, picked quantity, short-pick quantity, pick method (RF scan, voice, paper, goods-to-person), start timestamp, completion timestamp, and task status. Drives labor productivity tracking and order fill-rate measurement.' .

ind:PackOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Warehouse ;
    rdfs:label 'Pack Order' ;
    rdfs:comment 'Packing station work order capturing the consolidation and packaging of picked items into outbound cartons or pallets for a customer order. Records pack order number, associated outbound order, packing station ID, operative assigned, carton count, pallet count, total packed weight, total packed CBM, packaging material used, special handling instructions (fragile, hazmat, cold chain), pack start timestamp, pack completion timestamp, and pack status. Triggers label generation and outbound dispatch scheduling.' .

ind:OutboundShipmentOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Warehouse ;
    rdfs:label 'Outbound Shipment Order' ;
    rdfs:comment 'Outbound dispatch order representing a customer or transfer order released to the warehouse for fulfillment and outbound dispatch. Captures order number, order type (B2C e-commerce, B2B freight, inter-facility transfer, RMA return), customer reference, destination address, requested ship date, SLA service level, carrier assigned, total line count, total unit count, total weight, total CBM, order status (received, allocated, picked, packed, dispatched, cancelled), and OTD flag. Central orchestration record linking warehouse execution to the shipment and fulfillment domains.' .

ind:OutboundOrderLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Warehouse ;
    rdfs:label 'Outbound Order Line' ;
    rdfs:comment 'Line-level detail of an outbound shipment order specifying each SKU, quantity, and fulfillment status. Captures line number, SKU reference, ordered quantity, allocated quantity, picked quantity, packed quantity, shipped quantity, short-ship quantity, lot number, serial number, unit price reference, line status, and OTIF flag. Enables granular order fill-rate analysis and inventory depletion tracking.' .

ind:InventoryMovement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Warehouse ;
    rdfs:label 'Inventory Movement' ;
    rdfs:comment 'Atomic inventory transaction record capturing every movement, adjustment, or transfer of stock within or between warehouse locations. Records movement type (receipt, putaway, pick, replenishment, transfer, adjustment, cycle count, damage write-off, return), SKU, from-location, to-location, quantity moved, movement timestamp, operative ID, reference document number, and reason code. Provides full inventory audit trail required for FIFO/LIFO position recalculation, stock reconciliation, and regulatory compliance (SOX, customs bonded warehouse reporting).' .

ind:CycleCount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Warehouse ;
    rdfs:label 'Cycle Count' ;
    rdfs:comment 'Cycle count program record representing a scheduled or ad-hoc physical inventory count event for a defined set of storage locations or SKUs within a facility. Captures count program name, count type (full, cycle, spot, ABC-velocity), facility, zone scope, scheduled date, count start timestamp, count end timestamp, total locations counted, total SKUs counted, variance quantity, variance value, count status (scheduled, in-progress, completed, approved), and approver. Supports inventory accuracy KPI and regulatory stock reconciliation.' .

ind:CycleCountLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Warehouse ;
    rdfs:label 'Cycle Count Line' ;
    rdfs:comment 'Line-level result of a cycle count for each storage location and SKU combination counted. Records location, SKU, lot number, system quantity (book stock), counted quantity, variance quantity, variance percentage, recount flag, recount quantity, adjuster ID, adjustment timestamp, and approval status. Drives inventory adjustment postings and discrepancy investigation workflows.' .

ind:DockAppointment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Warehouse ;
    rdfs:label 'Dock Appointment' ;
    rdfs:comment 'Dock door appointment scheduling record managing the allocation of inbound and outbound dock doors to carriers, drivers, and shipments at a warehouse facility. Captures appointment number, appointment type (inbound/outbound), facility, dock door number, scheduled arrival window (start/end), carrier name, vehicle type, vehicle registration, driver name, associated ASN or outbound order reference, appointment status (scheduled, confirmed, arrived, in-progress, completed, no-show, cancelled), and actual arrival timestamp. Enables yard management and dock throughput optimization.' .

ind:Zone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Warehouse ;
    rdfs:label 'Zone' ;
    rdfs:comment 'Warehouse zone master defining the logical and physical zones within a facility used to organize storage, picking, and operational workflows. Captures zone code, zone name, zone type (receiving, bulk storage, pick-face, staging, dispatch, cold-chain, hazmat, quarantine, returns, VAS), facility reference, temperature range (min/max Celsius), floor area (sqm), height (m), automation type (manual, conveyor, AS/RS, goods-to-person), and active status. Provides the spatial hierarchy above storage locations for slotting, labor assignment, and compliance segregation.' .

ind:Declaration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customs ;
    rdfs:label 'Declaration' ;
    rdfs:comment 'Core master record for import and export customs declarations filed with national customs authorities. Captures declaration type (import/export/transit/re-export), declaration number, associated shipment reference, declarant identity, country of origin, country of destination, port of entry/exit, Incoterms, declaration status (draft/submitted/under_review/released/rejected), filing date, release date, and regulatory authority reference. Sourced from Descartes Customs GTM and aligned to WCO SAD (Single Administrative Document) standards.' .

ind:DeclarationLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customs ;
    rdfs:label 'Declaration Line' ;
    rdfs:comment 'Line-level detail within a customs declaration representing each distinct commodity or tariff line item. Captures HS code, commodity description, country of origin, quantity, unit of measure, gross weight, net weight, CBM, declared value, currency, duty rate applied, duty amount, VAT/tax amount, statistical value, and preference claim indicator. Each declaration may contain multiple lines corresponding to different goods classifications. Aligned to WCO tariff nomenclature and national customs tariff schedules.' .

ind:HsClassification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customs ;
    rdfs:label 'Hs Classification' ;
    rdfs:comment 'Master record for HS Code (Harmonized System Code) classification assignments made for specific goods traded by customers. Captures the assigned HS code at 6-digit (WCO), 8-digit (EU CN), and 10-digit (national tariff) levels, commodity description, classification ruling reference, classification method (automated/manual/ruling), classifier identity, classification date, validity period, country-specific applicability, and binding ruling indicator. Managed by customs brokers in Descartes Customs GTM. SSOT for tariff classification within the enterprise.' .

ind:TariffRate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customs ;
    rdfs:label 'Tariff Rate' ;
    rdfs:comment 'Reference data for duty and tax rates applicable to specific HS codes by country pair and trade agreement. Captures HS code, importing country, exporting country, applicable trade agreement (e.g., USMCA, EU-UK TCA, RCEP), MFN (Most Favoured Nation) duty rate, preferential duty rate, anti-dumping duty rate, countervailing duty rate, VAT/GST rate, excise rate, effective date, expiry date, and rate source authority. Enables automated duty calculation in declarations. Aligned to WTO tariff schedules and national customs authority publications.' .

ind:DutyAssessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customs ;
    rdfs:label 'Duty Assessment' ;
    rdfs:comment 'Transactional record of duty and tax calculations performed for a customs declaration or shipment. Captures total customs duty, anti-dumping duty, countervailing duty, VAT/GST, excise tax, port handling levies, total tax liability, currency, exchange rate applied, calculation basis (CIF/FOB/DDP), assessment date, assessment status (estimated/assessed/final/disputed), and payment due date. Supports duty payment reconciliation and landed cost computation. Generated by Descartes Customs GTM duty calculation engine.' .

ind:IsfFiling rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customs ;
    rdfs:label 'Isf Filing' ;
    rdfs:comment 'Importer Security Filing (ISF) record submitted to US CBP for ocean shipments bound for the United States, as mandated under 19 CFR Part 149. Captures ISF transaction number, filing type (ISF-10 or ISF-5), importer of record, consignee, seller, buyer, ship-to party, manufacturer/supplier, country of origin, HTSUS code, container stuffing location, consolidator, vessel name, voyage number, bill of lading number, filing date, CBP response status, and penalty risk flag. Sourced from Descartes Customs GTM AMS/ISF module.' .

ind:AmsFiling rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customs ;
    rdfs:label 'Ams Filing' ;
    rdfs:comment 'Automated Manifest System (AMS) filing record submitted to US CBP for advance cargo reporting on ocean (AMS), air (AMS Air), and rail/truck (ABI) shipments. Captures AMS transaction number, transport mode, carrier SCAC/IATA code, vessel/flight/conveyance identifier, voyage/flight number, port of lading, port of unlading, estimated arrival date, master bill of lading number, house bill of lading number, commodity description, piece count, weight, filing status, CBP hold indicator, and exam type (VACIS/CET/tailgate). Sourced from Descartes Customs GTM AMS module.' .

ind:DeniedPartyScreening rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customs ;
    rdfs:label 'Denied Party Screening' ;
    rdfs:comment 'Transactional record of denied party and restricted entity screening checks performed against shipment parties (shipper, consignee, notify party, manufacturer, broker). Captures screening run date and time, screened party name and address, screening list sources checked (OFAC SDN, BIS Entity List, EU Consolidated List, UN Sanctions, C-TPAT denied parties), match status (clear/potential_match/confirmed_match), match score, analyst review outcome, override justification, and regulatory hold flag. Powered by Descartes Customs GTM denied party screening module. Critical for trade compliance and AEO/C-TPAT program adherence.' .

ind:TradeParty rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customs ;
    rdfs:label 'Trade Party' ;
    rdfs:comment 'Master record for all parties involved in international trade transactions managed by the customs domain — importers of record, exporters, manufacturers, suppliers, consignees, notify parties, and customs brokers. Captures party type, legal name, trading name, tax identification number, EORI number (EU), CBP importer number (US), AEO certificate number, C-TPAT status, country of establishment, address, contact details, party status (active/suspended/blocked), and denied party screening clearance status. Distinct from the customer domain\'s account entity — trade_party covers all supply chain counterparties, not just Transport Shipping\'s direct customers.' .

ind:BrokerAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customs ;
    rdfs:label 'Broker Assignment' ;
    rdfs:comment 'Association record linking a shipment or declaration to the customs broker or brokerage office responsible for handling the filing. Captures broker license number, broker name, brokerage office, assigned country/port, power of attorney reference, assignment date, assignment status, and broker performance indicators (filing accuracy rate, average release time). Enables tracking of which broker handled each declaration and supports broker performance management. Managed within Descartes Customs GTM.' .

ind:ComplianceProgram rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customs ;
    rdfs:label 'Compliance Program' ;
    rdfs:comment 'Master record for trade compliance program memberships and certifications held by Transport Shipping or its clients, including C-TPAT (Customs-Trade Partnership Against Terrorism), AEO (Authorized Economic Operator), ISO 28000, and national trusted trader programs. Captures program name, certifying authority, membership tier, certificate number, issue date, expiry date, renewal status, program benefits (reduced examination rates, expedited release), and compliance obligations. SSOT for trusted trader program status across the enterprise.' .

ind:Hold rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customs ;
    rdfs:label 'Hold' ;
    rdfs:comment 'Transactional record capturing customs examination holds, detentions, and regulatory stops placed on shipments by customs authorities or internal compliance teams. Captures hold type (CBP exam/USDA/FDA/security/compliance_review), hold reason, issuing authority, hold date, expected release date, actual release date, examination type (VACIS/CET/intensive/tailgate), examination result, additional duties or penalties assessed, and hold resolution notes. Critical for shipment exception management and SLA impact tracking.' .

ind:OriginDetermination rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customs ;
    rdfs:label 'Origin Determination' ;
    rdfs:comment 'Master record for country of origin determinations made for specific goods, supporting preferential tariff claims and trade agreement benefits. Captures determination method (wholly obtained/substantial transformation/tariff shift/value added content), applicable trade agreement, origin criterion met, supporting documentation type (certificate of origin/EUR.1/Form A/REX declaration), determination date, validity period, issuing authority, and preferential rate claimed. Distinct from hs_classification — origin_determination establishes WHERE goods were made, not WHAT they are.' .

ind:CertificateOfOrigin rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customs ;
    rdfs:label 'Certificate Of Origin' ;
    rdfs:comment 'Transactional record for certificates of origin issued or managed for export shipments, supporting preferential duty claims at destination. Captures certificate number, certificate type (preferential/non-preferential/GSP Form A/EUR.1/USMCA/RCEP), issuing body (chamber of commerce/customs authority/exporter self-certification), issue date, expiry date, exporter details, consignee details, goods description, HS code, origin criterion, and certification status (draft/issued/endorsed/revoked). Managed in Descartes Customs GTM and linked to export declarations.' .

ind:IncotermsAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customs ;
    rdfs:label 'Incoterms Assignment' ;
    rdfs:comment 'Reference and association record capturing the Incoterms rule assigned to a shipment or trade transaction, governing the allocation of costs, risks, and responsibilities between buyer and seller. Captures Incoterms version (2020/2010), rule code (EXW/FCA/CPT/CIP/DAP/DPP/DDP/FAS/FOB/CFR/CIF), named place or port, risk transfer point, cost responsibility boundary, insurance obligation party, customs clearance responsibility (import/export), and effective date. Supports liability determination and duty basis calculation (CIF vs FOB).' .

ind:LicensePermit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customs ;
    rdfs:label 'License Permit' ;
    rdfs:comment 'Master record for import and export licenses, permits, and authorizations required for controlled, restricted, or regulated goods. Captures license type (import license/export license/dual-use export authorization/CITES permit/phytosanitary certificate/FDA prior notice), issuing authority, license number, commodity covered, HS code, authorized quantity, authorized value, country of origin/destination, issue date, expiry date, utilization balance, and license status (active/exhausted/suspended/revoked). Managed in Descartes Customs GTM trade compliance module.' .

ind:TradeAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customs ;
    rdfs:label 'Trade Agreement' ;
    rdfs:comment 'Reference master for free trade agreements (FTAs), preferential trade arrangements, and customs unions applicable to Transport Shipping\'s trade lanes. Captures agreement name, agreement type (FTA/customs union/GSP/EBA/bilateral), participating countries, effective date, expiry date, key provisions (tariff elimination schedule, rules of origin criteria, cumulation rules), administering authority, and agreement status (in_force/under_renegotiation/suspended). Enables automated preferential duty rate lookup and origin criterion validation in Descartes Customs GTM.' .

ind:Consignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shipment ;
    rdfs:label 'Consignment' ;
    rdfs:comment 'Core master entity representing a shipment booking/consignment record — the primary business object in the shipment domain. Captures the full lifecycle identity of a shipment from booking through final delivery, including service type (express parcel, freight, cross-border), origin/destination, declared weight, volumetric/DIM weight, CBM, number of pieces, incoterms code, COD flag, DDP/DAP/FOB terms, booking channel, booking date, committed SLA type, committed delivery date, transit time commitment, SLA source (customer contract/rate card/spot booking), priority level, delivery instructions (instruction type, preferred time window, special access notes, safe place, alternative address, contact phone), current lifecycle status, and OTD/OTIF target. Serves as the anchor entity integrating SAP TM freight orders, Oracle TMS shipment execution records, and FourKites visibility events. SSOT for shipment identity and service commitment across the enterprise.' .

ind:ShipmentLeg rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shipment ;
    rdfs:label 'Shipment Leg' ;
    rdfs:comment 'Represents an individual transport leg within a multi-leg shipment journey, including ETA/ETD milestone predictions and last-mile dispatch details. Each consignment may traverse multiple legs (e.g., first-mile pickup → origin hub → linehaul → destination hub → last-mile delivery). Captures leg sequence number, transport mode (air/ocean/road/rail), carrier SCAC/IATA code, origin and destination location codes, planned and actual departure/arrival timestamps (ETD/ETA), predicted ETA with confidence score and prediction source (FourKites AI/carrier EDI/manual), vehicle/vessel/flight reference, leg status, distance, delivery agent ID (for last-mile legs), route code, dispatch sequence, and delivery attempt number. Enables end-to-end route visibility, SLA milestone tracking per leg, ETA prediction, and last-mile delivery performance measurement. Sourced from SAP TM route segments, Oracle TMS load plans, and FourKites predictive ETA engine.' .

ind:TrackingEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shipment ;
    rdfs:label 'Tracking Event' ;
    rdfs:comment 'Immutable, append-only record of any shipment event captured throughout the shipment lifecycle — including carrier-reported tracking milestones, internal hub/sortation operational events, exception/deviation events, and business lifecycle state transitions. Each event records the event category (tracking/hub_operation/exception/lifecycle), event type code (e.g., PICKUP, DEPARTED, ARRIVED, SORTED, LOADED_OUTBOUND, EXCEPTION_DELAY, STATUS_CHANGE), event timestamp, location (facility code, city, country, GPS coordinates), event source (FourKites, carrier EDI, WMS scan, sortation system, TMS), operator ID, severity (for exceptions), resolution fields (for exceptions), previous/new status (for lifecycle transitions), and raw event description. Serves as the unified event log enabling OTD calculation, predictive ETA updates, exception detection, and full shipment audit trail. Never updated after insert.' .

ind:Pod rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shipment ;
    rdfs:label 'Pod' ;
    rdfs:comment 'Proof of Delivery (POD / ePOD) record capturing evidence of successful shipment delivery and any Cash on Delivery (COD) collection at the point of delivery. Stores delivery timestamp, recipient name, recipient signature (base64 or reference URI), delivery location coordinates (GPS), delivery type (door/reception/locker/neighbour), ePOD image reference, delivery agent employee ID, device ID used for capture, delivery notes or exceptions noted at delivery, POD status (accepted/disputed/pending), COD amount, COD currency, payment method (cash/card/digital wallet), amount collected, collection timestamp, remittance status, and any variance between COD amount and collected amount. Aligns with ePOD standards and supports COD reconciliation, remittance tracking to shippers, claims management, and financial settlement. SSOT for delivery confirmation evidence and COD collection.' .

ind:EtaMilestone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shipment ;
    rdfs:label 'Eta Milestone' ;
    rdfs:comment 'Stores planned and predicted ETA/ETD milestone records for each shipment leg and overall consignment. Captures milestone type (ETD_ORIGIN, ETA_TRANSIT_HUB, ETD_TRANSIT_HUB, ETA_DESTINATION, ETA_DELIVERY), original committed datetime, current predicted datetime, prediction source (FourKites AI, carrier EDI, manual override), prediction confidence score, variance in hours from original commitment, and last updated timestamp. Enables SLA breach prediction, proactive customer notification, and OTIF performance measurement. Sourced from FourKites predictive ETA engine.' .

ind:ExceptionEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shipment ;
    rdfs:label 'Exception Event' ;
    rdfs:comment 'Operational exception record raised during shipment execution when a deviation from the planned journey occurs. Captures exception type (DELAY, DAMAGE, LOST, CUSTOMS_HOLD, ADDRESS_ISSUE, WEATHER, MECHANICAL, REFUSED_DELIVERY, ATTEMPTED_DELIVERY), severity level, exception raised timestamp, location at time of exception, root cause code, responsible party (carrier/shipper/consignee/customs), resolution action taken, resolution timestamp, and escalation flag. Sourced from FourKites exception management module and Oracle TMS exception workflows. Feeds into claims and SLA breach reporting.' .

ind:ConsignmentStatus rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shipment ;
    rdfs:label 'Consignment Status' ;
    rdfs:comment 'Lifecycle status history table tracking every status transition of a consignment from booking through delivery. Each record captures the previous status, new status, transition timestamp, triggered-by source (system/user/carrier EDI), operator ID, and any status notes. Provides a complete audit trail of the consignment lifecycle enabling SLA compliance analysis, dispute resolution, and operational reporting. Distinct from tracking_event which captures carrier scan events — this table captures business-level lifecycle state transitions.' .

ind:Package rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shipment ;
    rdfs:label 'Package' ;
    rdfs:comment 'Individual package/piece-level master record within a consignment. Captures package sequence number within the consignment, barcode/label number, package type (carton, pallet, drum, envelope, crate), actual weight, volumetric weight (DIM weight), dimensions (L×W×H in cm), declared contents description, fragile flag, temperature-sensitive flag, and current package status. Enables piece-level tracking, DIM weight billing reconciliation, and warehouse handling instructions. Sourced from Manhattan WMS scan data and Oracle TMS load manifests.' .

ind:ShipmentCarrierAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shipment ;
    rdfs:label 'Shipment Carrier Assignment' ;
    rdfs:comment 'Records the assignment of a carrier (airline, ocean carrier, road haulier, rail operator) to a specific shipment leg. Captures carrier SCAC/IATA code, carrier name, service product code, booking reference number with the carrier, assigned vehicle/vessel/flight number, assignment date, assignment method (auto-optimized via SAP TM carrier selection / manual override), rate agreed, and assignment status (confirmed/tentative/cancelled). Enables carrier performance tracking, freight audit, and carrier spend analysis per shipment.' .

ind:DeliveryInstruction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shipment ;
    rdfs:label 'Delivery Instruction' ;
    rdfs:comment 'Shipper or consignee-specified delivery instructions associated with a consignment. Captures instruction type (LEAVE_AT_DOOR, REQUIRE_SIGNATURE, DELIVER_TO_NEIGHBOUR, LOCKER_DELIVERY, APPOINTMENT_REQUIRED, CALL_BEFORE_DELIVERY, RETURN_IF_ABSENT), preferred delivery time window (start/end), special access instructions, safe place description, alternative delivery address, contact phone for delivery, and instruction source (shipper/consignee/customer portal). Enables last-mile delivery agents to execute D2D delivery per customer preferences and reduces failed delivery attempts.' .

ind:ShipmentCharge rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shipment ;
    rdfs:label 'Shipment Charge' ;
    rdfs:comment 'Shipment-level charge record capturing all freight charges, surcharges, accessorial fees, and customs duty references applied to a consignment. Captures charge code, amount, currency, tax, and any linked customs declaration references.' .

ind:FreightManifest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shipment ;
    rdfs:label 'Freight Manifest' ;
    rdfs:comment 'Freight manifest record consolidating all consignments loaded onto a specific transport vehicle, vessel, or aircraft for a given departure. Captures manifest number, transport mode, vehicle/vessel/flight reference, origin facility, destination facility, departure date, total pieces, total weight, total CBM, number of consignments, dangerous goods indicator, temperature-controlled indicator, manifest status (open/closed/departed/arrived), and carrier seal number. Sourced from SAP TM and Oracle TMS load optimization outputs. Enables load reconciliation and carrier handover documentation.' .

ind:LastMileDispatch rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Last Mile Dispatch' ;
    rdfs:comment 'Last-mile delivery dispatch record assigning a consignment to a delivery agent/driver for final delivery execution. Captures dispatch date, delivery agent employee ID, vehicle registration, delivery route code, dispatch sequence number within the route, planned delivery time window, actual pickup time from depot, delivery attempt number, dispatch status (dispatched/in_transit/delivered/failed/returned), and return-to-depot timestamp if undelivered. Sourced from Oracle TMS last-mile dispatch module. Enables D2D delivery performance tracking and driver productivity measurement.' .

ind:ShipmentDocument rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shipment ;
    rdfs:label 'Shipment Document' ;
    rdfs:comment 'Registry of all transport and trade documents associated with a consignment beyond the primary AWB/BOL. Captures document type (commercial invoice, packing list, certificate of origin, phytosanitary certificate, dangerous goods manifest, insurance certificate, letter of credit, export license, import permit), document reference number, issuing authority, issue date, expiry date, document file URI, upload source, and document status (pending/submitted/approved/rejected). Provides a complete document envelope for a shipment enabling customs compliance and carrier acceptance checks.' .

ind:Invoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Invoice' ;
    rdfs:comment 'Master billing document issued to customers for logistics services rendered across all service lines (express parcel, freight forwarding, customs brokerage, warehousing, e-commerce fulfillment). Captures invoice header data including invoice number, invoice date, due date, billing period, currency, total amount, tax amount, discount amount, invoice status (draft, issued, sent, partially_paid, paid, overdue, disputed, cancelled, written_off), invoice type (standard, proforma, credit_note, debit_note, consolidated, recurring), payment terms (NET30, NET60, COD, prepaid), IFRS 15 revenue recognition status, SAP S/4HANA document reference, and originating service line. SSOT for all customer-facing billing documents.' .

ind:BillingInvoiceLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Billing Invoice Line' ;
    rdfs:comment 'Individual charge line items on a customer invoice, representing discrete billable services or surcharges. Each line captures the service code, charge description, quantity, unit of measure (kg, CBM, TEU, shipment, pallet), unit rate, line amount, tax code, tax amount, cost center, profit center, revenue account GL code, HS code reference for customs-related charges, surcharge type (BAF, THC, GRI, fuel surcharge, peak season surcharge, remote area surcharge), and IFRS 15 performance obligation identifier. Supports detailed revenue recognition and freight audit reconciliation.' .

ind:CreditNote rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Credit Note' ;
    rdfs:comment 'Formal credit document issued to customers to reverse or reduce a previously issued invoice amount. Captures credit note number, originating invoice reference, credit reason code (billing error, service failure, SLA breach, rate dispute, duplicate charge, goodwill adjustment, cargo claim settlement), credit amount, tax adjustment, approval status, approver identity, issue date, expiry date, application status (open, partially_applied, fully_applied), and SAP S/4HANA credit memo document reference. Supports dispute resolution and accounts receivable netting.' .

ind:Payment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Payment' ;
    rdfs:comment 'Record of customer payment received against outstanding invoices. Captures payment reference number, payment date, payment method (bank transfer, cheque, credit card, direct debit, COD collection, letter of credit), payment amount, currency, exchange rate, bank account reference, payment channel (online portal, EDI, manual, bank file), clearing status (uncleared, partially_cleared, fully_cleared), SAP S/4HANA clearing document reference, remittance advice reference, and any unapplied balance. SSOT for all inbound cash receipts in the order-to-cash cycle.' .

ind:PaymentAllocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Payment Allocation' ;
    rdfs:comment 'Cash application record linking a customer payment to one or more open items (invoices, credit notes, debit notes) with the allocated amount per item. Captures allocation amount, allocation date, allocation type (full settlement, partial payment, advance application, credit offset, on-account, write-off), remaining open balance after allocation, allocation status (provisional, confirmed, reversed), auto-match confidence score, and SAP S/4HANA clearing document reference. Enables accurate AR sub-ledger reconciliation, supports multi-invoice remittances common in enterprise freight forwarding, and drives aging bucket calculations. Critical for cash application automation and bank file processing.' .

ind:Receivable rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Receivable' ;
    rdfs:comment 'Accounts receivable balance record tracking the outstanding amount owed by each customer at any point in time. Captures AR balance, aging bucket (current, 1-30 days, 31-60 days, 61-90 days, 90+ days), credit limit, credit utilization percentage, last payment date, last invoice date, dunning level (1st notice, 2nd notice, final notice, collections), dunning date, dispute hold flag, bad debt provision amount, write-off status, collection agency referral flag, and SAP S/4HANA customer account reference. Supports credit risk management and DSO (Days Sales Outstanding) tracking.' .

ind:FreightAudit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Freight Audit' ;
    rdfs:comment 'Freight audit record capturing the systematic verification of carrier invoices against contracted rates, actual shipment parameters, and service level agreements before payment authorization. Covers inbound carrier payables (Freight Audit and Payment — FAP) validation. Each audit record captures: audit reference, carrier invoice number, shipment/AWB/BOL/container reference, contracted tariff rate, carrier-invoiced rate, variance amount and percentage, weight/volume discrepancy details, audit status (pending_review, in_audit, approved, disputed, adjusted, escalated, closed), finding type (rate overcharge, duplicate billing, accessorial not contracted, weight/dim discrepancy, service failure deduction, fuel surcharge miscalculation), auditor identity, audit completion date, resolution action, and savings captured amount. Integrates with carrier_payable for payment release and with pricing domain for rate validation. Typically recovers 2-8% of freight spend for large shippers.' .

ind:CarrierPayable rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Carrier Payable' ;
    rdfs:comment 'Accounts payable record for amounts owed to carriers, subcontractors, and transport partners for services rendered on behalf of Transport Shipping customers. Captures carrier payable reference, carrier identity, carrier invoice number, service type (air freight, ocean freight, road haulage, rail, last-mile delivery, port handling), shipment reference (MAWB, MBL, BOL), payable amount, currency, payment terms, due date, payment status (pending_audit, approved, scheduled, paid, disputed, on_hold), Coupa purchase order reference, and SAP S/4HANA vendor payment document reference. SSOT for procure-to-pay carrier cost management.' .

ind:Dispute rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Dispute' ;
    rdfs:comment 'Formal dispute record raised by customers or internal teams challenging the accuracy of an invoice, charge, or freight audit finding. Captures dispute reference number, dispute type (rate dispute, weight dispute, service failure, duplicate charge, unauthorized surcharge, SLA breach deduction, customs duty dispute), disputed invoice reference, disputed amount, dispute reason narrative, dispute status (open, under_review, escalated, resolved_accepted, resolved_rejected, partially_accepted, withdrawn), resolution type, resolution amount, resolution date, responsible team, SLA breach flag, and credit note issued reference. Supports chargeback management and customer satisfaction.' .

ind:BillingAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Billing Account' ;
    rdfs:comment 'Billing account master record defining the billing relationship and financial terms between Transport Shipping and a customer entity. Distinct from the customer identity record (owned by the customer domain), this entity captures billing-specific attributes: billing account number, billing currency, payment terms (NET30, NET60, prepaid, COD), credit limit, credit status (active, suspended, on_hold, blacklisted), billing cycle (weekly, bi-weekly, monthly, on-demand), invoice delivery method (email, EDI, portal, post), tax registration number (VAT/GST), tax exemption status, billing address, preferred payment method, dunning profile, and SAP S/4HANA customer account code. SSOT for billing configuration per customer.' .

ind:TaxSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Tax Schedule' ;
    rdfs:comment 'Reference master defining applicable tax rules, rates, and jurisdictions for logistics billing. Captures tax schedule code, tax type (VAT, GST, WHT, customs duty, excise, service tax), jurisdiction (country, state/province, free trade zone), tax rate percentage, tax basis (freight value, declared value, CIF value, DDP value), applicable service types, exemption categories, effective date, expiry date, regulatory authority reference, and SAP S/4HANA tax condition type. Supports multi-jurisdictional tax compliance for cross-border shipments and ensures correct tax calculation on customer invoices.' .

ind:PaymentTerm rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Payment Term' ;
    rdfs:comment 'Reference master defining standard payment terms offered to customers and applied to carrier payables. Captures payment term code, payment term description (NET30, NET60, NET90, COD, prepaid, 2/10 NET30), number of days, early payment discount percentage, early payment discount days, late payment penalty rate, applicable customer segments, applicable service lines, currency restrictions, and SAP S/4HANA payment term key. Provides standardized payment term taxonomy used across invoice issuance, contract agreements, and carrier payable management.' .

ind:Cycle rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Cycle' ;
    rdfs:comment 'Master configuration record defining the billing cycle parameters for a billing account or customer segment. Captures billing cycle code, cycle name, cycle frequency (daily, weekly, bi-weekly, monthly, quarterly, on-demand), cycle start day, cycle end day, invoice generation trigger (cycle-end, shipment-completion, milestone, manual), invoice delivery lead time (days), payment due offset (days from invoice date), applicable service lines, applicable customer tiers, and effective date range. Governs when invoices are generated and dispatched for each customer billing account.' .

ind:RateCard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Rate Card' ;
    rdfs:comment 'Master rate card defining published or contracted base freight rates for a specific service type, trade lane, and validity period. Serves as the foundational pricing instrument across freight forwarding, express delivery, and contract logistics. Captures rate card name, version, effective/expiry dates, service mode (air/ocean/road/rail), rate basis (per kg, per CBM, per TEU, per shipment), currency, approval status, and zone structure. Includes validity lifecycle (activation, expiry, extension, supersession). SSOT for all base rate structures feeding spot quote generation, contract pricing, and billing.' .

ind:RateLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Rate Line' ;
    rdfs:comment 'Individual rate line item within a rate card, capturing the specific charge amount for a defined origin-destination lane, weight/volume break tier, commodity class, and service level. Stores rate value, unit of measure (per kg, per CBM, per TEU), minimum charge, currency, transit time, applicable Incoterms, weight break thresholds (min/max weight or volume bands), and service level differentiation (Next Day, Economy, Priority, Deferred). Supports tiered pricing with inline break definitions and volume discounts. Child entity of rate_card.' .

ind:Tariff rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Tariff' ;
    rdfs:comment 'Published tariff schedule representing the official pricing structure for a carrier, service product, or trade lane. Captures tariff name, tariff type (import/export/domestic/cross-border), applicable transport mode, governing body reference (IATA, FMC, IMO), effective date, expiry date, currency, and publication status. Distinct from negotiated rate cards — tariffs represent the publicly filed or carrier-published rate basis before customer-specific discounts.' .

ind:Surcharge rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Surcharge' ;
    rdfs:comment 'Master definition of all surcharge types applicable to freight and express shipments, including fuel surcharges (BAF), general rate increases (GRI), terminal handling charges (THC), peak season surcharges, security surcharges, and war risk surcharges. Captures surcharge code, surcharge name, surcharge category, calculation method (flat, percentage, per unit), applicable transport mode, trade lane scope, and governing body reference. SSOT for surcharge definitions used across rate cards and spot quotes.' .

ind:PricingSurchargeSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Pricing Surcharge Schedule' ;
    rdfs:comment 'Time-bound schedule of active surcharge rates for a specific surcharge type, trade lane, and validity period. Captures the effective surcharge amount or percentage, currency, applicable weight/volume bands, origin and destination scope, and approval status. Enables tracking of BAF index changes, GRI announcements, and THC revisions over time. Links surcharge definitions to their current and historical rate values.' .

ind:FuelIndex rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Fuel Index' ;
    rdfs:comment 'Periodic fuel price index records from external sources used to calculate and adjust BAF (Bunker Adjustment Factor) and fuel surcharges for air, ocean, and road freight. Captures index date, fuel type (jet fuel, bunker fuel IFO380/VLSFO, diesel), index value, index source (IATA, Platts, MOPS, EIA), currency, applicable trade lane or region, effective period, and index publication frequency. Drives automated surcharge recalculation cycles (typically monthly for ocean, weekly for road) and provides audit trail for fuel surcharge adjustments.' .

ind:AccessorialCharge rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Accessorial Charge' ;
    rdfs:comment 'Master catalog of accessorial and ancillary charges applicable beyond base freight rates, including residential delivery surcharges, address correction fees, signature required fees, hazmat handling fees, oversize/overweight charges, liftgate fees, inside delivery, and COD fees. Captures charge code, charge name, charge category, calculation basis (flat fee, per shipment, per kg, percentage), applicable service types, and effective dates. SSOT for all non-base-rate charge definitions.' .

ind:DimWeightRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Dim Weight Rule' ;
    rdfs:comment 'Dimensional weight (DIM weight) calculation rules defining the volumetric divisor and rounding conventions applied per service type, transport mode, and customer segment. Captures DIM factor (e.g., 5000 for air, 4000 for express), unit system (metric/imperial), rounding method, minimum chargeable weight, applicable service codes, and effective date range. Critical for revenue integrity in express parcel and air freight pricing where chargeable weight = max(actual weight, DIM weight).' .

ind:SpotQuote rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Spot Quote' ;
    rdfs:comment 'Transactional spot quote issued to a customer or prospect for a specific shipment request outside standing contract rates. Captures quote reference, requesting customer, origin/destination, transport mode, commodity, weight, volume, chargeable weight, quoted all-in rate, itemized charges (via spot_quote_line), validity period, quote status (draft/issued/accepted/expired/rejected), issuing agent, and DIM weight calculation applied. SSOT for ad-hoc pricing events. Feeds billing and contract domains for revenue recognition and potential contract conversion.' .

ind:SpotQuoteLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Spot Quote Line' ;
    rdfs:comment 'Individual charge line item within a spot quote, detailing each component of the quoted price including base freight, fuel surcharge, THC, origin/destination charges, customs fees, and accessorial charges. Captures charge type, charge description, unit of measure, quantity, unit rate, total amount, currency, and whether the charge is included in the all-in rate or quoted separately. Enables full cost transparency and itemized billing reconciliation.' .

ind:ContractRate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Contract Rate' ;
    rdfs:comment 'Negotiated contract-specific rate agreed with a customer under a service contract or rate agreement. Captures contract reference, customer account, origin-destination lane, service type, transport mode, commodity, negotiated rate, discount percentage off tariff, minimum volume commitment, rate validity period, approval status, and deviation tracking (below-floor approvals, emergency rates, special commodity rates with business justification and approving authority). Distinct from published tariffs and spot quotes — represents the binding commercial rate for a specific customer relationship. Feeds billing domain for invoice generation.' .

ind:RateRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Rate Rule' ;
    rdfs:comment 'Dynamic pricing rule defining automated rate adjustment logic, conditional pricing triggers, and business rules governing how rates are calculated or modified. Captures rule name, rule type (volume discount, lane-based adjustment, customer tier discount, peak surcharge, promotional rate), trigger conditions, adjustment type (flat, percentage, tiered), priority order, effective dates, and active status. Enables rule-based pricing engine execution in SAP TM charge calculation.' .

ind:LaneRateZone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Lane Rate Zone' ;
    rdfs:comment 'Geographic rate zone definition mapping origin and destination postal codes, cities, countries, or regions to pricing zones used in rate card lookups. Captures zone code, zone name, zone type (origin/destination/both), geographic scope (domestic/international), applicable transport mode, and zone hierarchy level. Enables efficient rate lookup by resolving shipment origins and destinations to zone pairs for tariff and rate card matching.' .

ind:ChargeCode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Charge Code' ;
    rdfs:comment 'Standardized charge code reference catalog defining all billable charge types used across freight, express, and logistics services. Captures charge code, charge name, charge category (freight/surcharge/accessorial/customs/insurance/handling), revenue account mapping, applicable service lines, taxable flag, EDI code mapping (IATA charge codes, UN/EDIFACT charge codes), and active status. SSOT for charge type standardization across billing, rate cards, and spot quotes.' .

ind:CarrierBuyRate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Carrier Buy Rate' ;
    rdfs:comment 'Buy-side rate representing the cost Transport Shipping pays to carriers, airlines, shipping lines, and subcontractors for capacity procurement. Captures carrier reference, service type, transport mode, origin-destination lane, buy rate amount, currency, rate basis, contract reference, validity period, margin floor, and volume tier pricing. Enables sell/buy rate spread analysis, margin management, carrier cost benchmarking, and freight audit against carrier invoices. Distinct from sell-side rate_card — this is the cost basis for all pricing decisions and margin calculations.' .

ind:Supplier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Supplier' ;
    rdfs:comment 'Master record for all suppliers, vendors, and service providers engaged by Transport Shipping. Captures supplier identity, classification (carrier, fuel supplier, IT vendor, facility lessor, etc.), onboarding status, risk tier, AEO/C-TPAT certification status, payment terms, preferred currency, tax identifiers, and geographic coverage. This is the SSOT for supplier identity within the procurement domain and serves as the anchor for all sourcing, purchasing, and spend management activities. Sourced from Coupa Supplier Management module.' .

ind:SupplierSite rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Supplier Site' ;
    rdfs:comment 'Represents a physical or operational site (address, bank account, contact point) associated with a supplier. A single supplier may have multiple sites — e.g., a carrier with regional hubs, a fuel supplier with depot locations, or a warehouse equipment vendor with multiple warehouses. Tracks site type (remit-to, ship-from, order-from), site-level payment terms, currency, and active status. Sourced from Coupa Supplier Management.' .

ind:SupplierQualification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Supplier Qualification' ;
    rdfs:comment 'Tracks the formal qualification and onboarding lifecycle of a supplier, including pre-qualification assessments, due diligence checks, denied party screening results (OFAC, EU sanctions), financial health scores, insurance certificate validity, ISO/AEO/C-TPAT certification records, and qualification expiry dates. Each qualification event is a distinct record enabling audit trails for trade compliance and regulatory reporting. Sourced from Coupa and Descartes Customs screening.' .

ind:Rfq rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Rfq' ;
    rdfs:comment 'Request for Quotation issued to one or more suppliers for goods or services required by Transport Shipping. Captures RFQ number, category (carrier services, fuel, warehouse equipment, IT, facilities), issuing business unit, required delivery date, estimated spend, currency, evaluation criteria, submission deadline, and RFQ status (draft, issued, closed, awarded, cancelled). Supports the sourcing event lifecycle in Coupa. Distinct from RFP which is used for strategic/complex sourcing.' .

ind:SupplierQuote rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Supplier Quote' ;
    rdfs:comment 'Formal quotation submitted by a supplier in response to an RFQ or RFP. Captures quote reference number, submission timestamp, validity period, total quoted amount, currency, payment terms offered, lead time, and overall quote status (submitted, under review, accepted, rejected). Serves as the basis for sourcing award decisions and contract negotiation. Sourced from Coupa Sourcing.' .

ind:PurchaseOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Purchase Order' ;
    rdfs:comment 'Formal purchase order issued to a supplier authorizing the procurement of goods or services. Captures PO number, PO type (standard, blanket, planned, contract-release), issuing entity, supplier, ship-to location, bill-to entity, total PO value, currency, payment terms, INCOTERMS, delivery date, budget code, cost center, CAPEX/OPEX classification, and PO status (draft, approved, sent, partially received, fully received, closed, cancelled). SSOT for all purchase commitments. Sourced from Coupa, integrated with SAP S/4HANA Finance for budget control.' .

ind:PoLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Po Line' ;
    rdfs:comment 'Individual line items on a purchase order, each representing a distinct good or service being procured. Captures line number, item description, commodity category, unit of measure, ordered quantity, unit price, line total, delivery schedule, account assignment (cost center, WBS element, asset), and line status (open, partially received, fully received, cancelled). Enables granular goods receipt matching and three-way invoice matching. Sourced from Coupa.' .

ind:GoodsReceipt rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Goods Receipt' ;
    rdfs:comment 'Records the physical or electronic receipt of goods and services against a purchase order line. Captures GR number, receipt date, received quantity, accepted quantity, rejected quantity, rejection reason, receiving location (warehouse, depot, hub), receiver employee ID, and three-way match status. Critical for accounts payable invoice matching and inventory replenishment confirmation. Sourced from Coupa and Manhattan WMS receiving workflows.' .

ind:SupplierInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Supplier Invoice' ;
    rdfs:comment 'Supplier-submitted invoice for goods or services delivered under a purchase order or contract. Captures invoice number, dates, amounts (gross/tax/net), currency, payment terms, PO reference, invoice type (standard, credit memo, debit memo), and three-way match status including exception details and resolution workflow. SSOT for accounts payable obligations within procurement. Integrates with SAP S/4HANA AP for payment execution.' .

ind:ProcurementInvoiceLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Procurement Invoice Line' ;
    rdfs:comment 'Line-level detail of a supplier invoice, mapping to PO lines and goods receipt records for three-way matching. Captures line number, item description, invoiced quantity, unit price, line amount, tax code, account assignment, match status per line, and variance amount (price variance, quantity variance). Enables granular discrepancy identification and dispute resolution. Sourced from Coupa Invoice Management.' .

ind:PurchaseRequisition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Purchase Requisition' ;
    rdfs:comment 'Internal demand signal raised by a business unit to initiate procurement. Captures requisition number, requestor, business unit, item details, estimated cost, required delivery date, justification, budget check result, approval status, and conversion outcome (converted to PO, routed to sourcing event, or rejected). Represents the entry point of the procure-to-pay lifecycle.' .

ind:FulfillmentOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Fulfillment Order' ;
    rdfs:comment 'Core master entity representing an e-commerce or D2D fulfillment order received from a merchant or customer platform. Captures the full order lifecycle from receipt through completion, including order source channel (EDI/API), merchant reference, service type, fulfillment mode, order status, promised SLA window, COD flag and amount, special handling instructions, and omnichannel integration metadata. This is the SSOT for fulfillment order identity within the fulfillment domain — distinct from freight forwarding orders owned by the freight domain.' .

ind:OrderLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Order Line' ;
    rdfs:comment 'Individual line item within a fulfillment order representing a specific SKU, quantity, unit weight, dimensions, declared value, and fulfillment instruction. Tracks per-line status (picked, packed, shipped, returned), substitution flags, and back-order indicators. Supports multi-line order orchestration and partial fulfillment scenarios common in e-commerce fulfillment operations.' .

ind:Parcel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Parcel' ;
    rdfs:comment 'Physical parcel or package created during the pack stage of pick-pack-ship workflow. Captures parcel dimensions (CBM), actual weight, DIM weight, packaging type, barcode/tracking number, seal number, hazmat flag (IMDG/ICAO compliance), and assigned carrier service. Each parcel is linked to one or more order lines and is the unit of last-mile dispatch. Distinct from freight containers managed in the freight domain.' .

ind:ParcelManifest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Parcel Manifest' ;
    rdfs:comment 'Carrier manifest grouping parcels for a scheduled dispatch run to a specific carrier, service lane, or last-mile zone. Records manifest number, carrier SCAC/IATA code, dispatch date-time, origin facility, destination zone, total parcel count, total weight, total CBM, manifest status (open, closed, dispatched, reconciled), and EDI transmission status to carrier. Supports carrier handover and freight audit processes.' .

ind:DeliveryAttempt rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Delivery Attempt' ;
    rdfs:comment 'Records each physical attempt to deliver a parcel to the consignee address. Captures attempt sequence number, attempt date-time, delivery agent ID, GPS coordinates at attempt, outcome code (delivered, failed, refused, no-access, redirected), failure reason, next-action instruction (re-attempt, hold at facility, return to sender), and ePOD reference. Central to last-mile SLA tracking and OTD/OTIF KPI computation.' .

ind:FulfillmentCarrierAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Fulfillment Carrier Assignment' ;
    rdfs:comment 'Records the carrier selection decision for a fulfillment order or parcel, capturing the selected carrier, service level (express, standard, economy), carrier account number, rate quoted, selection rule applied (cheapest, fastest, SLA-compliant), assignment timestamp, and override flag with override reason. Supports carrier selection logic driven by SAP TM and Oracle TMS and enables freight audit reconciliation.' .

ind:DispatchRun rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Dispatch Run' ;
    rdfs:comment 'Operational dispatch run representing a scheduled last-mile delivery route or courier trip, including the carrier manifest documentation for handover. Captures run date, origin depot/facility, assigned vehicle or courier, carrier SCAC/IATA code, manifest number, planned and actual stop counts, departure and return times, total parcels loaded and delivered, failed delivery count, run status, EDI transmission status to carrier, and manifest reconciliation status. Serves as the unit of carrier handover for parcel dispatch and feeds fleet domain for vehicle utilization tracking.' .

ind:Rma rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Rma' ;
    rdfs:comment 'Return Merchandise Authorization record managing the end-to-end returns processing workflow. Captures RMA number, originating fulfillment order reference, return reason code, merchant-approved return flag, return label generated flag, return carrier and tracking number, expected return date, actual receipt date, condition assessment on receipt (sealed, opened, damaged), disposition instruction (restock, destroy, return-to-merchant), and refund/credit trigger status. Supports reverse logistics and e-commerce returns SLA compliance.' .

ind:PackTask rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Pack Task' ;
    rdfs:comment 'Warehouse pack task capturing the packing activity for one or more picked items into a parcel. Records pack station ID, packer employee ID, packaging material used, void fill type, parcel weight at pack, DIM measurement, label printed flag, pack start and completion timestamps, quality check flag, and exception notes. Links pick tasks to resulting parcels and supports pack-station throughput tracking.' .

ind:Merchant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Merchant' ;
    rdfs:comment 'Master record for merchant partners whose e-commerce orders are fulfilled by Transport Shipping. Captures merchant legal name, trading name, merchant tier (enterprise, SME, marketplace), platform type (Shopify, Magento, WooCommerce, custom), integration channel (EDI, API, portal), account manager reference, onboarding date, active status, default service level, COD enabled flag, returns policy reference, and billing account reference. SSOT for merchant identity within the fulfillment domain — distinct from the customer domain which owns end-consumer identity.' .

ind:MerchantIntegration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Merchant Integration' ;
    rdfs:comment 'Configuration and operational record for a merchant\'s integration channel with the fulfillment platform. Captures integration type (EDI 204/856/997, REST API, SFTP, webhook), endpoint URL or EDI qualifier/ISA ID, authentication method, message format version, polling frequency, last successful sync timestamp, error count, integration status (active, suspended, degraded), and supported transaction types. Enables omnichannel order ingestion from merchant e-commerce platforms.' .

ind:Consignee rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Consignee' ;
    rdfs:comment 'Master record for the end recipient (consignee) of a fulfillment delivery. Captures consignee name, structured delivery address (street, city, state, postal code, country ISO), address validation status and geocode, address type (residential, commercial, locker, PUDO point), contact phone, contact email, delivery preferences (leave at door, signature required, neighbor, time-slot preference), failed delivery history flag, and blacklist flag. Distinct from the customer domain\'s account/profile — the consignee is the physical delivery recipient, not necessarily the ordering customer or merchant.' .

ind:Center rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Center' ;
    rdfs:comment 'Master record for fulfillment center facilities operated or contracted by Transport Shipping for e-commerce fulfillment and D2D operations. Captures facility code, facility name, address, facility type (owned, 3PL, 4PL, cross-dock, dark store), total floor area (sqm), storage capacity (CBM and pallet positions), WMS system instance, operating hours, supported service types, last-mile zone coverage, and operational status. Distinct from warehouse domain\'s general warehouse master — this entity is scoped to fulfillment-specific facilities.' .

ind:FulfillmentDeliveryZone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Fulfillment Delivery Zone' ;
    rdfs:comment 'Reference master defining geographic delivery zones used for last-mile dispatch planning and carrier assignment. Captures zone code, zone name, country, state/province, postal code ranges covered, zone type (urban, suburban, rural, remote), serviceable flag, standard transit days, express transit days, carrier coverage map, and surcharge applicability flag. Used by carrier assignment logic and SLA promise calculation.' .

ind:TransportAsset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Transport Asset' ;
    rdfs:comment 'Master record for all owned and leased transport assets in the fleet including vehicles (trucks, vans, motorcycles), aircraft, vessels, and rail units. Captures asset identity, classification, registration, ownership type (owned/leased/chartered), acquisition date, CAPEX value, current operational status, assigned depot/hub, telematics device ID, RFID tag, DOT/ICAO registration numbers, payload capacity, dimensional specs (CBM, DIM weight), fuel type, engine specs, and full lifecycle state (active, in-maintenance, decommissioned). This is the SSOT for all fleet asset master data.' .

ind:ContainerUnit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Container Unit' ;
    rdfs:comment 'Master record for intermodal containers and unit load devices (ULDs) managed within the fleet. Tracks container number (ISO 6346), TEU size classification (20ft, 40ft, 45ft), container type (dry, reefer, open-top, flat-rack, tank), tare weight, max gross weight, CSC certification expiry, current location (port/depot/vessel), availability status, lease agreement reference, and last inspection date. Distinct from transport_asset as containers are cargo-carrying units with their own ISO standards and lifecycle separate from traction units.' .

ind:AssetAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Asset Assignment' ;
    rdfs:comment 'Transactional record capturing the assignment of a transport asset (vehicle, aircraft, vessel) to a specific route, freight order, driver, or operational depot for a defined period. Tracks assignment type (route execution, depot standby, charter, maintenance hold), assigned driver/crew reference, origin depot, destination, planned start/end datetime, actual start/end datetime, TMS freight order reference, and assignment status. Enables fleet utilization tracking and TMS-to-fleet reconciliation.' .

ind:TelematicsEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Telematics Event' ;
    rdfs:comment 'High-frequency IoT/GPS telemetry event records streamed from onboard telematics devices fitted to fleet assets. Captures asset ID, device ID, event timestamp (yyyy-MM-ddTHH:mm:ss.SSSXXX), GPS coordinates (latitude, longitude, altitude), speed, heading, odometer reading, engine RPM, fuel level, ignition state, harsh braking/acceleration flags, geofence entry/exit events, temperature sensor readings (for reefer units), and raw IoT payload reference. Sourced from FourKites real-time visibility platform. Enables predictive ETA, route deviation detection, and driver behavior scoring.' .

ind:DriverProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Driver Profile' ;
    rdfs:comment 'Master record for all drivers and vehicle operators employed or contracted by Transport Shipping. Captures driver identity (employee/contractor ID from Workday HCM), license number, license class and categories, license issuing country, license expiry date, DOT medical certificate expiry, hazmat endorsement flag, IATA dangerous goods certification, years of experience, current assignment status, home depot, language proficiency, and disciplinary flag. Distinct from the workforce domain employee record — this is the fleet-specific operational driver profile with licensing and compliance attributes not held in HCM.' .

ind:DriverAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Driver Assignment' ;
    rdfs:comment 'Transactional record linking a driver to a specific transport asset and operational run for a defined shift or trip. Captures driver profile reference, asset reference, trip/run reference, planned departure datetime, actual departure datetime, planned return datetime, actual return datetime, assignment type (FTL haul, LTL multi-drop, last-mile, linehaul), hours of service (HOS) counter at assignment start, and assignment outcome status. Supports DOT hours-of-service compliance tracking and driver utilization reporting.' .

ind:MaintenanceOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Maintenance Order' ;
    rdfs:comment 'Transactional record for all planned and unplanned maintenance work orders raised against fleet assets. Captures asset reference, maintenance type (preventive, corrective, statutory inspection, DOT annual inspection, ICAO airworthiness check), work order number, raised date, scheduled date, completion date, maintenance provider (internal workshop or external vendor reference), fault description, parts replaced, labor hours, total maintenance cost (OPEX), downtime duration, and post-maintenance asset status. Integrates with SAP TM for asset availability updates and SAP S/4HANA Finance for OPEX cost posting.' .

ind:MaintenanceSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Maintenance Schedule' ;
    rdfs:comment 'Master record defining the preventive maintenance schedule and service intervals for each fleet asset type. Captures asset type, service type (oil change, tyre rotation, brake inspection, DOT annual inspection, ICAO 100-hour check), trigger basis (mileage interval, engine hours, calendar days), next due mileage/hours/date, last completed date, compliance mandatory flag, regulatory body (DOT, ICAO, IMO), and schedule status. Drives automated maintenance_order generation and ensures regulatory compliance with DOT, ICAO, and IMO inspection requirements.' .

ind:FuelTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Fuel Transaction' ;
    rdfs:comment 'Transactional record capturing every fuel uplift and energy consumption event for fleet assets. Tracks asset reference, driver reference, transaction datetime, fuel station/depot location, fuel type (diesel, petrol, LNG, SAF — Sustainable Aviation Fuel, electric charge), quantity (litres or kWh), unit cost, total cost, odometer reading at fill, fuel card number, supplier reference, and CO2e emission factor applied. Feeds sustainability domain for GHG reporting under EU ETS and CORSIA, and finance domain for OPEX fuel cost allocation.' .

ind:AssetInspection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Asset Inspection' ;
    rdfs:comment 'Transactional record for all formal regulatory and operational inspections conducted on fleet assets. Captures asset reference, inspection type (DOT roadside inspection, ICAO airworthiness check, IMO vessel survey, pre-trip inspection, annual safety inspection, C-TPAT security inspection), inspection date, inspector name/authority, inspection outcome (pass, fail, conditional), defects identified, corrective actions required, reinspection due date, and regulatory certificate issued. Distinct from maintenance_order — inspections are compliance events that may or may not trigger maintenance work.' .

ind:AssetLicence rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Asset Licence' ;
    rdfs:comment 'Master record tracking all regulatory licences, permits, certificates, and registrations associated with individual fleet assets. Captures asset reference, licence/permit type (vehicle registration, operating licence, airworthiness certificate, vessel class certificate, dangerous goods transport permit, oversize/overweight permit, cross-border transit permit), issuing authority, issue date, expiry date, licence number, jurisdiction/country, renewal reminder days, and current validity status. Ensures DOT, ICAO, IMO, and national transport authority compliance across the global fleet.' .

ind:Incident rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Incident' ;
    rdfs:comment 'Transactional record capturing all fleet-related incidents including road accidents, near-misses, cargo damage events, vehicle breakdowns, and security incidents. Tracks incident datetime, location (GPS coordinates and address), asset reference, driver reference, incident type, severity classification, third-party involvement flag, police report number, injuries reported, estimated asset damage cost, cargo damage reference, insurance claim reference, root cause classification, and corrective action status. Feeds the claim domain for cargo insurance processing and supports DOT accident reporting obligations.' .

ind:AssetUtilisation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Asset Utilisation' ;
    rdfs:comment 'Periodic operational record (daily/weekly snapshot) capturing fleet utilisation metrics for each transport asset. Tracks asset reference, reporting period (date), total available hours, total operational hours, total idle hours, total downtime hours (maintenance + breakdown), distance travelled (km/miles), load factor (actual payload vs capacity), number of trips completed, fuel efficiency (litres per 100km or MPG), and utilisation rate percentage. This is an operational Silver Layer record — NOT an analytics aggregate — representing the daily operational state of each asset for fleet management decisions.' .

ind:Depot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Depot' ;
    rdfs:comment 'Master record for all fleet depots, vehicle yards, maintenance workshops, and staging areas that serve as home bases or operational hubs for fleet assets. Captures depot name, depot code, depot type (vehicle depot, maintenance workshop, fuel station, container yard, ICD), address, GPS coordinates, country, region, capacity (number of vehicles/containers), available maintenance bays, fuel types available, operating hours, and managing business unit. Provides the geographic and operational context for asset assignment and maintenance planning.' .

ind:AssetType rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Asset Type' ;
    rdfs:comment 'Reference data defining the classification taxonomy for all fleet asset types used by Transport Shipping. Captures asset type code, asset category (road vehicle, aircraft, vessel, rail unit, container, ULD), sub-category (rigid truck, articulated truck, cargo aircraft, container ship, flatcar), IATA/IMO/DOT classification code, standard payload capacity, standard CBM capacity, fuel type standard, applicable regulatory framework (DOT, ICAO, IMO), and typical maintenance interval. Provides standardized classification used across transport_asset, maintenance_schedule, and asset_acquisition.' .

ind:Agreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Agreement' ;
    rdfs:comment 'Master record for all commercial contracts and agreements managed by Transport Shipping, including customer service contracts, carrier agreements, 3PL/4PL partnership agreements, and vendor contracts. Captures contract type, status, effective and expiry dates, governing Incoterms (DDP, DAP, FOB, CIF, EXW), jurisdiction, signatory parties, contract owner, auto-renewal flags, notice period, and contract tier classification. Serves as the SSOT for all contractual relationships across the enterprise.' .

ind:AgreementVersion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Agreement Version' ;
    rdfs:comment 'Tracks the full version history, amendment lifecycle, and approval workflow of each contract agreement. Captures version number, amendment type (initial, renewal, addendum, termination), effective date of each version, change summary, document reference, and the complete approval workflow: workflow stage (draft, legal review, commercial review, finance review, executive approval, executed), assigned approver(s), approval action (approved, rejected, returned), action date, comments, escalation flag, and SOX-compliant authorization controls. Enables audit trail and compliance tracking for contract changes over time.' .

ind:SlaCommitment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Sla Commitment' ;
    rdfs:comment 'Defines the SLA thresholds and KPI commitments embedded within a contract, including OTD (On-Time Delivery) targets, OTIF (On-Time In-Full) percentages, transit time guarantees, pickup window SLAs, claims resolution SLAs, and customer service response SLAs. Captures measurement frequency, reporting period, baseline values, target values, and the service mode (express, freight, last-mile) to which each SLA applies.' .

ind:SlaPerformance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Sla Performance' ;
    rdfs:comment 'Transactional record of actual contract performance measured against committed thresholds for each measurement period, covering both SLA performance (OTD, OTIF, transit time) and volume attainment (TEU, kg, CBM, shipment count). Captures measurement type (SLA or volume), period start and end dates, actual value achieved, committed/target value, variance, attainment percentage, breach or shortfall flag, breach severity, number of shipments in scope, and the data source system used for measurement. Feeds penalty and incentive calculations and contract compliance reporting.' .

ind:RateSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Rate Schedule' ;
    rdfs:comment 'Contractually agreed rate schedules and tariff structures embedded within a specific agreement, distinct from the global pricing catalog. Captures lane-level or zone-level rates, mode of transport (air, ocean, road, rail), service type (FTL, LTL, FCL, LCL, express), currency, rate validity start and end dates, rate basis (per kg, per TEU, per CBM, per shipment), and minimum charge thresholds. Links to the parent agreement and pricing domain rate cards.' .

ind:ContractSurchargeSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Contract Surcharge Schedule' ;
    rdfs:comment 'Contractually agreed surcharge schedules applicable to a specific agreement, covering BAF (Bunker Adjustment Factor), GRI (General Rate Increase), THC (Terminal Handling Charge), fuel surcharges, peak season surcharges, remote area surcharges, and DIM weight adjustments. Captures surcharge type, calculation method, cap/floor values, applicability conditions, and validity period within the contract.' .

ind:VolumeCommitment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Volume Commitment' ;
    rdfs:comment 'Defines volume and capacity commitment obligations within a contract, including minimum volume guarantees (MVG), maximum volume caps, TEU commitments for ocean freight, weight-based commitments for air freight, shipment count commitments for express, and lane-level capacity allocations specifying origin-destination pairs, transport mode, weekly or monthly capacity (TEU, kg, flights, truck loads), minimum booking obligations, and rollover provisions. Captures commitment period (monthly, quarterly, annual), measurement unit, lane code, origin/destination port or hub, service string or route code, penalty for shortfall, and incentive for exceeding targets.' .

ind:VolumeActuals rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Volume Actuals' ;
    rdfs:comment 'Transactional record of actual volumes shipped against contracted volume commitments for each measurement period. Captures period start and end dates, actual volume shipped (TEU, kg, CBM, shipment count), committed volume, variance, attainment percentage, and shortfall or surplus flag. Used to trigger penalty or incentive clause calculations and contract compliance reporting.' .

ind:PenaltyClause rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Penalty Clause' ;
    rdfs:comment 'Defines financial clauses embedded within a contract, encompassing both penalty clauses (SLA breach penalties, volume shortfall penalties, late payment penalties, service failure deductions) and incentive/rebate clauses (volume rebates, performance bonuses for exceeding OTD/OTIF targets, loyalty discounts, early payment incentives). Captures clause type (penalty or incentive), trigger condition/threshold, calculation method (fixed fee, percentage of invoice, credit note, tiered rebate, flat bonus), maximum liability cap or maximum payout, cure period, escalation path, payment frequency, and accrual method. Linked to the parent agreement and specific SLA or volume commitment.' .

ind:PenaltyEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Penalty Event' ;
    rdfs:comment 'Transactional record of an actual penalty or incentive event triggered under a contract clause. Captures the triggering event (SLA breach, volume shortfall, service failure), event date, calculated penalty or incentive amount, currency, status (pending, approved, disputed, settled), reference to the billing domain for credit/debit note issuance, and resolution notes.' .

ind:CarrierAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Carrier Agreement' ;
    rdfs:comment 'Master record for carrier-specific agreements governing transport capacity procurement, including contracted lane allocations, space commitments, carrier performance standards, liability limits, and EDI connectivity requirements. Captures carrier type (ocean, air, road, rail), NVOCC or direct carrier flag, IATA/IMO carrier code, contracted capacity (TEU, kg, CBM), and agreement tier (preferred, approved, spot).' .

ind:LaneCommitment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Lane Commitment' ;
    rdfs:comment 'Defines contracted lane-level capacity commitments within a carrier agreement, specifying origin-destination pairs, transport mode, weekly or monthly capacity allocation (TEU, kg, flights, truck loads), minimum booking obligations, and rollover provisions. Captures lane code, origin port/hub, destination port/hub, service string or route code, and capacity unit.' .

ind:ServiceScope rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Service Scope' ;
    rdfs:comment 'Defines the specific logistics services and service lines included within a contract, such as express parcel delivery, air freight forwarding, ocean FCL/LCL, road FTL/LTL, customs brokerage, warehousing, last-mile delivery, and e-commerce fulfillment. Captures service code, service description, applicable geographies, service tier, and any service-specific terms or exclusions.' .

ind:ContractParty rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Contract Party' ;
    rdfs:comment 'Association entity capturing all parties to a contract, including the shipper/customer, carrier, 3PL partner, customs broker, and guarantor. Captures party role (buyer, seller, carrier, broker, guarantor, co-signatory), party type (corporate, individual), legal entity name, registration number, signatory name, signatory title, and date of signature. Supports multi-party contract structures.' .

ind:Carrier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Carrier' ;
    rdfs:comment 'Master record for all carrier partners in the Transport Shipping network, including airlines, ocean shipping lines, road hauliers, rail operators, and express courier partners. Captures carrier legal name, IATA/SCAC/IMO codes, carrier type, transport modes supported, country of registration, regulatory certifications (IATA, FIATA, C-TPAT, AEO), financial standing, insurance coverage details, operational status, and onboarding lifecycle stage. Serves as the SSOT for carrier identity across freight, route, and contract domains.' .

ind:CarrierProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Carrier Profile' ;
    rdfs:comment 'Operational capability profile for a carrier partner, extending the carrier master with detailed service capability data. Captures transport modes offered (air, ocean, road, rail, multimodal), geographic coverage (trade lanes, regions, countries served), service types (FTL, LTL, FCL, LCL, express, economy), capacity parameters (max weight, volume, TEU capacity), equipment types operated, temperature-controlled capability, dangerous goods handling certification, last-mile capability, and digital integration readiness (EDI, API). Distinct from the carrier master identity record — this is the operational capability profile.' .

ind:Agent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Agent' ;
    rdfs:comment 'Master record for freight agents, general sales agents (GSAs), handling agents, and ground handling agents in the Transport Shipping partner network. Captures agent legal name, agent type (freight agent, GSA, handling agent, customs agent, co-loader), IATA agent code, FIATA membership, country and city of operation, principal carrier relationships, bonding and financial guarantee status, commission structure type, and operational scope. Agents are distinct from carriers — they act as intermediaries and representatives rather than transport operators.' .

ind:AgentAppointment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Agent Appointment' ;
    rdfs:comment 'Formal appointment record authorizing a freight agent or GSA to act on behalf of Transport Shipping or a carrier partner in a defined territory or for a defined service scope. Captures appointment reference, appointing party, appointed agent, territory (country/region), authorized service lines, appointment start and expiry dates, commission rate agreed, exclusivity flag, performance bond requirement, and appointment status (active, suspended, terminated). Manages the lifecycle of agent authority grants across the network.' .

ind:InterlineAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Interline Agreement' ;
    rdfs:comment 'Master record for interline agreements between Transport Shipping and partner carriers enabling the exchange of traffic, co-loading, and through-billing across carrier networks. Captures agreement reference, partner carrier, agreement type (interline, code-share, blocked space, SPA — Special Prorate Agreement), transport mode, trade lanes covered, prorate methodology, revenue split terms, minimum volume commitments, IATA prorate rules reference, effective and expiry dates, and agreement status. Governs the commercial and operational terms for traffic interchange.' .

ind:TplProvider rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Tpl Provider' ;
    rdfs:comment 'Master record for third-party logistics (3PL) and fourth-party logistics (4PL) providers in the Transport Shipping partner network. Captures provider legal name, provider type (3PL, 4PL, co-packer, value-added logistics provider), operational capabilities (warehousing, distribution, customs brokerage, last-mile, cold chain), geographic footprint, technology platform integrations, certifications (ISO, GDP, HACCP), financial standing, and onboarding status. Distinct from carriers (who move goods) — 3PL/4PL providers manage logistics operations on behalf of shippers.' .

ind:Partner rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Partner' ;
    rdfs:comment 'Unified master record representing any external organization participating in the Transport Shipping logistics network beyond carriers and 3PL providers — including port authorities, airport ground handlers, customs brokers, bonded warehouse operators, freight stations (CFS/ICD), and co-loading partners. Captures partner legal name, partner category, country, regulatory registrations, operational scope, contact details, and network participation status. Acts as the umbrella partner identity record for network participants not covered by the carrier or 3PL provider masters.' .

ind:PartnerCertification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Partner Certification' ;
    rdfs:comment 'Master record tracking all regulatory, industry, and quality certifications held by network partners (carriers, agents, 3PL providers, correspondent offices). Captures partner reference, certification type (IATA, AEO, C-TPAT, ISO 9001, GDP, TAPA, SmartWay, FIATA), issuing authority, certificate number, issue date, expiry date, renewal status, and compliance verification date. Enables partner compliance monitoring and ensures only certified partners are used for regulated trade lanes and commodity types.' .

ind:PartnerPerformance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Partner Performance' ;
    rdfs:comment 'Periodic operational performance record evaluating network partner performance against contracted KPIs and service standards. Captures partner reference, measurement period, performance dimensions (OTD rate, transit time compliance, damage rate, documentation accuracy, claims rate, capacity fulfillment rate), actual vs. target values, performance tier (preferred, approved, probation, suspended), trend direction, and review outcome. Drives partner tiering decisions, contract renewals, and network optimization. Distinct from contract SLA performance — this is the network-level partner scorecard.' .

ind:CapacityAllocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Capacity Allocation' ;
    rdfs:comment 'Transactional record capturing the allocation of transport capacity from a carrier or 3PL partner to Transport Shipping for a defined period, trade lane, and service type. Captures carrier or partner reference, trade lane, transport mode, service type, allocation period (weekly/monthly), allocated capacity (kg, TEU, CBM, pallet positions), utilized capacity, fill rate, capacity source (blocked space, allotment, spot), and allocation status. Enables capacity planning, utilization monitoring, and carrier capacity procurement management.' .

ind:BlockedSpaceAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Blocked Space Agreement' ;
    rdfs:comment 'Master record for blocked space agreements (BSAs) between Transport Shipping and ocean or air carriers guaranteeing a fixed volume of capacity on specific services or trade lanes. Captures BSA reference, carrier, trade lane, transport mode (air/ocean), service or vessel/flight, guaranteed capacity (TEU, kg, CBM), minimum utilization commitment, penalty for under-utilization, rate basis, effective and expiry dates, and BSA status. Distinct from interline agreements (which govern revenue proration) — BSAs govern capacity reservation and utilization obligations.' .

ind:CarrierService rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Carrier Service' ;
    rdfs:comment 'Master record defining the specific transport services offered by a carrier partner, representing the named service products available for booking. Captures carrier reference, service name, service code, transport mode, service type (direct, transshipment, feeder, express, economy), origin and destination regions, transit time, frequency (daily, weekly, fortnightly), vessel/flight/train service identifier, cut-off times, and service status. Enables service-level carrier selection and route planning. Distinct from route.carrier_schedule (which captures published timetables) — this is the service product definition.' .

ind:CarrierContact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Carrier Contact' ;
    rdfs:comment 'Master record for key contacts at carrier and network partner organizations, capturing the individuals responsible for commercial, operational, and technical liaison with Transport Shipping. Captures carrier or partner reference, contact full name, job title, department, contact type (commercial, operations, claims, documentation, IT/EDI), email, phone, preferred communication channel, and active status. Enables relationship management and escalation routing across the partner network.' .

ind:NetworkEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Network Event' ;
    rdfs:comment 'Transactional event log capturing significant operational events affecting the partner network — including carrier service suspensions, capacity disruptions, port congestion alerts, strike actions, natural disaster impacts, regulatory changes affecting trade lanes, and partner status changes. Captures event type, affected partner or carrier, affected trade lanes or regions, event severity, start and end datetime, operational impact description, mitigation actions taken, and resolution status. Enables proactive network disruption management and partner communication.' .

ind:PartnerOnboarding rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Partner Onboarding' ;
    rdfs:comment 'Transactional record tracking the end-to-end onboarding lifecycle of a new network partner (carrier, agent, 3PL, correspondent office) from initial qualification through activation. Captures partner reference, onboarding type, onboarding stage (pre-qualification, due diligence, contract execution, system integration, go-live), stage completion dates, responsible onboarding manager, compliance checks completed (KYC, sanctions screening, certification verification), IT integration status (EDI, API), and overall onboarding status. Ensures structured and auditable partner onboarding.' .

ind:PartnerSettlement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Partner Settlement' ;
    rdfs:comment 'Transactional record managing financial settlement between Transport Shipping and network partners for interline traffic, capacity utilization, agent commissions, and 3PL service fees. Captures partner reference, settlement period, settlement type (interline prorate, agent commission, 3PL service fee, capacity penalty), gross amount, deductions, net settlement amount, currency, settlement method (CASS, bank transfer, netting), settlement date, and reconciliation status. Enables accurate partner financial settlement and dispute resolution.' .

ind:PartnerSla rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Partner Sla' ;
    rdfs:comment 'Master record defining the service level agreement commitments agreed with network partners (carriers, agents, 3PL providers) governing operational performance standards. Captures partner reference, SLA type (transit time, pickup compliance, documentation accuracy, claims response time, capacity fulfillment), target metric, measurement unit, threshold values (target, warning, breach), measurement frequency, penalty or incentive clause reference, effective date, and SLA status. Distinct from contract.sla_commitment (which governs customer-facing SLAs) — this is the partner-facing operational SLA.' .

ind:EdiConnection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Edi Connection' ;
    rdfs:comment 'Master record for electronic data interchange (EDI) and API integration connections established with network partners for automated message exchange. Captures partner reference, connection type (EDI TRADACOMS, EDIFACT, X12, API REST, SFTP), message types supported (booking confirmation, status update, AWB data, manifest, invoice), connection endpoint details, protocol version, test and production environment status, go-live date, message volume, and connection health status. Manages the digital integration layer of the partner network.' .

ind:Quote rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Freight ;
    rdfs:label 'Quote' ;
    rdfs:comment 'Formal freight quotation issued to a shipper or customer for a specific freight movement, capturing quoted rates, validity period, service terms, and mode options prior to booking confirmation.' .

ind:PerformanceObligation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Performance Obligation' ;
    rdfs:comment 'Master reference table for performance_obligation. Referenced by performance_obligation_id.' .

ind:Claimant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Claim ;
    rdfs:label 'Claimant' ;
    rdfs:comment 'Master reference table for claimant. Referenced by claimant_id.' .

ind:Trip rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Trip' ;
    rdfs:comment 'Master reference table for trip. Referenced by trip_id.' .

ind:Item rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Item' ;
    rdfs:comment 'Master reference table for item. Referenced by item_id.' .

ind:HandlingUnit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Warehouse ;
    rdfs:label 'Handling Unit' ;
    rdfs:comment 'Master reference table for handling_unit. Referenced by handling_unit_id.' .

ind:Cargo rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Freight ;
    rdfs:label 'Cargo' ;
    rdfs:comment 'Master reference table for cargo. Referenced by cargo_id.' .

ind:SupplyAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Supply Agreement' ;
    rdfs:comment 'This association product represents the contractual supply relationship between a supplier and an item. It captures the approved supplier list (ASL) and supplier item catalog maintained in procurement systems (Coupa, SAP SRM). Each record links one supplier to one item with pricing, lead time, minimum order quantities, and contract terms that exist only in the context of this specific supplier-item pairing. This is the foundation for sourcing decisions, RFQ evaluation, and preferred supplier management.. Existence Justification: In Transport Shipping\'s procurement operations, suppliers provide multiple items (fuel, packaging materials, IT equipment, facility services, vehicle parts), and each item can be sourced from multiple suppliers to ensure supply chain resilience and competitive pricing. The supply agreement (also known as Approved Supplier List or Supplier Item Catalog in Coupa/SAP SRM) is a recognized business entity that procurement teams actively manage, with each supplier-item pairing having distinct pricing, lead times, minimum order quantities, and contract terms.' .

ind:ManifestLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Shipment ;
    rdfs:label 'Manifest Line' ;
    rdfs:comment 'This association product represents the loading record between a freight manifest and a consignment. It captures the operational act of loading a specific consignment onto a specific manifest, including line-level loading details such as sequence, loaded pieces, weight, volume, and line status. Each record links one freight manifest to one consignment with attributes that exist only in the context of this loading relationship. This is a core operational entity in TMS and freight systems, enabling load reconciliation, carrier handover documentation, and multi-leg shipment tracking.. Existence Justification: In freight logistics operations, manifest consolidation is a core operational process where multiple consignments are physically loaded onto a single transport vehicle, vessel, or aircraft (the manifest). Reciprocally, a single consignment can appear on multiple manifests across its multi-leg journey (e.g., origin terminal → hub → destination terminal). The manifest line is a recognized operational entity in TMS and WMS systems, representing the loading record with line-level data such as sequence, loaded pieces, weight, volume, and status that belongs to neither the manifest nor the consignment alone, but to the specific loading relationship.' .

ind:Allocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Allocation' ;
    rdfs:comment 'This association product represents the operational assignment between a merchant and a fulfillment center. It captures the formal allocation of merchant inventory and order fulfillment capacity across Transport Shipping\'s fulfillment network. Each record links one merchant to one center with allocation percentages, priority rankings, service type enablement, and storage capacity assignments that exist only in the context of this specific merchant-center pairing.. Existence Justification: In Transport Shipping\'s fulfillment operations, merchants are formally allocated to one or more fulfillment centers based on geographic coverage, capacity, and service requirements. This is an actively managed operational relationship where fulfillment planners assign merchants to centers with specific allocation percentages (for load balancing), priority rankings (for routing logic), storage capacity allocations, and service type enablement. The business tracks both current and historical allocations for billing reconciliation, SLA audit, and capacity planning purposes.' .

ind:DeclarationComplianceBenefit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customs ;
    rdfs:label 'Declaration Compliance Benefit' ;
    rdfs:comment 'This association product represents the application of trade compliance program benefits to specific customs declarations. It captures which compliance programs (C-TPAT, AEO, trusted trader certifications) were invoked for each declaration to obtain expedited processing, reduced examination rates, or other program-specific benefits. Each record links one declaration to one compliance program with attributes documenting the specific benefits applied and their effectiveness. This is a recognized operational record in customs management systems used for program performance measurement and audit trail requirements.. Existence Justification: In customs clearance operations, a single declaration can invoke multiple compliance program benefits simultaneously (e.g., C-TPAT for security, AEO for EU recognition, and ISO 28000 for supply chain certification), and each compliance program is applied to thousands of declarations over time. Customs authorities require tracking which specific program benefits were claimed and verified for each declaration for audit, program performance measurement, and mutual recognition reporting. This is an operational business entity called \'declaration compliance benefit\' or \'program benefit application\' that is actively managed in trade compliance systems.' .

# --- Attribute Properties ---
ind:cargoClaimId rdf:type rdf:Property ;
    rdfs:label 'Cargo Claim Id' ;
    rdfs:comment 'Unique system-generated surrogate identifier for the cargo claim record. Primary key for the cargo_claim data product.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CargoClaim .

ind:agreementId rdf:type rdf:Property ;
    rdfs:label 'Agreement Id' ;
    rdfs:comment 'Foreign key linking to contract.agreement. Business justification: Claims arise from service failures under contractual agreements. Liability limits, SLA breach penalties, and settlement authority are defined in the governing agreement. Essential for liability determ' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:airWaybillId rdf:type rdf:Property ;
    rdfs:label 'Air Waybill Id' ;
    rdfs:comment 'Foreign key linking to freight.air_waybill. Business justification: Air cargo claims must reference AWB as primary transport document for Montreal/Warsaw Convention liability determination. Replaces denormalized awb_number with proper FK for weight verification, rate ' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AirWaybill .

ind:asnId rdf:type rdf:Property ;
    rdfs:label 'Asn Id' ;
    rdfs:comment 'Foreign key linking to warehouse.warehouse_asn. Business justification: Inbound cargo claims for ASN shortages or damage require linking to the warehouse_asn to verify expected vs. received quantities, carrier reference, and seal numbers. This is the standard inbound clai' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asn .

ind:assetInspectionId rdf:type rdf:Property ;
    rdfs:label 'Asset Inspection Id' ;
    rdfs:comment 'Foreign key linking to fleet.asset_inspection. Business justification: Insurers and claims handlers must verify the transport asset\'s last inspection record (roadworthiness, defects, regulatory certificates) when investigating a cargo claim. This is a standard subrogatio' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetInspection .

ind:billOfLadingId rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Id' ;
    rdfs:comment 'Foreign key linking to freight.bill_of_lading. Business justification: Ocean cargo claims must reference B/L as primary transport document and contract of carriage for Hague-Visby/Hamburg Rules liability determination. Replaces denormalized bol_number with proper FK for ' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillOfLading .

ind:bookingId rdf:type rdf:Property ;
    rdfs:label 'Booking Id' ;
    rdfs:comment 'Foreign key linking to freight.booking. Business justification: Claims may reference original booking when incident occurs during booking phase (space rejection, cargo refused at origin). Supports pre-shipment commercial dispute resolution and booking-level liabil' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Booking .

ind:cargoId rdf:type rdf:Property ;
    rdfs:label 'Cargo Id' ;
    rdfs:comment 'Foreign key linking to freight.cargo. Business justification: Claim valuation and liability cap calculation require cargo commodity code, declared value, hazmat class, and packaging type from the cargo entity. A logistics claims expert would always link a claim ' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cargo .

ind:carrierId rdf:type rdf:Property ;
    rdfs:label 'Carrier Id' ;
    rdfs:comment 'Foreign key linking to network.carrier. Business justification: Claims arise from carrier handling incidents; liability determination, subrogation recovery, and settlement negotiations require direct carrier identification. Essential for carrier liability assessme' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:carrierServiceId rdf:type rdf:Property ;
    rdfs:label 'Carrier Service Id' ;
    rdfs:comment 'Foreign key linking to network.carrier_service. Business justification: Claims reference specific carrier service levels (express, economy, temperature-controlled) which determine liability limits, SLA breaches, and service-specific exclusions. Critical for accurate liabi' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarrierService .

ind:claimantId rdf:type rdf:Property ;
    rdfs:label 'Claimant Id' ;
    rdfs:comment 'Reference to the party (customer, shipper, consignee, or third party) who filed the cargo claim. Serves as the PARTY_REFERENCE for this transaction header.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Claimant .

ind:consignmentId rdf:type rdf:Property ;
    rdfs:label 'Consignment Id' ;
    rdfs:comment 'Reference to the shipment against which this cargo claim is filed. Links the claim to the originating transport event.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Consignment .

ind:consolidationId rdf:type rdf:Property ;
    rdfs:label 'Consolidation Id' ;
    rdfs:comment 'Foreign key linking to freight.consolidation. Business justification: LCL/groupage cargo claims require identifying the consolidation to apportion liability among co-loaded shipments and recover costs from the NVOCC operator. Claims adjusters and subrogation teams depen' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Consolidation .

ind:containerUnitId rdf:type rdf:Property ;
    rdfs:label 'Container Unit Id' ;
    rdfs:comment 'Foreign key linking to fleet.container_unit. Business justification: Many cargo claims involve container-specific issues (structural damage, contamination, seal breaches, temperature control failures). Links claim to container maintenance, inspection, certification rec' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContainerUnit .

ind:customerAccountId rdf:type rdf:Property ;
    rdfs:label 'Customer Account Id' ;
    rdfs:comment 'Foreign key linking to customer.customer_account. Business justification: Every other major claim product links to customer_account, but the root cargo_claim record does not. Claims management, customer claim history reporting, credit exposure tracking, and SLA breach analy' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:customsDeclarationId rdf:type rdf:Property ;
    rdfs:label 'Customs Declaration Id' ;
    rdfs:comment 'Foreign key linking to customs.declaration. Business justification: Claims arising from customs issues (duty disputes, valuation disagreements, inspection damage, holds) require linking to the customs declaration to verify declared values, duty assessments, and custom' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Declaration .

ind:deliveryAttemptId rdf:type rdf:Property ;
    rdfs:label 'Delivery Attempt Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.delivery_attempt. Business justification: Claims arise from specific delivery attempts (proof of delivery disputes, signature fraud, delivery to wrong address, recipient impersonation). Legal and claims teams need attempt-level evidence inclu' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryAttempt .

ind:deniedPartyScreeningId rdf:type rdf:Property ;
    rdfs:label 'Denied Party Screening Id' ;
    rdfs:comment 'Foreign key linking to customs.denied_party_screening. Business justification: Claims involving denied parties require direct screening reference for compliance investigations, regulatory reporting, and liability exclusion determinations. Essential for AML/sanctions compliance a' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeniedPartyScreening .

ind:driverProfileId rdf:type rdf:Property ;
    rdfs:label 'Driver Profile Id' ;
    rdfs:comment 'Foreign key linking to fleet.driver_profile. Business justification: Claims may involve driver negligence, improper cargo handling, accidents, or HOS violations. Links to driver certification, training records, incident history, and performance data for liability deter' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DriverProfile .

ind:facilityId rdf:type rdf:Property ;
    rdfs:label 'Facility Id' ;
    rdfs:comment 'Foreign key linking to warehouse.facility. Business justification: Cargo claims are filed against incidents occurring at a specific warehouse facility (damage at dock, theft in storage). Claims teams and insurers require the originating facility for root-cause analys' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:filingContactId rdf:type rdf:Property ;
    rdfs:label 'Filing Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: The contact who filed the claim must be recorded on the root cargo_claim for correspondence, escalation notifications, and regulatory notification purposes. Claims operations require a named filing co' ;
    rdfs:domain ind:CargoClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:freightOrderId rdf:type rdf:Property ;
    rdfs:label 'Freight Order Id' ;
    rdfs:comment 'Foreign key linking to freight.freight_order. Business justification: Claims are filed against specific freight orders when cargo damage/loss/delay occurs. Core business process for linking claim liability to the shipment contract. Essential for claim investigation, lia' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightOrder .

ind:handlingAgentId rdf:type rdf:Property ;
    rdfs:label 'Handling Agent Id' ;
    rdfs:comment 'Foreign key linking to network.agent. Business justification: Cargo claims routinely involve customs agents, freight forwarders, or handling agents at origin/destination who are responsible parties or witnesses. Essential for multi-party liability determination ' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:handlingUnitId rdf:type rdf:Property ;
    rdfs:label 'Handling Unit Id' ;
    rdfs:comment 'Foreign key linking to warehouse.handling_unit. Business justification: Claims for damaged or missing handling units (pallets, cartons) require linking to the specific handling_unit record to verify contents, weight, SSCC, and condition at dispatch. This is distinct from ' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HandlingUnit .

ind:holdId rdf:type rdf:Property ;
    rdfs:label 'Hold Id' ;
    rdfs:comment 'Foreign key linking to customs.customs_hold. Business justification: Customs holds are a frequent cause of delay claims and can cause cargo deterioration (perishables, temperature-sensitive goods). Claims management must track which hold caused the loss to determine li' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hold .

ind:inboundReceiptId rdf:type rdf:Property ;
    rdfs:label 'Inbound Receipt Id' ;
    rdfs:comment 'Foreign key linking to warehouse.inbound_receipt. Business justification: Cargo damage and shortage claims are most commonly triggered at inbound receiving. The inbound_receipt is the primary evidence document (discrepancy_flag, seal_intact_flag, temperature_compliant_flag)' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundReceipt .

ind:intermodalTransferId rdf:type rdf:Property ;
    rdfs:label 'Intermodal Transfer Id' ;
    rdfs:comment 'Foreign key linking to freight.intermodal_transfer. Business justification: Damage frequently occurs at intermodal transfer points (port transshipment, rail-to-truck handover). Linking the claim to the specific transfer event supports root cause analysis, dwell-time liability' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IntermodalTransfer .

ind:lastMileDispatchId rdf:type rdf:Property ;
    rdfs:label 'Last Mile Dispatch Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.last_mile_dispatch. Business justification: Last-mile delivery is highest-risk stage for claims (delivery failures, COD disputes, recipient refusals, theft). Claims must reference specific dispatch for driver accountability, route analysis, and' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LastMileDispatch .

ind:merchantId rdf:type rdf:Property ;
    rdfs:label 'Merchant Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.merchant. Business justification: B2B e-commerce claims where merchant is claimant or liable party (merchant-owned inventory damage, merchant packaging inadequacy). Merchant account management needs claim history visibility for credit' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Merchant .

ind:outboundShipmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Outbound Shipment Order Id' ;
    rdfs:comment 'Foreign key linking to warehouse.outbound_shipment_order. Business justification: Claims for outbound shipment loss or damage require tracing back to the outbound_shipment_order to verify declared value, incoterm, carrier assignment, and SLA. This is the standard claims-to-dispatch' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OutboundShipmentOrder .

ind:packageId rdf:type rdf:Property ;
    rdfs:label 'Package Id' ;
    rdfs:comment 'Foreign key linking to shipment.shipment_package. Business justification: Cargo claims are frequently filed for specific damaged or missing packages. Package-level claim processing requires direct reference to the shipment_package record for weight, declared value, and hand' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Package .

ind:parcelId rdf:type rdf:Property ;
    rdfs:label 'Parcel Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.parcel. Business justification: Parcel-level claims are standard in logistics (individual package damage, loss during transit, dimensional weight disputes). Claims adjusters need direct parcel reference for liability assessment, ins' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Parcel .

ind:planId rdf:type rdf:Property ;
    rdfs:label 'Plan Id' ;
    rdfs:comment 'Foreign key linking to route.route_plan. Business justification: Claims teams perform root-cause analysis by tracing incidents back to the executed route plan. Essential for determining if routing decisions (carrier selection, lane choice, hub routing) contributed ' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:policyId rdf:type rdf:Property ;
    rdfs:label 'Policy Id' ;
    rdfs:comment 'Foreign key linking to claim.claim_policy. Business justification: Cargo claim is filed under a specific insurance policy. N:1 relationship (many claims per policy). Adding policy_id FK allows normalization of policy_number which is currently stored as STRING. The cl' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_order. Business justification: Claims involving purchased goods need PO linkage for contract terms verification, pricing validation, supplier liability determination, and warranty claim processing. Critical for procurement-related ' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:replacementSpotQuoteId rdf:type rdf:Property ;
    rdfs:label 'Replacement Spot Quote Id' ;
    rdfs:comment 'Foreign key linking to pricing.spot_quote. Business justification: Claims frequently trigger replacement shipment quotes when cargo is damaged/lost. Claim handlers coordinate with sales to obtain spot quotes for re-shipping goods to consignee or returning salvage. Re' ;
    rdfs:domain ind:CargoClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpotQuote .

ind:shipmentCarrierAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Carrier Assignment Id' ;
    rdfs:comment 'Foreign key linking to shipment.shipment_carrier_assignment. Business justification: Carrier recovery and subrogation processes require the specific carrier assignment record to identify contracted rates, assignment method, and carrier performance data. cargo_claim has carrier_id but ' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShipmentCarrierAssignment .

ind:shipmentLegId rdf:type rdf:Property ;
    rdfs:label 'Shipment Leg Id' ;
    rdfs:comment 'Foreign key linking to shipment.shipment_leg. Business justification: Cargo claims require identification of the specific shipment leg where damage/loss occurred for liability attribution and carrier recovery. Claims adjusters and operations teams use this to determine ' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShipmentLeg .

ind:slaEntitlementId rdf:type rdf:Property ;
    rdfs:label 'Sla Entitlement Id' ;
    rdfs:comment 'Foreign key linking to customer.sla_entitlement. Business justification: SLA entitlements define contractual claims_resolution_sla_days and penalty_clause terms. Claims teams must reference the applicable SLA entitlement to set resolution targets, calculate penalty exposur' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaEntitlement .

ind:supplierId rdf:type rdf:Property ;
    rdfs:label 'Supplier Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier. Business justification: Claims on supplier-provided goods require supplier linkage for supplier performance management, cost recovery, quality scorecarding, and chargeback processing. Essential for supplier accountability in' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:transportAssetId rdf:type rdf:Property ;
    rdfs:label 'Transport Asset Id' ;
    rdfs:comment 'Foreign key linking to fleet.transport_asset. Business justification: Cargo claims frequently involve specific transport assets (trucks, trailers, containers) that caused or were involved in damage incidents. Essential for liability determination, maintenance history re' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransportAsset .

ind:tripId rdf:type rdf:Property ;
    rdfs:label 'Trip Id' ;
    rdfs:comment 'Foreign key linking to fleet.trip. Business justification: A cargo claim is always associated with the specific trip during which loss or damage occurred. Claims handlers need the trip record to identify routing, timing, driver, and asset details. This is a f' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Trip .

ind:approvedAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Amount' ;
    rdfs:comment 'Monetary amount approved for settlement after liability determination, deductibles, and applicable convention liability caps. May differ from claimed_amount based on investigation findings and regulatory limits.' ;
    rdfs:domain ind:CargoClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Number' ;
    rdfs:comment 'Externally-known, human-readable unique reference number assigned to the cargo claim at registration. Used in all claimant correspondence, insurer filings, and regulatory submissions. Format: CLM-{YYYY}-{8-digit sequence}.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimStatus rdf:type rdf:Property ;
    rdfs:label 'Claim Status' ;
    rdfs:comment 'Current lifecycle state of the cargo claim from initial registration through final resolution. Drives workflow routing and SLA monitoring. [ENUM-REF-CANDIDATE: registered|under_investigation|liability_determined|settled|rejected|withdrawn|subrogation — promote to reference product]' ;
    rdfs:domain ind:CargoClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimType rdf:type rdf:Property ;
    rdfs:label 'Claim Type' ;
    rdfs:comment 'Classification of the cargo claim by the nature of the loss event. Determines applicable liability framework and settlement calculation methodology. [ENUM-REF-CANDIDATE: loss|damage|shortage|delay|contamination|dangerous_goods|misdelivery — promote to reference product]' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimedAmount rdf:type rdf:Property ;
    rdfs:label 'Claimed Amount' ;
    rdfs:comment 'Gross monetary amount claimed by the claimant for the loss, damage, shortage, delay, or contamination event. Represents the claimant\'s stated valuation before liability assessment and adjustment.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimedPieces rdf:type rdf:Property ;
    rdfs:label 'Claimed Pieces' ;
    rdfs:comment 'Number of pieces, packages, or units of cargo subject to the claim. Used in per-package liability limit calculations under Hague-Visby Rules and for shortage quantification.' ;
    rdfs:domain ind:CargoClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimedWeightKg rdf:type rdf:Property ;
    rdfs:label 'Claimed Weight Kg' ;
    rdfs:comment 'Gross weight in kilograms of the cargo subject to the claim as declared by the claimant. Used in per-kilogram liability limit calculations under Warsaw-Montreal and CMR conventions.' ;
    rdfs:domain ind:CargoClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditNoteReference rdf:type rdf:Property ;
    rdfs:label 'Credit Note Reference' ;
    rdfs:comment 'Reference number of the credit note issued to the claimant\'s billing account as part of the claim settlement. Links the claim to the billing and accounts receivable process in SAP S/4HANA Finance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which all monetary amounts on this claim (claimed, approved, settlement) are denominated.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damagedPieces rdf:type rdf:Property ;
    rdfs:label 'Damaged Pieces' ;
    rdfs:comment 'Number of pieces or packages confirmed as damaged or lost following cargo survey. Used to calculate the proportion of the shipment affected and to validate the claimed amount.' ;
    rdfs:domain ind:CargoClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dangerousGoodsClass rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Class' ;
    rdfs:comment 'IMDG/ICAO dangerous goods classification class and division (e.g., Class 1 Explosives, Class 3 Flammable Liquids, Class 6.1 Toxic Substances) for cargo subject to the claim. Populated only when is_dangerous_goods is true.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductibleAmount rdf:type rdf:Property ;
    rdfs:label 'Deductible Amount' ;
    rdfs:comment 'Insurance policy deductible amount applied to the claim settlement calculation. Reduces the net payable amount to the claimant.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the shipment\'s destination country. Used for jurisdictional analysis, cross-border claim routing, and applicable convention determination.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financeReserveAmount rdf:type rdf:Property ;
    rdfs:label 'Finance Reserve Amount' ;
    rdfs:comment 'Monetary amount set aside in the financial reserve (provision) for this outstanding claim. Used by SAP S/4HANA Finance for IFRS 4 insurance contract accounting and balance sheet provisioning.' ;
    rdfs:domain ind:CargoClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incidentCountryCode rdf:type rdf:Property ;
    rdfs:label 'Incident Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the incident occurred. Used for jurisdictional determination, regulatory reporting, and geographic analytics.' ;
    rdfs:domain ind:CargoClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentDate rdf:type rdf:Property ;
    rdfs:label 'Incident Date' ;
    rdfs:comment 'Calendar date on which the loss, damage, shortage, delay, or contamination event occurred or was discovered. Principal real-world event date for the claim. Used to determine applicable liability periods and statute of limitations.' ;
    rdfs:domain ind:CargoClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incidentDescription rdf:type rdf:Property ;
    rdfs:label 'Incident Description' ;
    rdfs:comment 'Narrative description of the circumstances surrounding the loss, damage, shortage, delay, or contamination event. Captures the factual account as reported by the claimant or discovered during survey.' ;
    rdfs:domain ind:CargoClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentLocation rdf:type rdf:Property ;
    rdfs:label 'Incident Location' ;
    rdfs:comment 'Geographic location (city, port, airport, warehouse, or route segment) where the loss, damage, shortage, or contamination event occurred or was identified. Used for root cause analysis and carrier liability determination.' ;
    rdfs:domain ind:CargoClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insurerName rdf:type rdf:Property ;
    rdfs:label 'Insurer Name' ;
    rdfs:comment 'Name of the cargo insurance underwriter or insurer responsible for covering this claim. Used for insurer correspondence and subrogation recovery tracking.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insurerReference rdf:type rdf:Property ;
    rdfs:label 'Insurer Reference' ;
    rdfs:comment 'Reference number assigned by the cargo insurer or underwriter to this claim. Used for insurer correspondence, reimbursement tracking, and subrogation proceedings.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDangerousGoods rdf:type rdf:Property ;
    rdfs:label 'Is Dangerous Goods' ;
    rdfs:comment 'Flag indicating whether the cargo subject to the claim is classified as dangerous goods under IMDG Code or ICAO Technical Instructions. Triggers specialized handling, regulatory notification, and enhanced liability assessment procedures.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Date and time when the cargo claim record was last modified. Used for audit trail, change detection, and incremental data pipeline processing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:liabilityConvention rdf:type rdf:Property ;
    rdfs:label 'Liability Convention' ;
    rdfs:comment 'International liability convention governing this claim and determining the applicable liability limits, time bars, and burden of proof. Determined by transport mode and route.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityDetermination rdf:type rdf:Property ;
    rdfs:label 'Liability Determination' ;
    rdfs:comment 'Outcome of the liability investigation indicating the degree to which the carrier is responsible for the loss or damage event. Drives settlement calculation and rejection decisions.' ;
    rdfs:domain ind:CargoClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Limit Amount' ;
    rdfs:comment 'Maximum carrier liability amount applicable to this claim as determined by the governing international convention (e.g., SDR per kg under Warsaw-Montreal, SDR per package under Hague-Visby, SDR per kg under CMR). Used to cap the approved settlement.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originCountryCode rdf:type rdf:Property ;
    rdfs:label 'Origin Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the shipment\'s origin country. Used for jurisdictional analysis, cross-border claim routing, and trade compliance reporting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Registration Timestamp' ;
    rdfs:comment 'Date and time when the cargo claim was formally registered in the claims management system. Marks the start of the claim lifecycle and SLA clock. Aligns with RECORD_AUDIT_CREATED category.' ;
    rdfs:domain ind:CargoClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Narrative explanation for the rejection of the cargo claim, including the specific convention article or policy clause invoked. Populated when claim_status is \'rejected\'. Required for formal rejection correspondence to the claimant.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Amount' ;
    rdfs:comment 'Final net monetary amount paid or to be paid to the claimant after applying approved_amount minus deductible_amount and any recoveries. Represents the actual financial outflow for this claim.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'Date on which the claim settlement payment was made or the claim was formally closed. Used for financial reserve release, P&L recognition, and SLA performance measurement.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subrogationRecoveryAmount rdf:type rdf:Property ;
    rdfs:label 'Subrogation Recovery Amount' ;
    rdfs:comment 'Monetary amount recovered through subrogation proceedings from the liable third party. Reduces the net financial impact of the claim on the carrier or insurer.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subrogationStatus rdf:type rdf:Property ;
    rdfs:label 'Subrogation Status' ;
    rdfs:comment 'Status of the subrogation process whereby the insurer or carrier pursues recovery from a liable third party (e.g., sub-carrier, port operator, customs authority) after settling the claim.' ;
    rdfs:domain ind:CargoClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyDate rdf:type rdf:Property ;
    rdfs:label 'Survey Date' ;
    rdfs:comment 'Date on which the cargo survey was conducted by the appointed surveyor. Used to validate timeliness of damage assessment relative to incident date and convention time bars.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surveyReportNumber rdf:type rdf:Property ;
    rdfs:label 'Survey Report Number' ;
    rdfs:comment 'Reference number of the independent cargo survey report documenting the extent of loss or damage. Issued by a licensed cargo surveyor and forms the evidentiary basis for liability determination.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeBarDate rdf:type rdf:Property ;
    rdfs:label 'Time Bar Date' ;
    rdfs:comment 'Statutory deadline by which legal action must be commenced under the applicable liability convention. After this date the claim is time-barred. Calculated from incident_date per convention rules (e.g., 2 years under Warsaw-Montreal, 1 year under Hague-Visby, 1 year under CMR).' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transportMode rdf:type rdf:Property ;
    rdfs:label 'Transport Mode' ;
    rdfs:comment 'Mode of transport under which the cargo loss or damage event occurred. Determines the applicable international liability convention (Warsaw-Montreal for air, Hague-Visby for ocean, CMR for road, CIM for rail).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimEventId rdf:type rdf:Property ;
    rdfs:label 'Claim Event Id' ;
    rdfs:comment 'Unique system-generated surrogate identifier for the cargo loss or damage event record. Primary key for the claim_event data product.' ;
    rdfs:domain ind:ClaimEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cargoSurveyId rdf:type rdf:Property ;
    rdfs:label 'Cargo Survey Id' ;
    rdfs:comment 'Reference to the cargo survey report generated following physical inspection of the damaged or lost cargo. Links to the survey report product for detailed findings, photographs, and surveyor recommendations.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CargoSurvey .

ind:contactId rdf:type rdf:Property ;
    rdfs:label 'Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: Claim events are reported by specific customer contacts. Enables notification routing, escalation tracking, and contact-level claim activity analysis. Critical for customer service and SLA compliance ' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:freightCarrierAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Freight Carrier Assignment Id' ;
    rdfs:comment 'Foreign key linking to freight.freight_carrier_assignment. Business justification: Claim events trigger carrier notification obligations under CMR/Hague-Visby rules. Direct reference to the carrier assignment identifies which carrier must be notified within statutory time limits, su' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightCarrierAssignment .

ind:fulfillmentCenterId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Center Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.center. Business justification: Incident location tracking - claim events occurring at specific fulfillment centers (warehouse damage, loading accidents, inventory shrinkage, equipment failures). Facility management analyzes center-' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Center .

ind:incidentId rdf:type rdf:Property ;
    rdfs:label 'Incident Id' ;
    rdfs:comment 'Foreign key linking to fleet.incident. Business justification: Claim events are triggered by fleet incidents (accidents, theft, damage). The claim event log must reference the originating incident for investigation traceability, regulatory reporting (DOT), and SL' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Incident .

ind:tplProviderId rdf:type rdf:Property ;
    rdfs:label 'Tpl Provider Id' ;
    rdfs:comment 'Foreign key linking to network.tpl_provider. Business justification: Third-party logistics providers handle cargo where damage/loss occurs; claims management requires tracking which 3PL was responsible for custody at incident time. Essential for 3PL liability determina' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TplProvider .

ind:affectedPieces rdf:type rdf:Property ;
    rdfs:label 'Affected Pieces' ;
    rdfs:comment 'Number of pieces, packages, or units confirmed as lost, damaged, short-shipped, or contaminated in the incident. Derived from initial notification; may be revised following cargo survey. Used for shortage and partial loss liability calculations.' ;
    rdfs:domain ind:ClaimEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cargoDescription rdf:type rdf:Property ;
    rdfs:label 'Cargo Description' ;
    rdfs:comment 'Textual description of the cargo involved in the incident as declared on the transport document. Includes commodity type, packaging, and any special handling designations. Used for survey instructions and liability limit calculations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'System timestamp when the claim event record was first created in the data platform. Used for audit trail and data lineage. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:declaredCargoValue rdf:type rdf:Property ;
    rdfs:label 'Declared Cargo Value' ;
    rdfs:comment 'Declared commercial value of the cargo as stated on the transport document or commercial invoice at the time of shipment. Forms the basis for liability limit calculations and insurer reserve setting. Customer-specific financial data.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:declaredCargoValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Declared Cargo Value Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the declared cargo value. Required for multi-currency liability calculations and insurer correspondence in cross-border claims.' ;
    rdfs:domain ind:ClaimEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCountry rdf:type rdf:Property ;
    rdfs:label 'Destination Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the intended shipment destination at the time of the incident. Used for jurisdictional liability determination and cross-border regulatory reporting.' ;
    rdfs:domain ind:ClaimEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dgClass rdf:type rdf:Property ;
    rdfs:label 'Dg Class' ;
    rdfs:comment 'IMDG/ICAO dangerous goods hazard class and division for the cargo involved in the incident (e.g., Class 1 Explosives, Class 3 Flammable Liquids, Class 6.1 Toxic Substances). Null if is_dangerous_goods is False. Drives emergency response and regulatory notification requirements.' ;
    rdfs:domain ind:ClaimEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current lifecycle state of the cargo incident event. Drives workflow routing from initial registration through survey, liability determination, claim generation, and closure. [ENUM-REF-CANDIDATE: registered|under_survey|liability_assessed|claim_raised|closed|withdrawn — promote to reference product if additional states are required]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Classification of the nature of the cargo incident. Determines the applicable liability framework, survey methodology, and settlement calculation approach. Loss = total non-delivery; Damage = physical harm to cargo; Shortage = partial non-delivery; Delay = late delivery beyond SLA; Contamination = cargo quality compromise; Dangerous Goods Incident = IMDG/ICAO DG event.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightVoyageNumber rdf:type rdf:Property ;
    rdfs:label 'Flight Voyage Number' ;
    rdfs:comment 'Flight number (air) or voyage number (ocean) of the specific service on which the cargo was carried at the time of the incident. Used for incident investigation, carrier correspondence, and regulatory reporting to IATA or IMO.' ;
    rdfs:domain ind:ClaimEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Kg' ;
    rdfs:comment 'Total gross weight of the cargo consignment involved in the incident, expressed in kilograms. Used for weight-based liability limit calculations under IATA Warsaw-Montreal Convention (SDR per kg) and CMR Convention.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hawbNumber rdf:type rdf:Property ;
    rdfs:label 'Hawb Number' ;
    rdfs:comment 'House Air Waybill number issued by the freight forwarder or NVOCC for the specific consignment involved in the incident. Distinct from the Master AWB (MAWB) issued by the airline. Used for HAWB-level liability claims in consolidated air shipments.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hblNumber rdf:type rdf:Property ;
    rdfs:label 'Hbl Number' ;
    rdfs:comment 'House Bill of Lading number issued by the freight forwarder or NVOCC for the specific consignment involved in the ocean freight incident. Distinct from the Master Bill of Lading (MBL). Used for HBL-level liability claims in consolidated ocean shipments.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsCode rdf:type rdf:Property ;
    rdfs:label 'Hs Code' ;
    rdfs:comment 'World Customs Organization Harmonized System commodity classification code for the cargo involved in the incident. Used for customs valuation, trade compliance reporting, and determining applicable duty drawback on lost or damaged goods.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentCauseCode rdf:type rdf:Property ;
    rdfs:label 'Incident Cause Code' ;
    rdfs:comment 'Standardized code classifying the root cause of the cargo incident (e.g., mishandling, weather, theft, fire, flooding, collision, improper packaging, documentation error). Used for root cause analysis, carrier performance management, and insurer reporting. [ENUM-REF-CANDIDATE: mishandling|weather|theft|fire|flooding|collision|improper_packaging|documentation_error|contamination|unknown — promote to reference product]' ;
    rdfs:domain ind:ClaimEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentCircumstances rdf:type rdf:Property ;
    rdfs:label 'Incident Circumstances' ;
    rdfs:comment 'Free-text narrative describing the circumstances of the cargo incident as reported by the notifying party. Captures initial factual account used for survey instructions, insurer notification, and liability investigation. Sourced from Salesforce CRM case notes or direct claimant notification.' ;
    rdfs:domain ind:ClaimEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentLocationCountry rdf:type rdf:Property ;
    rdfs:label 'Incident Location Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the cargo incident occurred or was discovered. Used for jurisdictional liability determination and regulatory reporting to national transport authorities.' ;
    rdfs:domain ind:ClaimEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentLocationName rdf:type rdf:Property ;
    rdfs:label 'Incident Location Name' ;
    rdfs:comment 'Descriptive name of the specific location where the cargo incident occurred, such as port name, airport code, warehouse facility name, road segment, or rail terminal. Provides operational context for survey dispatch and liability assessment.' ;
    rdfs:domain ind:ClaimEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentLocationType rdf:type rdf:Property ;
    rdfs:label 'Incident Location Type' ;
    rdfs:comment 'Classification of the type of location where the cargo incident occurred. Determines survey access procedures and applicable handling standards. CFS = Container Freight Station; ICD = Inland Container Depot. [ENUM-REF-CANDIDATE: port|airport|warehouse|road|rail_terminal|cfs|icd|customer_premises — promote to reference product if additional types are required]' ;
    rdfs:domain ind:ClaimEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Incident Timestamp' ;
    rdfs:comment 'Date and time at which the cargo loss, damage, shortage, delay, contamination, or dangerous goods incident occurred or was first observed. Principal real-world event time used for liability determination and convention time-bar calculations. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ClaimEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:incotermsCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Code' ;
    rdfs:comment 'International Commercial Terms (Incoterms) applicable to the shipment at the time of the incident. Determines the point of risk transfer between seller and buyer, which is critical for establishing which party bears the loss and has insurable interest. ICC Incoterms 2020. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insurerNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Insurer Notification Timestamp' ;
    rdfs:comment 'Date and time at which the cargo insurer was formally notified of the incident. Used to verify compliance with policy notification time requirements and to track insurer response timelines. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ClaimEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:insurerNotified rdf:type rdf:Property ;
    rdfs:label 'Insurer Notified' ;
    rdfs:comment 'Indicates whether the cargo insurer has been formally notified of this incident. Mandatory for incidents exceeding the insurer notification threshold. Tracks compliance with policy notification obligations.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liabilityLimitSdr rdf:type rdf:Property ;
    rdfs:label 'Liability Limit Sdr' ;
    rdfs:comment 'Calculated maximum carrier liability for this incident expressed in IMF Special Drawing Rights (SDR), derived from the applicable convention limit and cargo weight or package count. Used as the ceiling for settlement calculations and insurer reserve setting.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfPieces rdf:type rdf:Property ;
    rdfs:label 'Number Of Pieces' ;
    rdfs:comment 'Total number of individual pieces, packages, or units in the consignment involved in the incident. Used to quantify shortage claims and assess the scope of damage surveys.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originCountry rdf:type rdf:Property ;
    rdfs:label 'Origin Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the shipment origin at the time of the incident. Used for jurisdictional liability determination and cross-border regulatory reporting.' ;
    rdfs:domain ind:ClaimEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned to the cargo incident event at the time of registration. Used in insurer correspondence, survey reports, and claimant communications. Format: CE-{YYYY}-{8-digit sequence}.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reported Timestamp' ;
    rdfs:comment 'Date and time at which the cargo incident was formally reported to Transport Shipping by the claimant, consignee, or shipper. Used to calculate notification compliance against convention time-bar requirements. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ClaimEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Operational system of record from which the claim event was originated or first captured. Supports data lineage tracking and reconciliation between source systems. Salesforce CRM is the primary source for customer-reported incidents; FourKites for visibility-triggered exceptions.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyRequired rdf:type rdf:Property ;
    rdfs:label 'Survey Required' ;
    rdfs:comment 'Indicates whether a physical cargo survey by an independent surveyor or loss adjuster is required for this incident. Determined by incident type, declared value threshold, and insurer requirements. Triggers survey dispatch workflow.' ;
    rdfs:domain ind:ClaimEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unNumber rdf:type rdf:Property ;
    rdfs:label 'Un Number' ;
    rdfs:comment 'United Nations dangerous goods identification number for the hazardous substance involved in the incident. Mandatory for IMDG and ICAO DG incident reporting. Null if is_dangerous_goods is False. Format: UN followed by 4-digit number (e.g., UN1203).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'System timestamp when the claim event record was last modified. Supports change tracking and audit compliance. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:volumeCbm rdf:type rdf:Property ;
    rdfs:label 'Volume Cbm' ;
    rdfs:comment 'Total volume of the cargo consignment involved in the incident, expressed in cubic metres (CBM). Used for volumetric assessment of damage extent and DIM weight calculations for air freight liability.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surveyAgentId rdf:type rdf:Property ;
    rdfs:label 'Survey Agent Id' ;
    rdfs:comment 'Foreign key linking to network.agent. Business justification: Cargo surveys are commissioned through local agents at incident locations for independent damage assessment. Standard practice in international logistics claims requires tracking which agent conducted' ;
    rdfs:domain ind:CargoSurvey ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:cargoVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Cargo Volume Cbm' ;
    rdfs:comment 'Volume of the cargo under survey in cubic meters (CBM). Used for dimensional weight calculations, container utilization assessment, and loss quantification.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoWeightKg rdf:type rdf:Property ;
    rdfs:label 'Cargo Weight Kg' ;
    rdfs:comment 'Gross weight of the cargo under survey in kilograms as declared on the transport document. Used as basis for liability limit calculations under applicable conventions (e.g., SDR per kg under Montreal Convention).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Commissioned Timestamp' ;
    rdfs:comment 'Date and time when the cargo survey was formally commissioned and the surveyor was appointed. Used for SLA tracking and claim timeline management.' ;
    rdfs:domain ind:CargoSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:completedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completed Timestamp' ;
    rdfs:comment 'Date and time when the cargo survey report was formally completed and submitted. Used for turnaround time measurement and claim settlement scheduling.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:damageCauseCode rdf:type rdf:Property ;
    rdfs:label 'Damage Cause Code' ;
    rdfs:comment 'Standardized code identifying the root cause of the cargo damage or loss as determined by the surveyor (e.g., mishandling, water ingress, temperature excursion, collision, theft). [ENUM-REF-CANDIDATE: mishandling|water_ingress|temperature_excursion|collision|theft|contamination|improper_packing|force_majeure — promote to reference product]' ;
    rdfs:domain ind:CargoSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageCauseNarrative rdf:type rdf:Property ;
    rdfs:label 'Damage Cause Narrative' ;
    rdfs:comment 'Free-text narrative explanation of the probable cause of the cargo damage or loss as assessed by the surveyor, including contributing factors and chain of events.' ;
    rdfs:domain ind:CargoSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageDescription rdf:type rdf:Property ;
    rdfs:label 'Damage Description' ;
    rdfs:comment 'Detailed narrative description of the nature, extent, and visible characteristics of the cargo damage or loss as observed and documented by the surveyor during inspection.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damagedPiecesCount rdf:type rdf:Property ;
    rdfs:label 'Damaged Pieces Count' ;
    rdfs:comment 'Number of individual pieces or packages found to be damaged during the survey inspection. Used to calculate partial loss ratio and settlement amount.' ;
    rdfs:domain ind:CargoSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedLossValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Loss Value' ;
    rdfs:comment 'Surveyor\'s estimated monetary value of the cargo loss or damage based on inspection findings, market value assessment, and applicable depreciation. Primary input to claim settlement calculation.' ;
    rdfs:domain ind:CargoSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insurerReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Insurer Reference Number' ;
    rdfs:comment 'Reference number assigned by the cargo insurer to this survey report for their internal claim file. Used for insurer correspondence and settlement coordination.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jointSurveyIndicator rdf:type rdf:Property ;
    rdfs:label 'Joint Survey Indicator' ;
    rdfs:comment 'Indicates whether the survey was conducted jointly with the carrier, insurer, or other interested party. Joint surveys carry greater evidentiary weight in liability disputes.' ;
    rdfs:domain ind:CargoSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liabilityAttribution rdf:type rdf:Property ;
    rdfs:label 'Liability Attribution' ;
    rdfs:comment 'Surveyor\'s determination of the party to whom liability for the cargo loss or damage is attributed. Directly informs claim settlement calculations and subrogation proceedings.' ;
    rdfs:domain ind:CargoSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:missingPiecesCount rdf:type rdf:Property ;
    rdfs:label 'Missing Pieces Count' ;
    rdfs:comment 'Number of individual pieces or packages confirmed missing or unaccounted for during the survey. Used to quantify shortage claims and establish carrier liability for non-delivery.' ;
    rdfs:domain ind:CargoSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:photographicEvidenceIndicator rdf:type rdf:Property ;
    rdfs:label 'Photographic Evidence Indicator' ;
    rdfs:comment 'Indicates whether photographic or video evidence of the cargo damage was captured and attached to the survey report. Affects evidentiary strength of the claim.' ;
    rdfs:domain ind:CargoSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Report Submission Date' ;
    rdfs:comment 'Date on which the completed survey report was formally submitted to the claims department or insurer. Used for SLA compliance tracking and claim filing deadline management.' ;
    rdfs:domain ind:CargoSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salvageValue rdf:type rdf:Property ;
    rdfs:label 'Salvage Value' ;
    rdfs:comment 'Estimated residual or salvage value of the damaged cargo that can be recovered or sold. Deducted from estimated loss value to determine net claim settlement amount.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subrogationApplicable rdf:type rdf:Property ;
    rdfs:label 'Subrogation Applicable' ;
    rdfs:comment 'Indicates whether the survey findings support a subrogation action against a liable third party. Triggers the subrogation process in the claims management workflow.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surveyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Survey Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the declared cargo value, estimated loss value, and salvage value are expressed in this survey report.' ;
    rdfs:domain ind:CargoSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyLocationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Survey Location Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the cargo survey was conducted. Used for jurisdictional liability determination and regulatory reporting.' ;
    rdfs:domain ind:CargoSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyLocationName rdf:type rdf:Property ;
    rdfs:label 'Survey Location Name' ;
    rdfs:comment 'Name of the facility, port, warehouse, or location where the cargo survey inspection was physically conducted (e.g., port terminal name, warehouse address, CFS name).' ;
    rdfs:domain ind:CargoSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyMethodology rdf:type rdf:Property ;
    rdfs:label 'Survey Methodology' ;
    rdfs:comment 'Method employed by the surveyor to assess the cargo loss or damage. Determines the evidentiary weight of the survey findings in claim settlement.' ;
    rdfs:domain ind:CargoSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Survey Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned to the cargo survey report, used in insurer correspondence and claim settlement documentation.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyStatus rdf:type rdf:Property ;
    rdfs:label 'Survey Status' ;
    rdfs:comment 'Current lifecycle state of the cargo survey report. Tracks progression from initial commissioning through completion or cancellation.' ;
    rdfs:domain ind:CargoSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyType rdf:type rdf:Property ;
    rdfs:label 'Survey Type' ;
    rdfs:comment 'Classification of the cargo survey by the nature of the incident being assessed. Determines the survey methodology and applicable liability framework. [ENUM-REF-CANDIDATE: loss|damage|shortage|delay|contamination|dangerous_goods|theft|misdelivery — promote to reference product]' ;
    rdfs:domain ind:CargoSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyorRecommendations rdf:type rdf:Property ;
    rdfs:label 'Surveyor Recommendations' ;
    rdfs:comment 'Surveyor\'s formal recommendations for cargo disposal, remediation, repair, or preventive measures to avoid recurrence. Used in claim settlement negotiations and operational improvement.' ;
    rdfs:domain ind:CargoSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityDeterminationId rdf:type rdf:Property ;
    rdfs:label 'Liability Determination Id' ;
    rdfs:comment 'Unique surrogate identifier for the liability determination record. Primary key for this transactional entity.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LiabilityDetermination .

ind:claimPartyId rdf:type rdf:Property ;
    rdfs:label 'Claim Party Id' ;
    rdfs:comment 'Reference to the party (shipper, consignee, or insurer) who filed the cargo claim and against whom or in whose favour the liability determination is made.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClaimParty .

ind:freightLegId rdf:type rdf:Property ;
    rdfs:label 'Freight Leg Id' ;
    rdfs:comment 'Foreign key linking to freight.freight_leg. Business justification: Liability determination is fundamentally a per-leg analysis — which carrier had custody when the loss occurred. Direct FK to freight_leg enables automated liability convention selection (CMR for road,' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightLeg .

ind:laneId rdf:type rdf:Property ;
    rdfs:label 'Lane Id' ;
    rdfs:comment 'Foreign key linking to route.lane. Business justification: Liability limits and applicable conventions (CMR, Warsaw, Hague-Visby) vary by lane characteristics (cross-border, transport mode, incoterms). Determinations reference the lane to apply correct legal ' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lane .

ind:liableAgentId rdf:type rdf:Property ;
    rdfs:label 'Liable Agent Id' ;
    rdfs:comment 'Foreign key linking to network.agent. Business justification: In multi-party logistics chains, liability may be attributed to agents (customs brokers, freight forwarders, handling agents). Essential for agent liability allocation, subrogation recovery, and agent' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:maintenanceOrderId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Order Id' ;
    rdfs:comment 'Foreign key linking to fleet.maintenance_order. Business justification: When poor or deferred maintenance caused cargo damage, the liability determination must reference the specific maintenance order (fault codes, work performed, post-maintenance status). This is a stand' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenanceOrder .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Timestamp when the liability determination was formally approved by the authorised approver. Marks the transition from under_review to approved status.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cargoDeclaredValue rdf:type rdf:Property ;
    rdfs:label 'Cargo Declared Value' ;
    rdfs:comment 'The value of the cargo as declared by the shipper on the Air Waybill (AWB) or Bill of Lading (BOL). Used when ad valorem liability basis applies or when declared value exceeds the convention limit.' ;
    rdfs:domain ind:LiabilityDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoDeclaredValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Cargo Declared Value Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the cargo declared value. Required for multi-currency settlement and insurer correspondence.' ;
    rdfs:domain ind:LiabilityDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierLiabilityPct rdf:type rdf:Property ;
    rdfs:label 'Carrier Liability Pct' ;
    rdfs:comment 'The percentage of total loss or damage attributed to the carrier\'s fault or negligence, expressed as a value between 0.00 and 100.00. Used in proportional settlement calculations.' ;
    rdfs:domain ind:LiabilityDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consigneeLiabilityPct rdf:type rdf:Property ;
    rdfs:label 'Consignee Liability Pct' ;
    rdfs:comment 'The percentage of total loss or damage attributed to the consignee\'s contributory negligence or fault (e.g., failure to mitigate, improper handling at destination). Complements carrier and shipper liability percentages.' ;
    rdfs:domain ind:LiabilityDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contributoryNegligenceFlag rdf:type rdf:Property ;
    rdfs:label 'Contributory Negligence Flag' ;
    rdfs:comment 'Indicates whether contributory negligence by the shipper or consignee has been identified and factored into the liability determination, reducing the carrier\'s proportional liability.' ;
    rdfs:domain ind:LiabilityDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dangerousGoodsFlag rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Flag' ;
    rdfs:comment 'Indicates whether the cargo involved in the claim is classified as dangerous goods, triggering additional liability provisions under IMDG Code or ICAO Technical Instructions.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:delayHours rdf:type rdf:Property ;
    rdfs:label 'Delay Hours' ;
    rdfs:comment 'Number of hours by which the shipment was delayed beyond the agreed or scheduled delivery time. Applicable for delay claims under Montreal Convention Article 19 and CMR Convention Article 23(5).' ;
    rdfs:domain ind:LiabilityDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:determinationDate rdf:type rdf:Property ;
    rdfs:label 'Determination Date' ;
    rdfs:comment 'The business event date on which the formal liability assessment was completed and the determination was issued. Distinct from the record creation timestamp.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:determinationNumber rdf:type rdf:Property ;
    rdfs:label 'Determination Number' ;
    rdfs:comment 'Externally-known business reference number for this liability determination, used in insurer correspondence, legal filings, and settlement documentation. Format: LD-YYYY-NNNNNN.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:determinationStatus rdf:type rdf:Property ;
    rdfs:label 'Determination Status' ;
    rdfs:comment 'Current lifecycle state of the liability determination record. Drives workflow routing for settlement calculation and insurer correspondence.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeRaisedDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Raised Date' ;
    rdfs:comment 'Date on which the formal dispute against this liability determination was raised. Used to track statutory limitation periods under applicable conventions.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Narrative description of the grounds on which the liability determination has been disputed by the claimant or carrier. Populated when determination_status is \'disputed\'.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalBasisDescription rdf:type rdf:Property ;
    rdfs:label 'Legal Basis Description' ;
    rdfs:comment 'Narrative description of the legal and factual basis for the liability determination, including specific convention articles, exclusions applied (e.g., act of God, inherent vice, shipper fault), and supporting evidence references.' ;
    rdfs:domain ind:LiabilityDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityBasis rdf:type rdf:Property ;
    rdfs:label 'Liability Basis' ;
    rdfs:comment 'The unit basis on which the carrier liability limit is calculated — per kilogram, per package, per unit, or based on declared/ad valorem value. Drives the settlement calculation formula.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityExclusionType rdf:type rdf:Property ;
    rdfs:label 'Liability Exclusion Type' ;
    rdfs:comment 'Category of liability exclusion applied to reduce or eliminate carrier liability under the applicable convention. Drives the legal basis narrative and settlement outcome.' ;
    rdfs:domain ind:LiabilityDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityLimitCurrency rdf:type rdf:Property ;
    rdfs:label 'Liability Limit Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the liability limit per unit is expressed. Typically SDR (Special Drawing Rights) for international conventions, or USD for COGSA.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityLimitPerUnit rdf:type rdf:Property ;
    rdfs:label 'Liability Limit Per Unit' ;
    rdfs:comment 'The maximum carrier liability amount per unit (kg or package) as prescribed by the applicable convention. For Montreal Convention air freight: 22 SDR/kg. For Hague-Visby ocean: 666.67 SDR/package or 2 SDR/kg. Used in settlement calculation.' ;
    rdfs:domain ind:LiabilityDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:limitationPeriodExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Limitation Period Expiry Date' ;
    rdfs:comment 'The date on which the statutory limitation period for legal action expires under the applicable convention. Montreal Convention: 2 years; CMR: 1 year (3 for wilful misconduct); Hague-Visby: 1 year.' ;
    rdfs:domain ind:LiabilityDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumLiabilityAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Liability Amount' ;
    rdfs:comment 'The calculated maximum monetary amount the carrier is liable for under the applicable convention, derived from liability_limit_per_unit multiplied by the applicable weight or package count. Cap for settlement calculation.' ;
    rdfs:domain ind:LiabilityDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumLiabilityCurrency rdf:type rdf:Property ;
    rdfs:label 'Maximum Liability Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the maximum liability amount is expressed for settlement purposes.' ;
    rdfs:domain ind:LiabilityDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negligenceDescription rdf:type rdf:Property ;
    rdfs:label 'Negligence Description' ;
    rdfs:comment 'Narrative description of the contributory negligence factors identified for the shipper or consignee, including evidence basis (e.g., improper packaging, misdeclared weight, inadequate labelling).' ;
    rdfs:domain ind:LiabilityDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageCount rdf:type rdf:Property ;
    rdfs:label 'Package Count' ;
    rdfs:comment 'Number of packages or units in the shipment as declared on the transport document. Used to calculate per-package liability limits under Hague-Visby Rules and COGSA.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reserveAmount rdf:type rdf:Property ;
    rdfs:label 'Reserve Amount' ;
    rdfs:comment 'The financial reserve amount set aside in the general ledger for this liability determination, representing the estimated carrier liability exposure. Feeds SAP S/4HANA Finance reserve accounting.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reserveCurrency rdf:type rdf:Property ;
    rdfs:label 'Reserve Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the claims reserve amount. Required for multi-currency financial reporting and IFRS compliance.' ;
    rdfs:domain ind:LiabilityDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementRecommendationAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Recommendation Amount' ;
    rdfs:comment 'The recommended monetary settlement amount derived from this liability determination, factoring in the maximum liability cap, carrier liability percentage, and contributory negligence. Input to the settlement calculation process.' ;
    rdfs:domain ind:LiabilityDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementRecommendationCurrency rdf:type rdf:Property ;
    rdfs:label 'Settlement Recommendation Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the settlement recommendation amount.' ;
    rdfs:domain ind:LiabilityDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperLiabilityPct rdf:type rdf:Property ;
    rdfs:label 'Shipper Liability Pct' ;
    rdfs:comment 'The percentage of total loss or damage attributed to the shipper\'s contributory negligence or fault (e.g., improper packaging, misdeclaration). Complements carrier_liability_pct.' ;
    rdfs:domain ind:LiabilityDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subrogationAmount rdf:type rdf:Property ;
    rdfs:label 'Subrogation Amount' ;
    rdfs:comment 'The monetary amount the insurer is seeking to recover from the carrier through subrogation after having settled the claim with the insured party.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subrogationFlag rdf:type rdf:Property ;
    rdfs:label 'Subrogation Flag' ;
    rdfs:comment 'Indicates whether the insurer has exercised or intends to exercise subrogation rights against the carrier following settlement of the cargo claim.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:settlementId rdf:type rdf:Property ;
    rdfs:label 'Settlement Id' ;
    rdfs:comment 'Unique surrogate identifier for the claim settlement record in the Transport Shipping lakehouse. Primary key for this transactional entity.' ;
    rdfs:domain ind:Settlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agentId rdf:type rdf:Property ;
    rdfs:label 'Agent Id' ;
    rdfs:comment 'Foreign key linking to network.agent. Business justification: Settlements may be paid to or recovered from agents in the logistics chain when agent liability is established. Financial settlement tracking with agents for accounts payable/receivable, subrogation r' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:creditNoteId rdf:type rdf:Property ;
    rdfs:label 'Credit Note Id' ;
    rdfs:comment 'Foreign key linking to billing.credit_note. Business justification: Claim settlements trigger credit notes issued to customers for financial reconciliation. Real business process: when carrier settles cargo claim, finance issues credit note to customer account. Existi' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditNote .

ind:reserveId rdf:type rdf:Property ;
    rdfs:label 'Reserve Id' ;
    rdfs:comment 'Foreign key linking to claim.reserve. Business justification: When a cargo claim is settled, the financial reserve established for that claim is released or reduced. The settlement record should reference the reserve it is releasing to enable reserve reconciliat' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Reserve .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'Date on which the claimant formally accepted the settlement offer. Triggers payment processing and reserve release in SAP S/4HANA Finance.' ;
    rdfs:domain ind:Settlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Acceptance Status' ;
    rdfs:comment 'Indicates whether the claimant has formally accepted the settlement offer. Pending means offer made but not yet responded to; accepted means claimant signed off; disputed means claimant contests the amount; withdrawn means claimant retracted acceptance.' ;
    rdfs:domain ind:Settlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualSettlementDays rdf:type rdf:Property ;
    rdfs:label 'Actual Settlement Days' ;
    rdfs:comment 'Actual number of calendar days taken to settle the claim from claim registration date to settlement_date. Used to measure SLA compliance and KPI performance against sla_settlement_target_days.' ;
    rdfs:domain ind:Settlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'Gross base amount agreed to be paid to the claimant as settlement for the cargo claim, expressed in the settlement currency. This is the pre-deduction gross figure before any excess, deductible, or recovery offsets. Part of the MONETARY_TRIPLET for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date on which the settlement was internally approved by the authorized claims manager or finance controller. Required for SOX internal controls and audit trail.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currency rdf:type rdf:Property ;
    rdfs:label 'Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the settlement amount is denominated and paid (e.g., USD, EUR, GBP). Required for multi-currency financial reporting and FX conversion. Part of the MONETARY_TRIPLET.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'Foreign exchange rate applied to convert the settlement amount from the settlement currency to the company\'s functional reporting currency at the time of settlement. Required for multi-currency financial consolidation under IFRS.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Amount' ;
    rdfs:comment 'Net settlement amount converted to the company\'s functional reporting currency using the exchange rate at settlement date. Used for financial consolidation, P&L reporting, and reserve release accounting in SAP S/4HANA Finance.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insurerCorrespondenceReference rdf:type rdf:Property ;
    rdfs:label 'Insurer Correspondence Reference' ;
    rdfs:comment 'Reference number or file number assigned by the cargo insurer for their internal tracking of this claim settlement. Used for insurer correspondence, recovery claims, and co-insurance coordination.' ;
    rdfs:domain ind:Settlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insurerRecoveryAmount rdf:type rdf:Property ;
    rdfs:label 'Insurer Recovery Amount' ;
    rdfs:comment 'Amount recovered from the cargo insurer or underwriter as part of the settlement, reducing the net cost to Transport Shipping. Relevant for subrogation processes and insurer correspondence tracking.' ;
    rdfs:domain ind:Settlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the settlement record. Supports audit trail, change tracking, and incremental data pipeline processing. Satisfies the RECORD_AUDIT_UPDATED category for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:netSettlementAmount rdf:type rdf:Property ;
    rdfs:label 'Net Settlement Amount' ;
    rdfs:comment 'Final net amount payable to the claimant after deducting the policy excess/deductible from the gross settlement amount. Represents the net total component of the MONETARY_TRIPLET for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field capturing additional context, negotiation notes, special conditions, or remarks relevant to the settlement. Includes basis for ex gratia payments, dispute resolution notes, or partial settlement justification.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'Date on which the settlement payment was actually disbursed to the claimant. May differ from settlement_date (agreement date) due to payment processing lead times. Used for cash flow reporting and SLA measurement.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Method by which the settlement amount is disbursed to the claimant. Bank transfer is the standard for large settlements; credit note offsets against outstanding freight invoices; cheque for legacy or specific jurisdictions.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReference rdf:type rdf:Property ;
    rdfs:label 'Payment Reference' ;
    rdfs:comment 'Bank payment reference, cheque number, or transaction ID from the payment system confirming disbursement of the settlement amount to the claimant. Used for payment reconciliation in SAP S/4HANA Finance AP.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reserveReleaseAmount rdf:type rdf:Property ;
    rdfs:label 'Reserve Release Amount' ;
    rdfs:comment 'Amount of the financial reserve released back to the P&L upon settlement of the claim. Equals the difference between the reserve amount and the net settlement amount. Interfaces with SAP S/4HANA Finance for reserve accounting journal entries.' ;
    rdfs:domain ind:Settlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementNumber rdf:type rdf:Property ;
    rdfs:label 'Settlement Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the settlement transaction. Used in correspondence with claimants, insurers, and finance teams. Satisfies the BUSINESS_IDENTIFIER category for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:Settlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementStatus rdf:type rdf:Property ;
    rdfs:label 'Settlement Status' ;
    rdfs:comment 'Current lifecycle state of the claim settlement workflow. Tracks progression from initial draft through approval, payment, and closure. Satisfies the LIFECYCLE_STATUS category for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementType rdf:type rdf:Property ;
    rdfs:label 'Settlement Type' ;
    rdfs:comment 'Classification of the settlement by nature of resolution. Full settlement closes the claim entirely; partial settlement covers a portion; ex gratia is a goodwill payment without liability admission; subrogation involves insurer recovery; credit note offsets against future billing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaSettlementTargetDays rdf:type rdf:Property ;
    rdfs:label 'Sla Settlement Target Days' ;
    rdfs:comment 'Target number of calendar days within which the claim settlement must be completed from claim registration date, as defined in the applicable SLA or service contract. Used for KPI and OTD performance measurement.' ;
    rdfs:domain ind:Settlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subrogationInitiatedFlag rdf:type rdf:Property ;
    rdfs:label 'Subrogation Initiated Flag' ;
    rdfs:comment 'Indicates whether a subrogation action has been initiated against a third-party carrier, vendor, or responsible party following payment of the settlement to the claimant.' ;
    rdfs:domain ind:Settlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Status History Id' ;
    rdfs:comment 'Unique surrogate identifier for each claim status history record. Primary key of the claim_status_history entity.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsibleAgentId rdf:type rdf:Property ;
    rdfs:label 'Responsible Agent Id' ;
    rdfs:comment 'Foreign key linking to network.agent. Business justification: Status transitions (claim filed, survey completed, settlement offered) may involve agent actions or require agent notifications. Tracks agent responsibility for status changes, agent response times, a' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:awbNumber rdf:type rdf:Property ;
    rdfs:label 'Awb Number' ;
    rdfs:comment 'Air Waybill number associated with the shipment underlying this claim. Denormalized for audit trail completeness and to support regulatory reporting under IATA frameworks without requiring joins to the shipment domain.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bolNumber rdf:type rdf:Property ;
    rdfs:label 'Bol Number' ;
    rdfs:comment 'Bill of Lading number associated with the ocean or road shipment underlying this claim. Denormalized for audit trail completeness and regulatory reporting under IMO and CMR frameworks.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysInPreviousStatus rdf:type rdf:Property ;
    rdfs:label 'Days In Previous Status' ;
    rdfs:comment 'Number of calendar days the claim remained in the from_status_code before transitioning. Calculated at the time of transition and stored for SLA monitoring, aging analysis, and claims processing efficiency KPIs.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:delayClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Delay Claim Flag' ;
    rdfs:comment 'Indicates whether this claim is a delay claim (as opposed to loss or damage), which has distinct liability limits and processing rules under the Warsaw-Montreal Convention and CMR Convention.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicates whether this status transition was triggered by or resulted in an escalation of the claim to a higher authority (e.g., senior claims manager, legal counsel, or executive review). Used for management reporting and SLA breach tracking.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Free-text description of the reason for escalation when escalation_flag is True. Documents the specific circumstances requiring senior review or intervention.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fromStatusCode rdf:type rdf:Property ;
    rdfs:label 'From Status Code' ;
    rdfs:comment 'The claim lifecycle status code immediately before this transition occurred (e.g., REGISTERED, UNDER_INVESTIGATION, SURVEY_COMMISSIONED, LIABILITY_DETERMINED, SETTLEMENT_OFFERED, SETTLED, REJECTED, SUBROGATED, CLOSED, WITHDRAWN). [ENUM-REF-CANDIDATE: REGISTERED|UNDER_INVESTIGATION|SURVEY_COMMISSIONED|LIABILITY_DETERMINED|SETTLEMENT_OFFERED|SETTLED|REJECTED|SUBROGATED|CLOSED|WITHDRAWN — promote to reference product]' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityConventionCode rdf:type rdf:Property ;
    rdfs:label 'Liability Convention Code' ;
    rdfs:comment 'The international liability convention governing this claim at the time of this status transition (e.g., WARSAW_MONTREAL for air freight, CMR for road, HAGUE_VISBY for ocean, CIM for rail). Determines liability limits and procedural requirements.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityDeterminationCode rdf:type rdf:Property ;
    rdfs:label 'Liability Determination Code' ;
    rdfs:comment 'The outcome of the liability assessment at this status transition (FULL_LIABILITY, PARTIAL_LIABILITY, NO_LIABILITY, SHARED_LIABILITY, PENDING). Populated when to_status_code is LIABILITY_DETERMINED. Governs settlement calculation and reserve accounting.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required Flag' ;
    rdfs:comment 'Indicates whether this status transition triggers a mandatory regulatory notification obligation (e.g., dangerous goods incident reporting to IMO/IATA, customs authority notification under C-TPAT or AEO programs). Drives compliance workflow automation.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryNotificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Sent Flag' ;
    rdfs:comment 'Indicates whether the required regulatory notification has been dispatched following this status transition. Used in conjunction with regulatory_notification_required_flag to track compliance obligations and identify outstanding notifications.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsiblePartyName rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Name' ;
    rdfs:comment 'Full name or organizational name of the party responsible for this status transition. Denormalized for audit trail completeness and regulatory reporting without requiring joins.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyType rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Type' ;
    rdfs:comment 'Category of the party responsible for initiating or actioning this status transition (e.g., CLAIMS_HANDLER, SURVEYOR, INSURER, LEGAL_COUNSEL, CUSTOMER, SYSTEM for automated transitions).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the settlement offer amount (e.g., USD, EUR, GBP). Applicable when settlement_offer_amount is populated.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementOfferAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Offer Amount' ;
    rdfs:comment 'The monetary value of the settlement offer made to the claimant at this status transition. Populated when to_status_code is SETTLEMENT_OFFERED. Expressed in the currency defined by settlement_currency_code.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Indicates whether the status transition occurred after the sla_target_resolution_date, constituting an SLA breach. True if the transition_timestamp exceeded the target date; False otherwise. Used for SLA KPI reporting and escalation tracking.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Sla Target Resolution Date' ;
    rdfs:comment 'The contractual or regulatory target date by which the claim must be resolved or advanced to the next status, based on the applicable SLA for this claim type and transport mode. Used for SLA breach monitoring and KPI reporting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Identifies the operational system of record that originated this status transition record (e.g., SALESFORCE_CRM for customer-facing claim cases, SAP_S4HANA for finance-driven transitions, ORACLE_TMS for transport-triggered events, MANUAL for manually entered transitions).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Source System Transaction Reference' ;
    rdfs:comment 'The unique transaction or record identifier from the originating operational system (e.g., Salesforce Case ID, SAP document number) that triggered this status transition. Enables traceability back to the system of record.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subrogationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Subrogation Reference Number' ;
    rdfs:comment 'Reference number assigned to the subrogation recovery action initiated at this status transition. Populated when subrogation_flag is True and to_status_code is SUBROGATED.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toStatusCode rdf:type rdf:Property ;
    rdfs:label 'To Status Code' ;
    rdfs:comment 'The claim lifecycle status code immediately after this transition occurred (e.g., REGISTERED, UNDER_INVESTIGATION, SURVEY_COMMISSIONED, LIABILITY_DETERMINED, SETTLEMENT_OFFERED, SETTLED, REJECTED, SUBROGATED, CLOSED, WITHDRAWN). This is the new current state of the claim following this event. [ENUM-REF-CANDIDATE: REGISTERED|UNDER_INVESTIGATION|SURVEY_COMMISSIONED|LIABILITY_DETERMINED|SETTLEMENT_OFFERED|SETTLED|REJECTED|SUBROGATED|CLOSED|WITHDRAWN — promote to reference product]' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Transition Reason Code' ;
    rdfs:comment 'Standardized reason code explaining why the status transition occurred (e.g., SURVEY_REQUESTED, DOCS_RECEIVED, LIABILITY_ACCEPTED, LIABILITY_DENIED, SETTLEMENT_AGREED, INSURER_DECLINED, SUBROGATION_INITIATED, CLAIMANT_WITHDREW). [ENUM-REF-CANDIDATE: SURVEY_REQUESTED|DOCS_RECEIVED|LIABILITY_ACCEPTED|LIABILITY_DENIED|SETTLEMENT_AGREED|INSURER_DECLINED|SUBROGATION_INITIATED|CLAIMANT_WITHDREW — promote to reference product]' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Transition Reason Description' ;
    rdfs:comment 'Free-text narrative providing additional context or explanation for the status transition, supplementing the structured transition_reason_code. Used by claims handlers to document specific circumstances, exceptions, or instructions.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transition Timestamp' ;
    rdfs:comment 'The exact date and time (with timezone offset) at which the claim status transitioned from the from_status_code to the to_status_code. This is the principal business event time for this history record and is used for SLA monitoring and regulatory audit trails.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:claimDocumentId rdf:type rdf:Property ;
    rdfs:label 'Claim Document Id' ;
    rdfs:comment 'Unique surrogate identifier for each document or formal correspondence record attached to a cargo claim file in the Transport Shipping claims management system.' ;
    rdfs:domain ind:ClaimDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:issuingAgentId rdf:type rdf:Property ;
    rdfs:label 'Issuing Agent Id' ;
    rdfs:comment 'Foreign key linking to network.agent. Business justification: Claim documents (survey reports, damage certificates, delivery receipts) are often issued by or submitted to agents. Standard document workflow in agent-involved claims for document provenance, authen' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:communicationChannel rdf:type rdf:Property ;
    rdfs:label 'Communication Channel' ;
    rdfs:comment 'Channel through which the document was transmitted or received. Captures whether the document arrived via EDI (Electronic Data Interchange), email, carrier portal, postal mail, fax, or API integration. Supports audit trail and SLA measurement.' ;
    rdfs:domain ind:ClaimDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOriginCode rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the document was issued or originated. Relevant for customs declarations, certificates of origin, and cross-border claim regulatory compliance under WCO and trade compliance frameworks.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredValueAmount rdf:type rdf:Property ;
    rdfs:label 'Declared Value Amount' ;
    rdfs:comment 'Monetary value declared on the document (e.g., commercial invoice value, declared cargo value on AWB or BOL). Used as the basis for liability calculation and settlement offer determination under applicable liability conventions.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:declaredValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Declared Value Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the declared value amount on the document (e.g., USD, EUR, GBP). Required for multi-currency claim settlement calculations and financial reporting under IFRS.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:direction rdf:type rdf:Property ;
    rdfs:label 'Direction' ;
    rdfs:comment 'Indicates whether the document was received by Transport Shipping (inbound) or sent by Transport Shipping to an external party (outbound). Distinguishes correspondence flow for insurer SLA compliance and claim file completeness checks.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentCategory rdf:type rdf:Property ;
    rdfs:label 'Document Category' ;
    rdfs:comment 'High-level grouping of the document type for claim file organisation and regulatory compliance reporting. Enables structured retrieval of document sets required by IATA, IMO, and WCO frameworks.' ;
    rdfs:domain ind:ClaimDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The official date printed or stated on the document itself (e.g., invoice date, survey report date, AWB issue date). Distinct from upload or received timestamps; represents the document\'s own declared date for legal and regulatory validity.' ;
    rdfs:domain ind:ClaimDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentDescription rdf:type rdf:Property ;
    rdfs:label 'Document Description' ;
    rdfs:comment 'Free-text description of the document content, purpose, or any relevant notes about the document\'s role in the claim file. Provides context for claim handlers and insurers reviewing the document.' ;
    rdfs:domain ind:ClaimDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'Externally-known unique reference number or identifier assigned to the document (e.g., AWB number, BOL number, invoice number, survey report reference). Serves as the business-facing identifier for the document within the claim file.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentSource rdf:type rdf:Property ;
    rdfs:label 'Document Source' ;
    rdfs:comment 'Originating party or system that provided or generated the document. Identifies whether the document was submitted by the claimant, insurer, carrier, customs authority, independent surveyor, or generated internally. Used for chain-of-custody tracking. [ENUM-REF-CANDIDATE: claimant|insurer|carrier|customs_authority|surveyor|internal|third_party — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClaimDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStatus rdf:type rdf:Property ;
    rdfs:label 'Document Status' ;
    rdfs:comment 'Current lifecycle state of the document within the claim file. Tracks whether the document has been received, reviewed, accepted as valid evidence, rejected, or superseded by a newer version. Drives insurer SLA compliance monitoring.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Classification of the document attached to the claim file. Identifies the nature and purpose of the document within the claims process. [ENUM-REF-CANDIDATE: awb|bol|commercial_invoice|packing_list|survey_report|photo_evidence|epod|customs_declaration|dangerous_goods_manifest|insurer_correspondence|demand_letter|settlement_offer|claim_form|certificate_of_origin|delivery_receipt — promote to reference product]' ;
    rdfs:domain ind:ClaimDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'File format or MIME type of the stored document. Determines rendering capability and archival requirements. EDI and XML formats indicate structured electronic documents; PDF/image formats indicate scanned or photographed evidence. [ENUM-REF-CANDIDATE: pdf|jpeg|png|tiff|xlsx|docx|xml|edi — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileName rdf:type rdf:Property ;
    rdfs:label 'File Name' ;
    rdfs:comment 'Original file name of the uploaded document as provided by the submitting party. Preserves the source file identity for audit trail and document retrieval purposes.' ;
    rdfs:domain ind:ClaimDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeKb rdf:type rdf:Property ;
    rdfs:label 'File Size Kb' ;
    rdfs:comment 'Size of the document file in kilobytes. Used for storage management, upload validation, and ensuring document completeness (e.g., detecting empty or corrupt uploads).' ;
    rdfs:domain ind:ClaimDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isLatestVersion rdf:type rdf:Property ;
    rdfs:label 'Is Latest Version' ;
    rdfs:comment 'Indicates whether this document record represents the most current version of the document. Set to True for the active version and False for superseded versions. Prevents use of outdated documents in claim settlement calculations.' ;
    rdfs:domain ind:ClaimDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMandatory rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory' ;
    rdfs:comment 'Indicates whether this document type is mandatory for the claim file to be considered complete under applicable regulatory or insurer requirements (e.g., AWB is mandatory for air claims under IATA, BOL for ocean claims under IMO). Drives claim file completeness validation.' ;
    rdfs:domain ind:ClaimDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'Name of the authority, organisation, or party that officially issued or certified the document (e.g., customs authority, classification society, independent surveyor firm, insurer). Validates document authenticity for liability determination.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'ISO 639-1 two-letter language code of the document (e.g., EN, FR, DE, ZH). Determines whether translation is required for regulatory submission or insurer review. Relevant for cross-border claims under WCO and customs authority requirements.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pageCount rdf:type rdf:Property ;
    rdfs:label 'Page Count' ;
    rdfs:comment 'Total number of pages in the document. Used to verify document completeness and detect partial uploads. Particularly relevant for multi-page survey reports, customs declarations, and dangerous goods manifests.' ;
    rdfs:domain ind:ClaimDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'Date and time when the document was received by Transport Shipping. Applicable for inbound documents. Critical for calculating claim notification deadlines and insurer SLA compliance under IATA Warsaw-Montreal Convention and CMR Convention.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'Deadline by which a response to this document is required, based on applicable SLA or regulatory timeframe (e.g., insurer acknowledgement deadline, claimant response window under IATA or CMR Convention). Drives SLA compliance monitoring and escalation workflows.' ;
    rdfs:domain ind:ClaimDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Response Received Date' ;
    rdfs:comment 'Actual date on which a response to this document was received. Compared against response_due_date to determine SLA compliance and insurer response performance.' ;
    rdfs:domain ind:ClaimDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseStatus rdf:type rdf:Property ;
    rdfs:label 'Response Status' ;
    rdfs:comment 'Current status of the expected response to this document. Tracks whether a reply is pending, has been received, is not required, or is overdue. Supports insurer SLA compliance reporting and claim escalation management.' ;
    rdfs:domain ind:ClaimDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reviewed Timestamp' ;
    rdfs:comment 'Date and time when the document was reviewed by the claims handler. Used to measure internal processing time and SLA compliance for document review workflows.' ;
    rdfs:domain ind:ClaimDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sent Timestamp' ;
    rdfs:comment 'Date and time when the document was dispatched by the sending party. Applicable for outbound documents. Used to measure insurer SLA response times and regulatory submission deadlines under IATA and IMO frameworks.' ;
    rdfs:domain ind:ClaimDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:storageReference rdf:type rdf:Property ;
    rdfs:label 'Storage Reference' ;
    rdfs:comment 'Physical or digital storage location reference for the document file (e.g., object storage path, document management system URI, DMS folder reference). Enables retrieval of the actual document from the underlying storage system for claim review and regulatory audit.' ;
    rdfs:domain ind:ClaimDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uploadTimestamp rdf:type rdf:Property ;
    rdfs:label 'Upload Timestamp' ;
    rdfs:comment 'Date and time when the document was uploaded or ingested into the claims management system. Distinct from received_timestamp; captures the system ingestion event for audit trail and data lineage purposes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Sequential version number of the document, incremented when a revised or amended version is submitted. Enables tracking of document amendments throughout the claim lifecycle and ensures the latest version is used for liability determination.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adequacyReviewDate rdf:type rdf:Property ;
    rdfs:label 'Adequacy Review Date' ;
    rdfs:comment 'Date of the most recent periodic reserve adequacy review conducted by the claims finance team. IAS 37 requires reserves to be reviewed at each reporting date and adjusted to reflect the current best estimate.' ;
    rdfs:domain ind:Reserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or employee identifier of the authorized approver who sanctioned the reserve establishment or most recent material adjustment. Required for SOX segregation of duties and financial control compliance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentReserveAmount rdf:type rdf:Property ;
    rdfs:label 'Current Reserve Amount' ;
    rdfs:comment 'Most recent reserve balance after all adjustments (increases and decreases). Reflects the current best estimate of outstanding liability exposure on the balance sheet. Updated with each reserve adjustment posting in SAP S/4HANA Finance.' ;
    rdfs:domain ind:Reserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysReserveOpen rdf:type rdf:Property ;
    rdfs:label 'Days Reserve Open' ;
    rdfs:comment 'Number of calendar days the reserve has been open since establishment_date. Used in reserve aging reports and KPI dashboards to identify long-outstanding reserves requiring management escalation.' ;
    rdfs:domain ind:Reserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:establishmentDate rdf:type rdf:Property ;
    rdfs:label 'Establishment Date' ;
    rdfs:comment 'Calendar date on which the financial reserve was first established in SAP S/4HANA Finance. Used as the IAS 37 provision recognition date for balance sheet reporting and SOX-compliant financial close.' ;
    rdfs:domain ind:Reserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Expected Settlement Date' ;
    rdfs:comment 'Estimated date by which the underlying claim is expected to be settled and the reserve released. Used for cash flow forecasting, reserve aging analysis, and IFRS 37 disclosure of timing of outflows.' ;
    rdfs:domain ind:Reserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:functionalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter code for the entity\'s functional currency used in IFRS consolidated reporting (e.g., USD). Paired with functional_currency_amount.' ;
    rdfs:domain ind:Reserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialReserveAmount rdf:type rdf:Property ;
    rdfs:label 'Initial Reserve Amount' ;
    rdfs:comment 'Original estimated liability exposure amount posted to the balance sheet at reserve establishment. Represents the best estimate of the probable outflow of economic resources as required by IAS 37. Denominated in reserve_currency.' ;
    rdfs:domain ind:Reserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insurerNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Insurer Notification Date' ;
    rdfs:comment 'Date on which the insurer was formally notified of the claim and reserve. Used to track compliance with policy notification deadlines and manage insurer correspondence timelines.' ;
    rdfs:domain ind:Reserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Last Adjustment Amount' ;
    rdfs:comment 'Monetary value of the most recent reserve adjustment. Positive values indicate a reserve increase (strengthening); negative values indicate a reserve decrease (release). Denominated in reserve_currency.' ;
    rdfs:domain ind:Reserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastAdjustmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Adjustment Date' ;
    rdfs:comment 'Date of the most recent reserve adjustment (increase or decrease). Used to identify stale reserves requiring review during monthly reserve adequacy assessments.' ;
    rdfs:domain ind:Reserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastAdjustmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Last Adjustment Reason Code' ;
    rdfs:comment 'Standardized reason code explaining the basis for the most recent reserve adjustment. Supports audit trail requirements and reserve movement analysis. [ENUM-REF-CANDIDATE: new_evidence|survey_update|legal_development|settlement_negotiation|subrogation_recovery|reserve_adequacy_review — promote to reference product]' ;
    rdfs:domain ind:Reserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseAmount rdf:type rdf:Property ;
    rdfs:label 'Release Amount' ;
    rdfs:comment 'Amount released from the reserve upon settlement or closure. May be a partial or full release. Denominated in reserve_currency. Reconciled against settlement_amount in the claim record.' ;
    rdfs:domain ind:Reserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date on which the reserve was fully or partially released upon claim settlement, withdrawal, or closure. Triggers the corresponding SAP S/4HANA Finance reversal posting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releaseReason rdf:type rdf:Property ;
    rdfs:label 'Release Reason' ;
    rdfs:comment 'Reason for releasing the reserve. Supports audit trail and reserve movement reporting. [ENUM-REF-CANDIDATE: claim_settled|claim_withdrawn|claim_denied|subrogation_recovered|statute_expired|management_decision — promote to reference product]' ;
    rdfs:domain ind:Reserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reserveNumber rdf:type rdf:Property ;
    rdfs:label 'Reserve Number' ;
    rdfs:comment 'Externally-known business identifier for the reserve record, assigned at the time of reserve establishment. Used in insurer correspondence, SAP S/4HANA Finance postings, and audit trails. Format: RES-{YYYY}-{8-digit sequence}.' ;
    rdfs:domain ind:Reserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reserveStatus rdf:type rdf:Property ;
    rdfs:label 'Reserve Status' ;
    rdfs:comment 'Current lifecycle state of the claim reserve. Drives IFRS 17/IAS 37 provisioning workflows and monthly reserve adequacy reviews. [ENUM-REF-CANDIDATE: open|adjusted|partially_released|fully_released|closed|cancelled — promote to reference product]' ;
    rdfs:domain ind:Reserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reserveType rdf:type rdf:Property ;
    rdfs:label 'Reserve Type' ;
    rdfs:comment 'Classification of the reserve by its business purpose. Initial reserves are established at claim registration; supplemental reserves are created for additional exposure; subrogation reserves track recoverable amounts; salvage reserves reflect recoverable cargo value; litigation reserves cover legal proceedings.' ;
    rdfs:domain ind:Reserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Document Number' ;
    rdfs:comment 'SAP S/4HANA Finance accounting document number generated when the reserve provision was posted. Provides the audit trail linkage between the claim reserve record and the financial ledger entry.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subrogationPotential rdf:type rdf:Property ;
    rdfs:label 'Subrogation Potential' ;
    rdfs:comment 'Indicates whether the claim has identified subrogation recovery potential (i.e., the right to recover paid amounts from a liable third party such as a carrier or supplier). Triggers subrogation workflow initiation.' ;
    rdfs:domain ind:Reserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalAdjustmentsAmount rdf:type rdf:Property ;
    rdfs:label 'Total Adjustments Amount' ;
    rdfs:comment 'Cumulative net amount of all reserve adjustments since establishment (sum of all increases and decreases). Denominated in reserve_currency. Supports reserve movement waterfall reporting.' ;
    rdfs:domain ind:Reserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineId rdf:type rdf:Property ;
    rdfs:label 'Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each claim line record within the cargo claims management system. Primary key for the claim_line data product in the Silver Layer lakehouse.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customsDeclarationLineId rdf:type rdf:Property ;
    rdfs:label 'Customs Declaration Line Id' ;
    rdfs:comment 'Foreign key linking to customs.declaration_line. Business justification: Line-level claims need line-level customs data to match specific commodities, verify per-item declared values (liability caps per package/unit), and validate HS codes. Essential for multi-commodity sh' ;
    rdfs:domain ind:Line ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeclarationLine .

ind:hsClassificationId rdf:type rdf:Property ;
    rdfs:label 'Hs Classification Id' ;
    rdfs:comment 'Foreign key linking to customs.hs_classification. Business justification: Claim line items for specific commodities require direct HS classification reference for customs valuation disputes, duty-related claims, and tariff classification challenges. Critical for claims invo' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HsClassification .

ind:orderLineId rdf:type rdf:Property ;
    rdfs:label 'Order Line Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.order_line. Business justification: Claims are filed against specific order line items (SKU-level damage, quantity discrepancies, wrong item shipped). Finance and operations need line-item traceability for accurate settlement calculatio' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderLine .

ind:outboundOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Outbound Order Line Id' ;
    rdfs:comment 'Foreign key linking to warehouse.outbound_order_line. Business justification: A claim line for a specific outbound order item must reference the outbound_order_line to verify ordered vs. shipped quantities, unit price, and lot/serial numbers for settlement calculation. This is ' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OutboundOrderLine .

ind:poLineId rdf:type rdf:Property ;
    rdfs:label 'Po Line Id' ;
    rdfs:comment 'Foreign key linking to procurement.po_line. Business justification: Direct claim line to PO line linkage enables precise matching of claimed items to ordered items, quantities, and unit prices for accurate settlement calculation. Real business process: line-item claim' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PoLine .

ind:skuId rdf:type rdf:Property ;
    rdfs:label 'Sku Id' ;
    rdfs:comment 'Foreign key linking to warehouse.sku. Business justification: A claim line represents a specific SKU being claimed. Linking to warehouse.sku enables retrieval of product specifications (weight, dimensions, hazmat class, shelf life) for liability calculation and ' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:approvedQuantity rdf:type rdf:Property ;
    rdfs:label 'Approved Quantity' ;
    rdfs:comment 'Quantity approved by the claims assessor following survey and investigation. May differ from claimed_quantity where partial loss or damage is confirmed. Used in settlement calculation.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedValue rdf:type rdf:Property ;
    rdfs:label 'Approved Value' ;
    rdfs:comment 'Monetary value approved for settlement on this line item following assessment, survey, and liability determination. May be less than claimed_value due to liability caps, depreciation, or partial loss findings.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimFilingDate rdf:type rdf:Property ;
    rdfs:label 'Claim Filing Date' ;
    rdfs:comment 'Date on which this claim line was formally filed with the carrier or insurer. Used to assess compliance with statutory filing deadlines under the Montreal Convention (14 days for damage, 21 days for delay) and CMR Convention.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimedQuantity rdf:type rdf:Property ;
    rdfs:label 'Claimed Quantity' ;
    rdfs:comment 'Number of units, pieces, or cargo items being claimed on this line. Represents the quantity declared as lost, damaged, or short-shipped by the claimant.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimedValue rdf:type rdf:Property ;
    rdfs:label 'Claimed Value' ;
    rdfs:comment 'Total monetary value claimed by the claimant for this line item, calculated as claimed_quantity multiplied by unit_value plus any ancillary costs. Represents the claimant\'s gross demand before assessment.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conditionAtDestination rdf:type rdf:Property ;
    rdfs:label 'Condition At Destination' ;
    rdfs:comment 'Recorded condition of the cargo item upon delivery at destination, as noted on the Proof of Delivery (POD) or cargo survey report. Compared against condition_at_origin to establish loss or damage.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionAtOrigin rdf:type rdf:Property ;
    rdfs:label 'Condition At Origin' ;
    rdfs:comment 'Recorded condition of the cargo item at the point of origin or acceptance by the carrier, as noted on the AWB, BOL, or cargo receipt. Establishes the baseline for damage assessment and liability determination.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageCategory rdf:type rdf:Property ;
    rdfs:label 'Damage Category' ;
    rdfs:comment 'Categorical classification of the damage type for this claim line, enabling trend analysis and root cause reporting. [ENUM-REF-CANDIDATE: physical|water|fire|theft|contamination|temperature|handling|vermin|customs_examination — promote to reference product]' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationRate rdf:type rdf:Property ;
    rdfs:label 'Depreciation Rate' ;
    rdfs:comment 'Depreciation rate applied to the cargo item\'s declared value to reflect age, wear, or market value reduction at the time of loss or damage. Expressed as a decimal (e.g., 0.1500 = 15%). Applied in approved_value calculation.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liabilityCapValue rdf:type rdf:Property ;
    rdfs:label 'Liability Cap Value' ;
    rdfs:comment 'Maximum carrier liability applicable to this claim line under the governing convention or contract (e.g., SDR per kg under Montreal Convention for air, or CMR limits for road). Constrains the approved_value ceiling.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line number ordering this item within the parent claim. Used for display, sorting, and referencing individual line items in insurer correspondence and settlement documentation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current lifecycle status of this individual claim line item. Tracks the workflow state from initial registration through assessment, approval or rejection, and final settlement or withdrawal.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossDiscoveryDate rdf:type rdf:Property ;
    rdfs:label 'Loss Discovery Date' ;
    rdfs:comment 'Date on which the loss, damage, or shortage for this claim line was first discovered or reported by the consignee or shipper. Critical for determining claim filing timeliness under applicable liability conventions.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityUnit rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit' ;
    rdfs:comment 'Unit of measure for the claimed quantity (e.g., PCS for pieces, KG for kilograms, CBM for cubic metres, CTN for cartons, PLT for pallets, BAG for bags). Aligns with the unit declared on the AWB or BOL.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subrogationRecoveryValue rdf:type rdf:Property ;
    rdfs:label 'Subrogation Recovery Value' ;
    rdfs:comment 'Monetary amount recovered through subrogation proceedings for this claim line. Populated after recovery is confirmed. Used in finance for net claims cost reporting and P&L impact analysis.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitValue rdf:type rdf:Property ;
    rdfs:label 'Unit Value' ;
    rdfs:comment 'Declared or assessed value per unit of the cargo item at origin, as stated on the commercial invoice. Used as the basis for claim valuation and liability cap comparison under applicable conventions.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractPartyId rdf:type rdf:Property ;
    rdfs:label 'Contract Party Id' ;
    rdfs:comment 'Reference to the master party record (organisation or individual) involved in this claim. Enables lookup of full party profile from the master party registry.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractParty .

ind:tradePartyId rdf:type rdf:Property ;
    rdfs:label 'Trade Party Id' ;
    rdfs:comment 'Foreign key linking to customs.trade_party. Business justification: Claimants and respondents in customs-related claims are often registered trade parties (importers, exporters, brokers). Direct link required for AEO/C-TPAT status verification, compliance validation, ' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeParty .

ind:aeoNumber rdf:type rdf:Property ;
    rdfs:label 'Aeo Number' ;
    rdfs:comment 'AEO certification number of the party where applicable (carriers, freight handlers, customs brokers). Relevant for customs authority and freight handler roles in cross-border claims.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the party\'s registered jurisdiction. Determines applicable national regulations, customs authority jurisdiction, and governing law for the claim.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeRaised rdf:type rdf:Property ;
    rdfs:label 'Dispute Raised' ;
    rdfs:comment 'Indicates whether this party has formally raised a dispute against the claim amount, liability determination, or settlement terms. Triggers escalation to legal proceedings or arbitration.' ;
    rdfs:domain ind:ClaimParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentSubmissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Document Submission Deadline' ;
    rdfs:comment 'Deadline by which this party must submit supporting documentation (e.g., survey reports, invoices, packing lists, customs declarations) to support or defend the claim.' ;
    rdfs:domain ind:ClaimParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentsReceived rdf:type rdf:Property ;
    rdfs:label 'Documents Received' ;
    rdfs:comment 'Indicates whether all required supporting documents have been received from this party. Drives claim processing workflow and completeness checks.' ;
    rdfs:domain ind:ClaimParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iataCode rdf:type rdf:Property ;
    rdfs:label 'Iata Code' ;
    rdfs:comment 'IATA airline or agent code assigned to this party, applicable for air carrier and freight forwarder roles. Used to identify the party in air freight claim proceedings under IATA conventions.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imoNumber rdf:type rdf:Property ;
    rdfs:label 'Imo Number' ;
    rdfs:comment 'IMO vessel or company identification number for ocean carrier parties. Used to identify the maritime carrier in ocean freight claims under Hague-Visby or similar rules.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalRepresentationType rdf:type rdf:Property ;
    rdfs:label 'Legal Representation Type' ;
    rdfs:comment 'Indicates whether this party is represented by in-house legal counsel, external legal counsel, or has no legal representation in the claim proceedings.' ;
    rdfs:domain ind:ClaimParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityAccepted rdf:type rdf:Property ;
    rdfs:label 'Liability Accepted' ;
    rdfs:comment 'Indicates whether this party has formally accepted liability for the cargo loss, damage, or delay. Drives settlement calculation and subrogation recovery processes.' ;
    rdfs:domain ind:ClaimParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liabilityCurrency rdf:type rdf:Property ;
    rdfs:label 'Liability Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the liability limit amount is expressed (e.g., USD, EUR, XDR for Special Drawing Rights).' ;
    rdfs:domain ind:ClaimParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityFramework rdf:type rdf:Property ;
    rdfs:label 'Liability Framework' ;
    rdfs:comment 'International or contractual liability convention governing this party\'s exposure in the claim. Determines maximum liability limits and burden of proof requirements.' ;
    rdfs:domain ind:ClaimParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Liability Percentage' ;
    rdfs:comment 'Percentage of total claim liability attributed to this party in cases of shared or apportioned liability across multiple carriers or intermediaries in intermodal shipments.' ;
    rdfs:domain ind:ClaimParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationMethod rdf:type rdf:Property ;
    rdfs:label 'Notification Method' ;
    rdfs:comment 'Channel used to formally notify this party of the claim. Relevant for legal admissibility of notice under applicable conventions and SLA tracking.' ;
    rdfs:domain ind:ClaimParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationStatus rdf:type rdf:Property ;
    rdfs:label 'Notification Status' ;
    rdfs:comment 'Status of the formal claim notification sent to this party. Tracks whether the party has been formally notified per applicable convention timelines (e.g., 14-day notice under CMR, 7-day notice under Warsaw-Montreal).' ;
    rdfs:domain ind:ClaimParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Timestamp' ;
    rdfs:comment 'Date and time when the formal claim notification was dispatched to this party. Critical for calculating statutory response deadlines under applicable liability conventions.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:partyRole rdf:type rdf:Property ;
    rdfs:label 'Party Role' ;
    rdfs:comment 'Functional role of the party within the cargo claim process. Determines liability exposure, notification obligations, and response requirements. [ENUM-REF-CANDIDATE: claimant|carrier|sub_carrier|insurer|underwriter|surveyor|legal_counsel|customs_authority|port_operator|freight_handler — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyStatus rdf:type rdf:Property ;
    rdfs:label 'Party Status' ;
    rdfs:comment 'Current lifecycle status of this party\'s involvement in the claim. Tracks progression from initial notification through response, dispute resolution, and final settlement or withdrawal.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyType rdf:type rdf:Property ;
    rdfs:label 'Party Type' ;
    rdfs:comment 'Classification of the party as an organisation, individual, government body, or regulatory authority. Drives applicable liability frameworks and communication protocols.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerOfAttorney rdf:type rdf:Property ;
    rdfs:label 'Power Of Attorney' ;
    rdfs:comment 'Indicates whether a power of attorney has been received from this party authorising a representative to act on their behalf in the claim proceedings.' ;
    rdfs:domain ind:ClaimParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryParty rdf:type rdf:Property ;
    rdfs:label 'Primary Party' ;
    rdfs:comment 'Indicates whether this party is the primary counterparty for the claim (e.g., the main claimant or the primary liable carrier) as opposed to a secondary or supporting party.' ;
    rdfs:domain ind:ClaimParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseDeadline rdf:type rdf:Property ;
    rdfs:label 'Response Deadline' ;
    rdfs:comment 'Contractual or statutory deadline by which this party must respond to the claim notification. Derived from notification date plus applicable convention or SLA response period.' ;
    rdfs:domain ind:ClaimParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseReceivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Received Timestamp' ;
    rdfs:comment 'Date and time when this party\'s formal response to the claim notification was received. Used to assess timeliness of response against statutory deadlines.' ;
    rdfs:domain ind:ClaimParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:settlementCurrency rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the settlement amount with this party is denominated.' ;
    rdfs:domain ind:ClaimParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyReportReference rdf:type rdf:Property ;
    rdfs:label 'Survey Report Reference' ;
    rdfs:comment 'Reference number of the cargo survey report issued by the surveyor party. Links the party\'s assessment findings to the claim record for loss quantification and liability determination.' ;
    rdfs:domain ind:ClaimParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyorAccreditation rdf:type rdf:Property ;
    rdfs:label 'Surveyor Accreditation' ;
    rdfs:comment 'Professional accreditation or certification number of the cargo surveyor party. Validates the surveyor\'s authority to conduct loss and damage assessments for insurance and legal purposes.' ;
    rdfs:domain ind:ClaimParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aggregateAnnualLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Aggregate Annual Limit Amount' ;
    rdfs:comment 'Maximum total insurer liability across all claims filed within the policy year, expressed in coverage_limit_currency. Once exhausted, no further claims are payable under this policy until renewal. Critical for reserve accounting in SAP S/4HANA Finance.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether this policy automatically renews at expiry without requiring explicit action from Transport Shipping. When True, cancellation notice must be given before the renewal_date to prevent automatic continuation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:brokerName rdf:type rdf:Property ;
    rdfs:label 'Broker Name' ;
    rdfs:comment 'Name of the insurance broker or intermediary who placed this policy on behalf of Transport Shipping. The broker is the primary point of contact for policy renewals, endorsements, and claim escalations.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerReference rdf:type rdf:Property ;
    rdfs:label 'Broker Reference' ;
    rdfs:comment 'Broker\'s own reference number for this policy placement. Used in broker correspondence, premium invoices, and claim notifications routed through the broker.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Cancellation Notice Period Days' ;
    rdfs:comment 'Minimum number of calendar days\' written notice required by either party to cancel this policy before its expiry_date. Breach of this period may result in premium liability for the full policy term.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cargoCategory rdf:type rdf:Property ;
    rdfs:label 'Cargo Category' ;
    rdfs:comment 'Classification of cargo types covered under this policy. Determines applicable liability frameworks and special conditions. \'dangerous_goods\' aligns to IMDG Code and ICAO Technical Instructions; \'high_value\' triggers enhanced survey requirements. [ENUM-REF-CANDIDATE: general|perishable|dangerous_goods|high_value|fragile|bulk|pharmaceutical|automotive — promote to reference product]' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimsFilingPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Claims Filing Period Days' ;
    rdfs:comment 'Maximum number of calendar days after the loss event within which a formal claim must be filed with the insurer. Distinct from the notification period; this is the hard deadline for submitting full claim documentation.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimsNotificationPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Claims Notification Period Days' ;
    rdfs:comment 'Maximum number of calendar days after discovery of loss or damage within which a claim must be notified to the insurer to remain eligible for settlement. Breach of this period may void the claim. Aligned to IATA, CMR, and IMO convention time limits.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coInsuranceFlag rdf:type rdf:Property ;
    rdfs:label 'Co Insurance Flag' ;
    rdfs:comment 'Indicates whether this policy is co-insured by multiple underwriters sharing the risk proportionally. When True, the co_insurance_lead_insurer and individual underwriter shares must be tracked for claim apportionment.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coInsuranceSharePct rdf:type rdf:Property ;
    rdfs:label 'Co Insurance Share Pct' ;
    rdfs:comment 'Percentage of the total risk retained by the lead insurer named in insurer_name when this is a co-insured policy. Expressed as a decimal percentage (e.g., 60.00 for 60%). Only applicable when co_insurance_flag is True.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Coverage Limit Amount' ;
    rdfs:comment 'Maximum monetary amount the insurer will pay for any single claim or in aggregate under this policy, expressed in the policy currency. Serves as the upper bound for settlement calculations. Critical for claim eligibility assessment.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageLimitCurrency rdf:type rdf:Property ;
    rdfs:label 'Coverage Limit Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the coverage limit amount and deductible are denominated (e.g., USD, EUR, GBP). Required for multi-currency settlement calculations.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coveredTransportModes rdf:type rdf:Property ;
    rdfs:label 'Covered Transport Modes' ;
    rdfs:comment 'Pipe-delimited list of transport modes covered under this policy (e.g., \'air|ocean|road|rail\'). Determines claim eligibility based on the mode used for the shipment. Aligned to IATA (air), IMO (ocean), CMR Convention (road), and CIM/COTIF (rail) liability frameworks. [ENUM-REF-CANDIDATE: air|ocean|road|rail|multimodal|courier — promote to reference product]' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dangerousGoodsCovered rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Covered' ;
    rdfs:comment 'Indicates whether this policy explicitly covers dangerous goods shipments as classified under the IMDG Code (ocean), ICAO Technical Instructions (air), or ADR/RID (road/rail). When True, the policy must reference applicable DG endorsements and special conditions.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:declarationPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Declaration Period Days' ;
    rdfs:comment 'Number of calendar days after shipment dispatch within which a declaration must be submitted to the insurer under an open cover policy. Only applicable when declaration_required_flag is True. Null for specific voyage policies.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:declarationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Declaration Required Flag' ;
    rdfs:comment 'Indicates whether individual shipment declarations must be submitted to the insurer under this open cover policy. When True, each shipment must be declared within the agreed declaration period to activate coverage for that consignment.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deductibleType rdf:type rdf:Property ;
    rdfs:label 'Deductible Type' ;
    rdfs:comment 'Method by which the deductible is applied. \'fixed\' is a flat monetary amount; \'percentage\' is a proportion of the claim value; \'franchise\' means the deductible is waived if the claim exceeds the threshold; \'nil\' means no deductible applies.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Method' ;
    rdfs:comment 'Agreed mechanism for resolving disputes between Transport Shipping and the insurer regarding claim settlements or policy interpretation. \'arbitration\' is most common in international cargo insurance under Lloyd\'s and London Market policies.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReference rdf:type rdf:Property ;
    rdfs:label 'Document Reference' ;
    rdfs:comment 'Document management system reference or URL pointing to the signed policy wording, schedule, and endorsements stored in the enterprise content management system. Enables auditors and claims handlers to retrieve the authoritative policy text.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Calendar date on which the cargo insurance policy becomes binding and coverage commences. Used to determine claim eligibility based on shipment date. Maps to EFFECTIVE_FROM canonical category for MASTER_AGREEMENT role.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusions rdf:type rdf:Property ;
    rdfs:label 'Exclusions' ;
    rdfs:comment 'Structured description of risks, cargo types, or circumstances explicitly excluded from coverage under this policy. Common exclusions include inherent vice, delay, inadequate packing, and nuclear risks. Used during claim eligibility assessment.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Calendar date on which the cargo insurance policy coverage terminates. Claims for shipments dispatched after this date are not eligible under this policy. Nullable for open-ended or evergreen open cover policies. Maps to EFFECTIVE_UNTIL canonical category for MASTER_AGREEMENT role.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'Territorial extent of coverage under this policy. \'worldwide\' covers all global shipments; \'regional\' covers a defined geographic region; \'domestic\' covers in-country shipments only; \'cross_border\' covers international shipments excluding domestic legs.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLaw rdf:type rdf:Property ;
    rdfs:label 'Governing Law' ;
    rdfs:comment 'Jurisdiction whose laws govern the interpretation and enforcement of this insurance policy (e.g., \'English Law\', \'New York Law\', \'German Law\'). Determines dispute resolution forum and applicable legal standards for claim settlement.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insurerPolicyReference rdf:type rdf:Property ;
    rdfs:label 'Insurer Policy Reference' ;
    rdfs:comment 'Insurer\'s own internal reference or certificate number for this policy, distinct from the policy_number used by Transport Shipping. Required for direct insurer correspondence and electronic claim submission via EDI.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingCountry rdf:type rdf:Property ;
    rdfs:label 'Issuing Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction in which this insurance policy was issued. Determines applicable regulatory oversight (e.g., FCA in GBR, BaFin in DEU, NAIC in USA) and tax treatment of premiums.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openCoverFlag rdf:type rdf:Property ;
    rdfs:label 'Open Cover Flag' ;
    rdfs:comment 'Indicates whether this policy is structured as an open cover (blanket policy covering all qualifying shipments automatically without individual declaration) rather than a specific voyage or shipment policy. Open cover policies are common for high-volume freight forwarders.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:perShipmentLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Per Shipment Limit Amount' ;
    rdfs:comment 'Maximum insurer liability for any single shipment event under this policy, expressed in coverage_limit_currency. May be lower than the aggregate coverage_limit_amount. Used in claim settlement calculations for individual AWB, BOL, or consignment note events.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:policyNumber rdf:type rdf:Property ;
    rdfs:label 'Policy Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier assigned by the insurer to uniquely identify the cargo insurance policy. Used in all insurer correspondence, claim filings, and settlement documentation. Maps to the BUSINESS_IDENTIFIER canonical category for MASTER_AGREEMENT role.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyStatus rdf:type rdf:Property ;
    rdfs:label 'Policy Status' ;
    rdfs:comment 'Current lifecycle state of the cargo insurance policy. \'active\' indicates the policy is in force and eligible for claim filing; \'suspended\' indicates temporary coverage halt; \'expired\' indicates the policy period has ended without renewal; \'cancelled\' indicates early termination; \'pending_renewal\' indicates renewal is in progress; \'lapsed\' indicates non-renewal after expiry. Maps to LIFECYCLE_STATUS canonical category.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyType rdf:type rdf:Property ;
    rdfs:label 'Policy Type' ;
    rdfs:comment 'Classification of the cargo insurance policy by coverage scope. \'all_risk\' covers all physical loss or damage except named exclusions; \'named_perils\' covers only explicitly listed risks; \'war_risk\' covers war, strikes, and political risks; \'total_loss_only\' covers only complete cargo loss; \'open_cover\' is a continuous blanket policy for multiple shipments. Maps to CLASSIFICATION_OR_TYPE canonical category.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumAmount rdf:type rdf:Property ;
    rdfs:label 'Premium Amount' ;
    rdfs:comment 'Annual or periodic insurance premium paid by Transport Shipping to the insurer for this policy. Used in finance for cost allocation, OPEX reporting, and profitability analysis per trade lane or business unit.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:premiumPaymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Premium Payment Frequency' ;
    rdfs:comment 'Frequency at which the insurance premium is paid to the insurer. Drives accounts payable scheduling in SAP S/4HANA Finance and cash flow forecasting.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinsuranceFlag rdf:type rdf:Property ;
    rdfs:label 'Reinsurance Flag' ;
    rdfs:comment 'Indicates whether the insurer has placed reinsurance for this policy. Relevant for large-value cargo policies where the insurer\'s net retention is limited. Affects claim recovery timelines and insurer solvency risk assessment.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'Date on which the policy is due for renewal. Used to trigger renewal negotiations, premium reviews, and coverage reassessment. Typically aligns with or precedes the expiry_date.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specialConditions rdf:type rdf:Property ;
    rdfs:label 'Special Conditions' ;
    rdfs:comment 'Free-text field capturing policy-specific endorsements, exclusions, warranties, or special clauses that modify the standard Institute Cargo Clauses terms. Examples include temperature warranty for perishables, packing warranty, or exclusion of specific trade lanes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subrogationRights rdf:type rdf:Property ;
    rdfs:label 'Subrogation Rights' ;
    rdfs:comment 'Indicates whether the insurer retains the right of subrogation to pursue recovery from liable third parties (carriers, handlers, customs authorities) after settling a claim. When True, Transport Shipping must cooperate with insurer recovery actions and preserve evidence.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surveyRequiredThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Survey Required Threshold Amount' ;
    rdfs:comment 'Minimum claim value (in coverage_limit_currency) above which an independent cargo survey report is mandatory before the insurer will process the claim. Below this threshold, claims may be settled on documentary evidence alone.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentAccountCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Account Customer Account Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent customer account record, enabling hierarchical B2B enterprise account structures (e.g., subsidiary accounts rolling up to a global parent). Null for top-level accounts. Supports consolidated billing and group-level SLA management.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:preferredCarrierId rdf:type rdf:Property ;
    rdfs:label 'Preferred Carrier Id' ;
    rdfs:comment 'Foreign key linking to network.carrier. Business justification: Account-level preferred carrier drives automated shipment routing and rate application in TMS. Account managers configure this for volume-based carrier negotiations. A logistics domain expert expects ' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:preferredLaneId rdf:type rdf:Property ;
    rdfs:label 'Preferred Lane Id' ;
    rdfs:comment 'Foreign key linking to route.lane. Business justification: Strategic customers negotiate preferred lanes for their shipments. Drives TMS routing decisions, contract-specific lane assignments, and dedicated capacity allocation. Essential for customer-specific ' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lane .

ind:preferredServiceCorridorId rdf:type rdf:Property ;
    rdfs:label 'Preferred Service Corridor Id' ;
    rdfs:comment 'Foreign key linking to route.service_corridor. Business justification: Enterprise customers negotiate corridor-level service agreements for regional trade lanes. Required for corridor capacity reservations, multi-leg service commitments, and strategic account corridor pe' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceCorridor .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Foreign key linking to customer.customer_segment. Business justification: Normalizes the customer segmentation classification. Currently customer_account has account_segment as a STRING (likely storing segment_code). Adding customer_segment_id FK allows proper referential i' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'Externally-known alphanumeric account number assigned to the customer at onboarding. Printed on invoices, Air Waybills (AWBs), and Bills of Lading (BOLs) as the billing reference. Unique across the logistics network.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountSource rdf:type rdf:Property ;
    rdfs:label 'Account Source' ;
    rdfs:comment 'Channel or method through which the customer account was originally created: Salesforce CRM opportunity conversion, web portal self-registration, EDI partner onboarding, manual entry by operations team, data migration from legacy system, or partner referral.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle state of the customer account. \'active\' indicates the account is in good standing and can generate shipments; \'suspended\' indicates a temporary hold (e.g., credit breach); \'closed\' indicates the account has been permanently deactivated; \'pending\' indicates onboarding in progress; \'prospect\' indicates a pre-onboarding opportunity from Salesforce CRM.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountTier rdf:type rdf:Property ;
    rdfs:label 'Account Tier' ;
    rdfs:comment 'Commercial segmentation tier assigned to the customer account based on revenue contribution, shipment volume, and strategic value. Determines priority handling, dedicated account management, and access to premium services such as guaranteed capacity and priority customs clearance.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classifies the customer account into its primary commercial relationship category: B2B (enterprise shipper), B2C (individual sender), 3PL (Third-Party Logistics provider), 4PL (Fourth-Party Logistics provider), CONSIGNEE (receiving party), or BROKER (customs/freight broker). Drives SLA entitlements, pricing tiers, and service eligibility.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeoCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Aeo Certificate Number' ;
    rdfs:comment 'Official AEO certificate number issued by the customs authority to the customer. Required for customs declaration pre-population in Descartes Customs GTM and for claiming AEO mutual recognition benefits on cross-border shipments. Null if aeo_certified is False.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeoCertified rdf:type rdf:Property ;
    rdfs:label 'Aeo Certified' ;
    rdfs:comment 'Indicates whether the customer holds a valid Authorized Economic Operator (AEO) certification issued by a customs authority. AEO-certified customers benefit from expedited customs clearance, reduced inspection rates, and mutual recognition benefits under WCO SAFE Framework agreements.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:apiIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Api Integration Enabled' ;
    rdfs:comment 'Indicates whether the customer account has an active API integration for real-time shipment booking, tracking, and rate queries via Transport Shipping\'s logistics platform. API-enabled accounts can connect their ERP or e-commerce systems directly.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line1' ;
    rdfs:comment 'First line of the customer\'s registered billing address (street number and name). Used for invoice generation, tax compliance, and financial reporting in SAP S/4HANA Finance.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCity rdf:type rdf:Property ;
    rdfs:label 'Billing City' ;
    rdfs:comment 'City component of the customer\'s registered billing address. Used for tax jurisdiction determination, freight rate zone assignment, and regulatory reporting.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Billing Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code of the customer\'s registered billing address (e.g., USA, GBR, DEU). Drives VAT/GST applicability, customs compliance rules, trade sanctions screening, and currency assignment.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the customer\'s registered billing address. Used for freight rate zone calculation, tax jurisdiction mapping, and address validation.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'Calendar date on which the customer account was permanently closed. Null for active accounts. Used for churn analysis, regulatory data retention scheduling, and financial period-end reconciliation.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Credit Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the credit limit and outstanding balance are denominated (e.g., USD, EUR, GBP). Ensures consistent financial reporting across multi-currency accounts.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Maximum outstanding accounts receivable balance permitted for this customer account in the account\'s billing currency. Enforced by SAP S/4HANA Finance credit management module. Exceeding this limit triggers automatic shipment booking blocks.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Status' ;
    rdfs:comment 'Current credit standing of the customer account as assessed by the Finance team in SAP S/4HANA. \'approved\' allows standard credit terms; \'on_hold\' blocks new shipment bookings pending payment; \'suspended\' indicates credit facility withdrawn; \'under_review\' indicates active credit reassessment; \'cash_only\' requires prepayment for all services.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmAccountCode rdf:type rdf:Property ;
    rdfs:label 'Crm Account Code' ;
    rdfs:comment 'External account identifier sourced from Salesforce CRM Account object. Used to trace the master record back to the system of record and support bi-directional synchronisation with Salesforce.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctpatMember rdf:type rdf:Property ;
    rdfs:label 'Ctpat Member' ;
    rdfs:comment 'Indicates whether the customer is a validated member of the US Customs-Trade Partnership Against Terrorism (C-TPAT) program. C-TPAT membership enables expedited US Customs and Border Protection processing and reduced examination rates for US-bound shipments.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ddpEligible rdf:type rdf:Property ;
    rdfs:label 'Ddp Eligible' ;
    rdfs:comment 'Indicates whether the customer account is approved for Delivered Duty Paid (DDP) shipments, where Transport Shipping assumes responsibility for import duties and taxes on behalf of the customer. Requires credit approval and customs power of attorney on file.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deniedPartyScreenDate rdf:type rdf:Property ;
    rdfs:label 'Denied Party Screen Date' ;
    rdfs:comment 'Date on which the most recent denied party and sanctions screening was performed for this customer account in Descartes Customs GTM. Used to enforce periodic re-screening compliance and audit trail requirements.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deniedPartyScreened rdf:type rdf:Property ;
    rdfs:label 'Denied Party Screened' ;
    rdfs:comment 'Indicates whether the customer account has passed the most recent denied party and sanctions screening check in Descartes Customs GTM. Must be True before any shipment booking is permitted. Automatically reset to False when screening expires or a watchlist update occurs.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Nine-digit Dun & Bradstreet Data Universal Numbering System (DUNS) number uniquely identifying the customer\'s legal business entity globally. Used for credit risk assessment, supplier onboarding, and enterprise account hierarchy resolution.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediCapable rdf:type rdf:Property ;
    rdfs:label 'Edi Capable' ;
    rdfs:comment 'Indicates whether the customer account is configured for Electronic Data Interchange (EDI) integration for automated shipment booking, Advanced Shipping Notices (ASN), and status updates. EDI-capable accounts bypass manual data entry workflows.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eoriNumber rdf:type rdf:Property ;
    rdfs:label 'Eori Number' ;
    rdfs:comment 'Economic Operators Registration and Identification (EORI) number assigned by EU customs authorities to the customer for cross-border trade within the European Union. Required on all EU import/export customs declarations filed via Descartes Customs GTM.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryVertical rdf:type rdf:Property ;
    rdfs:label 'Industry Vertical' ;
    rdfs:comment 'The primary industry sector of the customer\'s business (e.g., Automotive, Retail, Pharmaceutical, Technology, Perishables, Energy). Used for industry-specific SLA configuration, dangerous goods handling rules, and targeted sales analytics. [ENUM-REF-CANDIDATE: Automotive|Retail|Pharmaceutical|Technology|Perishables|Energy|Aerospace|Consumer Goods|Industrial|Healthcare — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Verification Date' ;
    rdfs:comment 'Date on which the KYC verification was last completed for this customer account. Used to enforce periodic KYC renewal cycles and regulatory audit compliance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycVerified rdf:type rdf:Property ;
    rdfs:label 'Kyc Verified' ;
    rdfs:comment 'Indicates whether the customer account has completed Know Your Customer (KYC) identity verification as required by anti-money laundering (AML) regulations and Transport Shipping\'s customer onboarding policy. Required for high-value accounts and cross-border trade.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastShipmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Shipment Date' ;
    rdfs:comment 'Date of the most recent shipment booked or executed under this customer account. Used for dormancy detection, account health monitoring, and proactive retention outreach by the account management team.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'Full registered legal name of the customer entity as recorded with the relevant national business registry. Used for customs declarations, trade compliance screening, and financial invoicing. For B2C individuals this is the full personal name.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'Calendar date on which the customer account was formally activated and approved for shipment booking. Marks the start of the commercial relationship. Used for customer tenure analysis, anniversary-based tier reviews, and SLA effective date calculations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'Standard payment terms code assigned to the customer account (e.g., NET30, NET60, COD, PREPAID). Sourced from SAP S/4HANA Finance customer master. Determines invoice due dates and early payment discount eligibility. [ENUM-REF-CANDIDATE: NET30|NET60|NET90|COD|PREPAID|EOM|NET15 — promote to reference product]' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredIncotermsCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Incoterms Code' ;
    rdfs:comment 'Customer\'s default International Commercial Terms (Incoterms 2020) code governing risk and cost transfer in shipments (e.g., DDP, FOB, CIF, EXW). Pre-populated on new shipment bookings and freight orders in SAP TM. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — promote to reference product]' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredServiceMode rdf:type rdf:Property ;
    rdfs:label 'Preferred Service Mode' ;
    rdfs:comment 'Customer\'s preferred primary freight transport mode: air (express/freight), ocean (FCL/LCL), road (FTL/LTL), rail, or multimodal. Used by SAP TM for default carrier and route selection and by Blue Yonder for demand forecasting.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Primary email address for the account\'s main operational contact. Used for shipment notifications, Electronic Data Interchange (EDI) alerts, invoice delivery, and service case communications via Salesforce CRM.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary operational contact person at the customer account. Used for shipment documentation, customs declarations, and account management correspondence.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Primary telephone number for the account\'s main operational contact in E.164 international format. Used for last-mile delivery coordination, exception management, and Proof of Delivery (POD) confirmation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceOwnerCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Owner Code' ;
    rdfs:comment 'Salesforce CRM User ID of the account owner record. Retained for bi-directional synchronisation and audit traceability back to the Salesforce system of record.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTierCode rdf:type rdf:Property ;
    rdfs:label 'Sla Tier Code' ;
    rdfs:comment 'Code identifying the contracted Service Level Agreement (SLA) tier applicable to this customer account. Determines On-Time Delivery (OTD) targets, exception escalation thresholds, and guaranteed transit time commitments. Linked to the SLA entitlement configuration in SAP TM.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Number' ;
    rdfs:comment 'Employer Identification Number (EIN) or Tax Identification Number (TIN) assigned by the national tax authority (e.g., IRS EIN for US entities). Used for financial reporting, 1099/W-9 compliance, and customs importer of record identification.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingName rdf:type rdf:Property ;
    rdfs:label 'Trading Name' ;
    rdfs:comment 'Operating or \'doing business as\' (DBA) name used commercially by the customer, which may differ from the registered legal name. Used in customer-facing communications and shipment documentation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Vat Registration Number' ;
    rdfs:comment 'Customer\'s VAT or GST registration number issued by the relevant tax authority. Required for cross-border invoicing, customs declarations, and EU VAT compliance. Null for B2C customers or entities in non-VAT jurisdictions.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddressBookId rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Book Id' ;
    rdfs:comment 'Foreign key linking to customer.address_book. Business justification: Contact persons have mailing addresses used for correspondence, GDPR notifications, and regulatory communications. The contact table currently stores mailing_city, mailing_country_code, mailing_postal' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AddressBook .

ind:reportsToContactId rdf:type rdf:Property ;
    rdfs:label 'Reports To Contact Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the contact\'s managerial or supervisory contact within the same account. Mirrors the Salesforce CRM \'Reports To\' relationship. Enables organizational hierarchy navigation for escalation routing and account planning.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:contactDescription rdf:type rdf:Property ;
    rdfs:label 'Contact Description' ;
    rdfs:comment 'Free-text notes or description about the contact person, capturing additional context such as areas of responsibility, special handling instructions, relationship history, or account-specific notes entered by the account management team in Salesforce CRM.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactRole rdf:type rdf:Property ;
    rdfs:label 'Contact Role' ;
    rdfs:comment 'Functional role the contact plays in the customer relationship with Transport Shipping. Determines routing of communications, invoices, and service cases. [ENUM-REF-CANDIDATE: billing|operational|escalation|authorized_signatory|procurement|customs|compliance|executive — promote to reference product]' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the contact record. Active contacts receive communications and are eligible for service interactions. Inactive contacts have left the organization or are no longer relevant. Do_not_contact respects opt-out or legal restrictions per GDPR.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'Classification of the contact record indicating its priority and purpose within the account relationship. Primary contacts receive all standard communications; emergency contacts are activated for critical shipment exceptions or SLA breaches.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmContactCode rdf:type rdf:Property ;
    rdfs:label 'Crm Contact Code' ;
    rdfs:comment 'Source system identifier for the contact record in Salesforce CRM (Contact object ID, e.g., 003XXXXXXXXXXXXXXX). Used for cross-system reconciliation and lineage tracing back to the operational system of record.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Data Retention Expiry Date' ;
    rdfs:comment 'Date after which the contact\'s personal data must be reviewed for deletion or anonymization in compliance with GDPR Article 17 (Right to Erasure) and the organization\'s data retention policy. Calculated based on the last active engagement date plus the applicable retention period.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'Organizational department or business unit the contact belongs to within their company (e.g., Logistics, Procurement, Finance, Operations, Supply Chain). Supports targeted communications and service routing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotCall rdf:type rdf:Property ;
    rdfs:label 'Do Not Call' ;
    rdfs:comment 'Indicates whether the contact has opted out of phone-based outreach. When true, outbound calls to this contact are suppressed in CRM workflows. Supports GDPR consent management and national do-not-call registry compliance.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:email rdf:type rdf:Property ;
    rdfs:label 'Email' ;
    rdfs:comment 'Primary business email address of the contact person. Used for shipment notifications, EDI communications, invoice delivery, and CRM-driven customer service case correspondence. Governed under GDPR as personal data.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailOptOut rdf:type rdf:Property ;
    rdfs:label 'Email Opt Out' ;
    rdfs:comment 'Indicates whether the contact has opted out of marketing and non-transactional email communications. When true, only transactional emails (e.g., shipment confirmations, POD notifications) are permitted. Enforces GDPR Article 7 consent requirements.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fax rdf:type rdf:Property ;
    rdfs:label 'Fax' ;
    rdfs:comment 'Fax number for the contact, used in legacy customs documentation, trade compliance filings, and formal freight forwarding communications where fax remains an accepted channel per regulatory requirements.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Given name of the contact person as recorded in Salesforce CRM. Used for personalized communications, correspondence, and identity verification.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'Full display name of the contact person (typically first_name + last_name). Sourced directly from Salesforce CRM Name field. Used as the primary human-readable identity label for the contact across logistics operations, EDI communications, and customer service interactions.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentDate rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Date' ;
    rdfs:comment 'Date on which the contact provided or last updated their GDPR data processing consent. Required for audit trail and regulatory compliance demonstration under GDPR Article 7(1).' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdprConsentStatus rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Status' ;
    rdfs:comment 'Current GDPR data processing consent status for the contact. Tracks whether the contact has given, withdrawn, or not yet provided consent for personal data processing. Mandatory for contacts in EU/EEA jurisdictions. Drives data retention and communication eligibility.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAuthorizedSignatory rdf:type rdf:Property ;
    rdfs:label 'Is Authorized Signatory' ;
    rdfs:comment 'Indicates whether this contact is an authorized signatory for shipping contracts, customs declarations, power of attorney for customs brokerage, and trade compliance documents. Critical for Descartes Customs and AEO/C-TPAT compliance validation.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBillingContact rdf:type rdf:Property ;
    rdfs:label 'Is Billing Contact' ;
    rdfs:comment 'Indicates whether this contact is designated to receive invoices, freight charges, and financial communications. Billing contacts receive freight invoices, duty and tax statements, and payment reminders from SAP S/4HANA Finance AR processes.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCustomsContact rdf:type rdf:Property ;
    rdfs:label 'Is Customs Contact' ;
    rdfs:comment 'Indicates whether this contact is the designated point of contact for customs clearance, trade compliance queries, ISF (Importer Security Filing), and AMS (Automated Manifest System) communications. Used by Descartes Customs for routing compliance notifications.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Indicates whether this contact is the designated primary contact for the associated customer account. Only one contact per account should be flagged as primary. Drives default routing for shipment notifications, invoice delivery, and account management communications.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'Professional job title or designation of the contact person within their organization (e.g., Shipping Coordinator, Procurement Manager, Logistics Director, Finance Controller). Used for routing communications to the appropriate decision-maker and for account segmentation analytics.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the most recent logged activity (call, email, meeting, task) associated with this contact in Salesforce CRM. Used to identify dormant contacts, prioritize re-engagement campaigns, and measure account health.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Family name or surname of the contact person as recorded in Salesforce CRM. Combined with first_name to form the full display name for communications and reporting.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadSource rdf:type rdf:Property ;
    rdfs:label 'Lead Source' ;
    rdfs:comment 'Original source or channel through which this contact was acquired or entered the CRM system. Used for marketing attribution, sales pipeline analysis, and customer acquisition cost reporting in Salesforce CRM. [ENUM-REF-CANDIDATE: web|referral|trade_show|partner|cold_call|existing_customer|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedinUrl rdf:type rdf:Property ;
    rdfs:label 'Linkedin Url' ;
    rdfs:comment 'LinkedIn profile URL for the contact person. Used by account management and sales teams for relationship intelligence, opportunity tracking, and professional network engagement within Salesforce CRM.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilePhone rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone' ;
    rdfs:comment 'Mobile or cellular phone number of the contact in E.164 international format. Used for SMS-based shipment tracking alerts, last-mile delivery notifications, and ePOD (Electronic Proof of Delivery) confirmations.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phone rdf:type rdf:Property ;
    rdfs:label 'Phone' ;
    rdfs:comment 'Primary business phone number of the contact in E.164 international format. Used for shipment exception notifications, customs clearance coordination, and direct customer service interactions.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portalUserCode rdf:type rdf:Property ;
    rdfs:label 'Portal User Code' ;
    rdfs:comment 'Identifier for the contact\'s user account in the Transport Shipping customer self-service portal. Links the CRM contact to the portal login for shipment tracking, document retrieval, and service case submission. Enables single-sign-on (SSO) correlation.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Channel' ;
    rdfs:comment 'The contact\'s preferred communication channel for receiving shipment updates, service notifications, and account communications. Drives automated notification routing in TMS and CRM systems.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salutation rdf:type rdf:Property ;
    rdfs:label 'Salutation' ;
    rdfs:comment 'Honorific or salutation prefix for the contact person (e.g., Mr., Ms., Dr.). Used in formal correspondence, shipping documentation, and customer communications to ensure professional address.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentNotificationEligible rdf:type rdf:Property ;
    rdfs:label 'Shipment Notification Eligible' ;
    rdfs:comment 'Indicates whether this contact is subscribed to receive automated shipment status notifications including ETA updates, departure confirmations, POD (Proof of Delivery) alerts, and exception notifications from FourKites or the TMS.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaNotificationEligible rdf:type rdf:Property ;
    rdfs:label 'Sla Notification Eligible' ;
    rdfs:comment 'Indicates whether this contact is configured to receive SLA breach notifications and KPI performance alerts. When true, the contact is included in automated SLA exception communications from the TMS and FourKites visibility platform.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier representing the contact\'s local time zone (e.g., \'America/New_York\', \'Europe/London\', \'Asia/Singapore\'). Used to schedule communications, SLA notifications, and delivery window alerts at appropriate local times.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Account Hierarchy Id' ;
    rdfs:comment 'Unique surrogate identifier for each account hierarchy relationship record in the Transport Shipping customer domain. Primary key for the account_hierarchy data product.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:childAccountCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Child Account Customer Account Id' ;
    rdfs:comment 'Identifier of the child (subsidiary, affiliate, or regional) account in the hierarchy. References the subordinate account linked to the parent for group-level management and revenue roll-up.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:complianceProgramId rdf:type rdf:Property ;
    rdfs:label 'Compliance Program Id' ;
    rdfs:comment 'Foreign key linking to customs.compliance_program. Business justification: Multinational logistics customers manage AEO/C-TPAT compliance at the corporate hierarchy level for group-wide certification. Account hierarchy records must reference the group compliance program for ' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceProgram .

ind:primaryCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Customer Account Id' ;
    rdfs:comment 'Identifier of the parent account in the hierarchy. References the account that sits one level above the child account, enabling enterprise roll-up for consolidated billing and group SLA management.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:rateCardId rdf:type rdf:Property ;
    rdfs:label 'Rate Card Id' ;
    rdfs:comment 'Foreign key linking to pricing.rate_card. Business justification: Account hierarchies with pricing_inheritance_flag=true require a reference to the rate card that applies at the hierarchy level. Consolidated pricing for global corporate accounts — where a parent ent' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateCard .

ind:annualContractedRevenue rdf:type rdf:Property ;
    rdfs:label 'Annual Contracted Revenue' ;
    rdfs:comment 'Total annual contracted revenue committed by the enterprise account group under the master agreement. Used for group-level P&L reporting, EBITDA analysis, and account tier classification in SAP S/4HANA Finance.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:childAccountCount rdf:type rdf:Property ;
    rdfs:label 'Child Account Count' ;
    rdfs:comment 'Number of direct child accounts linked to the parent account at this hierarchy level. Provides a structural summary for account management and hierarchy governance without requiring recursive queries.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consolidationFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidation Flag' ;
    rdfs:comment 'Indicates whether the child account\'s shipment charges and invoices are consolidated into the parent account\'s billing statement. When true, enables group-level invoice generation and payment management in SAP S/4HANA Finance.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countryOfDomicile rdf:type rdf:Property ;
    rdfs:label 'Country Of Domicile' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the parent account\'s legal domicile. Determines applicable trade compliance regulations, customs requirements, and tax jurisdiction for the enterprise group.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditConsolidationFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Consolidation Flag' ;
    rdfs:comment 'Indicates whether the child account\'s credit exposure is pooled with the parent account for group-level credit limit management. When true, credit checks in SAP S/4HANA Finance are evaluated at the parent account level.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crmAccountHierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Crm Account Hierarchy Code' ;
    rdfs:comment 'Salesforce CRM system identifier for the account hierarchy record. Enables cross-system traceability between the lakehouse silver layer and the Salesforce CRM source of record for account management and opportunity tracking.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyRegion rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Region' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country or region code indicating the primary data privacy jurisdiction applicable to the account hierarchy record. Determines GDPR, CCPA, or other regional data protection obligations for customer data handling.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deniedPartyCheckDate rdf:type rdf:Property ;
    rdfs:label 'Denied Party Check Date' ;
    rdfs:comment 'Date on which the most recent denied party and sanctions screening was performed for the enterprise account group. Ensures compliance screening currency per regulatory requirements.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deniedPartyCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Denied Party Check Status' ;
    rdfs:comment 'Result of the most recent denied party and sanctions screening check for the enterprise account group. Managed in Descartes Customs denied party screening module. Flagged accounts require compliance review before shipment execution.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'Date from which the account hierarchy relationship becomes binding and operationally active. Used to manage time-bound corporate restructuring, mergers, and acquisitions in the customer master.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'Date on which the account hierarchy relationship ceases to be binding. Nullable for open-ended relationships. Populated upon corporate restructuring, divestiture, or account termination.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:erpCustomerHierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Erp Customer Hierarchy Code' ;
    rdfs:comment 'SAP S/4HANA Finance customer hierarchy node identifier for the account group. Enables reconciliation between CRM account structures and ERP financial hierarchies for consolidated billing and revenue recognition.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:globalAccountManager rdf:type rdf:Property ;
    rdfs:label 'Global Account Manager' ;
    rdfs:comment 'Name of the Transport Shipping global account manager responsible for the enterprise account hierarchy. Sourced from Salesforce CRM account ownership for escalation routing and relationship management.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Code' ;
    rdfs:comment 'Externally-known business identifier for the account hierarchy relationship, used in Salesforce CRM and SAP S/4HANA Finance for cross-system reference and consolidated billing linkage.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric depth of the child account within the corporate hierarchy tree, where level 1 represents the ultimate parent (global account). Enables multi-tier enterprise account navigation and reporting.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyName rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Name' ;
    rdfs:comment 'Human-readable label for the account hierarchy relationship, typically reflecting the corporate group name (e.g., \'Acme Corp Global Group\'). Used in CRM dashboards and enterprise account reporting.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Path' ;
    rdfs:comment 'Materialized path string representing the full ancestry chain from root to child account (e.g., \'/1001/2045/3087\'). Enables efficient tree traversal queries for enterprise account reporting and consolidated billing without recursive joins.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyStatus rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Status' ;
    rdfs:comment 'Current lifecycle state of the account hierarchy relationship. Controls whether the parent-child linkage is operationally active for billing consolidation, SLA management, and enterprise reporting.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyType rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Type' ;
    rdfs:comment 'Classifies the purpose of the hierarchy structure. Corporate hierarchies reflect legal ownership; billing hierarchies drive consolidated invoicing; operational hierarchies manage service delivery; 3PL/4PL hierarchies manage logistics partner structures.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxHierarchyDepth rdf:type rdf:Property ;
    rdfs:label 'Max Hierarchy Depth' ;
    rdfs:comment 'Maximum number of levels in the account hierarchy subtree rooted at this relationship node. Used for hierarchy validation, UI rendering optimization, and enterprise account structure governance.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'Percentage of ownership or equity stake held by the parent account in the child account. Relevant for subsidiary and joint venture relationships. Used for IFRS 10 consolidation threshold determination and financial reporting.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingInheritanceFlag rdf:type rdf:Property ;
    rdfs:label 'Pricing Inheritance Flag' ;
    rdfs:comment 'Indicates whether the child account inherits the contracted pricing, rate agreements, and GRI exemptions negotiated at the parent account level. Drives tariff application in SAP TM and Oracle TMS.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'Classifies the nature of the parent-child relationship within the account hierarchy. Drives how billing consolidation, SLA inheritance, and revenue roll-up are applied. [ENUM-REF-CANDIDATE: parent|subsidiary|affiliate|regional_division|branch|joint_venture — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restructureReason rdf:type rdf:Property ;
    rdfs:label 'Restructure Reason' ;
    rdfs:comment 'Business reason for the creation or modification of the account hierarchy relationship. Supports audit trail and change management for corporate restructuring events. [ENUM-REF-CANDIDATE: merger|acquisition|divestiture|reorganization|new_subsidiary|account_migration|other — promote to reference product if additional reasons are needed]' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueCurrency rdf:type rdf:Property ;
    rdfs:label 'Revenue Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the annual contracted revenue amount. Ensures consistent multi-currency financial reporting across global enterprise accounts.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRollUpFlag rdf:type rdf:Property ;
    rdfs:label 'Revenue Roll Up Flag' ;
    rdfs:comment 'Indicates whether the child account\'s revenue is rolled up to the parent account for enterprise-level P&L reporting and EBITDA analysis. Enables group revenue visibility in SAP S/4HANA Finance and CRM dashboards.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaInheritanceFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Inheritance Flag' ;
    rdfs:comment 'Indicates whether the child account inherits the SLA entitlements (e.g., OTD targets, OTIF commitments, priority service levels) from the parent account. Drives SLA enforcement and KPI reporting at the group level.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:votingRightsPercentage rdf:type rdf:Property ;
    rdfs:label 'Voting Rights Percentage' ;
    rdfs:comment 'Percentage of voting rights held by the parent account in the child entity. Determines control classification under IFRS 10 (control threshold typically >50%) for financial consolidation and regulatory reporting.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipperProfileId rdf:type rdf:Property ;
    rdfs:label 'Shipper Profile Id' ;
    rdfs:comment 'Unique surrogate identifier for the shipper operational profile record in the customer domain. Primary key for the shipper_profile data product.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShipperProfile .

ind:defaultCarrierServiceId rdf:type rdf:Property ;
    rdfs:label 'Default Carrier Service Id' ;
    rdfs:comment 'Foreign key linking to network.carrier_service. Business justification: shipper_profile has preferred_service_mode as plain text. The default carrier service drives automated booking, rate application, and equipment selection for the shipper. Role-prefixed as default_carr' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarrierService .

ind:defaultOriginAddressBookId rdf:type rdf:Property ;
    rdfs:label 'Default Origin Address Book Id' ;
    rdfs:comment 'Foreign key linking to customer.address_book. Business justification: A shipper profile defines the operational profile for a customer acting as a shipper (origin party). The shipper\'s default pickup/origin address should be stored in the centralized address_book rather' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AddressBook .

ind:defaultOriginNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Default Origin Network Node Id' ;
    rdfs:comment 'Foreign key linking to route.network_node. Business justification: Shippers have default origin nodes for pickup operations. Essential for pickup scheduling, origin facility assignment, route planning, and network capacity management. Replaces denormalized address fi' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:ediPartnerId rdf:type rdf:Property ;
    rdfs:label 'Edi Partner Id' ;
    rdfs:comment 'EDI interchange partner identifier (ISA qualifier + ID) used for automated shipment booking, ASN (Advanced Shipping Notice), and status message exchange between the shipper\'s systems and the TMS/WMS platforms.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:exportAgentId rdf:type rdf:Property ;
    rdfs:label 'Export Agent Id' ;
    rdfs:comment 'Foreign key linking to network.agent. Business justification: shipper_profile has exporter_trade_party_id → customs domain but no network agent FK. The export customs broker/freight agent is a network entity handling export declarations and AES filing. Role-pref' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:exportLicensePermitId rdf:type rdf:Property ;
    rdfs:label 'Export License Permit Id' ;
    rdfs:comment 'Foreign key linking to customs.license_permit. Business justification: Export license and permit management for shippers of controlled, hazmat, or dual-use goods is a regulatory requirement. Logistics systems link shipper profiles to their active export licenses to valid' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LicensePermit .

ind:exporterTradePartyId rdf:type rdf:Property ;
    rdfs:label 'Exporter Trade Party Id' ;
    rdfs:comment 'Foreign key linking to customs.trade_party. Business justification: Shipper profiles represent exporters in customs context. Required for: export declarations, AEO/CTPAT certification validation, denied party screening, and origin determination. Essential for outbound' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeParty .

ind:originTplProviderId rdf:type rdf:Property ;
    rdfs:label 'Origin Tpl Provider Id' ;
    rdfs:comment 'Foreign key linking to network.tpl_provider. Business justification: Shippers use origin 3PLs for pickup, consolidation, and cross-docking. shipper_profile has default_origin_network_node_id but no 3PL FK. Role-prefixed as origin_tpl_provider_id to distinguish from con' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TplProvider .

ind:aeoCertificationExpiry rdf:type rdf:Property ;
    rdfs:label 'Aeo Certification Expiry' ;
    rdfs:comment 'Expiry date of the shipper\'s AEO certification. Used to trigger renewal alerts and to validate AEO status at the time of shipment booking in Descartes Customs.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ctpatCertificationExpiry rdf:type rdf:Property ;
    rdfs:label 'Ctpat Certification Expiry' ;
    rdfs:comment 'Expiry date of the shipper\'s C-TPAT certification. Monitored to ensure continuous compliance eligibility for US cross-border shipments.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:defaultCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Default Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code representing the shipper\'s default billing and invoicing currency. Used in freight charge calculation, COD amounts, and SAP S/4HANA Finance revenue recognition.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultIncoterms rdf:type rdf:Property ;
    rdfs:label 'Default Incoterms' ;
    rdfs:comment 'Default Incoterms rule applied to shipments originated by this shipper. Defines the allocation of costs, risks, and responsibilities between shipper and consignee. Pre-populated on freight orders in SAP TM. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — promote to reference product]' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultPackagingType rdf:type rdf:Property ;
    rdfs:label 'Default Packaging Type' ;
    rdfs:comment 'Shipper\'s default packaging type used for shipment booking and warehouse operations. Drives packaging material selection, DIM weight calculation, and stacking rules in Manhattan WMS and SAP TM.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatCertificationExpiry rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certification Expiry' ;
    rdfs:comment 'Expiry date of the shipper\'s hazmat handling certification. Shipments tendered after this date will be blocked from hazmat routing until recertification is confirmed.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hazmatCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certification Number' ;
    rdfs:comment 'Regulatory certification or registration number authorizing the shipper to tender dangerous goods. Required for IMDG (ocean) and IATA DGR (air) hazmat shipments. Validated in Descartes Customs during shipment booking.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataShipperCode rdf:type rdf:Property ;
    rdfs:label 'Iata Shipper Code' ;
    rdfs:comment 'IATA-assigned shipper identification code used in air freight documentation including House Air Waybills (HAWB) and Master Air Waybills (MAWB). Required for IATA-regulated air cargo bookings.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCodEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Cod Enabled' ;
    rdfs:comment 'Indicates whether Cash on Delivery (COD) is enabled for shipments from this shipper. When true, COD collection instructions are appended to delivery orders and ePOD workflows.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFragileHandlingRequired rdf:type rdf:Property ;
    rdfs:label 'Is Fragile Handling Required' ;
    rdfs:comment 'Indicates whether shipments from this shipper require fragile handling by default. Triggers special handling instructions on freight orders and warehouse pick/pack operations in Manhattan WMS.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazmatAuthorized rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat Authorized' ;
    rdfs:comment 'Indicates whether the shipper is authorized to tender hazardous materials shipments. When true, hazmat-specific handling, documentation, and carrier routing rules are applied. Validated against IMDG Code for ocean and IATA DGR for air shipments.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTemperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Is Temperature Controlled' ;
    rdfs:comment 'Indicates whether this shipper regularly tenders temperature-controlled (cold chain) shipments. When true, temperature-controlled handling, equipment, and carrier capabilities are applied by default in SAP TM routing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationChannel rdf:type rdf:Property ;
    rdfs:label 'Notification Channel' ;
    rdfs:comment 'Preferred channel for shipment status notifications and alerts (e.g., booking confirmation, ETA updates, POD). EDI indicates Electronic Data Interchange integration; webhook indicates API-based push notifications via FourKites or TMS integrations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationEmail rdf:type rdf:Property ;
    rdfs:label 'Notification Email' ;
    rdfs:comment 'Primary email address for shipment status notifications, booking confirmations, and exception alerts. Used when notification_channel is set to email. Subject to GDPR consent management.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationPhone rdf:type rdf:Property ;
    rdfs:label 'Notification Phone' ;
    rdfs:comment 'Mobile phone number for SMS-based shipment notifications and alerts. Used when notification_channel is set to sms. Must be in E.164 international format.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLoadType rdf:type rdf:Property ;
    rdfs:label 'Preferred Load Type' ;
    rdfs:comment 'Shipper\'s default load consolidation preference. FTL (Full Truckload) and LTL (Less Than Truckload) apply to road freight; FCL (Full Container Load) and LCL (Less Than Container Load) apply to ocean freight. Used in load optimization in Oracle TMS.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileEffectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Profile Effective From' ;
    rdfs:comment 'Date from which this shipper profile becomes operationally active and eligible for shipment booking. Supports time-bounded profile management and contract-aligned activation.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:profileEffectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Profile Effective Until' ;
    rdfs:comment 'Date after which this shipper profile is no longer operationally active. Null indicates an open-ended profile with no planned expiry. Used to enforce time-bounded shipper authorizations.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current lifecycle status of the shipper profile. Active profiles are eligible for shipment booking. Suspended profiles are temporarily blocked. Blacklisted profiles are permanently barred due to compliance violations or fraud. Drives booking eligibility checks in SAP TM and Oracle TMS.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceAccountCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Account Code' ;
    rdfs:comment 'Salesforce CRM Account object identifier for the shipper. Enables cross-system traceability between the operational shipper profile and the CRM account record for opportunity tracking, service cases, and customer communications.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCustomerNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Customer Number' ;
    rdfs:comment 'SAP S/4HANA Finance and SAP TM customer master number for the shipper. Used for freight charge calculation, accounts receivable posting, and revenue recognition. Enables reconciliation between TMS and ERP financial records.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTier rdf:type rdf:Property ;
    rdfs:label 'Sla Tier' ;
    rdfs:comment 'SLA entitlement tier assigned to the shipper, determining priority handling, On-Time Delivery (OTD) targets, exception escalation thresholds, and dedicated account management levels. Sourced from Salesforce CRM contract records.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Free-text field capturing any additional special handling requirements for shipments from this shipper that are not covered by structured flags (e.g., \'Do not stack\', \'Keep upright\', \'Requires liftgate at delivery\'). Appended to freight orders in SAP TM.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRangeMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max Celsius' ;
    rdfs:comment 'Maximum acceptable temperature in degrees Celsius for temperature-controlled shipments from this shipper. Used alongside the minimum to define the acceptable cold chain envelope for carrier and equipment selection.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min Celsius' ;
    rdfs:comment 'Minimum acceptable temperature in degrees Celsius for temperature-controlled shipments from this shipper. Used to specify cold chain equipment requirements and validate carrier capabilities.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'Operating or doing-business-as (DBA) trade name of the shipper, which may differ from the legal name. Used for customer-facing communications and account management in Salesforce CRM.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:webhookEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Webhook Endpoint Url' ;
    rdfs:comment 'HTTPS endpoint URL registered by the shipper to receive real-time shipment event push notifications via webhook. Used when notification_channel is set to webhook. Must use HTTPS for security compliance.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneeProfileId rdf:type rdf:Property ;
    rdfs:label 'Consignee Profile Id' ;
    rdfs:comment 'Unique surrogate identifier for the consignee profile record in the Transport Shipping data platform. Primary key for the consignee_profile entity.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsigneeProfile .

ind:customsAgentId rdf:type rdf:Property ;
    rdfs:label 'Customs Agent Id' ;
    rdfs:comment 'Foreign key linking to network.agent. Business justification: consignee_profile has customs_broker_code as plain text. The import customs agent/broker is a network agent entity handling clearance for the consignee. Role-prefixed as customs_agent_id. customs_brok' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:deliveryAddressBookId rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Book Id' ;
    rdfs:comment 'Foreign key linking to customer.address_book. Business justification: A consignee profile represents the destination recipient in a logistics shipment. The consignee\'s delivery address should be stored in the centralized address_book for address validation, geocoding ac' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AddressBook .

ind:deliveryNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Delivery Network Node Id' ;
    rdfs:comment 'Foreign key linking to route.network_node. Business justification: Consignees have delivery location nodes for last-mile routing. Required for delivery scheduling, route optimization, last-mile zone assignment, and delivery promise calculation. Replaces denormalized ' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:importLicensePermitId rdf:type rdf:Property ;
    rdfs:label 'Import License Permit Id' ;
    rdfs:comment 'Foreign key linking to customs.license_permit. Business justification: Import license management is a core customs compliance process for consignees importing restricted or controlled goods. Logistics operators must link consignee profiles to their active import license/' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LicensePermit .

ind:importerTradePartyId rdf:type rdf:Property ;
    rdfs:label 'Importer Trade Party Id' ;
    rdfs:comment 'Foreign key linking to customs.trade_party. Business justification: Consignee profiles represent importers/receivers in customs. Required for: import declarations, customs broker assignment, duty assessment, and delivery clearance. Critical for inbound customs operati' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeParty .

ind:primaryContactId rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: A consignee profile has a designated primary contact person for delivery coordination (signature requirements, appointment scheduling, ePOD). The consignee_profile currently stores primary_contact_ema' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:routeDeliveryZoneId rdf:type rdf:Property ;
    rdfs:label 'Route Delivery Zone Id' ;
    rdfs:comment 'Foreign key linking to route.route_delivery_zone. Business justification: Consignee profiles are mapped to delivery zones for last-mile routing, residential/remote surcharge application, and delivery window scheduling. Zone assignment is fundamental to last-mile logistics o' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RouteDeliveryZone .

ind:asnRequired rdf:type rdf:Property ;
    rdfs:label 'Asn Required' ;
    rdfs:comment 'Indicates whether the consignee requires an Advanced Shipping Notice (ASN) to be transmitted via EDI prior to shipment arrival. When True, ASN generation is triggered in the WMS/TMS integration layer.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consigneeType rdf:type rdf:Property ;
    rdfs:label 'Consignee Type' ;
    rdfs:comment 'Classification of the consignee indicating the nature of the receiving party. Drives SLA entitlements, customs handling rules, and delivery workflows. B2B enterprise and 3PL/4PL partners are recurring; B2C individual may be one-time last-mile recipients. [ENUM-REF-CANDIDATE: b2b_enterprise|b2c_individual|3pl_partner|4pl_partner|government|nvocc|freight_forwarder|broker — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctpatStatus rdf:type rdf:Property ;
    rdfs:label 'Ctpat Status' ;
    rdfs:comment 'C-TPAT membership status of the consignee as maintained in Descartes Customs. Certified status qualifies the consignee for reduced US CBP examination rates and expedited cargo release.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ddpAuthorized rdf:type rdf:Property ;
    rdfs:label 'Ddp Authorized' ;
    rdfs:comment 'Indicates whether the consignee has authorized Transport Shipping to arrange DDP (Delivered Duty Paid) shipments on their behalf, where the shipper or carrier pre-pays import duties and taxes. Relevant for cross-border e-commerce fulfillment.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deniedPartyScreenResult rdf:type rdf:Property ;
    rdfs:label 'Denied Party Screen Result' ;
    rdfs:comment 'Outcome of the most recent denied-party screening check. A match_found or blocked result prevents shipment processing until compliance review is completed.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deniedPartyScreenedAt rdf:type rdf:Property ;
    rdfs:label 'Denied Party Screened At' ;
    rdfs:comment 'Timestamp of the most recent denied-party screening check performed against this consignee in Descartes Customs. Required for trade compliance audit trails under US EAR, OFAC, and EU dual-use regulations.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:epodContactEmail rdf:type rdf:Property ;
    rdfs:label 'Epod Contact Email' ;
    rdfs:comment 'Dedicated email address to which electronic proof of delivery (ePOD) documents are transmitted upon successful delivery. May differ from the primary contact email when a separate receiving or logistics team handles POD acknowledgment.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epodContactPhone rdf:type rdf:Property ;
    rdfs:label 'Epod Contact Phone' ;
    rdfs:comment 'Mobile or direct phone number for the ePOD recipient contact, used by drivers and last-mile couriers to confirm delivery and obtain digital signature authorization.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoLatitude rdf:type rdf:Property ;
    rdfs:label 'Geo Latitude' ;
    rdfs:comment 'GPS latitude coordinate of the consignee delivery location in decimal degrees (WGS84). Used by FourKites for geofencing, last-mile ETA prediction, and proof-of-delivery geo-stamping.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geoLongitude rdf:type rdf:Property ;
    rdfs:label 'Geo Longitude' ;
    rdfs:comment 'GPS longitude coordinate of the consignee delivery location in decimal degrees (WGS84). Used alongside latitude for geofencing and route optimization in SAP TM and FourKites.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:idVerificationRequired rdf:type rdf:Property ;
    rdfs:label 'Id Verification Required' ;
    rdfs:comment 'Indicates whether the consignee must present government-issued identification at the time of delivery. Applicable for high-value shipments, controlled goods, or regulatory requirements.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incotermsPreference rdf:type rdf:Property ;
    rdfs:label 'Incoterms Preference' ;
    rdfs:comment 'Consignee\'s preferred Incoterms rule governing the transfer of risk and cost responsibility for import shipments. Incoterms 2020 standard. Drives duty and tax liability assignment in customs declarations. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRecurring rdf:type rdf:Property ;
    rdfs:label 'Is Recurring' ;
    rdfs:comment 'Indicates whether this consignee is a recurring destination party (True) or a one-time recipient such as a B2C last-mile delivery addressee (False). Drives profile retention and SLA assignment logic.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Notification Language Code' ;
    rdfs:comment 'IETF BCP 47 language tag representing the consignee\'s preferred language for shipment notifications, delivery alerts, and ePOD communications (e.g., en-US, fr-FR, zh-CN).' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the consignee\'s preferred billing and invoicing currency for duty, tax, and freight charge settlements.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredDeliveryDays rdf:type rdf:Property ;
    rdfs:label 'Preferred Delivery Days' ;
    rdfs:comment 'Comma-separated list of preferred delivery days of the week (e.g., MON,TUE,WED,THU,FRI). Used by last-mile scheduling to avoid unattended delivery attempts and reduce failed delivery rates.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredDeliveryWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Preferred Delivery Window End' ;
    rdfs:comment 'Consignee-preferred latest time of day (HH:MM, 24-hour format) for delivery attempts. Defines the close of the acceptable delivery window for last-mile scheduling.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredDeliveryWindowStart rdf:type rdf:Property ;
    rdfs:label 'Preferred Delivery Window Start' ;
    rdfs:comment 'Consignee-preferred earliest time of day (HH:MM, 24-hour format) for delivery attempts. Used by last-mile routing engines in Oracle TMS and SAP TM to schedule delivery slots within SLA windows.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileCreatedAt rdf:type rdf:Property ;
    rdfs:label 'Profile Created At' ;
    rdfs:comment 'Timestamp when the consignee profile record was first created in the Transport Shipping data platform. Represents the record audit creation event for lineage and compliance tracking.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:profileUpdatedAt rdf:type rdf:Property ;
    rdfs:label 'Profile Updated At' ;
    rdfs:comment 'Timestamp of the most recent update to the consignee profile record. Used for change data capture (CDC) in the Databricks Silver layer and audit trail compliance.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requiresAppointment rdf:type rdf:Property ;
    rdfs:label 'Requires Appointment' ;
    rdfs:comment 'Indicates whether the consignee requires a pre-scheduled delivery appointment before a driver can attempt delivery. True triggers appointment scheduling workflow in Oracle TMS.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatureRequired rdf:type rdf:Property ;
    rdfs:label 'Signature Required' ;
    rdfs:comment 'Indicates whether a consignee signature is mandatory for proof of delivery (POD). When True, drivers must capture a digital signature via ePOD before completing the delivery event.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialDeliveryInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Delivery Instructions' ;
    rdfs:comment 'Free-text field capturing consignee-specific delivery instructions such as dock number, gate access codes, forklift requirements, temperature-controlled unloading bay, or security check-in procedures.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Id Number' ;
    rdfs:comment 'Government-issued tax identification number (TIN, VAT number, EIN, or equivalent) for the consignee. Required for customs declarations, duty invoicing, and trade compliance filings in Descartes Customs.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseDockNumber rdf:type rdf:Property ;
    rdfs:label 'Warehouse Dock Number' ;
    rdfs:comment 'Specific dock door or bay number at the consignee\'s receiving facility. Used by drivers and Manhattan WMS for directed unloading and dock scheduling.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressBookId rdf:type rdf:Property ;
    rdfs:label 'Address Book Id' ;
    rdfs:comment 'Unique surrogate identifier for each address record in the centralized address book. Primary key for the address_book data product.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:networkNodeId rdf:type rdf:Property ;
    rdfs:label 'Network Node Id' ;
    rdfs:comment 'Foreign key linking to route.network_node. Business justification: Customer addresses map to network nodes for routing and planning. Powers address-to-node geocoding, route optimization, network design, and facility assignment. Essential for translating customer loca' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:addressCode rdf:type rdf:Property ;
    rdfs:label 'Address Code' ;
    rdfs:comment 'Externally-known unique business identifier or short code assigned to this address record, used in shipment booking, EDI transactions, and TMS integrations (e.g., SAP TM location code, Oracle TMS address code). Enables cross-system address referencing.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLabel rdf:type rdf:Property ;
    rdfs:label 'Address Label' ;
    rdfs:comment 'Human-readable display name or alias for this address record (e.g., \'London Heathrow Warehouse\', \'NYC HQ Billing\', \'Shanghai Port CFS\'). Used in shipment booking UIs, ePOD systems, and customer-facing communications to identify addresses without displaying full address details.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address line including building number, street name, and any suite or unit designation. This is the first and most critical line of the physical address used on shipping labels, AWBs, BOLs, and customs declarations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address line for additional location details such as floor number, building name, industrial estate, or complex name. Optional field used when the primary address line is insufficient to uniquely identify the delivery location.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine3 rdf:type rdf:Property ;
    rdfs:label 'Address Line 3' ;
    rdfs:comment 'Tertiary address line for additional location context such as district, neighborhood, or landmark reference. Commonly used in international addresses where additional geographic context is required for customs or last-mile delivery.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressRole rdf:type rdf:Property ;
    rdfs:label 'Address Role' ;
    rdfs:comment 'Functional role this address plays in logistics operations. An address may be classified as an origin pickup location, delivery destination, billing address, return address, warehouse address, or notify party address. A single physical address may have multiple roles across different shipments. [ENUM-REF-CANDIDATE: origin|destination|billing|return|warehouse|notify_party — promote to reference product]' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressStatus rdf:type rdf:Property ;
    rdfs:label 'Address Status' ;
    rdfs:comment 'Current lifecycle state of the address record. Active addresses are available for shipment booking. Pending_validation addresses are awaiting address verification. Deprecated addresses are retained for historical reference but not available for new bookings. Blacklisted addresses are blocked due to compliance or fraud concerns.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressType rdf:type rdf:Property ;
    rdfs:label 'Address Type' ;
    rdfs:comment 'Classification of the physical address by its operational nature. Drives last-mile delivery rules, customs declaration requirements, and carrier surcharge logic. Residential addresses may attract residential delivery surcharges; port/airport addresses trigger terminal handling charge (THC) logic. [ENUM-REF-CANDIDATE: residential|commercial|warehouse|port|airport|border_crossing|free_trade_zone — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City or municipality name of the address. Used in route planning, carrier zone determination, customs declarations, and last-mile delivery assignment. Critical for TMS routing and freight rate calculation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyName rdf:type rdf:Property ;
    rdfs:label 'Company Name' ;
    rdfs:comment 'Name of the company, organization, or business entity at this address. Required for commercial shipments, customs declarations, and B2B delivery. Used on shipping labels, air waybills (AWB), bills of lading (BOL), and customs documentation.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Email address of the primary contact at this address. Used for shipment notifications, electronic proof of delivery (ePOD) dispatch, customs pre-arrival notifications, and delivery exception alerts.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactName rdf:type rdf:Property ;
    rdfs:label 'Contact Name' ;
    rdfs:comment 'Full name of the primary contact person at this address. Used for last-mile delivery coordination, customs notifications, and proof of delivery (POD) capture. Required for residential and commercial delivery addresses.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Primary telephone number for the contact person at this address, in E.164 international format. Used for last-mile delivery notifications, exception management, and customs clearance coordination. Required by many carriers for residential delivery.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsZone rdf:type rdf:Property ;
    rdfs:label 'Customs Zone' ;
    rdfs:comment 'Customs and trade compliance zone classification for this address. Free Trade Zone (FTZ) and bonded warehouse addresses require special customs handling in Descartes Customs. Special Economic Zone (SEZ) addresses may have preferential duty treatment. Drives customs declaration routing and duty calculation.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dangerousGoodsPermitted rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Permitted' ;
    rdfs:comment 'Indicates whether dangerous goods (DG) shipments are permitted at this address. When False, the TMS and booking systems will block DG shipments to/from this address. Governed by IMDG Code for ocean, ICAO Technical Instructions for air, and ADR/RID for road/rail transport.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryWindowClose rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Close' ;
    rdfs:comment 'Latest time of day (HH:MM in 24-hour format) when deliveries or pickups are accepted at this address. Used alongside delivery_window_open to define the acceptable delivery time window for route planning and SLA management.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryWindowOpen rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Open' ;
    rdfs:comment 'Earliest time of day (HH:MM in 24-hour format) when deliveries or pickups are accepted at this address. Used by TMS route optimization to schedule delivery windows and ensure SLA compliance. Critical for warehouse and commercial addresses with restricted receiving hours.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Type of logistics facility at this address when applicable. Drives specialized handling requirements in Manhattan WMS, carrier selection in SAP TM, and customs processing in Descartes. Cold storage facilities require temperature-controlled transport; bonded warehouses require customs bond management. [ENUM-REF-CANDIDATE: distribution_center|cross_dock|cold_storage|bonded_warehouse|cfs|icd|airport_cargo|seaport_terminal — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geocodingAccuracy rdf:type rdf:Property ;
    rdfs:label 'Geocoding Accuracy' ;
    rdfs:comment 'Precision level of the geocoded latitude/longitude coordinates. Rooftop indicates exact building-level precision; range_interpolated is street-level; geometric_center is centroid of a postal area; approximate is city/region level; unverified means coordinates have not been validated. Drives confidence in GPS-based routing and geofencing.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsCodeRestriction rdf:type rdf:Property ;
    rdfs:label 'Hs Code Restriction' ;
    rdfs:comment 'Comma-separated list of HS Code prefixes (Harmonized System codes per WCO) that are restricted or prohibited at this address due to local regulations, facility licensing, or trade compliance requirements. Used by Descartes Customs to flag non-compliant shipments during booking.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultBilling rdf:type rdf:Property ;
    rdfs:label 'Is Default Billing' ;
    rdfs:comment 'Indicates whether this address is the customer\'s default billing address for invoice generation and accounts receivable processing in SAP S/4HANA Finance. When True, this address is used for all financial documents unless overridden at the shipment level.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefaultDestination rdf:type rdf:Property ;
    rdfs:label 'Is Default Destination' ;
    rdfs:comment 'Indicates whether this address is the customer\'s default delivery destination. When True, this address is pre-populated as the destination in shipment booking workflows, supporting frequent lane customers and e-commerce fulfillment automation.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefaultOrigin rdf:type rdf:Property ;
    rdfs:label 'Is Default Origin' ;
    rdfs:comment 'Indicates whether this address is the customer\'s default pickup/origin location for shipment booking. When True, this address is pre-populated as the origin in shipment booking workflows in SAP TM and Oracle TMS, reducing data entry errors.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isResidential rdf:type rdf:Property ;
    rdfs:label 'Is Residential' ;
    rdfs:comment 'Indicates whether this address is classified as a residential location. Residential addresses trigger carrier-specific residential delivery surcharges (e.g., FedEx, UPS residential fees), require different last-mile delivery protocols, and may affect SLA commitments for D2D (door-to-door) services.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the address in decimal degrees (WGS84 datum), ranging from -90 to +90. Used for GPS-based last-mile routing, geofencing in FourKites real-time visibility, proximity-based warehouse assignment, and route optimization in TMS.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the address in decimal degrees (WGS84 datum), ranging from -180 to +180. Used alongside latitude for GPS-based routing, geofencing, real-time shipment tracking, and network design optimization in Blue Yonder.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the address. Used for carrier zone mapping, freight rate calculation, last-mile delivery routing, dimensional weight (DIM weight) zone surcharges, and address validation. Format varies by country.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemAddressCode rdf:type rdf:Property ;
    rdfs:label 'Source System Address Code' ;
    rdfs:comment 'Native identifier of this address record in the originating operational system (e.g., Salesforce CRM Address ID, SAP TM Location ID, Oracle TMS Address Code). Enables bidirectional synchronization, change data capture (CDC), and cross-system reconciliation during EDI processing.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Free-text field for special handling or access instructions at this address (e.g., \'Deliver to loading dock B\', \'Call 30 minutes before arrival\', \'Gate code: 1234\', \'No deliveries before 08:00\'). Transmitted to last-mile carriers and drivers via TMS dispatch notes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardizedAddress rdf:type rdf:Property ;
    rdfs:label 'Standardized Address' ;
    rdfs:comment 'Full normalized and standardized address string as returned by the address validation provider, conforming to postal authority formatting rules. Used as the canonical address for printing on shipping labels, AWBs, and customs declarations to ensure deliverability.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, or administrative region of the address using ISO 3166-2 subdivision codes where applicable. Required for domestic routing, tax jurisdiction determination, and US/Canada customs filings (AMS, ISF).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timezone rdf:type rdf:Property ;
    rdfs:label 'Timezone' ;
    rdfs:comment 'IANA timezone identifier for the address location (e.g., \'America/New_York\', \'Europe/London\', \'Asia/Shanghai\'). Used to correctly interpret delivery windows, calculate ETA/ETD in local time, and schedule last-mile delivery notifications across global operations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationProvider rdf:type rdf:Property ;
    rdfs:label 'Validation Provider' ;
    rdfs:comment 'Name of the third-party address validation service or postal authority database used to validate this address (e.g., USPS, Loqate, SmartyStreets, Google Maps, HERE). Enables audit trail for address quality and supports provider performance benchmarking.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Result of the address standardization and validation process against postal authority databases (e.g., USPS, Royal Mail, Deutsche Post). Validated addresses have been confirmed deliverable. Failed addresses contain errors. Partial addresses are incomplete but usable. Used to enforce address quality gates in shipment booking workflows.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validation Timestamp' ;
    rdfs:comment 'Date and time when the address was last validated against a postal authority or address verification service. Used to determine if re-validation is required based on address data freshness policies.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:primaryTradeLaneId rdf:type rdf:Property ;
    rdfs:label 'Primary Trade Lane Id' ;
    rdfs:comment 'Foreign key linking to route.lane. Business justification: Customer segments are scoped to primary trade lanes (e.g., Asia-Pacific exporters). Segment has primary_trade_lane as a denormalized text field — replacing with a proper FK enables lane-level segment ' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lane .

ind:tariffId rdf:type rdf:Property ;
    rdfs:label 'Tariff Id' ;
    rdfs:comment 'Foreign key linking to pricing.tariff. Business justification: Customer segments reference standard published tariffs for regulatory compliance and baseline pricing. In transport logistics, segments often map to tariff classes (e.g., retail vs wholesale). Require' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tariff .

ind:accountManagementModel rdf:type rdf:Property ;
    rdfs:label 'Account Management Model' ;
    rdfs:comment 'Defines the assigned account management approach for customers in this segment: STRATEGIC = dedicated named account manager with executive sponsorship; COMMERCIAL = shared account management team; DIGITAL = digital-first with inside sales support; SELF_SERVE = fully automated self-service with no dedicated account manager.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiAccessEligible rdf:type rdf:Property ;
    rdfs:label 'Api Access Eligible' ;
    rdfs:comment 'Indicates whether customers in this segment are entitled to direct API (Application Programming Interface) access to Transport Shipping\'s TMS and WMS platforms for automated shipment booking, tracking, and reporting.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'Date on which this segment definition was formally approved by the designated commercial authority. Used for audit trail, governance reporting, and SOX compliance.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commercialTier rdf:type rdf:Property ;
    rdfs:label 'Commercial Tier' ;
    rdfs:comment 'Commercial tier classification indicating the level of service, pricing, and account management investment assigned to this segment. STRATEGIC = top-tier enterprise accounts with dedicated account teams; PREMIUM = high-value accounts with enhanced SLAs; STANDARD = mid-market accounts; BASIC = transactional accounts; DIGITAL = self-serve digital-only accounts.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitUsd rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Usd' ;
    rdfs:comment 'Maximum credit exposure in USD extended to customers within this segment. Used by SAP S/4HANA Finance Accounts Receivable for credit control and order release decisions. Confidential financial data.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crmSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Crm Segment Code' ;
    rdfs:comment 'External identifier for this segment record in Salesforce CRM (15 or 18-character Salesforce record ID). Used for cross-system reconciliation between the Databricks Silver Layer and the Salesforce CRM source of record.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsFacilitationLevel rdf:type rdf:Property ;
    rdfs:label 'Customs Facilitation Level' ;
    rdfs:comment 'Level of customs clearance facilitation entitlement for customers in this segment. AEO_FAST_TRACK applies to segments serving Authorized Economic Operator (AEO) certified customers eligible for expedited customs processing via Descartes Customs.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dangerousGoodsEligible rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Eligible' ;
    rdfs:comment 'Indicates whether customers in this segment are eligible to ship dangerous goods (DG) under IATA Dangerous Goods Regulations (DGR) and IMDG Code. When TRUE, additional compliance checks and documentation requirements apply.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dedicatedWarehouseEligible rdf:type rdf:Property ;
    rdfs:label 'Dedicated Warehouse Eligible' ;
    rdfs:comment 'Indicates whether customers in this segment qualify for dedicated warehouse space and labour allocation within Transport Shipping\'s distribution network, as managed by Manhattan WMS.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discountTierCode rdf:type rdf:Property ;
    rdfs:label 'Discount Tier Code' ;
    rdfs:comment 'Code referencing the discount tier applicable to this segment, governing base rate reductions, General Rate Increase (GRI) exemptions, Bunker Adjustment Factor (BAF) caps, and Terminal Handling Charge (THC) waivers. Confidential as it reflects commercial negotiation outcomes.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecommerceFulfillmentEligible rdf:type rdf:Property ;
    rdfs:label 'Ecommerce Fulfillment Eligible' ;
    rdfs:comment 'Indicates whether customers in this segment are entitled to access e-commerce fulfillment services including last-mile delivery, returns management (RMA), and Advanced Shipping Notice (ASN) processing.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediIntegrationRequired rdf:type rdf:Property ;
    rdfs:label 'Edi Integration Required' ;
    rdfs:comment 'Indicates whether customers in this segment are required to exchange transactional data (shipment orders, ASNs, invoices) via Electronic Data Interchange (EDI). Drives onboarding and integration requirements.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibleServiceLines rdf:type rdf:Property ;
    rdfs:label 'Eligible Service Lines' ;
    rdfs:comment 'Comma-separated list of logistics service lines that customers in this segment are eligible to access (e.g., \'EXPRESS_PARCEL,FREIGHT_AIR,FREIGHT_OCEAN,CUSTOMS_BROKERAGE,ECOMMERCE_FULFILLMENT\'). Governs service entitlement and product catalogue access. [ENUM-REF-CANDIDATE: EXPRESS_PARCEL|FREIGHT_AIR|FREIGHT_OCEAN|FREIGHT_ROAD|FREIGHT_RAIL|CUSTOMS_BROKERAGE|WAREHOUSE|ECOMMERCE_FULFILLMENT|LAST_MILE|CONTRACT_LOGISTICS — promote to reference product]' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Erp Segment Code' ;
    rdfs:comment 'Segment code as recorded in SAP S/4HANA Finance for revenue allocation, cost center assignment, and P&L reporting by customer segment. Enables financial reporting alignment between the data lakehouse and ERP.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceFrequency rdf:type rdf:Property ;
    rdfs:label 'Invoice Frequency' ;
    rdfs:comment 'Frequency at which invoices are generated and issued to customers in this segment. Drives billing cycle configuration in SAP S/4HANA Finance and impacts cash flow planning.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otdTargetPct rdf:type rdf:Property ;
    rdfs:label 'Otd Target Pct' ;
    rdfs:comment 'Contractual On-Time Delivery (OTD) performance target expressed as a percentage (0.00–100.00) for customers in this segment. Used in KPI reporting, SLA compliance monitoring, and carrier performance management.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifTargetPct rdf:type rdf:Property ;
    rdfs:label 'Otif Target Pct' ;
    rdfs:comment 'Contractual On-Time In-Full (OTIF) performance target expressed as a percentage (0.00–100.00) for customers in this segment. Measures both delivery timeliness and order completeness. Used in supply chain performance reporting.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredTransportMode rdf:type rdf:Property ;
    rdfs:label 'Preferred Transport Mode' ;
    rdfs:comment 'Primary transport mode preference for customers in this segment (AIR, OCEAN, ROAD, RAIL, or MULTIMODAL). Used in SAP TM carrier selection and route planning to pre-configure default routing for segment accounts.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingModelCode rdf:type rdf:Property ;
    rdfs:label 'Pricing Model Code' ;
    rdfs:comment 'Code identifying the pricing model applied to customers in this segment (e.g., CONTRACTED_RATE, SPOT_RATE, VOLUME_DISCOUNT, TARIFF_PUBLISHED). Drives charge calculation in SAP TM and Oracle TMS. Confidential as it reflects commercial pricing strategy.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:realTimeVisibilityEligible rdf:type rdf:Property ;
    rdfs:label 'Real Time Visibility Eligible' ;
    rdfs:comment 'Indicates whether customers in this segment are entitled to real-time shipment tracking and predictive ETA services via FourKites. Typically reserved for STRATEGIC and PREMIUM commercial tiers.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueBandMaxUsd rdf:type rdf:Property ;
    rdfs:label 'Revenue Band Max Usd' ;
    rdfs:comment 'Maximum annualised revenue threshold in USD defining the upper boundary of this segment\'s revenue band. NULL indicates an open-ended upper bound (e.g., for the highest-tier segment). Used alongside revenue_band_min_usd for segment qualification.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueBandMinUsd rdf:type rdf:Property ;
    rdfs:label 'Revenue Band Min Usd' ;
    rdfs:comment 'Minimum annualised revenue threshold in USD that a customer account must meet to qualify for this segment. Used in segment assignment logic and periodic segment review cycles. Expressed in USD for global comparability.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewCriteria rdf:type rdf:Property ;
    rdfs:label 'Review Criteria' ;
    rdfs:comment 'Narrative description of the criteria used during the segment review cycle to determine whether a customer account should be upgraded, downgraded, or retained in this segment (e.g., revenue performance, shipment volume, strategic partnership status).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycle rdf:type rdf:Property ;
    rdfs:label 'Review Cycle' ;
    rdfs:comment 'Frequency at which customer accounts assigned to this segment are reviewed for re-segmentation based on updated revenue, volume, and strategic criteria. Drives the account management review calendar in Salesforce CRM.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the customer segment (e.g., ENT-GOLD, SME-SILVER, B2C-STANDARD). Used as the business key across CRM, TMS, and billing systems. Sourced from Salesforce CRM account segmentation module.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Detailed narrative description of the segment\'s commercial profile, target customer characteristics, and strategic intent. Used for onboarding account managers and informing pricing strategy.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable name of the customer segment (e.g., \'Enterprise Gold\', \'SME Silver\', \'B2C Standard\'). Used in reporting dashboards, account management workflows, and commercial strategy documents.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle status of the segment definition: ACTIVE = in use for customer assignment and pricing; INACTIVE = suspended from new customer assignments; DRAFT = under review and not yet published; DEPRECATED = retired segment retained for historical reporting only.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Broad classification of the segment by customer relationship type: B2B (business-to-business enterprise accounts), B2C (individual consumer shippers), 3PL (Third-Party Logistics partners), 4PL (Fourth-Party Logistics orchestrators), GOVERNMENT (public sector entities), or INTERNAL (intra-company accounts).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentVolumeBandMax rdf:type rdf:Property ;
    rdfs:label 'Shipment Volume Band Max' ;
    rdfs:comment 'Maximum annualised shipment volume (number of shipments) defining the upper boundary of this segment\'s volume band. NULL indicates open-ended upper bound for the highest-volume segment tier.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shipmentVolumeBandMin rdf:type rdf:Property ;
    rdfs:label 'Shipment Volume Band Min' ;
    rdfs:comment 'Minimum annualised shipment volume (number of shipments) threshold for segment qualification. Complements revenue thresholds for volume-based segmentation used in logistics pricing and SLA assignment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sustainabilityReportingEligible rdf:type rdf:Property ;
    rdfs:label 'Sustainability Reporting Eligible' ;
    rdfs:comment 'Indicates whether customers in this segment are entitled to receive Carbon Dioxide Equivalent (CO2e) and Greenhouse Gas (GHG) emissions reporting for their shipments. Supports customer ESG compliance and EU ETS reporting obligations.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnerId rdf:type rdf:Property ;
    rdfs:label 'Partner Id' ;
    rdfs:comment 'Foreign key linking to network.partner. Business justification: Freight forwarders and 3PLs (network partners) are often contractually responsible for SLA delivery, distinct from carriers. SLA entitlements with freight forwarder partners require a partner FK for p' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:reportingContactId rdf:type rdf:Property ;
    rdfs:label 'Reporting Contact Id' ;
    rdfs:comment 'Reference to the primary customer contact who receives SLA performance reports and is the designated recipient for escalation notifications under this entitlement.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:serviceCorridorId rdf:type rdf:Property ;
    rdfs:label 'Service Corridor Id' ;
    rdfs:comment 'Foreign key linking to route.service_corridor. Business justification: SLA entitlements are scoped to service corridors (e.g., Asia-Europe express). Corridor-level SLA reporting and customer commitment tracking require this link. Logistics domain experts expect entitleme' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceCorridor .

ind:slaCommitmentId rdf:type rdf:Property ;
    rdfs:label 'Sla Commitment Id' ;
    rdfs:comment 'Foreign key linking to contract.contract_sla_commitment. Business justification: Customer SLA entitlements must be traceable to the specific contract SLA commitment that backs them. Compliance audits, SLA breach investigations, and penalty calculations require verifying that each ' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaCommitment .

ind:transitTimeStandardId rdf:type rdf:Property ;
    rdfs:label 'Transit Time Standard Id' ;
    rdfs:comment 'Foreign key linking to route.transit_time_standard. Business justification: SLA compliance measurement requires linking customer entitlements to the published transit time standard they are measured against. Logistics KPI reporting (OTD, OTIF) depends on comparing actual vs. ' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransitTimeStandard .

ind:autoRenewal rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal' ;
    rdfs:comment 'Indicates whether this SLA entitlement automatically renews at the end of the effective period without requiring explicit renegotiation. When True, the entitlement rolls over under the same terms unless terminated.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:claimsResolutionSlaDays rdf:type rdf:Property ;
    rdfs:label 'Claims Resolution Sla Days' ;
    rdfs:comment 'Maximum number of calendar days within which a cargo claim must be acknowledged, investigated, and resolved under this SLA entitlement. Drives claims team prioritization and escalation triggers.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crmEntitlementCode rdf:type rdf:Property ;
    rdfs:label 'Crm Entitlement Code' ;
    rdfs:comment 'Source system identifier for this SLA entitlement record in Salesforce CRM. Enables traceability and reconciliation between the lakehouse silver layer and the operational CRM system of record.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTimeWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Delivery Time Window End' ;
    rdfs:comment 'Latest time of day (HH:MM, 24-hour local time) by which delivery must be completed to be considered on-time under this SLA entitlement. Defines the close of the delivery window for time-definite commitments.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTimeWindowStart rdf:type rdf:Property ;
    rdfs:label 'Delivery Time Window Start' ;
    rdfs:comment 'Earliest time of day (HH:MM, 24-hour local time) within which delivery must be attempted to be considered on-time under this SLA entitlement. Used for time-definite delivery commitments (e.g., AM delivery windows).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Calendar date from which this SLA entitlement becomes binding and enforceable. Performance measurement begins on or after this date.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntilDate rdf:type rdf:Property ;
    rdfs:label 'Effective Until Date' ;
    rdfs:comment 'Calendar date on which this SLA entitlement expires and ceases to be enforceable. Null indicates an open-ended entitlement with no fixed expiry. Aligns with contract renewal cycles.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entitlementName rdf:type rdf:Property ;
    rdfs:label 'Entitlement Name' ;
    rdfs:comment 'Descriptive business name for this SLA entitlement, e.g., \'Gold Express OTD Commitment — APAC Lane\'. Used in customer-facing documents and CRM dashboards.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementNumber rdf:type rdf:Property ;
    rdfs:label 'Entitlement Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for this SLA entitlement, used in customer communications, CRM service cases, and operational reporting. Format: SLA- followed by alphanumeric characters.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementStatus rdf:type rdf:Property ;
    rdfs:label 'Entitlement Status' ;
    rdfs:comment 'Current lifecycle state of the SLA entitlement. \'active\' means the entitlement is in force; \'suspended\' means temporarily paused (e.g., force majeure); \'expired\' means the effective period has lapsed; \'pending_activation\' means approved but not yet in effect; \'terminated\' means cancelled before natural expiry; \'draft\' means under negotiation.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Escalation Threshold Hours' ;
    rdfs:comment 'Number of hours after a shipment misses its committed delivery time before an automatic escalation is triggered to the account management or operations team. Enables proactive exception management for high-value customers.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exclusionConditions rdf:type rdf:Property ;
    rdfs:label 'Exclusion Conditions' ;
    rdfs:comment 'Free-text description of conditions under which SLA performance failures are excluded from penalty calculations, such as force majeure events, customs delays, natural disasters, consignee unavailability, or regulatory holds. Sourced from contract terms.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gracePeriodHours rdf:type rdf:Property ;
    rdfs:label 'Grace Period Hours' ;
    rdfs:comment 'Number of hours beyond the committed delivery time that are tolerated before a shipment is classified as a late delivery for SLA measurement purposes. Accounts for minor operational variances and is agreed upon at contract negotiation.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incentiveClauseApplicable rdf:type rdf:Property ;
    rdfs:label 'Incentive Clause Applicable' ;
    rdfs:comment 'Indicates whether a financial incentive or rebate clause is in effect for over-performance against the SLA targets. When True, the incentive_rate_pct field defines the reward structure.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incentiveRatePct rdf:type rdf:Property ;
    rdfs:label 'Incentive Rate Pct' ;
    rdfs:comment 'Percentage of the applicable freight charge or contract value awarded as a financial incentive or rebate for each percentage point of SLA over-performance above the committed target. Active only when incentive_clause_applicable is True.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'Date on which this SLA entitlement was last formally reviewed with the customer in a business review meeting. Used to track review cadence compliance and trigger upcoming review scheduling.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementMethodology rdf:type rdf:Property ;
    rdfs:label 'Measurement Methodology' ;
    rdfs:comment 'Description of the methodology used to measure SLA performance, including how on-time is defined (e.g., first delivery attempt, POD scan time, ePOD timestamp), exclusions (e.g., force majeure, customs delays, consignee unavailability), and data source (e.g., FourKites, SAP TM, Oracle TMS).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriod rdf:type rdf:Property ;
    rdfs:label 'Measurement Period' ;
    rdfs:comment 'Frequency at which SLA performance is measured and reported against the committed targets. Determines the rolling window for OTD, OTIF, and volume threshold calculations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minVolumeShipmentCount rdf:type rdf:Property ;
    rdfs:label 'Min Volume Shipment Count' ;
    rdfs:comment 'Minimum number of shipments the customer commits to tender per measurement period to qualify for the SLA entitlement terms. Failure to meet this threshold may trigger tier renegotiation or penalty clauses.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minVolumeTeu rdf:type rdf:Property ;
    rdfs:label 'Min Volume Teu' ;
    rdfs:comment 'Minimum volume in Twenty-Foot Equivalent Units (TEU) the customer commits to tender per measurement period. Applicable to ocean freight FCL/LCL services. TEU is the standard unit of container capacity measurement per IMO and FMC conventions.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minVolumeWeightKg rdf:type rdf:Property ;
    rdfs:label 'Min Volume Weight Kg' ;
    rdfs:comment 'Minimum chargeable weight in kilograms the customer commits to tender per measurement period. Applicable primarily to air freight and express services where weight-based volume commitments are standard.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next formal SLA performance review with the customer. Derived from last_reviewed_date and review_frequency but stored explicitly to support scheduling and CRM activity management.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:noticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Notice Period Days' ;
    rdfs:comment 'Number of calendar days advance notice required by either party to terminate or renegotiate this SLA entitlement before its effective_until_date. Governs contract exit obligations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:penaltyCapAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Cap Amount' ;
    rdfs:comment 'Maximum financial penalty amount (in the contract currency) that can be levied against Transport Shipping in a single measurement period for SLA under-performance. Caps total financial exposure under the penalty clause.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyClauseApplicable rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause Applicable' ;
    rdfs:comment 'Indicates whether a financial penalty clause is in effect for under-performance against the SLA targets. When True, the penalty_rate_pct and penalty_cap_amount fields define the financial exposure.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyRatePct rdf:type rdf:Property ;
    rdfs:label 'Penalty Rate Pct' ;
    rdfs:comment 'Percentage of the applicable freight charge or contract value applied as a financial penalty for each percentage point of SLA under-performance. Active only when penalty_clause_applicable is True.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickupCutoffTime rdf:type rdf:Property ;
    rdfs:label 'Pickup Cutoff Time' ;
    rdfs:comment 'Latest time of day (HH:MM, 24-hour local time) by which a shipment must be tendered for pickup to qualify for same-day transit under this SLA entitlement. Shipments tendered after this time are counted against the next business day for OTD measurement.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Frequency' ;
    rdfs:comment 'Agreed frequency at which SLA performance is formally reviewed with the customer in a business review meeting. Drives scheduling of Quarterly Business Reviews (QBRs) and account management activities.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLine rdf:type rdf:Property ;
    rdfs:label 'Service Line' ;
    rdfs:comment 'Business service line or product family to which this SLA entitlement applies, e.g., Express Parcel Delivery, Freight Forwarding, E-Commerce Fulfillment, Contract Logistics, Customs Brokerage. Aligns with the core business processes of Transport Shipping. [ENUM-REF-CANDIDATE: express_parcel|freight_forwarding|supply_chain_mgmt|customs_brokerage|warehouse_distribution|ecommerce_fulfillment|last_mile|contract_logistics|cross_border — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceMode rdf:type rdf:Property ;
    rdfs:label 'Service Mode' ;
    rdfs:comment 'Transport or logistics service mode to which this SLA entitlement applies, e.g., Air Express, Ocean FCL, Road FTL, Road LTL, Rail, Parcel. Determines which operational processes are governed by this entitlement. [ENUM-REF-CANDIDATE: air_express|ocean_fcl|ocean_lcl|road_ftl|road_ltl|rail|parcel|last_mile|warehouse — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitTimeGuaranteeDays rdf:type rdf:Property ;
    rdfs:label 'Transit Time Guarantee Days' ;
    rdfs:comment 'Maximum number of calendar days from shipment pickup to delivery guaranteed under this SLA entitlement. Defines the transit time window used to evaluate OTD compliance. Expressed in whole days; fractional-day commitments use transit_time_guarantee_hours.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transitTimeGuaranteeHours rdf:type rdf:Property ;
    rdfs:label 'Transit Time Guarantee Hours' ;
    rdfs:comment 'Maximum number of hours from shipment pickup to delivery guaranteed under this SLA entitlement. Used for express and time-definite services where day-level granularity is insufficient (e.g., next-day AM, same-day delivery). Takes precedence over transit_time_guarantee_days when both are populated.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:servicePreferenceId rdf:type rdf:Property ;
    rdfs:label 'Service Preference Id' ;
    rdfs:comment 'Unique surrogate identifier for the customer service preference record. Primary key for the service_preference data product within the customer domain.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServicePreference .

ind:preferredAgentId rdf:type rdf:Property ;
    rdfs:label 'Preferred Agent Id' ;
    rdfs:comment 'Foreign key linking to network.agent. Business justification: customs_clearance_preference is plain text on service_preference. Customers designate preferred customs brokers/agents for import and export clearance. This drives automated agent assignment in custom' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:preferredCarrierServiceId rdf:type rdf:Property ;
    rdfs:label 'Preferred Carrier Service Id' ;
    rdfs:comment 'Foreign key linking to network.carrier_service. Business justification: Customer service preferences specify preferred_service_level as plain text. Automated booking systems require a FK to the actual carrier service record to apply correct rates, transit times, and equip' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarrierService .

ind:preferredTplProviderId rdf:type rdf:Property ;
    rdfs:label 'Preferred Tpl Provider Id' ;
    rdfs:comment 'Foreign key linking to network.tpl_provider. Business justification: Customers in e-commerce logistics designate a preferred 3PL for warehousing and fulfillment. This preference drives automated warehouse assignment and WMS integration. No existing 3PL FK on service_pr' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TplProvider .

ind:primaryServicePreferredCarrierId rdf:type rdf:Property ;
    rdfs:label 'Primary Service Preferred Carrier Id' ;
    rdfs:comment 'Reference to the customer\'s preferred carrier for shipment execution. Used in SAP TM carrier selection and Oracle TMS freight audit to prioritize carrier assignment when capacity and rates are comparable.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:serviceScopeId rdf:type rdf:Property ;
    rdfs:label 'Service Scope Id' ;
    rdfs:comment 'Foreign key linking to contract.service_scope. Business justification: Service preferences must be validated against the contracted service scope to ensure customers only request services covered by their agreement. Booking validation and order acceptance processes depen' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceScope .

ind:awbTypePreference rdf:type rdf:Property ;
    rdfs:label 'Awb Type Preference' ;
    rdfs:comment 'Customer\'s preference for Air Waybill (AWB) type on air freight shipments. \'HAWB\' (House Air Waybill) is issued by the freight forwarder; \'MAWB\' (Master Air Waybill) is issued by the airline; \'either\' allows system-driven selection. Impacts IATA cargo documentation and customs filing.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blTypePreference rdf:type rdf:Property ;
    rdfs:label 'Bl Type Preference' ;
    rdfs:comment 'Customer\'s preference for Bill of Lading (BOL) type on ocean freight shipments. \'HBL\' (House Bill of Lading) is issued by the NVOCC or freight forwarder; \'MBL\' (Master Bill of Lading) is issued by the ocean carrier. Impacts FMC compliance and customs filing in Descartes Customs.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:co2eOffsetPreference rdf:type rdf:Property ;
    rdfs:label 'Co2e Offset Preference' ;
    rdfs:comment 'Customer\'s preference for carbon offset participation. \'none\' means no offset; \'voluntary\' means the customer opts into voluntary carbon offset programs; \'mandatory\' means offset is contractually required. Supports CORSIA compliance and sustainability reporting.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codEnabled rdf:type rdf:Property ;
    rdfs:label 'Cod Enabled' ;
    rdfs:comment 'Indicates whether Cash on Delivery (COD) collection is enabled for this customer\'s shipments. When true, delivery drivers are authorized to collect payment at the point of delivery. Relevant for B2C and e-commerce fulfillment scenarios.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:codMaxAmount rdf:type rdf:Property ;
    rdfs:label 'Cod Max Amount' ;
    rdfs:comment 'Maximum monetary value authorized for COD collection per shipment for this customer. Enforced during last-mile delivery dispatch to manage cash handling risk. Expressed in the customer\'s default currency.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:containerLoadPreference rdf:type rdf:Property ;
    rdfs:label 'Container Load Preference' ;
    rdfs:comment 'Customer\'s preference for ocean freight container loading. \'FCL\' (Full Container Load) provides exclusive use of a container; \'LCL\' (Less Than Container Load) consolidates cargo with other shippers. Drives container booking logic in SAP TM and Oracle TMS load optimization.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsClearancePreference rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Preference' ;
    rdfs:comment 'Indicates how the customer prefers customs clearance to be managed. \'self_clearance\' means the customer handles their own customs filings; \'broker_managed\' means a third-party customs broker is used; \'transport_managed\' means Transport Shipping handles clearance as part of the service. Drives workflow routing in Descartes Customs.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredValueRequired rdf:type rdf:Property ;
    rdfs:label 'Declared Value Required' ;
    rdfs:comment 'Indicates whether the customer is required to declare the cargo value on all shipments. When true, shipment booking validation enforces declared value entry, which is used for customs valuation in Descartes Customs and insurance calculation.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dimWeightMethod rdf:type rdf:Property ;
    rdfs:label 'Dim Weight Method' ;
    rdfs:comment 'Method used to calculate dimensional weight (DIM weight) for rating and billing purposes. Determines whether IATA volumetric divisor, carrier-specific divisor, or IMDG rules apply. Impacts freight charge calculation in SAP TM.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epodRequired rdf:type rdf:Property ;
    rdfs:label 'Epod Required' ;
    rdfs:comment 'Indicates whether the customer requires an electronic Proof of Delivery (ePOD) to be captured and transmitted upon shipment completion. When true, last-mile delivery drivers must capture digital signature or photo confirmation. Supports SLA compliance and invoice release workflows.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatEnabled rdf:type rdf:Property ;
    rdfs:label 'Hazmat Enabled' ;
    rdfs:comment 'Indicates whether this customer is authorized to ship hazardous materials (hazmat) under IMDG Code (ocean), IATA Dangerous Goods Regulations (air), or DOT regulations (road). When true, hazmat documentation and compliance checks are triggered in Descartes Customs.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceRequired rdf:type rdf:Property ;
    rdfs:label 'Insurance Required' ;
    rdfs:comment 'Indicates whether the customer requires cargo insurance to be arranged by Transport Shipping for their shipments by default. When true, insurance coverage is automatically included in shipment booking and charge calculation in SAP TM.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelFormat rdf:type rdf:Property ;
    rdfs:label 'Label Format' ;
    rdfs:comment 'Customer\'s preferred shipping label output format for parcel and freight labels. ZPL (Zebra Programming Language) is standard for thermal printers; PDF for laser printing; EPL for legacy Eltron printers; PNG for digital/web display. Configured in Oracle TMS shipment execution.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationEvents rdf:type rdf:Property ;
    rdfs:label 'Notification Events' ;
    rdfs:comment 'Comma-separated list of shipment lifecycle events that trigger customer notifications (e.g., \'booked,picked_up,in_transit,customs_cleared,out_for_delivery,delivered,exception\'). Configures FourKites exception management and Salesforce CRM service case alerts.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceCode rdf:type rdf:Property ;
    rdfs:label 'Preference Code' ;
    rdfs:comment 'Externally-known business identifier for this service preference profile, used in EDI integrations, API calls, and customer-facing communications. Sourced from Salesforce CRM customer preference records.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceName rdf:type rdf:Property ;
    rdfs:label 'Preference Name' ;
    rdfs:comment 'Human-readable label for this service preference profile, enabling customers and operations staff to distinguish between multiple preference sets (e.g., \'Standard B2B Freight\', \'E-Commerce Express\').' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceStatus rdf:type rdf:Property ;
    rdfs:label 'Preference Status' ;
    rdfs:comment 'Current lifecycle state of the service preference record. \'active\' means preferences are applied to new shipment bookings; \'inactive\' means preferences are archived; \'pending\' means awaiting customer or operations approval; \'suspended\' means temporarily disabled.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceType rdf:type rdf:Property ;
    rdfs:label 'Preference Type' ;
    rdfs:comment 'Classification of the preference profile indicating its scope and application context. \'default\' applies to all shipments unless overridden; \'override\' supersedes defaults for specific lanes or periods; \'seasonal\' applies during defined date windows; \'project\' is tied to a specific contract or project.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredDestinationCountry rdf:type rdf:Property ;
    rdfs:label 'Preferred Destination Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the customer\'s default shipment destination country. Used in SAP TM route planning and Descartes Customs trade compliance screening for import declarations and HS code validation.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredOriginCountry rdf:type rdf:Property ;
    rdfs:label 'Preferred Origin Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the customer\'s default shipment origin country. Used in SAP TM route planning and Descartes Customs trade compliance screening for export declarations.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredPackagingType rdf:type rdf:Property ;
    rdfs:label 'Preferred Packaging Type' ;
    rdfs:comment 'Customer\'s default packaging format for shipments, used to pre-populate booking forms and drive warehouse packing instructions in Manhattan WMS. Supports slotting optimization and labor management.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredServiceLevel rdf:type rdf:Property ;
    rdfs:label 'Preferred Service Level' ;
    rdfs:comment 'Customer\'s preferred shipment service level tier governing transit time and cost trade-off. Maps to SLA entitlements and carrier product codes in SAP TM charge calculation and Oracle TMS load optimization.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roadLoadPreference rdf:type rdf:Property ;
    rdfs:label 'Road Load Preference' ;
    rdfs:comment 'Customer\'s preference for road freight load type. \'FTL\' (Full Truckload) provides exclusive truck capacity; \'LTL\' (Less Than Truckload) consolidates with other shipments. Used in SAP TM route planning and Oracle TMS load optimization.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingCodes rdf:type rdf:Property ;
    rdfs:label 'Special Handling Codes' ;
    rdfs:comment 'Comma-separated list of special handling instruction codes applicable to this customer\'s shipments by default (e.g., \'FRAGILE,TEMP_CTRL,HAZMAT,PERISHABLE,HIGH_VALUE,OVERSIZED\'). Drives warehouse handling procedures in Manhattan WMS and carrier booking requirements in SAP TM.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityReportingEnabled rdf:type rdf:Property ;
    rdfs:label 'Sustainability Reporting Enabled' ;
    rdfs:comment 'Indicates whether the customer has opted into carbon emissions reporting for their shipments. When true, GHG (Greenhouse Gas) and CO2e (Carbon Dioxide Equivalent) data is calculated and included in customer sustainability reports, aligned with EU ETS and CORSIA requirements.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tempMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temp Max Celsius' ;
    rdfs:comment 'Maximum acceptable temperature in degrees Celsius for temperature-controlled shipments. Used to configure cold chain monitoring alerts in FourKites and warehouse environment controls in Manhattan WMS. Applicable only when temperature_controlled is true.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tempMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temp Min Celsius' ;
    rdfs:comment 'Minimum acceptable temperature in degrees Celsius for temperature-controlled shipments. Used to configure cold chain monitoring alerts in FourKites and warehouse environment controls in Manhattan WMS. Applicable only when temperature_controlled is true.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled' ;
    rdfs:comment 'Indicates whether this customer\'s shipments require temperature-controlled handling and transport by default. When true, cold chain equipment and monitoring requirements are applied during booking in SAP TM and warehouse slotting in Manhattan WMS.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trackingVisibilityLevel rdf:type rdf:Property ;
    rdfs:label 'Tracking Visibility Level' ;
    rdfs:comment 'Granularity of shipment tracking data shared with the customer via FourKites or customer portal. \'full\' provides GPS-level real-time updates; \'milestone\' provides key event updates (pickup, customs, delivery); \'summary\' provides ETA and final status only; \'none\' disables customer-facing tracking.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCaseId rdf:type rdf:Property ;
    rdfs:label 'Service Case Id' ;
    rdfs:comment 'Unique surrogate identifier for the customer service case record in the Transport Shipping lakehouse. Primary key for the service_case data product.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceCase .

ind:fulfillmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Order Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.fulfillment_order. Business justification: Customer service cases for delivery failures, missing items, and SLA breaches are raised against specific fulfillment orders. service_case has tracking_number and consignment_id but no fulfillment_ord' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentOrder .

ind:incotermsAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Incoterms Assignment Id' ;
    rdfs:comment 'Foreign key linking to customs.incoterms_assignment. Business justification: Incoterms disputes (cost/risk boundary disagreements between shipper and consignee) are a named service case type in logistics. Customer service agents resolving liability and cost allocation disputes' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IncotermsAssignment .

ind:interlineAgreementId rdf:type rdf:Property ;
    rdfs:label 'Interline Agreement Id' ;
    rdfs:comment 'Foreign key linking to network.interline_agreement. Business justification: Interline shipment claims require referencing the governing interline agreement for liability limits, prorate methodology, and dispute resolution. service_case has awb_number and claim_reference_numbe' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InterlineAgreement .

ind:networkEventId rdf:type rdf:Property ;
    rdfs:label 'Network Event Id' ;
    rdfs:comment 'Foreign key linking to network.network_event. Business justification: When network disruptions (port closures, weather events) cause service failures, cases are opened referencing the triggering event. root_cause_category is plain text. Linking to network_event enables ' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkEvent .

ind:penaltyClauseId rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause Id' ;
    rdfs:comment 'Foreign key linking to contract.penalty_clause. Business justification: When a service case results in a penalty (late delivery, damage, SLA breach), the specific penalty clause being invoked must be referenced for claims resolution, credit note generation, and dispute ma' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PenaltyClause .

ind:spotQuoteId rdf:type rdf:Property ;
    rdfs:label 'Spot Quote Id' ;
    rdfs:comment 'Foreign key linking to pricing.spot_quote. Business justification: Billing dispute and spot-quote-not-honored cases are a primary service case type in logistics. Customer service agents must reference the original spot_quote when resolving pricing disputes, overcharg' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpotQuote .

ind:caseCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Case Created Timestamp' ;
    rdfs:comment 'The date and time when the service case record was first created in Salesforce CRM. This is the principal business event timestamp representing when the customer interaction was formally logged. Used as the baseline for all SLA (Service Level Agreement) calculations.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:caseDescription rdf:type rdf:Property ;
    rdfs:label 'Case Description' ;
    rdfs:comment 'Full narrative description of the customer\'s issue, complaint, or inquiry as captured at case creation. May include shipment details, service failure context, or customer-provided evidence.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Externally visible, human-readable case reference number assigned by Salesforce CRM at case creation. Used in all customer-facing communications and SLA tracking. Format: CS- followed by 8–12 digits.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseStatus rdf:type rdf:Property ;
    rdfs:label 'Case Status' ;
    rdfs:comment 'Current workflow state of the service case lifecycle. Drives operational queues, SLA breach monitoring, and customer communication triggers. Transitions: new → in_progress → pending_customer | escalated → resolved → closed.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseType rdf:type rdf:Property ;
    rdfs:label 'Case Type' ;
    rdfs:comment 'Classification of the service case by the nature of the customer interaction. Drives routing, SLA assignment, and reporting segmentation. [ENUM-REF-CANDIDATE: shipment_inquiry|service_failure|complaint|claims_initiation|billing_dispute|general_support|customs_query|returns_rma — promote to reference product if additional types are added]' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimsInitiated rdf:type rdf:Property ;
    rdfs:label 'Claims Initiated' ;
    rdfs:comment 'Indicates whether this service case has triggered the initiation of a formal cargo claim in the claims domain. True when the case type is claims_initiation and a claim record has been created. Provides the handoff signal between customer service workflow and financial liability management.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'The date and time when the service case was formally closed after customer confirmation or automatic closure policy. Distinct from resolved_timestamp — a case may be resolved but remain open pending customer acknowledgement.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerFeedbackNotes rdf:type rdf:Property ;
    rdfs:label 'Customer Feedback Notes' ;
    rdfs:comment 'Free-text verbatim feedback provided by the customer as part of the post-case satisfaction survey. Complements the numeric CSAT score with qualitative insight for service improvement analysis.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Score' ;
    rdfs:comment 'Customer satisfaction rating provided by the customer upon case closure, typically on a 1–5 scale. Sourced from Salesforce CRM post-case survey. Key KPI (Key Performance Indicator) for service quality measurement and agent performance management.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'The highest escalation tier reached by this case. Populated when is_escalated is True. Used for escalation pattern analysis and workforce capacity planning. None indicates no escalation occurred.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalation Timestamp' ;
    rdfs:comment 'The date and time when the most recent escalation event was triggered for this case. Null if the case has never been escalated. Used for escalation response time analysis.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:firstResponseTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Response Timestamp' ;
    rdfs:comment 'The date and time when the first substantive agent response was sent to the customer after case creation. Used to calculate SLA (Service Level Agreement) first-response compliance and OTD (On-Time Delivery) of service commitments.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isEscalated rdf:type rdf:Property ;
    rdfs:label 'Is Escalated' ;
    rdfs:comment 'Indicates whether this service case has been formally escalated to a senior agent, team lead, or management tier at any point in its lifecycle. True if any escalation event has occurred.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReopenedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Reopened Timestamp' ;
    rdfs:comment 'The date and time when the case was most recently reopened after a prior resolution or closure. Null if the case has never been reopened. Used alongside reopen_count for resolution quality analytics.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originChannel rdf:type rdf:Property ;
    rdfs:label 'Origin Channel' ;
    rdfs:comment 'The communication channel through which the customer submitted this service case. Used for channel analytics, staffing optimization, and omnichannel service reporting. EDI (Electronic Data Interchange) channel applies to B2B automated case submissions.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podReceived rdf:type rdf:Property ;
    rdfs:label 'Pod Received' ;
    rdfs:comment 'Indicates whether the requested Proof of Delivery (POD) or Electronic Proof of Delivery (ePOD) document has been successfully retrieved and attached to this case. Used to track case resolution blockers.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:podRequired rdf:type rdf:Property ;
    rdfs:label 'Pod Required' ;
    rdfs:comment 'Indicates whether a Proof of Delivery (POD) or Electronic Proof of Delivery (ePOD) document has been requested as part of resolving this service case. Common for delivery dispute and non-receipt inquiry cases.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Business priority level assigned to the service case, determining response time targets and escalation thresholds per the customer SLA entitlement. Critical cases typically involve time-sensitive freight or enterprise account failures.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reopenCount rdf:type rdf:Property ;
    rdfs:label 'Reopen Count' ;
    rdfs:comment 'Number of times this service case has been reopened after being marked as resolved or closed. A non-zero value indicates resolution quality issues. Used for first-contact resolution (FCR) KPI (Key Performance Indicator) reporting.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionCode rdf:type rdf:Property ;
    rdfs:label 'Resolution Code' ;
    rdfs:comment 'Standardized code describing the action taken to resolve the service case. Distinct from root cause — this captures what was done, not why it happened. Used for resolution effectiveness analytics and SLA compliance reporting. [ENUM-REF-CANDIDATE: reshipped|refunded|credited|apology_issued|information_provided|escalated_to_claim|no_action_required|other — promote to reference product]' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Free-text narrative documenting the specific resolution actions taken, agent findings, and any commitments made to the customer. Captured at case closure and retained for audit and quality review.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolved Timestamp' ;
    rdfs:comment 'The date and time when the service case was first marked as resolved. Used to calculate total resolution time, SLA (Service Level Agreement) resolution compliance, and agent productivity metrics.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'Standardized classification of the underlying root cause identified during case investigation. Critical for operational improvement, KPI (Key Performance Indicator) reporting, and recurring failure analysis. [ENUM-REF-CANDIDATE: carrier_delay|customs_hold|documentation_error|damage_in_transit|lost_shipment|billing_error|system_error|weather_event|address_issue|other — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaFirstResponseBreached rdf:type rdf:Property ;
    rdfs:label 'Sla First Response Breached' ;
    rdfs:comment 'Indicates whether the first response SLA (Service Level Agreement) target was breached for this case. True if the first_response_timestamp exceeded the sla_response_target_hours from case creation. Key KPI (Key Performance Indicator) for customer service quality reporting.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaResolutionBreached rdf:type rdf:Property ;
    rdfs:label 'Sla Resolution Breached' ;
    rdfs:comment 'Indicates whether the resolution SLA (Service Level Agreement) target was breached for this case. True if the resolved_timestamp exceeded the sla_resolution_target_hours from case creation. Drives escalation workflows and executive service quality dashboards.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaResolutionTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Resolution Target Hours' ;
    rdfs:comment 'The contracted or policy-defined maximum number of hours within which the case must be fully resolved, as defined by the applicable SLA (Service Level Agreement) for this account segment and priority combination.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaResponseTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Response Target Hours' ;
    rdfs:comment 'The contracted or policy-defined maximum number of hours within which the first agent response must be delivered to the customer, as defined by the applicable SLA (Service Level Agreement) for this account segment and priority combination.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemCaseCode rdf:type rdf:Property ;
    rdfs:label 'Source System Case Code' ;
    rdfs:comment 'The native case identifier from Salesforce CRM (e.g., Salesforce Case ID / 18-character Salesforce record ID). Retained for lineage traceability, reconciliation with the source system, and EDI (Electronic Data Interchange) integration cross-referencing.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Short, descriptive title of the service case as entered by the customer or agent. Used for case list views, search, and initial triage. Typically 255 characters or fewer.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'Customer-facing parcel or shipment tracking number associated with this service case. Used for last-mile delivery inquiries, POD (Proof of Delivery) disputes, and express parcel service failures.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingId rdf:type rdf:Property ;
    rdfs:label 'Onboarding Id' ;
    rdfs:comment 'Unique system-generated identifier for the customer onboarding record. Primary key for the onboarding data product.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licensePermitId rdf:type rdf:Property ;
    rdfs:label 'License Permit Id' ;
    rdfs:comment 'Foreign key linking to customs.license_permit. Business justification: Customs license and permit verification is a mandatory onboarding compliance step for importers and exporters in logistics. The onboarding record must reference the verified license_permit to document' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LicensePermit .

ind:originNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Origin Network Node Id' ;
    rdfs:comment 'Foreign key linking to route.network_node. Business justification: Customer onboarding configures the origin network node (warehouse, port, hub) the customer ships from. Node-level provisioning tracking (WMS/TMS setup, customs bonding) requires this link. Logistics d' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:primaryCarrierId rdf:type rdf:Property ;
    rdfs:label 'Primary Carrier Id' ;
    rdfs:comment 'Foreign key linking to network.carrier. Business justification: Carrier setup is a named step in logistics customer onboarding (EDI configuration, rate loading, booking system provisioning). service_scope is plain text. Role-prefixed as primary_carrier_id. Require' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:primaryLaneId rdf:type rdf:Property ;
    rdfs:label 'Primary Lane Id' ;
    rdfs:comment 'Foreign key linking to route.lane. Business justification: Customer onboarding in logistics includes activating specific trade lanes. The primary lane being onboarded must be tracked for lane-level provisioning status, TMS configuration, and go-live readiness' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lane .

ind:actualGoLiveDate rdf:type rdf:Property ;
    rdfs:label 'Actual Go Live Date' ;
    rdfs:comment 'The actual date on which the customer was activated and went live on Transport Shipping systems. Compared against target_go_live_date to measure onboarding cycle time adherence and SLA compliance.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amlStatus rdf:type rdf:Property ;
    rdfs:label 'Aml Status' ;
    rdfs:comment 'Status of the Anti-Money Laundering (AML) screening check performed during onboarding. Includes sanctions list screening, denied party checks, and financial crime risk assessment. A flagged or rejected status blocks account activation.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiIntegrationStatus rdf:type rdf:Property ;
    rdfs:label 'Api Integration Status' ;
    rdfs:comment 'Status of the API integration setup for customers using direct API connectivity to Transport Shipping platforms for booking, tracking, and rate queries. Distinct from EDI for customers using REST/SOAP API channels.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The channel through which the customer onboarding was initiated and managed. Distinguishes between digital self-serve (customer-led portal) and managed (assigned onboarding manager) approaches, supporting channel performance analytics.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistCompletionPct rdf:type rdf:Property ;
    rdfs:label 'Checklist Completion Pct' ;
    rdfs:comment 'Percentage of onboarding checklist items that have been completed. Provides a single numeric indicator of overall onboarding progress for dashboards and SLA monitoring. Calculated from checklist item statuses in the onboarding checklist sub-entity.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completedChecklistItems rdf:type rdf:Property ;
    rdfs:label 'Completed Checklist Items' ;
    rdfs:comment 'Number of onboarding checklist items that have been marked as completed. Used alongside total_checklist_items to track onboarding progress and identify bottlenecks.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditAssessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Assessment Status' ;
    rdfs:comment 'Status of the credit risk assessment conducted during customer onboarding. Determines credit terms, payment conditions, and credit limit to be assigned. Conditionally approved may indicate a reduced credit limit or requirement for prepayment.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsRegistrationRequired rdf:type rdf:Property ;
    rdfs:label 'Customs Registration Required' ;
    rdfs:comment 'Indicates whether the customer requires customs brokerage registration and trade compliance setup as part of onboarding. Triggers Descartes Customs configuration, HS code profile setup, and AEO/C-TPAT compliance checks.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsSetupStatus rdf:type rdf:Property ;
    rdfs:label 'Customs Setup Status' ;
    rdfs:comment 'Status of the customs and trade compliance configuration in Descartes Customs for the customer. Includes denied party screening profile, tariff classification preferences, and import/export license registration.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dangerousGoodsCertified rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Certified' ;
    rdfs:comment 'Indicates whether the customer has been certified and approved to ship dangerous goods (DG) through Transport Shipping. Triggers IMDG/ICAO DG compliance checks and special handling configuration during onboarding.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataConsentDate rdf:type rdf:Property ;
    rdfs:label 'Data Consent Date' ;
    rdfs:comment 'The date on which the customer provided explicit consent for data processing. Required for GDPR compliance audit trail and consent management.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataProcessingConsent rdf:type rdf:Property ;
    rdfs:label 'Data Processing Consent' ;
    rdfs:comment 'Indicates whether the customer has provided explicit consent for processing of their personal and business data in accordance with GDPR and applicable data protection regulations. Must be TRUE before account activation.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediSetupStatus rdf:type rdf:Property ;
    rdfs:label 'Edi Setup Status' ;
    rdfs:comment 'Status of the Electronic Data Interchange (EDI) integration setup for the customer. EDI enables automated exchange of shipment orders, ASNs, invoices, and status messages between the customer\'s systems and Transport Shipping platforms.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiationDate rdf:type rdf:Property ;
    rdfs:label 'Initiation Date' ;
    rdfs:comment 'The date on which the customer onboarding process was formally initiated, typically coinciding with account creation or CRM opportunity conversion. Used as the start anchor for SLA and cycle time calculations.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycAmlCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Aml Completed Date' ;
    rdfs:comment 'The date on which both the Know Your Customer (KYC) and Anti-Money Laundering (AML) verification processes were successfully completed and approved for this customer onboarding.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycStatus rdf:type rdf:Property ;
    rdfs:label 'Kyc Status' ;
    rdfs:comment 'Current status of the Know Your Customer (KYC) identity verification process for the customer. Mandatory regulatory due diligence step before account activation. Tracks progression from pending submission through review, approval, or rejection.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerName rdf:type rdf:Property ;
    rdfs:label 'Manager Name' ;
    rdfs:comment 'Full name of the assigned onboarding manager. Retained for operational reference and reporting without requiring a join to the HR system.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onHoldReason rdf:type rdf:Property ;
    rdfs:label 'On Hold Reason' ;
    rdfs:comment 'Reason code explaining why the onboarding process has been placed on hold. Used for exception management, escalation tracking, and reporting on onboarding bottlenecks. [ENUM-REF-CANDIDATE: kyc_aml_pending|credit_review|document_missing|customer_unresponsive|system_issue|legal_review|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingStatus rdf:type rdf:Property ;
    rdfs:label 'Onboarding Status' ;
    rdfs:comment 'Overall lifecycle status of the onboarding record, distinct from the granular stage. Indicates whether the onboarding is actively progressing, completed, paused, or terminated.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Notes' ;
    rdfs:comment 'Free-text field capturing regulatory due diligence observations, compliance exceptions, or special conditions noted during the onboarding process. Supports audit trail requirements under C-TPAT, AEO, and GDPR accountability obligations.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'Current stage in the end-to-end customer onboarding lifecycle. Tracks progression from initial account creation through KYC/AML, credit assessment, system provisioning, training, and final activation. [ENUM-REF-CANDIDATE: initiated|kyc_aml_review|credit_assessment|system_provisioning|training|go_live_pending|active|on_hold|cancelled — promote to reference product]' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetGoLiveDate rdf:type rdf:Property ;
    rdfs:label 'Target Go Live Date' ;
    rdfs:comment 'The planned date by which the customer is expected to be fully activated and operationally live on Transport Shipping systems. Used for SLA tracking and resource planning.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tmsProvisioningStatus rdf:type rdf:Property ;
    rdfs:label 'Tms Provisioning Status' ;
    rdfs:comment 'Status of the customer account provisioning in the Transportation Management System (TMS — SAP TM or Oracle TMS). Tracks whether the customer has been set up for shipment booking, freight order management, and rate access.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalChecklistItems rdf:type rdf:Property ;
    rdfs:label 'Total Checklist Items' ;
    rdfs:comment 'Total number of onboarding checklist items assigned to this customer onboarding record. Used as the denominator for checklist completion percentage and for workload tracking.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Training Completed Date' ;
    rdfs:comment 'The date on which the customer completed all required onboarding training modules. Used to confirm readiness for go-live and to satisfy compliance documentation requirements.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingStatus rdf:type rdf:Property ;
    rdfs:label 'Training Status' ;
    rdfs:comment 'Status of the customer training program completion during onboarding. Training covers platform usage, booking procedures, compliance requirements, and service-specific processes. Waived status applies for experienced customers or self-serve digital onboarding.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wmsProvisioningStatus rdf:type rdf:Property ;
    rdfs:label 'Wms Provisioning Status' ;
    rdfs:comment 'Status of the customer account provisioning in the Warehouse Management System (WMS — Manhattan WMS). Applicable for customers requiring warehousing, distribution, or e-commerce fulfillment services.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditProfileId rdf:type rdf:Property ;
    rdfs:label 'Credit Profile Id' ;
    rdfs:comment 'Unique surrogate identifier for the customer credit profile record in the Transport Shipping lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditProfile .

ind:approvedCreditLimit rdf:type rdf:Property ;
    rdfs:label 'Approved Credit Limit' ;
    rdfs:comment 'The formally approved credit limit as of the most recent credit review, which may differ from the currently active credit_limit if a pending change is awaiting activation. Maintains the audit trail of the last approved value.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableCredit rdf:type rdf:Property ;
    rdfs:label 'Available Credit' ;
    rdfs:comment 'Remaining credit headroom calculated as credit_limit minus outstanding_balance minus open_order_exposure. Stored as a business-critical operational field (not a derived KPI) because it is directly consumed by SAP TM shipment release checks and Oracle TMS load authorization gates.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingCurrency rdf:type rdf:Property ;
    rdfs:label 'Billing Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which invoices are issued to this customer. May differ from credit_currency when the customer operates in a different functional currency. Sourced from SAP S/4HANA Finance customer master.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAgencyName rdf:type rdf:Property ;
    rdfs:label 'Credit Agency Name' ;
    rdfs:comment 'Name of the external credit reference agency that provided the credit rating or score (e.g., Dun & Bradstreet, Experian, Equifax, Coface, Euler Hermes). Required for audit trail and credit review documentation.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAgencyReference rdf:type rdf:Property ;
    rdfs:label 'Credit Agency Reference' ;
    rdfs:comment 'Unique reference number or DUNS number assigned by the external credit agency for this customer. Used to cross-reference credit bureau reports and validate the source of the credit assessment.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditControlArea rdf:type rdf:Property ;
    rdfs:label 'Credit Control Area' ;
    rdfs:comment 'SAP organizational unit (credit control area code) within which this customer\'s credit limit is managed. Defines the scope of credit monitoring and aligns with the company code structure in SAP S/4HANA Finance.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditCurrency rdf:type rdf:Property ;
    rdfs:label 'Credit Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the credit limit, outstanding balance, and exposure amounts are denominated (e.g., USD, EUR, GBP). Aligns with the customer\'s billing currency in SAP S/4HANA Finance.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditHoldDate rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Date' ;
    rdfs:comment 'Calendar date on which the credit hold was most recently applied to this account. Used for aging analysis of holds and SLA tracking for hold resolution.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Flag' ;
    rdfs:comment 'Indicates whether this customer account is currently under a credit hold, blocking the release of new shipments and freight orders in SAP TM and Oracle TMS. True = hold active; False = no hold. Operationally critical for shipment gating.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditHoldReason rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Reason' ;
    rdfs:comment 'Reason code explaining why the credit hold was applied. Used by finance and operations teams to prioritize resolution actions and communicate with customers. [ENUM-REF-CANDIDATE: overdue_invoices|credit_limit_exceeded|payment_dispute|bankruptcy_risk|manual_hold|compliance_review|other — promote to reference product]' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditHoldReleasedDate rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Released Date' ;
    rdfs:comment 'Calendar date on which the most recent credit hold was lifted, allowing shipment release to resume. Null if the hold is still active. Used for hold duration analytics and finance KPI reporting.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditInsuranceFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Flag' ;
    rdfs:comment 'Indicates whether this customer\'s credit exposure is covered by a trade credit insurance policy (e.g., Euler Hermes, Coface, Atradius). True = insured; False = uninsured. Affects net credit risk exposure and provisioning under IFRS 9.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditInsurancePolicyRef rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Policy Ref' ;
    rdfs:comment 'Reference number of the trade credit insurance policy covering this customer\'s receivables. Populated only when credit_insurance_flag is True. Used for claims processing and insurer reporting.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Approved By' ;
    rdfs:comment 'Name or employee ID of the finance officer or credit manager who formally approved the current credit limit. Required for SOX audit trail and segregation of duties compliance.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Utilization Pct' ;
    rdfs:comment 'Percentage of the approved credit limit currently utilized, calculated as (outstanding_balance + open_order_exposure) / credit_limit × 100. Stored as a business-critical operational field consumed by SAP TM shipment release checks and finance dashboards — not a derived analytics KPI.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'External or internal credit rating assigned to the customer, using a standardized rating scale (e.g., S&P/Moody\'s-aligned: AAA through D, or NR for Not Rated). Drives credit limit approval tiers and risk-based pricing decisions. [ENUM-REF-CANDIDATE: AAA|AA|A|BBB|BB|B|CCC|CC|C|D|NR — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditScore rdf:type rdf:Property ;
    rdfs:label 'Credit Score' ;
    rdfs:comment 'Numeric credit score assigned by an external credit agency or internal scoring model, typically on a scale of 0–1000 or 300–850 depending on the agency. Used alongside credit_rating for granular risk segmentation and credit limit setting.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysSalesOutstanding rdf:type rdf:Property ;
    rdfs:label 'Days Sales Outstanding' ;
    rdfs:comment 'Average number of days taken by this customer to pay invoices, calculated from SAP S/4HANA Finance AR data. A key credit risk indicator stored as a business field (not a computed KPI) because it is sourced directly from the credit management system and used in credit limit decisions.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlyPaymentDiscountDays rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Days' ;
    rdfs:comment 'Number of days from invoice date within which the customer must pay to qualify for the early payment discount. Paired with early_payment_discount_pct to define the discount window.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:earlyPaymentDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Pct' ;
    rdfs:comment 'Percentage discount offered to the customer for early payment of invoices within a specified discount period (e.g., 2% if paid within 10 days). Defined in SAP S/4HANA Finance payment terms configuration.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuredCreditLimit rdf:type rdf:Property ;
    rdfs:label 'Insured Credit Limit' ;
    rdfs:comment 'The portion of the total credit limit that is covered by trade credit insurance. May be less than or equal to credit_limit. Used to calculate net uninsured exposure for IFRS 9 provisioning.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date of the most recently completed formal credit review for this customer. Used to determine review frequency compliance and trigger overdue review alerts.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openOrderExposure rdf:type rdf:Property ;
    rdfs:label 'Open Order Exposure' ;
    rdfs:comment 'Total value of freight orders and shipments that have been accepted but not yet invoiced, representing committed but unbilled credit exposure. Sourced from SAP TM freight order management and used in real-time credit checks.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'Current total of unpaid invoices and open receivables against this credit profile, expressed in the credit currency. Sourced from SAP S/4HANA Finance Accounts Receivable (AR) sub-ledger. Used to calculate available credit headroom.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overdueAmount rdf:type rdf:Property ;
    rdfs:label 'Overdue Amount' ;
    rdfs:comment 'Total value of invoices that have passed their payment due date and remain unpaid, expressed in the credit currency. Sourced from SAP S/4HANA Finance AR aging. Triggers credit hold workflows when thresholds are breached.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overdueDays rdf:type rdf:Property ;
    rdfs:label 'Overdue Days' ;
    rdfs:comment 'Number of calendar days the oldest unpaid overdue invoice has been past its due date. Used for collection prioritization, credit hold triggers, and IFRS 9 expected credit loss staging.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentBehaviorCode rdf:type rdf:Property ;
    rdfs:label 'Payment Behavior Code' ;
    rdfs:comment 'Classification of the customer\'s historical payment behavior based on Days Sales Outstanding (DSO) analysis from SAP S/4HANA Finance AR aging reports. Informs credit risk assessment and collection prioritization.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Numeric representation of the standard payment due period in calendar days (e.g., 30, 60, 90). Complements payment_terms_code for analytics, SLA reporting, and Days Sales Outstanding (DSO) calculations in the finance domain.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:profileNumber rdf:type rdf:Property ;
    rdfs:label 'Profile Number' ;
    rdfs:comment 'Externally-known business identifier for the credit profile, used in correspondence with credit agencies, billing teams, and finance operations. Sourced from SAP S/4HANA Finance customer credit management (FD32).' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileType rdf:type rdf:Property ;
    rdfs:label 'Profile Type' ;
    rdfs:comment 'Classification of the credit profile by customer segment: enterprise B2B accounts, small-to-medium enterprises (SME), individual B2C shippers, Third-Party Logistics (3PL) partners, Fourth-Party Logistics (4PL) partners, or government entities. Drives credit policy rules and approval workflows. [ENUM-REF-CANDIDATE: enterprise|sme|individual|3pl_partner|4pl_partner|government — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedCreditLimit rdf:type rdf:Property ;
    rdfs:label 'Requested Credit Limit' ;
    rdfs:comment 'Credit limit amount requested by the customer or proposed by the sales/account management team (Salesforce CRM opportunity data), pending formal credit review and approval by the finance team.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Months' ;
    rdfs:comment 'Frequency in calendar months at which this customer\'s credit profile must be formally reviewed (e.g., 3, 6, 12, 24). Determined by credit risk tier: high-risk accounts reviewed quarterly, standard accounts annually.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Category' ;
    rdfs:comment 'Internal risk classification assigned to the customer based on credit score, payment history, and financial exposure. Drives credit limit approval authority levels, review frequency, and shipment release policies.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCreditAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Credit Account Number' ;
    rdfs:comment 'SAP S/4HANA Finance customer credit account number (10-digit SAP debtor number) used in FD32 credit management transactions. The system-of-record identifier for reconciliation with SAP AR and credit management modules.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityDepositAmount rdf:type rdf:Property ;
    rdfs:label 'Security Deposit Amount' ;
    rdfs:comment 'Cash deposit or bank guarantee amount held by Transport Shipping as collateral against the customer\'s credit exposure. Reduces the net unsecured credit risk. Tracked in SAP S/4HANA Finance.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:securityType rdf:type rdf:Property ;
    rdfs:label 'Security Type' ;
    rdfs:comment 'Type of financial security or collateral provided by the customer to support their credit facility. Includes cash deposits, bank guarantees, letters of credit (LC), parent company guarantees, or none for unsecured accounts.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerRelationshipId rdf:type rdf:Property ;
    rdfs:label 'Partner Relationship Id' ;
    rdfs:comment 'Unique surrogate identifier for the logistics partner relationship record in the Transport Shipping data platform. Primary key for this entity.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierAgreementId rdf:type rdf:Property ;
    rdfs:label 'Carrier Agreement Id' ;
    rdfs:comment 'Foreign key linking to contract.carrier_agreement. Business justification: When a partner relationship is with a carrier, the specific carrier agreement (rates, capacity, liability terms) governs the relationship. This is distinct from the master agreement link and enables c' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarrierAgreement .

ind:partnerSlaId rdf:type rdf:Property ;
    rdfs:label 'Partner Sla Id' ;
    rdfs:comment 'Foreign key linking to network.partner_sla. Business justification: partner_relationship has sla_tier_code as plain text. The governing partner SLA record defines penalty/incentive terms and measurement methodology. Linking to partner_sla enables automated SLA monitor' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerSla .

ind:partnerTradePartyId rdf:type rdf:Property ;
    rdfs:label 'Partner Trade Party Id' ;
    rdfs:comment 'Foreign key linking to customs.trade_party. Business justification: Partners (customs brokers, freight forwarders) are trade parties. Required for: customs broker assignment, power of attorney validation, broker license verification, and tracking broker performance on' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeParty .

ind:apiConnectivityStatus rdf:type rdf:Property ;
    rdfs:label 'Api Connectivity Status' ;
    rdfs:comment 'Current status of the API (Application Programming Interface) integration between Transport Shipping\'s TMS/WMS platforms and the partner\'s systems. Enables real-time shipment status, booking, and track-and-trace data exchange via FourKites or direct API.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Enabled' ;
    rdfs:comment 'Indicates whether this partner relationship is configured for automatic renewal upon reaching the effective_until_date. When true, the relationship extends for the standard renewal period defined in the master service agreement unless explicitly cancelled.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSharingPermissionLevel rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Permission Level' ;
    rdfs:comment 'Governs the level of Transport Shipping customer and shipment data the partner is authorized to access and receive. None = no data shared; shipment_status = track-and-trace only; full_visibility = complete shipment and inventory data; restricted = custom scope defined in data sharing agreement. Enforces GDPR data minimization principles.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediConnectivityStatus rdf:type rdf:Property ;
    rdfs:label 'Edi Connectivity Status' ;
    rdfs:comment 'Current status of the EDI (Electronic Data Interchange) integration channel between Transport Shipping and the partner. Active indicates live message exchange; pending_setup indicates configuration in progress; testing indicates UAT phase; inactive indicates EDI is not in use.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediPartnerQualifier rdf:type rdf:Property ;
    rdfs:label 'Edi Partner Qualifier' ;
    rdfs:comment 'Two-digit EDI interchange qualifier code identifying the partner\'s ID type in EDI X12 or UN/EDIFACT message headers (e.g., 01 = DUNS, 08 = UCC, ZZ = mutually defined). Required for AMS (Automated Manifest System) and ISF (Importer Security Filing) submissions.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverageRegions rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage Regions' ;
    rdfs:comment 'Comma-delimited list of ISO 3166-1 alpha-3 country codes or regional zone identifiers representing the geographic territories where the partner is authorized to operate under this relationship. Drives lane-level partner assignment in SAP TM route planning.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Number' ;
    rdfs:comment 'Reference number of the partner\'s cargo and liability insurance certificate. Required for high-value shipment authorization and claims processing. Validated against minimum coverage thresholds defined in the master service agreement.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Expiry Date' ;
    rdfs:comment 'Date on which the partner\'s cargo and liability insurance certificate expires. Triggers renewal alerts and may result in relationship suspension if insurance lapses before renewal is confirmed.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partnerCode rdf:type rdf:Property ;
    rdfs:label 'Partner Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the partner within Transport Shipping\'s TMS (Transportation Management System) and WMS (Warehouse Management System). Used in EDI (Electronic Data Interchange) message routing and SAP TM carrier/partner master.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerLegalName rdf:type rdf:Property ;
    rdfs:label 'Partner Legal Name' ;
    rdfs:comment 'Full registered legal name of the third-party logistics partner organization as recorded in official trade and customs documentation. Used for AWB (Air Waybill), BOL (Bill of Lading), and customs declaration filings.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerRole rdf:type rdf:Property ;
    rdfs:label 'Partner Role' ;
    rdfs:comment 'Operational role the partner plays within the customer\'s logistics network. Subcontractor performs services under the customer\'s brand; agent acts on behalf of the customer; co_loader shares freight capacity; principal is the primary contracting party; associate is a non-binding collaborative partner.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerTradingName rdf:type rdf:Property ;
    rdfs:label 'Partner Trading Name' ;
    rdfs:comment 'Commercial or brand name under which the partner operates, which may differ from the legal name. Used in operational communications, shipment documentation, and customer-facing reporting.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerType rdf:type rdf:Property ;
    rdfs:label 'Partner Type' ;
    rdfs:comment 'Classification of the logistics partner by operational role. 3PL (Third-Party Logistics) provides outsourced logistics services; 4PL (Fourth-Party Logistics) manages the entire supply chain; NVOCC (Non-Vessel Operating Common Carrier) issues house bills of lading; freight_broker arranges carrier capacity; customs_broker handles trade compliance; co_loader shares container capacity. [ENUM-REF-CANDIDATE: 3PL|4PL|NVOCC|freight_broker|customs_broker|co_loader — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceRating rdf:type rdf:Property ;
    rdfs:label 'Performance Rating' ;
    rdfs:comment 'Composite performance score for the partner on a 0.00–5.00 scale, derived from KPI (Key Performance Indicator) measurements including OTD (On-Time Delivery), OTIF (On-Time In-Full), claims ratio, and SLA compliance. Updated periodically from operational data. Used for carrier/partner selection scoring in SAP TM.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Performance Review Date' ;
    rdfs:comment 'Date of the most recent formal performance review conducted for this partner relationship. Used to schedule periodic KPI assessments and SLA compliance audits per contractual obligations.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipNumber rdf:type rdf:Property ;
    rdfs:label 'Relationship Number' ;
    rdfs:comment 'Externally-known business identifier for the partner relationship, used in EDI communications, contract references, and partner-facing correspondence. Sourced from Salesforce CRM or SAP TM partner master.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Relationship Status' ;
    rdfs:comment 'Current lifecycle state of the partner relationship. Active indicates the partnership is operational; suspended indicates temporary halt pending resolution; terminated indicates the relationship has ended; pending indicates onboarding in progress; under_review indicates compliance or performance review is underway.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of calendar days before the effective_until_date that a renewal notice must be issued to the partner. Drives automated alerts in Salesforce CRM and Coupa procurement workflows to initiate contract renewal negotiations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesforceRelationshipCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Relationship Code' ;
    rdfs:comment 'Salesforce CRM record identifier for this partner relationship, enabling bi-directional synchronization between the data lakehouse silver layer and the CRM system of record for opportunity tracking and service case management.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Actual date on which the partner relationship was formally terminated. Distinct from effective_until_date which is the planned expiry. Populated when relationship_status transitions to \'terminated\'. Used for audit trails and regulatory reporting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Reason code for the termination of the partner relationship. Used for partner lifecycle analytics, compliance audit trails, and procurement risk reporting. [ENUM-REF-CANDIDATE: contract_expiry|performance_failure|compliance_breach|mutual_agreement|insolvency|regulatory_action — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportModesAuthorized rdf:type rdf:Property ;
    rdfs:label 'Transport Modes Authorized' ;
    rdfs:comment 'Pipe-delimited set of transport modes the partner is authorized to handle under this relationship. Aligns with IATA (air), IMO (ocean), and DOT (road/rail) regulatory frameworks. Used in SAP TM carrier selection and Oracle TMS load optimization.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedCarrierServiceId rdf:type rdf:Property ;
    rdfs:label 'Contracted Carrier Service Id' ;
    rdfs:comment 'Foreign key linking to network.carrier_service. Business justification: Lanes are often contracted under specific carrier service products with defined service levels. Required for rate application during quoting, service-level routing decisions, and contracted service va' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarrierService .

ind:destinationLocationNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Network Node Id' ;
    rdfs:comment 'Reference to the destination network node (city, port, airport, ICD, CFS, or postal zone) at which this lane terminates. Paired with origin_location_id to define the directional transport corridor.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:laneNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Lane Network Node Id' ;
    rdfs:comment 'Reference to the origin network node (city, port, airport, Inland Container Depot (ICD), Container Freight Station (CFS), or postal zone) from which this lane departs. Drives carrier selection and rate lookup in SAP TM.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:aeoRequired rdf:type rdf:Property ;
    rdfs:label 'Aeo Required' ;
    rdfs:comment 'Indicates whether Authorized Economic Operator (AEO) certification is required for carriers or shippers operating on this lane. Enforced during carrier selection in SAP TM and compliance screening in Descartes Customs.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blueYonderLaneCode rdf:type rdf:Property ;
    rdfs:label 'Blue Yonder Lane Code' ;
    rdfs:comment 'External lane identifier assigned by Blue Yonder Supply Chain Planning system for network optimization, demand forecasting, and inventory optimization workflows. Used for cross-system reconciliation between the lakehouse and Blue Yonder.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:co2eEmissionFactor rdf:type rdf:Property ;
    rdfs:label 'Co2e Emission Factor' ;
    rdfs:comment 'Greenhouse Gas (GHG) emission factor in kilograms of Carbon Dioxide Equivalent (CO2e) per tonne-kilometre for this lane and transport mode. Used for sustainability reporting under EU ETS, CORSIA, and GHG Protocol Scope 3 calculations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationUnlocode rdf:type rdf:Property ;
    rdfs:label 'Destination Unlocode' ;
    rdfs:comment 'United Nations Code for Trade and Transport Locations (UN/LOCODE) for the lane destination node. Used in EDI messages, Air Waybill (AWB), Master Bill of Lading (MBL), and Automated Manifest System (AMS) filings.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distanceKm rdf:type rdf:Property ;
    rdfs:label 'Distance Km' ;
    rdfs:comment 'Physical distance of the lane corridor in kilometres. Used for freight rate calculation, Dimensional Weight (DIM Weight) pricing, Carbon Dioxide Equivalent (CO2e) emissions estimation, and network optimization in Blue Yonder.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distanceMiles rdf:type rdf:Property ;
    rdfs:label 'Distance Miles' ;
    rdfs:comment 'Physical distance of the lane corridor in miles. Maintained alongside distance_km to support US DOT regulatory reporting and North American carrier rate negotiations where miles are the contractual unit.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ediLaneCode rdf:type rdf:Property ;
    rdfs:label 'Edi Lane Code' ;
    rdfs:comment 'Lane identifier used in Electronic Data Interchange (EDI) messages exchanged with carriers, customs authorities, and trading partners. May differ from internal lane_code due to carrier-specific EDI mapping requirements.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyPerWeek rdf:type rdf:Property ;
    rdfs:label 'Frequency Per Week' ;
    rdfs:comment 'Number of scheduled departures per week on this lane. Used for capacity planning, shipment booking availability, and On-Time In-Full (OTIF) performance management. Sourced from carrier schedules in SAP TM.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ftzApplicable rdf:type rdf:Property ;
    rdfs:label 'Ftz Applicable' ;
    rdfs:comment 'Indicates whether this lane passes through or terminates in a Free Trade Zone (FTZ), enabling duty deferral, bonded warehouse processing, or re-export without full customs clearance. Managed in Descartes Customs.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCapacityFreeze rdf:type rdf:Property ;
    rdfs:label 'Is Capacity Freeze' ;
    rdfs:comment 'Indicates whether capacity on this lane is frozen, preventing new load optimization allocations. Set by Blue Yonder during peak season planning or carrier capacity constraint events. Synchronized to Oracle TMS for load optimization.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCrossBorder rdf:type rdf:Property ;
    rdfs:label 'Is Cross Border' ;
    rdfs:comment 'Indicates whether this lane crosses an international border, triggering customs brokerage, Importer Security Filing (ISF), and trade compliance workflows in Descartes Customs. True for international lanes; False for domestic.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDgPermitted rdf:type rdf:Property ;
    rdfs:label 'Is Dg Permitted' ;
    rdfs:comment 'Indicates whether Dangerous Goods (DG) shipments are permitted on this lane. False triggers a DG prohibition restriction. Governed by IMDG Code for ocean, ICAO Technical Instructions for air, and ADR for road transport.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEmbargoActive rdf:type rdf:Property ;
    rdfs:label 'Is Embargo Active' ;
    rdfs:comment 'Indicates whether a trade or operational embargo is currently active on this lane, blocking new shipment bookings. Embargo status is managed in Descartes Customs and synchronized to SAP TM for carrier selection exclusion.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSeasonalClosure rdf:type rdf:Property ;
    rdfs:label 'Is Seasonal Closure' ;
    rdfs:comment 'Indicates whether this lane is subject to a seasonal closure (e.g., weather-related road closures, monsoon port restrictions). When True, the lane is excluded from carrier selection and route planning during the closure window.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laneCode rdf:type rdf:Property ;
    rdfs:label 'Lane Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the lane, used in SAP TM and Oracle TMS for rate lookup, freight order management, and carrier selection. Serves as the canonical cross-system reference key.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneName rdf:type rdf:Property ;
    rdfs:label 'Lane Name' ;
    rdfs:comment 'Human-readable descriptive name for the lane, typically formatted as origin-destination pair (e.g., \'Shanghai Port – Los Angeles Port Ocean FCL\'). Used in reporting, carrier communications, and network planning dashboards.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneStatus rdf:type rdf:Property ;
    rdfs:label 'Lane Status' ;
    rdfs:comment 'Current operational lifecycle status of the lane. Active lanes are available for shipment booking and carrier allocation. Suspended lanes are temporarily unavailable. Under_review lanes are pending network optimization assessment in Blue Yonder.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneTier rdf:type rdf:Property ;
    rdfs:label 'Lane Tier' ;
    rdfs:comment 'Strategic tier classification of the lane based on volume, revenue contribution, and network criticality. Tier 1 lanes are high-volume strategic corridors; Tier 3 are low-frequency secondary lanes. Used by Blue Yonder for network optimization prioritization.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneType rdf:type rdf:Property ;
    rdfs:label 'Lane Type' ;
    rdfs:comment 'Classification of the lane by service category: express (time-definite premium), freight (standard bulk), last_mile (final delivery segment), cross_border (international), domestic (within-country), or multimodal (multiple transport modes). Drives SLA assignment and pricing tier in SAP TM. [ENUM-REF-CANDIDATE: express|freight|last_mile|cross_border|domestic|multimodal — promote to reference product]' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMileZoneCode rdf:type rdf:Property ;
    rdfs:label 'Last Mile Zone Code' ;
    rdfs:comment 'Delivery zone code for last-mile operations at the destination, used for postal zone routing, delivery slot assignment, and Door-to-Door (D2D) service configuration. Applicable when lane_type is \'last_mile\'.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Max Volume Cbm' ;
    rdfs:comment 'Maximum allowable shipment volume in Cubic Metres (CBM) for a single consignment on this lane. Used alongside Dimensional Weight (DIM Weight) calculations for air freight rating and ocean FCL/LCL capacity planning.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Weight Kg' ;
    rdfs:comment 'Maximum allowable gross shipment weight in kilograms for a single consignment on this lane. Enforced during load optimization in Oracle TMS and freight order management in SAP TM. Derived from carrier and infrastructure constraints.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkRegion rdf:type rdf:Property ;
    rdfs:label 'Network Region' ;
    rdfs:comment 'Geographic network region grouping for this lane (e.g., Asia-Pacific, Europe, Americas, Middle East Africa). Used for network planning, capacity management, and regional P&L reporting in SAP S/4HANA Finance.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originUnlocode rdf:type rdf:Property ;
    rdfs:label 'Origin Unlocode' ;
    rdfs:comment 'United Nations Code for Trade and Transport Locations (UN/LOCODE) for the lane origin node. Five-character code used in EDI (Electronic Data Interchange) messages, customs declarations, and Bill of Lading (BOL) documentation.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Free-text operational notes or remarks about this lane, capturing special handling instructions, carrier-specific requirements, or network planning context not captured in structured fields. Used by operations and network planning teams.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionAuthority rdf:type rdf:Property ;
    rdfs:label 'Restriction Authority' ;
    rdfs:comment 'Name of the regulatory body or internal authority that imposed the current lane restriction (e.g., \'IMO\', \'IATA\', \'US DOT\', \'WCO\', \'Internal Network Operations\'). Required for compliance audit and regulatory reporting.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionEffectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Restriction Effective From' ;
    rdfs:comment 'Date from which the current operational restriction on this lane becomes effective. Used by SAP TM to exclude the lane from carrier selection and by Descartes Customs for trade compliance enforcement.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restrictionEffectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Restriction Effective Until' ;
    rdfs:comment 'Date on which the current operational restriction on this lane expires and normal operations resume. Null indicates an indefinite restriction. Monitored by Blue Yonder for network re-optimization upon restriction lift.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restrictionType rdf:type rdf:Property ;
    rdfs:label 'Restriction Type' ;
    rdfs:comment 'Categorical type of the most recently applied operational restriction on this lane. Used for exception reporting and compliance audit trails. Detailed restriction history is maintained in the lane_restriction event log.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapTmLaneCode rdf:type rdf:Property ;
    rdfs:label 'Sap Tm Lane Code' ;
    rdfs:comment 'External lane identifier from SAP TM (Transportation Management) used for route planning, freight order management, charge calculation, and carrier selection. Enables bidirectional synchronization between the Silver Layer and SAP TM.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardTransitDays rdf:type rdf:Property ;
    rdfs:label 'Standard Transit Days' ;
    rdfs:comment 'Contractual standard transit time in calendar days from origin pickup to destination delivery for this lane. Used as the baseline for SLA compliance measurement, On-Time Delivery (OTD) KPI calculation, and Estimated Time of Arrival (ETA) computation in FourKites.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visibilityTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Visibility Tracking Enabled' ;
    rdfs:comment 'Indicates whether FourKites real-time GPS/IoT shipment tracking and predictive ETA calculation is enabled for shipments on this lane. Drives exception management and proactive customer notification workflows.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatorNetworkPartnerId rdf:type rdf:Property ;
    rdfs:label 'Operator Network Partner Id' ;
    rdfs:comment 'Foreign key linking to network.network_partner. Business justification: Many terminals, warehouses, and cross-docks are operated by third-party partners. Required for partner performance tracking, operational coordination, cost allocation, and partner SLA compliance monit' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address of the network node facility. Used for carrier pickup/delivery instructions, customs documentation in Descartes, and last-mile routing in Oracle TMS.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blueYonderNodeCode rdf:type rdf:Property ;
    rdfs:label 'Blue Yonder Node Code' ;
    rdfs:comment 'Node identifier as defined in Blue Yonder Supply Chain Planning for network design, demand forecasting, and inventory optimization models. Used to synchronize network topology between the lakehouse silver layer and Blue Yonder planning outputs.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cityName rdf:type rdf:Property ;
    rdfs:label 'City Name' ;
    rdfs:comment 'Name of the city or municipality where the network node is located. Used for geographic display in shipment tracking, carrier selection, and last-mile delivery zone mapping.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctpatCertified rdf:type rdf:Property ;
    rdfs:label 'Ctpat Certified' ;
    rdfs:comment 'Indicates whether the node is C-TPAT certified, confirming compliance with US Customs and Border Protection supply chain security standards. True = C-TPAT certified. Required for US-bound shipment routing and ISF filing in Descartes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsBonded rdf:type rdf:Property ;
    rdfs:label 'Customs Bonded' ;
    rdfs:comment 'Indicates whether the node operates as a customs bonded warehouse or zone, allowing storage of goods under customs control without duty payment until release. True = bonded facility. Used in Descartes Customs for trade compliance routing and ISF/AMS filing.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dgHandlingEnabled rdf:type rdf:Property ;
    rdfs:label 'Dg Handling Enabled' ;
    rdfs:comment 'Indicates whether the node is certified and equipped to handle Dangerous Goods (DG) shipments. True = DG-certified facility. Used in SAP TM carrier and route selection to ensure DG shipments are only routed through compliant nodes per IMDG Code and ICAO Technical Instructions.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:folioVisibilityCode rdf:type rdf:Property ;
    rdfs:label 'Folio Visibility Code' ;
    rdfs:comment 'Location identifier assigned to this node in the FourKites Real-Time Visibility Platform. Used to correlate network node records with live shipment tracking events, predictive ETA calculations, and exception alerts from FourKites.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftzDesignation rdf:type rdf:Property ;
    rdfs:label 'Ftz Designation' ;
    rdfs:comment 'Indicates whether the node is located within or operates as a Free Trade Zone (FTZ), enabling duty-free handling and value-added services. True = FTZ-designated node. Used for trade compliance routing in Descartes and DDP/DAP Incoterms processing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingCapacityCbm rdf:type rdf:Property ;
    rdfs:label 'Handling Capacity Cbm' ;
    rdfs:comment 'Maximum volumetric throughput capacity of the node measured in Cubic Meters (CBM) per day. Used for load optimization in Oracle TMS, capacity planning in Blue Yonder, and network bottleneck analysis.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hubTier rdf:type rdf:Property ;
    rdfs:label 'Hub Tier' ;
    rdfs:comment 'Hierarchical tier of the node within the hub-and-spoke network topology. \'primary\' = global mega-hub (e.g., main international gateway); \'secondary\' = regional hub; \'tertiary\' = country-level distribution center; \'spoke\' = local delivery depot. Drives routing hierarchy in SAP TM and Blue Yonder network design.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icaoAirportCode rdf:type rdf:Property ;
    rdfs:label 'Icao Airport Code' ;
    rdfs:comment 'Four-letter ICAO airport designator for air cargo terminal nodes (e.g., \'VHHH\' for Hong Kong International). Used for air freight routing, MAWB/HAWB coding, and ICAO regulatory compliance. Null for non-airport nodes.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imoPortCode rdf:type rdf:Property ;
    rdfs:label 'Imo Port Code' ;
    rdfs:comment 'Seven-digit IMO port facility code assigned to sea port nodes. Used for ocean freight Bill of Lading (BOL) routing, vessel manifest filing, and IMO regulatory compliance reporting. Null for non-port nodes.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxWeightCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Max Weight Capacity Kg' ;
    rdfs:comment 'Maximum gross weight in kilograms that the node can handle per shipment or per day (context defined by operational policy). Used for load optimization in Oracle TMS and freight order feasibility checks in SAP TM.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nodeCode rdf:type rdf:Property ;
    rdfs:label 'Node Code' ;
    rdfs:comment 'Externally-known, human-readable unique business code assigned to the node (e.g., \'HKG-HUB-01\', \'SIN-CFS-02\'). Used as the operational reference key in SAP TM route planning, Blue Yonder network design, and FourKites visibility integration.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeName rdf:type rdf:Property ;
    rdfs:label 'Node Name' ;
    rdfs:comment 'Full descriptive name of the network node (e.g., \'Hong Kong International Gateway Hub\', \'Singapore Container Freight Station\'). Used in operational reports, carrier communications, and customer-facing shipment tracking.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeStatus rdf:type rdf:Property ;
    rdfs:label 'Node Status' ;
    rdfs:comment 'Current lifecycle status of the network node. Controls whether the node is available for route planning and shipment assignment in SAP TM and Oracle TMS. \'active\' = fully operational; \'inactive\' = temporarily not in use; \'suspended\' = operations halted pending review; \'under_construction\' = not yet operational; \'decommissioned\' = permanently retired from the network.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeType rdf:type rdf:Property ;
    rdfs:label 'Node Type' ;
    rdfs:comment 'Classification of the node by its operational role in the transport network. Drives hub-and-spoke topology logic in SAP TM and Blue Yonder. Values: hub (major consolidation/distribution center), gateway (international entry/exit point), sorting_center (parcel sorting facility), warehouse (storage and fulfillment), port (sea port terminal), airport (air cargo terminal), icd (Inland Container Depot), cfs (Container Freight Station), ftz (Free Trade Zone), last_mile_depot (final delivery depot). [ENUM-REF-CANDIDATE: hub|gateway|sorting_center|warehouse|port|airport|icd|cfs|ftz|last_mile_depot — promote to reference product]' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingDays rdf:type rdf:Property ;
    rdfs:label 'Operating Days' ;
    rdfs:comment 'Comma-separated list of operating days using ISO weekday abbreviations (e.g., \'MON,TUE,WED,THU,FRI\' or \'MON,TUE,WED,THU,FRI,SAT\'). Used for freight scheduling, carrier dispatch planning, and SLA transit time calculation in SAP TM.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursEnd rdf:type rdf:Property ;
    rdfs:label 'Operating Hours End' ;
    rdfs:comment 'Local time at which the node ceases operations each day in HH:MM 24-hour format (e.g., \'22:00\'). Used by SAP TM for cut-off time enforcement, freight order scheduling, and SLA breach risk assessment.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursStart rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Start' ;
    rdfs:comment 'Local time at which the node begins operations each day in HH:MM 24-hour format (e.g., \'06:00\'). Used by SAP TM for freight order scheduling, carrier appointment booking, and last-mile delivery window planning.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oversizedCargoEnabled rdf:type rdf:Property ;
    rdfs:label 'Oversized Cargo Enabled' ;
    rdfs:comment 'Indicates whether the node has the equipment and infrastructure to handle oversized or out-of-gauge cargo (e.g., heavy lift cranes, wide-load bays). True = oversized cargo capable. Used in SAP TM special cargo routing.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentNodeCode rdf:type rdf:Property ;
    rdfs:label 'Parent Node Code' ;
    rdfs:comment 'Node code of the parent node in the hub-and-spoke hierarchy (e.g., a spoke depot\'s parent is its regional hub). Enables hierarchical network topology traversal for route planning and network performance roll-up reporting. Self-referencing relationship resolved in the linking step.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Internal geographic region code grouping the node into a commercial or operational region (e.g., \'APAC\', \'EMEA\', \'AMER\', \'MEA\'). Used for network performance reporting, regional P&L allocation in SAP S/4HANA Finance, and Blue Yonder network design segmentation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageCapacityCbm rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Cbm' ;
    rdfs:comment 'Maximum static storage capacity of the node measured in Cubic Meters (CBM). Used for warehouse capacity planning in Manhattan WMS, inventory optimization in Blue Yonder, and network design decisions.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tempRangeMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temp Range Max Celsius' ;
    rdfs:comment 'Maximum temperature in degrees Celsius that the node\'s temperature-controlled facility can maintain (e.g., 8.00 for refrigerated). Null if temperature_controlled is False. Used for cold-chain shipment routing and cargo integrity compliance.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tempRangeMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temp Range Min Celsius' ;
    rdfs:comment 'Minimum temperature in degrees Celsius that the node\'s temperature-controlled facility can maintain (e.g., -25.00 for deep freeze). Null if temperature_controlled is False. Used for cold-chain shipment routing and SLA compliance validation.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:teuCapacity rdf:type rdf:Property ;
    rdfs:label 'Teu Capacity' ;
    rdfs:comment 'Maximum container throughput capacity of the node measured in Twenty-foot Equivalent Units (TEU) per day. Applicable to port, ICD, CFS, and FTZ nodes. Used for ocean freight capacity planning and FCL/LCL load optimization in Oracle TMS.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timezoneCode rdf:type rdf:Property ;
    rdfs:label 'Timezone Code' ;
    rdfs:comment 'IANA time zone identifier for the node\'s local time zone (e.g., \'Asia/Hong_Kong\', \'America/New_York\', \'Europe/London\'). Critical for accurate ETD/ETA calculation, operating hours enforcement in SAP TM, and SLA compliance measurement across time zones.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tmsLocationCode rdf:type rdf:Property ;
    rdfs:label 'Tms Location Code' ;
    rdfs:comment 'Location identifier code as registered in SAP TM and Oracle TMS for route planning, freight order management, and carrier selection. Serves as the cross-system reference key for transport execution systems.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unLocode rdf:type rdf:Property ;
    rdfs:label 'Un Locode' ;
    rdfs:comment 'Five-character UN/LOCODE identifying the geographic location of the node (e.g., \'HKHKG\', \'SGSIN\'). Used for Bill of Lading (BOL), customs declarations in Descartes, and EDI messaging per WCO standards. Provides a globally standardized location reference across all transport modes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wmsFacilityCode rdf:type rdf:Property ;
    rdfs:label 'Wms Facility Code' ;
    rdfs:comment 'Facility identifier code as registered in Manhattan WMS for nodes that perform warehousing and fulfillment operations. Used to link network node records to WMS inventory, labor, and slotting data. Null for non-warehouse nodes.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeAgreementId rdf:type rdf:Property ;
    rdfs:label 'Trade Agreement Id' ;
    rdfs:comment 'Foreign key linking to customs.trade_agreement. Business justification: Service corridor planning incorporates trade agreement zones for network optimization. Corridors designed to leverage FTA benefits (e.g., USMCA-compliant routing through Mexico) require explicit agree' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeAgreement .

ind:awbPrefix rdf:type rdf:Property ;
    rdfs:label 'Awb Prefix' ;
    rdfs:comment 'Three-digit IATA Air Waybill (AWB) prefix assigned to the primary carrier operating this air corridor. Applicable only for AIR transport mode corridors. Used for MAWB (Master Air Waybill) and HAWB (House Air Waybill) number generation in SAP TM.' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityTeu rdf:type rdf:Property ;
    rdfs:label 'Capacity Teu' ;
    rdfs:comment 'Weekly or per-departure capacity of this corridor expressed in Twenty-foot Equivalent Units (TEU) for ocean corridors, or equivalent volumetric capacity for other modes. Used in Blue Yonder capacity planning and SAP TM load optimization.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierScacCodes rdf:type rdf:Property ;
    rdfs:label 'Carrier Scac Codes' ;
    rdfs:comment 'Comma-separated list of Standard Carrier Alpha Codes (SCAC) or IATA carrier codes for carriers allocated to operate on this corridor. Used in SAP TM carrier selection and Oracle TMS freight audit. Supports multi-carrier corridor configurations.' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corridorCode rdf:type rdf:Property ;
    rdfs:label 'Corridor Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the service corridor, used in SAP TM route planning and Blue Yonder network design (e.g., \'APAC-AIR-EXP-01\', \'TPAC-OCN-FCL-02\'). Referenced in EDI messages and carrier lane allocations.' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corridorName rdf:type rdf:Property ;
    rdfs:label 'Corridor Name' ;
    rdfs:comment 'Human-readable name of the service corridor describing the route path and service product (e.g., \'Express Air Asia-Pacific\', \'Ocean FCL Trans-Pacific\', \'Road FTL Europe Central\'). Used in operational dashboards, carrier communications, and Blue Yonder network design outputs.' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corridorStatus rdf:type rdf:Property ;
    rdfs:label 'Corridor Status' ;
    rdfs:comment 'Current operational lifecycle status of the service corridor. ACTIVE corridors are available for shipment routing in SAP TM. SUSPENDED corridors are temporarily unavailable (e.g., due to port congestion, regulatory hold). PLANNED corridors are in network design phase in Blue Yonder. DISCONTINUED corridors are archived.' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Required' ;
    rdfs:comment 'Indicates whether customs clearance is required for shipments transiting this corridor. TRUE for cross-border corridors requiring Descartes Customs processing, ISF filing, and AMS submission. FALSE for domestic or intra-customs-union corridors (e.g., intra-EU).' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destinationHubCode rdf:type rdf:Property ;
    rdfs:label 'Destination Hub Code' ;
    rdfs:comment 'IATA airport code or UN/LOCODE of the primary destination hub node for this corridor (e.g., \'LHR\' for London Heathrow, \'USLAX\' for Los Angeles). Anchors the corridor\'s terminal network node in SAP TM route planning and FourKites real-time visibility.' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationRegion rdf:type rdf:Property ;
    rdfs:label 'Destination Region' ;
    rdfs:comment 'Named geographic region where the service corridor terminates (e.g., \'Europe\', \'Middle East\', \'Latin America\'). Used for network topology grouping, lane allocation, and Blue Yonder network design. Distinct from specific destination node.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directionType rdf:type rdf:Property ;
    rdfs:label 'Direction Type' ;
    rdfs:comment 'Indicates whether the corridor is defined for outbound (origin to destination), inbound (destination to origin), or bilateral (both directions) traffic flow. Drives lane allocation and backhaul optimization in SAP TM and Oracle TMS.' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediEnabled rdf:type rdf:Property ;
    rdfs:label 'Edi Enabled' ;
    rdfs:comment 'Indicates whether Electronic Data Interchange (EDI) messaging is enabled for carrier communications on this corridor (e.g., EDI 214 shipment status, EDI 210 freight invoice). Drives automated data exchange configuration in SAP TM and Oracle TMS freight audit.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freightProduct rdf:type rdf:Property ;
    rdfs:label 'Freight Product' ;
    rdfs:comment 'Specific freight product type carried on this corridor. FCL (Full Container Load), LCL (Less than Container Load), FTL (Full Truckload), LTL (Less than Truckload), AIR_FREIGHT, PARCEL, BULK, or BREAKBULK. Governs load optimization rules in Oracle TMS and capacity planning in Blue Yonder. [ENUM-REF-CANDIDATE: FCL|LCL|FTL|LTL|AIR_FREIGHT|PARCEL|BULK|BREAKBULK — promote to reference product]' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyDaysOfWeek rdf:type rdf:Property ;
    rdfs:label 'Frequency Days Of Week' ;
    rdfs:comment 'Comma-separated list of days on which the corridor operates (e.g., \'MON,WED,FRI\' for tri-weekly ocean service, \'MON,TUE,WED,THU,FRI,SAT,SUN\' for daily express). Used in SAP TM departure scheduling and customer-facing ETD commitments.' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyType rdf:type rdf:Property ;
    rdfs:label 'Frequency Type' ;
    rdfs:comment 'Operational frequency at which the service corridor runs (e.g., DAILY for express parcel, WEEKLY for ocean FCL). Drives departure schedule planning in SAP TM, capacity allocation in Blue Yonder, and ETD/ETA commitments communicated to customers.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hubSpokeRole rdf:type rdf:Property ;
    rdfs:label 'Hub Spoke Role' ;
    rdfs:comment 'Classification of this corridor\'s role within the hub-and-spoke network topology. HUB_TO_HUB for main trunk routes, HUB_TO_SPOKE for distribution legs, SPOKE_TO_HUB for collection legs, SPOKE_TO_SPOKE for direct point-to-point routes. Used in Blue Yonder network design and SAP TM route planning.' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsApplicability rdf:type rdf:Property ;
    rdfs:label 'Incoterms Applicability' ;
    rdfs:comment 'Comma-separated list of Incoterms (International Commercial Terms) applicable to shipments on this corridor (e.g., \'FOB,CIF,DDP,DAP,EXW\'). Governs risk transfer and cost responsibility rules for cross-border shipments. Aligned with ICC Incoterms 2020 and WTO trade facilitation requirements.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intermediateHubSequence rdf:type rdf:Property ;
    rdfs:label 'Intermediate Hub Sequence' ;
    rdfs:comment 'Ordered, pipe-delimited sequence of intermediate hub codes (IATA or UN/LOCODE) traversed between origin and destination (e.g., \'DXB|FRA\' for Dubai then Frankfurt). Defines the multi-node path that distinguishes a corridor from a single O-D lane. Consumed by SAP TM for multi-leg route planning.' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMileIncluded rdf:type rdf:Property ;
    rdfs:label 'Last Mile Included' ;
    rdfs:comment 'Indicates whether last-mile delivery to the final consignee is included within this corridor\'s scope. TRUE for D2D (Door-to-Door) corridors. FALSE for port-to-port or hub-to-hub corridors where last-mile is handled separately.' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legCount rdf:type rdf:Property ;
    rdfs:label 'Leg Count' ;
    rdfs:comment 'Total number of transport legs in this service corridor, including origin-to-first-hub, all intermediate legs, and final leg to destination. Derived from the hub sequence but stored for query performance in SAP TM load optimization and Blue Yonder network design.' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:networkDesignCode rdf:type rdf:Property ;
    rdfs:label 'Network Design Code' ;
    rdfs:comment 'Reference to the Blue Yonder network design scenario that generated or last optimized this corridor configuration. Enables traceability between network optimization outputs and operational corridor definitions.' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originRegion rdf:type rdf:Property ;
    rdfs:label 'Origin Region' ;
    rdfs:comment 'Named geographic region where the service corridor originates (e.g., \'Asia-Pacific\', \'North America\', \'Europe\'). Used for network topology grouping, lane allocation, and Blue Yonder network design. Distinct from specific origin node — this is the macro-geographic classification.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Primary Carrier Code' ;
    rdfs:comment 'SCAC or IATA code of the primary/preferred carrier for this corridor. Used as the default carrier in SAP TM carrier selection logic. Distinct from carrier_scac_codes which lists all allocated carriers.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Numeric priority ranking of this corridor relative to alternative corridors for the same O-D pair. Lower values indicate higher priority in SAP TM carrier selection and load optimization. Used when multiple corridors serve the same origin-destination combination.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceLevelCode rdf:type rdf:Property ;
    rdfs:label 'Service Level Code' ;
    rdfs:comment 'Internal SLA (Service Level Agreement) code that maps this corridor to a defined service level tier (e.g., \'P1-NEXT-DAY\', \'P2-2DAY\', \'STD-5DAY\'). Links to SLA entitlement definitions in Salesforce CRM and drives OTD/OTIF KPI measurement.' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceType rdf:type rdf:Property ;
    rdfs:label 'Service Type' ;
    rdfs:comment 'Classification of the service product offered on this corridor (e.g., EXPRESS for time-definite delivery, STANDARD for deferred, ECONOMY for cost-optimized). Determines SLA commitments, pricing tiers, and priority handling rules in SAP TM and Oracle TMS.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardTransitHours rdf:type rdf:Property ;
    rdfs:label 'Standard Transit Hours' ;
    rdfs:comment 'Standard total transit time expressed in hours for sub-day precision, particularly relevant for express air corridors where transit is measured in hours rather than days (e.g., 18 hours for an overnight express air corridor). Complements standard_transit_days for precise ETA calculation.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionEndDate rdf:type rdf:Property ;
    rdfs:label 'Suspension End Date' ;
    rdfs:comment 'Expected or actual date on which a suspended corridor resumes operations. NULL if suspension end date is unknown. Used for proactive customer communication in Salesforce CRM and re-routing planning in SAP TM.' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'Reason code for corridor suspension. Used for exception reporting, root cause analysis, and regulatory compliance documentation. [ENUM-REF-CANDIDATE: PORT_CONGESTION|REGULATORY_EMBARGO|FORCE_MAJEURE|CARRIER_CAPACITY|INFRASTRUCTURE|SEASONAL|OTHER — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionStartDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Start Date' ;
    rdfs:comment 'Date from which the corridor is temporarily suspended (e.g., due to port congestion, regulatory embargo, force majeure). Populated only when corridor_status is SUSPENDED. Used for exception management in FourKites and customer notification in Salesforce CRM.' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trackingVisibilityEnabled rdf:type rdf:Property ;
    rdfs:label 'Tracking Visibility Enabled' ;
    rdfs:comment 'Indicates whether real-time shipment tracking and predictive ETA via FourKites is enabled for this corridor. TRUE enables GPS/IoT-based visibility, exception alerts, and predictive ETA updates for shipments on this corridor.' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:corridorLegId rdf:type rdf:Property ;
    rdfs:label 'Corridor Leg Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual transport leg within a service corridor. Primary key for the corridor_leg entity in the Silver Layer lakehouse.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorridorLeg .

ind:destinationNodeNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Destination Node Network Node Id' ;
    rdfs:comment 'Reference to the network node (hub, port, airport, depot, ICD, CFS, or warehouse) where this leg terminates. Together with origin_node_id defines the origin-destination (OD) pair for this leg.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:primaryCorridorNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Corridor Network Node Id' ;
    rdfs:comment 'Reference to the network node (hub, port, airport, depot, ICD, CFS, or warehouse) where this leg originates. Supports hub-and-spoke topology decomposition in SAP TM and Oracle TMS.' ;
    rdfs:domain ind:CorridorLeg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:carrierType rdf:type rdf:Property ;
    rdfs:label 'Carrier Type' ;
    rdfs:comment 'Classification of the carrier operating this leg. Determines applicable regulatory frameworks (IATA for airlines, IMO for ocean carriers, DOT for road), rate structures, and liability regimes. NVOCC applies to Non-Vessel Operating Common Carriers. [ENUM-REF-CANDIDATE: AIRLINE|OCEAN_CARRIER|ROAD_CARRIER|RAIL_OPERATOR|NVOCC|COURIER|INTERMODAL — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cutoffTime rdf:type rdf:Property ;
    rdfs:label 'Cutoff Time' ;
    rdfs:comment 'Latest local time (HH:MM, 24-hour) by which freight must be tendered at the origin node to be accepted on this leg\'s scheduled departure. Critical for shipment booking deadlines in Oracle TMS and customer SLA management.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:departureDaysMask rdf:type rdf:Property ;
    rdfs:label 'Departure Days Mask' ;
    rdfs:comment '7-character binary string (Mon=pos1 through Sun=pos7) indicating which days of the week this leg operates departures (1=operates, 0=does not operate). Enables precise booking calendar generation in SAP TM and Oracle TMS scheduling.' ;
    rdfs:domain ind:CorridorLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departureFrequency rdf:type rdf:Property ;
    rdfs:label 'Departure Frequency' ;
    rdfs:comment 'Frequency at which this leg operates departures. Drives shipment booking availability windows, capacity planning in Blue Yonder, and customer-facing transit time commitments. ON_DEMAND applies to charter and FTL legs.' ;
    rdfs:domain ind:CorridorLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationLocationCode rdf:type rdf:Property ;
    rdfs:label 'Destination Location Code' ;
    rdfs:comment 'Standardized location code for the leg destination — IATA airport code (3-letter) for air legs, UN/LOCODE (5-character) for ocean/road/rail legs. Used in AWB, BOL, and HAWB generation and customs declarations in Descartes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'Date after which this corridor leg definition is no longer operationally valid. Null indicates an open-ended lane with no planned expiry. Used for seasonal route deactivation, carrier contract expiry alignment, and network change management.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fourtitesTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Fourtites Tracking Enabled' ;
    rdfs:comment 'Indicates whether this leg is enrolled in FourKites real-time visibility tracking (True). When enabled, GPS/IoT telemetry is streamed for predictive ETA updates and exception management. Supports independent leg trackability as defined in the corridor_leg product scope.' ;
    rdfs:domain ind:CorridorLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDangerousGoodsPermitted rdf:type rdf:Property ;
    rdfs:label 'Is Dangerous Goods Permitted' ;
    rdfs:comment 'Indicates whether this leg is certified and permitted to carry dangerous goods (True) or not (False). Governs shipment acceptance rules per IMDG Code for ocean legs and ICAO Technical Instructions for air legs.' ;
    rdfs:domain ind:CorridorLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legCode rdf:type rdf:Property ;
    rdfs:label 'Leg Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for this corridor leg, used in SAP TM route planning, Oracle TMS load optimization, and EDI interchange with carriers. Unique within the parent corridor.' ;
    rdfs:domain ind:CorridorLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Leg Sequence Number' ;
    rdfs:comment 'Ordinal position of this leg within the parent corridor, starting at 1. Defines the execution order for multi-modal route decomposition (e.g., leg 1 = road pickup, leg 2 = air haul, leg 3 = road delivery). Aligns with Oracle TMS load optimization sequencing.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:legStatus rdf:type rdf:Property ;
    rdfs:label 'Leg Status' ;
    rdfs:comment 'Current operational lifecycle status of this corridor leg. ACTIVE legs are available for shipment assignment; SUSPENDED legs are temporarily unavailable; DISCONTINUED legs are retired from the network. Governs availability in Oracle TMS load optimization.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadType rdf:type rdf:Property ;
    rdfs:label 'Load Type' ;
    rdfs:comment 'Freight load configuration for this leg. FTL (Full Truckload), LTL (Less Than Truckload), FCL (Full Container Load), LCL (Less Than Container Load), PARCEL, BULK, or BREAK_BULK. Drives Oracle TMS load optimization, rate calculation, and capacity planning in Blue Yonder. [ENUM-REF-CANDIDATE: FTL|LTL|FCL|LCL|PARCEL|BULK|BREAK_BULK — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxVolumeCapacityCbm rdf:type rdf:Property ;
    rdfs:label 'Max Volume Capacity Cbm' ;
    rdfs:comment 'Maximum volumetric capacity in Cubic Metres (CBM) available on this leg per departure. Used alongside max_weight_capacity_kg for DIM weight-based load optimization and capacity utilization analytics in Oracle TMS.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originLocationCode rdf:type rdf:Property ;
    rdfs:label 'Origin Location Code' ;
    rdfs:comment 'Standardized location code for the leg origin — IATA airport code (3-letter) for air legs, UN/LOCODE (5-character) for ocean/road/rail legs. Used in AWB, BOL, and HAWB generation and AMS/ISF filings.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaOnTimeThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Sla On Time Threshold Hours' ;
    rdfs:comment 'Maximum allowable transit time in hours for this leg before it is classified as a late delivery for OTD (On-Time Delivery) and OTIF (On-Time In-Full) KPI measurement. Sourced from contracted SLA terms and used in FourKites exception management.' ;
    rdfs:domain ind:CorridorLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Standard Arrival Time' ;
    rdfs:comment 'Standard local arrival time (HH:MM, 24-hour) at the destination node for this leg. Used as the baseline Estimated Time of Arrival (ETA) for downstream leg connections, delivery scheduling, and OTD/OTIF KPI measurement.' ;
    rdfs:domain ind:CorridorLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:standardDepartureTime rdf:type rdf:Property ;
    rdfs:label 'Standard Departure Time' ;
    rdfs:comment 'Standard local departure time (HH:MM, 24-hour) for this leg at the origin node. Used as the baseline Estimated Time of Departure (ETD) for shipment scheduling, FourKites tracking initialization, and customer notification triggers.' ;
    rdfs:domain ind:CorridorLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:temperatureMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Max Celsius' ;
    rdfs:comment 'Maximum temperature in degrees Celsius maintained during transport on this leg. Applicable only when is_temperature_controlled is True. Used for cold chain compliance validation and cargo acceptance rules.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Min Celsius' ;
    rdfs:comment 'Minimum temperature in degrees Celsius maintained during transport on this leg. Applicable only when is_temperature_controlled is True. Used for cold chain compliance validation and cargo acceptance rules.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timezoneDestination rdf:type rdf:Property ;
    rdfs:label 'Timezone Destination' ;
    rdfs:comment 'IANA timezone identifier for the destination node (e.g., Asia/Singapore, Europe/Frankfurt). Required to correctly interpret standard_arrival_time and compute accurate ETA in local destination time for delivery scheduling.' ;
    rdfs:domain ind:CorridorLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timezoneOrigin rdf:type rdf:Property ;
    rdfs:label 'Timezone Origin' ;
    rdfs:comment 'IANA timezone identifier for the origin node (e.g., America/New_York, Europe/London). Required to correctly interpret cutoff_time and standard_departure_time for cross-timezone route planning and ETA calculations.' ;
    rdfs:domain ind:CorridorLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingMethod rdf:type rdf:Property ;
    rdfs:label 'Tracking Method' ;
    rdfs:comment 'Method used to track shipment progress on this leg. GPS for road/fleet, AIS (Automatic Identification System) for ocean vessels, EDI_MILESTONE for carrier EDI updates, API_CARRIER for direct carrier API integration, RFID for warehouse handoffs, or MANUAL for exception-based updates. Drives FourKites data ingestion configuration.' ;
    rdfs:domain ind:CorridorLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleType rdf:type rdf:Property ;
    rdfs:label 'Vehicle Type' ;
    rdfs:comment 'Type of vehicle, vessel, or aircraft used on this leg (e.g., B747F for air freighter, 20FT_CONTAINER for ocean, SEMI_TRAILER for road, FLATCAR for rail). Determines capacity constraints, dangerous goods handling rules per IMDG/ICAO TI, and emissions factors for CO2e calculation.' ;
    rdfs:domain ind:CorridorLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicingAgentId rdf:type rdf:Property ;
    rdfs:label 'Servicing Agent Id' ;
    rdfs:comment 'Foreign key linking to network.agent. Business justification: Last-mile delivery zones are frequently serviced by local agents. Required for agent commission calculation, service coverage validation, and agent performance tracking. Essential for agent-based dist' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:servingDepotId rdf:type rdf:Property ;
    rdfs:label 'Serving Depot Id' ;
    rdfs:comment 'Foreign key linking to fleet.fleet_depot. Business justification: Delivery zones are served from specific depots; linking enables territory management, last-mile route planning, depot workload balancing, and service coverage analysis.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:applicableServiceProducts rdf:type rdf:Property ;
    rdfs:label 'Applicable Service Products' ;
    rdfs:comment 'Pipe-separated list of service product codes eligible for delivery within this zone (e.g., \'EXPRESS|STANDARD|ECONOMY|FREIGHT\'). Drives service product availability validation during shipment booking and carrier selection in SAP TM. [ENUM-REF-CANDIDATE: promote to reference product for zone-service-product association]' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaSqkm rdf:type rdf:Property ;
    rdfs:label 'Area Sqkm' ;
    rdfs:comment 'Total geographic area of the delivery zone in square kilometres. Used in network density analysis, carrier capacity planning, and cost-per-delivery benchmarking in Blue Yonder network design.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Code' ;
    rdfs:comment 'Code of the primary carrier or last-mile delivery partner assigned to service this zone. Used in carrier selection logic within SAP TM and Oracle TMS. May be overridden by dynamic carrier selection based on capacity and cost.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:co2eFactorKgPerShipment rdf:type rdf:Property ;
    rdfs:label 'Co2e Factor Kg Per Shipment' ;
    rdfs:comment 'Estimated CO2e (Carbon Dioxide Equivalent) emission factor in kilograms per shipment for last-mile delivery within this zone. Used for GHG (Greenhouse Gas) emissions reporting, EU ETS compliance, and CORSIA carbon offsetting calculations.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:codRestricted rdf:type rdf:Property ;
    rdfs:label 'Cod Restricted' ;
    rdfs:comment 'Indicates whether Cash on Delivery (COD) service is restricted or unavailable within this delivery zone. COD restrictions may apply due to security concerns, carrier capability limitations, or local regulatory requirements. Referenced during e-commerce fulfillment order validation.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coverageGeojson rdf:type rdf:Property ;
    rdfs:label 'Coverage Geojson' ;
    rdfs:comment 'GeoJSON-encoded polygon or multipolygon representing the precise geographic boundary of the delivery zone. Used for GPS-based serviceability validation, FourKites real-time visibility geofencing, and last-mile dispatch optimization. Stored as serialized GeoJSON string per RFC 7946.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsZoneType rdf:type rdf:Property ;
    rdfs:label 'Customs Zone Type' ;
    rdfs:comment 'Classification of the zone from a customs and trade compliance perspective: domestic (standard domestic territory), ftz (Free Trade Zone), bonded (customs bonded area), international (cross-border delivery zone), special_economic (Special Economic Zone). Used in Descartes Customs for trade compliance routing and ISF/AMS filing requirements.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dgRestricted rdf:type rdf:Property ;
    rdfs:label 'Dg Restricted' ;
    rdfs:comment 'Indicates whether the transport of dangerous goods (DG) is restricted or prohibited within this delivery zone. Enforced during shipment booking validation and carrier selection. Aligned with IMDG Code, ICAO Technical Instructions, and local regulatory requirements.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hubNodeCode rdf:type rdf:Property ;
    rdfs:label 'Hub Node Code' ;
    rdfs:comment 'Code of the hub, depot, or distribution center assigned to service this delivery zone in the hub-and-spoke network topology. Drives carrier selection, load optimization, and last-mile dispatch routing in SAP TM and Oracle TMS.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isfRequired rdf:type rdf:Property ;
    rdfs:label 'Isf Required' ;
    rdfs:comment 'Indicates whether an Importer Security Filing (ISF) is required for shipments entering this zone. Applicable to US import zones under CBP 10+2 rule. Used in Descartes Customs for automated compliance filing.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxDimWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Dim Weight Kg' ;
    rdfs:comment 'Maximum dimensional weight (DIM weight) in kilograms accepted for delivery within this zone. DIM weight is calculated from volumetric dimensions and used alongside actual weight for carrier charge calculation and capacity planning.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxLengthCm rdf:type rdf:Property ;
    rdfs:label 'Max Length Cm' ;
    rdfs:comment 'Maximum allowable length in centimetres for a single shipment piece accepted for delivery within this zone. Used in oversized shipment validation during booking and load optimization in Oracle TMS.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oversizedRestricted rdf:type rdf:Property ;
    rdfs:label 'Oversized Restricted' ;
    rdfs:comment 'Indicates whether oversized or overweight shipments are restricted within this delivery zone due to infrastructure limitations, road access constraints, or local regulations. Used in load optimization and carrier selection in Oracle TMS.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:peakSurcharge rdf:type rdf:Property ;
    rdfs:label 'Peak Surcharge' ;
    rdfs:comment 'Indicates whether a peak season surcharge is applicable for this zone during designated peak periods (e.g., holiday season, Chinese New Year). Drives dynamic pricing adjustments in SAP TM charge calculation.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postalCodeFrom rdf:type rdf:Property ;
    rdfs:label 'Postal Code From' ;
    rdfs:comment 'Starting postal code of the range covered by this delivery zone. Together with postal_code_to, defines the postal code band for zone membership evaluation. Used in SAP TM zone-based routing and pricing surcharge determination.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCodeTo rdf:type rdf:Property ;
    rdfs:label 'Postal Code To' ;
    rdfs:comment 'Ending postal code of the range covered by this delivery zone. Together with postal_code_from, defines the postal code band for zone membership evaluation. Null if the zone is defined by a single postal code or polygon only.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteAreaSurcharge rdf:type rdf:Property ;
    rdfs:label 'Remote Area Surcharge' ;
    rdfs:comment 'Indicates whether a remote area surcharge (RAS) applies to shipments delivered within this zone. Remote area surcharges are applied by carriers for zones with limited accessibility or extended delivery routes. Referenced by the pricing and rating domain for charge calculation.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residentialSurcharge rdf:type rdf:Property ;
    rdfs:label 'Residential Surcharge' ;
    rdfs:comment 'Indicates whether a residential delivery surcharge applies to shipments within this zone. Residential surcharges are levied by carriers for deliveries to non-commercial addresses. Used in pricing and rating charge calculation for B2C and e-commerce fulfillment.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceCutoffTime rdf:type rdf:Property ;
    rdfs:label 'Service Cutoff Time' ;
    rdfs:comment 'Latest time of day (HH:MM, 24-hour local time) by which a shipment must be tendered to the hub to achieve the standard transit time for this zone. Critical for last-mile dispatch scheduling and customer booking cutoff enforcement.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceDays rdf:type rdf:Property ;
    rdfs:label 'Service Days' ;
    rdfs:comment 'Pipe-separated list of days of the week on which delivery service operates within this zone (e.g., \'MON|TUE|WED|THU|FRI\'). Used for ETA calculation, SLA management, and dispatch scheduling. Supports zones with restricted weekend or holiday service.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceable rdf:type rdf:Property ;
    rdfs:label 'Serviceable' ;
    rdfs:comment 'Master serviceability flag indicating whether Transport Shipping currently provides delivery service within this zone. A zone may be defined but temporarily unserviceable due to operational, regulatory, or capacity constraints. Used as the primary gate in shipment booking serviceability checks.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaStandardCode rdf:type rdf:Property ;
    rdfs:label 'Sla Standard Code' ;
    rdfs:comment 'Code referencing the standard SLA profile applicable to this delivery zone. Defines OTD (On-Time Delivery) and OTIF (On-Time In-Full) performance targets. Used in SLA entitlement validation and KPI reporting.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvinceCode rdf:type rdf:Property ;
    rdfs:label 'State Province Code' ;
    rdfs:comment 'ISO 3166-2 subdivision code for the state, province, or region within the country (e.g., US-CA, GB-ENG, AU-NSW). Used for sub-national routing rules, tax jurisdiction mapping, and regional SLA configuration.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlledCapable rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Capable' ;
    rdfs:comment 'Indicates whether temperature-controlled (cold chain) delivery is available within this zone. Used during shipment booking to validate serviceability for pharmaceutical, perishable, and temperature-sensitive cargo.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transitTimeHours rdf:type rdf:Property ;
    rdfs:label 'Transit Time Hours' ;
    rdfs:comment 'Standard transit time expressed in total hours for time-definite and express service products where sub-day precision is required. Complements standard_transit_days for same-day, next-day, and time-critical shipment SLA management.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneCode rdf:type rdf:Property ;
    rdfs:label 'Zone Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the delivery zone across systems (SAP TM, Oracle TMS, FourKites). Used as the business key for zone-based routing, surcharge lookup, and carrier selection. Maps to the zone identifier in SAP TM zone-based routing configuration.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneDescription rdf:type rdf:Property ;
    rdfs:label 'Zone Description' ;
    rdfs:comment 'Free-text description providing additional context about the delivery zone, including notable geographic features, operational constraints, special handling instructions, or historical notes. Used by operations and network planning teams.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneGroupCode rdf:type rdf:Property ;
    rdfs:label 'Zone Group Code' ;
    rdfs:comment 'Code of the zone group or zone cluster to which this delivery zone belongs. Zone groups aggregate individual zones for pricing rate card application, carrier contract negotiation, and network planning. Used in SAP TM zone group configuration.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneName rdf:type rdf:Property ;
    rdfs:label 'Zone Name' ;
    rdfs:comment 'Human-readable name of the delivery zone (e.g., \'Greater London Last-Mile Zone\', \'Singapore CBD Service Area\'). Used in operational dashboards, carrier communications, and customer-facing serviceability checks.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneStatus rdf:type rdf:Property ;
    rdfs:label 'Zone Status' ;
    rdfs:comment 'Current lifecycle status of the delivery zone. Active zones are eligible for shipment routing and serviceability validation. Inactive or retired zones are excluded from new shipment assignments. Suspended zones may be temporarily blocked due to operational or regulatory reasons.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneTier rdf:type rdf:Property ;
    rdfs:label 'Zone Tier' ;
    rdfs:comment 'Service tier classification of the zone reflecting delivery density, infrastructure quality, and cost profile (e.g., tier_1 = major urban centre, tier_4 = remote/rural). Used in pricing rate card assignment, SLA differentiation, and network optimization in Blue Yonder.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneType rdf:type rdf:Property ;
    rdfs:label 'Zone Type' ;
    rdfs:comment 'Classification of the zone by its definition methodology: postal (based on postal code ranges), administrative (country/state/city boundaries), custom (business-defined polygon), last_mile (final delivery leg zone), service_area (carrier or hub service coverage area). Drives routing logic and surcharge applicability in SAP TM.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originRouteDeliveryZoneId rdf:type rdf:Property ;
    rdfs:label 'Origin Route Delivery Zone Id' ;
    rdfs:comment 'Foreign key linking to route.route_delivery_zone. Business justification: transit_time_standard captures origin_zone_code as a STRING, which is a denormalized reference to the origin route_delivery_zone. Adding origin_route_delivery_zone_id as a FK to route.route_delivery_z' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RouteDeliveryZone .

ind:primaryTransitLaneId rdf:type rdf:Property ;
    rdfs:label 'Primary Transit Lane Id' ;
    rdfs:comment 'Reference to the origin-destination lane master record that this transit time standard applies to. Links to the lane product in the route domain.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lane .

ind:supersededByTransitTimeStandardId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Transit Time Standard Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the newer transit time standard record that replaces this one when lifecycle_status is SUPERSEDED. Enables version chain traversal for historical SLA analysis.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransitTimeStandard .

ind:blueYonderStandardCode rdf:type rdf:Property ;
    rdfs:label 'Blue Yonder Standard Code' ;
    rdfs:comment 'External identifier from Blue Yonder Supply Chain Planning that maps this transit time standard to the network design and demand forecasting outputs. Enables traceability between the route domain SSOT and Blue Yonder optimization results.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsClearanceDays rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Days' ;
    rdfs:comment 'Number of days allocated for customs clearance included within the standard transit time for cross-border shipments. Used in Descartes Customs integration and trade compliance planning. Relevant for DDP, DAP, and CIF Incoterms.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cutoffTimezone rdf:type rdf:Property ;
    rdfs:label 'Cutoff Timezone' ;
    rdfs:comment 'IANA timezone identifier for the cut-off time (e.g., America/New_York, Europe/London). Ensures unambiguous interpretation of cutoff_time across global operations.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTimezone rdf:type rdf:Property ;
    rdfs:label 'Delivery Timezone' ;
    rdfs:comment 'IANA timezone identifier for the delivery time window at the destination node (e.g., Asia/Singapore, America/Los_Angeles). Ensures unambiguous interpretation of first_available_delivery_time and latest_delivery_time.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationNodeCode rdf:type rdf:Property ;
    rdfs:label 'Destination Node Code' ;
    rdfs:comment 'Code identifying the destination hub, depot, port, airport, or facility node for this transit time standard. Aligns with IATA airport codes, UN/LOCODE, or internal network node identifiers.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationNodeType rdf:type rdf:Property ;
    rdfs:label 'Destination Node Type' ;
    rdfs:comment 'Classification of the destination node (e.g., airport, seaport, Inland Container Depot (ICD), Container Freight Station (CFS), Free Trade Zone (FTZ)). Supports network topology and hub-and-spoke configuration. [ENUM-REF-CANDIDATE: AIRPORT|SEAPORT|RAIL_TERMINAL|ROAD_HUB|WAREHOUSE|ICD|CFS|FTZ — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationZoneCode rdf:type rdf:Property ;
    rdfs:label 'Destination Zone Code' ;
    rdfs:comment 'Postal or geographic zone code for the destination area, used in last-mile delivery zone mapping and zone-based transit time calculations in SAP TM and Oracle TMS.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstAvailableDeliveryTime rdf:type rdf:Property ;
    rdfs:label 'First Available Delivery Time' ;
    rdfs:comment 'The earliest time of day (HH:MM, 24-hour local) at which delivery can be attempted at the destination under this transit time standard. Used in last-mile scheduling, delivery window commitments, and ePOD (Electronic Proof of Delivery) planning.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:hazmatApplicable rdf:type rdf:Property ;
    rdfs:label 'Hazmat Applicable' ;
    rdfs:comment 'Indicates whether this transit time standard applies to hazardous materials shipments. When true, IMDG Code (ocean) or ICAO Technical Instructions (air) dangerous goods regulations govern the transit. Affects carrier selection and routing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hubRoutingRequired rdf:type rdf:Property ;
    rdfs:label 'Hub Routing Required' ;
    rdfs:comment 'Indicates whether this transit time standard requires routing through an intermediate hub node (hub-and-spoke configuration). When true, hub transit time is included in standard_transit_days.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intermediateHubCode rdf:type rdf:Property ;
    rdfs:label 'Intermediate Hub Code' ;
    rdfs:comment 'Code of the primary intermediate hub node through which shipments are routed when hub_routing_required is true. Aligns with IATA airport codes or internal network node identifiers.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latestDeliveryTime rdf:type rdf:Property ;
    rdfs:label 'Latest Delivery Time' ;
    rdfs:comment 'The latest time of day (HH:MM, 24-hour local) by which delivery must be completed at the destination to meet this transit time standard. Used in SLA compliance measurement and On-Time In-Full (OTIF) reporting.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current operational state of this transit time standard in its lifecycle. ACTIVE records are used in ETA calculation and carrier selection. SUPERSEDED records are retained for historical SLA audit. DRAFT records are pending approval.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingDaysMask rdf:type rdf:Property ;
    rdfs:label 'Operating Days Mask' ;
    rdfs:comment '7-character binary string (Mon-Sun) indicating which days of the week this transit time standard is active (1=active, 0=inactive). Example: \'1111100\' = Monday to Friday only. Encodes day-of-week restrictions for scheduling and ETA calculation.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originNodeCode rdf:type rdf:Property ;
    rdfs:label 'Origin Node Code' ;
    rdfs:comment 'Code identifying the origin hub, depot, port, airport, or facility node for this transit time standard. Aligns with IATA airport codes, UN/LOCODE, or internal network node identifiers.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originNodeType rdf:type rdf:Property ;
    rdfs:label 'Origin Node Type' ;
    rdfs:comment 'Classification of the origin node (e.g., airport, seaport, Inland Container Depot (ICD), Container Freight Station (CFS), Free Trade Zone (FTZ)). Supports network topology analysis and hub-and-spoke configuration. [ENUM-REF-CANDIDATE: AIRPORT|SEAPORT|RAIL_TERMINAL|ROAD_HUB|WAREHOUSE|ICD|CFS|FTZ — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapTmRouteCode rdf:type rdf:Property ;
    rdfs:label 'Sap Tm Route Code' ;
    rdfs:comment 'External route identifier from SAP TM used to link this transit time standard to the corresponding route planning and freight order management record in SAP TM. Supports system-of-record traceability.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentType rdf:type rdf:Property ;
    rdfs:label 'Shipment Type' ;
    rdfs:comment 'Type of shipment load for which this transit time standard applies: Full Truckload (FTL), Less Than Truckload (LTL), Full Container Load (FCL), Less Than Container Load (LCL), parcel, pallet, or bulk. Drives carrier selection and load optimization. [ENUM-REF-CANDIDATE: FTL|LTL|FCL|LCL|PARCEL|PALLET|BULK — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCode rdf:type rdf:Property ;
    rdfs:label 'Standard Code' ;
    rdfs:comment 'Externally-known unique business code identifying this transit time standard record, used in SAP TM, Oracle TMS, and FourKites integrations for ETA calculation and carrier selection.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardDescription rdf:type rdf:Property ;
    rdfs:label 'Standard Description' ;
    rdfs:comment 'Free-text description providing additional context about this transit time standard, including special conditions, exceptions, or operational notes relevant to SLA management and carrier selection.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardName rdf:type rdf:Property ;
    rdfs:label 'Standard Name' ;
    rdfs:comment 'Human-readable descriptive name for this transit time standard, used in reporting, SLA contract references, and carrier selection displays.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitDayType rdf:type rdf:Property ;
    rdfs:label 'Transit Day Type' ;
    rdfs:comment 'Specifies whether standard_transit_days is measured in calendar days, business days, or working days. Critical for accurate SLA commitment and ETA calculation, particularly for cross-border shipments with customs clearance.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierLaneAllocationId rdf:type rdf:Property ;
    rdfs:label 'Carrier Lane Allocation Id' ;
    rdfs:comment 'Unique identifier for the carrier lane allocation record. Primary key.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarrierLaneAllocation .

ind:allocationCode rdf:type rdf:Property ;
    rdfs:label 'Allocation Code' ;
    rdfs:comment 'Business identifier for this carrier lane allocation, used in SAP TM carrier selection engine and tendering processes.' ;
    rdfs:domain ind:CarrierLaneAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationNotes rdf:type rdf:Property ;
    rdfs:label 'Allocation Notes' ;
    rdfs:comment 'Free-text notes or comments regarding this carrier lane allocation, including special handling instructions, restrictions, or operational considerations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocation Percentage' ;
    rdfs:comment 'Percentage of lane volume allocated to this carrier, expressed as a decimal (e.g., 35.50 for 35.5%). Used for load balancing and capacity planning.' ;
    rdfs:domain ind:CarrierLaneAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current lifecycle status of the carrier lane allocation. Active allocations are eligible for carrier selection.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationType rdf:type rdf:Property ;
    rdfs:label 'Allocation Type' ;
    rdfs:comment 'Type of allocation: contracted (long-term agreement), spot (ad-hoc booking), backup (contingency), seasonal (time-bound), or preferred (strategic partner).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Approval workflow status for this carrier lane allocation. Only approved allocations are activated for carrier selection.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByUser rdf:type rdf:Property ;
    rdfs:label 'Approved By User' ;
    rdfs:comment 'User ID or name of the person who approved this carrier lane allocation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonEmissionFactorKgCo2e rdf:type rdf:Property ;
    rdfs:label 'Carbon Emission Factor Kg Co2e' ;
    rdfs:comment 'Carbon emission factor in kilograms of CO2 equivalent per unit (per TEU-km, per ton-km, or per shipment) for this carrier on this lane. Used for GHG (Greenhouse Gas) reporting and sustainability analytics.' ;
    rdfs:domain ind:CarrierLaneAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierCertificationLevel rdf:type rdf:Property ;
    rdfs:label 'Carrier Certification Level' ;
    rdfs:comment 'Certification or partnership level of the carrier: standard, preferred, strategic, AEO (Authorized Economic Operator), C-TPAT (Customs-Trade Partnership Against Terrorism), or other industry certifications.' ;
    rdfs:domain ind:CarrierLaneAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractReference rdf:type rdf:Property ;
    rdfs:label 'Contract Reference' ;
    rdfs:comment 'Reference number of the underlying carrier contract or rate agreement that governs this allocation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedCapacityTeu rdf:type rdf:Property ;
    rdfs:label 'Contracted Capacity Teu' ;
    rdfs:comment 'Contracted capacity for ocean freight expressed in TEU (Twenty-foot Equivalent Units). Null for non-ocean modes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedCapacityVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Contracted Capacity Volume Cbm' ;
    rdfs:comment 'Contracted volume capacity in cubic meters (CBM) for freight. Used for dimensional capacity planning.' ;
    rdfs:domain ind:CarrierLaneAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedCapacityWeightKg rdf:type rdf:Property ;
    rdfs:label 'Contracted Capacity Weight Kg' ;
    rdfs:comment 'Contracted weight capacity in kilograms for air, road, or rail freight. Used for capacity management and load optimization.' ;
    rdfs:domain ind:CarrierLaneAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the cost per unit (e.g., USD, EUR, CNY).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerUnit rdf:type rdf:Property ;
    rdfs:label 'Cost Per Unit' ;
    rdfs:comment 'Contracted cost per unit (per TEU, per kg, per CBM, or per shipment) for this carrier on this lane. Used for freight cost calculation and carrier selection optimization.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'User ID or name of the person who created this carrier lane allocation record.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentType rdf:type rdf:Property ;
    rdfs:label 'Equipment Type' ;
    rdfs:comment 'Type of equipment or container used by this carrier on this lane (e.g., 20ft dry, 40ft reefer, flatbed truck, aircraft type). Free-text to accommodate diverse equipment specifications.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSurchargeApplicable rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Applicable' ;
    rdfs:comment 'Indicates whether a fuel surcharge (BAF - Bunker Adjustment Factor for ocean, or fuel surcharge for air/road) is applicable to this allocation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatCapable rdf:type rdf:Property ;
    rdfs:label 'Hazmat Capable' ;
    rdfs:comment 'Indicates whether this carrier is certified and capable of transporting hazardous materials (HAZMAT) on this lane per IMDG Code or ICAO Technical Instructions.' ;
    rdfs:domain ind:CarrierLaneAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incoterm rdf:type rdf:Property ;
    rdfs:label 'Incoterm' ;
    rdfs:comment 'Applicable Incoterm for this carrier lane allocation, defining the division of costs and risks between shipper and carrier (e.g., FOB, CIF, DDP). [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'User ID or name of the person who last modified this carrier lane allocation record.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'Required lead time in days for booking this carrier on this lane. Used for tendering and capacity reservation planning.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maximumVolumeLimit rdf:type rdf:Property ;
    rdfs:label 'Maximum Volume Limit' ;
    rdfs:comment 'Maximum volume limit (in applicable unit: TEU, kg, CBM) that can be allocated to this carrier on this lane per capacity constraints or contract terms.' ;
    rdfs:domain ind:CarrierLaneAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumVolumeCommitment rdf:type rdf:Property ;
    rdfs:label 'Minimum Volume Commitment' ;
    rdfs:comment 'Minimum volume commitment (in applicable unit: TEU, kg, CBM) that the shipper must tender to this carrier on this lane per contract terms.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceScore rdf:type rdf:Property ;
    rdfs:label 'Performance Score' ;
    rdfs:comment 'Historical performance score (0-100) for this carrier on this lane, based on OTD (On-Time Delivery), OTIF (On-Time In-Full), claims rate, and service quality KPIs (Key Performance Indicators).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaOnTimeDeliveryPct rdf:type rdf:Property ;
    rdfs:label 'Sla On Time Delivery Pct' ;
    rdfs:comment 'Service Level Agreement target for on-time delivery percentage (OTD) for this carrier on this lane, expressed as a decimal (e.g., 95.00 for 95%).' ;
    rdfs:domain ind:CarrierLaneAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transitTimeDays rdf:type rdf:Property ;
    rdfs:label 'Transit Time Days' ;
    rdfs:comment 'Standard transit time in days for this carrier on this lane, used for ETA (Estimated Time of Arrival) calculation and service level planning.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visibilityEnabled rdf:type rdf:Property ;
    rdfs:label 'Visibility Enabled' ;
    rdfs:comment 'Indicates whether real-time shipment visibility is enabled for this carrier on this lane via FourKites or other visibility platforms.' ;
    rdfs:domain ind:CarrierLaneAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Plan Network Node Id' ;
    rdfs:comment 'Reference to the starting location (warehouse, port, terminal, customer site) for this route plan.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Free-text explanation of why this route plan was cancelled. Null if plan was not cancelled.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancellation Timestamp' ;
    rdfs:comment 'Timestamp when this route plan was cancelled. Null if plan was not cancelled. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'Timestamp when this route plan was completed (final leg arrival at destination). Null if not yet completed. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmed Timestamp' ;
    rdfs:comment 'Timestamp when this route plan was confirmed and approved for execution. Null if plan is still in draft status. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:destinationAddress rdf:type rdf:Property ;
    rdfs:label 'Destination Address' ;
    rdfs:comment 'Full address of the destination location including street, city, postal code, and country. Business-confidential organizational contact data.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Execution Start Timestamp' ;
    rdfs:comment 'Timestamp when execution of this route plan began (first leg departure). Null if execution has not started. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isHazmat rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat' ;
    rdfs:comment 'Indicates whether this route plan involves the transport of dangerous goods or hazardous materials requiring special handling and compliance. True if hazmat, False otherwise.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfLegs rdf:type rdf:Property ;
    rdfs:label 'Number Of Legs' ;
    rdfs:comment 'Total number of transport legs (segments) in this route plan. Each leg represents movement between two consecutive nodes.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfStops rdf:type rdf:Property ;
    rdfs:label 'Number Of Stops' ;
    rdfs:comment 'Total number of intermediate stops (hubs, terminals, cross-docks) between origin and destination, excluding origin and destination.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optimizationObjective rdf:type rdf:Property ;
    rdfs:label 'Optimization Objective' ;
    rdfs:comment 'Primary optimization goal used by the planning system: Cost (minimize freight cost), Time (minimize transit time), CO2e (minimize carbon emissions), or Balanced (multi-objective optimization).' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originAddress rdf:type rdf:Property ;
    rdfs:label 'Origin Address' ;
    rdfs:comment 'Full address of the origin location including street, city, postal code, and country. Business-confidential organizational contact data.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle status of the route plan: Draft (under planning), Confirmed (approved for execution), In Execution (actively being executed), Completed (successfully finished), Cancelled (terminated before completion), or Failed (execution unsuccessful).' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Arrival Timestamp' ;
    rdfs:comment 'Planned Estimated Time of Arrival (ETA) at the destination location. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedCo2eEmissionsKg rdf:type rdf:Property ;
    rdfs:label 'Planned Co2e Emissions Kg' ;
    rdfs:comment 'Estimated total greenhouse gas emissions for this route plan, measured in kilograms of CO2 equivalent (CO2e). Used for sustainability reporting and carbon offsetting.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Cost Amount' ;
    rdfs:comment 'Total planned cost for executing this route plan, including carrier charges, fuel surcharges, and terminal handling charges. Business-confidential financial data.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Planned Cost Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the planned cost amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Departure Timestamp' ;
    rdfs:comment 'Planned Estimated Time of Departure (ETD) from the origin location. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:planningSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Planning Source System' ;
    rdfs:comment 'System that generated this route plan: SAP TM (Transportation Management), Blue Yonder (Supply Chain Planning), Oracle TMS, or manual planning.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planning Timestamp' ;
    rdfs:comment 'Timestamp when this route plan was generated or last re-optimized by the planning system. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requiresCustomsClearance rdf:type rdf:Property ;
    rdfs:label 'Requires Customs Clearance' ;
    rdfs:comment 'Indicates whether this route plan requires customs brokerage and trade compliance processing. True if customs clearance is required, False otherwise.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Target Delivery Timestamp' ;
    rdfs:comment 'Contractual SLA target timestamp for delivery at destination. Used to measure On-Time Delivery (OTD) and On-Time In-Full (OTIF) performance. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalPlannedDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Total Planned Distance Km' ;
    rdfs:comment 'Total planned distance for the entire route from origin to destination, measured in kilometers. Sum of all leg distances.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPlannedTransitTimeHours rdf:type rdf:Property ;
    rdfs:label 'Total Planned Transit Time Hours' ;
    rdfs:comment 'Total planned transit time for the entire route from origin to destination, measured in hours. Includes transport time and planned dwell time at intermediate nodes.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version number of this route plan. Incremented when the plan is re-optimized or modified. Version 1 is the initial plan.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planLegId rdf:type rdf:Property ;
    rdfs:label 'Plan Leg Id' ;
    rdfs:comment 'Unique identifier for the route plan leg. Primary key for this entity.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlanLeg .

ind:brokerAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Broker Assignment Id' ;
    rdfs:comment 'Foreign key linking to customs.broker_assignment. Business justification: Plan leg execution requires tracking which customs broker is handling clearance at that leg\'s port of entry/exit. Critical for coordinating documentation handoff, filing deadlines, and release timing ' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BrokerAssignment .

ind:carrierBuyRateId rdf:type rdf:Property ;
    rdfs:label 'Carrier Buy Rate Id' ;
    rdfs:comment 'Foreign key linking to pricing.carrier_buy_rate. Business justification: Route plan legs use carrier buy rates for cost. Carrier_buy_rate_id enables leg-level cost calculation, supporting multi-leg cost optimization, carrier selection by leg, and leg-level margin analysis.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarrierBuyRate .

ind:carrierScheduleId rdf:type rdf:Property ;
    rdfs:label 'Carrier Schedule Id' ;
    rdfs:comment 'Foreign key linking to route.carrier_schedule. Business justification: plan_leg represents the planned execution of a transport leg, which is typically booked against a specific published carrier schedule (flight, vessel voyage, truck departure). Linking plan_leg to carr' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarrierSchedule .

ind:primaryPlanNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Plan Network Node Id' ;
    rdfs:comment 'Reference to the origin location node for this leg. Represents the departure point such as a warehouse, hub, terminal, or customer location.' ;
    rdfs:domain ind:PlanLeg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:primaryPlanTransportAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Plan Transport Asset Id' ;
    rdfs:comment 'Foreign key linking to fleet.transport_asset. Business justification: Route plan legs specify which vehicle/trailer/container executes each leg—essential for capacity planning, asset utilization tracking, maintenance scheduling, and operational execution visibility.' ;
    rdfs:domain ind:PlanLeg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransportAsset .

ind:rateLineId rdf:type rdf:Property ;
    rdfs:label 'Rate Line Id' ;
    rdfs:comment 'Foreign key linking to pricing.rate_line. Business justification: Plan legs execute specific rate line commitments from contracts or rate cards. Enables actual-vs-quoted freight cost analysis, margin tracking, and rate accuracy validation. Critical for freight cost ' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateLine .

ind:actualArrivalDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Datetime' ;
    rdfs:comment 'Actual arrival date and time for this leg. Captured from real-time tracking systems such as FourKites or carrier EDI messages. Null if leg has not yet arrived.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDepartureDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Datetime' ;
    rdfs:comment 'Actual departure date and time for this leg. Captured from real-time tracking systems such as FourKites or carrier EDI messages. Null if leg has not yet departed.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualTransitHours rdf:type rdf:Property ;
    rdfs:label 'Actual Transit Hours' ;
    rdfs:comment 'Actual transit time for this leg in hours. Calculated as the difference between actual arrival and actual departure times. Used for performance analysis and OTD (On-Time Delivery) measurement.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Booking Reference Number' ;
    rdfs:comment 'Carrier booking or reservation number for this leg. Used for ocean freight bookings, air freight reservations, and dedicated transport bookings.' ;
    rdfs:domain ind:PlanLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonEmissionsKg rdf:type rdf:Property ;
    rdfs:label 'Carbon Emissions Kg' ;
    rdfs:comment 'Estimated carbon dioxide equivalent (CO2e) emissions for this leg in kilograms. Calculated based on transport mode, distance, and load weight. Used for sustainability reporting and compliance with EU ETS and CORSIA.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'Total transportation cost for this leg. Includes base freight charges, fuel surcharges, and accessorial charges. Used for freight audit and cost allocation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsClearanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Required Flag' ;
    rdfs:comment 'Indicates whether this leg crosses an international border and requires customs clearance. True for cross-border legs requiring customs declarations and trade compliance processing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Status' ;
    rdfs:comment 'Current status of customs clearance for this leg. Tracks the progression through customs processing from submission to release. Integrated with Descartes Customs system.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayMinutes rdf:type rdf:Property ;
    rdfs:label 'Delay Minutes' ;
    rdfs:comment 'Total delay time in minutes for this leg. Calculated as the difference between actual and planned arrival times. Null if leg arrived on time or early.' ;
    rdfs:domain ind:PlanLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:delayReasonCode rdf:type rdf:Property ;
    rdfs:label 'Delay Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for any delay on this leg. Used for root cause analysis and exception management. Examples include weather, customs hold, mechanical failure, traffic congestion.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightNumber rdf:type rdf:Property ;
    rdfs:label 'Flight Number' ;
    rdfs:comment 'Flight number for air freight legs. Identifies the specific airline flight carrying the shipment (e.g., AA1234, LH456).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Flag' ;
    rdfs:comment 'Indicates whether this leg transports hazardous materials requiring special handling and compliance with IMDG Code or ICAO Technical Instructions for Dangerous Goods.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedArrivalDatetime rdf:type rdf:Property ;
    rdfs:label 'Planned Arrival Datetime' ;
    rdfs:comment 'Planned arrival date and time for this leg. Represents the scheduled ETA (Estimated Time of Arrival) at the destination node.' ;
    rdfs:domain ind:PlanLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedDepartureDatetime rdf:type rdf:Property ;
    rdfs:label 'Planned Departure Datetime' ;
    rdfs:comment 'Planned departure date and time for this leg. Represents the scheduled ETD (Estimated Time of Departure) from the origin node.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedTransitHours rdf:type rdf:Property ;
    rdfs:label 'Planned Transit Hours' ;
    rdfs:comment 'Planned transit time for this leg in hours. Calculated as the difference between planned arrival and planned departure times. Used for transit time standard compliance and SLA tracking.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Flag' ;
    rdfs:comment 'Indicates whether this leg requires temperature-controlled transport (reefer). True for cold chain shipments requiring refrigeration or climate control.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trailerNumber rdf:type rdf:Property ;
    rdfs:label 'Trailer Number' ;
    rdfs:comment 'Trailer or semi-trailer identification number for road freight legs. Used for FTL and LTL shipments.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voyageNumber rdf:type rdf:Property ;
    rdfs:label 'Voyage Number' ;
    rdfs:comment 'Voyage or sailing number for ocean freight legs. Identifies the specific vessel voyage carrying the shipment.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etaEventId rdf:type rdf:Property ;
    rdfs:label 'Eta Event Id' ;
    rdfs:comment 'Unique identifier for the ETA/ETD event record. Primary key for the eta_event product.' ;
    rdfs:domain ind:EtaEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryEtaLocationNodeNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Eta Location Node Network Node Id' ;
    rdfs:comment 'Reference to the network node (hub, terminal, warehouse, Container Freight Station (CFS), Inland Container Depot (ICD), or delivery zone) where the shipment was located at the time of this event. Links to the network topology master data.' ;
    rdfs:domain ind:EtaEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:actualEtd rdf:type rdf:Property ;
    rdfs:label 'Actual Etd' ;
    rdfs:comment 'The actual recorded time of departure when the shipment left the origin location, hub, or intermediate node. Captured from GPS, carrier Electronic Data Interchange (EDI), or manual confirmation. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:EtaEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualTransitTimeHours rdf:type rdf:Property ;
    rdfs:label 'Actual Transit Time Hours' ;
    rdfs:comment 'The actual transit time in hours for this shipment leg, calculated from actual Estimated Time of Departure (ETD) to actual Estimated Time of Arrival (ETA). Populated once the leg is completed. Used for Key Performance Indicator (KPI) reporting and continuous improvement.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:containerNumber rdf:type rdf:Property ;
    rdfs:label 'Container Number' ;
    rdfs:comment 'The unique container number for Full Container Load (FCL) or Less Than Container Load (LCL) ocean freight shipments. Follows International Organization for Standardization (ISO) 6346 standard for container identification. Used for tracking and terminal handling.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentPredictedEta rdf:type rdf:Property ;
    rdfs:label 'Current Predicted Eta' ;
    rdfs:comment 'The most recent predicted estimated time of arrival based on real-time tracking data, traffic conditions, weather, and predictive algorithms from FourKites or SAP TM. This is the current best estimate of when the shipment will arrive. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:EtaEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerNotificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Sent Flag' ;
    rdfs:comment 'Boolean indicator (True/False) that identifies whether a customer notification (email, SMS, Application Programming Interface (API) push) was sent for this ETA/ETD event. True indicates the customer was notified; False indicates no notification was sent. Used for customer communication audit and Service Level Agreement (SLA) compliance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Timestamp' ;
    rdfs:comment 'The date and time when the customer notification was sent for this ETA/ETD event. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. Used for audit trail and Service Level Agreement (SLA) compliance verification.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:delayReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Delay Reason Description' ;
    rdfs:comment 'A free-text description providing additional context or details about the delay or exception. Captured from carrier Electronic Data Interchange (EDI) messages, driver notes, or customer service case logs.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etaVarianceHours rdf:type rdf:Property ;
    rdfs:label 'Eta Variance Hours' ;
    rdfs:comment 'The difference in hours between the original planned ETA and the current predicted ETA. Positive values indicate a delay; negative values indicate the shipment is ahead of schedule. Used for Service Level Agreement (SLA) monitoring and On-Time Delivery (OTD) / On-Time In-Full (OTIF) Key Performance Indicator (KPI) calculation.' ;
    rdfs:domain ind:EtaEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:etdVarianceHours rdf:type rdf:Property ;
    rdfs:label 'Etd Variance Hours' ;
    rdfs:comment 'The difference in hours between the original planned ETD and the actual ETD. Positive values indicate a late departure; negative values indicate an early departure. Used for root cause analysis of delays and transit time performance.' ;
    rdfs:domain ind:EtaEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventSource rdf:type rdf:Property ;
    rdfs:label 'Event Source' ;
    rdfs:comment 'The system or channel that generated this ETA/ETD event. Indicates whether the event originated from FourKites real-time visibility platform, SAP TM route planning, carrier Electronic Data Interchange (EDI), GPS tracking device, manual operator entry, Oracle TMS, or Blue Yonder supply chain planning. [ENUM-REF-CANDIDATE: FourKites|SAP TM|Carrier EDI|GPS|Manual|Oracle TMS|Blue Yonder — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'The date and time when this ETA/ETD event was generated or recorded. Represents the moment the prediction or update was made. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exceptionFlag rdf:type rdf:Property ;
    rdfs:label 'Exception Flag' ;
    rdfs:comment 'Boolean indicator (True/False) that identifies whether this ETA/ETD event represents an exception condition requiring attention. True indicates a delay, early arrival, or other deviation from the Service Level Agreement (SLA) or planned schedule. Used to trigger exception management workflows.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceptionSeverity rdf:type rdf:Property ;
    rdfs:label 'Exception Severity' ;
    rdfs:comment 'The severity level of the exception condition. Critical indicates Service Level Agreement (SLA) breach or customer escalation required; High indicates significant delay; Medium indicates minor delay; Low indicates minimal impact; None indicates no exception.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionType rdf:type rdf:Property ;
    rdfs:label 'Exception Type' ;
    rdfs:comment 'The specific type of exception or status condition associated with this ETA/ETD event. Categorizes the nature of the deviation (delay, early arrival, on-time, weather delay, traffic delay, customs delay, mechanical failure, route deviation, carrier issue). Used for root cause analysis and Key Performance Indicator (KPI) reporting. [ENUM-REF-CANDIDATE: Delay|Early|On-Time|Weather Delay|Traffic Delay|Customs Delay|Mechanical Failure|Route Deviation|Carrier Issue — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationLatitude rdf:type rdf:Property ;
    rdfs:label 'Location Latitude' ;
    rdfs:comment 'The geographic latitude coordinate of the shipment or vehicle at the time this ETA/ETD event was generated. Captured from Global Positioning System (GPS) or Radio Frequency Identification (RFID) tracking devices. Used for real-time visibility and geofencing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationLongitude rdf:type rdf:Property ;
    rdfs:label 'Location Longitude' ;
    rdfs:comment 'The geographic longitude coordinate of the shipment or vehicle at the time this ETA/ETD event was generated. Captured from Global Positioning System (GPS) or Radio Frequency Identification (RFID) tracking devices. Used for real-time visibility and geofencing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalPlannedEta rdf:type rdf:Property ;
    rdfs:label 'Original Planned Eta' ;
    rdfs:comment 'The initial planned estimated time of arrival as defined in the original route plan or shipment booking. This is the baseline ETA against which all subsequent updates and variances are measured. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:EtaEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originalPlannedEtd rdf:type rdf:Property ;
    rdfs:label 'Original Planned Etd' ;
    rdfs:comment 'The initial planned estimated time of departure as defined in the original route plan or shipment booking. This is the baseline ETD for the origin or intermediate hub. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:EtaEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedTransitTimeHours rdf:type rdf:Property ;
    rdfs:label 'Planned Transit Time Hours' ;
    rdfs:comment 'The planned transit time in hours for this shipment leg as defined in the route plan or service corridor standard. Used as the baseline for On-Time Delivery (OTD) and transit time variance analysis.' ;
    rdfs:domain ind:EtaEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:podStatus rdf:type rdf:Property ;
    rdfs:label 'Pod Status' ;
    rdfs:comment 'The Proof of Delivery (POD) status for this shipment leg. Indicates whether the shipment has not been delivered, has been delivered, delivery was attempted, was refused by the consignee, was damaged, or was lost. Used for Electronic Proof of Delivery (ePOD) integration and claims processing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pod Timestamp' ;
    rdfs:comment 'The date and time when Proof of Delivery (POD) was captured. This is the actual delivery timestamp recorded by the driver or Electronic Proof of Delivery (ePOD) system. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. Used for On-Time Delivery (OTD) calculation and billing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:predictionConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Prediction Confidence Score' ;
    rdfs:comment 'A confidence score (0-100) indicating the reliability of the current predicted ETA. Higher scores indicate greater confidence based on historical accuracy, data quality, and real-time tracking signal strength. Generated by FourKites or SAP TM predictive algorithms.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trafficCondition rdf:type rdf:Property ;
    rdfs:label 'Traffic Condition' ;
    rdfs:comment 'A description of the traffic conditions at the time of the ETA/ETD event or along the route. Captured from traffic Application Programming Interface (API) integration, Global Positioning System (GPS) data, or driver reports. Used for delay analysis and dynamic route optimization.' ;
    rdfs:domain ind:EtaEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weatherCondition rdf:type rdf:Property ;
    rdfs:label 'Weather Condition' ;
    rdfs:comment 'A description of the weather conditions at the time of the ETA/ETD event or along the route. Examples include clear, rain, snow, fog, storm, hurricane. Captured from weather Application Programming Interface (API) integration or driver reports. Used for delay analysis and predictive modeling.' ;
    rdfs:domain ind:EtaEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hubSpokeConfigId rdf:type rdf:Property ;
    rdfs:label 'Hub Spoke Config Id' ;
    rdfs:comment 'Unique identifier for the hub-and-spoke network configuration record. Primary key.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatorTplProviderId rdf:type rdf:Property ;
    rdfs:label 'Operator Tpl Provider Id' ;
    rdfs:comment 'Foreign key linking to network.tpl_provider. Business justification: Hub consolidation operations frequently outsourced to 3PL providers. Required for operational accountability, cost allocation, performance tracking, and 3PL contract compliance validation. Essential f' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TplProvider .

ind:spokeDepotId rdf:type rdf:Property ;
    rdfs:label 'Spoke Depot Id' ;
    rdfs:comment 'Foreign key linking to fleet.fleet_depot. Business justification: Hub-spoke configurations define which depots serve as spokes (in addition to hub_node_id); critical for fleet deployment planning, asset allocation, and last-mile service design.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:carrierAllocationStrategy rdf:type rdf:Property ;
    rdfs:label 'Carrier Allocation Strategy' ;
    rdfs:comment 'Strategy for allocating carriers to hub-spoke lanes: dedicated carriers per lane, shared carrier pool, dynamic selection via TMS, or contract-based assignment.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configCode rdf:type rdf:Property ;
    rdfs:label 'Config Code' ;
    rdfs:comment 'Business identifier code for the hub-spoke configuration, used for external reference and reporting. Typically follows a naming convention combining region, service product, and version.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configName rdf:type rdf:Property ;
    rdfs:label 'Config Name' ;
    rdfs:comment 'Human-readable name describing the hub-spoke configuration, typically including geographic scope and service type (e.g., \'APAC Express Hub-Spoke Q1 2024\').' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configStatus rdf:type rdf:Property ;
    rdfs:label 'Config Status' ;
    rdfs:comment 'Current lifecycle status of the hub-spoke configuration. Only active configurations are used for operational route planning and shipment execution.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configVersion rdf:type rdf:Property ;
    rdfs:label 'Config Version' ;
    rdfs:comment 'Version number of this configuration. Incremented when the configuration is updated, supporting change tracking and audit trails.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consolidationCutoffTime rdf:type rdf:Property ;
    rdfs:label 'Consolidation Cutoff Time' ;
    rdfs:comment 'Daily cutoff time (HH:MM format, hub local time) by which shipments must arrive at the hub to be included in the next consolidation cycle.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consolidationFrequency rdf:type rdf:Property ;
    rdfs:label 'Consolidation Frequency' ;
    rdfs:comment 'Frequency at which shipments are consolidated at the hub before distribution to spokes. Impacts inventory holding time and service level.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryScope rdf:type rdf:Property ;
    rdfs:label 'Country Scope' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes covered by this hub-spoke configuration. Defines the geographic boundary for customs and trade compliance.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directLaneBypassEnabled rdf:type rdf:Property ;
    rdfs:label 'Direct Lane Bypass Enabled' ;
    rdfs:comment 'Indicates whether direct spoke-to-spoke or spoke-to-destination lanes are allowed when volume/weight thresholds are met, bypassing the hub.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date on which this hub-spoke configuration expires or is superseded by a new configuration. Null indicates an open-ended configuration.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date from which this hub-spoke configuration becomes active and is used for route planning and shipment execution. Supports temporal network design.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ftzZoneApplicable rdf:type rdf:Property ;
    rdfs:label 'Ftz Zone Applicable' ;
    rdfs:comment 'Indicates whether the hub operates within or has access to a Free Trade Zone, enabling duty deferral and trade compliance benefits.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hubCapacityPallets rdf:type rdf:Property ;
    rdfs:label 'Hub Capacity Pallets' ;
    rdfs:comment 'Maximum handling capacity of the hub in standard pallet positions. Relevant for LTL, parcel, and e-commerce fulfillment operations.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hubCapacityTeu rdf:type rdf:Property ;
    rdfs:label 'Hub Capacity Teu' ;
    rdfs:comment 'Maximum handling capacity of the hub in Twenty-foot Equivalent Units (TEU) for containerized freight. Used for capacity planning and network design.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxHubToSpokeTransitHours rdf:type rdf:Property ;
    rdfs:label 'Max Hub To Spoke Transit Hours' ;
    rdfs:comment 'Maximum allowable transit time in hours from the hub to any spoke node. Critical for On-Time Delivery (OTD) and On-Time In-Full (OTIF) performance.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxSpokeToHubTransitHours rdf:type rdf:Property ;
    rdfs:label 'Max Spoke To Hub Transit Hours' ;
    rdfs:comment 'Maximum allowable transit time in hours from any spoke node to the hub. Used for SLA validation, route planning, and network design optimization.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minVolumeThresholdCbm rdf:type rdf:Property ;
    rdfs:label 'Min Volume Threshold Cbm' ;
    rdfs:comment 'Minimum shipment volume in cubic meters (CBM) required to bypass the hub and establish a direct lane from spoke to destination. Used for load optimization and cost efficiency.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minWeightThresholdKg rdf:type rdf:Property ;
    rdfs:label 'Min Weight Threshold Kg' ;
    rdfs:comment 'Minimum shipment weight in kilograms required to qualify for direct lane bypass, avoiding hub consolidation. Supports FTL and FCL optimization logic.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'Identifier of the user or system that last modified this hub-spoke configuration record. Supports accountability and audit trails.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkDesignModelCode rdf:type rdf:Property ;
    rdfs:label 'Network Design Model Code' ;
    rdfs:comment 'Reference to the Blue Yonder network design model or optimization run that generated or validated this hub-spoke configuration.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predictiveEtaEnabled rdf:type rdf:Property ;
    rdfs:label 'Predictive Eta Enabled' ;
    rdfs:comment 'Indicates whether predictive ETA calculation using FourKites or Blue Yonder is enabled for this configuration, supporting proactive exception management.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:realTimeVisibilityEnabled rdf:type rdf:Property ;
    rdfs:label 'Real Time Visibility Enabled' ;
    rdfs:comment 'Indicates whether FourKites real-time visibility tracking is enabled for shipments routed through this hub-spoke configuration.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceProductScope rdf:type rdf:Property ;
    rdfs:label 'Service Product Scope' ;
    rdfs:comment 'The service product line or business segment this hub-spoke configuration applies to. Determines operational rules, SLA targets, and routing logic.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetOtdPercent rdf:type rdf:Property ;
    rdfs:label 'Sla Target Otd Percent' ;
    rdfs:comment 'Target On-Time Delivery percentage for shipments routed through this hub-spoke configuration. Used for performance monitoring and carrier evaluation.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaTargetOtifPercent rdf:type rdf:Property ;
    rdfs:label 'Sla Target Otif Percent' ;
    rdfs:comment 'Target On-Time In-Full percentage for shipments routed through this hub-spoke configuration. Measures both timeliness and completeness of delivery.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spokeCount rdf:type rdf:Property ;
    rdfs:label 'Spoke Count' ;
    rdfs:comment 'Total number of spoke nodes included in this hub-spoke configuration. Used for network complexity analysis and capacity planning.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spokeNodesList rdf:type rdf:Property ;
    rdfs:label 'Spoke Nodes List' ;
    rdfs:comment 'Comma-separated list of spoke node codes or identifiers that are served by this hub. Represents the delivery/pickup points connected to the hub in this configuration.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityTargetCo2eKgPerShipment rdf:type rdf:Property ;
    rdfs:label 'Sustainability Target Co2e Kg Per Shipment' ;
    rdfs:comment 'Target carbon emissions in CO2e kilograms per shipment for this hub-spoke configuration. Supports CORSIA and EU ETS compliance and sustainability reporting.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lanePerformanceId rdf:type rdf:Property ;
    rdfs:label 'Lane Performance Id' ;
    rdfs:comment 'Unique surrogate identifier for each lane-period performance measurement record in the Silver Layer lakehouse. Primary key for this operational measurement entity.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:avgDelayHours rdf:type rdf:Property ;
    rdfs:label 'Avg Delay Hours' ;
    rdfs:comment 'Average number of hours by which shipments on this lane exceeded the planned transit time during the measurement period. Positive values indicate late delivery; negative values indicate early delivery. Key input for SLA breach analysis.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgDimWeightKg rdf:type rdf:Property ;
    rdfs:label 'Avg Dim Weight Kg' ;
    rdfs:comment 'Average dimensional (volumetric) weight in kilograms per shipment on this lane during the measurement period. DIM weight is used by carriers to price low-density shipments. Sourced from Oracle TMS freight audit.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgFreightCost rdf:type rdf:Property ;
    rdfs:label 'Avg Freight Cost' ;
    rdfs:comment 'Average freight cost per shipment on this lane during the measurement period, in the reporting currency. Sourced from Oracle TMS freight audit. Used for cost-per-lane benchmarking and network optimization analysis.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgShipmentWeightKg rdf:type rdf:Property ;
    rdfs:label 'Avg Shipment Weight Kg' ;
    rdfs:comment 'Average actual gross weight in kilograms per shipment on this lane during the measurement period. Used for load optimization, carrier rate benchmarking, and CO2e intensity calculations.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierInvoiceAccuracyRate rdf:type rdf:Property ;
    rdfs:label 'Carrier Invoice Accuracy Rate' ;
    rdfs:comment 'Proportion of carrier invoices for shipments on this lane that matched the contracted rate without dispute during the measurement period. Sourced from Oracle TMS freight audit. Supports carrier financial performance evaluation.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierPerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Carrier Performance Score' ;
    rdfs:comment 'Composite carrier performance score for this lane-period, typically on a 0–100 scale, derived from OTD rate, OTIF rate, exception rate, and transit time adherence. Primary input for carrier scorecard and SAP TM carrier selection decisions.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:co2ePerShipmentKg rdf:type rdf:Property ;
    rdfs:label 'Co2e Per Shipment Kg' ;
    rdfs:comment 'Average CO2e emissions in kilograms per shipment on this lane during the measurement period. Calculated from fuel consumption, transport mode, and distance. Supports EU ETS, CORSIA, and GHG sustainability reporting.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsClearanceDelayHours rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Delay Hours' ;
    rdfs:comment 'Average hours of delay attributable to customs clearance processes for shipments on this lane during the measurement period. Sourced from Descartes Customs. Used for cross-border lane performance root cause analysis.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:damageRate rdf:type rdf:Property ;
    rdfs:label 'Damage Rate' ;
    rdfs:comment 'Proportion of shipments on this lane that incurred cargo damage during the measurement period, expressed as a decimal. Used for carrier liability assessment, insurance claims analysis, and lane risk scoring.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionCount rdf:type rdf:Property ;
    rdfs:label 'Exception Count' ;
    rdfs:comment 'Total number of shipment exceptions (delays, damages, misroutes, customs holds, etc.) recorded on this lane during the measurement period. Sourced from FourKites exception management. Triggers network optimization review.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exceptionRate rdf:type rdf:Property ;
    rdfs:label 'Exception Rate' ;
    rdfs:comment 'Proportion of shipments on this lane that incurred at least one exception during the measurement period, expressed as a decimal (exception_count / shipment_count). Used for lane risk scoring and network optimization triggers.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:folioSource rdf:type rdf:Property ;
    rdfs:label 'Folio Source' ;
    rdfs:comment 'Identifies the primary operational system of record from which actuals for this lane-period measurement were sourced (FourKites, Oracle TMS, SAP TM, or manual entry). Supports data lineage and audit traceability.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foukitesTrackingCoverageRate rdf:type rdf:Property ;
    rdfs:label 'Foukites Tracking Coverage Rate' ;
    rdfs:comment 'Proportion of shipments on this lane that had active FourKites real-time GPS/IoT tracking during the measurement period. Low coverage rates may indicate data quality issues in actuals-based metrics.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastMileDelayHours rdf:type rdf:Property ;
    rdfs:label 'Last Mile Delay Hours' ;
    rdfs:comment 'Average hours of delay attributable specifically to the last-mile delivery segment for shipments on this lane during the measurement period. Enables root cause decomposition of total delay into linehaul vs. last-mile components.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End Date' ;
    rdfs:comment 'The last calendar date of the performance measurement window for this lane-period record. Combined with measurement_period_start_date defines the exact reporting interval.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start Date' ;
    rdfs:comment 'The first calendar date of the performance measurement window for this lane-period record. Combined with measurement_period_end_date defines the exact reporting interval (e.g., weekly, monthly).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementStatus rdf:type rdf:Property ;
    rdfs:label 'Measurement Status' ;
    rdfs:comment 'Lifecycle status of this lane-period performance measurement record. Draft = initial load; Confirmed = validated by freight audit; Published = available for scorecard and SLA reporting; Superseded = replaced by a corrected record.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkOptimizationTrigger rdf:type rdf:Property ;
    rdfs:label 'Network Optimization Trigger' ;
    rdfs:comment 'Indicates whether this lane-period measurement has triggered a network optimization review in Blue Yonder based on SLA breach, high exception rate, or cost threshold exceedance. True = optimization review triggered.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onTimeShipmentCount rdf:type rdf:Property ;
    rdfs:label 'On Time Shipment Count' ;
    rdfs:comment 'Number of shipments on this lane that were delivered on or before the planned delivery date/time during the measurement period. Numerator for OTD rate calculation.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:otdRate rdf:type rdf:Property ;
    rdfs:label 'Otd Rate' ;
    rdfs:comment 'Proportion of shipments on this lane delivered on or before the planned delivery date/time during the measurement period, expressed as a decimal (e.g., 0.9500 = 95%). Core KPI for SLA monitoring and carrier scorecard.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifRate rdf:type rdf:Property ;
    rdfs:label 'Otif Rate' ;
    rdfs:comment 'Proportion of shipments on this lane delivered both on time and in full (no quantity shortfall) during the measurement period, expressed as a decimal. Composite SLA metric used for customer contract compliance and carrier evaluation.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'Granularity of the measurement window for this lane-period record. Determines the aggregation cadence used for SLA monitoring and carrier scorecard reporting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podCompletionRate rdf:type rdf:Property ;
    rdfs:label 'Pod Completion Rate' ;
    rdfs:comment 'Proportion of shipments on this lane for which an electronic Proof of Delivery (ePOD) was captured and confirmed during the measurement period. Supports compliance with customer SLA documentation requirements.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:predictiveEtaAccuracyRate rdf:type rdf:Property ;
    rdfs:label 'Predictive Eta Accuracy Rate' ;
    rdfs:comment 'Proportion of shipments on this lane for which FourKites\' predictive ETA was within the agreed tolerance window of the actual delivery time during the measurement period. Measures the reliability of the real-time visibility platform\'s ETA predictions.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when this lane-period performance measurement record was first created in the Silver Layer lakehouse. Supports data lineage, audit trail, and incremental processing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp when this lane-period performance measurement record was last modified in the Silver Layer lakehouse. Used for change tracking, SLA audit, and incremental ETL processing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shipmentCount rdf:type rdf:Property ;
    rdfs:label 'Shipment Count' ;
    rdfs:comment 'Total number of shipments executed on this lane during the measurement period. Denominator for OTD, OTIF, and exception rate calculations. Sourced from Oracle TMS shipment execution records.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaThresholdOtd rdf:type rdf:Property ;
    rdfs:label 'Sla Threshold Otd' ;
    rdfs:comment 'The contracted minimum OTD rate threshold for this lane as defined in the applicable SLA or carrier agreement, expressed as a decimal (e.g., 0.9500 = 95%). Used to determine SLA compliance status for the period.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source System Record Reference' ;
    rdfs:comment 'The native record identifier from the operational source system (FourKites or Oracle TMS) from which this lane-period measurement was extracted. Enables back-tracing to the system of record for audit and reconciliation.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCo2eKg rdf:type rdf:Property ;
    rdfs:label 'Total Co2e Kg' ;
    rdfs:comment 'Total CO2e emissions in kilograms for all shipments on this lane during the measurement period. Aggregate of co2e_per_shipment_kg × shipment_count. Used for sustainability reporting and carbon offset calculations.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFreightCost rdf:type rdf:Property ;
    rdfs:label 'Total Freight Cost' ;
    rdfs:comment 'Total freight cost for all shipments on this lane during the measurement period, in the reporting currency. Sourced from Oracle TMS freight audit and SAP S/4HANA Finance. Used for P&L lane-level cost analysis.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryCarrierNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Carrier Network Node Id' ;
    rdfs:comment 'Reference to the network node (port, airport, hub, depot, ICD, CFS) from which this schedule departs. Supports hub-and-spoke topology and FourKites real-time visibility integration.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:allianceCode rdf:type rdf:Property ;
    rdfs:label 'Alliance Code' ;
    rdfs:comment 'Code identifying the ocean carrier alliance (e.g., \'2M\', \'THE Alliance\', \'Ocean Alliance\') or air cargo alliance to which this schedule belongs. Used for slot-sharing and co-loading capacity management in Blue Yonder and Oracle TMS.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrivalDaysOfWeek rdf:type rdf:Property ;
    rdfs:label 'Arrival Days Of Week' ;
    rdfs:comment 'Comma-separated list of ISO weekday numbers (1=Monday through 7=Sunday) on which this schedule arrives at the destination node. May differ from departure days for multi-day transits. Used for ETA calculation and last-mile delivery zone scheduling.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrivalTime rdf:type rdf:Property ;
    rdfs:label 'Arrival Time' ;
    rdfs:comment 'Scheduled local arrival time at the destination node in HH:mm (24-hour) format. Combined with arrival_days_of_week to determine the Estimated Time of Arrival (ETA) for delivery planning and SLA entitlement matching.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:arrivalTimezone rdf:type rdf:Property ;
    rdfs:label 'Arrival Timezone' ;
    rdfs:comment 'IANA timezone identifier for the destination node (e.g., \'Europe/Rotterdam\', \'Asia/Tokyo\'). Required to convert local arrival time to UTC for cross-border ETA management and FourKites real-time visibility integration.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Capacity Volume Cbm' ;
    rdfs:comment 'Maximum volumetric capacity in Cubic Meters (CBM) for this schedule. Used alongside DIM Weight (Dimensional Weight) calculations for air freight and LTL/LCL load optimization in Oracle TMS.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityWeightKg rdf:type rdf:Property ;
    rdfs:label 'Capacity Weight Kg' ;
    rdfs:comment 'Maximum payload weight capacity in kilograms for this schedule. Applicable across all transport modes (air, ocean, road, rail). Used for load optimization in Oracle TMS and freight order management in SAP TM.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cutoffHoursBeforeDeparture rdf:type rdf:Property ;
    rdfs:label 'Cutoff Hours Before Departure' ;
    rdfs:comment 'Cargo receipt deadline expressed as the number of hours before scheduled departure by which cargo must be tendered to the carrier at the origin node. Used by SAP TM for freight order management and Oracle TMS for shipment execution planning.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dangerousGoodsAccepted rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Accepted' ;
    rdfs:comment 'Indicates whether this carrier schedule accepts dangerous goods (DG) shipments (True) or not (False). Drives compliance routing in Descartes Customs and shipment eligibility checks against IMDG Code (ocean) and ICAO Technical Instructions (air).' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:departureDaysOfWeek rdf:type rdf:Property ;
    rdfs:label 'Departure Days Of Week' ;
    rdfs:comment 'Comma-separated list of ISO weekday numbers (1=Monday through 7=Sunday) on which this schedule departs (e.g., \'1,3,5\' for Mon/Wed/Fri). Used by SAP TM for departure planning and Blue Yonder for network optimization.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departureTime rdf:type rdf:Property ;
    rdfs:label 'Departure Time' ;
    rdfs:comment 'Scheduled local departure time at the origin node in HH:mm (24-hour) format. Combined with departure_days_of_week to determine the Estimated Time of Departure (ETD) for shipment planning in SAP TM and Oracle TMS.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:departureTimezone rdf:type rdf:Property ;
    rdfs:label 'Departure Timezone' ;
    rdfs:comment 'IANA timezone identifier for the origin node (e.g., \'America/New_York\', \'Asia/Shanghai\'). Required to convert local departure time to UTC for cross-border schedule coordination and FourKites predictive ETA calculation.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPortCode rdf:type rdf:Property ;
    rdfs:label 'Destination Port Code' ;
    rdfs:comment 'UN/LOCODE (5-character) for ocean/road/rail destinations or IATA 3-letter airport code for air destinations. Denormalised from the destination network node for EDI messaging, customs filing, and carrier schedule matching.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:docCutoffHoursBeforeDeparture rdf:type rdf:Property ;
    rdfs:label 'Doc Cutoff Hours Before Departure' ;
    rdfs:comment 'Deadline for submission of shipping documents (AWB, BOL, customs declarations) expressed as hours before scheduled departure. Required for Descartes Customs AMS/ISF filing compliance and carrier EDI submission.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ediSourceCode rdf:type rdf:Property ;
    rdfs:label 'Edi Source Code' ;
    rdfs:comment 'Identifier of the EDI feed or carrier data exchange channel from which this schedule record was sourced (e.g., EDIFACT IFTMCS, ANSI X12 204, carrier API). Used for data lineage, reconciliation, and Silver layer ingestion audit in the Databricks lakehouse.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelType rdf:type rdf:Property ;
    rdfs:label 'Fuel Type' ;
    rdfs:comment 'Primary fuel type used by the vessel, aircraft, or vehicle operating this schedule. Used for BAF (Bunker Adjustment Factor) surcharge calculation, GHG emissions reporting, and EU ETS compliance. [ENUM-REF-CANDIDATE: VLSFO|HFO|MGO|LNG|SAF|DIESEL|ELECTRIC|HYBRID — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDirectService rdf:type rdf:Property ;
    rdfs:label 'Is Direct Service' ;
    rdfs:comment 'Indicates whether this schedule operates as a direct (non-stop) service between origin and destination nodes (True) or involves intermediate port calls / transshipment stops (False). Used for transit time accuracy and customer SLA commitments.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originPortCode rdf:type rdf:Property ;
    rdfs:label 'Origin Port Code' ;
    rdfs:comment 'UN/LOCODE (5-character) for ocean/road/rail origins or IATA 3-letter airport code for air origins. Denormalised from the origin network node for EDI messaging, AMS filing, and carrier schedule matching without requiring a node lookup.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Published Timestamp' ;
    rdfs:comment 'Timestamp when the carrier published or last updated this schedule via EDI feed. Represents the principal business event time for this record. Used for schedule freshness validation and EDI reconciliation in the Databricks Silver layer.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ref rdf:type rdf:Property ;
    rdfs:label 'Ref' ;
    rdfs:comment 'Carrier\'s own internal reference or booking system identifier for this schedule, as received via EDI. Enables round-trip reconciliation with the carrier\'s system and supports freight audit in Oracle TMS.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Number' ;
    rdfs:comment 'Externally-known carrier schedule reference number or code as published by the carrier via EDI feed. Used as the business identifier for matching against carrier EDI messages (e.g., EDIFACT IFTMCS) and for reconciliation in SAP TM and Oracle TMS.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the carrier schedule record. ACTIVE: available for booking and departure planning. SUSPENDED: temporarily unavailable (e.g., port congestion, force majeure). CANCELLED: permanently discontinued. DRAFT: pending carrier confirmation. EXPIRED: past effective_until_date.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleVersion rdf:type rdf:Property ;
    rdfs:label 'Schedule Version' ;
    rdfs:comment 'Monotonically incrementing version number for this carrier schedule record, incremented each time the carrier publishes an updated schedule via EDI. Supports schedule change management and historical comparison in the Silver layer.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transshipmentPortCode rdf:type rdf:Property ;
    rdfs:label 'Transshipment Port Code' ;
    rdfs:comment 'UN/LOCODE of the primary transshipment hub for indirect services (is_direct_service = False). Used for multi-leg ETA calculation, customs transit declaration in Descartes Customs, and FourKites milestone tracking.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vgmCutoffHoursBeforeDeparture rdf:type rdf:Property ;
    rdfs:label 'Vgm Cutoff Hours Before Departure' ;
    rdfs:comment 'Deadline for submission of Verified Gross Mass (VGM) declaration expressed as hours before scheduled departure. Mandatory for ocean shipments under SOLAS Amendment 2016. Null for non-ocean modes.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voyageRotationNumber rdf:type rdf:Property ;
    rdfs:label 'Voyage Rotation Number' ;
    rdfs:comment 'Carrier-assigned voyage or rotation number for ocean services, or equivalent rotation identifier for air/rail. Used for Bill of Lading (BOL) and Master Bill of Lading (MBL) cross-referencing and port authority reporting.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneeId rdf:type rdf:Property ;
    rdfs:label 'Consignee Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.consignee. Business justification: Freight order execution requires the operational consignee record (geocodes, delivery preferences, blacklist status, COD eligibility) for last-mile handoff planning and SLA compliance. The existing co' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Consignee .

ind:contractRateId rdf:type rdf:Property ;
    rdfs:label 'Contract Rate Id' ;
    rdfs:comment 'Foreign key linking to pricing.contract_rate. Business justification: Contract rates are the negotiated sell-side rates applied to customer freight orders. Linking enables revenue recognition, contract utilization tracking, and deviation reporting. A logistics expert ex' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractRate .

ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: The freight order is the primary billable unit; its invoice_id enables order-to-cash tracking, revenue recognition at order level, and customer invoice reconciliation — fundamental to logistics AR ope' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:laneCommitmentId rdf:type rdf:Property ;
    rdfs:label 'Lane Commitment Id' ;
    rdfs:comment 'Foreign key linking to contract.lane_commitment. Business justification: Lane commitments define contracted capacity and minimum volumes per trade lane. Linking freight orders to lane commitments enables real-time volume utilization tracking against contracted commitments ' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LaneCommitment .

ind:notificationContactId rdf:type rdf:Property ;
    rdfs:label 'Notification Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: Freight orders require a designated notification contact for shipment updates, exception alerts, and POD confirmation. Role-prefixed \'notification_contact_id\' because freight_order may have multiple c' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:originFacilityId rdf:type rdf:Property ;
    rdfs:label 'Origin Facility Id' ;
    rdfs:comment 'Foreign key linking to warehouse.facility. Business justification: Freight orders originating from warehouse facilities (e.g., export consolidation, cross-dock) need origin_facility_id for cargo readiness verification, facility performance metrics, and origin-to-carr' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:originSupplierSiteId rdf:type rdf:Property ;
    rdfs:label 'Origin Supplier Site Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier_site. Business justification: Inbound freight pickup planning: the supplier site is the physical origin location for supplier-to-DC freight orders. Logistics teams need the supplier site reference on the freight order to coordinat' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierSite .

ind:actualDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Timestamp' ;
    rdfs:comment 'Actual date and time the freight was delivered to the consignee. Used for POD (Proof of Delivery) confirmation, OTD and OTIF KPI measurement, and SLA compliance reporting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Timestamp' ;
    rdfs:comment 'Actual date and time the freight departed from the origin port or facility. Used for transit time calculation, carrier performance measurement, and OTD reporting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bookingDate rdf:type rdf:Property ;
    rdfs:label 'Booking Date' ;
    rdfs:comment 'The business date on which the freight order was accepted and confirmed by the carrier or freight forwarder. Represents the principal real-world event time for this transaction and is used for revenue recognition and SLA measurement start.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeableWeightKg rdf:type rdf:Property ;
    rdfs:label 'Chargeable Weight Kg' ;
    rdfs:comment 'The weight basis used for freight charge calculation — the higher of gross weight and dimensional weight. Stored explicitly to support freight audit, carrier invoice reconciliation, and revenue recognition.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:co2eEmissionsKg rdf:type rdf:Property ;
    rdfs:label 'Co2e Emissions Kg' ;
    rdfs:comment 'Estimated greenhouse gas (GHG) emissions in kilograms of CO2 equivalent (CO2e) for this freight order. Calculated based on transport mode, distance, and cargo weight. Required for EU ETS reporting, CORSIA compliance (air), and customer sustainability reporting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationPortOrFacility rdf:type rdf:Property ;
    rdfs:label 'Destination Port Or Facility' ;
    rdfs:comment 'UN/LOCODE or internal facility code identifying the specific port, airport, CFS, ICD, or delivery facility at the destination. Used for last-mile planning, customs clearance, and THC calculation.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimWeightKg rdf:type rdf:Property ;
    rdfs:label 'Dim Weight Kg' ;
    rdfs:comment 'Calculated dimensional weight in kilograms derived from shipment volume using the applicable DIM factor (e.g., 1:6000 for air). The chargeable weight is the higher of gross weight and DIM weight. Stored as a business field to support charge audit and dispute resolution.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eta rdf:type rdf:Property ;
    rdfs:label 'Eta' ;
    rdfs:comment 'Estimated Time of Arrival (ETA) at the destination port or facility. Used for delivery scheduling, customs pre-clearance, and OTD (On-Time Delivery) KPI measurement. Updated dynamically by FourKites predictive ETA engine.' ;
    rdfs:domain ind:Freight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:etd rdf:type rdf:Property ;
    rdfs:label 'Etd' ;
    rdfs:comment 'Estimated Time of Departure (ETD) from the origin port or facility. Used for vessel/flight scheduling, carrier coordination, and customer notification. Sourced from SAP TM and updated via FourKites real-time visibility.' ;
    rdfs:domain ind:Freight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:freightChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Charge Amount' ;
    rdfs:comment 'Base freight charge amount for this order before surcharges and adjustments, in the billing currency. Represents the core revenue line for freight forwarding. Used for revenue recognition, P&L reporting, and freight audit.' ;
    rdfs:domain ind:Freight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isNvocc rdf:type rdf:Property ;
    rdfs:label 'Is Nvocc' ;
    rdfs:comment 'Indicates whether this freight order is executed under an NVOCC (Non-Vessel Operating Common Carrier) arrangement, where the company acts as a carrier to the shipper but uses another vessel operator. Affects BOL issuance, liability, and FMC filing requirements.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Externally visible, human-readable business identifier for the freight order as assigned by SAP TM freight order management. Used in customer communications, EDI messages, and operational tracking.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle state of the freight order from booking acceptance through final delivery. Drives operational workflows, exception management, and SLA monitoring. [ENUM-REF-CANDIDATE: draft|booked|confirmed|in_transit|customs_hold|at_destination|delivered|cancelled|on_hold — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originPortOrFacility rdf:type rdf:Property ;
    rdfs:label 'Origin Port Or Facility' ;
    rdfs:comment 'UN/LOCODE or internal facility code identifying the specific port, airport, CFS (Container Freight Station), ICD (Inland Container Depot), or warehouse from which the freight departs. Used for scheduling, carrier assignment, and THC calculation.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Freight charge payment arrangement indicating whether charges are prepaid by the shipper, collected from the consignee, or billed to a third party. Drives invoicing workflow and accounts receivable allocation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevel rdf:type rdf:Property ;
    rdfs:label 'Service Level' ;
    rdfs:comment 'Contracted service level commitment for this freight order defining the speed and priority of delivery. Drives SLA measurement, carrier selection, and premium charge application. [ENUM-REF-CANDIDATE: same_day|next_day|two_day|standard|deferred|economy|priority — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingCode rdf:type rdf:Property ;
    rdfs:label 'Special Handling Code' ;
    rdfs:comment 'Industry-standard special handling code indicating specific requirements such as temperature control, fragile, live animals, or oversized cargo. Uses IATA Special Handling Codes (e.g., PER for perishables, AVI for live animals, HEA for heavy cargo). Multiple codes may be concatenated.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRequirement rdf:type rdf:Property ;
    rdfs:label 'Temperature Requirement' ;
    rdfs:comment 'Temperature control requirement for the shipment. Applicable for pharmaceutical, perishable, and cold-chain freight. Drives equipment selection, carrier qualification, and GDP (Good Distribution Practice) compliance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teuCount rdf:type rdf:Property ;
    rdfs:label 'Teu Count' ;
    rdfs:comment 'Number of TEUs (Twenty-foot Equivalent Units) allocated to this freight order for ocean container movements. Applicable for FCL and LCL ocean shipments. Used for vessel capacity planning, GRI application, and port statistics reporting.' ;
    rdfs:domain ind:Freight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderAmount rdf:type rdf:Property ;
    rdfs:label 'Total Order Amount' ;
    rdfs:comment 'Total billable amount for this freight order including base freight charges, all surcharges, and applicable taxes. Represents the net total for invoicing and revenue recognition. Equals freight_charge_amount plus total_surcharge_amount plus applicable taxes.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Total Surcharge Amount' ;
    rdfs:comment 'Aggregate of all applicable surcharges for this freight order including BAF (Bunker Adjustment Factor), GRI (General Rate Increase), THC (Terminal Handling Charge), fuel surcharge, and security surcharge. Stored as a total to support charge breakdown analysis.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookingNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Booking Network Node Id' ;
    rdfs:comment 'Reference to the network node entity representing the pickup or origin point for this booking (e.g., shipper warehouse, Container Freight Station (CFS), Inland Container Depot (ICD), or airport/seaport terminal).' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:quoteId rdf:type rdf:Property ;
    rdfs:label 'Quote Id' ;
    rdfs:comment 'Foreign key linking to freight.freight_quote. Business justification: A booking may be created based on a freight quote. This FK tracks the quote-to-booking lineage. Nullable for direct bookings not based on a quote. No reverse FK exists, no bidirectional violation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Quote .

ind:bookingStatus rdf:type rdf:Property ;
    rdfs:label 'Booking Status' ;
    rdfs:comment 'Current lifecycle state of the freight booking. Tracks progression from initial submission through carrier confirmation or rejection to execution. \'executed\' indicates a freight order has been raised against this booking.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'Timestamp when this booking was cancelled by the shipper or operations team. Null if the booking has not been cancelled. Used for cancellation fee assessment, capacity release, and booking lifecycle analytics.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:carrierBookingRef rdf:type rdf:Property ;
    rdfs:label 'Carrier Booking Ref' ;
    rdfs:comment 'The booking confirmation reference number issued by the carrier upon space reservation acceptance. For ocean shipments this is the carrier\'s booking number; for air it may be the airline\'s booking code. Used for cross-referencing with carrier systems.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerType rdf:type rdf:Property ;
    rdfs:label 'Container Type' ;
    rdfs:comment 'ISO container type code for ocean freight bookings (e.g., 20GP = 20-foot General Purpose, 40HC = 40-foot High Cube, 20RF = 20-foot Refrigerated). Null for non-ocean or non-containerized shipments. Drives Twenty-foot Equivalent Unit (TEU) calculation and Terminal Handling Charge (THC) assessment. [ENUM-REF-CANDIDATE: 20GP|40GP|40HC|45HC|20RF|40RF|20OT|40OT — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dangerousGoods rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods' ;
    rdfs:comment 'Indicates whether the cargo contains dangerous goods or hazardous materials requiring special handling, documentation, and regulatory compliance. True triggers IMDG Code compliance checks for ocean, ICAO Technical Instructions for air, and ADR for road transport.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedFreightCharge rdf:type rdf:Property ;
    rdfs:label 'Estimated Freight Charge' ;
    rdfs:comment 'Estimated base freight charge for this booking in the billing currency, calculated at time of booking based on applicable rate tariff, chargeable weight, and lane. Excludes surcharges (BAF, GRI, THC). Used for shipper quotation and revenue forecasting.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightTerms rdf:type rdf:Property ;
    rdfs:label 'Freight Terms' ;
    rdfs:comment 'Indicates who is responsible for paying the freight charges: prepaid (shipper pays), collect (consignee pays), or third_party (a nominated third party pays). Drives accounts receivable routing and invoice generation in SAP S/4HANA Finance.' ;
    rdfs:domain ind:Freight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incoterms rdf:type rdf:Property ;
    rdfs:label 'Incoterms' ;
    rdfs:comment 'International Commercial Terms (Incoterms) agreed between buyer and seller governing the transfer of risk, cost responsibility, and delivery obligations. Determines freight charge allocation (prepaid vs collect), insurance responsibility, and customs clearance party. Published by the International Chamber of Commerce (ICC). [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mawbNumber rdf:type rdf:Property ;
    rdfs:label 'Mawb Number' ;
    rdfs:comment 'Master Air Waybill (MAWB) number issued by the airline or ground handling agent for air freight bookings. Follows IATA 3-digit airline prefix plus 8-digit serial number format. Null for non-air transport modes. Used for cargo tracking and customs filing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mblNumber rdf:type rdf:Property ;
    rdfs:label 'Mbl Number' ;
    rdfs:comment 'Master Bill of Lading (MBL) number issued by the ocean carrier for ocean freight bookings. Serves as the primary transport document and title of goods for ocean shipments. Null for non-ocean transport modes.' ;
    rdfs:domain ind:Freight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nvoccArrangement rdf:type rdf:Property ;
    rdfs:label 'Nvocc Arrangement' ;
    rdfs:comment 'Indicates whether this booking is executed under a Non-Vessel Operating Common Carrier (NVOCC) arrangement, where Transport Shipping acts as a carrier to the shipper but contracts with an actual vessel operator. Relevant for FMC tariff filing and House Bill of Lading (HBL) issuance.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pieceCount rdf:type rdf:Property ;
    rdfs:label 'Piece Count' ;
    rdfs:comment 'Total number of individual pieces, packages, or handling units included in this booking. Used for cargo receipt verification, load planning, and Proof of Delivery (POD) reconciliation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reference rdf:type rdf:Property ;
    rdfs:label 'Reference' ;
    rdfs:comment 'Externally-known alphanumeric booking reference number assigned at the time of booking submission. Communicated to the shipper and used across EDI, API, and manual channels for tracking and correspondence. Maps to Oracle TMS booking reference field.' ;
    rdfs:domain ind:Freight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'The date on which the shipper requests cargo to be delivered to the consignee at the destination. Basis for SLA commitment and On-Time Delivery (OTD) performance measurement.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedPickupDate rdf:type rdf:Property ;
    rdfs:label 'Requested Pickup Date' ;
    rdfs:comment 'The date on which the shipper requests cargo to be collected from the origin location. Used for capacity planning, driver/vehicle scheduling, and SLA commitment calculation.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:spaceConfirmationDate rdf:type rdf:Property ;
    rdfs:label 'Space Confirmation Date' ;
    rdfs:comment 'Timestamp when the carrier confirmed space reservation for this booking. Null if space has not yet been confirmed. Used for SLA tracking and booking lead-time analytics.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:spaceConfirmed rdf:type rdf:Property ;
    rdfs:label 'Space Confirmed' ;
    rdfs:comment 'Indicates whether the carrier has confirmed space reservation for this booking. True when the carrier has issued a booking confirmation; False when the booking is pending carrier acceptance or has been rejected.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Timestamp' ;
    rdfs:comment 'Actual date and time the cargo arrived at the destination airport. Used for OTD (On-Time Delivery) KPI calculation, SLA compliance reporting, and claims assessment.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:awbStatus rdf:type rdf:Property ;
    rdfs:label 'Awb Status' ;
    rdfs:comment 'Current lifecycle status of the air waybill. DRAFT: document being prepared; ISSUED: AWB formally issued and accepted by carrier; ACCEPTED: cargo accepted at origin; IN_TRANSIT: cargo in movement; ARRIVED: cargo arrived at destination airport; DELIVERED: cargo delivered to consignee; CANCELLED: AWB voided. [ENUM-REF-CANDIDATE: DRAFT|ISSUED|ACCEPTED|IN_TRANSIT|ARRIVED|DELIVERED|CANCELLED — promote to reference product]' ;
    rdfs:domain ind:AirWaybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awbType rdf:type rdf:Property ;
    rdfs:label 'Awb Type' ;
    rdfs:comment 'Indicates whether this record represents a Master Air Waybill (MAWB) issued by the airline, a House Air Waybill (HAWB) issued by the freight forwarder, or a DIRECT AWB for a single-shipper direct airline shipment.' ;
    rdfs:domain ind:AirWaybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargesCollectOrPrepaid rdf:type rdf:Property ;
    rdfs:label 'Charges Collect Or Prepaid' ;
    rdfs:comment 'Indicates whether freight charges are to be paid by the shipper at origin (PREPAID) or by the consignee at destination (COLLECT). Determines billing party and accounts receivable assignment.' ;
    rdfs:domain ind:AirWaybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredValueForCarriage rdf:type rdf:Property ;
    rdfs:label 'Declared Value For Carriage' ;
    rdfs:comment 'The value of the shipment declared by the shipper for the purpose of determining the carrier\'s liability in case of loss or damage. May be \'NVD\' (No Value Declared) in which case this field is null. Governs maximum liability per IATA conditions of contract.' ;
    rdfs:domain ind:AirWaybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:declaredValueForCustoms rdf:type rdf:Property ;
    rdfs:label 'Declared Value For Customs' ;
    rdfs:comment 'The customs value of the shipment declared by the shipper for import duty and tax assessment at the destination country. Used by Descartes Customs for duty calculation and customs entry filing.' ;
    rdfs:domain ind:AirWaybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationAirportCode rdf:type rdf:Property ;
    rdfs:label 'Destination Airport Code' ;
    rdfs:comment '3-letter IATA airport code for the final destination airport where the cargo is to be delivered to the consignee (e.g., LAX, SIN, LHR). Used for routing, customs filing, and rate determination.' ;
    rdfs:domain ind:AirWaybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstTransitAirportCode rdf:type rdf:Property ;
    rdfs:label 'First Transit Airport Code' ;
    rdfs:comment '3-letter IATA airport code for the first intermediate transit/transfer point in the routing, if applicable. Null for direct flights. Used for multi-leg routing documentation on the AWB.' ;
    rdfs:domain ind:AirWaybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isfFilingNumber rdf:type rdf:Property ;
    rdfs:label 'Isf Filing Number' ;
    rdfs:comment 'The US Customs and Border Protection Importer Security Filing (ISF, also known as 10+2) reference number. Required for ocean and air cargo imports into the United States for advance security screening.' ;
    rdfs:domain ind:AirWaybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'The date on which the air waybill was formally issued and signed, representing the principal business event timestamp for this contract of carriage. Corresponds to the execution date of the freight contract between shipper and carrier.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issue Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone offset) when the air waybill was issued in SAP TM. Provides sub-day precision for operational sequencing and SLA measurement.' ;
    rdfs:domain ind:Freight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originAirportCode rdf:type rdf:Property ;
    rdfs:label 'Origin Airport Code' ;
    rdfs:comment '3-letter IATA airport code for the airport of departure where the cargo is tendered to the airline (e.g., DXB, FRA, JFK). Used for routing, rate determination, and regulatory reporting.' ;
    rdfs:domain ind:AirWaybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piecesCount rdf:type rdf:Property ;
    rdfs:label 'Pieces Count' ;
    rdfs:comment 'Total number of individual pieces, packages, or handling units included in this shipment as declared on the AWB. Used for cargo acceptance, loading, and delivery verification.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:podSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Pod Signatory Name' ;
    rdfs:comment 'Name of the individual who signed for receipt of the cargo at delivery, as captured on the electronic or paper proof of delivery (ePOD). Used for delivery confirmation and dispute resolution.' ;
    rdfs:domain ind:AirWaybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateClass rdf:type rdf:Property ;
    rdfs:label 'Rate Class' ;
    rdfs:comment 'IATA rate class code indicating the type of rate applied to this shipment (e.g., N=Normal, Q=Quantity, M=Minimum, B=Basic, C=Specific Commodity, E=Express, R=Reduced, S=Surcharge, U=Unit Load Device, X=Express). Determines the applicable tariff structure. [ENUM-REF-CANDIDATE: N|Q|M|B|C|E|R|S|U|X — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AirWaybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePerKg rdf:type rdf:Property ;
    rdfs:label 'Rate Per Kg' ;
    rdfs:comment 'The agreed freight rate applied per kilogram of chargeable weight for this shipment, in the billing currency. Commercially sensitive pricing data used for revenue recognition and freight audit.' ;
    rdfs:domain ind:AirWaybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:secondTransitAirportCode rdf:type rdf:Property ;
    rdfs:label 'Second Transit Airport Code' ;
    rdfs:comment '3-letter IATA airport code for the second intermediate transit/transfer point in the routing, if applicable. Null for direct or single-transit flights. Supports complex multi-leg air freight routing.' ;
    rdfs:domain ind:AirWaybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Total Charge Amount' ;
    rdfs:comment 'Grand total of all charges on the AWB including base freight charge and all other charges (surcharges, fees, taxes). Represents the total amount due from the shipper or consignee. Used for invoice generation and accounts receivable.' ;
    rdfs:domain ind:AirWaybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Date' ;
    rdfs:comment 'Actual date the vessel arrived at the port of discharge. Used for transit time calculation, demurrage and detention computation, customs import filing, and on-time delivery (OTD) KPI reporting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualDepartureDate rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Date' ;
    rdfs:comment 'Actual date the vessel departed from the port of loading. Used for transit time calculation, carrier performance measurement, and customs export record finalization.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amsFilingNumber rdf:type rdf:Property ;
    rdfs:label 'Ams Filing Number' ;
    rdfs:comment 'US Customs and Border Protection (CBP) Automated Manifest System (AMS) filing reference number. Required for all ocean shipments destined for or transiting through US ports. Must be filed 24 hours prior to vessel loading under the 24-Hour Advance Manifest Rule.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bolStatus rdf:type rdf:Property ;
    rdfs:label 'Bol Status' ;
    rdfs:comment 'Current lifecycle state of the bill of lading document. Draft indicates pre-issuance; issued means the original has been released to the shipper; released indicates cargo release authorized; surrendered means original returned to carrier; amended reflects post-issuance corrections; cancelled indicates the BOL is void. Satisfies TRANSACTION_HEADER LIFECYCLE_STATUS minimum category.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bolType rdf:type rdf:Property ;
    rdfs:label 'Bol Type' ;
    rdfs:comment 'Classification of the bill of lading indicating whether it is a master (MBL), house (HBL), seaway, straight (non-negotiable), to-order (negotiable), or surrendered BOL. Determines negotiability and title transfer rules. [ENUM-REF-CANDIDATE: master|house|seaway|straight|order|surrender — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierScac rdf:type rdf:Property ;
    rdfs:label 'Carrier Scac' ;
    rdfs:comment 'Four-letter Standard Carrier Alpha Code (SCAC) identifying the ocean carrier (vessel operating common carrier) that issued the master bill of lading. Used for AMS filing, EDI transactions, and carrier performance tracking.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerCount rdf:type rdf:Property ;
    rdfs:label 'Container Count' ;
    rdfs:comment 'Total number of containers covered by this bill of lading. Used for capacity planning, terminal handling charge (THC) calculation, and TEU-based reporting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:freightAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Amount' ;
    rdfs:comment 'Base ocean freight charge amount as stated on the bill of lading, before surcharges. Expressed in the currency indicated by freight_currency_code. Used for freight invoice reconciliation, revenue recognition in SAP S/4HANA Finance, and freight audit in Oracle TMS. Satisfies TRANSACTION_HEADER MONETARY_TRIPLET minimum category (base amount component).' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Freight Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the freight charges are denominated (e.g., USD, EUR, CNY). Required for multi-currency freight invoice processing and foreign exchange revaluation in SAP S/4HANA Finance. Satisfies TRANSACTION_HEADER MONETARY_TRIPLET minimum category (currency code component).' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightSurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Surcharge Amount' ;
    rdfs:comment 'Total surcharge amount applied to the base freight, including Bunker Adjustment Factor (BAF), General Rate Increase (GRI), Terminal Handling Charge (THC), and other accessorial charges. Satisfies TRANSACTION_HEADER MONETARY_TRIPLET minimum category (adjustment component).' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:imdgClass rdf:type rdf:Property ;
    rdfs:label 'Imdg Class' ;
    rdfs:comment 'IMDG hazard class of the dangerous goods (e.g., Class 1 Explosives, Class 3 Flammable Liquids, Class 6.1 Toxic Substances). Populated only when is_hazardous is true. Drives stowage segregation, emergency procedures, and port authority notifications. [ENUM-REF-CANDIDATE: 1|2|3|4|5|6|7|8|9 — promote to reference product]' ;
    rdfs:domain ind:Freight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHazardous rdf:type rdf:Property ;
    rdfs:label 'Is Hazardous' ;
    rdfs:comment 'Flag indicating whether the cargo contains dangerous goods as classified under the IMDG Code. When true, additional IMDG declarations, special stowage requirements, and emergency response information are mandatory.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNegotiable rdf:type rdf:Property ;
    rdfs:label 'Is Negotiable' ;
    rdfs:comment 'Flag indicating whether the bill of lading is negotiable (to-order) or non-negotiable (straight/waybill). A negotiable BOL serves as a document of title and can be transferred by endorsement; a non-negotiable BOL cannot be used to transfer title.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalBolCount rdf:type rdf:Property ;
    rdfs:label 'Original Bol Count' ;
    rdfs:comment 'Number of original signed copies of the bill of lading issued to the shipper (typically 3). All originals must be surrendered to the carrier for cargo release when the BOL is negotiable. Used for document control and letter of credit compliance.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packageType rdf:type rdf:Property ;
    rdfs:label 'Package Type' ;
    rdfs:comment 'Description of the type of packaging used for the cargo (e.g., cartons, pallets, drums, crates, bags). Used for cargo handling instructions, stowage planning, and customs declarations. [ENUM-REF-CANDIDATE: carton|pallet|drum|crate|bag|bundle|roll|cylinder — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placeOfDelivery rdf:type rdf:Property ;
    rdfs:label 'Place Of Delivery' ;
    rdfs:comment 'Final destination where the carrier delivers the cargo to the consignee, which may differ from the port of discharge (e.g., an inland CFS, ICD, or door delivery address). Defines the end of the carrier\'s responsibility under the contract of carriage.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placeOfIssue rdf:type rdf:Property ;
    rdfs:label 'Place Of Issue' ;
    rdfs:comment 'City and country where the bill of lading was issued by the carrier or NVOCC. Required for letter of credit compliance and legal jurisdiction determination in case of disputes.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placeOfReceipt rdf:type rdf:Property ;
    rdfs:label 'Place Of Receipt' ;
    rdfs:comment 'Location where the carrier takes custody of the cargo, which may differ from the port of loading (e.g., an inland container depot (ICD) or container freight station (CFS)). Defines the start of the carrier\'s responsibility under the contract of carriage.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfDischarge rdf:type rdf:Property ;
    rdfs:label 'Port Of Discharge' ;
    rdfs:comment 'UN/LOCODE of the port where the cargo is discharged from the ocean vessel. Represents the destination port for the ocean leg. Used for customs import filing, terminal handling charge (THC) calculation, and delivery planning.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfLoading rdf:type rdf:Property ;
    rdfs:label 'Port Of Loading' ;
    rdfs:comment 'UN/LOCODE of the port where the cargo is loaded onto the ocean vessel. Represents the origin port for the ocean leg of the shipment. Used for freight rate calculation, customs export filing, and carrier scheduling.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperReference rdf:type rdf:Property ;
    rdfs:label 'Shipper Reference' ;
    rdfs:comment 'Shipper\'s own internal reference number or purchase order number associated with this shipment. Printed on the bill of lading for cross-referencing with the shipper\'s ERP or order management system. Facilitates EDI reconciliation.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFreightAmount rdf:type rdf:Property ;
    rdfs:label 'Total Freight Amount' ;
    rdfs:comment 'Total freight charges payable as stated on the bill of lading, being the sum of the base freight amount and all applicable surcharges. Used for freight invoice generation, letter of credit compliance, and revenue reporting. Satisfies TRANSACTION_HEADER MONETARY_TRIPLET minimum category (net total component).' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blockedSpaceAgreementId rdf:type rdf:Property ;
    rdfs:label 'Blocked Space Agreement Id' ;
    rdfs:comment 'Foreign key linking to network.blocked_space_agreement. Business justification: NVOCC consolidations are frequently built against blocked space agreements with carriers. Linking consolidation to BSA enables utilization tracking against guaranteed capacity, penalty/incentive calcu' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BlockedSpaceAgreement .

ind:consolidationCarrierId rdf:type rdf:Property ;
    rdfs:label 'Consolidation Carrier Id' ;
    rdfs:comment 'Identifier of the ocean carrier, airline, or surface carrier assigned to transport the consolidation. For NVOCC operations, this is the underlying vessel or flight operator.' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:consolidationNvoccOperatorCarrierId rdf:type rdf:Property ;
    rdfs:label 'Consolidation Nvocc Operator Carrier Id' ;
    rdfs:comment 'Identifier of the NVOCC or freight forwarder operating the consolidation. For direct carrier consolidations, this may be null.' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:destinationCfsFacilityId rdf:type rdf:Property ;
    rdfs:label 'Destination Cfs Facility Id' ;
    rdfs:comment 'Identifier of the destination CFS or ICD facility where the consolidation will be deconsolidated and cargo distributed. Links to warehouse or facility master data.' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:originCfsFacilityId rdf:type rdf:Property ;
    rdfs:label 'Origin Cfs Facility Id' ;
    rdfs:comment 'Identifier of the origin CFS or ICD facility where cargo is received and consolidated. Links to warehouse or facility master data.' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:pickWaveId rdf:type rdf:Property ;
    rdfs:label 'Pick Wave Id' ;
    rdfs:comment 'Foreign key linking to warehouse.pick_wave. Business justification: In 3PL consolidation operations, a pick wave produces the individual shipments that are consolidated into one freight movement. Linking consolidation to pick_wave enables cargo cutoff coordination and' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PickWave .

ind:cargoCutoffDatetime rdf:type rdf:Property ;
    rdfs:label 'Cargo Cutoff Datetime' ;
    rdfs:comment 'Latest date and time by which cargo must be received at the origin CFS facility to be included in this consolidation.' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:carrierBookingReference rdf:type rdf:Property ;
    rdfs:label 'Carrier Booking Reference' ;
    rdfs:comment 'Booking or reservation number provided by the carrier for the consolidation space allocation.' ;
    rdfs:domain ind:Freight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationStatus rdf:type rdf:Property ;
    rdfs:label 'Consolidation Status' ;
    rdfs:comment 'Current lifecycle status of the consolidation from planning through deconsolidation at destination. [ENUM-REF-CANDIDATE: planned|booking_open|cargo_receiving|closed|departed|in_transit|arrived|deconsolidated — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationType rdf:type rdf:Property ;
    rdfs:label 'Consolidation Type' ;
    rdfs:comment 'Type of consolidation based on transport mode. Ocean LCL (Less Than Container Load) groups multiple shippers cargo into a single FCL container. Air groupage consolidates shipments into a single ULD (Unit Load Device). Road and rail groupage combine multiple LTL shipments.' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerSizeType rdf:type rdf:Property ;
    rdfs:label 'Container Size Type' ;
    rdfs:comment 'ISO container size and type code for ocean consolidations. 20GP = 20-foot General Purpose, 40GP = 40-foot General Purpose, 40HC = 40-foot High Cube, 45HC = 45-foot High Cube. Null for non-containerized modes.' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containsDangerousGoods rdf:type rdf:Property ;
    rdfs:label 'Contains Dangerous Goods' ;
    rdfs:comment 'Indicates whether the consolidation contains any dangerous goods (hazardous materials) requiring special handling and documentation per IMDG or IATA DGR.' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containsTemperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Contains Temperature Controlled' ;
    rdfs:comment 'Indicates whether the consolidation contains temperature-sensitive cargo requiring reefer container or climate-controlled handling.' ;
    rdfs:domain ind:Freight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deconsolidationCompleteDatetime rdf:type rdf:Property ;
    rdfs:label 'Deconsolidation Complete Datetime' ;
    rdfs:comment 'Date and time when all cargo was deconsolidated and available for onward delivery or pickup.' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deconsolidationStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Deconsolidation Start Datetime' ;
    rdfs:comment 'Date and time when deconsolidation operations began at the destination CFS facility.' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedArrivalDatetime rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Datetime' ;
    rdfs:comment 'Estimated arrival date and time at the destination port. Updated based on carrier tracking and real-time visibility data.' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:freightChargeCurrency rdf:type rdf:Property ;
    rdfs:label 'Freight Charge Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for freight charges (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDepartureDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Departure Datetime' ;
    rdfs:comment 'Scheduled departure date and time of the carrier vessel, flight, or vehicle transporting the consolidation from origin port.' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalChargeableWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Chargeable Weight Kg' ;
    rdfs:comment 'Total chargeable weight for the consolidation, calculated as the greater of gross weight or volumetric weight (volume * dimensional weight factor). Used for freight charge calculation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFreightChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Total Freight Charge Amount' ;
    rdfs:comment 'Total freight charges for the consolidation, including base ocean or air freight, BAF (Bunker Adjustment Factor), GRI (General Rate Increase), THC (Terminal Handling Charge), and other surcharges.' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalGrossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Gross Weight Kg' ;
    rdfs:comment 'Total gross weight of all cargo in the consolidation, measured in kilograms.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPieceCount rdf:type rdf:Property ;
    rdfs:label 'Total Piece Count' ;
    rdfs:comment 'Total number of individual pieces or packages across all shipments in the consolidation.' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalShipmentCount rdf:type rdf:Property ;
    rdfs:label 'Total Shipment Count' ;
    rdfs:comment 'Number of individual shipper shipments (house shipments) consolidated into this master consolidation.' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Total Volume Cbm' ;
    rdfs:comment 'Total volume of all cargo in the consolidation, measured in cubic meters. Critical for LCL and air groupage space utilization.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uldNumber rdf:type rdf:Property ;
    rdfs:label 'Uld Number' ;
    rdfs:comment 'IATA ULD identifier for air groupage consolidations. Format: 3-letter ULD type code + 5-digit serial + 2-letter owner code. Null for non-air consolidations.' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Utilization Percentage' ;
    rdfs:comment 'Percentage of container or ULD capacity utilized by the consolidation, calculated as (actual volume / maximum capacity) * 100. Key metric for consolidation efficiency.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loadPlanId rdf:type rdf:Property ;
    rdfs:label 'Load Plan Id' ;
    rdfs:comment 'Unique identifier for the load plan record. Primary key.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoadPlan .

ind:storageLocationId rdf:type rdf:Property ;
    rdfs:label 'Storage Location Id' ;
    rdfs:comment 'Foreign key linking to warehouse.storage_location. Business justification: Load plans specify staging locations within warehouses where cargo is assembled before container/vehicle loading. Tracking staging_location_id enables warehouse space utilization analysis, load sequen' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:actualLoadCompletionTime rdf:type rdf:Property ;
    rdfs:label 'Actual Load Completion Time' ;
    rdfs:comment 'Actual timestamp when loading operations were completed. Critical for on-time performance tracking and operational efficiency analysis.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualLoadStartTime rdf:type rdf:Property ;
    rdfs:label 'Actual Load Start Time' ;
    rdfs:comment 'Actual timestamp when loading operations commenced. Used for performance measurement and variance analysis against planned time.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cargoPlacementInstructions rdf:type rdf:Property ;
    rdfs:label 'Cargo Placement Instructions' ;
    rdfs:comment 'Detailed instructions for cargo placement within the transport unit, including stacking rules, orientation requirements, and securing methods.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:centerOfGravityX rdf:type rdf:Property ;
    rdfs:label 'Center Of Gravity X' ;
    rdfs:comment 'Calculated X-coordinate of the load center of gravity relative to transport unit reference point. Critical for vessel and aircraft stability.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:centerOfGravityY rdf:type rdf:Property ;
    rdfs:label 'Center Of Gravity Y' ;
    rdfs:comment 'Calculated Y-coordinate of the load center of gravity relative to transport unit reference point. Critical for vessel and aircraft stability.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:centerOfGravityZ rdf:type rdf:Property ;
    rdfs:label 'Center Of Gravity Z' ;
    rdfs:comment 'Calculated Z-coordinate (vertical) of the load center of gravity relative to transport unit reference point. Critical for vessel and aircraft stability.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:containsHazmat rdf:type rdf:Property ;
    rdfs:label 'Contains Hazmat' ;
    rdfs:comment 'Indicates whether the load plan includes hazardous materials requiring special handling and segregation. Triggers additional compliance checks.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatClass rdf:type rdf:Property ;
    rdfs:label 'Hazmat Class' ;
    rdfs:comment 'UN hazard class of dangerous goods included in the load plan. Determines segregation requirements and handling procedures. Pipe-separated list if multiple classes present.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatSegregationVerified rdf:type rdf:Property ;
    rdfs:label 'Hazmat Segregation Verified' ;
    rdfs:comment 'Indicates whether hazmat segregation requirements have been verified and approved by qualified personnel. Mandatory for hazmat loads.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loadOptimizationMethod rdf:type rdf:Property ;
    rdfs:label 'Load Optimization Method' ;
    rdfs:comment 'Method used to create the load plan. Automated plans use TMS optimization algorithms, manual plans are created by planners, hybrid combines both.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Load Plan Status' ;
    rdfs:comment 'Current lifecycle status of the load plan. Tracks progression from initial planning through execution completion. [ENUM-REF-CANDIDATE: draft|planned|approved|in_progress|completed|cancelled|on_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Load Sequence Number' ;
    rdfs:comment 'Sequential order in which cargo items are to be loaded onto the transport unit. Critical for LIFO/FIFO optimization and unloading efficiency.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loadingDockBay rdf:type rdf:Property ;
    rdfs:label 'Loading Dock Bay' ;
    rdfs:comment 'Specific dock, bay, or gate number where loading operations are performed. Used for operational coordination and resource allocation.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadingLocationCode rdf:type rdf:Property ;
    rdfs:label 'Loading Location Code' ;
    rdfs:comment 'Code identifying the facility or terminal where loading operations take place. May be UN/LOCODE, IATA airport code, or internal facility code.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedLoadCompletionTime rdf:type rdf:Property ;
    rdfs:label 'Planned Load Completion Time' ;
    rdfs:comment 'Scheduled timestamp when loading operations are expected to be completed. Used for departure scheduling and SLA management.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedLoadDate rdf:type rdf:Property ;
    rdfs:label 'Planned Load Date' ;
    rdfs:comment 'Scheduled date when loading operations are planned to begin. Used for resource planning and scheduling.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedLoadStartTime rdf:type rdf:Property ;
    rdfs:label 'Planned Load Start Time' ;
    rdfs:comment 'Precise timestamp when loading operations are scheduled to commence. Critical for dock scheduling and labor planning.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:specialHandlingRequirements rdf:type rdf:Property ;
    rdfs:label 'Special Handling Requirements' ;
    rdfs:comment 'Any special handling requirements for the load, such as fragile cargo, high-value goods, live animals, or oversized items requiring special equipment.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalActualVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Total Actual Volume Cbm' ;
    rdfs:comment 'Total actual volume of all cargo loaded, measured in cubic meters. Captured post-loading for utilization analysis.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalActualWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Actual Weight Kg' ;
    rdfs:comment 'Total actual weight of all cargo loaded, measured in kilograms. Captured post-loading for verification and compliance documentation.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPlannedVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Total Planned Volume Cbm' ;
    rdfs:comment 'Total planned volume of all cargo to be loaded, measured in cubic meters. Used for space utilization and capacity planning.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPlannedWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Planned Weight Kg' ;
    rdfs:comment 'Total planned weight of all cargo to be loaded, measured in kilograms. Used for weight distribution calculations and regulatory compliance.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportUnitType rdf:type rdf:Property ;
    rdfs:label 'Transport Unit Type' ;
    rdfs:comment 'Type of transport unit for which the load plan is created. Determines applicable loading rules and constraints.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeUtilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Volume Utilization Percentage' ;
    rdfs:comment 'Percentage of volume capacity utilized by the planned load. Key performance indicator for space optimization efficiency.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightUtilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Weight Utilization Percentage' ;
    rdfs:comment 'Percentage of weight capacity utilized by the planned load. Key performance indicator for load optimization efficiency.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierPayableId rdf:type rdf:Property ;
    rdfs:label 'Carrier Payable Id' ;
    rdfs:comment 'Foreign key linking to billing.carrier_payable. Business justification: Carrier assignments drive carrier payables (AP for carrier services). Assignment-to-payable link enables carrier cost tracking, rate validation, and carrier invoice reconciliation against contracted a' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarrierPayable .

ind:accessorialChargesAmount rdf:type rdf:Property ;
    rdfs:label 'Accessorial Charges Amount' ;
    rdfs:comment 'Total accessorial charges for additional services such as liftgate, inside delivery, detention, demurrage, Terminal Handling Charge (THC), or special equipment.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Date' ;
    rdfs:comment 'Date when the carrier was assigned to the freight order. Represents the business event date of carrier selection.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current status of the carrier assignment in its lifecycle: pending carrier confirmation, confirmed by carrier, rejected by carrier, cancelled by shipper, or expired due to timeout.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Timestamp' ;
    rdfs:comment 'Precise timestamp when the carrier assignment was created in the system. Supports audit trail and carrier selection analytics.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:carrierIataCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Iata Code' ;
    rdfs:comment 'IATA two-letter or three-character airline designator code for air carriers. Used for air waybill (AWB) and flight operations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierInstructions rdf:type rdf:Property ;
    rdfs:label 'Carrier Instructions' ;
    rdfs:comment 'Special instructions or requirements specific to this carrier assignment, such as handling requirements, delivery windows, contact information, or operational constraints.' ;
    rdfs:domain ind:FreightCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierScacCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Scac Code' ;
    rdfs:comment 'Standard Carrier Alpha Code uniquely identifying the carrier in North American freight operations. 2-4 uppercase letters assigned by the National Motor Freight Traffic Association (NMFTA).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationDate rdf:type rdf:Property ;
    rdfs:label 'Confirmation Date' ;
    rdfs:comment 'Date when the carrier confirmed acceptance of the freight assignment. Null if not yet confirmed.' ;
    rdfs:domain ind:FreightCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmation Timestamp' ;
    rdfs:comment 'Precise timestamp when the carrier confirmed the assignment. Used for Service Level Agreement (SLA) tracking and carrier performance measurement.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customsBrokerRequired rdf:type rdf:Property ;
    rdfs:label 'Customs Broker Required' ;
    rdfs:comment 'Boolean flag indicating whether this carrier assignment requires customs brokerage services for cross-border shipments. Integrates with Descartes Customs system.' ;
    rdfs:domain ind:FreightCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Date' ;
    rdfs:comment 'Estimated date when the carrier will deliver the freight to the destination. Used for customer communication and Service Level Agreement (SLA) tracking.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedPickupDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Pickup Date' ;
    rdfs:comment 'Estimated date when the carrier will pick up the freight from the origin location. Used for planning and coordination.' ;
    rdfs:domain ind:FreightCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fuelSurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Amount' ;
    rdfs:comment 'Fuel surcharge or Bunker Adjustment Factor (BAF) applied by the carrier to account for fuel price fluctuations. Separate from base freight charge.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatCertified rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified' ;
    rdfs:comment 'Boolean flag indicating whether the assigned carrier is certified to transport hazardous materials (dangerous goods) per International Maritime Dangerous Goods (IMDG) Code or ICAO Technical Instructions.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isIntermodal rdf:type rdf:Property ;
    rdfs:label 'Is Intermodal' ;
    rdfs:comment 'Boolean flag indicating whether this carrier assignment is part of an intermodal transport chain involving multiple modes (e.g., ocean to rail to road).' ;
    rdfs:domain ind:FreightCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryCarrier rdf:type rdf:Property ;
    rdfs:label 'Is Primary Carrier' ;
    rdfs:comment 'Boolean flag indicating whether this is the primary carrier assignment for the freight order. True if primary, False if backup or secondary carrier.' ;
    rdfs:domain ind:FreightCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:masterAwbNumber rdf:type rdf:Property ;
    rdfs:label 'Master Awb Number' ;
    rdfs:comment 'Master Air Waybill number issued by the air carrier for air freight assignments. Format: 3-digit airline code followed by 8-digit serial number.' ;
    rdfs:domain ind:FreightCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:masterBolNumber rdf:type rdf:Property ;
    rdfs:label 'Master Bol Number' ;
    rdfs:comment 'Master Bill of Lading number issued by the ocean carrier or Non-Vessel Operating Common Carrier (NVOCC) for ocean freight assignments.' ;
    rdfs:domain ind:FreightCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Timestamp when this carrier assignment record was last modified. Updated on any change to assignment status, confirmation, or carrier details.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Priority level assigned to this carrier assignment for operational sequencing and resource allocation: critical (urgent), high, normal, or low priority.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectionCriteria rdf:type rdf:Property ;
    rdfs:label 'Selection Criteria' ;
    rdfs:comment 'Business criteria or rules applied during carrier selection, such as lowest cost, fastest transit, preferred carrier, service level, or capacity availability.' ;
    rdfs:domain ind:FreightCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectionMethod rdf:type rdf:Property ;
    rdfs:label 'Selection Method' ;
    rdfs:comment 'Method used to select this carrier: manual selection by planner, automated rule-based selection, optimization algorithm, spot market quote, or pre-negotiated contract assignment.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCarrierCost rdf:type rdf:Property ;
    rdfs:label 'Total Carrier Cost' ;
    rdfs:comment 'Total cost payable to the carrier including base freight charge, fuel surcharge, and all accessorial charges. Used for freight audit and cost reconciliation.' ;
    rdfs:domain ind:FreightCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Tracking Enabled' ;
    rdfs:comment 'Boolean flag indicating whether real-time shipment tracking is enabled for this carrier assignment via integration with FourKites or carrier tracking systems.' ;
    rdfs:domain ind:FreightCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vehicleCount rdf:type rdf:Property ;
    rdfs:label 'Vehicle Count' ;
    rdfs:comment 'Number of vehicles (trucks, trailers, railcars) assigned by the carrier for this freight order. Applicable for road and rail transport modes.' ;
    rdfs:domain ind:FreightCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessorialChargeId rdf:type rdf:Property ;
    rdfs:label 'Accessorial Charge Id' ;
    rdfs:comment 'Foreign key linking to pricing.accessorial_charge. Business justification: Accessorial charges (THC, BAF, GRI) are applied at the leg level in intermodal operations. Linking enables leg-level accessorial charge breakdown for billing, audit, and carrier cost allocation. No ex' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccessorialCharge .

ind:amsFilingId rdf:type rdf:Property ;
    rdfs:label 'Ams Filing Id' ;
    rdfs:comment 'Foreign key linking to customs.ams_filing. Business justification: AMS filings are submitted per vessel/flight leg for CBP compliance. Linking freight_leg to ams_filing enables leg-level manifest compliance tracking. Booking links to AMS for commercial records; freig' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AmsFiling .

ind:isfFilingId rdf:type rdf:Property ;
    rdfs:label 'Isf Filing Id' ;
    rdfs:comment 'Foreign key linking to customs.isf_filing. Business justification: ISF (10+2) is tied to the specific ocean leg carrying cargo into the US. Linking freight_leg to isf_filing enables CBP compliance tracking at the operational leg level, supporting penalty avoidance an' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IsfFiling .

ind:originNodeNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Origin Node Network Node Id' ;
    rdfs:comment 'Reference to the origin location for this leg. Can be a port, airport, warehouse, Container Freight Station (CFS), Inland Container Depot (ICD), or other network node.' ;
    rdfs:domain ind:FreightLeg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:primaryFreightNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Freight Network Node Id' ;
    rdfs:comment 'Reference to the network node where the intermodal transfer occurs. Typically a Container Freight Station (CFS), Inland Container Depot (ICD), or intermodal terminal.' ;
    rdfs:domain ind:FreightLeg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:transferFacilityId rdf:type rdf:Property ;
    rdfs:label 'Transfer Facility Id' ;
    rdfs:comment 'Foreign key linking to warehouse.facility. Business justification: Freight legs with intermodal transfers (e.g., ocean-to-rail, air-to-truck) occur at warehouse facilities (CFS, cross-dock terminals). Tracking transfer_facility_id enables transfer dwell time analysis' ;
    rdfs:domain ind:Freight ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:bafAmount rdf:type rdf:Property ;
    rdfs:label 'Baf Amount' ;
    rdfs:comment 'Bunker Adjustment Factor surcharge for this leg. Fuel-related surcharge applied to ocean freight to account for fluctuating fuel costs.' ;
    rdfs:domain ind:FreightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:delayDurationHours rdf:type rdf:Property ;
    rdfs:label 'Delay Duration Hours' ;
    rdfs:comment 'Duration of delay for this leg in hours. Calculated as the difference between actual and scheduled arrival times when a delay occurs.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationLocationType rdf:type rdf:Property ;
    rdfs:label 'Destination Location Type' ;
    rdfs:comment 'Type of facility at the destination of this leg. Classifies the ending point as port, airport, warehouse, Container Freight Station (CFS), Inland Container Depot (ICD), terminal, or depot. [ENUM-REF-CANDIDATE: port|airport|warehouse|CFS|ICD|terminal|depot — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FreightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dwellTimeHours rdf:type rdf:Property ;
    rdfs:label 'Dwell Time Hours' ;
    rdfs:comment 'Duration in hours that freight remains at the destination location before moving to the next leg. Critical for intermodal transfer efficiency and Service Level Agreement (SLA) monitoring.' ;
    rdfs:domain ind:Freight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightChargesAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Charges Amount' ;
    rdfs:comment 'Base freight charges for this leg. Excludes surcharges such as Bunker Adjustment Factor (BAF), General Rate Increase (GRI), and Terminal Handling Charge (THC).' ;
    rdfs:domain ind:FreightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightChargesCurrency rdf:type rdf:Property ;
    rdfs:label 'Freight Charges Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the freight charges amount. Indicates the currency in which base freight fees are denominated.' ;
    rdfs:domain ind:FreightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:griAmount rdf:type rdf:Property ;
    rdfs:label 'Gri Amount' ;
    rdfs:comment 'General Rate Increase surcharge for this leg. Carrier-imposed rate adjustment applied to base freight charges, typically for ocean freight.' ;
    rdfs:domain ind:FreightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handlingChargesAmount rdf:type rdf:Property ;
    rdfs:label 'Handling Charges Amount' ;
    rdfs:comment 'Total handling charges incurred at the destination of this leg. Includes Terminal Handling Charge (THC), Container Freight Station (CFS) charges, and other transfer-related fees.' ;
    rdfs:domain ind:FreightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handlingChargesCurrency rdf:type rdf:Property ;
    rdfs:label 'Handling Charges Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the handling charges amount. Indicates the currency in which handling fees are denominated.' ;
    rdfs:domain ind:FreightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isIntermodalTransfer rdf:type rdf:Property ;
    rdfs:label 'Is Intermodal Transfer' ;
    rdfs:comment 'Indicates whether this leg involves an intermodal transfer (change of transport mode) at the destination. True if freight transitions between air/ocean/road/rail at the end of this leg.' ;
    rdfs:domain ind:FreightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originLocationType rdf:type rdf:Property ;
    rdfs:label 'Origin Location Type' ;
    rdfs:comment 'Type of facility at the origin of this leg. Classifies the starting point as port, airport, warehouse, Container Freight Station (CFS), Inland Container Depot (ICD), terminal, or depot. [ENUM-REF-CANDIDATE: port|airport|warehouse|CFS|ICD|terminal|depot — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FreightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival Timestamp' ;
    rdfs:comment 'Planned arrival date and time for this leg at the destination location. Represents the Estimated Time of Arrival (ETA) used for planning and customer communication.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Departure Timestamp' ;
    rdfs:comment 'Planned departure date and time for this leg from the origin location. Represents the Estimated Time of Departure (ETD) used for planning and customer communication.' ;
    rdfs:domain ind:FreightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Sequential order of this leg within the multi-leg freight movement. Indicates the position in the transport chain (e.g., 1 for first leg, 2 for second leg).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thcAmount rdf:type rdf:Property ;
    rdfs:label 'Thc Amount' ;
    rdfs:comment 'Terminal Handling Charge for this leg. Fee charged for handling containers at the origin or destination terminal.' ;
    rdfs:domain ind:Freight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLegChargesAmount rdf:type rdf:Property ;
    rdfs:label 'Total Leg Charges Amount' ;
    rdfs:comment 'Total charges for this leg including base freight, surcharges (BAF, GRI, THC), and handling charges. Represents the complete cost of this transport segment.' ;
    rdfs:domain ind:FreightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLegChargesCurrency rdf:type rdf:Property ;
    rdfs:label 'Total Leg Charges Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the total leg charges amount. Indicates the currency in which total leg costs are denominated.' ;
    rdfs:domain ind:FreightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferType rdf:type rdf:Property ;
    rdfs:label 'Transfer Type' ;
    rdfs:comment 'Type of intermodal transfer occurring at the destination of this leg. Specifies the mode transition (e.g., ocean to road, air to road, rail to road) or none if no transfer. [ENUM-REF-CANDIDATE: ocean_to_road|ocean_to_rail|air_to_road|road_to_ocean|road_to_rail|rail_to_road|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Freight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Transport Document Number' ;
    rdfs:comment 'Reference number of the transport document for this leg. Can be an Air Waybill (AWB), Bill of Lading (BOL), House Air Waybill (HAWB), Master Air Waybill (MAWB), House Bill of Lading (HBL), or Master Bill of Lading (MBL) depending on mode.' ;
    rdfs:domain ind:FreightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportDocumentType rdf:type rdf:Property ;
    rdfs:label 'Transport Document Type' ;
    rdfs:comment 'Type of transport document issued for this leg. Identifies whether it is an Air Waybill (AWB), Bill of Lading (BOL), House/Master variants, or road/rail consignment note. [ENUM-REF-CANDIDATE: AWB|BOL|HAWB|MAWB|HBL|MBL|CMR|CIM — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FreightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselName rdf:type rdf:Property ;
    rdfs:label 'Vessel Name' ;
    rdfs:comment 'Name of the ocean vessel or aircraft used for this leg. Applicable for air and ocean transport modes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voyageFlightNumber rdf:type rdf:Property ;
    rdfs:label 'Voyage Flight Number' ;
    rdfs:comment 'Voyage number (for ocean) or flight number (for air) for this leg. Identifies the specific sailing or flight carrying the freight.' ;
    rdfs:domain ind:FreightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Dock Appointment Id' ;
    rdfs:comment 'Foreign key linking to warehouse.dock_appointment. Business justification: Intermodal transfers at a facility require a dock appointment for the physical transfer operation (unloading from one mode, loading onto another). This link enables transfer scheduling, dwell time tra' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DockAppointment .

ind:pricingChargeCodeId rdf:type rdf:Property ;
    rdfs:label 'Pricing Charge Code Id' ;
    rdfs:comment 'Foreign key linking to pricing.charge_code. Business justification: Charge codes classify transfer costs (THC, handling, storage) for GL allocation and billing. Standard in intermodal operations to code each transfer charge for financial reporting. No existing pricing' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChargeCode .

ind:transferNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Transfer Network Node Id' ;
    rdfs:comment 'Foreign key linking to route.network_node. Business justification: Intermodal transfers occur at network nodes (ports, rail yards, air hubs). Dwell time analysis, node throughput reporting, and SLA compliance tracking by transfer point require linking intermodal_tran' ;
    rdfs:domain ind:IntermodalTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:exceptionDescription rdf:type rdf:Property ;
    rdfs:label 'Exception Description' ;
    rdfs:comment 'Detailed narrative description of the exception or delay encountered during the intermodal transfer, including root cause and impact.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingEquipmentType rdf:type rdf:Property ;
    rdfs:label 'Handling Equipment Type' ;
    rdfs:comment 'Type of material handling equipment used to perform the physical transfer of cargo between transport modes.' ;
    rdfs:domain ind:IntermodalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledTransferTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Transfer Timestamp' ;
    rdfs:comment 'The planned date and time for the intermodal transfer as per the original schedule or booking.' ;
    rdfs:domain ind:IntermodalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sealNumber rdf:type rdf:Property ;
    rdfs:label 'Seal Number' ;
    rdfs:comment 'Security seal number applied to the container or cargo unit at the transfer point to ensure cargo integrity.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sealVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Seal Verification Status' ;
    rdfs:comment 'Status of seal verification at the transfer point, indicating whether the inbound seal was intact and whether a new seal was applied.' ;
    rdfs:domain ind:IntermodalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Flag' ;
    rdfs:comment 'Boolean indicator of whether the actual dwell time met the SLA target. True = compliant, False = SLA breach.' ;
    rdfs:domain ind:IntermodalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaDwellTimeHours rdf:type rdf:Property ;
    rdfs:label 'Sla Dwell Time Hours' ;
    rdfs:comment 'The maximum allowable dwell time in hours as defined by the service level agreement or operational target for this transfer type.' ;
    rdfs:domain ind:IntermodalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageCharge rdf:type rdf:Property ;
    rdfs:label 'Storage Charge' ;
    rdfs:comment 'Additional charge for cargo storage at the interchange facility if dwell time exceeds free time allowances.' ;
    rdfs:domain ind:IntermodalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supervisorName rdf:type rdf:Property ;
    rdfs:label 'Supervisor Name' ;
    rdfs:comment 'Name of the on-site supervisor or shift manager who oversaw the transfer operation.' ;
    rdfs:domain ind:IntermodalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalTransferCost rdf:type rdf:Property ;
    rdfs:label 'Total Transfer Cost' ;
    rdfs:comment 'Total cost of the intermodal transfer including handling charges, THC, storage, and any other applicable fees.' ;
    rdfs:domain ind:IntermodalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferFacilityType rdf:type rdf:Property ;
    rdfs:label 'Transfer Facility Type' ;
    rdfs:comment 'Classification of the interchange facility type. ICD = Inland Container Depot, CFS = Container Freight Station.' ;
    rdfs:domain ind:IntermodalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferHandlingCharge rdf:type rdf:Property ;
    rdfs:label 'Transfer Handling Charge' ;
    rdfs:comment 'The monetary charge for the physical handling and transfer of cargo at the interchange facility, excluding other accessorial charges.' ;
    rdfs:domain ind:IntermodalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Number' ;
    rdfs:comment 'Business-facing unique reference number for the intermodal transfer, used for tracking and documentation across systems and partners.' ;
    rdfs:domain ind:IntermodalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Status' ;
    rdfs:comment 'Current lifecycle status of the intermodal transfer operation, tracking progression from scheduled through completion or exception states.' ;
    rdfs:domain ind:IntermodalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transfer Timestamp' ;
    rdfs:comment 'The actual date and time when the physical transfer of cargo between transport modes occurred at the interchange point.' ;
    rdfs:domain ind:IntermodalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:freightChargeId rdf:type rdf:Property ;
    rdfs:label 'Freight Charge Id' ;
    rdfs:comment 'Unique identifier for the freight charge line item. Primary key for this entity.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightCharge .

ind:billingInvoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Billing Invoice Line Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice_line. Business justification: Freight charges must map to invoice lines for charge-to-bill reconciliation. Critical for freight audit, revenue assurance, and dispute resolution. Enables operational charge validation against billed' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingInvoiceLine .

ind:contractSurchargeScheduleId rdf:type rdf:Property ;
    rdfs:label 'Contract Surcharge Schedule Id' ;
    rdfs:comment 'Foreign key linking to contract.contract_surcharge_schedule. Business justification: Applied surcharges (BAF, GRI, security) must be validated against the contracted surcharge schedule for billing compliance. Linking freight_charge to contract_surcharge_schedule enables automated surc' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractSurchargeSchedule .

ind:disputeId rdf:type rdf:Property ;
    rdfs:label 'Dispute Id' ;
    rdfs:comment 'Foreign key linking to billing.billing_dispute. Business justification: Individual freight charges (surcharges, accessorials, base rates) are the specific line items disputed in billing disputes. Linking freight_charge directly to billing_dispute enables dispute teams to ' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dispute .

ind:dutyAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Duty Assessment Id' ;
    rdfs:comment 'Foreign key linking to customs.duty_assessment. Business justification: Freight charges include duty and tax components assessed by customs. Linking freight_charge to duty_assessment enables accurate billing reconciliation between freight charges and customs-assessed duti' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DutyAssessment .

ind:paymentAllocationId rdf:type rdf:Property ;
    rdfs:label 'Payment Allocation Id' ;
    rdfs:comment 'Foreign key linking to billing.payment_allocation. Business justification: Payment allocations reconcile customer payments against specific freight charges. Charge-level payment matching enables granular AR reconciliation and supports partial payment allocation to multi-char' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentAllocation .

ind:pricingSurchargeId rdf:type rdf:Property ;
    rdfs:label 'Pricing Surcharge Id' ;
    rdfs:comment 'Foreign key linking to pricing.surcharge. Business justification: Individual surcharge line items (fuel, security, peak season) must reference the surcharge definition master for billing transparency and regulatory compliance. Pricing_surcharge_id links each charge ' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Surcharge .

ind:rateScheduleId rdf:type rdf:Property ;
    rdfs:label 'Rate Schedule Id' ;
    rdfs:comment 'Foreign key linking to contract.rate_schedule. Business justification: Freight charges must be validated against the contractual rate schedule for billing audit and dispute resolution. The contract.rate_schedule is the authoritative contractual rate basis, distinct from ' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateSchedule .

ind:basis rdf:type rdf:Property ;
    rdfs:label 'Basis' ;
    rdfs:comment 'Unit of measurement or calculation method for the charge. Defines how the charge is computed, such as per Twenty-foot Equivalent Unit (TEU), per kilogram, per Cubic Meter (CBM), flat rate, or as a percentage of another value. [ENUM-REF-CANDIDATE: per_TEU|per_kg|per_CBM|per_shipment|per_container|per_pallet|per_package|per_ton|per_mile|per_kilometer|per_day|flat_rate|percentage — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeCategory rdf:type rdf:Property ;
    rdfs:label 'Charge Category' ;
    rdfs:comment 'High-level grouping of the charge for financial reporting and analysis. Distinguishes between core freight charges, surcharges, accessorial services, regulatory fees, administrative fees, and penalty charges.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeDescription rdf:type rdf:Property ;
    rdfs:label 'Charge Description' ;
    rdfs:comment 'Human-readable description of the charge component. Provides additional context beyond the charge type for billing transparency and customer communication.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeStatus rdf:type rdf:Property ;
    rdfs:label 'Charge Status' ;
    rdfs:comment 'The current lifecycle status of this charge. Tracks whether the charge is pending approval, approved for billing, already invoiced, paid, under dispute, waived, or cancelled. [ENUM-REF-CANDIDATE: pending|approved|invoiced|paid|disputed|waived|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeType rdf:type rdf:Property ;
    rdfs:label 'Charge Type' ;
    rdfs:comment 'Classification of the freight charge component. Identifies whether this is a base freight rate or a specific surcharge type such as Bunker Adjustment Factor (BAF), General Rate Increase (GRI), Terminal Handling Charge (THC), fuel surcharge, peak season surcharge, port congestion surcharge, documentation fee, or other mode-specific and service-specific charges. [ENUM-REF-CANDIDATE: base_freight|BAF|GRI|THC|fuel_surcharge|peak_season_surcharge|port_congestion_surcharge|documentation_fee|customs_clearance_fee|handling_charge|storage_charge|demurrage|detention|chassis_fee|inland_haulage|security_surcharge|war_risk_surcharge|currency_adjustment_factor|low_sulfur_surcharge|emergency_bunker_surcharge|container_service_charge — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'The cost center to which this charge is allocated for internal cost accounting and profitability analysis. Used for operational cost tracking.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'The General Ledger account code to which this charge is posted for financial accounting. Used for revenue recognition or cost allocation depending on charge direction.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'The invoice document number to which this charge has been posted. Null if the charge has not yet been invoiced. Links the charge to the billing domain.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBillable rdf:type rdf:Property ;
    rdfs:label 'Is Billable' ;
    rdfs:comment 'Boolean flag indicating whether this charge should be included in customer invoicing. True if the charge is billable to the customer, false if it is an internal cost or non-billable item.' ;
    rdfs:domain ind:FreightCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDisputed rdf:type rdf:Property ;
    rdfs:label 'Is Disputed' ;
    rdfs:comment 'Boolean flag indicating whether this charge is currently under dispute by the customer or carrier. True if a dispute has been raised, false otherwise.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTaxable rdf:type rdf:Property ;
    rdfs:label 'Is Taxable' ;
    rdfs:comment 'Boolean flag indicating whether this charge is subject to tax (VAT, GST, sales tax). Used to determine if tax calculation should be applied during invoicing.' ;
    rdfs:domain ind:FreightCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'The profit center to which this charge is allocated for segment reporting and profitability analysis. Used for business unit performance measurement.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'The quantity or volume to which the charge rate is applied. For example, number of TEUs, weight in kilograms, volume in CBM, or number of days. Used in conjunction with charge_basis and unit_rate to calculate the charge amount.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'The tax classification code applicable to this charge. Used by the financial system to determine the correct tax rate and treatment. Null if the charge is not taxable.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitRate rdf:type rdf:Property ;
    rdfs:label 'Unit Rate' ;
    rdfs:comment 'The rate per unit for this charge. Combined with quantity to calculate the total charge amount. For percentage-based charges, this represents the percentage value.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:updatedBy rdf:type rdf:Property ;
    rdfs:label 'Updated By' ;
    rdfs:comment 'The username or identifier of the user or system process that last modified this charge record. Used for audit trail and change accountability.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'The username or identifier of the user or system process that created this charge record. Used for audit trail and accountability.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneId rdf:type rdf:Property ;
    rdfs:label 'Milestone Id' ;
    rdfs:comment 'Unique identifier for the freight milestone event record. Primary key.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Timestamp' ;
    rdfs:comment 'Actual date and time when the milestone event occurred, as confirmed by carrier, warehouse, customs, or tracking system.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customsClearanceNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Number' ;
    rdfs:comment 'Customs declaration or clearance reference number if this milestone is related to customs processing.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'System or channel through which the milestone event data was received (e.g., EDI message, FourKites real-time feed, manual entry, carrier API). [ENUM-REF-CANDIDATE: edi|api|fourkites|manual|carrier_portal|tms|wms|customs_system — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediMessageType rdf:type rdf:Property ;
    rdfs:label 'Edi Message Type' ;
    rdfs:comment 'EDI message type code if this milestone was received via EDI (e.g., IFTSTA, IFTMAN, DESADV for EDIFACT; 214, 315 for ANSI X12).' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Estimated Timestamp' ;
    rdfs:comment 'Current estimated date and time for this milestone event, updated dynamically based on real-time tracking data from FourKites and carrier feeds. Represents predictive ETA.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exceptionCode rdf:type rdf:Property ;
    rdfs:label 'Exception Code' ;
    rdfs:comment 'Standardized code representing the type of exception if is_exception is true (e.g., DELAY_WEATHER, CUSTOMS_HOLD, MISSED_CUTOFF, DAMAGED_CARGO).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCriticalMilestone rdf:type rdf:Property ;
    rdfs:label 'Is Critical Milestone' ;
    rdfs:comment 'Indicates whether this milestone is considered critical for SLA compliance and customer notifications (e.g., vessel departure, customs clearance, delivery).' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isException rdf:type rdf:Property ;
    rdfs:label 'Is Exception' ;
    rdfs:comment 'Indicates whether this milestone represents an exception or deviation from the planned schedule (e.g., delay, missed connection, customs hold).' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Type of facility or location where the milestone event occurred. [ENUM-REF-CANDIDATE: port|airport|warehouse|cfs|icd|customs_facility|customer_site|carrier_terminal — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneCategory rdf:type rdf:Property ;
    rdfs:label 'Milestone Category' ;
    rdfs:comment 'High-level category grouping for the milestone event to support analytics and reporting segmentation. [ENUM-REF-CANDIDATE: booking|origin|transit|customs|destination|delivery|exception — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneCode rdf:type rdf:Property ;
    rdfs:label 'Milestone Code' ;
    rdfs:comment 'Standardized code representing the milestone event type (e.g., BKG_CONF, CARGO_RCV, CUST_CLR, VSL_DEP, VSL_ARR, POD_RCV). Aligns with industry EDI standards and internal TMS milestone taxonomy.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneName rdf:type rdf:Property ;
    rdfs:label 'Milestone Name' ;
    rdfs:comment 'Human-readable name or description of the milestone event (e.g., Booking Confirmed, Cargo Received at Origin, Customs Cleared, Vessel Departed, Vessel Arrived, Proof of Delivery Received).' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Milestone Status' ;
    rdfs:comment 'Current status of the milestone event in its lifecycle.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSent rdf:type rdf:Property ;
    rdfs:label 'Notification Sent' ;
    rdfs:comment 'Indicates whether a customer notification (email, SMS, portal alert) was sent for this milestone event.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Timestamp' ;
    rdfs:comment 'Originally scheduled or planned date and time for this milestone event to occur, based on initial routing and scheduling.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:podDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Pod Document Url' ;
    rdfs:comment 'URL or storage path to the electronic proof of delivery document (ePOD) or scanned signature.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podSignatureName rdf:type rdf:Property ;
    rdfs:label 'Pod Signature Name' ;
    rdfs:comment 'Name of the person who signed for delivery, if applicable and captured.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofOfDeliveryReceived rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Received' ;
    rdfs:comment 'Indicates whether proof of delivery documentation has been received for this milestone (applicable to delivery milestones).' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sequence rdf:type rdf:Property ;
    rdfs:label 'Sequence' ;
    rdfs:comment 'Sequential order of this milestone within the freight order lifecycle. Enables chronological sorting and progress tracking.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureRecordedCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Recorded Celsius' ;
    rdfs:comment 'Temperature reading recorded at this milestone for temperature-controlled shipments.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:updatedByUser rdf:type rdf:Property ;
    rdfs:label 'Updated By User' ;
    rdfs:comment 'Username or identifier of the user or system process that last updated this milestone record.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionId rdf:type rdf:Property ;
    rdfs:label 'Exception Id' ;
    rdfs:comment 'Unique identifier for the freight exception record. Primary key.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acknowledgedBy rdf:type rdf:Property ;
    rdfs:label 'Acknowledged By' ;
    rdfs:comment 'Name or identifier of the person or system that acknowledged the exception.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledged Timestamp' ;
    rdfs:comment 'Date and time when the exception was acknowledged by operations team or responsible party.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:awbOrBolNumber rdf:type rdf:Property ;
    rdfs:label 'Awb Or Bol Number' ;
    rdfs:comment 'Transport document number associated with the exception. AWB for air shipments, BOL for ocean/road shipments.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Claim Filed Flag' ;
    rdfs:comment 'Indicates whether a cargo claim was filed as a result of this exception. True if claim filed, false otherwise.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerNotificationChannel rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Channel' ;
    rdfs:comment 'Communication channel used to notify customer of the exception. Includes email, SMS, customer portal, phone, and EDI.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notified Flag' ;
    rdfs:comment 'Indicates whether the customer has been notified of the exception. True if notification sent, false otherwise.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detected Timestamp' ;
    rdfs:comment 'Date and time when the exception was first detected or reported. Primary business event timestamp for this transaction.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:detectionLocation rdf:type rdf:Property ;
    rdfs:label 'Detection Location' ;
    rdfs:comment 'Geographic location or facility where the exception was detected. May be port, airport, warehouse, or in-transit location.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionSource rdf:type rdf:Property ;
    rdfs:label 'Detection Source' ;
    rdfs:comment 'Origin or channel through which the exception was identified. Includes system automated alerts, carrier notifications, customer reports, warehouse scans, customs alerts, manual inspections, IoT sensors, and GPS tracking. [ENUM-REF-CANDIDATE: system_automated|carrier_notification|customer_report|warehouse_scan|customs_alert|manual_inspection|iot_sensor|gps_tracking — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalated Timestamp' ;
    rdfs:comment 'Date and time when the exception was escalated to higher management tier.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exceptionCategory rdf:type rdf:Property ;
    rdfs:label 'Exception Category' ;
    rdfs:comment 'High-level grouping of exception types for reporting and analysis. Categories include operational, carrier, customs, documentation, cargo, infrastructure, and force majeure. [ENUM-REF-CANDIDATE: operational|carrier|customs|documentation|cargo|infrastructure|force_majeure — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionNumber rdf:type rdf:Property ;
    rdfs:label 'Exception Number' ;
    rdfs:comment 'Business-facing unique identifier for the exception, used in customer communications and tracking.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionStatus rdf:type rdf:Property ;
    rdfs:label 'Exception Status' ;
    rdfs:comment 'Current lifecycle status of the exception. Tracks progression from detection through resolution.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'Estimated or actual financial impact of the exception, including additional costs, penalties, or revenue loss. Expressed in transaction currency.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightExceptionDescription rdf:type rdf:Property ;
    rdfs:label 'Freight Exception Description' ;
    rdfs:comment 'Detailed narrative description of the exception event, including circumstances, impact, and any immediate actions taken.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactedLegSequence rdf:type rdf:Property ;
    rdfs:label 'Impacted Leg Sequence' ;
    rdfs:comment 'Sequence number of the freight order leg affected by this exception. Null if exception impacts entire order.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preventableFlag rdf:type rdf:Property ;
    rdfs:label 'Preventable Flag' ;
    rdfs:comment 'Indicates whether the exception was preventable through better processes, controls, or carrier selection. Used for continuous improvement analysis.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recurrenceFlag rdf:type rdf:Property ;
    rdfs:label 'Recurrence Flag' ;
    rdfs:comment 'Indicates whether this exception is a repeat occurrence on the same freight order or lane. True if recurring issue, false if first occurrence.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionAction rdf:type rdf:Property ;
    rdfs:label 'Resolution Action' ;
    rdfs:comment 'Description of corrective actions taken to resolve the exception. Includes rerouting, re-booking, documentation correction, or customer accommodation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Date and time when the exception was fully resolved and normal operations resumed.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:revisedEta rdf:type rdf:Property ;
    rdfs:label 'Revised Eta' ;
    rdfs:comment 'Updated estimated arrival time following the exception event. Communicated to customer as part of exception management.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Detailed explanation of the underlying cause of the exception. Captured during investigation and resolution process.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Business impact severity of the exception. Critical indicates immediate customer escalation required; high indicates significant delay or cost impact; medium indicates moderate impact; low indicates minor deviation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Sla Target Delivery Date' ;
    rdfs:comment 'Original committed delivery date per customer SLA. Used to calculate breach impact.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address line for suite, building, or unit information. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualGhgEmissionsCo2eTonnes rdf:type rdf:Property ;
    rdfs:label 'Annual Ghg Emissions Co2e Tonnes' ;
    rdfs:comment 'Total annual greenhouse gas emissions from facility operations measured in tonnes of CO2 equivalent. Used for sustainability reporting and carbon footprint tracking.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date when the facility ceased operations, if applicable. Null for active facilities.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customsBondedWarehouse rdf:type rdf:Property ;
    rdfs:label 'Customs Bonded Warehouse' ;
    rdfs:comment 'Indicates whether the facility is a customs bonded warehouse authorized to store imported goods before duties and taxes are paid.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dockDoorCount rdf:type rdf:Property ;
    rdfs:label 'Dock Door Count' ;
    rdfs:comment 'Total number of loading and unloading dock doors available at the facility for inbound and outbound freight operations.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilityCode rdf:type rdf:Property ;
    rdfs:label 'Facility Code' ;
    rdfs:comment 'Externally-known unique business identifier for the facility, used across operational systems and customer communications. Typically a short alphanumeric code.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityName rdf:type rdf:Property ;
    rdfs:label 'Facility Name' ;
    rdfs:comment 'Human-readable name of the warehouse or distribution center facility.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasColdStorage rdf:type rdf:Property ;
    rdfs:label 'Has Cold Storage' ;
    rdfs:comment 'Indicates whether the facility has refrigerated or frozen storage capabilities for temperature-sensitive goods.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasHazmatStorage rdf:type rdf:Property ;
    rdfs:label 'Has Hazmat Storage' ;
    rdfs:comment 'Indicates whether the facility is certified and equipped to store hazardous materials per IMDG Code and local regulations.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAeoCertified rdf:type rdf:Property ;
    rdfs:label 'Is Aeo Certified' ;
    rdfs:comment 'Indicates whether the facility holds AEO certification for trusted trader status and simplified customs procedures in the EU and partner countries.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCtpatCertified rdf:type rdf:Property ;
    rdfs:label 'Is Ctpat Certified' ;
    rdfs:comment 'Indicates whether the facility holds C-TPAT certification for enhanced supply chain security and expedited customs processing.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isIso28000Certified rdf:type rdf:Property ;
    rdfs:label 'Is Iso28000 Certified' ;
    rdfs:comment 'Indicates whether the facility holds ISO 28000 certification for supply chain security management.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isIso9001Certified rdf:type rdf:Property ;
    rdfs:label 'Is Iso9001 Certified' ;
    rdfs:comment 'Indicates whether the facility holds ISO 9001 certification for quality management systems.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiration Date' ;
    rdfs:comment 'Date when the current facility lease expires, if applicable. Used for real estate planning and contract renewal tracking.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxDailyInboundVolumeUnits rdf:type rdf:Property ;
    rdfs:label 'Max Daily Inbound Volume Units' ;
    rdfs:comment 'Maximum number of units (pallets, cartons, or SKUs) the facility can receive and process in a single day. Used for capacity planning and load balancing.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxDailyOutboundVolumeUnits rdf:type rdf:Property ;
    rdfs:label 'Max Daily Outbound Volume Units' ;
    rdfs:comment 'Maximum number of units (pallets, cartons, or SKUs) the facility can pick, pack, and ship in a single day. Used for capacity planning and order fulfillment forecasting.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openedDate rdf:type rdf:Property ;
    rdfs:label 'Opened Date' ;
    rdfs:comment 'Date when the facility first became operational. Used for lifecycle tracking and depreciation calculations.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingHoursWeekday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekday' ;
    rdfs:comment 'Standard operating hours for weekdays in format HH:MM-HH:MM (e.g., 08:00-18:00). Used for scheduling inbound and outbound operations.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursWeekend rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekend' ;
    rdfs:comment 'Standard operating hours for weekends in format HH:MM-HH:MM. May be different from weekday hours or closed.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current operational lifecycle status of the facility.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewableEnergyPercentage rdf:type rdf:Property ;
    rdfs:label 'Renewable Energy Percentage' ;
    rdfs:comment 'Percentage of facility energy consumption sourced from renewable energy (solar, wind, etc.). Used for sustainability KPIs and environmental reporting.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureZoneCount rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone Count' ;
    rdfs:comment 'Number of distinct temperature-controlled zones within the facility (e.g., ambient, refrigerated, frozen) for specialized inventory storage.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalFloorAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Total Floor Area Sqm' ;
    rdfs:comment 'Total usable floor area of the facility measured in square meters, used for capacity planning and utilization analysis.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wmsInstanceCode rdf:type rdf:Property ;
    rdfs:label 'Wms Instance Code' ;
    rdfs:comment 'Identifier of the Manhattan WMS instance managing this facility. Used for system integration and operational tracking.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneId rdf:type rdf:Property ;
    rdfs:label 'Zone Id' ;
    rdfs:comment 'Reference to the logical zone within the warehouse to which this storage location is assigned.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Zone .

ind:activeFromDate rdf:type rdf:Property ;
    rdfs:label 'Active From Date' ;
    rdfs:comment 'Date when this storage location became active and available for warehouse operations.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activeToDate rdf:type rdf:Property ;
    rdfs:label 'Active To Date' ;
    rdfs:comment 'Date when this storage location was deactivated or retired from warehouse operations. Null if currently active.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aisle rdf:type rdf:Property ;
    rdfs:label 'Aisle' ;
    rdfs:comment 'Aisle designation within the warehouse where the storage location is physically situated. Used for route optimization and labor management.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automationType rdf:type rdf:Property ;
    rdfs:label 'Automation Type' ;
    rdfs:comment 'Level and type of automation technology deployed at this storage location. Impacts labor planning and throughput capacity.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bin rdf:type rdf:Property ;
    rdfs:label 'Bin' ;
    rdfs:comment 'Specific bin or slot position within the level. Represents the most granular storage position.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondedWarehouseFlag rdf:type rdf:Property ;
    rdfs:label 'Bonded Warehouse Flag' ;
    rdfs:comment 'Indicates whether this storage location is within a bonded warehouse zone where goods are stored without payment of customs duties until released for domestic consumption.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossDockFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Dock Flag' ;
    rdfs:comment 'Indicates whether this storage location is used for cross-docking operations where inbound shipments are directly transferred to outbound without long-term storage.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cycleCountFrequency rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Frequency' ;
    rdfs:comment 'Scheduled frequency for physical inventory cycle counting at this storage location. Supports inventory accuracy and compliance with ISO 9001 quality management.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireSuppressionZone rdf:type rdf:Property ;
    rdfs:label 'Fire Suppression Zone' ;
    rdfs:comment 'Fire suppression system zone identifier covering this storage location. Critical for safety compliance and insurance requirements.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freeTradeZoneFlag rdf:type rdf:Property ;
    rdfs:label 'Free Trade Zone Flag' ;
    rdfs:comment 'Indicates whether this storage location is within a Free Trade Zone (FTZ) where goods can be stored, processed, or re-exported without customs intervention.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatClassPermitted rdf:type rdf:Property ;
    rdfs:label 'Hazmat Class Permitted' ;
    rdfs:comment 'Comma-separated list of International Maritime Organization (IMO) hazard classes permitted in this storage location (e.g., 1.1, 2.2, 3, 4.1, 5.1, 6.1, 8, 9). Empty if not hazmat suitable.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatSuitable rdf:type rdf:Property ;
    rdfs:label 'Hazmat Suitable' ;
    rdfs:comment 'Indicates whether the storage location is certified and equipped for storing hazardous materials per International Maritime Dangerous Goods (IMDG) Code and International Civil Aviation Organization (ICAO) Technical Instructions.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:heightCm rdf:type rdf:Property ;
    rdfs:label 'Height Cm' ;
    rdfs:comment 'Physical height dimension of the storage location in centimeters.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Cycle Count Date' ;
    rdfs:comment 'Date when the most recent physical cycle count was performed at this storage location.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lengthCm rdf:type rdf:Property ;
    rdfs:label 'Length Cm' ;
    rdfs:comment 'Physical length dimension of the storage location in centimeters.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationBarcode rdf:type rdf:Property ;
    rdfs:label 'Location Barcode' ;
    rdfs:comment 'Scannable barcode identifier for the storage location used by handheld Radio Frequency Identification (RFID) devices and mobile scanning equipment during warehouse operations.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Human-readable unique code identifying the storage location within the warehouse. Used for directed putaway and picking operations in Manhattan Warehouse Management System (WMS).' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationStatus rdf:type rdf:Property ;
    rdfs:label 'Location Status' ;
    rdfs:comment 'Current operational status of the storage location indicating availability for putaway and picking operations.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occupancyStatus rdf:type rdf:Property ;
    rdfs:label 'Occupancy Status' ;
    rdfs:comment 'Current inventory occupancy state of the storage location based on capacity utilization.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickFaceFlag rdf:type rdf:Property ;
    rdfs:label 'Pick Face Flag' ;
    rdfs:comment 'Indicates whether this location is designated as a pick-face position for order fulfillment operations. Pick-face locations are optimized for high-velocity Stock Keeping Units (SKUs).' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quarantineFlag rdf:type rdf:Property ;
    rdfs:label 'Quarantine Flag' ;
    rdfs:comment 'Indicates whether this storage location is designated for quarantine inventory pending quality inspection, customs clearance, or Return Merchandise Authorization (RMA) processing.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rack rdf:type rdf:Property ;
    rdfs:label 'Rack' ;
    rdfs:comment 'Rack or bay identifier within the aisle where the storage location is positioned.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentFlag rdf:type rdf:Property ;
    rdfs:label 'Replenishment Flag' ;
    rdfs:comment 'Indicates whether this location requires periodic replenishment from bulk storage. Used in First In First Out (FIFO) and Last In First Out (LIFO) inventory management strategies.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnsProcessingFlag rdf:type rdf:Property ;
    rdfs:label 'Returns Processing Flag' ;
    rdfs:comment 'Indicates whether this storage location is designated for processing customer returns and Return Merchandise Authorization (RMA) inventory.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:securityLevel rdf:type rdf:Property ;
    rdfs:label 'Security Level' ;
    rdfs:comment 'Security classification of the storage location. High-value and bonded locations require additional access controls per Customs-Trade Partnership Against Terrorism (C-TPAT) and Authorized Economic Operator (AEO) programs.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationLevel rdf:type rdf:Property ;
    rdfs:label 'Storage Location Level' ;
    rdfs:comment 'Vertical level or shelf position within the rack structure. Used for slotting optimization based on Stock Keeping Unit (SKU) velocity and weight.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureClass rdf:type rdf:Property ;
    rdfs:label 'Temperature Class' ;
    rdfs:comment 'Temperature control classification of the storage location. Critical for cold-chain logistics and pharmaceutical shipments.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueAddedServicesFlag rdf:type rdf:Property ;
    rdfs:label 'Value Added Services Flag' ;
    rdfs:comment 'Indicates whether this storage location is designated for value-added services such as kitting, labeling, repackaging, or customization operations.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeCapacityCbm rdf:type rdf:Property ;
    rdfs:label 'Volume Capacity Cbm' ;
    rdfs:comment 'Maximum volumetric capacity of the storage location in cubic meters. Used for dimensional weight (DIM Weight) calculations and space optimization.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Weight Capacity Kg' ;
    rdfs:comment 'Maximum weight capacity of the storage location in kilograms. Used for slotting optimization and safety compliance.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:widthCm rdf:type rdf:Property ;
    rdfs:label 'Width Cm' ;
    rdfs:comment 'Physical width dimension of the storage location in centimeters.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originDeterminationId rdf:type rdf:Property ;
    rdfs:label 'Origin Determination Id' ;
    rdfs:comment 'Foreign key linking to customs.origin_determination. Business justification: Preferential tariff programs: the formal origin determination record establishes whether a SKU qualifies for reduced duty rates under trade agreements. Linking SKU to origin_determination replaces the' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OriginDetermination .

ind:abcClassification rdf:type rdf:Property ;
    rdfs:label 'Abc Classification' ;
    rdfs:comment 'The ABC inventory classification (A=high-value/high-velocity, B=medium, C=low) used for prioritization and slotting optimization.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barcode rdf:type rdf:Property ;
    rdfs:label 'Barcode' ;
    rdfs:comment 'The primary barcode identifier (UPC, EAN, or other format) used for scanning and automated identification in warehouse operations.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barcodeType rdf:type rdf:Property ;
    rdfs:label 'Barcode Type' ;
    rdfs:comment 'The barcode symbology or format type used for this SKU (UPC, EAN, CODE128, etc.).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryDateRequired rdf:type rdf:Property ;
    rdfs:label 'Expiry Date Required' ;
    rdfs:comment 'Boolean flag indicating whether this SKU requires expiry date tracking for inventory management and FEFO rotation.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fragile rdf:type rdf:Property ;
    rdfs:label 'Fragile' ;
    rdfs:comment 'Boolean flag indicating whether this SKU is fragile and requires special handling to prevent damage.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventoryMethod rdf:type rdf:Property ;
    rdfs:label 'Inventory Method' ;
    rdfs:comment 'The inventory valuation and rotation method applied to this SKU: FIFO (First In First Out), LIFO (Last In First Out), FEFO (First Expired First Out), or standard.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotTrackingRequired rdf:type rdf:Property ;
    rdfs:label 'Lot Tracking Required' ;
    rdfs:comment 'Boolean flag indicating whether this SKU requires lot or batch number tracking for traceability and quality control.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'The name of the manufacturer or producer of this SKU, used for quality tracking and compliance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Part Number' ;
    rdfs:comment 'The manufacturers own part number or SKU identifier for this item, used for cross-referencing and procurement.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxStackHeight rdf:type rdf:Property ;
    rdfs:label 'Max Stack Height' ;
    rdfs:comment 'The maximum number of units that can be safely stacked vertically. Null if not stackable or no limit.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pickType rdf:type rdf:Property ;
    rdfs:label 'Pick Type' ;
    rdfs:comment 'The standard picking method or unit used for order fulfillment of this SKU (each-pick, case-pick, pallet-pick, or bulk).' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategory rdf:type rdf:Property ;
    rdfs:label 'Product Category' ;
    rdfs:comment 'High-level classification category for this SKU used for inventory segmentation, slotting optimization, and reporting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productSubcategory rdf:type rdf:Property ;
    rdfs:label 'Product Subcategory' ;
    rdfs:comment 'Detailed subcategory classification within the product category for granular inventory management and analytics.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPoint rdf:type rdf:Property ;
    rdfs:label 'Reorder Point' ;
    rdfs:comment 'The inventory quantity threshold that triggers replenishment or reorder action for this SKU.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfidEnabled rdf:type rdf:Property ;
    rdfs:label 'Rfid Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this SKU is tagged with RFID technology for automated tracking and inventory visibility.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfidTagCode rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag Code' ;
    rdfs:comment 'The RFID tag identifier or Electronic Product Code (EPC) associated with this SKU for automated identification.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Quantity' ;
    rdfs:comment 'The minimum buffer inventory quantity maintained to prevent stockouts and ensure service level for this SKU.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serialTrackingRequired rdf:type rdf:Property ;
    rdfs:label 'Serial Tracking Required' ;
    rdfs:comment 'Boolean flag indicating whether this SKU requires individual serial number tracking at the unit level for high-value or regulated items.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'The number of days from receipt or manufacture date that the SKU remains usable or saleable before expiration. Null for non-perishable items.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:skuCode rdf:type rdf:Property ;
    rdfs:label 'Sku Code' ;
    rdfs:comment 'The externally-known unique alphanumeric code identifying this SKU across all warehouse operations and systems. Used for scanning, picking, and inventory transactions.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuDescription rdf:type rdf:Property ;
    rdfs:label 'Sku Description' ;
    rdfs:comment 'Detailed human-readable description of the product or item represented by this SKU, including key characteristics and specifications.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuStatus rdf:type rdf:Property ;
    rdfs:label 'Sku Status' ;
    rdfs:comment 'Current lifecycle status of the SKU indicating whether it is available for warehouse operations, discontinued, or pending activation.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stackable rdf:type rdf:Property ;
    rdfs:label 'Stackable' ;
    rdfs:comment 'Boolean flag indicating whether this SKU can be safely stacked vertically in storage and transport.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageClass rdf:type rdf:Property ;
    rdfs:label 'Storage Class' ;
    rdfs:comment 'The warehouse storage class or zone assignment for this SKU based on handling requirements, velocity, and physical characteristics (e.g., fast-pick, bulk, secure, hazmat).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Max C' ;
    rdfs:comment 'The maximum allowable storage temperature in Celsius for temperature-controlled SKUs. Null for ambient items.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Min C' ;
    rdfs:comment 'The minimum allowable storage temperature in Celsius for temperature-controlled SKUs. Null for ambient items.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'The standard unit of measure used for inventory counting, picking, and tracking of this SKU.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:velocityCode rdf:type rdf:Property ;
    rdfs:label 'Velocity Code' ;
    rdfs:comment 'The movement velocity classification indicating how frequently this SKU is picked or shipped (fast, medium, slow movers).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Code' ;
    rdfs:comment 'The code or identifier of the primary vendor or supplier for this SKU, used for procurement and replenishment.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightKg rdf:type rdf:Property ;
    rdfs:label 'Weight Kg' ;
    rdfs:comment 'The actual gross weight of the SKU in kilograms, used for handling, labor planning, and freight calculations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryPositionId rdf:type rdf:Property ;
    rdfs:label 'Inventory Position Id' ;
    rdfs:comment 'Unique identifier for the inventory position record. Primary key for this entity.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availableQuantity rdf:type rdf:Property ;
    rdfs:label 'Available Quantity' ;
    rdfs:comment 'Quantity available for allocation to new orders. Calculated as on-hand minus reserved, quarantine, hold, damaged, and expired quantities.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'Three-letter ISO 3166 country code indicating where the product was manufactured or produced. Required for customs declarations and trade compliance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damagedQuantity rdf:type rdf:Property ;
    rdfs:label 'Damaged Quantity' ;
    rdfs:comment 'Quantity identified as physically damaged or defective. Typically segregated for disposal, return to vendor, or salvage processing.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fifoSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Fifo Sequence Number' ;
    rdfs:comment 'Sequential number assigned based on receipt date to enforce FIFO picking logic. Lower numbers are picked first to ensure oldest inventory is consumed before newer stock.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hazmatIndicator rdf:type rdf:Property ;
    rdfs:label 'Hazmat Indicator' ;
    rdfs:comment 'Flag indicating whether the inventory item is classified as hazardous material requiring special handling, storage, and transportation compliance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdQuantity rdf:type rdf:Property ;
    rdfs:label 'Hold Quantity' ;
    rdfs:comment 'Quantity placed on administrative hold due to customer disputes, regulatory issues, or business decisions. Not available for allocation.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inTransitQuantity rdf:type rdf:Property ;
    rdfs:label 'In Transit Quantity' ;
    rdfs:comment 'Quantity currently being moved within the facility between storage locations. Temporarily unavailable during putaway or replenishment operations.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Status' ;
    rdfs:comment 'Current status of the inventory position indicating availability for order fulfillment. Available = ready for allocation; Reserved = committed to orders; Quarantine = pending quality inspection; Hold = administrative block; Damaged = physically impaired; Expired = past expiration date.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMovementDate rdf:type rdf:Property ;
    rdfs:label 'Last Movement Date' ;
    rdfs:comment 'Date of the most recent inventory transaction affecting this position (receipt, pick, adjustment, transfer). Used for slow-moving inventory analysis.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifoSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Lifo Sequence Number' ;
    rdfs:comment 'Sequential number assigned based on receipt date to enforce LIFO picking logic. Higher numbers are picked first to ensure newest inventory is consumed before older stock.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'Batch or lot identifier for traceability and quality control. Used for FIFO/LIFO inventory management and product recalls.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufactureDate rdf:type rdf:Property ;
    rdfs:label 'Manufacture Date' ;
    rdfs:comment 'Date when the product was manufactured or produced. Used for traceability, quality control, and shelf-life calculations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onHandQuantity rdf:type rdf:Property ;
    rdfs:label 'On Hand Quantity' ;
    rdfs:comment 'Total physical quantity of the SKU present at the storage location, regardless of availability status. Includes available, reserved, quarantine, hold, and damaged quantities.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickFaceIndicator rdf:type rdf:Property ;
    rdfs:label 'Pick Face Indicator' ;
    rdfs:comment 'Flag indicating whether this inventory position is in an active pick face location (forward pick area) versus reserve storage. Pick face locations are optimized for high-velocity picking.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:putawayZone rdf:type rdf:Property ;
    rdfs:label 'Putaway Zone' ;
    rdfs:comment 'Warehouse zone designation where the inventory was placed during putaway operations. Used for slotting optimization and pick path planning.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarantineQuantity rdf:type rdf:Property ;
    rdfs:label 'Quarantine Quantity' ;
    rdfs:comment 'Quantity held for quality inspection or pending release approval. Not available for order fulfillment until cleared.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'Date when the inventory was received into the facility. Used for FIFO/LIFO sequencing and aging analysis.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:replenishmentTriggerQuantity rdf:type rdf:Property ;
    rdfs:label 'Replenishment Trigger Quantity' ;
    rdfs:comment 'Minimum quantity threshold that triggers automatic replenishment from reserve storage to pick face. Used to maintain optimal pick face inventory levels.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reservedQuantity rdf:type rdf:Property ;
    rdfs:label 'Reserved Quantity' ;
    rdfs:comment 'Quantity committed to existing orders or work orders but not yet picked. Reduces available quantity for new allocations.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Unique serial number for individual item-level tracking. Used for high-value or serialized inventory items.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlledIndicator rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Indicator' ;
    rdfs:comment 'Flag indicating whether the inventory requires temperature-controlled storage (refrigerated or frozen). Drives storage zone assignment and handling requirements.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureRangeMax rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max' ;
    rdfs:comment 'Maximum acceptable storage temperature for temperature-controlled inventory. Used to monitor cold chain compliance.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMin rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min' ;
    rdfs:comment 'Minimum acceptable storage temperature for temperature-controlled inventory. Used to monitor cold chain compliance.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureUom rdf:type rdf:Property ;
    rdfs:label 'Temperature Uom' ;
    rdfs:comment 'Unit of measure for temperature range values. Standard units are celsius or fahrenheit.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumePerUnit rdf:type rdf:Property ;
    rdfs:label 'Volume Per Unit' ;
    rdfs:comment 'Physical volume or cubic measurement of a single unit of the SKU. Used for warehouse space planning, slotting optimization, and freight rating.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeUom rdf:type rdf:Property ;
    rdfs:label 'Volume Uom' ;
    rdfs:comment 'Unit of measure for the volume per unit value. Standard units include CBM (cubic meter), CFT (cubic foot), liter, gallon.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightPerUnit rdf:type rdf:Property ;
    rdfs:label 'Weight Per Unit' ;
    rdfs:comment 'Physical weight of a single unit of the SKU. Used for dimensional weight calculations, freight rating, and capacity planning.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightUom rdf:type rdf:Property ;
    rdfs:label 'Weight Uom' ;
    rdfs:comment 'Unit of measure for the weight per unit value. Standard units include kg (kilogram), lb (pound), g (gram), oz (ounce), ton (short ton), mt (metric ton).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationFacilityId rdf:type rdf:Property ;
    rdfs:label 'Destination Facility Id' ;
    rdfs:comment 'Identifier of the receiving warehouse or distribution center where the ASN shipment will arrive.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:forwardingAgentId rdf:type rdf:Property ;
    rdfs:label 'Forwarding Agent Id' ;
    rdfs:comment 'Foreign key linking to network.agent. Business justification: Inbound ASNs in international logistics are coordinated by a freight forwarding agent managing carrier booking, customs clearance, and delivery scheduling to the warehouse. Referencing the agent on th' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:appointmentNumber rdf:type rdf:Property ;
    rdfs:label 'Appointment Number' ;
    rdfs:comment 'Dock appointment or slot reservation number for this ASN. Links to yard management system scheduling.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asnNumber rdf:type rdf:Property ;
    rdfs:label 'Asn Number' ;
    rdfs:comment 'Externally-known unique business identifier for the ASN, typically shared with suppliers and carriers. Used for cross-system tracking and communication.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asnStatus rdf:type rdf:Property ;
    rdfs:label 'Asn Status' ;
    rdfs:comment 'Current lifecycle status of the ASN. Tracks progression from initial notification through final receipt or cancellation.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billOfLadingNumber rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Number' ;
    rdfs:comment 'Master or house bill of lading number associated with this ASN. Links to freight documentation.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Reference Number' ;
    rdfs:comment 'Tracking or reference number assigned by the carrier for this shipment. Used for cross-referencing with carrier systems.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsEntryNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Entry Number' ;
    rdfs:comment 'Customs declaration or entry number for international shipments. Required for cross-border compliance tracking.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockDoorAssignment rdf:type rdf:Property ;
    rdfs:label 'Dock Door Assignment' ;
    rdfs:comment 'Specific receiving dock door assigned for unloading this ASN shipment. Supports yard management and labor dispatch.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTransmissionReference rdf:type rdf:Property ;
    rdfs:label 'Edi Transmission Reference' ;
    rdfs:comment 'Unique identifier for the EDI 856 (ASN) transmission that created this record. Used for EDI audit trail and troubleshooting.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Expected Arrival Date' ;
    rdfs:comment 'Planned date when the shipment is expected to arrive at the destination facility. Used for receiving dock scheduling.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Expected Arrival Time' ;
    rdfs:comment 'Precise timestamp when the shipment is expected to arrive at the destination facility. Enables detailed dock appointment scheduling.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:proNumber rdf:type rdf:Property ;
    rdfs:label 'Pro Number' ;
    rdfs:comment 'Progressive number assigned by LTL carriers for tracking and freight billing. Common in less-than-truckload shipments.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedCartonCount rdf:type rdf:Property ;
    rdfs:label 'Received Carton Count' ;
    rdfs:comment 'Actual number of cartons received and verified at the destination facility. Used for variance analysis against expected count.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receivedPalletCount rdf:type rdf:Property ;
    rdfs:label 'Received Pallet Count' ;
    rdfs:comment 'Actual number of pallets received and verified at the destination facility. Used for variance analysis against expected count.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receivingNotes rdf:type rdf:Property ;
    rdfs:label 'Receiving Notes' ;
    rdfs:comment 'Free-text notes captured by receiving personnel during the unloading and inspection process. Documents exceptions or observations.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipDate rdf:type rdf:Property ;
    rdfs:label 'Ship Date' ;
    rdfs:comment 'Date when the shipment departed from the origin facility or supplier location.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentPriority rdf:type rdf:Property ;
    rdfs:label 'Shipment Priority' ;
    rdfs:comment 'Priority level assigned to this inbound shipment. Determines receiving dock scheduling sequence and resource allocation.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRangeMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max C' ;
    rdfs:comment 'Maximum acceptable temperature in Celsius for temperature-controlled shipments. Used for cold chain compliance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min C' ;
    rdfs:comment 'Minimum acceptable temperature in Celsius for temperature-controlled shipments. Used for cold chain compliance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCartonCount rdf:type rdf:Property ;
    rdfs:label 'Total Carton Count' ;
    rdfs:comment 'Total number of cartons or boxes included in this ASN shipment. Used for receiving verification and labor planning.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalLineCount rdf:type rdf:Property ;
    rdfs:label 'Total Line Count' ;
    rdfs:comment 'Total number of distinct SKU line items included in this ASN. Used for receiving complexity assessment.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPalletCount rdf:type rdf:Property ;
    rdfs:label 'Total Pallet Count' ;
    rdfs:comment 'Total number of pallets included in this ASN shipment. Used for dock space allocation and material handling equipment planning.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Weight Kg' ;
    rdfs:comment 'Total gross weight of the shipment in kilograms. Used for capacity planning and freight cost validation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Variance Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for any discrepancy between expected and received quantities or condition.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asnLineId rdf:type rdf:Property ;
    rdfs:label 'Asn Line Id' ;
    rdfs:comment 'Primary key for asn_line' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AsnLine .

ind:declarationLineId rdf:type rdf:Property ;
    rdfs:label 'Declaration Line Id' ;
    rdfs:comment 'Foreign key linking to customs.declaration_line. Business justification: Import duty reconciliation: each ASN line represents a specific commodity line on the inbound shipment, corresponding directly to a customs declaration line. Linking them enables duty assessment accur' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeclarationLine .

ind:discrepancyNotes rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Notes' ;
    rdfs:comment 'Free-text notes describing the nature of any receiving discrepancy. Provides additional context for exception resolution and claims processing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyReasonCode rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Reason Code' ;
    rdfs:comment 'Code indicating the type of discrepancy between expected and received quantities. Used for root cause analysis and supplier performance tracking.' ;
    rdfs:domain ind:AsnLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Expected Quantity' ;
    rdfs:comment 'The quantity of the SKU expected to be received as declared in the ASN. Used for receiving reconciliation against actual received quantity.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:putawayLocation rdf:type rdf:Property ;
    rdfs:label 'Putaway Location' ;
    rdfs:comment 'Designated storage location (bin, slot, or zone) where the received inventory will be placed. Assigned during receiving or putaway process.' ;
    rdfs:domain ind:AsnLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putawayTimestamp rdf:type rdf:Property ;
    rdfs:label 'Putaway Timestamp' ;
    rdfs:comment 'Date and time when the received inventory was placed into its designated storage location. Marks completion of the inbound process.' ;
    rdfs:domain ind:AsnLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualityInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required' ;
    rdfs:comment 'Boolean flag indicating whether this line item requires quality inspection before putaway. True if inspection is mandatory, False otherwise.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Status' ;
    rdfs:comment 'Current status of quality inspection for this line item. Tracks the inspection lifecycle from pending through final disposition.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Received Quantity' ;
    rdfs:comment 'The actual quantity of the SKU physically received at the warehouse. Used to identify discrepancies against expected quantity.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Max C' ;
    rdfs:comment 'Maximum allowable storage temperature in degrees Celsius for temperature-sensitive products. Used for cold chain compliance monitoring.' ;
    rdfs:domain ind:AsnLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Min C' ;
    rdfs:comment 'Minimum allowable storage temperature in degrees Celsius for temperature-sensitive products. Used for cold chain compliance monitoring.' ;
    rdfs:domain ind:AsnLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'Cost per unit for the SKU on this ASN line. Used for inventory valuation, cost of goods sold (COGS) calculation, and financial reporting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightAuditId rdf:type rdf:Property ;
    rdfs:label 'Freight Audit Id' ;
    rdfs:comment 'Foreign key linking to billing.freight_audit. Business justification: Freight audit 3-way matching requires the inbound receipt to verify carrier-invoiced weight, volume, and delivery date against actual receipt data. Audit teams use this link to identify overbilling va' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightAudit .

ind:rmaId rdf:type rdf:Property ;
    rdfs:label 'Rma Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.rma. Business justification: Returns receiving process: when returned goods arrive at the warehouse, the inbound receipt must reference the authorizing RMA for disposition instructions, refund triggering, and restocking decisions' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rma .

ind:bondedGoodsFlag rdf:type rdf:Property ;
    rdfs:label 'Bonded Goods Flag' ;
    rdfs:comment 'Indicates whether goods are under customs bond and require special handling in bonded warehouse area. Critical for customs compliance.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discrepancyFlag rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Flag' ;
    rdfs:comment 'Indicates whether any variance was detected between expected and actual quantities, quality, or documentation. Triggers exception workflow when true.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discrepancyType rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Type' ;
    rdfs:comment 'Classification of the type of variance or exception identified during receipt. Used for root cause analysis and supplier performance tracking.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockDoorNumber rdf:type rdf:Property ;
    rdfs:label 'Dock Door Number' ;
    rdfs:comment 'Specific dock door or bay assigned for unloading this inbound receipt. Used for resource allocation and tracking.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedCartonsCount rdf:type rdf:Property ;
    rdfs:label 'Expected Cartons Count' ;
    rdfs:comment 'Number of cartons expected based on the ASN or purchase order. Used to calculate receipt variance.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedPalletsCount rdf:type rdf:Property ;
    rdfs:label 'Expected Pallets Count' ;
    rdfs:comment 'Number of pallets expected based on the ASN or purchase order. Used to calculate receipt variance.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:goodsReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Number' ;
    rdfs:comment 'ERP system goods receipt document number generated upon receipt completion. Links warehouse receipt to financial inventory posting.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putawayPriority rdf:type rdf:Property ;
    rdfs:label 'Putaway Priority' ;
    rdfs:comment 'Priority level assigned for moving received goods from dock to storage location. Determines task sequencing in warehouse operations.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required Flag' ;
    rdfs:comment 'Indicates whether goods require quality inspection before putaway. Determined by product type, supplier rating, or regulatory requirements.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receiptCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Completed Timestamp' ;
    rdfs:comment 'Date and time when the entire receipt process was finalized, including quality checks and system confirmation. Marks the official completion of the receipt transaction.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receiptNumber rdf:type rdf:Property ;
    rdfs:label 'Receipt Number' ;
    rdfs:comment 'Externally-known unique business identifier for the inbound receipt transaction. Used for tracking and reference across systems and with external parties.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptStatus rdf:type rdf:Property ;
    rdfs:label 'Receipt Status' ;
    rdfs:comment 'Current lifecycle status of the inbound receipt process. Tracks progression from scheduled arrival through completion or exception handling.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptType rdf:type rdf:Property ;
    rdfs:label 'Receipt Type' ;
    rdfs:comment 'Classification of the receipt transaction based on the source and purpose of the inbound goods.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sealIntactFlag rdf:type rdf:Property ;
    rdfs:label 'Seal Intact Flag' ;
    rdfs:comment 'Indicates whether the security seal was found intact upon arrival. False value triggers security investigation.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Compliant Flag' ;
    rdfs:comment 'Indicates whether temperature-sensitive goods were received within required temperature range. Critical for cold chain compliance.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureRecordedC rdf:type rdf:Property ;
    rdfs:label 'Temperature Recorded C' ;
    rdfs:comment 'Actual temperature recorded at time of receipt for temperature-controlled shipments. Used for cold chain validation.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCartonsReceived rdf:type rdf:Property ;
    rdfs:label 'Total Cartons Received' ;
    rdfs:comment 'Total number of cartons or cases physically received in this inbound receipt. Used for variance analysis against ASN.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPalletsReceived rdf:type rdf:Property ;
    rdfs:label 'Total Pallets Received' ;
    rdfs:comment 'Total number of pallets or handling units physically received. Used for space planning and material handling resource allocation.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unloadingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Unloading End Timestamp' ;
    rdfs:comment 'Date and time when physical unloading of goods was completed. Used to calculate unloading duration and dock turnaround time.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:unloadingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Unloading Start Timestamp' ;
    rdfs:comment 'Date and time when physical unloading of goods from the vehicle began. Used for labor productivity and dock utilization analysis.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inboundReceiptLineId rdf:type rdf:Property ;
    rdfs:label 'Inbound Receipt Line Id' ;
    rdfs:comment 'Unique identifier for the inbound receipt line record. Primary key for this entity.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundReceiptLine .

ind:primaryInboundStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Inbound Storage Location Id' ;
    rdfs:comment 'Reference to the warehouse location where the received goods were stored. Final storage location after putaway completion.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:conditionCode rdf:type rdf:Property ;
    rdfs:label 'Condition Code' ;
    rdfs:comment 'Condition classification of the received inventory. Determines storage location, availability for picking, and valuation. NEW=new goods, USED=returned/used items, REFURBISHED=reconditioned goods, DAMAGED=damaged goods, EXPIRED=past expiry date, QUARANTINE=held for inspection.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Timestamp' ;
    rdfs:comment 'Date and time when quality inspection was completed for this receipt line. Used for cycle time analysis and compliance reporting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lpnNumber rdf:type rdf:Property ;
    rdfs:label 'Lpn Number' ;
    rdfs:comment 'License Plate Number assigned to the physical container or pallet holding the received goods. Used for tracking and putaway task assignment.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putawayCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Putaway Completed Timestamp' ;
    rdfs:comment 'Date and time when putaway was completed and goods were stored in their final warehouse location. Marks inventory availability for picking.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:putawayStatus rdf:type rdf:Property ;
    rdfs:label 'Putaway Status' ;
    rdfs:comment 'Status of the putaway process for this receipt line. NOT_STARTED=received but not yet assigned to putaway task, IN_PROGRESS=putaway task active, COMPLETED=goods stored in final location, EXCEPTION=putaway blocked or failed.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Rejected Quantity' ;
    rdfs:comment 'Quantity of the SKU rejected during receiving inspection due to quality issues, incorrect item, or other non-conformance. Not accepted into inventory.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCost rdf:type rdf:Property ;
    rdfs:label 'Total Cost' ;
    rdfs:comment 'Total cost for this receipt line (received quantity multiplied by unit cost). Used for financial accrual and inventory valuation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'Difference between expected and received quantities (received minus expected). Positive indicates over-receipt, negative indicates short-receipt.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volume rdf:type rdf:Property ;
    rdfs:label 'Volume' ;
    rdfs:comment 'Total volume or cubic measurement of the goods received on this line. Used for warehouse space planning and slotting optimization.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weight rdf:type rdf:Property ;
    rdfs:label 'Weight' ;
    rdfs:comment 'Total weight of the goods received on this line. Used for freight reconciliation, capacity planning, and handling equipment selection.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:putawayTaskId rdf:type rdf:Property ;
    rdfs:label 'Putaway Task Id' ;
    rdfs:comment 'Unique identifier for the putaway task. Primary key.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PutawayTask .

ind:destinationLocationStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Storage Location Id' ;
    rdfs:comment 'Identifier of the storage location (bin, slot, pallet position) where the goods must be placed. Determined by slotting optimization rules.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:primaryPutawayStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Putaway Storage Location Id' ;
    rdfs:comment 'Identifier of the staging or receiving location where the goods are currently located and must be picked up from.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:assignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assigned Timestamp' ;
    rdfs:comment 'Date and time when the task was assigned to a warehouse operative. Used to measure task allocation latency.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'Date and time when the task was cancelled, if applicable. Cancellation may occur due to inventory discrepancies, damage, or process exceptions.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'Total elapsed time from task start to completion, in seconds. Key metric for labor productivity analysis and engineered labor standards validation.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:equipmentTypeRequired rdf:type rdf:Property ;
    rdfs:label 'Equipment Type Required' ;
    rdfs:comment 'Type of material handling equipment required to execute this putaway task, based on weight, height, and location characteristics.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionNotes rdf:type rdf:Property ;
    rdfs:label 'Exception Notes' ;
    rdfs:comment 'Free-text notes entered by the operative or supervisor describing any exception, issue, or special handling during task execution.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fifoDate rdf:type rdf:Property ;
    rdfs:label 'Fifo Date' ;
    rdfs:comment 'Date used for FIFO inventory rotation logic. Typically the receipt date or production date. Ensures oldest inventory is picked first.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'User ID or system process that last modified the task record. Used for audit trail and accountability.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerType rdf:type rdf:Property ;
    rdfs:label 'Owner Type' ;
    rdfs:comment 'Classification of inventory ownership: own_stock (company-owned), customer_stock (3PL client inventory), consignment (supplier-owned), vendor_managed (VMI program).' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCheckRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Check Required' ;
    rdfs:comment 'Indicates whether a quality inspection or verification step is required before or after putaway, based on SKU classification or customer requirements.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Check Status' ;
    rdfs:comment 'Status of the quality inspection: not_required (no check needed), pending (awaiting inspection), passed (approved for storage), failed (rejected, requires disposition).' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentTriggerFlag rdf:type rdf:Property ;
    rdfs:label 'Replenishment Trigger Flag' ;
    rdfs:comment 'Indicates whether completion of this putaway task will trigger an automatic replenishment task to move goods from reserve to forward pick locations.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Standard Time Seconds' ;
    rdfs:comment 'Engineered labor standard time for this task type and distance, in seconds. Used to calculate labor productivity percentage (actual vs. standard).' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:startedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Started Timestamp' ;
    rdfs:comment 'Date and time when the operative began executing the task (scanned source location or handling unit). Marks transition to in_progress status.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:systemDirectedFlag rdf:type rdf:Property ;
    rdfs:label 'System Directed Flag' ;
    rdfs:comment 'Indicates whether the destination location was system-directed by slotting optimization algorithms (true) or manually specified by a user (false).' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taskNumber rdf:type rdf:Property ;
    rdfs:label 'Task Number' ;
    rdfs:comment 'Externally visible business identifier for the putaway task, generated by Manhattan WMS. Used for tracking and operator reference.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskStatus rdf:type rdf:Property ;
    rdfs:label 'Task Status' ;
    rdfs:comment 'Current lifecycle status of the putaway task: open (created, awaiting assignment), assigned (allocated to operative), in_progress (operative has started), completed (goods placed in destination), cancelled (task voided), suspended (temporarily paused).' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskType rdf:type rdf:Property ;
    rdfs:label 'Task Type' ;
    rdfs:comment 'Classification of the putaway task based on the destination and handling strategy: standard (normal putaway to reserve), cross-dock (direct to outbound), replenishment (to forward pick location), bulk (large quantity), directed (system-optimized), reserve (long-term storage), forward_pick (active pick face). [ENUM-REF-CANDIDATE: standard|cross_dock|replenishment|bulk|directed|reserve|forward_pick — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureZone rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone' ;
    rdfs:comment 'Required temperature control zone for storage: ambient (room temperature), chilled (2-8°C), frozen (<-18°C), controlled (specific range). Ensures cold chain integrity.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelDistanceMeters rdf:type rdf:Property ;
    rdfs:label 'Travel Distance Meters' ;
    rdfs:comment 'Calculated or actual travel distance from source to destination location, in meters. Used for slotting optimization and labor standards.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Timestamp' ;
    rdfs:comment 'Actual date and time when all picking and packing activities for this wave were completed. Used to calculate wave cycle time and On-Time In-Full (OTIF) performance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Release Timestamp' ;
    rdfs:comment 'Actual date and time when the wave was released to pickers. Used to measure schedule adherence and identify release delays.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cancellationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Code' ;
    rdfs:comment 'Code indicating the reason for wave cancellation if wave status is cancelled. Used for root cause analysis and process improvement.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierServiceType rdf:type rdf:Property ;
    rdfs:label 'Carrier Service Type' ;
    rdfs:comment 'Primary carrier service level for orders in this wave (e.g., express, standard, economy). Used for wave grouping and Service Level Agreement (SLA) management.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Customer Segment Code' ;
    rdfs:comment 'Customer segment classification for orders in this wave (e.g., retail, wholesale, e-commerce, Third-Party Logistics (3PL) client). Used for prioritization and Service Level Agreement (SLA) differentiation.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHighValue rdf:type rdf:Property ;
    rdfs:label 'Is High Value' ;
    rdfs:comment 'Indicates whether this wave contains high-value goods requiring enhanced security measures, additional insurance, or special handling procedures.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborHoursActual rdf:type rdf:Property ;
    rdfs:label 'Labor Hours Actual' ;
    rdfs:comment 'Actual total labor hours consumed to complete picking and packing for this wave. Used for productivity analysis and labor cost calculation.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborHoursPlanned rdf:type rdf:Property ;
    rdfs:label 'Labor Hours Planned' ;
    rdfs:comment 'Estimated total labor hours required to complete picking and packing for this wave. Used for workforce planning and scheduling.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Packing End Timestamp' ;
    rdfs:comment 'Date and time when the last packing task for this wave was completed. Marks readiness for outbound dispatch.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Packing Start Timestamp' ;
    rdfs:comment 'Date and time when the first packing task for this wave was started. Marks the beginning of the packing phase.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packingStationCount rdf:type rdf:Property ;
    rdfs:label 'Packing Station Count' ;
    rdfs:comment 'Number of packing stations allocated to process orders from this wave. Used for packing capacity planning.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pickAccuracyPercentage rdf:type rdf:Property ;
    rdfs:label 'Pick Accuracy Percentage' ;
    rdfs:comment 'Percentage of pick tasks completed without errors (correct Stock Keeping Unit (SKU), correct quantity, correct location). Key Performance Indicator (KPI) for picking quality.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickerCount rdf:type rdf:Property ;
    rdfs:label 'Picker Count' ;
    rdfs:comment 'Number of warehouse pickers assigned to execute this wave. Used for labor planning and productivity measurement.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pickingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Picking End Timestamp' ;
    rdfs:comment 'Date and time when the last pick task in this wave was completed. Marks the end of picking phase before packing begins.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Picking Start Timestamp' ;
    rdfs:comment 'Date and time when the first pick task in this wave was started by a picker. Marks the beginning of active picking operations.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Completion Timestamp' ;
    rdfs:comment 'Target date and time for completing all picking and packing activities for this wave. Used for capacity planning and Service Level Agreement (SLA) management.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Release Timestamp' ;
    rdfs:comment 'Scheduled date and time when the wave is planned to be released to the warehouse floor for picking execution.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shortPickCount rdf:type rdf:Property ;
    rdfs:label 'Short Pick Count' ;
    rdfs:comment 'Number of order lines that could not be fully picked due to insufficient inventory. Indicates inventory accuracy issues or stock-outs.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaCutoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Cutoff Timestamp' ;
    rdfs:comment 'Latest date and time by which this wave must be completed to meet Service Level Agreement (SLA) commitments for included orders. Used for On-Time Delivery (OTD) tracking.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalOrderCount rdf:type rdf:Property ;
    rdfs:label 'Total Order Count' ;
    rdfs:comment 'Total number of distinct outbound orders included in this pick wave. Used for wave sizing and throughput analysis.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalUnitCount rdf:type rdf:Property ;
    rdfs:label 'Total Unit Count' ;
    rdfs:comment 'Total number of individual units (eaches) to be picked across all orders in this wave. Represents total picking volume.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waveAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Wave Allocation Method' ;
    rdfs:comment 'Inventory allocation strategy used for this wave. First In First Out (FIFO): oldest stock first. Last In First Out (LIFO): newest stock first. First Expired First Out (FEFO): shortest shelf-life first. Nearest Location: minimize travel distance. Optimal Path: system-optimized routing.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waveNotes rdf:type rdf:Property ;
    rdfs:label 'Wave Notes' ;
    rdfs:comment 'Free-text operational notes or special instructions for this wave. Used for communicating exceptions, special handling requirements, or coordination messages.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waveNumber rdf:type rdf:Property ;
    rdfs:label 'Wave Number' ;
    rdfs:comment 'Business-facing unique wave identifier assigned by the Warehouse Management System (WMS). Used for operational tracking and communication.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waveStatus rdf:type rdf:Property ;
    rdfs:label 'Wave Status' ;
    rdfs:comment 'Current lifecycle status of the pick wave. Tracks progression from planning through completion or cancellation. [ENUM-REF-CANDIDATE: planned|released|in_progress|picking_complete|packing_in_progress|completed|cancelled|on_hold — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waveTemplateCode rdf:type rdf:Property ;
    rdfs:label 'Wave Template Code' ;
    rdfs:comment 'Code identifying the wave template or configuration profile used to generate this wave. Templates define picking rules, zone assignments, and resource allocation strategies.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waveType rdf:type rdf:Property ;
    rdfs:label 'Wave Type' ;
    rdfs:comment 'Classification of the picking strategy used for this wave. Single-order: one order per picker. Multi-order: multiple orders picked simultaneously. Zone: picking confined to specific warehouse zones. Cluster: multiple orders picked into separate containers. Batch: orders grouped by similar characteristics. Wave: large-scale coordinated release.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickTaskId rdf:type rdf:Property ;
    rdfs:label 'Pick Task Id' ;
    rdfs:comment 'Primary key for pick_task' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PickTask .

ind:aisleCode rdf:type rdf:Property ;
    rdfs:label 'Aisle Code' ;
    rdfs:comment 'The aisle identifier within the warehouse where the source location is situated. Supports travel distance calculation and slotting analysis.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Order Number' ;
    rdfs:comment 'The customer-facing order number associated with this pick task. Provides traceability from warehouse execution back to customer order.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickMethod rdf:type rdf:Property ;
    rdfs:label 'Pick Method' ;
    rdfs:comment 'Technology or process method used to execute the pick task. Determines equipment requirements and productivity benchmarks.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Pick Sequence Number' ;
    rdfs:comment 'The sequence order of this task within the assigned pick wave or batch. Optimizes travel path and minimizes operative movement.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pickedQuantity rdf:type rdf:Property ;
    rdfs:label 'Picked Quantity' ;
    rdfs:comment 'The actual quantity of the SKU that the operative successfully picked and confirmed. Used to calculate fill rate and order completeness.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Hold Flag' ;
    rdfs:comment 'Indicates whether the picked inventory is subject to a quality hold pending inspection or release. True if on quality hold.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:replenishmentTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Replenishment Triggered Flag' ;
    rdfs:comment 'Indicates whether this pick task triggered an automatic replenishment task to refill the source location from reserve storage. True if replenishment was triggered.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestedQuantity rdf:type rdf:Property ;
    rdfs:label 'Requested Quantity' ;
    rdfs:comment 'The quantity of the SKU that the operative is instructed to pick, as determined by the order line requirement.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shortPickQuantity rdf:type rdf:Property ;
    rdfs:label 'Short Pick Quantity' ;
    rdfs:comment 'The quantity shortfall when the operative cannot fulfill the full requested quantity due to inventory discrepancy, damage, or location error.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shortPickReasonCode rdf:type rdf:Property ;
    rdfs:label 'Short Pick Reason Code' ;
    rdfs:comment 'Standardized code indicating why the operative could not fulfill the full requested quantity. Drives root cause analysis and inventory accuracy improvement.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'The date and time when the operative began executing the pick task, typically captured via RF scan or voice confirmation.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Task Duration Seconds' ;
    rdfs:comment 'The elapsed time in seconds from task start to completion. Key metric for labor productivity analysis and engineered labor standards.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taskPriority rdf:type rdf:Property ;
    rdfs:label 'Task Priority' ;
    rdfs:comment 'Priority level assigned to the pick task, determining execution sequence. Urgent tasks support expedited shipments and SLA commitments.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'The method used to verify the accuracy of the pick before task completion. Ensures order accuracy and reduces mis-picks.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Verification Required Flag' ;
    rdfs:comment 'Indicates whether this pick task requires additional verification (e.g., weight check, barcode scan, supervisor approval) before completion. True if verification is required.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumePickedCbm rdf:type rdf:Property ;
    rdfs:label 'Volume Picked Cbm' ;
    rdfs:comment 'The total volume in cubic meters of the picked quantity. Used for space utilization analysis and container load optimization.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightPickedKg rdf:type rdf:Property ;
    rdfs:label 'Weight Picked Kg' ;
    rdfs:comment 'The total weight in kilograms of the picked quantity. Used for load planning, freight calculation, and weight verification.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packOrderId rdf:type rdf:Property ;
    rdfs:label 'Pack Order Id' ;
    rdfs:comment 'Unique identifier for the pack order. Primary key.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackOrder .

ind:cartonCount rdf:type rdf:Property ;
    rdfs:label 'Carton Count' ;
    rdfs:comment 'Total number of cartons or boxes packed for this order. Used for shipment planning and carrier manifesting.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dimensionalWeightKg rdf:type rdf:Property ;
    rdfs:label 'Dimensional Weight Kg' ;
    rdfs:comment 'Calculated dimensional weight based on volumetric measurement, used by carriers to determine billable weight when volume exceeds actual weight.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dispatchActualTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispatch Actual Timestamp' ;
    rdfs:comment 'Actual timestamp when the packed order was dispatched from the warehouse. Used for On-Time Delivery (OTD) and On-Time In-Full (OTIF) performance tracking.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispatchScheduledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispatch Scheduled Timestamp' ;
    rdfs:comment 'Scheduled timestamp for outbound dispatch of the packed order. Used for dock scheduling and carrier pickup coordination.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:labelGeneratedFlag rdf:type rdf:Property ;
    rdfs:label 'Label Generated Flag' ;
    rdfs:comment 'Indicates whether shipping labels have been generated for this pack order. Label generation is triggered upon pack completion.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelGenerationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Label Generation Timestamp' ;
    rdfs:comment 'Timestamp when shipping labels were generated for the packed cartons or pallets.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Completion Timestamp' ;
    rdfs:comment 'Timestamp when packing was completed and the order was ready for outbound dispatch. Triggers label generation and carrier manifesting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Pack Duration Minutes' ;
    rdfs:comment 'Total time in minutes taken to complete the packing operation, calculated as the difference between start and completion timestamps. Key performance indicator (KPI) for labor efficiency.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packMethodCode rdf:type rdf:Property ;
    rdfs:label 'Pack Method Code' ;
    rdfs:comment 'Packing methodology applied based on order characteristics: single-item for individual SKUs, multi-item for consolidated cartons, bulk for large quantities, pallet for palletized loads, mixed for heterogeneous packaging.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Pack Order Number' ;
    rdfs:comment 'Human-readable business identifier for the pack order, typically displayed on packing station screens and printed on labels.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packPriorityCode rdf:type rdf:Property ;
    rdfs:label 'Pack Priority Code' ;
    rdfs:comment 'Priority level assigned to the pack order, determining sequence in the packing queue. Urgent orders are typically express shipments or SLA-critical.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Start Timestamp' ;
    rdfs:comment 'Timestamp when the operative began packing this order. Used for labor productivity analysis and cycle time measurement.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packStatus rdf:type rdf:Property ;
    rdfs:label 'Pack Status' ;
    rdfs:comment 'Current lifecycle status of the pack order in the packing workflow.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingCostAmount rdf:type rdf:Property ;
    rdfs:label 'Packaging Cost Amount' ;
    rdfs:comment 'Total cost of packaging materials consumed for this pack order, used for cost center accounting and profitability analysis.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packingExceptionCode rdf:type rdf:Property ;
    rdfs:label 'Packing Exception Code' ;
    rdfs:comment 'Code indicating any exception or issue encountered during packing (e.g., short pick from upstream, damaged item discovered, packaging material shortage, equipment malfunction).' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingInstructions rdf:type rdf:Property ;
    rdfs:label 'Packing Instructions' ;
    rdfs:comment 'Free-text field capturing specific packing instructions from the customer or order management system, such as gift wrapping, custom labeling, or assembly requirements.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingZoneCode rdf:type rdf:Property ;
    rdfs:label 'Packing Zone Code' ;
    rdfs:comment 'Code identifying the packing zone or area within the warehouse where the station is located, used for labor allocation and workflow optimization.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:palletCount rdf:type rdf:Property ;
    rdfs:label 'Pallet Count' ;
    rdfs:comment 'Total number of pallets used for this pack order. Relevant for Full Truckload (FTL) and Less Than Truckload (LTL) shipments.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetTemperatureRangeC rdf:type rdf:Property ;
    rdfs:label 'Target Temperature Range C' ;
    rdfs:comment 'Required temperature range in Celsius for cold chain shipments (e.g., \'2 to 8\' for vaccines, \'-18 to -22\' for frozen goods).' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Control Required Flag' ;
    rdfs:comment 'Indicates whether the packed order requires temperature-controlled handling (cold chain for pharmaceuticals, perishables, or temperature-sensitive goods).' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalItemQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Item Quantity' ;
    rdfs:comment 'Total quantity of individual Stock Keeping Units (SKUs) packed in this order, summed across all cartons and pallets.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPackedVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Total Packed Volume Cbm' ;
    rdfs:comment 'Total volumetric measurement of all packed units in cubic meters (CBM). Critical for dimensional weight (DIM weight) calculation and load optimization.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPackedWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Packed Weight Kg' ;
    rdfs:comment 'Total gross weight of all packed cartons and pallets in kilograms, including packaging materials. Used for freight rating and carrier selection.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSkuCount rdf:type rdf:Property ;
    rdfs:label 'Total Sku Count' ;
    rdfs:comment 'Total number of distinct SKUs included in this pack order. Used for complexity analysis and packing time estimation.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verification Timestamp' ;
    rdfs:comment 'Timestamp when quality verification was completed. Null if verification was not required or not yet performed.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:certificateOfOriginId rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Origin Id' ;
    rdfs:comment 'Foreign key linking to customs.certificate_of_origin. Business justification: Export orders claiming preferential tariff treatment under trade agreements require certificates of origin. Links shipment to COO document for USMCA/FTA compliance, preferential duty eligibility, and ' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CertificateOfOrigin .

ind:dimWeightRuleId rdf:type rdf:Property ;
    rdfs:label 'Dim Weight Rule Id' ;
    rdfs:comment 'Foreign key linking to pricing.dim_weight_rule. Business justification: The dim weight rule determines chargeable weight for outbound shipments, directly setting the freight charge. Billing auditors and dispute resolution teams require this link to verify which divisor wa' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DimWeightRule .

ind:performanceObligationId rdf:type rdf:Property ;
    rdfs:label 'Performance Obligation Id' ;
    rdfs:comment 'Foreign key linking to billing.performance_obligation. Business justification: ASC 606/IFRS 15 revenue recognition: each outbound shipment order fulfills a specific performance obligation under a customer contract. Finance teams require this link to trigger revenue recognition u' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformanceObligation .

ind:allocatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Allocated Timestamp' ;
    rdfs:comment 'Date and time when inventory was successfully allocated to this outbound shipment order in the warehouse management system.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:codAmount rdf:type rdf:Property ;
    rdfs:label 'Cod Amount' ;
    rdfs:comment 'Cash on delivery amount to be collected from the consignee upon delivery, if applicable.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:codCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cod Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the COD amount.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Reference Number' ;
    rdfs:comment 'External reference number or purchase order number provided by the customer for tracking and reconciliation purposes.' ;
    rdfs:domain ind:OutboundShipmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Destination Address Line1' ;
    rdfs:comment 'Primary street address line for the shipment destination.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Destination Address Line2' ;
    rdfs:comment 'Secondary address line for the shipment destination (suite, apartment, building, etc.).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCity rdf:type rdf:Property ;
    rdfs:label 'Destination City' ;
    rdfs:comment 'City name for the shipment destination address.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPostalCode rdf:type rdf:Property ;
    rdfs:label 'Destination Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the shipment destination address.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationStateProvince rdf:type rdf:Property ;
    rdfs:label 'Destination State Province' ;
    rdfs:comment 'State, province, or region code for the shipment destination address.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispatched Timestamp' ;
    rdfs:comment 'Date and time when the outbound shipment order was handed over to the carrier and departed the warehouse facility.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:giftMessage rdf:type rdf:Property ;
    rdfs:label 'Gift Message' ;
    rdfs:comment 'Optional gift message provided by the customer to be included with the shipment, common in B2C e-commerce orders.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderReceivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Received Timestamp' ;
    rdfs:comment 'Date and time when the outbound shipment order was received by the warehouse management system from the upstream order management or ERP system.' ;
    rdfs:domain ind:OutboundShipmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of the outbound order by business purpose: B2C e-commerce fulfillment, B2B freight shipment, inter-facility transfer, RMA (Return Merchandise Authorization) return, replenishment order, or cross-dock operation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otdFlag rdf:type rdf:Property ;
    rdfs:label 'Otd Flag' ;
    rdfs:comment 'Boolean indicator of whether the order was dispatched on or before the requested ship date, meeting the on-time delivery commitment.' ;
    rdfs:domain ind:OutboundShipmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Packed Timestamp' ;
    rdfs:comment 'Date and time when the order was fully packed and prepared for dispatch.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Picked Timestamp' ;
    rdfs:comment 'Date and time when all order lines were successfully picked from warehouse inventory locations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestedShipDate rdf:type rdf:Property ;
    rdfs:label 'Requested Ship Date' ;
    rdfs:comment 'Date by which the customer has requested the order to be shipped from the warehouse.' ;
    rdfs:domain ind:OutboundShipmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocatedQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocated Quantity' ;
    rdfs:comment 'The quantity of inventory allocated or reserved for this order line. Represents inventory commitment prior to physical picking.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerItemReference rdf:type rdf:Property ;
    rdfs:label 'Customer Item Reference' ;
    rdfs:comment 'Customer\'s own SKU or item reference number. Used for cross-referencing in e-commerce fulfillment and contract logistics scenarios.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Line Total Amount' ;
    rdfs:comment 'Total monetary value for this order line, calculated as shipped quantity multiplied by unit price. Used for financial reporting and invoicing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'The quantity of the SKU originally ordered by the customer or requested for fulfillment. Represents the target fulfillment quantity.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Flag' ;
    rdfs:comment 'Indicates whether this line was fulfilled on-time and in-full per customer SLA. Key performance indicator for warehouse and fulfillment operations.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packStation rdf:type rdf:Property ;
    rdfs:label 'Pack Station' ;
    rdfs:comment 'Packing station identifier where the item was packed. Used for labor productivity tracking and quality control.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packedQuantity rdf:type rdf:Property ;
    rdfs:label 'Packed Quantity' ;
    rdfs:comment 'The quantity packed into shipping containers or cartons. Represents items prepared for outbound dispatch.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickLocation rdf:type rdf:Property ;
    rdfs:label 'Pick Location' ;
    rdfs:comment 'Warehouse location code where the item was picked from. Supports slotting optimization and pick path analysis.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnReasonCode rdf:type rdf:Property ;
    rdfs:label 'Return Reason Code' ;
    rdfs:comment 'Reason code if this line item was returned or rejected. Supports RMA (Return Merchandise Authorization) processing and quality analysis.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippedQuantity rdf:type rdf:Property ;
    rdfs:label 'Shipped Quantity' ;
    rdfs:comment 'The quantity actually shipped to the customer or consignee. Represents final fulfilled quantity that left the warehouse.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shippedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Shipped Timestamp' ;
    rdfs:comment 'Date and time when the line item left the warehouse facility. Marks completion of warehouse fulfillment and start of carrier transit.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shortShipQuantity rdf:type rdf:Property ;
    rdfs:label 'Short Ship Quantity' ;
    rdfs:comment 'The quantity not fulfilled due to inventory shortage, damage, or other constraints. Calculated as ordered quantity minus shipped quantity.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'Price per unit of the SKU for this order line. Used for order valuation, invoicing, and revenue recognition. Currency is defined at order header level.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryMovementId rdf:type rdf:Property ;
    rdfs:label 'Inventory Movement Id' ;
    rdfs:comment 'Unique identifier for the inventory movement transaction. Primary key for atomic inventory transaction records.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryMovement .

ind:reversedMovementInventoryMovementId rdf:type rdf:Property ;
    rdfs:label 'Reversed Movement Inventory Movement Id' ;
    rdfs:comment 'Reference to the original inventory movement transaction that this record reverses. Null if this is not a reversal transaction.' ;
    rdfs:domain ind:InventoryMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryMovement .

ind:bondedStatus rdf:type rdf:Property ;
    rdfs:label 'Bonded Status' ;
    rdfs:comment 'Customs bonded warehouse status of the inventory. Indicates whether goods are held in a Free Trade Zone (FTZ) or bonded warehouse pending customs clearance.' ;
    rdfs:domain ind:InventoryMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fromLocationCode rdf:type rdf:Property ;
    rdfs:label 'From Location Code' ;
    rdfs:comment 'Source warehouse location code from which inventory is being moved. Null for receipt transactions. Supports multi-level location hierarchy (zone-aisle-bay-level-position).' ;
    rdfs:domain ind:InventoryMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementNumber rdf:type rdf:Property ;
    rdfs:label 'Movement Number' ;
    rdfs:comment 'Externally-visible business identifier for the inventory movement transaction. Used for audit trail and cross-system reconciliation.' ;
    rdfs:domain ind:InventoryMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementStatus rdf:type rdf:Property ;
    rdfs:label 'Movement Status' ;
    rdfs:comment 'Current lifecycle status of the inventory movement transaction. Tracks progression from initiation through completion or cancellation.' ;
    rdfs:domain ind:InventoryMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Movement Timestamp' ;
    rdfs:comment 'Date and time when the physical inventory movement occurred. Principal business event timestamp for FIFO/LIFO position calculation and audit trail.' ;
    rdfs:domain ind:InventoryMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'Classification of the inventory movement transaction. Defines the nature of the stock movement within or between warehouse locations. [ENUM-REF-CANDIDATE: receipt|putaway|pick|replenishment|transfer|adjustment|cycle_count|damage_writeoff|return|consolidation|deconsolidation — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InventoryMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectCode rdf:type rdf:Property ;
    rdfs:label 'Project Code' ;
    rdfs:comment 'Identifier of the project or contract logistics engagement associated with this inventory. Used for project-based inventory segregation and billing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityMoved rdf:type rdf:Property ;
    rdfs:label 'Quantity Moved' ;
    rdfs:comment 'Quantity of inventory units moved in this transaction. Positive for additions, negative for reductions. Supports fractional quantities for catch-weight items.' ;
    rdfs:domain ind:InventoryMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Standardized code explaining the business reason for the movement. Required for adjustments, write-offs, and exception transactions.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'Business identifier of the source document that triggered this movement (ASN number, PO number, sales order number, etc.). Enables cross-system reconciliation.' ;
    rdfs:domain ind:InventoryMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Reference Document Type' ;
    rdfs:comment 'Type of source document that triggered or authorized this inventory movement. Provides audit trail linkage to originating business transaction. [ENUM-REF-CANDIDATE: asn|purchase_order|sales_order|transfer_order|work_order|cycle_count|adjustment_request — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InventoryMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceLineNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Line Number' ;
    rdfs:comment 'Line item number within the reference document. Links movement to specific order line or ASN line for detailed reconciliation.' ;
    rdfs:domain ind:InventoryMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this movement is a reversal or correction of a previous transaction. Used for audit trail and inventory reconciliation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:toLocationCode rdf:type rdf:Property ;
    rdfs:label 'To Location Code' ;
    rdfs:comment 'Destination warehouse location code to which inventory is being moved. Null for shipment/dispatch transactions. Supports multi-level location hierarchy (zone-aisle-bay-level-position).' ;
    rdfs:domain ind:InventoryMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCountId rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Id' ;
    rdfs:comment 'Unique identifier for the cycle count event. Primary key.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CycleCount .

ind:accuracyPercentage rdf:type rdf:Property ;
    rdfs:label 'Accuracy Percentage' ;
    rdfs:comment 'Inventory accuracy percentage for this count event. Calculated as (locations with zero variance / total locations counted) * 100. Key performance indicator for warehouse operations.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentPosted rdf:type rdf:Property ;
    rdfs:label 'Adjustment Posted' ;
    rdfs:comment 'Indicates whether inventory adjustments resulting from count variances have been posted to the WMS and financial systems.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adjustmentPostedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Adjustment Posted Timestamp' ;
    rdfs:comment 'Date and time when inventory adjustments were posted to the system. Used for financial reconciliation and audit trail.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:aisleRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Aisle Range End' ;
    rdfs:comment 'Ending aisle identifier for the count scope. Used to define physical location boundaries.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aisleRangeStart rdf:type rdf:Property ;
    rdfs:label 'Aisle Range Start' ;
    rdfs:comment 'Starting aisle identifier for the count scope. Used to define physical location boundaries.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when the cycle count results were approved by the authorized approver.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'Name of the warehouse manager or supervisor who approved the cycle count results and variances.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count End Timestamp' ;
    rdfs:comment 'Actual date and time when the physical count activity was completed. Marks the end of the count execution window.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countMethod rdf:type rdf:Property ;
    rdfs:label 'Count Method' ;
    rdfs:comment 'Method used to perform the physical count. Manual = paper-based or visual; RFID = radio frequency identification; Barcode Scan = handheld scanner; Automated = robotic or sensor-based.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countProgramCode rdf:type rdf:Property ;
    rdfs:label 'Count Program Code' ;
    rdfs:comment 'Business identifier for the cycle count program or event. Externally-known code used for tracking and reporting.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countProgramName rdf:type rdf:Property ;
    rdfs:label 'Count Program Name' ;
    rdfs:comment 'Human-readable name of the cycle count program or event.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countReason rdf:type rdf:Property ;
    rdfs:label 'Count Reason' ;
    rdfs:comment 'Business reason or trigger for the cycle count. Examples: scheduled rotation, exception investigation, audit requirement, pre-physical inventory, post-receiving verification.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count Start Timestamp' ;
    rdfs:comment 'Actual date and time when the physical count activity began. Marks the beginning of the count execution window.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countStatus rdf:type rdf:Property ;
    rdfs:label 'Count Status' ;
    rdfs:comment 'Current lifecycle status of the cycle count event. Scheduled = planned but not started; In-Progress = counting underway; Completed = count finished awaiting approval; Approved = variances reviewed and accepted; Cancelled = count aborted; On-Hold = temporarily suspended.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countType rdf:type rdf:Property ;
    rdfs:label 'Count Type' ;
    rdfs:comment 'Classification of the count event. Full = complete facility inventory; Cycle = scheduled rotating count; Spot = ad-hoc targeted count; ABC-Velocity = frequency-based on SKU velocity; Blind = count without system quantity reference; Location-Directed = system-assigned location count.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fifoLifoMethod rdf:type rdf:Property ;
    rdfs:label 'Fifo Lifo Method' ;
    rdfs:comment 'Inventory valuation method applied during count variance adjustment. FIFO = First In First Out; LIFO = Last In First Out; FEFO = First Expired First Out; Not Applicable = no specific method.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatCountFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Count Flag' ;
    rdfs:comment 'Indicates whether this cycle count includes hazardous materials requiring special handling and compliance procedures.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recountCount rdf:type rdf:Property ;
    rdfs:label 'Recount Count' ;
    rdfs:comment 'Number of times this cycle count has been recounted. Used to track count quality and identify problematic locations or SKUs.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recountRequired rdf:type rdf:Property ;
    rdfs:label 'Recount Required' ;
    rdfs:comment 'Indicates whether a recount is required due to significant variances or count discrepancies exceeding tolerance thresholds.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryAuditFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Audit Flag' ;
    rdfs:comment 'Indicates whether this cycle count is part of a regulatory audit or compliance requirement (e.g., customs bonded warehouse audit, ISO certification audit).' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'Planned date for the cycle count event to be executed. Used for count program planning and resource allocation.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalLocationsCounted rdf:type rdf:Property ;
    rdfs:label 'Total Locations Counted' ;
    rdfs:comment 'Total number of storage locations physically counted during this cycle count event.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSkusCounted rdf:type rdf:Property ;
    rdfs:label 'Total Skus Counted' ;
    rdfs:comment 'Total number of unique SKUs physically counted during this cycle count event.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalUnitsCounted rdf:type rdf:Property ;
    rdfs:label 'Total Units Counted' ;
    rdfs:comment 'Total quantity of inventory units physically counted across all SKUs and locations.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceTolerancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Tolerance Percentage' ;
    rdfs:comment 'Acceptable variance threshold percentage for this count event. Variances exceeding this threshold trigger recount or approval workflows.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceValueUsd rdf:type rdf:Property ;
    rdfs:label 'Variance Value Usd' ;
    rdfs:comment 'Financial value of the inventory variance in USD. Calculated as variance quantity multiplied by unit cost. Used for financial reconciliation and inventory accuracy KPI.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wmsBatchReference rdf:type rdf:Property ;
    rdfs:label 'Wms Batch Reference' ;
    rdfs:comment 'Batch identifier from the source WMS system. Used for traceability and integration with Manhattan WMS.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCountLineId rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Line Id' ;
    rdfs:comment 'Unique identifier for the cycle count line record. Primary key.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentPostedFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Posted Flag' ;
    rdfs:comment 'Indicates whether the inventory adjustment has been posted to the WMS and financial systems. True if posted, False if pending.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adjustmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Adjustment Timestamp' ;
    rdfs:comment 'The date and time when the inventory adjustment was posted to the system. Nullable if adjustment not yet posted.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count Timestamp' ;
    rdfs:comment 'The date and time when the initial physical count was performed. Business event timestamp for the count activity.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countedQuantity rdf:type rdf:Property ;
    rdfs:label 'Counted Quantity' ;
    rdfs:comment 'The actual physical quantity counted by the warehouse associate during the cycle count.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'The expiration or best-before date of the lot counted. Used for FEFO (First Expired First Out) inventory management. Nullable for non-perishable items.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inventoryConditionCode rdf:type rdf:Property ;
    rdfs:label 'Inventory Condition Code' ;
    rdfs:comment 'The condition or quality status of the inventory counted. Determines whether inventory is available for sale or fulfillment.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Investigation Required Flag' ;
    rdfs:comment 'Indicates whether this variance requires formal investigation due to high value, high percentage, or recurring pattern. True if investigation is required, False otherwise.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investigationStatus rdf:type rdf:Property ;
    rdfs:label 'Investigation Status' ;
    rdfs:comment 'Current status of the variance investigation workflow. Tracks progression from initiation through resolution.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recountQuantity rdf:type rdf:Property ;
    rdfs:label 'Recount Quantity' ;
    rdfs:comment 'The quantity recorded during the recount verification. Nullable if no recount was performed.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recountRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Recount Required Flag' ;
    rdfs:comment 'Indicates whether this line requires a recount due to variance exceeding threshold or other business rules. True if recount is required, False otherwise.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recountTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recount Timestamp' ;
    rdfs:comment 'The date and time when the recount verification was performed. Nullable if no recount was performed.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recountVarianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Recount Variance Quantity' ;
    rdfs:comment 'The variance between recount quantity and system quantity. Nullable if no recount was performed.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:systemQuantity rdf:type rdf:Property ;
    rdfs:label 'System Quantity' ;
    rdfs:comment 'The book stock quantity recorded in the WMS system before the physical count. Also known as expected quantity or on-hand quantity.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceNotes rdf:type rdf:Property ;
    rdfs:label 'Variance Notes' ;
    rdfs:comment 'Free-text notes explaining the variance, investigation findings, or corrective actions taken. Used for audit trail and continuous improvement.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'The variance expressed as a percentage of system quantity. Calculated as (variance_quantity / system_quantity) * 100. Used for threshold-based recount triggers.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceValueAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Value Amount' ;
    rdfs:comment 'The financial value of the variance, calculated as variance_quantity multiplied by cost_per_unit. Used for financial reporting and variance analysis.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appointmentDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Appointment Duration Minutes' ;
    rdfs:comment 'Estimated or planned duration of the loading or unloading operation in minutes. Used for dock scheduling optimization and labor allocation.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appointmentStatus rdf:type rdf:Property ;
    rdfs:label 'Appointment Status' ;
    rdfs:comment 'Current lifecycle status of the dock appointment. Scheduled indicates initial booking, confirmed indicates carrier acknowledgment, checked-in indicates driver arrival, in-progress indicates active loading/unloading, completed indicates finished operation, no-show indicates missed appointment, cancelled indicates appointment termination. [ENUM-REF-CANDIDATE: scheduled|confirmed|checked-in|in-progress|completed|no-show|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentType rdf:type rdf:Property ;
    rdfs:label 'Appointment Type' ;
    rdfs:comment 'Classification of the dock appointment indicating the direction and nature of the operation. Inbound for receiving shipments, outbound for dispatch, cross-dock for direct transfer, live-unload for immediate unloading with driver waiting, drop-trailer for trailer left at facility.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Check In Timestamp' ;
    rdfs:comment 'Date and time when the driver completed check-in procedures at the facility gate or reception desk. Marks the beginning of the appointment lifecycle.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expectedCartonCount rdf:type rdf:Property ;
    rdfs:label 'Expected Carton Count' ;
    rdfs:comment 'Number of cartons expected to be loaded or unloaded during this appointment. Used for labor planning and throughput estimation.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedPalletCount rdf:type rdf:Property ;
    rdfs:label 'Expected Pallet Count' ;
    rdfs:comment 'Number of pallets expected to be loaded or unloaded during this appointment. Used for labor planning and dock capacity management.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Expected Volume Cbm' ;
    rdfs:comment 'Total expected volume of the shipment in cubic meters. Used for space planning and trailer utilization analysis.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedWeightKg rdf:type rdf:Property ;
    rdfs:label 'Expected Weight Kg' ;
    rdfs:comment 'Total expected weight of the shipment in kilograms. Used for equipment selection and dock floor load capacity verification.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loadingCompleteTimestamp rdf:type rdf:Property ;
    rdfs:label 'Loading Complete Timestamp' ;
    rdfs:comment 'Date and time when loading or unloading operations were completed. Used for turnaround time calculation and dock throughput metrics.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loadingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Loading Start Timestamp' ;
    rdfs:comment 'Date and time when loading or unloading operations actually began at the dock door. Used for measuring dock productivity and dwell time.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:noShowReason rdf:type rdf:Property ;
    rdfs:label 'No Show Reason' ;
    rdfs:comment 'Explanation for why a scheduled appointment was missed by the carrier or driver. Used for carrier performance tracking and root cause analysis.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outboundOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Outbound Order Number' ;
    rdfs:comment 'Reference to the outbound shipment order or wave being loaded during this appointment. Links dock appointment to order fulfillment operations.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledArrivalEnd rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival End' ;
    rdfs:comment 'End of the scheduled arrival time window for the carrier or driver. Represents the latest acceptable arrival time for the appointment without being considered late.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledArrivalStart rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival Start' ;
    rdfs:comment 'Beginning of the scheduled arrival time window for the carrier or driver. Represents the earliest acceptable arrival time for the appointment.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:aisleCount rdf:type rdf:Property ;
    rdfs:label 'Aisle Count' ;
    rdfs:comment 'Number of aisles within the zone. Used for labor planning and travel distance optimization.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fireSuppressionSystem rdf:type rdf:Property ;
    rdfs:label 'Fire Suppression System' ;
    rdfs:comment 'Type of fire suppression system installed in the zone. Critical for safety compliance and insurance requirements.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Floor Area Sqm' ;
    rdfs:comment 'Total floor area of the zone measured in square meters. Used for capacity planning and space utilization analysis.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatSuitableFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Suitable Flag' ;
    rdfs:comment 'Indicates whether the zone is certified and equipped for storing hazardous materials per IMDG and ICAO regulations.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:heightM rdf:type rdf:Property ;
    rdfs:label 'Height M' ;
    rdfs:comment 'Maximum vertical clearance height of the zone in meters. Critical for slotting tall items and equipment operation.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationCount rdf:type rdf:Property ;
    rdfs:label 'Location Count' ;
    rdfs:comment 'Total number of discrete storage locations within the zone. Key metric for capacity planning and utilization tracking.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replenishmentSourceFlag rdf:type rdf:Property ;
    rdfs:label 'Replenishment Source Flag' ;
    rdfs:comment 'Indicates whether the zone serves as a bulk storage source for replenishing pick-face locations.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vasFlag rdf:type rdf:Property ;
    rdfs:label 'Vas Flag' ;
    rdfs:comment 'Indicates whether the zone is designated for value-added services such as kitting, labeling, packaging, or customization.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:declarationId rdf:type rdf:Property ;
    rdfs:label 'Declaration Id' ;
    rdfs:comment 'Unique identifier for the customs declaration record. Primary key.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Declaration .

ind:exporterSupplierId rdf:type rdf:Property ;
    rdfs:label 'Exporter Supplier Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier. Business justification: Customs declarations require supplier/exporter master data for denied party screening, origin verification, and duty assessment. Brokers link declarations to supplier records for compliance validation' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:portOfEntryNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Port Of Entry Network Node Id' ;
    rdfs:comment 'Foreign key linking to route.network_node. Business justification: Port of entry is a physical network node where customs clearance occurs. Required for customs processing location tracking, facility capacity planning, and clearance time analysis by node. Replaces de' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:amendmentReason rdf:type rdf:Property ;
    rdfs:label 'Amendment Reason' ;
    rdfs:comment 'Reason for amending the declaration after initial submission (e.g., corrected HS code, updated value, additional documentation). Null if declaration was not amended.' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateOfOriginNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Origin Number' ;
    rdfs:comment 'Reference number of the certificate of origin document supporting preferential duty treatment or country-of-origin claims. Null if not applicable.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfDestination rdf:type rdf:Property ;
    rdfs:label 'Country Of Destination' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the final destination country where the goods will be consumed or used.' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfExport rdf:type rdf:Property ;
    rdfs:label 'Country Of Export' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the country from which the goods are being exported.' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsAuthority rdf:type rdf:Property ;
    rdfs:label 'Customs Authority' ;
    rdfs:comment 'Name of the national customs authority or agency to which the declaration was filed (e.g., US CBP, UK HMRC, EU Member State Customs).' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsOfficeCode rdf:type rdf:Property ;
    rdfs:label 'Customs Office Code' ;
    rdfs:comment 'Official code of the specific customs office or location where the declaration was processed.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsProcedureCode rdf:type rdf:Property ;
    rdfs:label 'Customs Procedure Code' ;
    rdfs:comment 'Code indicating the customs procedure or regime applied to the goods (e.g., free circulation, temporary admission, inward processing, customs warehousing).' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarantIdentifier rdf:type rdf:Property ;
    rdfs:label 'Declarant Identifier' ;
    rdfs:comment 'Official identifier of the declarant assigned by customs authority (e.g., customs broker license number, SCAC code, or national business registration number).' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarantName rdf:type rdf:Property ;
    rdfs:label 'Declarant Name' ;
    rdfs:comment 'Legal name of the party (customs broker, freight forwarder, or direct importer/exporter) filing the declaration with customs authorities.' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationNumber rdf:type rdf:Property ;
    rdfs:label 'Declaration Number' ;
    rdfs:comment 'Official customs declaration number assigned by the national customs authority upon submission. This is the externally-known business identifier used for tracking and reference.' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationStatus rdf:type rdf:Property ;
    rdfs:label 'Declaration Status' ;
    rdfs:comment 'Current lifecycle status of the customs declaration: draft (being prepared), submitted (filed with customs), under_review (customs examination in progress), released (cleared for movement), rejected (not accepted by customs), cancelled (withdrawn), or amended (modified after submission). [ENUM-REF-CANDIDATE: draft|submitted|under_review|released|rejected|cancelled|amended — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationType rdf:type rdf:Property ;
    rdfs:label 'Declaration Type' ;
    rdfs:comment 'Type of customs declaration indicating the nature of the cross-border movement: import (goods entering), export (goods leaving), transit (goods passing through), re-export (previously imported goods leaving), temporary admission (goods entering temporarily), or inward processing (goods for processing then re-export).' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deniedPartyScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Denied Party Screening Status' ;
    rdfs:comment 'Result of screening all parties (importer, exporter, consignee, shipper) against denied party lists (OFAC, BIS, EU sanctions, etc.): cleared (no matches), flagged (potential match requiring review), pending (screening in progress), or not_screened.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyTaxCurrency rdf:type rdf:Property ;
    rdfs:label 'Duty Tax Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for duty and tax amounts (typically the currency of the importing country).' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDate rdf:type rdf:Property ;
    rdfs:label 'Filing Date' ;
    rdfs:comment 'Date when the customs declaration was officially submitted to the customs authority.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Filing Timestamp' ;
    rdfs:comment 'Precise date and time when the customs declaration was submitted to the customs authority, including timezone.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ftzEntryNumber rdf:type rdf:Property ;
    rdfs:label 'Ftz Entry Number' ;
    rdfs:comment 'Entry number assigned when goods are admitted into a Free Trade Zone or Foreign Trade Zone. Null if goods are not entering an FTZ.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Inspection Required' ;
    rdfs:comment 'Indicates whether customs authority has flagged this declaration for physical inspection or examination of goods.' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionType rdf:type rdf:Property ;
    rdfs:label 'Inspection Type' ;
    rdfs:comment 'Type of customs inspection conducted or required: none, document review only, x-ray scan, physical examination, full examination, or random sample. Null if inspection_required is false.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfExit rdf:type rdf:Property ;
    rdfs:label 'Port Of Exit' ;
    rdfs:comment 'Name or code of the port, airport, or border crossing where goods exit the country of export.' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Release Timestamp' ;
    rdfs:comment 'Precise date and time when customs authority released the goods, including timezone. Null if not yet released.' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalDeclaredValue rdf:type rdf:Property ;
    rdfs:label 'Total Declared Value' ;
    rdfs:comment 'Total customs value of all goods declared on this declaration, used as the basis for duty and tax calculation.' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDutyAmount rdf:type rdf:Property ;
    rdfs:label 'Total Duty Amount' ;
    rdfs:comment 'Total customs duty assessed on the declared goods. Null if not yet calculated or if duty-free.' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Total Tax Amount' ;
    rdfs:comment 'Total taxes (VAT, GST, excise, etc.) assessed on the declared goods. Null if not yet calculated or if tax-exempt.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tariffRateId rdf:type rdf:Property ;
    rdfs:label 'Tariff Rate Id' ;
    rdfs:comment 'Foreign key linking to customs.tariff_rate. Business justification: Each declaration line has an hs_code and duty_rate_percent. Linking to tariff_rate provides the authoritative rate reference. Not removing duty_rate_percent as it\'s a point-in-time transactional value' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TariffRate .

ind:antidumpingCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Antidumping Case Number' ;
    rdfs:comment 'Reference number of the antidumping or countervailing duty investigation or order. Null if not subject to trade remedy measures.' ;
    rdfs:domain ind:DeclarationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:antidumpingIndicator rdf:type rdf:Property ;
    rdfs:label 'Antidumping Indicator' ;
    rdfs:comment 'Indicates whether this line item is subject to antidumping or countervailing duties. True if subject to trade remedy measures, false otherwise.' ;
    rdfs:domain ind:DeclarationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:brandName rdf:type rdf:Property ;
    rdfs:label 'Brand Name' ;
    rdfs:comment 'Commercial brand or trademark name of the goods. Used for intellectual property enforcement and product identification.' ;
    rdfs:domain ind:DeclarationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityDescription rdf:type rdf:Property ;
    rdfs:label 'Commodity Description' ;
    rdfs:comment 'Detailed textual description of the goods being declared. Includes material composition, intended use, brand, model, and other identifying characteristics required by customs authorities.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsValueAmount rdf:type rdf:Property ;
    rdfs:label 'Customs Value Amount' ;
    rdfs:comment 'Declared customs value of the goods for duty calculation purposes. Represents the transaction value or adjusted value per WCO Valuation Agreement (GATT Article VII).' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsValueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Customs Value Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the customs value amount. Indicates the currency in which the goods value is declared.' ;
    rdfs:domain ind:DeclarationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dangerousGoodsIndicator rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Indicator' ;
    rdfs:comment 'Indicates whether this line item contains dangerous goods requiring special handling and documentation per IMDG Code or IATA Dangerous Goods Regulations. True if dangerous goods, false otherwise.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dutyAmount rdf:type rdf:Property ;
    rdfs:label 'Duty Amount' ;
    rdfs:comment 'Calculated customs duty amount payable on this line item. Computed as customs value multiplied by duty rate, subject to any preferential treatment or exemptions.' ;
    rdfs:domain ind:DeclarationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dutyRatePercent rdf:type rdf:Property ;
    rdfs:label 'Duty Rate Percent' ;
    rdfs:comment 'Applicable customs duty rate expressed as a percentage of the customs value. Determined by HS code classification and country of origin.' ;
    rdfs:domain ind:DeclarationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exciseTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Excise Tax Amount' ;
    rdfs:comment 'Calculated excise tax amount payable on this line item for goods subject to special excise duties (e.g., alcohol, tobacco, fuel). Zero if not applicable.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ftzIndicator rdf:type rdf:Property ;
    rdfs:label 'Ftz Indicator' ;
    rdfs:comment 'Indicates whether this line item is admitted into a free trade zone or bonded warehouse with duty suspension. True if FTZ admission, false otherwise.' ;
    rdfs:domain ind:DeclarationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturerAddress rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Address' ;
    rdfs:comment 'Full address of the manufacturer or producer of the goods. Required for origin verification and product safety traceability.' ;
    rdfs:domain ind:DeclarationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelNumber rdf:type rdf:Property ;
    rdfs:label 'Model Number' ;
    rdfs:comment 'Manufacturer\'s model number or part number for the goods. Used for product identification and classification verification.' ;
    rdfs:domain ind:DeclarationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netWeightKg rdf:type rdf:Property ;
    rdfs:label 'Net Weight Kg' ;
    rdfs:comment 'Weight of the goods excluding all packaging materials, expressed in kilograms. Used for duty calculation and statistical purposes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageTypeCode rdf:type rdf:Property ;
    rdfs:label 'Package Type Code' ;
    rdfs:comment 'Two-letter UN/CEFACT code identifying the type of packaging. Examples: CT=carton, PL=pallet, DR=drum, BX=box. Aligned to UN/CEFACT Recommendation 21.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceIndicator rdf:type rdf:Property ;
    rdfs:label 'Preference Indicator' ;
    rdfs:comment 'Indicates whether preferential tariff treatment is claimed for this line item under a free trade agreement or trade preference program. True if preference is claimed, false otherwise.' ;
    rdfs:domain ind:DeclarationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferenceProgramCode rdf:type rdf:Property ;
    rdfs:label 'Preference Program Code' ;
    rdfs:comment 'Code identifying the specific trade agreement or preference program under which preferential treatment is claimed. Examples include USMCA, EU-GSP, CPTPP. Null if no preference is claimed.' ;
    rdfs:domain ind:DeclarationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prohibitedRestrictedIndicator rdf:type rdf:Property ;
    rdfs:label 'Prohibited Restricted Indicator' ;
    rdfs:comment 'Indicates whether this line item contains goods subject to import prohibitions or restrictions (e.g., endangered species, hazardous materials, dual-use goods). True if restricted, false otherwise.' ;
    rdfs:domain ind:DeclarationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quotaIndicator rdf:type rdf:Property ;
    rdfs:label 'Quota Indicator' ;
    rdfs:comment 'Indicates whether this line item is subject to a tariff rate quota or quantitative import restriction. True if quota applies, false otherwise.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quotaNumber rdf:type rdf:Property ;
    rdfs:label 'Quota Number' ;
    rdfs:comment 'Reference number of the quota allocation or license under which this line item is imported. Null if no quota applies.' ;
    rdfs:domain ind:DeclarationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalValueAmount rdf:type rdf:Property ;
    rdfs:label 'Statistical Value Amount' ;
    rdfs:comment 'Value of the goods for trade statistics purposes, typically converted to the importing country\'s currency. Used for balance of payments and trade flow analysis.' ;
    rdfs:domain ind:DeclarationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statisticalValueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Statistical Value Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the statistical value amount. Typically the local currency of the importing country.' ;
    rdfs:domain ind:DeclarationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationMethodCode rdf:type rdf:Property ;
    rdfs:label 'Valuation Method Code' ;
    rdfs:comment 'Code indicating the WCO valuation method used to determine customs value. Values: 1=Transaction Value, 2=Identical Goods, 3=Similar Goods, 4=Deductive Value, 5=Computed Value, 6=Fall-back Method.' ;
    rdfs:domain ind:DeclarationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatAmount rdf:type rdf:Property ;
    rdfs:label 'Vat Amount' ;
    rdfs:comment 'Calculated value-added tax or goods and services tax amount payable on this line item. Computed based on the taxable base (customs value plus duty) and applicable VAT rate.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vatRatePercent rdf:type rdf:Property ;
    rdfs:label 'Vat Rate Percent' ;
    rdfs:comment 'Applicable value-added tax or goods and services tax rate expressed as a percentage. Applied to the sum of customs value and duty amount.' ;
    rdfs:domain ind:DeclarationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bindingRulingExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Binding Ruling Expiry Date' ;
    rdfs:comment 'The date on which the binding tariff ruling expires and is no longer valid for use. Nullable if the ruling has no expiration or is valid indefinitely.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bindingRulingIndicator rdf:type rdf:Property ;
    rdfs:label 'Binding Ruling Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this classification is based on a binding tariff ruling issued by a customs authority. Binding rulings provide legal certainty and protection from reclassification penalties.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bindingRulingIssueDate rdf:type rdf:Property ;
    rdfs:label 'Binding Ruling Issue Date' ;
    rdfs:comment 'The date on which the binding tariff ruling was officially issued by the customs authority. Determines the start of the ruling validity period.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bindingRulingIssuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Binding Ruling Issuing Authority' ;
    rdfs:comment 'The name of the customs authority or government agency that issued the binding tariff ruling. Examples include US CBP, HMRC, EU Commission.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bindingRulingReference rdf:type rdf:Property ;
    rdfs:label 'Binding Ruling Reference' ;
    rdfs:comment 'The official reference number or identifier of the binding tariff ruling issued by the customs authority. Used to cite the ruling in customs declarations and audits.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Classification Confidence Score' ;
    rdfs:comment 'A numerical score (0-100) representing the confidence level in the assigned HS Code classification. Used for automated classifications to flag low-confidence assignments for manual review.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:classificationDate rdf:type rdf:Property ;
    rdfs:label 'Classification Date' ;
    rdfs:comment 'The date on which the HS Code classification was assigned or approved. Used to determine applicability of tariff rates and trade regulations in effect at that time.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:classificationMethod rdf:type rdf:Property ;
    rdfs:label 'Classification Method' ;
    rdfs:comment 'The method by which the HS Code classification was determined. Automated indicates system-driven classification; manual indicates customs broker review; binding ruling indicates official customs authority determination; third party ruling indicates external consultant classification; customer declared indicates shipper-provided classification.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationNotes rdf:type rdf:Property ;
    rdfs:label 'Classification Notes' ;
    rdfs:comment 'Free-text notes and comments from the classifier explaining the rationale for the HS Code assignment, including references to tariff schedule notes, explanatory notes, or ruling precedents.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationStatus rdf:type rdf:Property ;
    rdfs:label 'Classification Status' ;
    rdfs:comment 'Current lifecycle status of the HS classification record. Tracks whether the classification is in draft, under review, approved for use, rejected, expired, or superseded by a newer classification.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classifierLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Classifier License Number' ;
    rdfs:comment 'Professional license or certification number of the customs broker who performed the classification. Required for regulatory compliance and audit purposes in jurisdictions that mandate licensed brokers.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfClassification rdf:type rdf:Property ;
    rdfs:label 'Country Of Classification' ;
    rdfs:comment 'The 3-letter ISO country code indicating the jurisdiction for which this HS classification applies. HS codes may vary by country at the 8-digit and 10-digit levels.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Duty Rate Percentage' ;
    rdfs:comment 'The applicable customs duty rate as a percentage of the goods value, based on the assigned HS Code and destination country. Used for landed cost calculation and duty estimation.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exciseTaxApplicableIndicator rdf:type rdf:Property ;
    rdfs:label 'Excise Tax Applicable Indicator' ;
    rdfs:comment 'Boolean flag indicating whether excise taxes apply to the classified goods in addition to customs duties. Common for alcohol, tobacco, fuel, and luxury goods.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exportControlClassificationNumber rdf:type rdf:Property ;
    rdfs:label 'Export Control Classification Number' ;
    rdfs:comment 'The ECCN assigned to the goods for export control purposes. Used to determine whether an export license is required under dual-use or military export regulations.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsCode10Digit rdf:type rdf:Property ;
    rdfs:label 'Hs Code 10 Digit' ;
    rdfs:comment 'The 10-digit national tariff code used by specific countries (e.g., USA HTS code). Provides the most granular level of commodity classification for duty and tax calculation.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsCode6Digit rdf:type rdf:Property ;
    rdfs:label 'Hs Code 6 Digit' ;
    rdfs:comment 'The 6-digit HS Code as defined by the World Customs Organization (WCO). This is the internationally standardized classification code used globally for customs tariff purposes.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsCode8Digit rdf:type rdf:Property ;
    rdfs:label 'Hs Code 8 Digit' ;
    rdfs:comment 'The 8-digit HS Code used in the European Union Combined Nomenclature (CN). Extends the 6-digit WCO code with two additional digits for EU-specific classification.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importLicenseRequiredIndicator rdf:type rdf:Property ;
    rdfs:label 'Import License Required Indicator' ;
    rdfs:comment 'Boolean flag indicating whether an import license or permit is required for the classified goods in the destination country. Used to trigger license application workflows.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'The username or identifier of the user who last modified this HS classification record. Used for accountability and audit trail purposes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferentialDutyRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Preferential Duty Rate Percentage' ;
    rdfs:comment 'The reduced duty rate applicable under a Free Trade Agreement (FTA) or preferential trade program. Nullable if no preferential treatment applies.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productSku rdf:type rdf:Property ;
    rdfs:label 'Product Sku' ;
    rdfs:comment 'The customer or internal SKU code for the specific product or commodity to which this HS classification applies. Links the classification to inventory and order management systems.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Record Version Number' ;
    rdfs:comment 'Sequential version number incremented each time the classification record is modified. Used for optimistic locking and change history tracking.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:restrictedGoodsIndicator rdf:type rdf:Property ;
    rdfs:label 'Restricted Goods Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the classified goods are subject to import or export restrictions, embargoes, or sanctions. Triggers compliance screening and approval workflows.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewRequiredIndicator rdf:type rdf:Property ;
    rdfs:label 'Review Required Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this classification requires periodic review or re-validation. Set to true for complex classifications, borderline cases, or when tariff schedules are updated.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'The unique identifier of this classification record in the source operational system. Used for data lineage, reconciliation, and troubleshooting.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Vat Rate Percentage' ;
    rdfs:comment 'The applicable VAT or Goods and Services Tax (GST) rate as a percentage, based on the HS Code and destination country. Used for total landed cost calculation.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supersededByTariffRateId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Tariff Rate Id' ;
    rdfs:comment 'Reference to the tariff_rate_id that replaces this record when status is superseded. Enables rate history tracking.' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TariffRate .

ind:antiDumpingDutyRate rdf:type rdf:Property ;
    rdfs:label 'Anti Dumping Duty Rate' ;
    rdfs:comment 'Additional duty imposed on imports sold below fair market value to protect domestic industry. Expressed as a percentage or specific amount per unit.' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countervailingDutyRate rdf:type rdf:Property ;
    rdfs:label 'Countervailing Duty Rate' ;
    rdfs:comment 'Additional duty imposed to offset foreign government subsidies that distort trade. Expressed as a percentage or specific amount per unit.' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dutyCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Duty Calculation Method' ;
    rdfs:comment 'Method used to calculate the duty: ad valorem (percentage of value), specific (fixed amount per unit), compound (combination), or mixed.' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exciseDutyRate rdf:type rdf:Property ;
    rdfs:label 'Excise Duty Rate' ;
    rdfs:comment 'Special tax levied on specific goods such as alcohol, tobacco, fuel, or luxury items. Expressed as a percentage or specific amount per unit.' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exportingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Exporting Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the origin country from which goods are being exported.' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gstRate rdf:type rdf:Property ;
    rdfs:label 'Gst Rate' ;
    rdfs:comment 'The goods and services tax rate applicable in jurisdictions using GST instead of VAT. Expressed as a percentage.' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:importingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Importing Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the destination country where goods are being imported.' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Verified Date' ;
    rdfs:comment 'Date when this tariff rate was last verified against official customs authority publications to ensure accuracy.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mfnDutyRate rdf:type rdf:Property ;
    rdfs:label 'Mfn Duty Rate' ;
    rdfs:comment 'The standard duty rate applied to imports from WTO member countries in the absence of a preferential trade agreement. Expressed as a percentage or specific rate.' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originCriteria rdf:type rdf:Property ;
    rdfs:label 'Origin Criteria' ;
    rdfs:comment 'Rules of origin requirements that must be met to qualify for preferential duty rates under the trade agreement (e.g., regional value content, tariff shift, specific process).' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferentialDutyRate rdf:type rdf:Property ;
    rdfs:label 'Preferential Duty Rate' ;
    rdfs:comment 'Reduced duty rate available under a specific trade agreement when origin and compliance criteria are met. Expressed as a percentage or specific rate.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publicationReference rdf:type rdf:Property ;
    rdfs:label 'Publication Reference' ;
    rdfs:comment 'Official document reference, gazette number, or regulation identifier where this tariff rate was published.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Quota Order Number' ;
    rdfs:comment 'Official quota order number or TRQ identifier when tariff_quota_flag is true. Used to track quota utilization.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateSourceAuthority rdf:type rdf:Property ;
    rdfs:label 'Rate Source Authority' ;
    rdfs:comment 'The official government or regulatory body that published this tariff rate (e.g., US Customs and Border Protection, HMRC, European Commission DG TAXUD).' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateType rdf:type rdf:Property ;
    rdfs:label 'Rate Type' ;
    rdfs:comment 'Classification of the tariff rate type for operational and reporting purposes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalPeriod rdf:type rdf:Property ;
    rdfs:label 'Seasonal Period' ;
    rdfs:comment 'Description of the seasonal period when this rate applies (e.g., January-March, Summer, Harvest Season). Populated when seasonal_rate_flag is true.' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalRateFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Rate Flag' ;
    rdfs:comment 'Indicates whether this tariff rate varies by season or time of year (common for agricultural products).' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specificDutyAmount rdf:type rdf:Property ;
    rdfs:label 'Specific Duty Amount' ;
    rdfs:comment 'Fixed duty amount per unit of measure when specific or compound duty calculation method applies.' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:suspensionFlag rdf:type rdf:Property ;
    rdfs:label 'Suspension Flag' ;
    rdfs:comment 'Indicates whether duty collection is temporarily suspended for this HS code and country pair (autonomous suspension).' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tariffQuotaFlag rdf:type rdf:Property ;
    rdfs:label 'Tariff Quota Flag' ;
    rdfs:comment 'Indicates whether this rate is subject to a tariff rate quota (TRQ) limiting the quantity eligible for preferential rates.' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tariffRateStatus rdf:type rdf:Property ;
    rdfs:label 'Tariff Rate Status' ;
    rdfs:comment 'Current lifecycle status of the tariff rate record in the system.' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatRate rdf:type rdf:Property ;
    rdfs:label 'Vat Rate' ;
    rdfs:comment 'The value-added tax or goods and services tax rate applicable to the imported goods in the destination country. Expressed as a percentage.' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessedPlanLegId rdf:type rdf:Property ;
    rdfs:label 'Assessed Plan Leg Id' ;
    rdfs:comment 'Foreign key linking to route.plan_leg. Business justification: Duty assessments generate accessorial charges allocated to specific transport legs for landed cost calculation. Finance systems need leg-level duty attribution to reconcile carrier invoices, calculate' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlanLeg .

ind:originalAssessmentDutyAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Original Assessment Duty Assessment Id' ;
    rdfs:comment 'Reference to the original duty assessment record if this is an adjusted or corrected assessment. Creates audit trail for assessment changes. Null for original assessments.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DutyAssessment .

ind:adjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason' ;
    rdfs:comment 'Reason for adjusting the duty assessment after initial calculation. May include post-entry amendment, reconciliation, or customs authority correction. Null if no adjustment made.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:antiDumpingDutyAmount rdf:type rdf:Property ;
    rdfs:label 'Anti Dumping Duty Amount' ;
    rdfs:comment 'Anti-dumping duty assessed when goods are imported at below fair market value. Additional duty imposed to protect domestic industry from unfair trade practices.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'Date when the duty assessment was calculated and issued by the customs authority or broker system. Principal business event timestamp for this transaction.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assessment Method' ;
    rdfs:comment 'Method by which the duty assessment was calculated. Automated = system-calculated; Manual = customs officer review; Hybrid = system with officer override; Post_audit = retrospective assessment after release.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Number' ;
    rdfs:comment 'Business identifier for the duty assessment. Externally visible reference number used in customs documentation and payment processing.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Assessment Source System' ;
    rdfs:comment 'Name of the system that generated the duty assessment calculation. Typically the customs broker GTM system or customs authority automated system.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assessment Status' ;
    rdfs:comment 'Current lifecycle status of the duty assessment. Estimated = preliminary calculation; Assessed = official customs authority calculation; Final = confirmed and payable; Disputed = under review or appeal; Adjusted = modified after initial assessment; Cancelled = voided assessment.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assessment Timestamp' ;
    rdfs:comment 'Precise date and time when the duty assessment calculation was executed. Used for audit trail and calculation sequencing.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:calculationBasis rdf:type rdf:Property ;
    rdfs:label 'Calculation Basis' ;
    rdfs:comment 'Incoterms basis used for duty calculation. CIF = Cost Insurance Freight; FOB = Free on Board; DDP = Delivered Duty Paid; DAP = Delivered at Place; EXW = Ex Works; FCA = Free Carrier. Determines which costs are included in the customs value.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countervailingDutyAmount rdf:type rdf:Property ;
    rdfs:label 'Countervailing Duty Amount' ;
    rdfs:comment 'Countervailing duty assessed to offset foreign government subsidies. Additional duty imposed when imported goods benefit from subsidies in the country of origin.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsDutyAmount rdf:type rdf:Property ;
    rdfs:label 'Customs Duty Amount' ;
    rdfs:comment 'Total customs duty assessed on the imported or exported goods. Standard ad valorem or specific duty based on HS Code classification and tariff schedule.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeFiledDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Filed Date' ;
    rdfs:comment 'Date when a formal dispute or protest was filed with the customs authority regarding this assessment. Null if no dispute filed.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entryType rdf:type rdf:Property ;
    rdfs:label 'Entry Type' ;
    rdfs:comment 'Type of customs entry for which duty is assessed. Consumption = immediate release for domestic use; Warehouse = bonded storage; Temporary = temporary import; FTZ = Free Trade Zone; Carnet = temporary admission under ATA Carnet.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRateDate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Date' ;
    rdfs:comment 'Date for which the exchange rate was published and applied. Typically the date of export, entry filing, or customs authority determination.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:harborMaintenanceFee rdf:type rdf:Property ;
    rdfs:label 'Harbor Maintenance Fee' ;
    rdfs:comment 'Fee assessed on cargo loaded or unloaded at US ports. Used to fund harbor maintenance and dredging operations.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:importExportIndicator rdf:type rdf:Property ;
    rdfs:label 'Import Export Indicator' ;
    rdfs:comment 'Indicates whether this duty assessment is for an import or export transaction. Most assessments are for imports; some jurisdictions assess export duties.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchandiseProcessingFee rdf:type rdf:Property ;
    rdfs:label 'Merchandise Processing Fee' ;
    rdfs:comment 'Fee charged by customs authority for processing the import entry. Administrative charge for customs clearance services.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'Date by which the assessed duties and taxes must be paid to the customs authority. Failure to pay by this date may result in penalties, interest, or cargo holds.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'Reference number or transaction identifier for the duty payment. Links to the payment transaction in the financial system or customs payment portal.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current payment status of the assessed duties and taxes. Unpaid = not yet paid; Paid = fully settled; Partial = partially paid; Overdue = past due date; Waived = exempted from payment.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfEntryCode rdf:type rdf:Property ;
    rdfs:label 'Port Of Entry Code' ;
    rdfs:comment 'Code identifying the customs port or border crossing where the goods entered the country and duty was assessed. UN/LOCODE or national port code.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferentialTariffProgram rdf:type rdf:Property ;
    rdfs:label 'Preferential Tariff Program' ;
    rdfs:comment 'Free trade agreement or preferential tariff program applied to reduce or eliminate duty. Examples: USMCA, EU-UK TCA, CPTPP, GSP. Empty if no preference claimed.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDutyTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Total Duty Tax Amount' ;
    rdfs:comment 'Total liability including all duties, taxes, and fees assessed on this customs entry. Sum of customs duty, anti-dumping duty, countervailing duty, VAT, excise tax, and all fees.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufacturerSupplierId rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Supplier Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier. Business justification: ISF 10+2 filings require manufacturer/supplier details for CBP compliance. Customs brokers pull supplier master data (name, address, country) from procurement systems for accurate ISF submission and i' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:portOfUnladingNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Port Of Unlading Network Node Id' ;
    rdfs:comment 'Foreign key linking to route.network_node. Business justification: ISF 10+2 rule requires specifying the port where cargo will be unladed. CBP uses this for vessel arrival coordination and security screening. Critical for ISF compliance validation and arrival plannin' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'Number of times this ISF filing has been amended after initial submission. ISF data must be updated if changes occur before cargo arrival.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bondNumber rdf:type rdf:Property ;
    rdfs:label 'Bond Number' ;
    rdfs:comment 'Unique identifier for the customs bond that guarantees payment of duties, taxes, and penalties for this ISF filing.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondType rdf:type rdf:Property ;
    rdfs:label 'Bond Type' ;
    rdfs:comment 'Type of customs bond covering this ISF filing. Single transaction bond covers one shipment. Continuous bond covers multiple shipments over a year.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerAddress rdf:type rdf:Property ;
    rdfs:label 'Buyer Address' ;
    rdfs:comment 'Full address of the buyer, including street, city, state/province, postal code, and country.' ;
    rdfs:domain ind:IsfFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerName rdf:type rdf:Property ;
    rdfs:label 'Buyer Name' ;
    rdfs:comment 'Name of the last known entity to whom the goods are sold or agreed to be sold. If the goods are to be imported otherwise than in pursuance of a purchase, the name of the owner. This is one of the 10 required data elements for ISF-10.' ;
    rdfs:domain ind:IsfFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cbpRejectionReason rdf:type rdf:Property ;
    rdfs:label 'Cbp Rejection Reason' ;
    rdfs:comment 'Detailed reason provided by CBP for rejecting the ISF filing. May include error codes, missing data elements, or compliance violations.' ;
    rdfs:domain ind:IsfFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cbpResponseDate rdf:type rdf:Property ;
    rdfs:label 'Cbp Response Date' ;
    rdfs:comment 'Date and time when CBP responded to the ISF filing with acceptance, rejection, or request for amendment.' ;
    rdfs:domain ind:IsfFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cbpResponseStatus rdf:type rdf:Property ;
    rdfs:label 'Cbp Response Status' ;
    rdfs:comment 'Status of CBP\'s response to the ISF filing. Accepted indicates the filing meets all requirements. Rejected indicates the filing contains errors or missing data. Amendment required indicates CBP requires corrections. Pending review indicates CBP has not yet completed their review.' ;
    rdfs:domain ind:IsfFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneeAddress rdf:type rdf:Property ;
    rdfs:label 'Consignee Address' ;
    rdfs:comment 'Full address of the consignee, including street, city, state/province, postal code, and country.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneeName rdf:type rdf:Property ;
    rdfs:label 'Consignee Name' ;
    rdfs:comment 'Name of the party to whom the goods are being shipped. This is one of the 10 required data elements for ISF-10.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidatorAddress rdf:type rdf:Property ;
    rdfs:label 'Consolidator Address' ;
    rdfs:comment 'Full address of the consolidator, including street, city, state/province, postal code, and country.' ;
    rdfs:domain ind:IsfFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidatorName rdf:type rdf:Property ;
    rdfs:label 'Consolidator Name' ;
    rdfs:comment 'Name of the party who stuffed the container or arranged for the stuffing of the container. This is one of the 10 required data elements for ISF-10.' ;
    rdfs:domain ind:IsfFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerStuffingLocation rdf:type rdf:Property ;
    rdfs:label 'Container Stuffing Location' ;
    rdfs:comment 'Physical location where the container was stuffed (loaded). Must include the name and address of the facility. This is one of the 10 required data elements for ISF-10.' ;
    rdfs:domain ind:IsfFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBrokerLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Broker License Number' ;
    rdfs:comment 'CBP-issued license number of the customs broker who filed the ISF.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Date' ;
    rdfs:comment 'Estimated date when the vessel is expected to arrive at the US port of unlading.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingStatus rdf:type rdf:Property ;
    rdfs:label 'Filing Status' ;
    rdfs:comment 'Current lifecycle status of the ISF filing. Draft indicates the filing is being prepared. Submitted indicates the filing has been sent to CBP. Accepted indicates CBP has accepted the filing. Rejected indicates CBP has rejected the filing due to errors or missing data. Amended indicates the filing has been updated after initial submission. Withdrawn indicates the filing has been cancelled.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingType rdf:type rdf:Property ;
    rdfs:label 'Filing Type' ;
    rdfs:comment 'Type of ISF filing. ISF-10 is for standard ocean shipments (10 data elements required). ISF-5 is for specific scenarios such as FROB (Foreign Remaining On Board), IE (Immediate Exportation), or TE (Transportation and Exportation) shipments (5 data elements required).' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isfTransactionNumber rdf:type rdf:Property ;
    rdfs:label 'Isf Transaction Number' ;
    rdfs:comment 'Unique transaction number assigned by US Customs and Border Protection (CBP) upon successful ISF submission. This is the official CBP reference number for the filing.' ;
    rdfs:domain ind:IsfFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'Date and time when the most recent amendment to this ISF filing was submitted to CBP.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'Monetary penalty amount assessed by CBP for ISF violations. Penalties can range from $5,000 to $10,000 per violation depending on severity and whether the violation was timely, accurate, or complete.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyReason rdf:type rdf:Property ;
    rdfs:label 'Penalty Reason' ;
    rdfs:comment 'Detailed explanation of why a penalty was assessed by CBP. May include late filing, inaccurate data, missing data elements, or failure to update.' ;
    rdfs:domain ind:IsfFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Risk Flag' ;
    rdfs:comment 'Indicates whether this ISF filing is at risk of CBP penalties due to late filing, inaccurate data, or non-compliance. True indicates penalty risk exists. False indicates no known penalty risk.' ;
    rdfs:domain ind:IsfFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portOfLading rdf:type rdf:Property ;
    rdfs:label 'Port Of Lading' ;
    rdfs:comment 'Foreign port where the cargo was laden aboard the vessel. Represented as a 5-character UN/LOCODE.' ;
    rdfs:domain ind:IsfFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerAddress rdf:type rdf:Property ;
    rdfs:label 'Seller Address' ;
    rdfs:comment 'Full address of the seller, including street, city, state/province, postal code, and country.' ;
    rdfs:domain ind:IsfFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerName rdf:type rdf:Property ;
    rdfs:label 'Seller Name' ;
    rdfs:comment 'Name of the last known entity by whom the goods are sold or agreed to be sold. If the goods are to be imported otherwise than in pursuance of a purchase, the name of the owner. This is one of the 10 required data elements for ISF-10.' ;
    rdfs:domain ind:IsfFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToPartyAddress rdf:type rdf:Property ;
    rdfs:label 'Ship To Party Address' ;
    rdfs:comment 'Full address of the ship-to party, including street, city, state/province, postal code, and country.' ;
    rdfs:domain ind:IsfFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToPartyName rdf:type rdf:Property ;
    rdfs:label 'Ship To Party Name' ;
    rdfs:comment 'Name of the first deliver-to party scheduled to physically receive the goods after the goods have been released from customs custody. This is one of the 10 required data elements for ISF-10.' ;
    rdfs:domain ind:IsfFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperSupplierId rdf:type rdf:Property ;
    rdfs:label 'Shipper Supplier Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier. Business justification: AMS cargo manifest filings identify shipper (often supplier) for CBP advance screening. Carriers reference supplier master for accurate shipper details in manifest submissions, enabling denied party s' ;
    rdfs:domain ind:AmsFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'Sequential number tracking amendments to the original AMS filing. Zero for original filing, incremented for each amendment.' ;
    rdfs:domain ind:AmsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amsTransactionNumber rdf:type rdf:Property ;
    rdfs:label 'Ams Transaction Number' ;
    rdfs:comment 'The unique transaction number assigned by US Customs and Border Protection (CBP) upon successful AMS filing submission. This is the official CBP reference for the manifest filing.' ;
    rdfs:domain ind:AmsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerFilerCode rdf:type rdf:Property ;
    rdfs:label 'Broker Filer Code' ;
    rdfs:comment 'The CBP-assigned filer code identifying the licensed customs broker who submitted this AMS filing on behalf of the importer.' ;
    rdfs:domain ind:AmsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cbpHoldIndicator rdf:type rdf:Property ;
    rdfs:label 'Cbp Hold Indicator' ;
    rdfs:comment 'Boolean flag indicating whether CBP has placed a hold on this shipment for inspection or further review. True if hold is active.' ;
    rdfs:domain ind:AmsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conveyanceName rdf:type rdf:Property ;
    rdfs:label 'Conveyance Name' ;
    rdfs:comment 'The name or identifier of the conveyance (truck, rail car, barge) for rail and truck AMS filings.' ;
    rdfs:domain ind:AmsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examLocation rdf:type rdf:Property ;
    rdfs:label 'Exam Location' ;
    rdfs:comment 'The facility or terminal where the CBP examination will take place or has taken place.' ;
    rdfs:domain ind:AmsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examType rdf:type rdf:Property ;
    rdfs:label 'Exam Type' ;
    rdfs:comment 'The type of physical examination ordered by CBP. VACIS = Vehicle and Cargo Inspection System (non-intrusive imaging), CET = Container Examination Team (physical inspection), tailgate = partial inspection, intensive = full unload and inspection.' ;
    rdfs:domain ind:AmsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notifyPartyName rdf:type rdf:Property ;
    rdfs:label 'Notify Party Name' ;
    rdfs:comment 'The name of the party to be notified upon arrival of the cargo. Often the consignee or their customs broker.' ;
    rdfs:domain ind:AmsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfLadingCode rdf:type rdf:Property ;
    rdfs:label 'Port Of Lading Code' ;
    rdfs:comment 'The five-character UN/LOCODE identifying the foreign port where the cargo was loaded onto the conveyance.' ;
    rdfs:domain ind:AmsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselImoNumber rdf:type rdf:Property ;
    rdfs:label 'Vessel Imo Number' ;
    rdfs:comment 'The seven-digit IMO ship identification number, a unique permanent identifier for the vessel.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAccountId rdf:type rdf:Property ;
    rdfs:label 'Billing Account Id' ;
    rdfs:comment 'Foreign key linking to billing.billing_account. Business justification: Denied party screening results block billing and credit extension; direct link enforces compliance holds, prevents invoicing to sanctioned entities, and supports regulatory reporting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingAccount .

ind:screenedTradePartyId rdf:type rdf:Property ;
    rdfs:label 'Screened Trade Party Id' ;
    rdfs:comment 'Foreign key linking to customs.trade_party. Business justification: The denied_party_screening table has denormalized party attributes (name, address, city, state, postal_code, country_code, tax_number) that correspond to trade_party master data. Linking to trade_part' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeParty .

ind:analystReviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Analyst Review Outcome' ;
    rdfs:comment 'Outcome of the compliance analyst review for potential or confirmed matches (approved, rejected, escalated, pending review).' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analystReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Analyst Review Required Flag' ;
    rdfs:comment 'Indicates whether manual analyst review is required for this screening result (true for potential matches, false for clear results).' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:analystReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Analyst Review Timestamp' ;
    rdfs:comment 'Date and time when the compliance analyst completed their review of the screening result.' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Reference identifier linking this screening record to the complete audit trail for regulatory reporting and compliance verification.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceProgram rdf:type rdf:Property ;
    rdfs:label 'Compliance Program' ;
    rdfs:comment 'Trade compliance program under which this screening was performed (C-TPAT, AEO, Partners in Protection, Customs Self Assessment, Secure Exports Scheme).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:falsePositiveFlag rdf:type rdf:Property ;
    rdfs:label 'False Positive Flag' ;
    rdfs:comment 'Indicates whether the match was determined to be a false positive after analyst review.' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Release Timestamp' ;
    rdfs:comment 'Date and time when the regulatory hold was released and the shipment was cleared for processing.' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:matchScore rdf:type rdf:Property ;
    rdfs:label 'Match Score' ;
    rdfs:comment 'Numerical confidence score (0.00 to 100.00) indicating the strength of the match between the screened party and denied party list entries.' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchStatus rdf:type rdf:Property ;
    rdfs:label 'Match Status' ;
    rdfs:comment 'Result of the screening check indicating whether the party matched any denied party list (clear, potential match, confirmed match, false positive).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedEntityCode rdf:type rdf:Property ;
    rdfs:label 'Matched Entity Code' ;
    rdfs:comment 'Unique identifier of the matched entity on the denied party list (e.g., OFAC SDN number).' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedEntityName rdf:type rdf:Property ;
    rdfs:label 'Matched Entity Name' ;
    rdfs:comment 'Name of the denied party entity from the sanctions list that matched the screened party.' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedEntityProgram rdf:type rdf:Property ;
    rdfs:label 'Matched Entity Program' ;
    rdfs:comment 'Sanctions program or regulatory program associated with the matched denied party (e.g., Iran Sanctions, Counter-Terrorism, Narcotics Trafficking).' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedListName rdf:type rdf:Property ;
    rdfs:label 'Matched List Name' ;
    rdfs:comment 'Name of the specific denied party list where a match was found (e.g., OFAC SDN, BIS Entity List).' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideJustification rdf:type rdf:Property ;
    rdfs:label 'Override Justification' ;
    rdfs:comment 'Detailed justification provided by the compliance analyst for overriding a potential or confirmed match and approving the shipment.' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Flag' ;
    rdfs:comment 'Indicates whether the shipment is placed on regulatory hold due to denied party screening results, preventing further processing until cleared.' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Overall risk score (0.00 to 100.00) assigned to this screening result based on match quality, party type, and destination country risk.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:screeningEngineVersion rdf:type rdf:Property ;
    rdfs:label 'Screening Engine Version' ;
    rdfs:comment 'Version number of the denied party screening engine used to perform this check.' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningListSources rdf:type rdf:Property ;
    rdfs:label 'Screening List Sources' ;
    rdfs:comment 'Comma-separated list of denied party and restricted entity lists checked during this screening (OFAC SDN, BIS Entity List, EU Consolidated List, UN Sanctions, C-TPAT denied parties, HMT Sanctions, DFAT Sanctions, etc.).' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningNotes rdf:type rdf:Property ;
    rdfs:label 'Screening Notes' ;
    rdfs:comment 'Additional notes or comments recorded during the screening process or analyst review.' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Screening Reference Number' ;
    rdfs:comment 'Externally-known unique reference number for this screening transaction, used for audit trail and compliance reporting.' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningRuleSetVersion rdf:type rdf:Property ;
    rdfs:label 'Screening Rule Set Version' ;
    rdfs:comment 'Version number of the screening rule set and list data used during this check.' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningRunTimestamp rdf:type rdf:Property ;
    rdfs:label 'Screening Run Timestamp' ;
    rdfs:comment 'Date and time when the denied party screening check was executed. Principal business event timestamp for this transaction.' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:screeningStatus rdf:type rdf:Property ;
    rdfs:label 'Screening Status' ;
    rdfs:comment 'Current lifecycle status of the screening check workflow.' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeoStatus rdf:type rdf:Property ;
    rdfs:label 'Aeo Status' ;
    rdfs:comment 'Current status of the party\'s AEO certification, indicating their standing in the trusted trader program.' ;
    rdfs:domain ind:TradeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Business Registration Number' ;
    rdfs:comment 'The official registration number assigned by the national business registry or companies house in the country of establishment.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cbpImporterNumber rdf:type rdf:Property ;
    rdfs:label 'Cbp Importer Number' ;
    rdfs:comment 'The unique identifier assigned by US Customs and Border Protection to importers of record conducting business in the United States. Required for ISF and AMS filings.' ;
    rdfs:domain ind:TradeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfEstablishment rdf:type rdf:Property ;
    rdfs:label 'Country Of Establishment' ;
    rdfs:comment 'The country where the trade party is legally registered and established, represented as ISO 3166-1 alpha-3 country code.' ;
    rdfs:domain ind:TradeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctpatSviNumber rdf:type rdf:Property ;
    rdfs:label 'Ctpat Svi Number' ;
    rdfs:comment 'The unique identifier assigned to C-TPAT certified members following successful supply chain security validation.' ;
    rdfs:domain ind:TradeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftzOperatorNumber rdf:type rdf:Property ;
    rdfs:label 'Ftz Operator Number' ;
    rdfs:comment 'The authorization number for parties approved to operate or use Free Trade Zone facilities for customs-privileged storage and processing.' ;
    rdfs:domain ind:TradeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Kyc Verification Status' ;
    rdfs:comment 'Status of the Know Your Customer due diligence verification process for this trade party, ensuring compliance with anti-money laundering and trade compliance requirements.' ;
    rdfs:domain ind:TradeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Last Screening Date' ;
    rdfs:comment 'The date when the trade party was last screened against denied party and sanctions lists.' ;
    rdfs:domain ind:TradeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTransactionDate rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Date' ;
    rdfs:comment 'The date of the most recent customs declaration or trade transaction involving this party.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leiCode rdf:type rdf:Property ;
    rdfs:label 'Lei Code' ;
    rdfs:comment 'The 20-character ISO 17442 standard identifier for legal entities participating in financial transactions. Used for regulatory reporting and entity verification.' ;
    rdfs:domain ind:TradeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScreeningDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Screening Due Date' ;
    rdfs:comment 'The date by which the next periodic denied party screening must be completed to maintain compliance.' ;
    rdfs:domain ind:TradeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredCurrency rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency' ;
    rdfs:comment 'The preferred currency for invoicing and payment transactions with this trade party, represented as ISO 4217 three-letter currency code.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'The preferred language for customs documentation and communications with this trade party, represented as ISO 639-1 two-letter language code.' ;
    rdfs:domain ind:TradeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskClassification rdf:type rdf:Property ;
    rdfs:label 'Risk Classification' ;
    rdfs:comment 'The risk level assigned to this trade party based on compliance history, denied party screening results, geographic risk factors, and transaction patterns.' ;
    rdfs:domain ind:TradeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'The national tax identification number assigned by the tax authority of the party\'s country of establishment. Used for customs duty and tax assessment.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedPortNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Assigned Port Network Node Id' ;
    rdfs:comment 'Foreign key linking to route.network_node. Business justification: Customs brokers are licensed to operate at specific ports/nodes. Required for broker jurisdiction enforcement, service coverage planning, and assignment validation. Replaces denormalized assigned_port' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:brokerAgentId rdf:type rdf:Property ;
    rdfs:label 'Broker Agent Id' ;
    rdfs:comment 'Foreign key linking to network.agent. Business justification: Customs broker assignments must link to the agent entity for operational coordination, performance tracking (filing accuracy, release times), and network management. Role prefix distinguishes from bro' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:brokerTradePartyId rdf:type rdf:Property ;
    rdfs:label 'Broker Trade Party Id' ;
    rdfs:comment 'Foreign key linking to customs.trade_party. Business justification: Customs broker is a trade party entity. Adding broker_trade_party_id FK to trade_party.trade_party_id normalizes the broker reference. Cardinality: N:1 (many assignments can use the same broker). Remo' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeParty .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Indicates whether this broker assignment is currently active. True for active assignments, false for completed or cancelled assignments. Used for filtering current workload.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualFilingDate rdf:type rdf:Property ;
    rdfs:label 'Actual Filing Date' ;
    rdfs:comment 'Actual date when the customs declaration was filed with the customs authority. Used for SLA compliance measurement and audit trails.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Release Date' ;
    rdfs:comment 'Actual date when the shipment was released by customs authority. Critical milestone for supply chain visibility and performance measurement.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aeoCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Aeo Certified Flag' ;
    rdfs:comment 'Indicates whether the broker holds AEO certification, which provides expedited customs processing and reduced inspection rates. True if certified, false otherwise.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assignedCountryCode rdf:type rdf:Property ;
    rdfs:label 'Assigned Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the country where customs clearance is being performed. Determines applicable customs regulations and procedures.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assignment Notes' ;
    rdfs:comment 'Free-text field for capturing special instructions, exceptions, or contextual information relevant to this broker assignment. Used for operational communication.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentPriority rdf:type rdf:Property ;
    rdfs:label 'Assignment Priority' ;
    rdfs:comment 'Priority level for this broker assignment. Influences processing sequence and resource allocation for time-sensitive shipments.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentType rdf:type rdf:Property ;
    rdfs:label 'Assignment Type' ;
    rdfs:comment 'Type of customs procedure the broker is handling. Determines applicable regulations, documentation requirements, and processing workflows.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageReleaseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Average Release Time Hours' ;
    rdfs:comment 'Average time in hours from declaration filing to customs release for shipments handled by this broker. Performance metric for broker efficiency.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brokerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Broker Contact Email' ;
    rdfs:comment 'Primary email address for communicating with the assigned customs broker. Used for document exchange and status updates.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Broker Contact Phone' ;
    rdfs:comment 'Primary phone number for reaching the assigned customs broker. Critical for urgent communications and issue resolution.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Broker Fee Amount' ;
    rdfs:comment 'Total fee charged by the customs broker for handling this declaration. Excludes government duties and taxes.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brokerFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Broker Fee Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the broker fee amount. Supports multi-currency brokerage operations.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerageOfficeCode rdf:type rdf:Property ;
    rdfs:label 'Brokerage Office Code' ;
    rdfs:comment 'Internal code identifying the specific brokerage office or branch handling this assignment. Supports multi-location brokerage operations and workload distribution.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerageOfficeLocation rdf:type rdf:Property ;
    rdfs:label 'Brokerage Office Location' ;
    rdfs:comment 'City and country location of the brokerage office handling this assignment. Enables geographic analysis of broker utilization.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctpatCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Ctpat Certified Flag' ;
    rdfs:comment 'Indicates whether the broker is C-TPAT certified for enhanced supply chain security. True if certified, false otherwise. Applicable for US customs operations.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedFilingDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Filing Date' ;
    rdfs:comment 'Projected date when the customs declaration will be filed by the broker. Used for planning and customer communication.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Release Date' ;
    rdfs:comment 'Projected date when customs clearance and release will be completed. Used for downstream logistics planning and customer expectations.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exceptionReason rdf:type rdf:Property ;
    rdfs:label 'Exception Reason' ;
    rdfs:comment 'Description of the exception or issue encountered during customs processing. Populated only when exception_flag is true. Used for root cause analysis.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingAccuracyRate rdf:type rdf:Property ;
    rdfs:label 'Filing Accuracy Rate' ;
    rdfs:comment 'Percentage of declarations filed by this broker that were accepted without errors or rejections. Key performance indicator for broker quality. Expressed as percentage (0.00 to 100.00).' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poaEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Poa Effective Date' ;
    rdfs:comment 'Date when the power of attorney authorization becomes effective. Used to validate broker authority at time of filing.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poaExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Poa Expiry Date' ;
    rdfs:comment 'Date when the power of attorney authorization expires. Nullable for indefinite authorizations. Critical for compliance validation.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:powerOfAttorneyReference rdf:type rdf:Property ;
    rdfs:label 'Power Of Attorney Reference' ;
    rdfs:comment 'Reference number of the legal power of attorney document authorizing the broker to act on behalf of the importer or exporter. Required for regulatory compliance.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousBrokerLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Previous Broker License Number' ;
    rdfs:comment 'License number of the previous broker if this assignment was reassigned. Nullable for initial assignments. Supports audit trails and handoff tracking.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reassignmentCount rdf:type rdf:Property ;
    rdfs:label 'Reassignment Count' ;
    rdfs:comment 'Number of times this declaration has been reassigned to a different broker. High values may indicate complexity or resource constraints.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceLevelAgreement rdf:type rdf:Property ;
    rdfs:label 'Service Level Agreement' ;
    rdfs:comment 'Contractual service level tier governing response times, filing deadlines, and support availability for this broker assignment.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specializationCodes rdf:type rdf:Property ;
    rdfs:label 'Specialization Codes' ;
    rdfs:comment 'Comma-separated list of commodity or procedure specialization codes indicating the broker\'s areas of expertise (e.g., dangerous goods, pharmaceuticals, automotive). Used for intelligent broker assignment.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDeclarationsHandled rdf:type rdf:Property ;
    rdfs:label 'Total Declarations Handled' ;
    rdfs:comment 'Cumulative count of customs declarations this broker has processed. Used for workload balancing and performance trending.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certifiedNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Certified Network Node Id' ;
    rdfs:comment 'Foreign key linking to route.network_node. Business justification: AEO/C-TPAT compliance programs grant expedited processing at specific certified ports and hubs. Routing optimization must know which nodes have program certification to leverage reduced inspection rat' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:participantTradePartyId rdf:type rdf:Property ;
    rdfs:label 'Participant Trade Party Id' ;
    rdfs:comment 'Foreign key linking to customs.trade_party. Business justification: Compliance program memberships (C-TPAT, AEO, etc.) are held by trade parties. The compliance_program product appears to be an association entity tracking trade party participation in compliance progra' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeParty .

ind:annualReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Annual Reporting Required Flag' ;
    rdfs:comment 'Indicates whether the program requires submission of annual compliance reports, self-assessments, or status updates.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicationDate rdf:type rdf:Property ;
    rdfs:label 'Application Date' ;
    rdfs:comment 'Date when Transport Shipping or its client submitted the initial application for program membership.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency Months' ;
    rdfs:comment 'Required interval in months between compliance audits or validation visits as mandated by the program.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorityContactEmail rdf:type rdf:Property ;
    rdfs:label 'Authority Contact Email' ;
    rdfs:comment 'Email address of the assigned contact person at the certifying authority.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityContactName rdf:type rdf:Property ;
    rdfs:label 'Authority Contact Name' ;
    rdfs:comment 'Name of the assigned contact person or account manager at the certifying authority.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityContactPhone rdf:type rdf:Property ;
    rdfs:label 'Authority Contact Phone' ;
    rdfs:comment 'Phone number of the assigned contact person at the certifying authority.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityCountryCode rdf:type rdf:Property ;
    rdfs:label 'Authority Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the certifying authority\'s jurisdiction (e.g., USA, GBR, DEU, CHN).' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'Unique certificate, authorization, or membership identification number issued by the certifying authority.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingAuthority rdf:type rdf:Property ;
    rdfs:label 'Certifying Authority' ;
    rdfs:comment 'Name of the government agency, customs authority, or international body that issues and governs the program (e.g., US Customs and Border Protection, European Commission, ISO).' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceObligationsDescription rdf:type rdf:Property ;
    rdfs:label 'Compliance Obligations Description' ;
    rdfs:comment 'Detailed narrative description of all compliance requirements, obligations, and commitments that must be maintained to retain program membership.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPersonEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Person Email' ;
    rdfs:comment 'Email address of the primary internal contact person responsible for this program.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPersonPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Person Phone' ;
    rdfs:comment 'Phone number of the primary internal contact person responsible for this program.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dedicatedAccountManagerFlag rdf:type rdf:Property ;
    rdfs:label 'Dedicated Account Manager Flag' ;
    rdfs:comment 'Indicates whether the program provides access to a dedicated customs account manager or liaison officer.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expeditedReleaseFlag rdf:type rdf:Property ;
    rdfs:label 'Expedited Release Flag' ;
    rdfs:comment 'Indicates whether the program membership provides access to expedited customs clearance or release procedures.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent compliance audit, validation visit, or review conducted by the certifying authority.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastSelfAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Self Assessment Date' ;
    rdfs:comment 'Date when the most recent internal compliance self-assessment or security profile review was completed.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:membershipStatus rdf:type rdf:Property ;
    rdfs:label 'Membership Status' ;
    rdfs:comment 'Current lifecycle status of the compliance program membership or certification. [ENUM-REF-CANDIDATE: active|pending|suspended|revoked|expired|withdrawn|under_review — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipTier rdf:type rdf:Property ;
    rdfs:label 'Membership Tier' ;
    rdfs:comment 'Level or tier of membership within the program (e.g., Tier 1, Tier 2, Tier 3 for C-TPAT; Full AEO, AEO-C, AEO-S for EU AEO). Empty if program has no tier structure.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mutualRecognitionCountries rdf:type rdf:Property ;
    rdfs:label 'Mutual Recognition Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where this program membership is recognized through mutual recognition agreements (MRAs).' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Date' ;
    rdfs:comment 'Scheduled date for the next compliance audit, validation visit, or periodic review.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:participantType rdf:type rdf:Property ;
    rdfs:label 'Participant Type' ;
    rdfs:comment 'Role or capacity in which Transport Shipping or its client participates in the compliance program. [ENUM-REF-CANDIDATE: importer|exporter|carrier|broker|warehouse|manufacturer|consolidator|forwarder — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityProcessingFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Processing Flag' ;
    rdfs:comment 'Indicates whether shipments under this program receive priority processing during customs clearance.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programBenefitsDescription rdf:type rdf:Property ;
    rdfs:label 'Program Benefits Description' ;
    rdfs:comment 'Detailed narrative description of all benefits, privileges, and advantages conferred by this program membership.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Official name of the trade compliance or trusted trader program (e.g., C-TPAT, AEO, ISO 28000, FAST, PIP).' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'Classification of the compliance program by its primary focus area (trusted trader, security, quality, environmental, customs partnership).' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programWebsiteUrl rdf:type rdf:Property ;
    rdfs:label 'Program Website Url' ;
    rdfs:comment 'Official website URL of the compliance program for reference and documentation access.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reducedExaminationRateFlag rdf:type rdf:Property ;
    rdfs:label 'Reduced Examination Rate Flag' ;
    rdfs:comment 'Indicates whether the program membership grants eligibility for reduced physical or documentary examination rates at customs.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Due Date' ;
    rdfs:comment 'Date by which renewal application or recertification must be submitted to maintain continuous membership.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'Current status of the membership renewal or recertification process.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationReason rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason' ;
    rdfs:comment 'Explanation of the reason for revocation if membership was revoked. Null if not revoked.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityCriteriaMetFlag rdf:type rdf:Property ;
    rdfs:label 'Security Criteria Met Flag' ;
    rdfs:comment 'Indicates whether all mandatory security criteria and minimum security requirements of the program are currently met.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilityPartnerId rdf:type rdf:Property ;
    rdfs:label 'Facility Partner Id' ;
    rdfs:comment 'Foreign key linking to network.partner. Business justification: Customs holds require physical examination/storage at a facility (CFS, bonded warehouse, examination site) operated by a partner. Links hold to the facility partner for operational coordination, cost ' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:aeoCertifiedIndicator rdf:type rdf:Property ;
    rdfs:label 'Aeo Certified Indicator' ;
    rdfs:comment 'Flag indicating whether the shipper or consignee holds Authorized Economic Operator (AEO) certification, which may expedite hold resolution. True if certified, False otherwise.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cTpatCertifiedIndicator rdf:type rdf:Property ;
    rdfs:label 'C Tpat Certified Indicator' ;
    rdfs:comment 'Flag indicating whether the shipper or consignee holds C-TPAT certification, which may expedite hold resolution. True if certified, False otherwise.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countryOfExaminationCode rdf:type rdf:Property ;
    rdfs:label 'Country Of Examination Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code where the examination took place (e.g., USA, GBR, DEU).' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationSentIndicator rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Sent Indicator' ;
    rdfs:comment 'Flag indicating whether the customer was notified about the customs hold. True if notification was sent, False otherwise.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:durationHours rdf:type rdf:Property ;
    rdfs:label 'Duration Hours' ;
    rdfs:comment 'Total duration of the hold in hours, calculated from hold placed timestamp to actual release timestamp. Used for Service Level Agreement (SLA) impact analysis.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:examinationFindings rdf:type rdf:Property ;
    rdfs:label 'Examination Findings' ;
    rdfs:comment 'Detailed narrative of the examination findings, including any discrepancies, violations, or compliance issues discovered during the inspection.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinationLocation rdf:type rdf:Property ;
    rdfs:label 'Examination Location' ;
    rdfs:comment 'Physical location where the examination was conducted (e.g., port facility, Container Freight Station (CFS), bonded warehouse, Inland Container Depot (ICD)).' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinationResultCode rdf:type rdf:Property ;
    rdfs:label 'Examination Result Code' ;
    rdfs:comment 'Outcome of the customs examination. CLEARED = no issues found, DISCREPANCY_FOUND = documentation or commodity discrepancies identified, VIOLATION_DETECTED = regulatory violation discovered, ADDITIONAL_DUTY_ASSESSED = additional duties or taxes levied, SEIZURE = goods seized, PENALTY_ISSUED = monetary penalty imposed.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinationTypeCode rdf:type rdf:Property ;
    rdfs:label 'Examination Type Code' ;
    rdfs:comment 'Type of physical or documentary examination conducted. VACIS = Vehicle and Cargo Inspection System (non-intrusive imaging), CET = Container Examination Team (physical inspection), INTENSIVE = full intensive examination, TAILGATE = tailgate inspection, DOCUMENT_ONLY = documentary review only, NO_EXAM = hold released without examination.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Expected Release Date' ;
    rdfs:comment 'Anticipated date when the hold is expected to be resolved and the shipment released, based on examination schedule and processing timelines.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdNumber rdf:type rdf:Property ;
    rdfs:label 'Hold Number' ;
    rdfs:comment 'Externally-known unique identifier or reference number assigned to this customs hold by the issuing authority or internal system.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdStatus rdf:type rdf:Property ;
    rdfs:label 'Hold Status' ;
    rdfs:comment 'Current lifecycle status of the customs hold. ACTIVE = hold is in effect, PENDING_RELEASE = awaiting clearance, RELEASED = hold has been lifted, ESCALATED = requires higher-level review, CANCELLED = hold was cancelled or withdrawn.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthorityCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Code' ;
    rdfs:comment 'Code identifying the customs authority or regulatory agency that placed the hold (e.g., CBP, USDA, FDA, port authority, internal compliance team).' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Name' ;
    rdfs:comment 'Full name of the customs authority or regulatory agency that issued the hold.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingOfficerBadgeNumber rdf:type rdf:Property ;
    rdfs:label 'Issuing Officer Badge Number' ;
    rdfs:comment 'Badge or identification number of the customs officer who placed the hold.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingOfficerName rdf:type rdf:Property ;
    rdfs:label 'Issuing Officer Name' ;
    rdfs:comment 'Name of the customs officer or inspector who placed the hold.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the penalty amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Placed Timestamp' ;
    rdfs:comment 'Date and time when the customs hold was officially placed on the shipment. Principal business event timestamp for this transaction.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Detailed narrative explanation of why the customs hold was placed, including any specific regulatory concerns or compliance issues identified.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionActionCode rdf:type rdf:Property ;
    rdfs:label 'Resolution Action Code' ;
    rdfs:comment 'Code representing the action taken to resolve the hold (e.g., documentation provided, duty paid, goods returned, goods destroyed, appeal filed).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyCode rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Code' ;
    rdfs:comment 'Code identifying which party is responsible for resolving the hold. SHIPPER = shipper responsible, CONSIGNEE = consignee responsible, BROKER = customs broker responsible, CARRIER = carrier responsible, INTERNAL = internal compliance team responsible.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachIndicator rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Indicator' ;
    rdfs:comment 'Flag indicating whether the hold caused a breach of the shipment Service Level Agreement (SLA) for on-time delivery. True if SLA was breached, False otherwise.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalFinancialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Total Financial Impact Amount' ;
    rdfs:comment 'Total financial impact of the hold including additional duties, penalties, storage fees, and other charges, in the currency specified by total_financial_impact_currency_code.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFinancialImpactCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Total Financial Impact Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the total financial impact amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeCode rdf:type rdf:Property ;
    rdfs:label 'Type Code' ;
    rdfs:comment 'Classification of the customs hold type. CBP_EXAM = Customs and Border Protection examination, USDA_INSPECTION = United States Department of Agriculture inspection, FDA_INSPECTION = Food and Drug Administration inspection, SECURITY_HOLD = security-related detention, COMPLIANCE_REVIEW = internal compliance review, DOCUMENTATION_REVIEW = documentation verification hold.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:determinationMethod rdf:type rdf:Property ;
    rdfs:label 'Determination Method' ;
    rdfs:comment 'The method used to determine country of origin: wholly obtained (goods entirely produced in one country), substantial transformation (goods undergo significant processing), tariff shift (change in HS classification), value added content (percentage of value added in origin country), change in tariff classification, or regional value content (for trade agreement purposes).' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:determinedByUser rdf:type rdf:Property ;
    rdfs:label 'Determined By User' ;
    rdfs:comment 'Name or identifier of the customs specialist or trade compliance officer who made the origin determination.' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutySavingsAmount rdf:type rdf:Property ;
    rdfs:label 'Duty Savings Amount' ;
    rdfs:comment 'Estimated or actual duty savings realized by claiming preferential origin under the trade agreement.' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dutySavingsCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Duty Savings Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the duty savings amount.' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exporterIdentifier rdf:type rdf:Property ;
    rdfs:label 'Exporter Identifier' ;
    rdfs:comment 'Tax ID, customs registration number, or other official identifier of the exporter.' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exporterName rdf:type rdf:Property ;
    rdfs:label 'Exporter Name' ;
    rdfs:comment 'Name of the exporting party who prepared or provided the origin documentation.' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthorityCountryCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 code of the country where the issuing authority is located.' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialsCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Materials Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for materials values.' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonOriginatingMaterialsValue rdf:type rdf:Property ;
    rdfs:label 'Non Originating Materials Value' ;
    rdfs:comment 'Total value of non-originating materials used in production, relevant for regional value content calculations.' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originCriterionMet rdf:type rdf:Property ;
    rdfs:label 'Origin Criterion Met' ;
    rdfs:comment 'Specific origin criterion satisfied under the applicable trade agreement (e.g., Criterion A: wholly obtained, Criterion B: produced exclusively from originating materials, Criterion C: tariff shift rule met).' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingMaterialsValue rdf:type rdf:Property ;
    rdfs:label 'Originating Materials Value' ;
    rdfs:comment 'Total value of originating materials used in production, relevant for regional value content calculations.' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferentialTariffRatePercent rdf:type rdf:Property ;
    rdfs:label 'Preferential Tariff Rate Percent' ;
    rdfs:comment 'The preferential duty rate (as percentage) claimed under the applicable trade agreement based on this origin determination.' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionLocation rdf:type rdf:Property ;
    rdfs:label 'Production Location' ;
    rdfs:comment 'Specific facility, plant, or location where the goods were produced or substantially transformed.' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionalValueContentPercent rdf:type rdf:Property ;
    rdfs:label 'Regional Value Content Percent' ;
    rdfs:comment 'Percentage of regional value content calculated for trade agreement compliance, representing the proportion of value added within the trade agreement region.' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rvcCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Rvc Calculation Method' ;
    rdfs:comment 'Method used to calculate regional value content: transaction value (based on sale price), net cost (based on production costs), build-up (sum of originating materials and costs), or build-down (subtract non-originating materials from total value).' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardTariffRatePercent rdf:type rdf:Property ;
    rdfs:label 'Standard Tariff Rate Percent' ;
    rdfs:comment 'The standard (Most Favored Nation) duty rate that would apply without preferential origin, for comparison purposes.' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportingDocumentType rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Type' ;
    rdfs:comment 'Type of documentation supporting the origin determination: certificate of origin (traditional paper certificate), EUR.1 (EU preferential certificate), Form A (GSP certificate), REX declaration (Registered Exporter system), USMCA certification, manufacturer affidavit, supplier declaration, or origin declaration on commercial invoice. [ENUM-REF-CANDIDATE: certificate_of_origin|eur1|form_a|rex_declaration|usmca_certification|manufacturer_affidavit|supplier_declaration|origin_declaration — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffShiftRuleMet rdf:type rdf:Property ;
    rdfs:label 'Tariff Shift Rule Met' ;
    rdfs:comment 'Description of the specific tariff shift rule satisfied (e.g., change from any other chapter, change from any other heading, change from any other subheading).' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'Date on which the customs authority verified or audited this origin determination.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Verification Reference Number' ;
    rdfs:comment 'Reference number assigned by customs authority during verification or audit of the origin determination.' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedByCustomsAuthority rdf:type rdf:Property ;
    rdfs:label 'Verified By Customs Authority' ;
    rdfs:comment 'Indicates whether this origin determination has been verified or audited by the destination country customs authority.' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificateStatus rdf:type rdf:Property ;
    rdfs:label 'Certificate Status' ;
    rdfs:comment 'Current lifecycle status of the certificate. Draft indicates preparation; issued means certificate is active; endorsed means validated by authority; revoked means certificate has been invalidated; expired means validity period has passed; pending approval means awaiting authority review.' ;
    rdfs:domain ind:CertificateOfOrigin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateType rdf:type rdf:Property ;
    rdfs:label 'Certificate Type' ;
    rdfs:comment 'Type of certificate of origin. Preferential certificates support duty reduction under trade agreements; non-preferential certificates confirm origin without tariff benefits; GSP Form A for Generalized System of Preferences; EUR.1 for EU trade; USMCA for United States-Mexico-Canada Agreement; RCEP for Regional Comprehensive Economic Partnership.' ;
    rdfs:domain ind:CertificateOfOrigin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneeCountryCode rdf:type rdf:Property ;
    rdfs:label 'Consignee Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the destination country where the consignee is located.' ;
    rdfs:domain ind:CertificateOfOrigin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneeIdentifier rdf:type rdf:Property ;
    rdfs:label 'Consignee Identifier' ;
    rdfs:comment 'Unique business identifier for the consignee, such as tax ID, EORI number, or customs registration number.' ;
    rdfs:domain ind:CertificateOfOrigin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endorsementDate rdf:type rdf:Property ;
    rdfs:label 'Endorsement Date' ;
    rdfs:comment 'Date when the certificate was endorsed or validated by the issuing authority. Nullable if not yet endorsed.' ;
    rdfs:domain ind:CertificateOfOrigin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:endorsementOfficialName rdf:type rdf:Property ;
    rdfs:label 'Endorsement Official Name' ;
    rdfs:comment 'Name of the official or authorized signatory who endorsed the certificate. Nullable if not yet endorsed.' ;
    rdfs:domain ind:CertificateOfOrigin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportDeclarationNumber rdf:type rdf:Property ;
    rdfs:label 'Export Declaration Number' ;
    rdfs:comment 'Reference number of the export customs declaration to which this certificate is linked.' ;
    rdfs:domain ind:CertificateOfOrigin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsDescription rdf:type rdf:Property ;
    rdfs:label 'Goods Description' ;
    rdfs:comment 'Detailed description of the goods covered by this certificate, including product name, specifications, and characteristics sufficient for customs identification.' ;
    rdfs:domain ind:CertificateOfOrigin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'Date of the commercial invoice associated with the goods covered by this certificate.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuingBodyIdentifier rdf:type rdf:Property ;
    rdfs:label 'Issuing Body Identifier' ;
    rdfs:comment 'Unique identifier or registration number of the issuing body, such as chamber registration number or customs authority code.' ;
    rdfs:domain ind:CertificateOfOrigin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBodyName rdf:type rdf:Property ;
    rdfs:label 'Issuing Body Name' ;
    rdfs:comment 'Full legal name of the organization or authority that issued the certificate of origin.' ;
    rdfs:domain ind:CertificateOfOrigin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBodyType rdf:type rdf:Property ;
    rdfs:label 'Issuing Body Type' ;
    rdfs:comment 'Type of organization or authority that issued the certificate. Chamber of commerce for trade association issuance; customs authority for government-issued certificates; exporter self-certification for approved exporter programs; authorized body for designated third-party certifiers.' ;
    rdfs:domain ind:CertificateOfOrigin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the certificate was issued.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originCriterion rdf:type rdf:Property ;
    rdfs:label 'Origin Criterion' ;
    rdfs:comment 'Specific rule or criterion under which the goods qualify for origin status, such as wholly obtained, substantial transformation, regional value content percentage, or change in tariff classification. Format and content vary by trade agreement.' ;
    rdfs:domain ind:CertificateOfOrigin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationDate rdf:type rdf:Property ;
    rdfs:label 'Revocation Date' ;
    rdfs:comment 'Date when the certificate was revoked by the issuing authority. Nullable if certificate has not been revoked.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentReference rdf:type rdf:Property ;
    rdfs:label 'Shipment Reference' ;
    rdfs:comment 'Reference number linking this certificate to the associated export shipment, such as internal shipment ID or booking reference.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalNetWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Net Weight Kg' ;
    rdfs:comment 'Total net weight of all goods covered by this certificate, excluding packaging, measured in kilograms.' ;
    rdfs:domain ind:CertificateOfOrigin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buyerTradePartyId rdf:type rdf:Property ;
    rdfs:label 'Buyer Trade Party Id' ;
    rdfs:comment 'Foreign key linking to customs.trade_party. Business justification: The buyer party in an incoterms assignment is a trade party managed in the customs domain. incoterms_assignment carries buyer_party_name as a STRING denormalized reference. Replacing it with buyer_tra' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeParty .

ind:assignmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Number' ;
    rdfs:comment 'Business-readable unique identifier for the Incoterms assignment. Used for external communication and audit trail purposes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentSource rdf:type rdf:Property ;
    rdfs:label 'Assignment Source' ;
    rdfs:comment 'Indicates the source document or process from which this Incoterms assignment was derived. Supports audit trail and data lineage tracking.' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerCostResponsibility rdf:type rdf:Property ;
    rdfs:label 'Buyer Cost Responsibility' ;
    rdfs:comment 'Detailed enumeration of costs that the buyer is responsible for under the assigned Incoterms rule. Complements seller cost responsibility to provide full cost allocation picture.' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityType rdf:type rdf:Property ;
    rdfs:label 'Commodity Type' ;
    rdfs:comment 'General classification of the commodity being shipped under this Incoterms assignment. Certain commodities may have preferred or restricted Incoterms rules.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'Reference to the sales contract or purchase order that specifies the Incoterms rule for this transaction. Provides traceability to the commercial agreement.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costResponsibilityBoundary rdf:type rdf:Property ;
    rdfs:label 'Cost Responsibility Boundary' ;
    rdfs:comment 'Description of the point up to which the seller bears transportation and logistics costs. Defines the financial split between buyer and seller for freight, handling, and related charges.' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyBasisCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Duty Basis Calculation Method' ;
    rdfs:comment 'Indicates the valuation basis used for customs duty calculation. CIF-based Incoterms include cost, insurance, and freight in the customs value; FOB-based rules include only the goods value. Critical for accurate duty and tax assessment.' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportCustomsClearanceParty rdf:type rdf:Property ;
    rdfs:label 'Export Customs Clearance Party' ;
    rdfs:comment 'Indicates which party is responsible for completing export customs clearance formalities and paying export duties and taxes. Under most Incoterms rules, the seller handles export clearance.' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importCustomsClearanceParty rdf:type rdf:Property ;
    rdfs:label 'Import Customs Clearance Party' ;
    rdfs:comment 'Indicates which party is responsible for completing import customs clearance formalities and paying import duties and taxes. Only under DDP does the seller handle import clearance; under all other rules, the buyer is responsible.' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsRuleCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Rule Code' ;
    rdfs:comment 'The three-letter code representing the specific Incoterms rule assigned to the transaction. Defines the allocation of costs, risks, and responsibilities between buyer and seller. Examples: EXW (Ex Works), FOB (Free on Board), CIF (Cost Insurance and Freight), DDP (Delivered Duty Paid). [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsRuleName rdf:type rdf:Property ;
    rdfs:label 'Incoterms Rule Name' ;
    rdfs:comment 'The full descriptive name of the Incoterms rule. Provides human-readable context for the rule code (e.g., \'Free on Board\', \'Delivered Duty Paid\').' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsVersion rdf:type rdf:Property ;
    rdfs:label 'Incoterms Version' ;
    rdfs:comment 'The version year of the Incoterms rules being applied. Determines which rule set and interpretations govern the transaction. Most common versions are 2020 and 2010.' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCoverageLevel rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Level' ;
    rdfs:comment 'The minimum insurance coverage level required under the Incoterms rule. For CIP, Institute Cargo Clauses (A) or equivalent is required; for CIF, Institute Cargo Clauses (C) or equivalent minimum coverage applies.' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceObligationParty rdf:type rdf:Property ;
    rdfs:label 'Insurance Obligation Party' ;
    rdfs:comment 'Indicates which party (seller or buyer) is obligated to procure cargo insurance under the assigned Incoterms rule. For CIP and CIF, the seller must insure; for most other rules, insurance is optional or buyer\'s responsibility.' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:namedPlace rdf:type rdf:Property ;
    rdfs:label 'Named Place' ;
    rdfs:comment 'The specific location or port designated in the Incoterms rule where risk and cost transfer occurs. This is the critical point that defines obligations (e.g., \'Port of Shanghai\', \'Warehouse in Hamburg\', \'Customer facility in Chicago\').' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:namedPlaceCountryCode rdf:type rdf:Property ;
    rdfs:label 'Named Place Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the country where the named place is located. Supports geographic analysis and customs compliance.' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:namedPlaceType rdf:type rdf:Property ;
    rdfs:label 'Named Place Type' ;
    rdfs:comment 'Classification of the named place location type. Indicates whether the named place is a seaport, airport, inland terminal, warehouse, or customer facility.' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTransferPoint rdf:type rdf:Property ;
    rdfs:label 'Risk Transfer Point' ;
    rdfs:comment 'Detailed description of the exact point at which risk transfers from seller to buyer under the assigned Incoterms rule. Critical for liability determination and insurance coverage decisions.' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerCostResponsibility rdf:type rdf:Property ;
    rdfs:label 'Seller Cost Responsibility' ;
    rdfs:comment 'Detailed enumeration of costs that the seller is responsible for under the assigned Incoterms rule. May include export packing, loading, main carriage, insurance, unloading, and import duties depending on the rule.' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerPartyName rdf:type rdf:Property ;
    rdfs:label 'Seller Party Name' ;
    rdfs:comment 'Name of the seller party in the transaction governed by this Incoterms assignment. Provides business context for liability and cost allocation.' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeLane rdf:type rdf:Property ;
    rdfs:label 'Trade Lane' ;
    rdfs:comment 'The origin-destination trade lane for this transaction (e.g., \'Asia-Europe\', \'Transpacific Eastbound\'). Supports analysis of Incoterms usage patterns by trade corridor.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportModeApplicability rdf:type rdf:Property ;
    rdfs:label 'Transport Mode Applicability' ;
    rdfs:comment 'Indicates whether the assigned Incoterms rule can be used for any mode of transport or is restricted to sea and inland waterway transport only. Rules like FOB, CFR, CIF, FAS are sea/waterway only; rules like EXW, FCA, CPT, CIP, DAP, DPU, DDP apply to any mode.' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedLaneId rdf:type rdf:Property ;
    rdfs:label 'Authorized Lane Id' ;
    rdfs:comment 'Foreign key linking to route.lane. Business justification: Export/import licenses for controlled commodities (ITAR, dual-use, pharmaceuticals) restrict which lanes can be used. License terms specify authorized ports of entry/exit; routing systems must validat' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lane .

ind:authorizedSupplierId rdf:type rdf:Property ;
    rdfs:label 'Authorized Supplier Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier. Business justification: Import/export licenses specify authorized suppliers or beneficiaries for controlled goods. Compliance teams validate shipments against licensed supplier lists, requiring supplier master linkage for li' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:authorizedQuantity rdf:type rdf:Property ;
    rdfs:label 'Authorized Quantity' ;
    rdfs:comment 'Maximum quantity of goods authorized for import or export under this license or permit. Measured in the unit specified in authorized_unit_of_measure.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizedUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Authorized Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the authorized quantity (e.g., kilograms, pieces, liters, cubic meters). Aligns with customs declaration unit standards.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedValueAmount rdf:type rdf:Property ;
    rdfs:label 'Authorized Value Amount' ;
    rdfs:comment 'Maximum monetary value of goods authorized for import or export under this license or permit. Expressed in the currency specified in authorized_value_currency_code.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizedValueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Authorized Value Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the authorized value amount.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endUseDescription rdf:type rdf:Property ;
    rdfs:label 'End Use Description' ;
    rdfs:comment 'Description of the intended end use or purpose of the goods covered by this license. Required for certain controlled items and dual-use export authorizations to ensure compliance with end-use restrictions.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endUserName rdf:type rdf:Property ;
    rdfs:label 'End User Name' ;
    rdfs:comment 'Legal name of the final end user or consignee of the goods covered by this license. Required for export control compliance and denied party screening.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'Official license or permit number issued by the regulatory authority. This is the externally-known unique identifier used for customs declarations and trade compliance filings.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseStatus rdf:type rdf:Property ;
    rdfs:label 'License Status' ;
    rdfs:comment 'Current lifecycle status of the license or permit. Indicates whether the authorization is valid and available for use in customs declarations.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseType rdf:type rdf:Property ;
    rdfs:label 'License Type' ;
    rdfs:comment 'Classification of the license or permit based on regulatory purpose. Determines the type of authorization granted for controlled, restricted, or regulated goods movement.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Previous License Number' ;
    rdfs:comment 'License number of the previous authorization if this is a renewal. Provides audit trail and continuity for renewed licenses.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingQuantity rdf:type rdf:Property ;
    rdfs:label 'Remaining Quantity' ;
    rdfs:comment 'Available balance of quantity that can still be utilized under this license or permit. Calculated as authorized_quantity minus utilized_quantity.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingValueAmount rdf:type rdf:Property ;
    rdfs:label 'Remaining Value Amount' ;
    rdfs:comment 'Available balance of monetary value that can still be utilized under this license or permit. Calculated as authorized_value_amount minus utilized_value_amount.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalIndicator rdf:type rdf:Property ;
    rdfs:label 'Renewal Indicator' ;
    rdfs:comment 'Flag indicating whether this license or permit is a renewal of a previously expired authorization. True if renewal, false if original issuance.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suspensionDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Date' ;
    rdfs:comment 'Date on which the license or permit was suspended by the issuing authority. Indicates when the authorization was temporarily invalidated due to compliance issues or regulatory action.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:utilizedQuantity rdf:type rdf:Property ;
    rdfs:label 'Utilized Quantity' ;
    rdfs:comment 'Cumulative quantity of goods that have been imported or exported against this license or permit to date. Measured in the same unit as authorized_quantity.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizedValueAmount rdf:type rdf:Property ;
    rdfs:label 'Utilized Value Amount' ;
    rdfs:comment 'Cumulative monetary value of goods that have been imported or exported against this license or permit to date. Expressed in the same currency as authorized_value_amount.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commercialAgreementId rdf:type rdf:Property ;
    rdfs:label 'Commercial Agreement Id' ;
    rdfs:comment 'Foreign key linking to contract.agreement. Business justification: Commercial service agreements often reference trade agreements (USMCA, EU FTAs) to validate preferential rate eligibility, origin compliance requirements, and duty drawback programs. Linking trade agr' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:administeringAuthority rdf:type rdf:Property ;
    rdfs:label 'Administering Authority' ;
    rdfs:comment 'Name of the international body, secretariat, or national agency responsible for administering and monitoring compliance with the trade agreement (e.g., WTO Secretariat, European Commission DG Trade, USTR).' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementCode rdf:type rdf:Property ;
    rdfs:label 'Agreement Code' ;
    rdfs:comment 'Standardized short code or abbreviation for the trade agreement (e.g., USMCA, CPTPP, EU-UK_TCA). Used for system lookups and operational references.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementName rdf:type rdf:Property ;
    rdfs:label 'Agreement Name' ;
    rdfs:comment 'Full official name of the trade agreement as published by the administering authority (e.g., United States-Mexico-Canada Agreement, Comprehensive and Progressive Agreement for Trans-Pacific Partnership).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the trade agreement. FTA (Free Trade Agreement) = reciprocal tariff elimination; Customs Union = common external tariff; GSP (Generalized System of Preferences) = unilateral preference; EBA (Everything But Arms) = duty-free for LDCs; Bilateral = two parties; Multilateral = three or more parties.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityWebsiteUrl rdf:type rdf:Property ;
    rdfs:label 'Authority Website Url' ;
    rdfs:comment 'Official website URL of the administering authority where the full text of the agreement, tariff schedules, and implementation guidance are published.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateOfOriginFormat rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Origin Format' ;
    rdfs:comment 'Standardized format or form type required for the Certificate of Origin under this agreement (e.g., Form A for GSP, EUR.1 for EU agreements, self-certification for USMCA).' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateOfOriginRequired rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Origin Required' ;
    rdfs:comment 'Indicates whether a formal Certificate of Origin document must be presented to customs authorities to claim preferential duty rates under this agreement. True = COO required; False = self-certification or no certification required.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cumulationRules rdf:type rdf:Property ;
    rdfs:label 'Cumulation Rules' ;
    rdfs:comment 'Type of origin cumulation permitted under the agreement. Bilateral = materials from partner country count as originating; Diagonal = materials from multiple FTA partners cumulate; Full = all processing in partner countries cumulates; None = no cumulation allowed.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Name of the source system or database from which this trade agreement record was ingested (e.g., Descartes Customs GTM, WTO RTA Database, internal trade compliance repository).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalTradeProvisions rdf:type rdf:Property ;
    rdfs:label 'Digital Trade Provisions' ;
    rdfs:comment 'Indicates whether the agreement includes provisions on e-commerce, cross-border data flows, digital services, and prohibition of data localization requirements. True = digital trade provisions included; False = no digital trade provisions.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeResolutionMechanism rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Mechanism' ;
    rdfs:comment 'Summary of the dispute settlement procedures established by the agreement for resolving conflicts between member countries regarding interpretation or implementation (e.g., arbitration panels, joint committees).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalProvisions rdf:type rdf:Property ;
    rdfs:label 'Environmental Provisions' ;
    rdfs:comment 'Indicates whether the agreement includes commitments on environmental protection, sustainable development, and enforcement of environmental laws. True = environmental provisions included; False = no environmental provisions.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governmentProcurementProvisions rdf:type rdf:Property ;
    rdfs:label 'Government Procurement Provisions' ;
    rdfs:comment 'Indicates whether the agreement opens government procurement markets to suppliers from member countries on a non-discriminatory basis. True = procurement provisions included; False = no procurement provisions.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intellectualPropertyProvisions rdf:type rdf:Property ;
    rdfs:label 'Intellectual Property Provisions' ;
    rdfs:comment 'Indicates whether the agreement includes chapters or provisions on intellectual property rights protection, enforcement, and cooperation. True = IP provisions included; False = no IP provisions.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investmentProvisions rdf:type rdf:Property ;
    rdfs:label 'Investment Provisions' ;
    rdfs:comment 'Indicates whether the agreement includes provisions on foreign direct investment protection, investor-state dispute settlement, and national treatment for investors. True = investment provisions included; False = no investment provisions.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborStandardsProvisions rdf:type rdf:Property ;
    rdfs:label 'Labor Standards Provisions' ;
    rdfs:comment 'Indicates whether the agreement includes enforceable labor rights and working conditions standards aligned with International Labour Organization (ILO) conventions. True = labor provisions included; False = no labor provisions.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mutualRecognitionAgreements rdf:type rdf:Property ;
    rdfs:label 'Mutual Recognition Agreements' ;
    rdfs:comment 'Description of any mutual recognition agreements for conformity assessment, product standards, professional qualifications, or Authorized Economic Operator (AEO) programs included in or linked to the trade agreement.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participatingCountries rdf:type rdf:Property ;
    rdfs:label 'Participating Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes representing all member countries or customs territories party to the agreement (e.g., USA,CAN,MEX for USMCA).' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCoverageScope rdf:type rdf:Property ;
    rdfs:label 'Product Coverage Scope' ;
    rdfs:comment 'Defines the breadth of goods and services covered by the trade agreement. All Goods = comprehensive coverage; Industrial Goods Only = excludes agriculture; Agricultural Excluded = industrial focus; Services Included = covers trade in services; Limited Product List = specific HS Codes only.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaProvisions rdf:type rdf:Property ;
    rdfs:label 'Quota Provisions' ;
    rdfs:comment 'Description of any tariff-rate quotas (TRQs) or quantitative restrictions included in the agreement. Specifies product categories subject to quota limits and the preferential in-quota duty rates.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycleYears rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Years' ;
    rdfs:comment 'Number of years between scheduled reviews or renegotiations of the trade agreement by member countries. Used to track when agreement terms may be updated or modernized.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rulesOfOriginCriteria rdf:type rdf:Property ;
    rdfs:label 'Rules Of Origin Criteria' ;
    rdfs:comment 'Summary of the origin determination rules required to qualify for preferential treatment under this agreement (e.g., change in tariff classification, regional value content percentage, specific processing requirements). Full rules are maintained in tariff_rate product.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safeguardMeasures rdf:type rdf:Property ;
    rdfs:label 'Safeguard Measures' ;
    rdfs:comment 'Summary of bilateral safeguard provisions that allow temporary suspension or modification of preferential treatment if imports cause or threaten serious injury to domestic industry.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureDate rdf:type rdf:Property ;
    rdfs:label 'Signature Date' ;
    rdfs:comment 'Date when the trade agreement was formally signed by participating parties, prior to ratification and entry into force.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supersededByAgreementCode rdf:type rdf:Property ;
    rdfs:label 'Superseded By Agreement Code' ;
    rdfs:comment 'Agreement code of the successor trade agreement that replaced this agreement, if applicable. Used to maintain historical lineage when agreements are renegotiated or replaced (e.g., NAFTA superseded by USMCA).' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffEliminationSchedule rdf:type rdf:Property ;
    rdfs:label 'Tariff Elimination Schedule' ;
    rdfs:comment 'Classification of the duty reduction timeline under the agreement. Immediate = zero duty on entry into force; Staged = phased reduction over specified years; Partial = some products excluded; Product Specific = varies by HS Code.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Trade Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the trade agreement. In Force = active and applicable; Under Negotiation = being drafted; Signed Not Ratified = awaiting legislative approval; Suspended = temporarily inactive; Terminated = ended by parties; Expired = reached end date.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeFacilitationProvisions rdf:type rdf:Property ;
    rdfs:label 'Trade Facilitation Provisions' ;
    rdfs:comment 'Description of customs procedures simplification, advance rulings, single window systems, and other trade facilitation commitments included in the agreement to reduce border clearance times and costs.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wtoNotificationNumber rdf:type rdf:Property ;
    rdfs:label 'Wto Notification Number' ;
    rdfs:comment 'WTO Regional Trade Agreement notification number assigned when the agreement was notified to the WTO under GATT Article XXIV or GATS Article V (e.g., WT/REG123/N/1).' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationRouteDeliveryZoneId rdf:type rdf:Property ;
    rdfs:label 'Destination Route Delivery Zone Id' ;
    rdfs:comment 'Foreign key linking to route.route_delivery_zone. Business justification: Destination postal code maps to a delivery zone determining surcharges, service days, OTD targets, and last-mile carrier assignment. Zone-based billing, SLA reporting, and COD restriction checks requi' ;
    rdfs:domain ind:Consignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RouteDeliveryZone .

ind:bookingChannel rdf:type rdf:Property ;
    rdfs:label 'Booking Channel' ;
    rdfs:comment 'The channel through which the consignment was booked: web portal, mobile app, API integration, EDI, call center, branch office, or partner system. [ENUM-REF-CANDIDATE: web_portal|mobile_app|api|edi|call_center|branch|partner — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Consignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Booking Timestamp' ;
    rdfs:comment 'The precise date and time when the consignment booking was created in the system.' ;
    rdfs:domain ind:Consignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:committedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Committed Delivery Date' ;
    rdfs:comment 'The date by which delivery is committed to the customer per the service level agreement.' ;
    rdfs:domain ind:Consignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:committedDeliveryTime rdf:type rdf:Property ;
    rdfs:label 'Committed Delivery Time' ;
    rdfs:comment 'The precise date and time by which delivery is committed to the customer per the service level agreement.' ;
    rdfs:domain ind:Consignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consigneeContactPhone rdf:type rdf:Property ;
    rdfs:label 'Consignee Contact Phone' ;
    rdfs:comment 'The contact phone number for the consignee or receiver.' ;
    rdfs:domain ind:Consignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredValueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Declared Value Currency Code' ;
    rdfs:comment 'The three-letter ISO currency code for the declared value amount.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredWeightKg rdf:type rdf:Property ;
    rdfs:label 'Declared Weight Kg' ;
    rdfs:comment 'The actual or declared gross weight of the consignment in kilograms as provided by the shipper.' ;
    rdfs:domain ind:Consignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryInstructionType rdf:type rdf:Property ;
    rdfs:label 'Delivery Instruction Type' ;
    rdfs:comment 'The type of special delivery instruction provided by the customer (e.g., signature required, leave at door, call before delivery, safe place).' ;
    rdfs:domain ind:Consignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCod rdf:type rdf:Property ;
    rdfs:label 'Is Cod' ;
    rdfs:comment 'Indicates whether this consignment requires cash on delivery payment collection from the consignee.' ;
    rdfs:domain ind:Consignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOtdTarget rdf:type rdf:Property ;
    rdfs:label 'Is Otd Target' ;
    rdfs:comment 'Indicates whether this consignment is included in on-time delivery performance measurement and reporting.' ;
    rdfs:domain ind:Consignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOtifTarget rdf:type rdf:Property ;
    rdfs:label 'Is Otif Target' ;
    rdfs:comment 'Indicates whether this consignment is included in on-time in-full performance measurement and reporting.' ;
    rdfs:domain ind:Consignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Origin Address Line1' ;
    rdfs:comment 'The first line of the pickup or origin address for the consignment.' ;
    rdfs:domain ind:Consignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originCity rdf:type rdf:Property ;
    rdfs:label 'Origin City' ;
    rdfs:comment 'The city or municipality of the consignment origin location.' ;
    rdfs:domain ind:Consignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originPostalCode rdf:type rdf:Property ;
    rdfs:label 'Origin Postal Code' ;
    rdfs:comment 'The postal or ZIP code of the consignment origin location.' ;
    rdfs:domain ind:Consignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperContactPhone rdf:type rdf:Property ;
    rdfs:label 'Shipper Contact Phone' ;
    rdfs:comment 'The contact phone number for the shipper or sender.' ;
    rdfs:domain ind:Consignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperName rdf:type rdf:Property ;
    rdfs:label 'Shipper Name' ;
    rdfs:comment 'The full name of the shipper or sender of the consignment.' ;
    rdfs:domain ind:Consignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaSource rdf:type rdf:Property ;
    rdfs:label 'Sla Source' ;
    rdfs:comment 'The source of the service level commitment: customer contract, published rate card, spot booking, or standard terms.' ;
    rdfs:domain ind:Consignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingNotes rdf:type rdf:Property ;
    rdfs:label 'Special Handling Notes' ;
    rdfs:comment 'Free-text notes describing any special handling requirements, access instructions, or delivery preferences for the consignment.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumetricWeightKg rdf:type rdf:Property ;
    rdfs:label 'Volumetric Weight Kg' ;
    rdfs:comment 'The dimensional or volumetric weight calculated based on the consignment dimensions, used for pricing when it exceeds actual weight.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryAgentId rdf:type rdf:Property ;
    rdfs:label 'Delivery Agent Id' ;
    rdfs:comment 'Reference to the delivery agent or driver assigned to execute this leg. Primarily used for last-mile delivery legs to track individual courier performance.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:delayDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Delay Duration Minutes' ;
    rdfs:comment 'Total delay time in minutes calculated as the difference between planned and actual timestamps. Used for SLA breach detection and performance reporting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryAttemptNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Attempt Number' ;
    rdfs:comment 'Count of delivery attempts made for this leg. Increments with each failed delivery attempt. Used for last-mile legs to track delivery success rates and customer availability.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispatchSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Dispatch Sequence Number' ;
    rdfs:comment 'Order of this delivery within the drivers daily dispatch route. Used for last-mile legs to optimize delivery sequence and track route adherence.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:equipmentTypeCode rdf:type rdf:Property ;
    rdfs:label 'Equipment Type Code' ;
    rdfs:comment 'Code identifying the type of transport equipment used (e.g., 20ft container, 40ft reefer, flatbed truck, pallet). Follows ISO 6346 for containers or internal classification for other equipment.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etaPredictionSource rdf:type rdf:Property ;
    rdfs:label 'Eta Prediction Source' ;
    rdfs:comment 'System or method that generated the predicted ETA. Identifies whether the prediction came from FourKites AI engine, carrier EDI feed, manual operator input, TMS route calculation, GPS tracking, or IoT sensor data.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsTrackingEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Gps Tracking Enabled Flag' ;
    rdfs:comment 'Indicates whether real-time GPS tracking is active for this leg. True when vehicle/container has active GPS device transmitting location data.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:predictedEtaConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Predicted Eta Confidence Score' ;
    rdfs:comment 'Confidence level of the predicted ETA expressed as a percentage (0.00 to 100.00). Higher scores indicate greater certainty in the prediction based on data quality and model accuracy.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:predictedEtaTimestamp rdf:type rdf:Property ;
    rdfs:label 'Predicted Eta Timestamp' ;
    rdfs:comment 'Real-time predicted arrival timestamp generated by AI/ML models or carrier systems. Updated dynamically based on current location, traffic, weather, and historical patterns.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:vehicleReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Vehicle Reference Number' ;
    rdfs:comment 'Identifier for the vehicle, vessel, aircraft, or rail car used for this leg. May be truck license plate, vessel IMO number, aircraft tail number, or rail car number.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingEventId rdf:type rdf:Property ;
    rdfs:label 'Tracking Event Id' ;
    rdfs:comment 'Unique identifier for the tracking event record. Primary key. Immutable once assigned.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:apiTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Api Transaction Reference' ;
    rdfs:comment 'Unique identifier of the API call or transaction that created this event record. Used for API audit trail and troubleshooting. Nullable for non-API events.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageReported rdf:type rdf:Property ;
    rdfs:label 'Damage Reported' ;
    rdfs:comment 'Indicates whether damage to the shipment was observed and reported during this event. True if damage detected, False otherwise. Triggers claims workflow.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediMessageReference rdf:type rdf:Property ;
    rdfs:label 'Edi Message Reference' ;
    rdfs:comment 'Unique identifier of the EDI message that generated this event, if applicable. Used for EDI 214 carrier status messages and event reconciliation.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Timestamp' ;
    rdfs:comment 'Updated ETA (Estimated Time of Arrival) for final delivery, recalculated at the time of this event. Predictive ETA updates from FourKites or carrier systems. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventCategory rdf:type rdf:Property ;
    rdfs:label 'Event Category' ;
    rdfs:comment 'High-level classification of the event type. Tracking events are carrier-reported milestones; hub operations are internal facility scans; exceptions are deviations or delays; lifecycle events are status transitions.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDescription rdf:type rdf:Property ;
    rdfs:label 'Event Description' ;
    rdfs:comment 'Human-readable narrative description of the event. May include raw event text from carrier or system source. Used for audit trail and customer communication.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTypeCode rdf:type rdf:Property ;
    rdfs:label 'Event Type Code' ;
    rdfs:comment 'Standardized code representing the specific event type. Examples: PICKUP, DEPARTED, ARRIVED, IN_TRANSIT, SORTED, LOADED_OUTBOUND, OUT_FOR_DELIVERY, DELIVERED, EXCEPTION_DELAY, EXCEPTION_DAMAGE, STATUS_CHANGE. Aligns with IATA and carrier EDI standards.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Exception Reason Code' ;
    rdfs:comment 'Standardized code indicating the root cause of the exception. Examples: WEATHER_DELAY, CUSTOMS_HOLD, ADDRESS_INCORRECT, DAMAGE_IN_TRANSIT, REFUSED_BY_CONSIGNEE. Only populated for exception events.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionResolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Exception Resolution Notes' ;
    rdfs:comment 'Free-text notes documenting how the exception was resolved, actions taken, and any follow-up required. Only populated for exception events.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionResolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Exception Resolution Status' ;
    rdfs:comment 'Current resolution state of the exception. Only populated for exception events. Tracks whether the issue has been addressed.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionResolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exception Resolution Timestamp' ;
    rdfs:comment 'Date and time when the exception was resolved. Only populated for exception events that have been closed. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gpsLatitude rdf:type rdf:Property ;
    rdfs:label 'Gps Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the event location in decimal degrees. Range: -90.0000000 to +90.0000000. Captured from GPS-enabled devices or FourKites real-time tracking.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsLongitude rdf:type rdf:Property ;
    rdfs:label 'Gps Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the event location in decimal degrees. Range: -180.0000000 to +180.0000000. Captured from GPS-enabled devices or FourKites real-time tracking.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:humidityPercentage rdf:type rdf:Property ;
    rdfs:label 'Humidity Percentage' ;
    rdfs:comment 'Relative humidity percentage recorded at the time of the event. Used for sensitive cargo monitoring. Range: 0.00 to 100.00. Nullable for non-humidity-controlled shipments.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationCity rdf:type rdf:Property ;
    rdfs:label 'Location City' ;
    rdfs:comment 'City name where the tracking event occurred. Used for customer visibility and geographic analytics.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Location Country Code' ;
    rdfs:comment 'Three-letter ISO country code where the event occurred. Examples: USA, CAN, GBR, DEU, CHN.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationPostalCode rdf:type rdf:Property ;
    rdfs:label 'Location Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the event location. Used for last-mile delivery precision and route optimization.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationStateProvince rdf:type rdf:Property ;
    rdfs:label 'Location State Province' ;
    rdfs:comment 'State or province code where the event occurred. ISO 3166-2 subdivision code preferred.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newStatus rdf:type rdf:Property ;
    rdfs:label 'New Status' ;
    rdfs:comment 'The shipment status after this lifecycle event. Only populated for event_category = lifecycle. Represents the state transition target.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podImageUrl rdf:type rdf:Property ;
    rdfs:label 'Pod Image Url' ;
    rdfs:comment 'URL or storage path to the scanned or photographed proof of delivery document. Used for audit and claims resolution.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podRecipientName rdf:type rdf:Property ;
    rdfs:label 'Pod Recipient Name' ;
    rdfs:comment 'Name of the person who received and signed for the shipment. Only populated for delivered events with POD. Personally identifiable information.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podSignatureCaptured rdf:type rdf:Property ;
    rdfs:label 'Pod Signature Captured' ;
    rdfs:comment 'Indicates whether a physical or electronic signature was captured at delivery. True if signature obtained, False otherwise. Used for delivery verification and dispute resolution.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:previousStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Status' ;
    rdfs:comment 'The shipment status immediately before this lifecycle event. Only populated for event_category = lifecycle. Enables status transition audit trail.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Record Source System' ;
    rdfs:comment 'Name of the operational system that originally created this event record. Examples: SAP TM, Oracle TMS, Manhattan WMS, FourKites, carrier EDI gateway. Used for data lineage and quality assessment.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanType rdf:type rdf:Property ;
    rdfs:label 'Scan Type' ;
    rdfs:comment 'Method used to capture the tracking event. Barcode: handheld or fixed scanner; RFID: radio frequency identification; Manual: keyboard entry; OCR: optical character recognition.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Celsius' ;
    rdfs:comment 'Ambient or cargo temperature recorded at the time of the event, in degrees Celsius. Used for cold chain monitoring and compliance. Nullable for non-temperature-controlled shipments.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:podId rdf:type rdf:Property ;
    rdfs:label 'Pod Id' ;
    rdfs:comment 'Unique identifier for the proof of delivery record. Primary key for the POD entity.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryTransportAssetId rdf:type rdf:Property ;
    rdfs:label 'Delivery Transport Asset Id' ;
    rdfs:comment 'Foreign key linking to fleet.transport_asset. Business justification: Proof of delivery must record which vehicle performed the delivery for driver accountability, vehicle performance tracking, and dispute resolution. Role-prefixed because delivery context is specific. ' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransportAsset .

ind:paymentId rdf:type rdf:Property ;
    rdfs:label 'Payment Id' ;
    rdfs:comment 'Foreign key linking to billing.payment. Business justification: COD remittance reconciliation: POD records cash/card collected at delivery (cod_amount, amount_collected). This collected amount must be matched to a payment record in billing for COD remittance recon' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payment .

ind:amountCollected rdf:type rdf:Property ;
    rdfs:label 'Amount Collected' ;
    rdfs:comment 'The actual amount collected from the recipient at delivery. May differ from COD amount if partial payment or variance occurred.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:codCurrency rdf:type rdf:Property ;
    rdfs:label 'Cod Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the COD amount to be collected.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Collection Timestamp' ;
    rdfs:comment 'The exact date and time when the COD payment was collected from the recipient. May differ slightly from delivery timestamp if payment processing occurred after handover.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:collectionVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Collection Variance Amount' ;
    rdfs:comment 'The difference between the COD amount and the amount collected. Positive value indicates over-collection, negative indicates under-collection or shortfall.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line1' ;
    rdfs:comment 'First line of the physical address where the delivery was completed. Captures street number and street name.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line2' ;
    rdfs:comment 'Second line of the delivery address. May include apartment number, suite, building name, or other secondary address details.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCity rdf:type rdf:Property ;
    rdfs:label 'Delivery City' ;
    rdfs:comment 'City or municipality where the delivery was completed.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the delivery location.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryExceptionCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Exception Code' ;
    rdfs:comment 'Standardized code indicating any exception or deviation from normal delivery process noted at the time of delivery (e.g., damaged package, partial delivery, refused).' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLatitude rdf:type rdf:Property ;
    rdfs:label 'Delivery Latitude' ;
    rdfs:comment 'GPS latitude coordinate of the exact delivery location captured by the delivery agent\'s device at the time of delivery.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryLongitude rdf:type rdf:Property ;
    rdfs:label 'Delivery Longitude' ;
    rdfs:comment 'GPS longitude coordinate of the exact delivery location captured by the delivery agent\'s device at the time of delivery.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryNotes rdf:type rdf:Property ;
    rdfs:label 'Delivery Notes' ;
    rdfs:comment 'Free-text notes entered by the delivery agent at the time of delivery. May include special instructions followed, access issues, or recipient comments.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPostalCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Postal Code' ;
    rdfs:comment 'Postal code or ZIP code of the delivery location.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStateProvince rdf:type rdf:Property ;
    rdfs:label 'Delivery State Province' ;
    rdfs:comment 'State, province, or region where the delivery was completed.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'The exact date and time when the shipment was delivered to the recipient. This is the principal business event timestamp for the POD transaction, distinct from audit timestamps.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryType rdf:type rdf:Property ;
    rdfs:label 'Delivery Type' ;
    rdfs:comment 'Classification of the delivery method used to complete the shipment handover. Indicates where and how the package was left.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceCode rdf:type rdf:Property ;
    rdfs:label 'Device Code' ;
    rdfs:comment 'Unique identifier of the mobile device or handheld scanner used by the delivery agent to capture the POD. Supports audit trail and device tracking.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeRaisedFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Raised Flag' ;
    rdfs:comment 'Boolean indicator of whether the shipper or recipient has raised a dispute regarding this delivery or COD collection. True indicates an active or historical dispute.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epodImageReference rdf:type rdf:Property ;
    rdfs:label 'Epod Image Reference' ;
    rdfs:comment 'URI or storage path reference to the digital photograph of the delivered package taken at the delivery location. Supports ePOD standards for visual delivery confirmation.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientContactNumber rdf:type rdf:Property ;
    rdfs:label 'Recipient Contact Number' ;
    rdfs:comment 'Phone number of the recipient who accepted the delivery. Used for delivery confirmation and follow-up communication.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientEmail rdf:type rdf:Property ;
    rdfs:label 'Recipient Email' ;
    rdfs:comment 'Email address of the recipient who accepted the delivery. Used for sending electronic proof of delivery confirmation.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientIdNumber rdf:type rdf:Property ;
    rdfs:label 'Recipient Id Number' ;
    rdfs:comment 'Identification document number presented by the recipient at delivery. Captured for high-value shipments or regulatory compliance.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientIdType rdf:type rdf:Property ;
    rdfs:label 'Recipient Id Type' ;
    rdfs:comment 'Type of identification document presented by the recipient at delivery for high-value or restricted shipments.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientName rdf:type rdf:Property ;
    rdfs:label 'Recipient Name' ;
    rdfs:comment 'Full name of the person who received the shipment at the delivery location. This is the identity label for the receiving party.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientSignature rdf:type rdf:Property ;
    rdfs:label 'Recipient Signature' ;
    rdfs:comment 'Base64-encoded signature image or reference URI to the signature captured at delivery. Serves as biometric proof of receipt.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Remittance Batch Number' ;
    rdfs:comment 'Identifier of the financial batch in which this COD collection was remitted to the shipper. Supports reconciliation and audit of COD settlements.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceDate rdf:type rdf:Property ;
    rdfs:label 'Remittance Date' ;
    rdfs:comment 'The date on which the collected COD amount was remitted to the shipper. Used for financial settlement tracking and Service Level Agreement (SLA) compliance.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remittanceStatus rdf:type rdf:Property ;
    rdfs:label 'Remittance Status' ;
    rdfs:comment 'Current status of the COD amount remittance back to the shipper. Tracks the financial settlement lifecycle from collection through to shipper payment.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Reference Number' ;
    rdfs:comment 'External payment transaction reference number or receipt number for non-cash COD payments. Links POD to payment gateway or card processor transaction.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etaMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Eta Milestone Id' ;
    rdfs:comment 'Unique identifier for the ETA/ETD milestone record. Primary key for the eta_milestone product.' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Datetime' ;
    rdfs:comment 'The actual recorded datetime when the milestone event occurred (e.g., actual departure, actual arrival). Populated after the event has been confirmed. Null until the event is completed.' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:createdDatetime rdf:type rdf:Property ;
    rdfs:label 'Created Datetime' ;
    rdfs:comment 'Timestamp when this milestone record was first created in the system. Audit field for record lifecycle tracking.' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currentPredictedDatetime rdf:type rdf:Property ;
    rdfs:label 'Current Predicted Datetime' ;
    rdfs:comment 'The most recent predicted ETA or ETD datetime based on real-time tracking, AI/ML models, or carrier updates. This value is continuously updated as new information becomes available.' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'Quality score (0.00 to 100.00) indicating the completeness and reliability of the data used to generate this milestone prediction. Higher scores indicate better data quality.' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distanceRemainingKm rdf:type rdf:Property ;
    rdfs:label 'Distance Remaining Km' ;
    rdfs:comment 'Estimated distance remaining in kilometers from current position to the milestone location. Updated in real-time based on GPS tracking data.' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastModifiedDatetime rdf:type rdf:Property ;
    rdfs:label 'Last Modified Datetime' ;
    rdfs:comment 'Timestamp when this milestone record was last modified. Audit field for tracking changes to milestone data.' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Human-readable name of the milestone location (e.g., Los Angeles International Airport, Port of Rotterdam).' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Milestone Sequence Number' ;
    rdfs:comment 'Sequential order number of this milestone within the overall shipment journey. Used to track progression through the shipment lifecycle (e.g., 1 = first milestone, 2 = second milestone).' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milestoneType rdf:type rdf:Property ;
    rdfs:label 'Milestone Type' ;
    rdfs:comment 'Type of milestone event in the shipment lifecycle. ETD_ORIGIN = Estimated Time of Departure from origin, ETA_TRANSIT_HUB = Estimated Time of Arrival at transit hub, ETD_TRANSIT_HUB = Estimated Time of Departure from transit hub, ETA_DESTINATION = Estimated Time of Arrival at destination facility, ETA_DELIVERY = Estimated Time of Arrival for final delivery to consignee, ETD_PICKUP = Estimated Time of Departure for pickup from shipper.' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentDatetime rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Datetime' ;
    rdfs:comment 'Timestamp when the customer notification was sent for this milestone update. Null if no notification has been sent.' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Boolean flag indicating whether a proactive customer notification has been sent for this milestone update. True = notification sent, False = notification not yet sent.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalCommittedDatetime rdf:type rdf:Property ;
    rdfs:label 'Original Committed Datetime' ;
    rdfs:comment 'The original committed ETA or ETD datetime provided at booking or shipment creation. This is the baseline SLA commitment against which performance is measured.' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:predictionLastUpdatedDatetime rdf:type rdf:Property ;
    rdfs:label 'Prediction Last Updated Datetime' ;
    rdfs:comment 'Timestamp when the current predicted datetime was last updated. Used to track the freshness of prediction data and trigger re-prediction cycles.' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:predictionSource rdf:type rdf:Property ;
    rdfs:label 'Prediction Source' ;
    rdfs:comment 'Source system or method that generated the current predicted datetime. FOURKITES_AI = FourKites predictive analytics engine, CARRIER_EDI = Electronic Data Interchange from carrier, TMS_CALCULATION = Transportation Management System route calculation, MANUAL_OVERRIDE = Manual adjustment by operations team, GPS_TRACKING = Real-time GPS device data, HISTORICAL_AVERAGE = Statistical average based on historical performance.' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predictionUpdateFrequencyMinutes rdf:type rdf:Property ;
    rdfs:label 'Prediction Update Frequency Minutes' ;
    rdfs:comment 'Frequency in minutes at which the prediction is updated for this milestone. Varies based on transport mode, priority, and data availability (e.g., 15 minutes for air, 60 minutes for ocean).' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Status' ;
    rdfs:comment 'Current SLA compliance status for this milestone. ON_TIME = predicted to meet commitment, AT_RISK = potential delay within threshold, DELAYED = predicted or actual breach of commitment, EARLY = predicted or actual early completion.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Sla Threshold Hours' ;
    rdfs:comment 'The acceptable variance threshold in hours for this milestone as defined in the customer SLA. Variance beyond this threshold triggers SLA breach status.' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceHours rdf:type rdf:Property ;
    rdfs:label 'Variance Hours' ;
    rdfs:comment 'Variance in hours between the current predicted datetime and the original committed datetime. Positive values indicate delay (late), negative values indicate early arrival/departure. Used for SLA breach prediction and OTIF measurement.' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weatherImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Weather Impact Flag' ;
    rdfs:comment 'Boolean flag indicating whether adverse weather conditions are impacting or predicted to impact this milestone. True = weather impact detected, False = no weather impact.' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceptionEventId rdf:type rdf:Property ;
    rdfs:label 'Exception Event Id' ;
    rdfs:comment 'Unique identifier for the exception event record. Primary key.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExceptionEvent .

ind:assignedToTeam rdf:type rdf:Property ;
    rdfs:label 'Assigned To Team' ;
    rdfs:comment 'Name or code of the operational team responsible for handling this exception event.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Claim Eligible Flag' ;
    rdfs:comment 'Indicator of whether this exception event qualifies for a cargo claim or insurance claim filing.' ;
    rdfs:domain ind:ExceptionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationTier rdf:type rdf:Property ;
    rdfs:label 'Escalation Tier' ;
    rdfs:comment 'Level of escalation indicating the organizational tier handling the exception resolution.' ;
    rdfs:domain ind:ExceptionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedRecoveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Estimated Recovery Timestamp' ;
    rdfs:comment 'Projected date and time when the shipment is expected to return to normal schedule after exception resolution.' ;
    rdfs:domain ind:ExceptionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exceptionLocationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Exception Location Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the location where the exception occurred.' ;
    rdfs:domain ind:ExceptionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionLocationName rdf:type rdf:Property ;
    rdfs:label 'Exception Location Name' ;
    rdfs:comment 'Human-readable name of the location where the exception occurred.' ;
    rdfs:domain ind:ExceptionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionRaisedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exception Raised Timestamp' ;
    rdfs:comment 'Date and time when the exception was first detected and recorded in the system. Primary business event timestamp for this transaction.' ;
    rdfs:domain ind:ExceptionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:financialImpactCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the financial impact amount.' ;
    rdfs:domain ind:ExceptionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionActionDescription rdf:type rdf:Property ;
    rdfs:label 'Resolution Action Description' ;
    rdfs:comment 'Detailed narrative of the actions taken to resolve the exception and restore normal shipment flow.' ;
    rdfs:domain ind:ExceptionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleParty rdf:type rdf:Property ;
    rdfs:label 'Responsible Party' ;
    rdfs:comment 'Entity or stakeholder determined to be responsible for the exception occurrence, used for accountability and claims processing. [ENUM-REF-CANDIDATE: CARRIER|SHIPPER|CONSIGNEE|CUSTOMS|WAREHOUSE|THIRD_PARTY|INTERNAL — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCode rdf:type rdf:Property ;
    rdfs:label 'Root Cause Code' ;
    rdfs:comment 'Standardized code identifying the underlying cause of the exception, used for analytics and process improvement.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed explanation of the root cause analysis findings for this exception event.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachType rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Type' ;
    rdfs:comment 'Classification of the type of SLA commitment that was breached due to this exception.' ;
    rdfs:domain ind:ExceptionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Source System Reference Code' ;
    rdfs:comment 'Unique identifier of this exception event in the originating source system, used for data lineage and reconciliation.' ;
    rdfs:domain ind:ExceptionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consignmentStatusId rdf:type rdf:Property ;
    rdfs:label 'Consignment Status Id' ;
    rdfs:comment 'Unique identifier for the consignment status transition record. Primary key for the consignment status history table.' ;
    rdfs:domain ind:ConsignmentStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customsClearedFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Cleared Flag' ;
    rdfs:comment 'Boolean indicator of whether customs clearance was completed at this status transition. Relevant for cross-border shipments and international freight.' ;
    rdfs:domain ind:ConsignmentStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dwellTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Dwell Time Minutes' ;
    rdfs:comment 'The duration in minutes that the consignment remained in the previous status before this transition. Measures processing time and identifies bottlenecks in the supply chain.' ;
    rdfs:domain ind:ConsignmentStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:etaUpdatedFlag rdf:type rdf:Property ;
    rdfs:label 'Eta Updated Flag' ;
    rdfs:comment 'Boolean indicator of whether the estimated time of arrival was recalculated or updated as a result of this status transition. Used to track predictive ETA accuracy.' ;
    rdfs:domain ind:ConsignmentStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'The unique identifier for this status transition in the source system or carrier system. Used for cross-system reconciliation and EDI message correlation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geolocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Latitude' ;
    rdfs:comment 'The geographic latitude coordinate where the status transition occurred, captured from GPS or RFID tracking systems. Enables spatial analysis of consignment movements.' ;
    rdfs:domain ind:ConsignmentStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geolocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Longitude' ;
    rdfs:comment 'The geographic longitude coordinate where the status transition occurred, captured from GPS or RFID tracking systems. Enables spatial analysis of consignment movements.' ;
    rdfs:domain ind:ConsignmentStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newEtaTimestamp rdf:type rdf:Property ;
    rdfs:label 'New Eta Timestamp' ;
    rdfs:comment 'The updated estimated time of arrival calculated at this status transition. Reflects the latest predictive delivery time based on current consignment progress.' ;
    rdfs:domain ind:ConsignmentStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:newStatusCode rdf:type rdf:Property ;
    rdfs:label 'New Status Code' ;
    rdfs:comment 'The lifecycle status code of the consignment after this transition. Represents the current state following the status change event. [ENUM-REF-CANDIDATE: BOOKED|PICKED_UP|IN_TRANSIT|AT_HUB|OUT_FOR_DELIVERY|DELIVERED|EXCEPTION|CANCELLED|RETURNED|ON_HOLD — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsignmentStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Photo Captured Flag' ;
    rdfs:comment 'Boolean indicator of whether a photo was captured as proof of delivery or condition at this status transition. Used for ePOD and claims evidence.' ;
    rdfs:domain ind:ConsignmentStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:previousStatusCode rdf:type rdf:Property ;
    rdfs:label 'Previous Status Code' ;
    rdfs:comment 'The lifecycle status code of the consignment immediately before this transition. Represents the prior state in the consignment workflow. [ENUM-REF-CANDIDATE: BOOKED|PICKED_UP|IN_TRANSIT|AT_HUB|OUT_FOR_DELIVERY|DELIVERED|EXCEPTION|CANCELLED|RETURNED|ON_HOLD — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsignmentStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeDeviationFlag rdf:type rdf:Property ;
    rdfs:label 'Route Deviation Flag' ;
    rdfs:comment 'Boolean indicator of whether the consignment deviated from the planned route at this status transition. Used for exception management and route optimization analysis.' ;
    rdfs:domain ind:ConsignmentStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Signature Captured Flag' ;
    rdfs:comment 'Boolean indicator of whether an electronic proof of delivery signature was captured at this status transition. Typically true for DELIVERED status transitions.' ;
    rdfs:domain ind:ConsignmentStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statusNotes rdf:type rdf:Property ;
    rdfs:label 'Status Notes' ;
    rdfs:comment 'Free-text notes or comments providing additional context about the status transition. May include operator remarks, exception details, or customer instructions.' ;
    rdfs:domain ind:ConsignmentStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusReasonCode rdf:type rdf:Property ;
    rdfs:label 'Status Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason or cause for the status transition. Provides context for why the consignment moved to the new status, especially for exceptions. [ENUM-REF-CANDIDATE: NORMAL_FLOW|CUSTOMER_REQUEST|EXCEPTION_DELAY|WEATHER|CUSTOMS_HOLD|ADDRESS_CORRECTION|DAMAGED|REFUSED|SECURITY_HOLD — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsignmentStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusTransitionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Status Transition Timestamp' ;
    rdfs:comment 'The precise date and time when the consignment status changed from the previous status to the new status. Represents the real-world business event time of the lifecycle transition.' ;
    rdfs:domain ind:ConsignmentStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:triggeredBySource rdf:type rdf:Property ;
    rdfs:label 'Triggered By Source' ;
    rdfs:comment 'The originating system or channel that initiated the status transition. Identifies whether the change was automated (system/EDI), manual (user), or via integration (API/WMS).' ;
    rdfs:domain ind:ConsignmentStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packTaskId rdf:type rdf:Property ;
    rdfs:label 'Pack Task Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.pack_task. Business justification: A shipment package is the physical output of a warehouse pack task. Linking them enables quality traceability (which station packed this package), exception root-cause analysis (was damage caused at p' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackTask .

ind:actualWeightKg rdf:type rdf:Property ;
    rdfs:label 'Actual Weight Kg' ;
    rdfs:comment 'Physical gross weight of the package measured in kilograms. Used for freight charge calculation, load planning, and carrier capacity management.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:barcodeNumber rdf:type rdf:Property ;
    rdfs:label 'Barcode Number' ;
    rdfs:comment 'Unique barcode or label number assigned to the package for scanning and tracking throughout the logistics network. Used for piece-level visibility and warehouse operations.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentsDescription rdf:type rdf:Property ;
    rdfs:label 'Contents Description' ;
    rdfs:comment 'Textual description of the declared contents within the package. Used for customs declarations, dangerous goods screening, and handling instructions.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentLocationCode rdf:type rdf:Property ;
    rdfs:label 'Current Location Code' ;
    rdfs:comment 'Code identifying the current physical location of the package (warehouse, hub, terminal, or in-transit vehicle). Updated by scan events for real-time visibility.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverySignatureName rdf:type rdf:Property ;
    rdfs:label 'Delivery Signature Name' ;
    rdfs:comment 'Name of the person who signed for the package upon delivery. Part of electronic proof of delivery (ePOD) record.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fragileFlag rdf:type rdf:Property ;
    rdfs:label 'Fragile Flag' ;
    rdfs:comment 'Indicates whether the package contains fragile items requiring special handling care. Triggers warehouse handling instructions and carrier notifications.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Amount' ;
    rdfs:comment 'Monetary amount of insurance coverage purchased for the package. Used for claims processing and liability determination.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceCurrency rdf:type rdf:Property ;
    rdfs:label 'Insurance Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the insurance coverage amount.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Required Flag' ;
    rdfs:comment 'Indicates whether the shipper has purchased additional insurance coverage for this package beyond standard carrier liability limits.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastScanLocationCode rdf:type rdf:Property ;
    rdfs:label 'Last Scan Location Code' ;
    rdfs:comment 'Location code where the most recent scan event occurred. Used for tracking history and route verification.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastScanTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Scan Timestamp' ;
    rdfs:comment 'Date and time of the most recent barcode scan event for this package. Provides real-time tracking visibility and exception detection.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxStackWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Stack Weight Kg' ;
    rdfs:comment 'Maximum weight in kilograms that can be stacked on top of this package without causing damage. Used for warehouse stacking rules and load optimization.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageStatus rdf:type rdf:Property ;
    rdfs:label 'Package Status' ;
    rdfs:comment 'Current lifecycle status of the package in the logistics network. Tracks the package from booking through final delivery or exception resolution. [ENUM-REF-CANDIDATE: booked|picked_up|in_transit|at_hub|out_for_delivery|delivered|exception|returned|damaged|lost — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stackableFlag rdf:type rdf:Property ;
    rdfs:label 'Stackable Flag' ;
    rdfs:comment 'Indicates whether the package can be stacked with other packages during storage and transportation. Affects warehouse slotting and load planning.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assignmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assignment Method' ;
    rdfs:comment 'Method by which the carrier was assigned to this shipment leg. Auto-optimized indicates algorithmic carrier selection via SAP TM or Oracle TMS; manual override indicates planner intervention; contract based indicates assignment per existing carrier contract; spot market indicates ad-hoc market rate booking; tender indicates competitive bidding process; preferred carrier indicates selection from preferred carrier list.' ;
    rdfs:domain ind:ShipmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierPerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Carrier Performance Rating' ;
    rdfs:comment 'Performance rating assigned to the carrier for this shipment leg, typically on a scale of 0.00 to 5.00. Used for carrier scorecard and future selection optimization.' ;
    rdfs:domain ind:ShipmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractRateFlag rdf:type rdf:Property ;
    rdfs:label 'Contract Rate Flag' ;
    rdfs:comment 'Indicates whether the rate applied is a contracted rate (true) or a spot market rate (false).' ;
    rdfs:domain ind:ShipmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedDepartureDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Departure Date' ;
    rdfs:comment 'Estimated date of departure for this carrier leg as provided by the carrier.' ;
    rdfs:domain ind:ShipmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modeOfTransport rdf:type rdf:Property ;
    rdfs:label 'Mode Of Transport' ;
    rdfs:comment 'Primary mode of transport for this carrier assignment (air, ocean, road, rail, multimodal, courier).' ;
    rdfs:domain ind:ShipmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onTimeDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Flag' ;
    rdfs:comment 'Indicates whether the carrier delivered the shipment on time per the agreed service level agreement (true) or late (false).' ;
    rdfs:domain ind:ShipmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Amount' ;
    rdfs:comment 'Agreed freight rate amount charged by the carrier for this shipment leg. Base rate before surcharges and adjustments.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Rate Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the rate amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Rate Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the rate (e.g., per kilogram, per cubic meter, per TEU, per shipment, per pallet, per mile, per kilometer). [ENUM-REF-CANDIDATE: per_kg|per_cbm|per_teu|per_shipment|per_pallet|per_mile|per_km — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCarrierCharge rdf:type rdf:Property ;
    rdfs:label 'Total Carrier Charge' ;
    rdfs:comment 'Total amount charged by the carrier for this shipment leg, including base rate, fuel surcharge, and other carrier fees.' ;
    rdfs:domain ind:ShipmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainNumber rdf:type rdf:Property ;
    rdfs:label 'Train Number' ;
    rdfs:comment 'Train service number assigned for rail freight transport.' ;
    rdfs:domain ind:ShipmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryInstructionId rdf:type rdf:Property ;
    rdfs:label 'Delivery Instruction Id' ;
    rdfs:comment 'Unique identifier for the delivery instruction record. Primary key.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alternativeAddressBookId rdf:type rdf:Property ;
    rdfs:label 'Alternative Address Book Id' ;
    rdfs:comment 'Foreign key linking to customer.address_book. Business justification: Alternative delivery addresses in delivery instructions should reference validated entries in the customer address_book to ensure address accuracy, enable reuse of pre-validated addresses, and support' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AddressBook .

ind:customerContactId rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: Delivery instructions frequently specify customer contact person for access coordination, delivery authorization, and issue resolution. Normalizes denormalized contact fields. Critical for last-mile d' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:authorityToLeaveFlag rdf:type rdf:Property ;
    rdfs:label 'Authority To Leave Flag' ;
    rdfs:comment 'Indicates whether the delivery driver has authority to leave the shipment unattended at the delivery location without obtaining a signature. True if authority is granted, False otherwise.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryNotificationPreference rdf:type rdf:Property ;
    rdfs:label 'Delivery Notification Preference' ;
    rdfs:comment 'Preferred method for receiving delivery notifications. Specifies whether the consignee wants to be notified via SMS, email, phone call, mobile app push notification, or no notification.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:idVerificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Id Verification Required Flag' ;
    rdfs:comment 'Indicates whether government-issued identification must be verified at delivery. Typically required for age-restricted or high-value shipments.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:instructionEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Instruction Effective Date' ;
    rdfs:comment 'The date from which this delivery instruction becomes effective. Supports future-dated instructions and instruction scheduling.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:instructionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Instruction Expiry Date' ;
    rdfs:comment 'The date on which this delivery instruction expires and is no longer valid. Nullable for instructions with no expiration.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:instructionPriority rdf:type rdf:Property ;
    rdfs:label 'Instruction Priority' ;
    rdfs:comment 'Priority level assigned to this delivery instruction. High priority instructions take precedence in case of conflicting instructions or operational constraints.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionSource rdf:type rdf:Property ;
    rdfs:label 'Instruction Source' ;
    rdfs:comment 'The origin or channel through which the delivery instruction was captured. Indicates whether the instruction came from the shipper, consignee, customer portal, call center, mobile app, or Electronic Data Interchange (EDI) system.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionStatus rdf:type rdf:Property ;
    rdfs:label 'Instruction Status' ;
    rdfs:comment 'Current lifecycle status of the delivery instruction. Tracks whether the instruction is active, has been cancelled, completed, superseded by a newer instruction, or is pending activation.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionType rdf:type rdf:Property ;
    rdfs:label 'Instruction Type' ;
    rdfs:comment 'The type of delivery instruction specified by the shipper or consignee. Defines the primary delivery handling requirement for last-mile execution.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockerCode rdf:type rdf:Property ;
    rdfs:label 'Locker Code' ;
    rdfs:comment 'Identifier of the parcel locker or automated pickup point where the shipment should be delivered if locker delivery is selected.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockerLocationCode rdf:type rdf:Property ;
    rdfs:label 'Locker Location Code' ;
    rdfs:comment 'Geographic or facility code identifying the location of the parcel locker. Used for routing and last-mile optimization.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumAgeRequirement rdf:type rdf:Property ;
    rdfs:label 'Minimum Age Requirement' ;
    rdfs:comment 'Minimum age of the recipient required for delivery. Used for age-restricted goods such as alcohol, tobacco, or pharmaceuticals.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:neighbourDeliveryAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Neighbour Delivery Allowed Flag' ;
    rdfs:comment 'Indicates whether the shipment can be delivered to a neighbor if the consignee is not available. True if neighbor delivery is permitted, False otherwise.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Preferred Delivery Date' ;
    rdfs:comment 'The date on which the consignee prefers to receive the delivery. Used for appointment scheduling and delivery planning.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredNeighbourAddress rdf:type rdf:Property ;
    rdfs:label 'Preferred Neighbour Address' ;
    rdfs:comment 'Address of a preferred neighbor to whom the shipment can be delivered if the consignee is unavailable.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredTimeWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Preferred Time Window End' ;
    rdfs:comment 'The end of the preferred delivery time window specified by the consignee. Defines the latest acceptable time for delivery within the preferred window.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:preferredTimeWindowStart rdf:type rdf:Property ;
    rdfs:label 'Preferred Time Window Start' ;
    rdfs:comment 'The start of the preferred delivery time window specified by the consignee. Enables time-definite delivery services and appointment-based deliveries.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:returnIfAbsentFlag rdf:type rdf:Property ;
    rdfs:label 'Return If Absent Flag' ;
    rdfs:comment 'Indicates whether the shipment should be returned to the depot or origin if the consignee is not present. True if return is required, False if alternative delivery options should be attempted.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safePlaceDescription rdf:type rdf:Property ;
    rdfs:label 'Safe Place Description' ;
    rdfs:comment 'Description of a safe place where the parcel can be left if the consignee is not present. Examples include porch, garage, side door, or with a specific neighbor.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Signature Required Flag' ;
    rdfs:comment 'Indicates whether a signature is required upon delivery. True if signature is mandatory, False if delivery can be completed without signature.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatureType rdf:type rdf:Property ;
    rdfs:label 'Signature Type' ;
    rdfs:comment 'The type of signature required for delivery. Specifies whether the consignee must sign, any adult can sign, an indirect signature is acceptable, or an electronic signature is permitted.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialAccessInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Access Instructions' ;
    rdfs:comment 'Free-text instructions provided by the consignee for accessing the delivery location. May include gate codes, building entry procedures, parking instructions, or security protocols.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentChargeId rdf:type rdf:Property ;
    rdfs:label 'Shipment Charge Id' ;
    rdfs:comment 'Unique identifier for the shipment charge record. Primary key.' ;
    rdfs:domain ind:ShipmentCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Supplier Invoice Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier_invoice. Business justification: Freight charges on inbound supplier shipments (freight collect, DDP terms) often appear as line items on supplier invoices. Links freight charge to AP invoice for 3-way match, accrual accuracy, and la' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierInvoice .

ind:surchargeId rdf:type rdf:Property ;
    rdfs:label 'Surcharge Id' ;
    rdfs:comment 'Foreign key linking to pricing.surcharge. Business justification: Surcharge billing validation requires linking each applied surcharge charge to the master surcharge rule. Logistics finance teams verify that fuel, hazmat, and peak-season surcharges applied to shipme' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Surcharge .

ind:taxScheduleId rdf:type rdf:Property ;
    rdfs:label 'Tax Schedule Id' ;
    rdfs:comment 'Foreign key linking to billing.tax_schedule. Business justification: Tax compliance and audit: each shipment charge must reference the governing tax schedule for correct tax calculation across jurisdictions. Logistics tax auditors require traceability from individual c' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxSchedule .

ind:applicationLevel rdf:type rdf:Property ;
    rdfs:label 'Application Level' ;
    rdfs:comment 'The level at which this charge is applied within the shipment hierarchy.' ;
    rdfs:domain ind:ShipmentCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether this charge requires managerial or financial approval before invoicing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditTimestamp rdf:type rdf:Property ;
    rdfs:label 'Audit Timestamp' ;
    rdfs:comment 'Date and time when this charge record was last audited or reviewed for accuracy.' ;
    rdfs:domain ind:ShipmentCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billableWeightKg rdf:type rdf:Property ;
    rdfs:label 'Billable Weight Kg' ;
    rdfs:comment 'Chargeable weight used for freight calculation, which may be actual weight or dimensional (DIM) weight, whichever is greater.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calculation Timestamp' ;
    rdfs:comment 'Date and time when this charge was calculated or rated by the system.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Monetary value of any discount applied to this charge, reducing the net payable amount.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Indicates whether this charge is currently under dispute by the customer or payer.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Net Charge Amount' ;
    rdfs:comment 'Final charge amount after applying discounts and adding taxes. This is the amount invoiced to the customer.' ;
    rdfs:domain ind:ShipmentCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originSystem rdf:type rdf:Property ;
    rdfs:label 'Origin System' ;
    rdfs:comment 'Source system or process that generated or recorded this charge. [ENUM-REF-CANDIDATE: tms|wms|customs|carrier_invoice|manual|rating_engine|erp — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShipmentCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermCode rdf:type rdf:Property ;
    rdfs:label 'Payment Term Code' ;
    rdfs:comment 'Indicates who is responsible for paying this charge and when payment is due (e.g., prepaid by shipper, collect from consignee).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePerUnit rdf:type rdf:Property ;
    rdfs:label 'Rate Per Unit' ;
    rdfs:comment 'Unit rate applied to the quantity to calculate the base charge amount.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'Date on which revenue from this charge is recognized in the financial statements.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceProviderName rdf:type rdf:Property ;
    rdfs:label 'Service Provider Name' ;
    rdfs:comment 'Name of the carrier, vendor, or service provider who levied or is responsible for this charge.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Total tax applied to this charge, including VAT, GST, sales tax, or other applicable taxes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxRatePercent rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Percent' ;
    rdfs:comment 'Percentage rate of tax applied to the charge amount.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waivedFlag rdf:type rdf:Property ;
    rdfs:label 'Waived Flag' ;
    rdfs:comment 'Indicates whether this charge has been waived and will not be billed to the customer.' ;
    rdfs:domain ind:ShipmentCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverReason rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason' ;
    rdfs:comment 'Business justification or reason for waiving this charge.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightManifestId rdf:type rdf:Property ;
    rdfs:label 'Freight Manifest Id' ;
    rdfs:comment 'Unique identifier for the freight manifest record. Primary key.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightManifest .

ind:originDepotId rdf:type rdf:Property ;
    rdfs:label 'Origin Depot Id' ;
    rdfs:comment 'Foreign key linking to fleet.depot. Business justification: Freight manifests originate from a fleet depot. Linking origin_depot_id enables depot throughput reporting, capacity planning, and departure scheduling. Logistics network managers track manifest volum' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:parcelManifestId rdf:type rdf:Property ;
    rdfs:label 'Parcel Manifest Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.parcel_manifest. Business justification: A freight manifest (consolidated shipment) contains parcels tracked in parcel manifests. Cross-manifest reconciliation — verifying all parcels in a parcel manifest are accounted for in the freight man' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ParcelManifest .

ind:destinationFacilityCode rdf:type rdf:Property ;
    rdfs:label 'Destination Facility Code' ;
    rdfs:comment 'Code identifying the warehouse, terminal, port, or distribution center where the manifest load is destined.' ;
    rdfs:domain ind:FreightManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationFacilityName rdf:type rdf:Property ;
    rdfs:label 'Destination Facility Name' ;
    rdfs:comment 'Full name of the destination facility, terminal, or port where the manifest will be unloaded.' ;
    rdfs:domain ind:FreightManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadPlanReference rdf:type rdf:Property ;
    rdfs:label 'Load Plan Reference' ;
    rdfs:comment 'Reference identifier to the load optimization plan generated by Oracle TMS or SAP TM that produced this manifest.' ;
    rdfs:domain ind:FreightManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestClosedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manifest Closed Timestamp' ;
    rdfs:comment 'Date and time when the manifest was closed and locked for departure, preventing further additions or changes.' ;
    rdfs:domain ind:FreightManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manifestCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manifest Completed Timestamp' ;
    rdfs:comment 'Date and time when the manifest was marked as completed after successful delivery and unloading at destination.' ;
    rdfs:domain ind:FreightManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manifestCostAmount rdf:type rdf:Property ;
    rdfs:label 'Manifest Cost Amount' ;
    rdfs:comment 'Total transportation cost allocated to this manifest, including carrier charges, fuel surcharges, and accessorial fees.' ;
    rdfs:domain ind:FreightManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manifestCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Manifest Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the manifest cost amount.' ;
    rdfs:domain ind:FreightManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manifest Created Timestamp' ;
    rdfs:comment 'Date and time when this manifest record was first created in the TMS or WMS system.' ;
    rdfs:domain ind:FreightManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manifestNumber rdf:type rdf:Property ;
    rdfs:label 'Manifest Number' ;
    rdfs:comment 'Externally-known unique manifest number assigned by the carrier or TMS for this consolidated load. Used for carrier handover documentation and regulatory compliance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestStatus rdf:type rdf:Property ;
    rdfs:label 'Manifest Status' ;
    rdfs:comment 'Current lifecycle status of the manifest indicating its operational state from creation through completion. [ENUM-REF-CANDIDATE: draft|open|closed|departed|in_transit|arrived|completed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalConsignments rdf:type rdf:Property ;
    rdfs:label 'Total Consignments' ;
    rdfs:comment 'Total number of individual consignments (AWBs, BOLs, HAWBs) consolidated into this manifest.' ;
    rdfs:domain ind:FreightManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPieces rdf:type rdf:Property ;
    rdfs:label 'Total Pieces' ;
    rdfs:comment 'Total number of individual pieces, packages, or handling units loaded onto this manifest across all consignments.' ;
    rdfs:domain ind:FreightManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryDriverProfileId rdf:type rdf:Property ;
    rdfs:label 'Delivery Driver Profile Id' ;
    rdfs:comment 'Foreign key linking to fleet.driver_profile. Business justification: Last-mile delivery agent assignment requires driver profile lookup for license validation, HOS compliance verification, performance tracking, and route authorization. Existing delivery_agent_employee_' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DriverProfile .

ind:dispatchRunId rdf:type rdf:Property ;
    rdfs:label 'Dispatch Run Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.dispatch_run. Business justification: A dispatch_run is the operational route/courier trip that groups multiple last-mile dispatches. last_mile_dispatch assigns a single consignment to a driver, while dispatch_run represents the full sche' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DispatchRun .

ind:fulfillmentDeliveryZoneId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Delivery Zone Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.delivery_zone. Business justification: Last-mile dispatch assignments are zone-based. Adding delivery_zone_id FK enables proper zone-based routing, SLA tracking, and delivery agent assignment. The delivery address fields remain (execution-' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentDeliveryZone .

ind:actualPickupTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Pickup Timestamp' ;
    rdfs:comment 'Actual date and time when the delivery agent picked up the consignment from the depot or hub. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:LastMileDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:codCollectedFlag rdf:type rdf:Property ;
    rdfs:label 'Cod Collected Flag' ;
    rdfs:comment 'Indicates whether the COD amount was successfully collected from the recipient. True if collected, False if not collected or not applicable.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryFailureReasonCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Failure Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for delivery failure. Null if delivery was successful. [ENUM-REF-CANDIDATE: recipient_unavailable|address_incorrect|access_denied|refused_by_recipient|damaged_package|weather_delay|vehicle_breakdown — promote to reference product]' ;
    rdfs:domain ind:LastMileDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryInstructions rdf:type rdf:Property ;
    rdfs:label 'Delivery Instructions' ;
    rdfs:comment 'Special instructions provided by the customer or shipper for the delivery. May include gate codes, safe drop locations, or contact preferences.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryRouteCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Route Code' ;
    rdfs:comment 'Code identifying the planned delivery route or zone for this dispatch. Used for route optimization and territory management.' ;
    rdfs:domain ind:LastMileDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchDate rdf:type rdf:Property ;
    rdfs:label 'Dispatch Date' ;
    rdfs:comment 'The calendar date on which the consignment was dispatched for last-mile delivery. Primary business event date for this transaction.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dispatchNumber rdf:type rdf:Property ;
    rdfs:label 'Dispatch Number' ;
    rdfs:comment 'Externally-visible unique dispatch reference number used for tracking and communication. Format: DSP-XXXXXXXXXX.' ;
    rdfs:domain ind:LastMileDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchStatus rdf:type rdf:Property ;
    rdfs:label 'Dispatch Status' ;
    rdfs:comment 'Current lifecycle status of the dispatch. Tracks progression from dispatch through delivery or return. Values: dispatched (assigned to driver), in_transit (en route to delivery area), out_for_delivery (active delivery attempt), delivered (successfully completed), failed (delivery unsuccessful), returned_to_depot (consignment returned).' ;
    rdfs:domain ind:LastMileDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispatch Timestamp' ;
    rdfs:comment 'Precise date and time when the consignment was dispatched from the depot or hub for final delivery. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:epodPhotoCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Epod Photo Captured Flag' ;
    rdfs:comment 'Indicates whether a photo was captured as proof of delivery. True if photo captured, False otherwise.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epodSignatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Epod Signature Captured Flag' ;
    rdfs:comment 'Indicates whether an electronic signature was captured as proof of delivery. True if signature captured, False otherwise.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedDeliveryTimeWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Time Window End' ;
    rdfs:comment 'End of the planned delivery time window communicated to the customer. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:LastMileDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedDeliveryTimeWindowStart rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Time Window Start' ;
    rdfs:comment 'Start of the planned delivery time window communicated to the customer. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:LastMileDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:returnToDepotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Return To Depot Timestamp' ;
    rdfs:comment 'Date and time when the consignment was returned to the depot after a failed delivery attempt. Null if not returned. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:LastMileDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shipmentDocumentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Document Id' ;
    rdfs:comment 'Unique identifier for the shipment document record. Primary key.' ;
    rdfs:domain ind:ShipmentDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementVersionId rdf:type rdf:Property ;
    rdfs:label 'Agreement Version Id' ;
    rdfs:comment 'Foreign key linking to contract.agreement_version. Business justification: Shipment documents (commercial invoices, BOLs, certificates) must reference the specific agreement version in force at time of shipment for compliance audit and legal disputes. The existing agreement_' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AgreementVersion .

ind:supersededByDocumentShipmentDocumentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Document Shipment Document Id' ;
    rdfs:comment 'Reference to the shipment_document_id of the newer version that supersedes this document. Nullable if this is the current version.' ;
    rdfs:domain ind:ShipmentDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShipmentDocument .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Boolean indicator whether the document meets all regulatory and carrier compliance requirements. True=compliant, False=non-compliant or pending review.' ;
    rdfs:domain ind:ShipmentDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'Size of the document file in bytes. Used for storage management and upload validation.' ;
    rdfs:domain ind:ShipmentDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fileUri rdf:type rdf:Property ;
    rdfs:label 'File Uri' ;
    rdfs:comment 'Uniform Resource Identifier (URI) or file path pointing to the stored digital copy of the document in the document management system or cloud storage. Confidential as it may expose internal storage architecture.' ;
    rdfs:domain ind:ShipmentDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hash rdf:type rdf:Property ;
    rdfs:label 'Hash' ;
    rdfs:comment 'Cryptographic hash (e.g., SHA-256) of the document file content, used for integrity verification and tamper detection.' ;
    rdfs:domain ind:ShipmentDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Flag' ;
    rdfs:comment 'Boolean indicator whether this document is mandatory for the shipment to proceed (e.g., commercial invoice for customs clearance). True=mandatory, False=optional or supplementary.' ;
    rdfs:domain ind:ShipmentDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for document rejection. INCOMPLETE=missing required fields, EXPIRED=document past validity, INVALID=does not meet regulatory requirements, MISMATCH=data does not match shipment details, ILLEGIBLE=poor quality scan, UNAUTHORIZED=issuer not recognized.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Description' ;
    rdfs:comment 'Free-text explanation provided by the reviewing authority detailing why the document was rejected and what corrective action is required.' ;
    rdfs:domain ind:ShipmentDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rejection Timestamp' ;
    rdfs:comment 'The date and time when the document was rejected by the reviewing authority. Nullable if not rejected. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ShipmentDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:retentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Retention Expiry Date' ;
    rdfs:comment 'The date after which the document may be archived or purged according to regulatory retention policies (e.g., 7 years for customs records). Format: yyyy-MM-dd.' ;
    rdfs:domain ind:ShipmentDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewedByAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Reviewed By Authority Name' ;
    rdfs:comment 'Name of the customs office, carrier, or compliance authority that reviewed and approved or rejected the document.' ;
    rdfs:domain ind:ShipmentDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'The date and time when the document was officially submitted to customs, carrier, or other external authority for review. Nullable if not yet submitted. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:translationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Translation Required Flag' ;
    rdfs:comment 'Boolean indicator whether the document requires translation into the destination country language for customs clearance or carrier acceptance. True=translation required, False=no translation needed.' ;
    rdfs:domain ind:ShipmentDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:uploadSource rdf:type rdf:Property ;
    rdfs:label 'Upload Source' ;
    rdfs:comment 'The channel or system through which the document was uploaded or received. Shipper_portal=customer web portal, EDI=Electronic Data Interchange, API=Application Programming Interface integration, Email=email attachment, Manual=manual entry by operations, Carrier_system=received from carrier system.' ;
    rdfs:domain ind:ShipmentDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billToAddressBookId rdf:type rdf:Property ;
    rdfs:label 'Bill To Address Book Id' ;
    rdfs:comment 'Foreign key linking to customer.address_book. Business justification: Invoice address standardization: logistics invoices are sent to a billing address from the customer\'s validated address book. bill_to_address_line1/2, bill_to_city, bill_to_country_code, bill_to_posta' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AddressBook .

ind:billToContactId rdf:type rdf:Property ;
    rdfs:label 'Bill To Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: Invoice-to-contact billing workflow: logistics billing teams direct invoice delivery, payment chasing, and dispute escalation to a specific billing contact. bill_to_name is a denormalized contact name' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:originatingAgentId rdf:type rdf:Property ;
    rdfs:label 'Originating Agent Id' ;
    rdfs:comment 'Foreign key linking to network.agent. Business justification: Agent-originated shipments generate invoices that must track the originating agent for commission calculation, agent performance reporting, and revenue attribution by sales channel. Critical for agent' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:paymentTermId rdf:type rdf:Property ;
    rdfs:label 'Payment Term Id' ;
    rdfs:comment 'Foreign key linking to billing.payment_term. Business justification: Invoice currently has payment_terms as STRING. This should be normalized to reference billing.payment_term master table. The payment_term_id FK allows joining to get code, name, net_days, discount ter' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentTerm .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Additional adjustments applied to the invoice. Includes surcharges, fuel adjustment factors (BAF), currency adjustment factors, and other miscellaneous charges or credits.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountOutstanding rdf:type rdf:Property ;
    rdfs:label 'Amount Outstanding' ;
    rdfs:comment 'Remaining unpaid balance on the invoice. Calculated as total_amount minus amount_paid. Used for accounts receivable reporting and collections.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountPaid rdf:type rdf:Property ;
    rdfs:label 'Amount Paid' ;
    rdfs:comment 'Total amount received from customer to date. Used to calculate outstanding balance and track partial payments.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'End date of the period covered by this invoice. Relevant for consolidated and recurring invoices that cover a range of services.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'Start date of the period covered by this invoice. Relevant for consolidated and recurring invoices that cover a range of services.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'Method by which the invoice was or will be delivered to the customer. Email is electronic delivery; postal_mail is physical mail; EDI is electronic data interchange; customer_portal is self-service download; fax is facsimile transmission.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Date' ;
    rdfs:comment 'Date the customer raised a dispute on this invoice. Used for dispute aging and resolution tracking.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'Date by which payment is expected from the customer. Calculated based on invoice date and payment terms. Used for accounts receivable aging and collections management.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'Date the invoice was posted to the general ledger in SAP S/4HANA Finance. Used for financial period closing and accounting reconciliation.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle status of the invoice. Draft invoices are being prepared; issued invoices are finalized but not yet sent; sent invoices have been transmitted to customer; partially_paid invoices have received partial payment; paid invoices are fully settled; overdue invoices are past due date; disputed invoices are under customer challenge; cancelled invoices are voided; written_off invoices are uncollectible. [ENUM-REF-CANDIDATE: draft|issued|sent|partially_paid|paid|overdue|disputed|cancelled|written_off — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the invoice document type. Standard invoices are regular billing documents; proforma invoices are preliminary estimates; credit notes reduce amounts owed; debit notes increase amounts owed; consolidated invoices combine multiple shipments; recurring invoices are for subscription-based services.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Payment Received Date' ;
    rdfs:comment 'Date the payment was received from the customer. Used for cash flow analysis and days sales outstanding (DSO) calculation.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'Customer purchase order number associated with this invoice. Used for customer invoice matching and accounts payable reconciliation on customer side.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionStatus rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Status' ;
    rdfs:comment 'Status of revenue recognition for this invoice under IFRS 15. Not_recognized indicates revenue has not yet been booked; partially_recognized indicates partial revenue booking for multi-period services; fully_recognized indicates complete revenue booking; deferred indicates revenue is held for future recognition.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentDate rdf:type rdf:Property ;
    rdfs:label 'Sent Date' ;
    rdfs:comment 'Date the invoice was transmitted to the customer. Used for tracking invoice delivery and calculating customer response time.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Subtotal Amount' ;
    rdfs:comment 'Sum of all line item charges before taxes, discounts, and adjustments. Base amount for invoice calculation.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Registration Number' ;
    rdfs:comment 'Tax identification number of the billing party. VAT number, GST number, or equivalent tax registration identifier used for tax compliance and reporting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'Final invoice amount due from customer. Calculated as subtotal + tax + adjustment - discount. Net amount for payment and revenue recognition.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Status of freight audit review for this line item (pending, approved, rejected, under_review).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billableFlag rdf:type rdf:Property ;
    rdfs:label 'Billable Flag' ;
    rdfs:comment 'Indicates whether this line item is billable to the customer (True) or non-billable/internal (False).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chargebackFlag rdf:type rdf:Property ;
    rdfs:label 'Chargeback Flag' ;
    rdfs:comment 'Indicates whether this line item has been charged back to a carrier or vendor (True) or not (False).' ;
    rdfs:domain ind:BillingInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Cost center code to which this charge is allocated for internal cost accounting and management reporting.' ;
    rdfs:domain ind:BillingInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountReason rdf:type rdf:Property ;
    rdfs:label 'Discount Reason' ;
    rdfs:comment 'Reason or code for the discount applied (e.g., volume discount, promotional discount, service failure credit).' ;
    rdfs:domain ind:BillingInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineAmount rdf:type rdf:Property ;
    rdfs:label 'Line Amount' ;
    rdfs:comment 'Total charge amount for this line item before tax (quantity × unit_rate, or flat charge if quantity is 1).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineTotal rdf:type rdf:Property ;
    rdfs:label 'Line Total' ;
    rdfs:comment 'Total amount for this line item including tax (line_amount + tax_amount).' ;
    rdfs:domain ind:BillingInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profitCenter rdf:type rdf:Property ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'Profit center code for internal profitability analysis and segment reporting.' ;
    rdfs:domain ind:BillingInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueType rdf:type rdf:Property ;
    rdfs:label 'Revenue Type' ;
    rdfs:comment 'Classification of revenue type for financial reporting and revenue recognition purposes.' ;
    rdfs:domain ind:BillingInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCode rdf:type rdf:Property ;
    rdfs:label 'Service Code' ;
    rdfs:comment 'Code identifying the type of billable service or charge (e.g., freight, handling, storage, customs clearance).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDate rdf:type rdf:Property ;
    rdfs:label 'Service Date' ;
    rdfs:comment 'Date when the service was performed or the charge was incurred. Used for revenue recognition timing.' ;
    rdfs:domain ind:BillingInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surchargeType rdf:type rdf:Property ;
    rdfs:label 'Surcharge Type' ;
    rdfs:comment 'Specific type of surcharge applied (BAF - Bunker Adjustment Factor, THC - Terminal Handling Charge, GRI - General Rate Increase, fuel surcharge, peak season surcharge, remote area surcharge, DIM weight surcharge). Null if not a surcharge.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate' ;
    rdfs:comment 'Tax rate percentage applied to this line item (e.g., 20.00 for 20% VAT).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issuedToContactId rdf:type rdf:Property ;
    rdfs:label 'Issued To Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: Credit note issuance process: in logistics, credit notes are issued to a designated billing contact for acknowledgment and application against open invoices. The contact receives notification and conf' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:applicationStatus rdf:type rdf:Property ;
    rdfs:label 'Application Status' ;
    rdfs:comment 'Tracks whether the credit note has been applied to customer invoices. Open indicates unused credit, partially_applied shows partial usage, fully_applied means completely consumed, expired for time-lapsed credits, and voided for cancelled credits.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliedAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Amount' ;
    rdfs:comment 'Cumulative amount of this credit note that has been applied to customer invoices. Tracks utilization for accounts receivable netting and credit balance management.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessUnit rdf:type rdf:Property ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'Organizational business unit or division responsible for this credit note. Supports multi-entity financial reporting and cost center allocation.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'Gross credit amount before tax adjustments. Represents the base value being credited to the customer account in the transaction currency.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Note Number' ;
    rdfs:comment 'Externally-known unique business identifier for the credit note, typically following company numbering convention (e.g., CN-20240001234). Used for customer communication and audit trail.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditReasonCode rdf:type rdf:Property ;
    rdfs:label 'Credit Reason Code' ;
    rdfs:comment 'Standardized code indicating the business reason for issuing the credit note. Categories include billing errors, service failures, SLA breaches, rate disputes, duplicate charges, and goodwill adjustments. Used for root cause analysis and process improvement.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Credit Reason Description' ;
    rdfs:comment 'Detailed free-text explanation of the specific circumstances that led to the credit note issuance. Provides context beyond the standardized reason code for audit and customer service purposes.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditType rdf:type rdf:Property ;
    rdfs:label 'Credit Type' ;
    rdfs:comment 'Classification of the credit note by its financial impact type. Distinguishes between full invoice reversals, partial adjustments, tax-only corrections, freight-specific adjustments, and claim settlements.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAutomated rdf:type rdf:Property ;
    rdfs:label 'Is Automated' ;
    rdfs:comment 'Flag indicating whether this credit note was generated by an automated system rule (true) or manually created by a user (false). Supports process automation analysis and quality control.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingLocationCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Location Code' ;
    rdfs:comment 'Three-letter code identifying the station, branch, or facility that issued the credit note. Supports geographic performance analysis and operational accountability.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingBalance rdf:type rdf:Property ;
    rdfs:label 'Remaining Balance' ;
    rdfs:comment 'Unapplied credit balance available for future invoice netting. Calculated as total_credit_amount minus applied_amount. Used for customer credit balance reporting.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueReversalPeriod rdf:type rdf:Property ;
    rdfs:label 'Revenue Reversal Period' ;
    rdfs:comment 'Fiscal period (YYYY-MM format) to which the revenue reversal is allocated for financial reporting. Supports IFRS 15 revenue recognition compliance and period-specific P&L adjustments.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCreditMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Credit Memo Number' ;
    rdfs:comment 'Reference to the corresponding credit memo document in SAP S/4HANA Finance system. Enables reconciliation between lakehouse and ERP financial records.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Total Credit Amount' ;
    rdfs:comment 'Net total credit amount including all tax adjustments. This is the final amount that will be applied to the customer\'s accounts receivable balance.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payerContactId rdf:type rdf:Property ;
    rdfs:label 'Payer Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: Payment remittance tracking: logistics payments are submitted by a specific AP contact. Linking payment to contact enables remittance advice matching, payment confirmation workflows, and audit trails.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:authorizationCode rdf:type rdf:Property ;
    rdfs:label 'Authorization Code' ;
    rdfs:comment 'Authorization code provided by the payment processor confirming the transaction was approved. Used for fraud prevention and dispute resolution.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountReference rdf:type rdf:Property ;
    rdfs:label 'Bank Account Reference' ;
    rdfs:comment 'Reference to the bank account into which the payment was deposited. Used for bank reconciliation and cash management.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankCharges rdf:type rdf:Property ;
    rdfs:label 'Bank Charges' ;
    rdfs:comment 'Bank fees or charges deducted from the payment amount during processing. Reduces the net amount received.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Base Currency Amount' ;
    rdfs:comment 'The payment amount converted to the organization\'s base reporting currency using the exchange rate. Used for consolidated financial reporting.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchReference rdf:type rdf:Property ;
    rdfs:label 'Batch Reference' ;
    rdfs:comment 'Reference to the batch or file in which this payment was received. Used for bulk payment processing and reconciliation.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessUnitCode rdf:type rdf:Property ;
    rdfs:label 'Business Unit Code' ;
    rdfs:comment 'Code identifying the business unit or division that received this payment. Used for segment reporting and profitability analysis.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'The date on which the payment was cleared against one or more invoices in the accounts receivable system.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Reference' ;
    rdfs:comment 'Reference to the SAP S/4HANA clearing document that applied this payment to outstanding invoices. Used for audit trail and reconciliation.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingStatus rdf:type rdf:Property ;
    rdfs:label 'Clearing Status' ;
    rdfs:comment 'Current clearing status of the payment indicating whether it has been applied against outstanding invoices. Drives accounts receivable aging and dunning processes.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlyPaymentDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Amount' ;
    rdfs:comment 'Discount amount granted for early payment according to agreed payment terms. Reduces the net amount due.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Gl Document Reference' ;
    rdfs:comment 'Reference to the general ledger document created for this payment transaction. Used for financial audit and traceability.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionReference rdf:type rdf:Property ;
    rdfs:label 'Instruction Reference' ;
    rdfs:comment 'Reference to the original payment instruction or request that initiated this payment. Used for traceability and audit.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:narrative rdf:type rdf:Property ;
    rdfs:label 'Narrative' ;
    rdfs:comment 'Free-text description or notes provided by the payer with the payment. Used for manual reconciliation and customer service.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerBankIdentifier rdf:type rdf:Property ;
    rdfs:label 'Payer Bank Identifier' ;
    rdfs:comment 'Bank identifier code or SWIFT code of the payer\'s bank. Used for international payment tracking and reconciliation.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Payment Timestamp' ;
    rdfs:comment 'The precise date and time when the payment transaction was recorded in the system. Used for audit trail and real-time reconciliation.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processorReference rdf:type rdf:Property ;
    rdfs:label 'Processor Reference' ;
    rdfs:comment 'Transaction identifier provided by the payment processor or gateway. Used for dispute resolution and chargeback management.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'The date on which the payment was reconciled with bank statements. Used for cash management and audit trail.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Status indicating whether the payment has been successfully reconciled with bank statements and invoice records. Drives exception management workflow.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceAdviceReference rdf:type rdf:Property ;
    rdfs:label 'Remittance Advice Reference' ;
    rdfs:comment 'Reference to the remittance advice document provided by the customer detailing which invoices this payment covers. Used for automated payment application.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'The date on which the payment was reversed or cancelled. Used for financial period reconciliation.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'Business reason for reversing or cancelling the payment. Used for root cause analysis and process improvement.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unappliedBalance rdf:type rdf:Property ;
    rdfs:label 'Unapplied Balance' ;
    rdfs:comment 'The portion of the payment amount that has not yet been applied to any invoice. Represents customer credit or overpayment requiring manual review.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'Tax amount withheld by the customer at source as per local tax regulations. Reduces the net payment received.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingTaxCertificateReference rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Certificate Reference' ;
    rdfs:comment 'Reference to the tax withholding certificate provided by the customer. Required for tax compliance and audit.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount' ;
    rdfs:comment 'The monetary amount from the payment that is allocated to this specific open item. Must not exceed the payment amount or the open item balance.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Date' ;
    rdfs:comment 'The business date on which the payment was allocated to the open item. Determines AR aging bucket calculation.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Number' ;
    rdfs:comment 'Business-readable unique identifier for the payment allocation. Used for audit trail and user reference.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Allocation Timestamp' ;
    rdfs:comment 'Precise date and time when the allocation was created in the system. Used for audit and sequencing.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:autoMatchConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Auto Match Confidence Score' ;
    rdfs:comment 'Machine learning confidence score (0-100) indicating the likelihood that the automatic payment-to-invoice match is correct. Supports cash application automation and exception handling.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'SAP S/4HANA clearing document reference that records the offsetting entries in the AR sub-ledger. Critical for financial reconciliation and audit.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Percentage rate of early payment discount applied. Nullable when no discount applies.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'The fiscal period (month) within the fiscal year when the allocation was posted. Supports monthly AR close and reporting.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'The fiscal year in which the allocation was posted. Used for period-based financial reporting and AR aging analysis.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:localCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Amount' ;
    rdfs:comment 'Allocated amount converted to the company\'s local reporting currency. Used for consolidated financial reporting.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchingMethod rdf:type rdf:Property ;
    rdfs:label 'Matching Method' ;
    rdfs:comment 'The technique used to match the payment to the open item: exact_invoice_match (invoice number provided), amount_match (amount-based matching), customer_match (customer-level matching), remittance_advice (EDI 820 or bank file), manual (user-entered), ai_predicted (ML model).' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openBalanceAfter rdf:type rdf:Property ;
    rdfs:label 'Open Balance After' ;
    rdfs:comment 'The remaining outstanding balance of the open item after this allocation. Zero indicates full settlement. Drives aging bucket recalculation.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openBalanceBefore rdf:type rdf:Property ;
    rdfs:label 'Open Balance Before' ;
    rdfs:comment 'The outstanding balance of the open item immediately before this allocation was applied. Used for reconciliation and audit.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The date on which the allocation was posted to the general ledger. May differ from allocation_date due to period-end processing.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'The effective date for interest calculation and cash flow purposes. Typically the bank value date from the payment transaction.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffAmount rdf:type rdf:Property ;
    rdfs:label 'Write Off Amount' ;
    rdfs:comment 'Amount written off as uncollectible during this allocation. Typically small residual balances or bad debt. Nullable when not applicable.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffReasonCode rdf:type rdf:Property ;
    rdfs:label 'Write Off Reason Code' ;
    rdfs:comment 'Classification of why the write-off was applied: bad_debt (uncollectible), small_balance (immaterial residual), customer_dispute (settlement concession), bankruptcy (insolvency), goodwill (customer retention), other.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivableId rdf:type rdf:Property ;
    rdfs:label 'Receivable Id' ;
    rdfs:comment 'Unique identifier for the accounts receivable balance record.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectionsContactId rdf:type rdf:Property ;
    rdfs:label 'Collections Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: Collections and dunning workflow: logistics AR teams direct dunning letters and collection calls to a designated customer contact. Linking receivable to contact enables automated dunning targeting the' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:agingBucket rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket' ;
    rdfs:comment 'Classification of the receivable based on days outstanding: current (0 days), 1-30 days, 31-60 days, 61-90 days, or over 90 days past due.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Ar Balance Amount' ;
    rdfs:comment 'Total outstanding amount owed by the customer at the snapshot date.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:badDebtProvisionAmount rdf:type rdf:Property ;
    rdfs:label 'Bad Debt Provision Amount' ;
    rdfs:comment 'Amount reserved as provision for potential bad debt based on credit risk assessment and aging analysis.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessArea rdf:type rdf:Property ;
    rdfs:label 'Business Area' ;
    rdfs:comment 'Business area or division to which this receivable is attributed for internal reporting and profitability analysis.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionAgencyName rdf:type rdf:Property ;
    rdfs:label 'Collection Agency Name' ;
    rdfs:comment 'Name of the external collection agency handling the receivable, if referred.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionAgencyReferralFlag rdf:type rdf:Property ;
    rdfs:label 'Collection Agency Referral Flag' ;
    rdfs:comment 'Indicates whether the receivable has been referred to an external collection agency (True) or not (False).' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collectionReferralDate rdf:type rdf:Property ;
    rdfs:label 'Collection Referral Date' ;
    rdfs:comment 'Date when the receivable was referred to the external collection agency.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'Company code representing the legal entity that owns this receivable in the SAP S/4HANA Finance system.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentAmount rdf:type rdf:Property ;
    rdfs:label 'Current Amount' ;
    rdfs:comment 'Portion of the AR balance that is not yet past due (0 days outstanding).' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:days130Amount rdf:type rdf:Property ;
    rdfs:label 'Days 1 30 Amount' ;
    rdfs:comment 'Portion of the AR balance that is 1 to 30 days past due.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:days3160Amount rdf:type rdf:Property ;
    rdfs:label 'Days 31 60 Amount' ;
    rdfs:comment 'Portion of the AR balance that is 31 to 60 days past due.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:days6190Amount rdf:type rdf:Property ;
    rdfs:label 'Days 61 90 Amount' ;
    rdfs:comment 'Portion of the AR balance that is 61 to 90 days past due.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysOver90Amount rdf:type rdf:Property ;
    rdfs:label 'Days Over 90 Amount' ;
    rdfs:comment 'Portion of the AR balance that is more than 90 days past due.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Hold Flag' ;
    rdfs:comment 'Indicates whether the receivable is on hold due to a customer dispute (True) or not (False).' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputedAmount rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount' ;
    rdfs:comment 'Total amount currently under dispute by the customer.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dunningDate rdf:type rdf:Property ;
    rdfs:label 'Dunning Date' ;
    rdfs:comment 'Date when the most recent dunning notice was sent to the customer.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Current stage of the collection process: none, first notice, second notice, final notice, collections, or legal action.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInvoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Last Invoice Amount' ;
    rdfs:comment 'Amount of the most recent invoice issued to the customer.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastInvoiceDate rdf:type rdf:Property ;
    rdfs:label 'Last Invoice Date' ;
    rdfs:comment 'Date of the most recent invoice issued to the customer.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Last Payment Amount' ;
    rdfs:comment 'Amount of the most recent payment received from the customer.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Payment Date' ;
    rdfs:comment 'Date of the most recent payment received from the customer.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapCustomerAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Customer Account Number' ;
    rdfs:comment 'Customer account number in the SAP S/4HANA Finance system for reconciliation and integration.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:snapshotDate rdf:type rdf:Property ;
    rdfs:label 'Snapshot Date' ;
    rdfs:comment 'Date on which this receivable balance snapshot was captured for reporting and analysis.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffDate rdf:type rdf:Property ;
    rdfs:label 'Write Off Date' ;
    rdfs:comment 'Date when the receivable was written off as uncollectible.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffStatus rdf:type rdf:Property ;
    rdfs:label 'Write Off Status' ;
    rdfs:comment 'Indicates whether the receivable is active, partially written off, or fully written off as uncollectible.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Audit Completion Timestamp' ;
    rdfs:comment 'Timestamp when the audit was completed and a final determination was made (approved, disputed, or adjusted).' ;
    rdfs:domain ind:FreightAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:auditReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this freight audit case for tracking and communication purposes.' ;
    rdfs:domain ind:FreightAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Audit Start Timestamp' ;
    rdfs:comment 'Timestamp when the audit process was initiated for this carrier invoice.' ;
    rdfs:domain ind:FreightAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:carrierInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Invoice Number' ;
    rdfs:comment 'The invoice number issued by the carrier for the freight charges being audited. This is the primary document under review.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierInvoicedAmount rdf:type rdf:Property ;
    rdfs:label 'Carrier Invoiced Amount' ;
    rdfs:comment 'The total amount the carrier invoiced for this shipment, subject to audit verification.' ;
    rdfs:domain ind:FreightAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedRateAmount rdf:type rdf:Property ;
    rdfs:label 'Contracted Rate Amount' ;
    rdfs:comment 'The rate amount agreed upon in the contract or tariff for this shipment, used as the baseline for audit comparison.' ;
    rdfs:domain ind:FreightAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'The date the shipment was delivered, used to validate SLA compliance and service failure deductions.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dimWeightContractedKg rdf:type rdf:Property ;
    rdfs:label 'Dim Weight Contracted Kg' ;
    rdfs:comment 'The dimensional weight (volumetric weight) calculated per contract terms, used when DIM weight exceeds actual weight for rate determination.' ;
    rdfs:domain ind:FreightAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dimWeightInvoicedKg rdf:type rdf:Property ;
    rdfs:label 'Dim Weight Invoiced Kg' ;
    rdfs:comment 'The dimensional weight the carrier used for invoicing, which may differ due to measurement discrepancies or calculation method differences.' ;
    rdfs:domain ind:FreightAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeNotes rdf:type rdf:Property ;
    rdfs:label 'Dispute Notes' ;
    rdfs:comment 'Free-text notes documenting the nature of the dispute, findings, carrier responses, and resolution discussions. Used for audit trail and knowledge management.' ;
    rdfs:domain ind:FreightAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingType rdf:type rdf:Property ;
    rdfs:label 'Finding Type' ;
    rdfs:comment 'Classification of the audit finding: rate_overcharge (carrier charged higher rate than contracted), duplicate_billing (same shipment invoiced multiple times), accessorial_not_contracted (charges for services not in contract), weight_discrepancy (invoiced weight differs from actual), dim_discrepancy (dimensional weight calculation error), service_failure_deduction (SLA breach requiring credit), fuel_surcharge_miscalculation (BAF/fuel surcharge incorrectly applied), no_finding (invoice validated as correct). [ENUM-REF-CANDIDATE: rate_overcharge|duplicate_billing|accessorial_not_contracted|weight_discrepancy|dim_discrepancy|service_failure_deduction|fuel_surcharge_miscalculation|no_finding — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FreightAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDueDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Due Date' ;
    rdfs:comment 'The payment due date specified on the carrier invoice. Audit completion must occur before this date to prevent late payment penalties.' ;
    rdfs:domain ind:FreightAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:savingsCapturedAmount rdf:type rdf:Property ;
    rdfs:label 'Savings Captured Amount' ;
    rdfs:comment 'The total amount of cost savings or recovery achieved through this audit, representing overcharges identified and successfully recovered or credited. Typically 2-8% of freight spend for large shippers.' ;
    rdfs:domain ind:FreightAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipmentDate rdf:type rdf:Property ;
    rdfs:label 'Shipment Date' ;
    rdfs:comment 'The date the shipment was picked up or departed, used to validate rate applicability and service level compliance.' ;
    rdfs:domain ind:FreightAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Reference Number' ;
    rdfs:comment 'Reference to the shipment associated with this audit. May be an internal shipment ID, AWB (Air Waybill), BOL (Bill of Lading), or container number depending on service type.' ;
    rdfs:domain ind:FreightAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'The absolute difference between the contracted rate and the carrier-invoiced amount. Positive values indicate overcharges; negative values indicate undercharges.' ;
    rdfs:domain ind:FreightAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeContractedCbm rdf:type rdf:Property ;
    rdfs:label 'Volume Contracted Cbm' ;
    rdfs:comment 'The shipment volume (in cubic meters) used in the contracted rate calculation.' ;
    rdfs:domain ind:FreightAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeInvoicedCbm rdf:type rdf:Property ;
    rdfs:label 'Volume Invoiced Cbm' ;
    rdfs:comment 'The shipment volume (in cubic meters) the carrier used for invoicing.' ;
    rdfs:domain ind:FreightAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightContractedKg rdf:type rdf:Property ;
    rdfs:label 'Weight Contracted Kg' ;
    rdfs:comment 'The shipment weight (in kilograms) used in the contracted rate calculation, typically from the original booking or manifest.' ;
    rdfs:domain ind:FreightAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightInvoicedKg rdf:type rdf:Property ;
    rdfs:label 'Weight Invoiced Kg' ;
    rdfs:comment 'The shipment weight (in kilograms) the carrier used for invoicing, which may differ from the contracted weight due to reweighing or discrepancies.' ;
    rdfs:domain ind:FreightAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightVarianceKg rdf:type rdf:Property ;
    rdfs:label 'Weight Variance Kg' ;
    rdfs:comment 'The difference between invoiced weight and contracted weight in kilograms. Positive values indicate the carrier invoiced for more weight than contracted.' ;
    rdfs:domain ind:FreightAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Date' ;
    rdfs:comment 'Date on which the dispute was resolved and the payable was cleared for payment. Null if dispute is unresolved or no dispute exists.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netPayableAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payable Amount' ;
    rdfs:comment 'Net amount payable to the carrier after applying taxes, discounts, and any other adjustments. This is the final amount to be paid.' ;
    rdfs:domain ind:CarrierPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payableAmount rdf:type rdf:Property ;
    rdfs:label 'Payable Amount' ;
    rdfs:comment 'Total amount owed to the carrier for services rendered, in the specified currency. Represents the gross payable before any adjustments or deductions.' ;
    rdfs:domain ind:CarrierPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payableReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payable Reference Number' ;
    rdfs:comment 'Externally-known unique reference number for this carrier payable transaction, used for reconciliation and audit purposes.' ;
    rdfs:domain ind:CarrierPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapVendorDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Vendor Document Number' ;
    rdfs:comment 'SAP S/4HANA vendor payment document reference number. Links this payable to the financial system payment record.' ;
    rdfs:domain ind:CarrierPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceEndDate rdf:type rdf:Property ;
    rdfs:label 'Service End Date' ;
    rdfs:comment 'Date on which the carrier service period ended. Used for accrual accounting and service period tracking.' ;
    rdfs:domain ind:CarrierPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceStartDate rdf:type rdf:Property ;
    rdfs:label 'Service Start Date' ;
    rdfs:comment 'Date on which the carrier service period began. Used for accrual accounting and service period tracking.' ;
    rdfs:domain ind:CarrierPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Customer Invoice Id' ;
    rdfs:comment 'Reference to the customer invoice being disputed. Links to the invoice that contains the disputed charges.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:raisedByContactId rdf:type rdf:Property ;
    rdfs:label 'Raised By Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: Dispute management workflow: logistics billing disputes are raised by a specific customer contact (e.g., AP manager). Linking enables SLA tracking, communication routing, and CSAT measurement per cont' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:assignedToUser rdf:type rdf:Property ;
    rdfs:label 'Assigned To User' ;
    rdfs:comment 'The individual user or agent currently assigned to handle the dispute. May be employee ID or username from Workday HCM.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionTaken rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Taken' ;
    rdfs:comment 'Description of corrective actions implemented to prevent recurrence of similar disputes (e.g., rate table updated, training provided, process revised).' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Rating' ;
    rdfs:comment 'Customer-provided satisfaction rating for the dispute resolution process, typically on a scale of 1-5 or 1-10. Captured via post-resolution survey.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeCategory rdf:type rdf:Property ;
    rdfs:label 'Dispute Category' ;
    rdfs:comment 'High-level categorization of the dispute for reporting and root cause analysis. Values: pricing (rate or charge calculation issues), operations (service delivery failures), documentation (missing or incorrect paperwork), compliance (customs or regulatory issues), service_quality (performance below SLA), billing_error (invoice processing mistakes).' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current lifecycle status of the dispute. Values: open (newly raised, awaiting review), under_review (being investigated by billing or operations team), escalated (requires senior management or legal review), resolved_accepted (dispute validated, customer claim accepted), resolved_rejected (dispute investigated and rejected), partially_accepted (partial credit issued). [ENUM-REF-CANDIDATE: open|under_review|escalated|resolved_accepted|resolved_rejected|partially_accepted|withdrawn|pending_customer_response|pending_carrier_response — promote to reference product]' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeType rdf:type rdf:Property ;
    rdfs:label 'Dispute Type' ;
    rdfs:comment 'Classification of the dispute by root cause. Values: rate_dispute (incorrect rate applied), weight_dispute (chargeable weight calculation error), service_failure (service not delivered as promised), duplicate_charge (same charge billed multiple times), unauthorized_surcharge (surcharge applied without authorization), sla_breach_deduction (customer claims SLA breach and requests deduction). [ENUM-REF-CANDIDATE: rate_dispute|weight_dispute|service_failure|duplicate_charge|unauthorized_surcharge|sla_breach_deduction|customs_duty_dispute|dimensional_weight_dispute|fuel_surcharge_dispute|accessorial_charge_dispute — promote to reference product]' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedWeightKg rdf:type rdf:Property ;
    rdfs:label 'Disputed Weight Kg' ;
    rdfs:comment 'The weight value that the customer claims is correct, if the dispute is related to weight calculation discrepancies.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:raisedChannel rdf:type rdf:Property ;
    rdfs:label 'Raised Channel' ;
    rdfs:comment 'The channel through which the dispute was submitted. Values: email, phone, web_portal (customer self-service portal), edi (Electronic Data Interchange), salesforce_case (CRM service case), manual_entry (internal team entry).' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raisedDate rdf:type rdf:Property ;
    rdfs:label 'Raised Date' ;
    rdfs:comment 'The date the dispute was formally raised by the customer or internal team. Represents the business event timestamp for dispute initiation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reasonNarrative rdf:type rdf:Property ;
    rdfs:label 'Reason Narrative' ;
    rdfs:comment 'Free-text narrative provided by the customer or internal team explaining the reason for the dispute. Captures detailed justification and supporting context.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionAmount rdf:type rdf:Property ;
    rdfs:label 'Resolution Amount' ;
    rdfs:comment 'The monetary amount credited or adjusted as a result of the dispute resolution. May be equal to, less than, or zero relative to disputed_amount.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'The date the dispute was formally resolved and closed. Represents the business event timestamp for dispute closure.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionType rdf:type rdf:Property ;
    rdfs:label 'Resolution Type' ;
    rdfs:comment 'The type of resolution action taken. Values: full_credit (entire disputed amount credited), partial_credit (portion of disputed amount credited), no_credit (dispute rejected, no adjustment), rate_adjustment (rate corrected and invoice adjusted), rebill (invoice cancelled and reissued), waiver (charge waived as goodwill gesture).' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceFailureType rdf:type rdf:Property ;
    rdfs:label 'Service Failure Type' ;
    rdfs:comment 'Specific type of service failure if dispute_type is service_failure (e.g., late_delivery, damaged_goods, lost_shipment, incorrect_routing, missed_pickup). Used for operational performance analysis.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressBookId rdf:type rdf:Property ;
    rdfs:label 'Billing Address Book Id' ;
    rdfs:comment 'Foreign key linking to customer.address_book. Business justification: Billing account address normalization: logistics billing accounts reference a validated billing address from the customer address book for invoice delivery and regulatory compliance. billing_address_l' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AddressBook .

ind:cycleId rdf:type rdf:Property ;
    rdfs:label 'Cycle Id' ;
    rdfs:comment 'Foreign key linking to billing.billing_cycle. Business justification: Account currently has billing_cycle as STRING. This should be normalized to reference billing.billing_cycle master table. The billing_cycle_id FK allows joining to get cycle configuration (frequency, ' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cycle .

ind:parentBillingAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Billing Account Id' ;
    rdfs:comment 'Reference to the parent billing account if this account is part of a hierarchical billing structure. Used for consolidated invoicing and corporate account management.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingAccount .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'Descriptive name for the billing account, typically reflecting the customer legal entity or division name for this billing relationship.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoPayEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Pay Enabled Flag' ;
    rdfs:comment 'Indicates whether automatic payment processing is enabled for this account. When true, invoices are automatically charged to the preferred payment method on the due date.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Billing Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which this account is billed. All invoices and payments for this account are denominated in this currency.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAreaCode rdf:type rdf:Property ;
    rdfs:label 'Business Area Code' ;
    rdfs:comment 'SAP business area code representing the service line or division (e.g., express parcel, freight forwarding, contract logistics) for internal P&L (Profit and Loss) reporting.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidatedBillingFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidated Billing Flag' ;
    rdfs:comment 'Indicates whether this account participates in consolidated billing where multiple accounts or locations are invoiced together under a master account.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dunningBlockFlag rdf:type rdf:Property ;
    rdfs:label 'Dunning Block Flag' ;
    rdfs:comment 'Indicates whether automated dunning (collections reminders) is blocked for this account. True when account is in dispute resolution, under special payment arrangement, or managed by dedicated account manager.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dunningProfile rdf:type rdf:Property ;
    rdfs:label 'Dunning Profile' ;
    rdfs:comment 'Collections strategy profile defining the escalation sequence and tone for overdue payment reminders. Standard for typical accounts. Aggressive for high-risk accounts. Gentle for strategic customers. VIP for top-tier accounts with relationship managers. Legal for accounts in litigation.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Invoice Delivery Method' ;
    rdfs:comment 'Primary method by which invoices are delivered to the customer. Email for electronic PDF delivery. EDI (Electronic Data Interchange) for automated system-to-system transmission. Portal for customer self-service download. Post for physical mail. Fax for legacy customers.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Invoice Email Address' ;
    rdfs:comment 'Primary email address to which electronic invoices are sent. May differ from the customer contact email if invoices go to accounts payable department.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paperlessBillingFlag rdf:type rdf:Property ;
    rdfs:label 'Paperless Billing Flag' ;
    rdfs:comment 'Indicates whether the customer has opted for paperless billing. When true, all invoices and statements are delivered electronically only, with no postal mail.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredPaymentMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Payment Method' ;
    rdfs:comment 'Customer preferred payment instrument. ACH (Automated Clearing House) for US bank transfers. Wire transfer for international payments. Credit card for smaller accounts. Check for traditional payment. Direct debit for automated recurring payments.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCustomerAccountCode rdf:type rdf:Property ;
    rdfs:label 'Sap Customer Account Code' ;
    rdfs:comment 'Customer account number in SAP S/4HANA Finance system. Used for integration and reconciliation between lakehouse and ERP system of record.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Certificate Number' ;
    rdfs:comment 'Reference number of the tax exemption certificate on file, if applicable. Required for audit trail when tax exemption status is exempt or partially exempt.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Status' ;
    rdfs:comment 'Indicates whether this billing account is subject to standard taxation, fully exempt (e.g., government entities, non-profits), or partially exempt for specific service types.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableServiceTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Service Types' ;
    rdfs:comment 'Comma-separated list of service types to which this tax schedule applies (e.g., express_parcel, air_freight, ocean_freight, road_freight, rail_freight, warehousing, customs_brokerage, last_mile_delivery).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compoundTaxFlag rdf:type rdf:Property ;
    rdfs:label 'Compound Tax Flag' ;
    rdfs:comment 'Indicates whether this tax is calculated on top of other taxes (compound/cascading tax). True if compound tax applies, False if calculated on base amount only.' ;
    rdfs:domain ind:TaxSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exemptionCategory rdf:type rdf:Property ;
    rdfs:label 'Exemption Category' ;
    rdfs:comment 'Category or code identifying the type of tax exemption that may apply (e.g., diplomatic, humanitarian, re-export, AEO certified, C-TPAT certified). Nullable if no exemption applies.' ;
    rdfs:domain ind:TaxSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionCertificateRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Exemption Certificate Required Flag' ;
    rdfs:comment 'Indicates whether a tax exemption certificate must be provided to apply this schedule. True if certificate is required, False otherwise.' ;
    rdfs:domain ind:TaxSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hsCodeRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Hs Code Range End' ;
    rdfs:comment 'Ending HS Code in the range of commodity codes to which this tax schedule applies. Nullable if not commodity-specific.' ;
    rdfs:domain ind:TaxSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsCodeRangeStart rdf:type rdf:Property ;
    rdfs:label 'Hs Code Range Start' ;
    rdfs:comment 'Starting HS Code in the range of commodity codes to which this tax schedule applies. Nullable if not commodity-specific.' ;
    rdfs:domain ind:TaxSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionCountryCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Country Code' ;
    rdfs:comment 'Three-letter ISO country code identifying the tax jurisdiction country where this tax schedule applies.' ;
    rdfs:domain ind:TaxSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionStateProvince rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction State Province' ;
    rdfs:comment 'State, province, or regional subdivision within the country where this tax schedule applies. Nullable for country-level taxes.' ;
    rdfs:domain ind:TaxSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionZoneType rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Zone Type' ;
    rdfs:comment 'Type of economic or customs zone. FTZ (Free Trade Zone), ICD (Inland Container Depot), CFS (Container Freight Station), or special economic zone with distinct tax treatment.' ;
    rdfs:domain ind:TaxSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumTaxableAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Taxable Amount' ;
    rdfs:comment 'Maximum transaction amount threshold above which this tax schedule does not apply or a different schedule takes effect. Nullable if no maximum threshold exists.' ;
    rdfs:domain ind:TaxSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumTaxableAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Taxable Amount' ;
    rdfs:comment 'Minimum transaction amount threshold below which this tax schedule does not apply. Nullable if no minimum threshold exists.' ;
    rdfs:domain ind:TaxSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority' ;
    rdfs:comment 'Name of the government or regulatory body that mandates this tax schedule (e.g., IRS, HMRC, GST Council, Customs Authority).' ;
    rdfs:domain ind:TaxSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference Number' ;
    rdfs:comment 'Official reference number, gazette notification, or legal citation from the regulatory authority that establishes this tax schedule.' ;
    rdfs:domain ind:TaxSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reverseChargeApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Reverse Charge Applicable Flag' ;
    rdfs:comment 'Indicates whether reverse charge mechanism applies, where the recipient of goods or services is responsible for tax payment instead of the supplier. True if reverse charge applies, False otherwise.' ;
    rdfs:domain ind:TaxSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapTaxCode rdf:type rdf:Property ;
    rdfs:label 'Sap Tax Code' ;
    rdfs:comment 'SAP tax code identifier used in SAP S/4HANA for GL posting and tax reporting. Links to SAP tax determination logic.' ;
    rdfs:domain ind:TaxSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapTaxConditionType rdf:type rdf:Property ;
    rdfs:label 'Sap Tax Condition Type' ;
    rdfs:comment 'SAP S/4HANA tax condition type code used for integration with the financial system. Maps this tax schedule to SAP pricing and billing configuration.' ;
    rdfs:domain ind:TaxSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleCode rdf:type rdf:Property ;
    rdfs:label 'Schedule Code' ;
    rdfs:comment 'Business identifier code for the tax schedule used in billing and invoicing systems. Externally known reference code.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleName rdf:type rdf:Property ;
    rdfs:label 'Schedule Name' ;
    rdfs:comment 'Descriptive name of the tax schedule for business user identification and reporting purposes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxBasis rdf:type rdf:Property ;
    rdfs:label 'Tax Basis' ;
    rdfs:comment 'The valuation basis on which the tax is calculated. CIF (Cost Insurance and Freight), DDP (Delivered Duty Paid), FOB (Free on Board), EXW (Ex Works), or other Incoterms-based valuation.' ;
    rdfs:domain ind:TaxSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Percentage' ;
    rdfs:comment 'The applicable tax rate expressed as a percentage (e.g., 15.0000 for 15%). Supports up to four decimal places for precision in multi-jurisdictional tax calculations.' ;
    rdfs:domain ind:TaxSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxReportingCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Category' ;
    rdfs:comment 'Category used for grouping tax amounts in statutory tax returns and regulatory reports (e.g., domestic sales, export sales, import duties, inter-state supplies).' ;
    rdfs:domain ind:TaxSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxScheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the tax schedule. Active schedules are in use, inactive are retired, pending are awaiting approval, superseded have been replaced by newer schedules.' ;
    rdfs:domain ind:TaxSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxType rdf:type rdf:Property ;
    rdfs:label 'Tax Type' ;
    rdfs:comment 'Classification of the tax applied. VAT (Value Added Tax), GST (Goods and Services Tax), WHT (Withholding Tax), customs duty, excise tax, or service tax.' ;
    rdfs:domain ind:TaxSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeAgreementCode rdf:type rdf:Property ;
    rdfs:label 'Trade Agreement Code' ;
    rdfs:comment 'Code identifying the bilateral or multilateral trade agreement under which preferential tax rates or exemptions apply (e.g., USMCA, EU-UK TCA, RCEP). Nullable if no trade agreement applies.' ;
    rdfs:domain ind:TaxSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxFlag rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Flag' ;
    rdfs:comment 'Indicates whether this schedule represents a withholding tax that must be deducted at source. True if withholding tax applies, False otherwise.' ;
    rdfs:domain ind:TaxSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableCustomerSegments rdf:type rdf:Property ;
    rdfs:label 'Applicable Customer Segments' ;
    rdfs:comment 'Comma-separated list of customer segments to which this payment term is applicable (e.g., enterprise, SMB, government, retail). Used to enforce eligibility rules during contract setup and invoicing. [ENUM-REF-CANDIDATE: enterprise|smb|government|retail|ecommerce|3pl|freight_forwarder — promote to reference product]' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableServiceLines rdf:type rdf:Property ;
    rdfs:label 'Applicable Service Lines' ;
    rdfs:comment 'Comma-separated list of service lines to which this payment term applies (e.g., express_parcel, freight_forwarding, warehousing, customs_brokerage, ecommerce_fulfillment). Ensures payment terms align with service-specific billing policies. [ENUM-REF-CANDIDATE: express_parcel|freight_forwarding|warehousing|customs_brokerage|ecommerce_fulfillment|contract_logistics|last_mile — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoDunningEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Dunning Enabled Flag' ;
    rdfs:comment 'Indicates whether automated dunning (collections reminder) processes are enabled for invoices using this payment term. True for standard credit terms. False for prepaid or special arrangement terms.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:codCollectionMethod rdf:type rdf:Property ;
    rdfs:label 'Cod Collection Method' ;
    rdfs:comment 'Specifies the acceptable payment collection method for COD (Cash on Delivery) terms. Applicable only when type is cash_on_delivery. Not_applicable for non-COD terms.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coupaPaymentTermCode rdf:type rdf:Property ;
    rdfs:label 'Coupa Payment Term Code' ;
    rdfs:comment 'Payment term code used in Coupa Procurement and Spend Management system for carrier payables and supplier invoice processing. Ensures alignment between customer receivables and carrier payables payment terms.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyRestrictions rdf:type rdf:Property ;
    rdfs:label 'Currency Restrictions' ;
    rdfs:comment 'Comma-separated list of ISO 4217 three-letter currency codes for which this payment term is valid (e.g., USD, EUR, GBP). Null or empty if the term applies to all currencies. Used to enforce currency-specific payment policies.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultForCustomerSegment rdf:type rdf:Property ;
    rdfs:label 'Default For Customer Segment' ;
    rdfs:comment 'Customer segment for which this payment term is the default option during contract setup or customer onboarding. Null if not a default term. Streamlines contract creation workflows.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultForServiceLine rdf:type rdf:Property ;
    rdfs:label 'Default For Service Line' ;
    rdfs:comment 'Service line for which this payment term is the default option during contract setup or service agreement creation. Null if not a default term. Ensures service-specific billing alignment.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningStartDaysAfterDue rdf:type rdf:Property ;
    rdfs:label 'Dunning Start Days After Due' ;
    rdfs:comment 'Number of days after the invoice due date when automated dunning (collections reminder) process begins. Null if auto_dunning_enabled_flag is false.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:earlyPaymentDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Percentage' ;
    rdfs:comment 'Percentage discount offered if payment is made within the early payment discount period (e.g., 2.00 for 2% discount in 2/10 NET30 terms). Null if no early payment discount applies.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Grace Period Days' ;
    rdfs:comment 'Number of additional days after the net due date before late payment penalties are applied. Provides a buffer period for customers. Zero or null if no grace period is offered.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:installmentCount rdf:type rdf:Property ;
    rdfs:label 'Installment Count' ;
    rdfs:comment 'Number of installment payments allowed under this payment term. Applicable for installment-based payment terms. Null or 1 for single-payment terms.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:installmentFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Installment Frequency Days' ;
    rdfs:comment 'Number of days between each installment payment. Applicable for installment-based payment terms. Null for single-payment terms.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:latePaymentPenaltyRate rdf:type rdf:Property ;
    rdfs:label 'Late Payment Penalty Rate' ;
    rdfs:comment 'Percentage penalty or interest rate applied to overdue balances after the net payment due date. Expressed as an annual percentage rate (APR) or per-period rate. Null if no late payment penalty applies.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumCreditLimit rdf:type rdf:Property ;
    rdfs:label 'Maximum Credit Limit' ;
    rdfs:comment 'Maximum outstanding accounts receivable balance allowed for customers using this payment term. Enforces credit exposure limits. Null if no limit applies (e.g., for prepaid or COD terms).' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumCreditScoreRequired rdf:type rdf:Property ;
    rdfs:label 'Minimum Credit Score Required' ;
    rdfs:comment 'Minimum credit risk score a customer must have to be eligible for this payment term. Used to enforce credit policy and reduce bad debt risk. Null if no minimum score is required.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netDays rdf:type rdf:Property ;
    rdfs:label 'Net Days' ;
    rdfs:comment 'Number of days from invoice date by which full payment is due. Standard payment window for the term (e.g., 30 for NET30, 60 for NET60). Zero for immediate payment terms like COD or PREPAID.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentTermDescription rdf:type rdf:Property ;
    rdfs:label 'Payment Term Description' ;
    rdfs:comment 'Detailed explanation of the payment term, including conditions, discount eligibility, and any special instructions. Provides clarity for finance teams and customers.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermName rdf:type rdf:Property ;
    rdfs:label 'Payment Term Name' ;
    rdfs:comment 'Full descriptive name of the payment term (e.g., Net 30 Days, Cash on Delivery, Prepaid, 2% 10 Net 30). Human-readable label used in customer-facing documents and internal reports.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Term Status' ;
    rdfs:comment 'Current lifecycle status of the payment term. Active terms are available for use in new contracts and invoices. Inactive or deprecated terms are retained for historical reference but not available for new transactions.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermType rdf:type rdf:Property ;
    rdfs:label 'Payment Term Type' ;
    rdfs:comment 'Classification of the payment term based on its structure and purpose. Determines how the term is applied in billing and collections workflows.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prepaymentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Prepayment Required Flag' ;
    rdfs:comment 'Indicates whether full payment must be received before service delivery or shipment. True for prepaid terms. False for post-service payment terms.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresCreditApprovalFlag rdf:type rdf:Property ;
    rdfs:label 'Requires Credit Approval Flag' ;
    rdfs:comment 'Indicates whether assignment of this payment term to a customer requires credit manager approval. True for extended terms (e.g., NET90) or high-risk terms. False for standard or prepaid terms.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueRecognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Method' ;
    rdfs:comment 'Specifies the IFRS 15 revenue recognition method associated with this payment term. Point_in_time for immediate recognition (e.g., COD, prepaid). Over_time or deferred for extended terms. Guides accounting treatment.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPaymentTermKey rdf:type rdf:Property ;
    rdfs:label 'Sap Payment Term Key' ;
    rdfs:comment 'Four-character alphanumeric key used in SAP S/4HANA Finance to represent this payment term. Enables seamless integration with SAP AR, AP, and revenue recognition modules.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'Total number of active customer accounts, contracts, or invoices currently using this payment term. Provides insight into term popularity and impact of changes. Updated periodically via batch process.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableCustomerTiers rdf:type rdf:Property ;
    rdfs:label 'Applicable Customer Tiers' ;
    rdfs:comment 'Comma-separated list of customer tier codes or segments to which this billing cycle applies (e.g., ENTERPRISE, SMB, RETAIL, PLATINUM, GOLD). Empty means applicable to all customer tiers.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverRoleCode rdf:type rdf:Property ;
    rdfs:label 'Approver Role Code' ;
    rdfs:comment 'Role code or job function authorized to approve invoices generated under this billing cycle (e.g., BILLING_MANAGER, FINANCE_CONTROLLER). Null if no approval required.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoInvoiceGenerationFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Invoice Generation Flag' ;
    rdfs:comment 'Indicates whether invoices are automatically generated by the billing system when the trigger event occurs (True) or require manual approval (False).' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consolidationLevel rdf:type rdf:Property ;
    rdfs:label 'Consolidation Level' ;
    rdfs:comment 'Defines the level at which charges are consolidated into invoices for this billing cycle (e.g., shipment-level for individual AWB/BOL invoices, account-level for consolidated monthly statements).' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCode rdf:type rdf:Property ;
    rdfs:label 'Cycle Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the billing cycle configuration (e.g., MONTHLY_STD, WEEKLY_EXPRESS, ONDEMAND_FCL).' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleName rdf:type rdf:Property ;
    rdfs:label 'Cycle Name' ;
    rdfs:comment 'Human-readable descriptive name of the billing cycle (e.g., Standard Monthly Billing, Weekly Express Parcel Cycle).' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleStatus rdf:type rdf:Property ;
    rdfs:label 'Cycle Status' ;
    rdfs:comment 'Current lifecycle status of the billing cycle configuration.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionSlaDays rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Sla Days' ;
    rdfs:comment 'Target number of days for resolving billing disputes for invoices generated under this billing cycle, as defined in customer SLA agreements.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dunningEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Dunning Enabled Flag' ;
    rdfs:comment 'Indicates whether automated dunning (payment reminder) processes are enabled for overdue invoices generated under this billing cycle.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dunningGracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Dunning Grace Period Days' ;
    rdfs:comment 'Number of days after payment due date before the first dunning notice is sent. Null if dunning is not enabled.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endDay rdf:type rdf:Property ;
    rdfs:label 'End Day' ;
    rdfs:comment 'Day of the month or week when the billing cycle period ends (1-31 for monthly, 1-7 for weekly). Null for on-demand cycles.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'Frequency at which invoices are generated for accounts assigned to this billing cycle. [ENUM-REF-CANDIDATE: daily|weekly|bi-weekly|monthly|quarterly|annual|on-demand — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDeliveryLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Invoice Delivery Lead Time Days' ;
    rdfs:comment 'Number of days between invoice generation and invoice delivery/dispatch to the customer.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceFormat rdf:type rdf:Property ;
    rdfs:label 'Invoice Format' ;
    rdfs:comment 'Default format for invoice delivery under this billing cycle (e.g., PDF for email, EDI-810 for Electronic Data Interchange, XML for API integration).' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceGenerationTrigger rdf:type rdf:Property ;
    rdfs:label 'Invoice Generation Trigger' ;
    rdfs:comment 'Business event that triggers invoice generation for this billing cycle (e.g., cycle-end for periodic billing, shipment-completion for transactional billing, pod-confirmed for proof-of-delivery based billing).' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latePaymentFeePercentage rdf:type rdf:Property ;
    rdfs:label 'Late Payment Fee Percentage' ;
    rdfs:comment 'Percentage fee applied to overdue invoice amounts for late payment under this billing cycle. Null if no late fees apply.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumInvoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Invoice Amount' ;
    rdfs:comment 'Minimum invoice amount threshold below which invoices are not generated and charges are carried forward to the next billing cycle. Null if no minimum applies.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDueOffsetDays rdf:type rdf:Property ;
    rdfs:label 'Payment Due Offset Days' ;
    rdfs:comment 'Number of days from invoice date when payment is due, defining the payment terms for this billing cycle (e.g., 30 for Net 30, 15 for Net 15).' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:startDay rdf:type rdf:Property ;
    rdfs:label 'Start Day' ;
    rdfs:comment 'Day of the month or week when the billing cycle period begins (1-31 for monthly, 1-7 for weekly). Null for on-demand cycles.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Tax Calculation Method' ;
    rdfs:comment 'Method for calculating and displaying tax on invoices generated under this billing cycle (e.g., inclusive for tax-included pricing, exclusive for tax added at invoice time, reverse-charge for VAT reverse charge mechanism).' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByRateCardId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rate Card Id' ;
    rdfs:comment 'Identifier of the rate card that replaces this one, supporting version control and rate card lifecycle management. Null if this is the current version.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateCard .

ind:accessorialChargesIncluded rdf:type rdf:Property ;
    rdfs:label 'Accessorial Charges Included' ;
    rdfs:comment 'Indicates whether common accessorial charges (e.g., liftgate, residential delivery, inside delivery, appointment) are included in the base rate or billed separately.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseRateMaximum rdf:type rdf:Property ;
    rdfs:label 'Base Rate Maximum' ;
    rdfs:comment 'Maximum base freight rate per unit (as defined by rate_basis) applicable under this rate card. Used for ceiling pricing and rate cap enforcement.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseRateMinimum rdf:type rdf:Property ;
    rdfs:label 'Base Rate Minimum' ;
    rdfs:comment 'Minimum base freight rate per unit (as defined by rate_basis) applicable under this rate card. Used for floor pricing and minimum charge calculations.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerSegment rdf:type rdf:Property ;
    rdfs:label 'Customer Segment' ;
    rdfs:comment 'Target customer segment or tier for this rate card (e.g., \'Enterprise\', \'SMB\', \'E-Commerce\', \'Retail\', \'Government\'). Used for customer-specific or segment-specific pricing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSurchargeType rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Type' ;
    rdfs:comment 'Type of fuel surcharge mechanism: BAF (Bunker Adjustment Factor for ocean), FSC (Fuel Surcharge for air/road), fixed_percentage (static percentage), index_linked (tied to fuel price index).' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:griApplicable rdf:type rdf:Property ;
    rdfs:label 'Gri Applicable' ;
    rdfs:comment 'Indicates whether General Rate Increase adjustments apply to this rate card. GRI is a carrier-announced across-the-board rate increase, common in ocean freight.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatSurchargeApplicable rdf:type rdf:Property ;
    rdfs:label 'Hazmat Surcharge Applicable' ;
    rdfs:comment 'Indicates whether a surcharge applies for shipments containing dangerous goods or hazardous materials under this rate card.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incotermsDefault rdf:type rdf:Property ;
    rdfs:label 'Incoterms Default' ;
    rdfs:comment 'Default International Commercial Terms (Incoterms 2020) rule applied to shipments under this rate card, defining cost and risk allocation between buyer and seller (e.g., FOB, CIF, DDP, DAP, EXW). [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Charge Amount' ;
    rdfs:comment 'Maximum total charge cap per shipment under this rate card, used for contract pricing or promotional rate cards.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Charge Amount' ;
    rdfs:comment 'Minimum total charge per shipment under this rate card, regardless of weight or volume. Ensures cost recovery for small shipments.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakSeasonSurchargeApplicable rdf:type rdf:Property ;
    rdfs:label 'Peak Season Surcharge Applicable' ;
    rdfs:comment 'Indicates whether peak season surcharges (e.g., holiday season, Chinese New Year) apply to shipments priced under this rate card.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publishedDate rdf:type rdf:Property ;
    rdfs:label 'Published Date' ;
    rdfs:comment 'Date when this rate card was officially published or released to customers, sales teams, or operational systems.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateBasis rdf:type rdf:Property ;
    rdfs:label 'Rate Basis' ;
    rdfs:comment 'Unit of measure on which the base rate is calculated: per kilogram, per cubic meter (CBM), per twenty-foot equivalent unit (TEU), per shipment, per pallet, per mile, per kilometer, or per hour. [ENUM-REF-CANDIDATE: per_kg|per_cbm|per_teu|per_shipment|per_pallet|per_mile|per_km|per_hour — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardName rdf:type rdf:Property ;
    rdfs:label 'Rate Card Name' ;
    rdfs:comment 'Human-readable name of the rate card, typically describing the service type, trade lane, or customer segment (e.g., \'Asia-Europe Ocean FCL Q1 2024\', \'Express Air Domestic Standard\').' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardNumber rdf:type rdf:Property ;
    rdfs:label 'Rate Card Number' ;
    rdfs:comment 'Externally-known unique business identifier for the rate card, used in contracts, quotes, and billing references. Format: RC- followed by alphanumeric code.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Card Status' ;
    rdfs:comment 'Current lifecycle state of the rate card: draft (under construction), pending_approval (awaiting authorization), active (in use), suspended (temporarily inactive), expired (past validity), superseded (replaced by newer version), archived (historical record). [ENUM-REF-CANDIDATE: draft|pending_approval|active|suspended|expired|superseded|archived — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardType rdf:type rdf:Property ;
    rdfs:label 'Rate Card Type' ;
    rdfs:comment 'Classification of the rate card by pricing model: published (standard public rates), contract (customer-specific negotiated rates), spot (one-time market rates), promotional (limited-time discount rates), seasonal (peak/off-peak rates).' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securitySurchargeApplicable rdf:type rdf:Property ;
    rdfs:label 'Security Surcharge Applicable' ;
    rdfs:comment 'Indicates whether security-related surcharges (e.g., TSA, C-TPAT, AEO compliance fees) apply to shipments under this rate card.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thcIncluded rdf:type rdf:Property ;
    rdfs:label 'Thc Included' ;
    rdfs:comment 'Indicates whether Terminal Handling Charges (origin and destination terminal fees) are included in the base rate or billed separately.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weightBreakStructure rdf:type rdf:Property ;
    rdfs:label 'Weight Break Structure' ;
    rdfs:comment 'Pricing structure model for weight-based rates: flat (single rate regardless of weight), tiered (discrete weight bands with fixed rates), banded (progressive discounts by weight range), continuous (formula-based).' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allInRateFlag rdf:type rdf:Property ;
    rdfs:label 'All In Rate Flag' ;
    rdfs:comment 'Indicates whether this rate line represents an all-inclusive rate covering all charges (true) or a component rate requiring additional surcharges and fees (false).' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commodityClass rdf:type rdf:Property ;
    rdfs:label 'Commodity Class' ;
    rdfs:comment 'Classification of goods type or freight class applicable to this rate line. May reference NMFC class codes, IATA commodity codes, or internal classification schemes.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSurchargePct rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Pct' ;
    rdfs:comment 'Percentage fuel surcharge applied to the base rate. Reflects fluctuations in fuel costs and may be updated periodically based on fuel price indices.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatSurchargePct rdf:type rdf:Property ;
    rdfs:label 'Hazmat Surcharge Pct' ;
    rdfs:comment 'Percentage surcharge applied to the base rate for dangerous goods or hazardous materials shipments. Null if not applicable to this rate line.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineSequence rdf:type rdf:Property ;
    rdfs:label 'Line Sequence' ;
    rdfs:comment 'Sequential ordering of rate lines within the parent rate card. Used for display and processing order of tiered pricing structures.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumCharge rdf:type rdf:Property ;
    rdfs:label 'Minimum Charge' ;
    rdfs:comment 'Minimum charge amount that applies to this rate line regardless of actual weight or volume. Ensures a floor revenue for small shipments.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:negotiatedRateFlag rdf:type rdf:Property ;
    rdfs:label 'Negotiated Rate Flag' ;
    rdfs:comment 'Indicates whether this rate line was individually negotiated with a specific customer (true) or represents a standard published tariff rate (false).' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:peakSeasonSurchargePct rdf:type rdf:Property ;
    rdfs:label 'Peak Season Surcharge Pct' ;
    rdfs:comment 'Percentage surcharge applied during peak shipping seasons or high-demand periods. Null if not applicable to this rate line.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateBasisDescription rdf:type rdf:Property ;
    rdfs:label 'Rate Basis Description' ;
    rdfs:comment 'Detailed explanation of how the rate is calculated and applied. Provides context for complex pricing rules, tiered structures, or special conditions.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateLineStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Line Status' ;
    rdfs:comment 'Current lifecycle status of the rate line. Indicates whether the rate is available for use in pricing calculations and quote generation.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateValue rdf:type rdf:Property ;
    rdfs:label 'Rate Value' ;
    rdfs:comment 'The charge amount for this rate line. Represents the base rate applied per unit of measure for the defined lane, service level, and weight/volume tier.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spotRateFlag rdf:type rdf:Property ;
    rdfs:label 'Spot Rate Flag' ;
    rdfs:comment 'Indicates whether this rate line represents a spot market rate (true) subject to immediate market conditions or a contract rate (false) with longer-term stability.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeBreakMaxCbm rdf:type rdf:Property ;
    rdfs:label 'Volume Break Max Cbm' ;
    rdfs:comment 'Maximum volume threshold in cubic meters (CBM) for this rate tier. Defines the upper bound of the volume band for dimensional pricing structures. Null indicates no upper limit.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeBreakMinCbm rdf:type rdf:Property ;
    rdfs:label 'Volume Break Min Cbm' ;
    rdfs:comment 'Minimum volume threshold in cubic meters (CBM) for this rate tier. Defines the lower bound of the volume band for dimensional pricing structures.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Pct' ;
    rdfs:comment 'Percentage discount applied for high-volume shipments meeting the weight or volume break thresholds. Incentivizes larger shipment consolidation.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightBreakMaxKg rdf:type rdf:Property ;
    rdfs:label 'Weight Break Max Kg' ;
    rdfs:comment 'Maximum weight threshold in kilograms for this rate tier. Defines the upper bound of the weight band for tiered pricing structures. Null indicates no upper limit.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightBreakMinKg rdf:type rdf:Property ;
    rdfs:label 'Weight Break Min Kg' ;
    rdfs:comment 'Minimum weight threshold in kilograms for this rate tier. Defines the lower bound of the weight band for tiered pricing structures.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseRateStructure rdf:type rdf:Property ;
    rdfs:label 'Base Rate Structure' ;
    rdfs:comment 'Methodology used to calculate base freight charges (e.g., flat rate per shipment, weight-based per kg, distance-based per km, zone-to-zone matrix, dimensional weight). Defines the pricing model foundation.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityRestrictions rdf:type rdf:Property ;
    rdfs:label 'Commodity Restrictions' ;
    rdfs:comment 'Description of any commodity-specific restrictions or exclusions under this tariff (e.g., \'No perishables\', \'Hazmat Class 1 excluded\', \'Electronics only\'). Nullable if no restrictions apply.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsClearanceIncluded rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Included' ;
    rdfs:comment 'Indicates whether customs brokerage and clearance services are included in the tariff rate or billed separately. Relevant for cross-border and international tariffs.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dimWeightDivisor rdf:type rdf:Property ;
    rdfs:label 'Dim Weight Divisor' ;
    rdfs:comment 'Divisor used to calculate dimensional weight from volumetric measurements (length x width x height / divisor). Common values: 5000 for air freight (cm), 166 for express (in). Nullable if tariff does not use DIM weight.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distanceUnit rdf:type rdf:Property ;
    rdfs:label 'Distance Unit' ;
    rdfs:comment 'Standard unit of measure for distance used in distance-based tariffs (e.g., kilometers, miles, nautical miles). Nullable if tariff is not distance-based.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingBody rdf:type rdf:Property ;
    rdfs:label 'Governing Body' ;
    rdfs:comment 'Regulatory authority or industry body that oversees or approves this tariff (e.g., \'FMC\', \'IATA\', \'IMO\', \'DOT\'). Determines compliance requirements and filing procedures.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingBodyReference rdf:type rdf:Property ;
    rdfs:label 'Governing Body Reference' ;
    rdfs:comment 'Official reference number or filing identifier assigned by the governing body (e.g., FMC tariff number, IATA resolution reference). Used for regulatory traceability.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceIncluded rdf:type rdf:Property ;
    rdfs:label 'Insurance Included' ;
    rdfs:comment 'Indicates whether cargo insurance coverage is included in the tariff rate or offered as an optional add-on. Relevant for high-value or international shipments.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'Date on which the tariff was officially published or filed with the governing body. Used for regulatory compliance and audit trail.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicationStatus rdf:type rdf:Property ;
    rdfs:label 'Publication Status' ;
    rdfs:comment 'Current lifecycle status of the tariff. Published tariffs are active and enforceable; filed tariffs are submitted to regulatory bodies; approved tariffs have received regulatory clearance. [ENUM-REF-CANDIDATE: draft|published|filed|approved|suspended|withdrawn|archived — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceProductType rdf:type rdf:Property ;
    rdfs:label 'Service Product Type' ;
    rdfs:comment 'Service level or product category this tariff applies to (e.g., express parcel, standard freight, economy ocean). Defines speed, handling, and service commitments. [ENUM-REF-CANDIDATE: express|standard|economy|freight|ltl|ftl|fcl|lcl — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffDescription rdf:type rdf:Property ;
    rdfs:label 'Tariff Description' ;
    rdfs:comment 'Detailed textual description of the tariff scope, coverage, special terms, and conditions. Provides context for tariff application and interpretation.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffName rdf:type rdf:Property ;
    rdfs:label 'Tariff Name' ;
    rdfs:comment 'Human-readable name or title of the tariff schedule (e.g., \'Asia-Pacific Express Air Tariff 2024\', \'North America LTL Standard Rates\').' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffNumber rdf:type rdf:Property ;
    rdfs:label 'Tariff Number' ;
    rdfs:comment 'Externally published tariff identification number used for regulatory filing and customer reference. Unique business identifier for the tariff schedule.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffType rdf:type rdf:Property ;
    rdfs:label 'Tariff Type' ;
    rdfs:comment 'Classification of the tariff based on trade direction and geographic scope. Determines applicable regulatory framework and pricing structure.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeUnit rdf:type rdf:Property ;
    rdfs:label 'Volume Unit' ;
    rdfs:comment 'Standard unit of measure for volume used in this tariff (e.g., cubic meters, cubic feet). Relevant for LCL, LTL, and dimensional weight calculations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightUnit rdf:type rdf:Property ;
    rdfs:label 'Weight Unit' ;
    rdfs:comment 'Standard unit of measure for weight used in this tariff (e.g., kilograms, pounds, metric tonnes). All weight-based rates are expressed in this unit.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelIndexId rdf:type rdf:Property ;
    rdfs:label 'Fuel Index Id' ;
    rdfs:comment 'Foreign key linking to pricing.fuel_index. Business justification: surcharge has fuel_index_linked_flag (BOOLEAN) and fuel_index_source (STRING), strongly indicating that fuel surcharges are linked to a specific fuel_index record. Normalizing this with a FK to fuel_i' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FuelIndex .

ind:applicableServiceType rdf:type rdf:Property ;
    rdfs:label 'Applicable Service Type' ;
    rdfs:comment 'Service type(s) to which this surcharge applies. Express includes time-definite delivery; standard includes regular service; economy includes deferred service; freight_forwarding includes forwarding services; contract_logistics includes warehousing and distribution; all indicates universal applicability.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableTransportMode rdf:type rdf:Property ;
    rdfs:label 'Applicable Transport Mode' ;
    rdfs:comment 'Transport mode(s) to which this surcharge applies. Air includes air freight; ocean includes FCL/LCL; road includes FTL/LTL; rail includes intermodal rail; multimodal includes combined transport; all indicates surcharge applies across all modes.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliesToDimWeightFlag rdf:type rdf:Property ;
    rdfs:label 'Applies To Dim Weight Flag' ;
    rdfs:comment 'Indicates whether this surcharge is calculated based on dimensional weight (true) or actual weight (false). Relevant for air freight and express parcel surcharges where volumetric weight may exceed actual weight.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToHazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Applies To Hazmat Flag' ;
    rdfs:comment 'Indicates whether this surcharge applies specifically to hazardous materials shipments (true) or to all shipments (false). Hazmat surcharges cover additional handling, documentation, and compliance costs.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToOversizeFlag rdf:type rdf:Property ;
    rdfs:label 'Applies To Oversize Flag' ;
    rdfs:comment 'Indicates whether this surcharge applies to oversize or out-of-gauge shipments (true) or to standard shipments (false). Oversize surcharges cover special handling and equipment requirements.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToTemperatureControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Applies To Temperature Controlled Flag' ;
    rdfs:comment 'Indicates whether this surcharge applies to temperature-controlled (reefer) shipments (true) or to all shipments (false). Temperature-controlled surcharges cover refrigeration equipment and monitoring costs.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calculationFormula rdf:type rdf:Property ;
    rdfs:label 'Calculation Formula' ;
    rdfs:comment 'Custom formula or algorithm used when calculation_method is formula_based. May reference fuel index, base freight, weight, volume, or other variables. Null for standard calculation methods.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'Method used to calculate the surcharge amount. Flat_rate applies a fixed amount; percentage applies a rate to base freight; per_unit applies a rate per weight/volume/TEU; tiered applies different rates based on thresholds; formula_based uses a custom calculation (e.g., fuel index-linked).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeAllocationParty rdf:type rdf:Property ;
    rdfs:label 'Charge Allocation Party' ;
    rdfs:comment 'Party responsible for paying the surcharge. Shipper indicates origin party pays; consignee indicates destination party pays; carrier indicates carrier absorbs; third_party indicates a third party (e.g., freight forwarder) pays; negotiable indicates allocation is determined per contract or shipment.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compoundingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Compounding Allowed Flag' ;
    rdfs:comment 'Indicates whether this surcharge can be compounded with other surcharges (true) or is mutually exclusive (false). Compounding affects total charge calculation when multiple surcharges apply to a single shipment.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerVisibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Visibility Flag' ;
    rdfs:comment 'Indicates whether this surcharge is displayed as a separate line item on customer invoices and quotes (true) or is bundled into total freight charges (false). Affects billing transparency and customer communication.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flatRateAmount rdf:type rdf:Property ;
    rdfs:label 'Flat Rate Amount' ;
    rdfs:comment 'Fixed surcharge amount when calculation_method is flat_rate. Expressed in the currency specified by currency_code. Null for non-flat-rate surcharges.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelIndexLinkedFlag rdf:type rdf:Property ;
    rdfs:label 'Fuel Index Linked Flag' ;
    rdfs:comment 'Indicates whether this surcharge is dynamically linked to a fuel price index (true) or is a static rate (false). Applicable primarily to BAF (Bunker Adjustment Factor) surcharges.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Notes' ;
    rdfs:comment 'Internal operational notes or comments about the surcharge definition, including implementation guidance, system mapping instructions, or historical context. Not visible to customers.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perUnitRate rdf:type rdf:Property ;
    rdfs:label 'Per Unit Rate' ;
    rdfs:comment 'Rate applied per unit of measure when calculation_method is per_unit. Unit of measure specified in unit_of_measure field. Null for non-per-unit surcharges.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentageRate rdf:type rdf:Property ;
    rdfs:label 'Percentage Rate' ;
    rdfs:comment 'Percentage rate applied to base freight when calculation_method is percentage. Expressed as a decimal (e.g., 15.00 for 15%). Null for non-percentage surcharges.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prioritySequence rdf:type rdf:Property ;
    rdfs:label 'Priority Sequence' ;
    rdfs:comment 'Numeric sequence indicating the order in which this surcharge is applied when multiple surcharges are compounded. Lower numbers are applied first. Used to ensure correct calculation order (e.g., base freight → GRI → BAF → THC).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryMandateFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Mandate Flag' ;
    rdfs:comment 'Indicates whether this surcharge is mandated by a regulatory body (true) or is a carrier-discretionary surcharge (false). Regulatory surcharges include security fees, customs processing fees, environmental levies.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surchargeCategory rdf:type rdf:Property ;
    rdfs:label 'Surcharge Category' ;
    rdfs:comment 'High-level classification of the surcharge type. Fuel includes BAF; rate_adjustment includes GRI; terminal includes THC; seasonal includes peak season; security includes security fees; risk includes war risk and insurance; regulatory includes customs and compliance fees; operational includes handling and storage; accessorial includes special services. [ENUM-REF-CANDIDATE: fuel|rate_adjustment|terminal|seasonal|security|risk|regulatory|operational|accessorial — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeCode rdf:type rdf:Property ;
    rdfs:label 'Surcharge Code' ;
    rdfs:comment 'Unique business identifier for the surcharge type (e.g., BAF, GRI, PSS, SEC, THC, WAR). Used across rate cards, spot quotes, and billing systems.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeDescription rdf:type rdf:Property ;
    rdfs:label 'Surcharge Description' ;
    rdfs:comment 'Detailed business description of the surcharge, including purpose, rationale, and any special conditions or exclusions. Used for customer communication and internal documentation.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeName rdf:type rdf:Property ;
    rdfs:label 'Surcharge Name' ;
    rdfs:comment 'Full descriptive name of the surcharge (e.g., Bunker Adjustment Factor, General Rate Increase, Peak Season Surcharge, Security Surcharge, Terminal Handling Charge, War Risk Surcharge).' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeStatus rdf:type rdf:Property ;
    rdfs:label 'Surcharge Status' ;
    rdfs:comment 'Current lifecycle status of the surcharge definition. Active indicates currently in use; inactive indicates not in use; pending indicates scheduled for future activation; expired indicates past effective_end_date; suspended indicates temporarily disabled.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeLaneScope rdf:type rdf:Property ;
    rdfs:label 'Trade Lane Scope' ;
    rdfs:comment 'Geographic scope of the surcharge applicability. Global applies worldwide; regional applies to specific regions (e.g., Asia-Pacific, Europe); country_specific applies to individual countries; lane_specific applies to origin-destination pairs.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingSurchargeScheduleId rdf:type rdf:Property ;
    rdfs:label 'Pricing Surcharge Schedule Id' ;
    rdfs:comment 'Unique identifier for the surcharge schedule record. Primary key.' ;
    rdfs:domain ind:PricingSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededBySchedulePricingSurchargeScheduleId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Schedule Pricing Surcharge Schedule Id' ;
    rdfs:comment 'Reference to the newer surcharge schedule that replaces this one. Nullable if this is the current active schedule.' ;
    rdfs:domain ind:PricingSurchargeSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PricingSurchargeSchedule .

ind:commodityGroupCode rdf:type rdf:Property ;
    rdfs:label 'Commodity Group Code' ;
    rdfs:comment 'Business classification code for commodity types this surcharge applies to (e.g., DG for dangerous goods, PERISHABLE, GENERAL).' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationRegionCode rdf:type rdf:Property ;
    rdfs:label 'Destination Region Code' ;
    rdfs:comment 'Business-defined region code for destination (e.g., APAC, EMEA, AMER). Used when surcharge applies to a broader geographic area.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermCode rdf:type rdf:Property ;
    rdfs:label 'Incoterm Code' ;
    rdfs:comment 'International Commercial Terms (Incoterms) code defining cost and risk allocation. Determines which party bears the surcharge (e.g., DDP, FOB, CIF, EXW). [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexBaseValue rdf:type rdf:Property ;
    rdfs:label 'Index Base Value' ;
    rdfs:comment 'Baseline index value used as reference point for indexed surcharge calculations. Changes in index relative to this base drive surcharge adjustments.' ;
    rdfs:domain ind:PricingSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indexCurrentValue rdf:type rdf:Property ;
    rdfs:label 'Index Current Value' ;
    rdfs:comment 'Current index value at time of schedule creation or last update. Used to calculate indexed surcharge amount.' ;
    rdfs:domain ind:PricingSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originRegionCode rdf:type rdf:Property ;
    rdfs:label 'Origin Region Code' ;
    rdfs:comment 'Business-defined region code for origin (e.g., APAC, EMEA, AMER). Used when surcharge applies to a broader geographic area.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishedFlag rdf:type rdf:Property ;
    rdfs:label 'Published Flag' ;
    rdfs:comment 'Indicates whether this surcharge schedule has been published to customers and external systems. True if published, False if internal-only.' ;
    rdfs:domain ind:PricingSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradeLaneCode rdf:type rdf:Property ;
    rdfs:label 'Trade Lane Code' ;
    rdfs:comment 'Business identifier for the trade lane or service corridor this surcharge applies to (e.g., ASIA_US_WEST, TRANSATLANTIC_NORTH).' ;
    rdfs:domain ind:PricingSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentFactor rdf:type rdf:Property ;
    rdfs:label 'Adjustment Factor' ;
    rdfs:comment 'Multiplier or adjustment factor applied to the index value for specific trade lanes, service types, or contractual agreements (e.g., 1.05 for 5% premium on express services).' ;
    rdfs:domain ind:FuelIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineIndexValue rdf:type rdf:Property ;
    rdfs:label 'Baseline Index Value' ;
    rdfs:comment 'Reference baseline value used to calculate percentage change or delta for surcharge formulas. Typically set at contract inception or annually.' ;
    rdfs:domain ind:FuelIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indexChangePercentage rdf:type rdf:Property ;
    rdfs:label 'Index Change Percentage' ;
    rdfs:comment 'Calculated percentage change from the baseline index value. Used directly in BAF and fuel surcharge formulas (e.g., +15.25% triggers tier-based surcharge).' ;
    rdfs:domain ind:FuelIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indexCode rdf:type rdf:Property ;
    rdfs:label 'Index Code' ;
    rdfs:comment 'Business identifier code for the fuel index (e.g., IATA_JET_FUEL, PLATTS_IFO380, MOPS_DIESEL). Used for external reference and integration with pricing systems.' ;
    rdfs:domain ind:FuelIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexCurrency rdf:type rdf:Property ;
    rdfs:label 'Index Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the index value is denominated (e.g., USD, EUR, SGD).' ;
    rdfs:domain ind:FuelIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexDate rdf:type rdf:Property ;
    rdfs:label 'Index Date' ;
    rdfs:comment 'The date for which this fuel index value is published. Represents the business event timestamp for the index observation.' ;
    rdfs:domain ind:FuelIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:indexName rdf:type rdf:Property ;
    rdfs:label 'Index Name' ;
    rdfs:comment 'Human-readable name of the fuel index (e.g., IATA Jet Fuel Index - Singapore, Platts Brent Crude).' ;
    rdfs:domain ind:FuelIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexPublicationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Index Publication Timestamp' ;
    rdfs:comment 'Timestamp when the index was officially published by the source organization. Distinct from index_date (the date the index represents) and created_timestamp (when the record was ingested).' ;
    rdfs:domain ind:FuelIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:indexSource rdf:type rdf:Property ;
    rdfs:label 'Index Source' ;
    rdfs:comment 'Source organization or exchange publishing the fuel index. IATA (International Air Transport Association), Platts (S&P Global Platts), MOPS (Mean of Platts Singapore), EIA (US Energy Information Administration), ICE (Intercontinental Exchange), NYMEX (New York Mercantile Exchange). [ENUM-REF-CANDIDATE: iata|platts|mops|eia|ice|nymex|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FuelIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexSourceUrl rdf:type rdf:Property ;
    rdfs:label 'Index Source Url' ;
    rdfs:comment 'URL or reference link to the official publication source of the fuel index. Supports audit trail and verification.' ;
    rdfs:domain ind:FuelIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexStatus rdf:type rdf:Property ;
    rdfs:label 'Index Status' ;
    rdfs:comment 'Current lifecycle status of the fuel index record. Active indices are used for surcharge calculations; superseded indices are replaced by newer values; archived indices are retained for audit; pending verification indices await approval.' ;
    rdfs:domain ind:FuelIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexValue rdf:type rdf:Property ;
    rdfs:label 'Index Value' ;
    rdfs:comment 'The published fuel price index value for the index date. Precision supports fractional currency units and per-unit pricing (e.g., USD per gallon, USD per metric ton).' ;
    rdfs:domain ind:FuelIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publicationFrequency rdf:type rdf:Property ;
    rdfs:label 'Publication Frequency' ;
    rdfs:comment 'Frequency at which the index source publishes updates (daily, weekly, monthly, quarterly). Drives automated surcharge recalculation cycles.' ;
    rdfs:domain ind:FuelIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeTier rdf:type rdf:Property ;
    rdfs:label 'Surcharge Tier' ;
    rdfs:comment 'Surcharge tier or bracket assigned based on index value or change percentage (e.g., Tier 1, Tier 2, Tier 3). Maps to predefined surcharge rate tables.' ;
    rdfs:domain ind:FuelIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Indicates whether the index value has been verified against the official source. Supports data quality and audit compliance.' ;
    rdfs:domain ind:FuelIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verified Timestamp' ;
    rdfs:comment 'Timestamp when the index value was verified. Null if verification_status is unverified.' ;
    rdfs:domain ind:FuelIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:accessorialChargeStatus rdf:type rdf:Property ;
    rdfs:label 'Accessorial Charge Status' ;
    rdfs:comment 'Current lifecycle status of the accessorial charge definition. Active charges are available for use in rating and billing; inactive or deprecated charges are retained for historical reference only.' ;
    rdfs:domain ind:AccessorialCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableIncoterms rdf:type rdf:Property ;
    rdfs:label 'Applicable Incoterms' ;
    rdfs:comment 'Comma-separated list of Incoterms under which this charge applies (e.g., DDP, DAP, FOB, CIF, EXW, FCA). Determines which party (shipper or consignee) is responsible for the charge. Empty if applicable to all Incoterms.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableModes rdf:type rdf:Property ;
    rdfs:label 'Applicable Modes' ;
    rdfs:comment 'Comma-separated list of transportation modes to which this charge applies (e.g., air, ocean, road, rail, multimodal). Empty if applicable to all modes.' ;
    rdfs:domain ind:AccessorialCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoApplyConditions rdf:type rdf:Property ;
    rdfs:label 'Auto Apply Conditions' ;
    rdfs:comment 'Business rules or conditions that trigger automatic application of this charge (e.g., delivery_address_type=residential, package_weight>70kg, requires_signature=true, contains_hazmat=true). Stored as structured text or rule expression.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoApplyFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Apply Flag' ;
    rdfs:comment 'Indicates whether this accessorial charge is automatically applied by the rating engine when conditions are met (True) or requires manual addition by operations staff (False).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chargeAmount rdf:type rdf:Property ;
    rdfs:label 'Charge Amount' ;
    rdfs:comment 'Standard charge amount in the base currency. For flat fees, this is the fixed amount. For rate-based charges, this is the rate per unit (e.g., per kg, per package). Null if calculation is percentage-based.' ;
    rdfs:domain ind:AccessorialCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargeBearer rdf:type rdf:Property ;
    rdfs:label 'Charge Bearer' ;
    rdfs:comment 'Party responsible for paying the accessorial charge: shipper (sender), consignee (receiver), third_party (bill-to party), or as_per_incoterm (determined by Incoterms agreement).' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeName rdf:type rdf:Property ;
    rdfs:label 'Charge Name' ;
    rdfs:comment 'Human-readable name of the accessorial charge (e.g., Residential Delivery Surcharge, Address Correction Fee, Signature Required Fee, Hazmat Handling Fee).' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargePercentage rdf:type rdf:Property ;
    rdfs:label 'Charge Percentage' ;
    rdfs:comment 'Percentage rate applied to base freight charge when calculation_basis is percentage_of_freight. Expressed as a decimal (e.g., 15.00 for 15%). Null for non-percentage charges.' ;
    rdfs:domain ind:AccessorialCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargeTier rdf:type rdf:Property ;
    rdfs:label 'Charge Tier' ;
    rdfs:comment 'Service tier or level associated with this accessorial charge, used for tiered pricing structures and service differentiation.' ;
    rdfs:domain ind:AccessorialCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCountryCodes rdf:type rdf:Property ;
    rdfs:label 'Destination Country Codes' ;
    rdfs:comment 'Comma-separated list of three-letter ISO 3166-1 alpha-3 country codes where this charge applies to shipments destined. Empty if applicable to all destinations.' ;
    rdfs:domain ind:AccessorialCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimWeightApplicable rdf:type rdf:Property ;
    rdfs:label 'Dim Weight Applicable' ;
    rdfs:comment 'Indicates whether this accessorial charge calculation considers dimensional weight in addition to actual weight. Relevant for oversize or low-density shipments.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Eligible Flag' ;
    rdfs:comment 'Indicates whether customers can dispute this accessorial charge through the claims or billing dispute process. True if disputable, False if non-disputable.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatClassApplicable rdf:type rdf:Property ;
    rdfs:label 'Hazmat Class Applicable' ;
    rdfs:comment 'Comma-separated list of hazmat classes (per IMDG, ICAO, or DOT classifications) to which this charge applies. Empty if not hazmat-specific. Used for dangerous goods handling fees.' ;
    rdfs:domain ind:AccessorialCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumCharge rdf:type rdf:Property ;
    rdfs:label 'Maximum Charge' ;
    rdfs:comment 'Maximum charge amount that will be applied regardless of calculated value. Caps the accessorial charge at a ceiling value.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originCountryCodes rdf:type rdf:Property ;
    rdfs:label 'Origin Country Codes' ;
    rdfs:comment 'Comma-separated list of three-letter ISO 3166-1 alpha-3 country codes where this charge applies to shipments originating. Empty if applicable to all origins.' ;
    rdfs:domain ind:AccessorialCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishedTariffFlag rdf:type rdf:Property ;
    rdfs:label 'Published Tariff Flag' ;
    rdfs:comment 'Indicates whether this accessorial charge is part of the published tariff available to all customers (True) or is a negotiated/contract-specific charge (False).' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryFilingReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Reference' ;
    rdfs:comment 'Reference number or identifier for regulatory tariff filings with governing bodies (e.g., FMC tariff number, IATA resolution reference). Required for published tariffs in regulated markets.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Category' ;
    rdfs:comment 'Accounting classification for revenue recognition purposes. Determines how the charge is recognized in financial statements.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalEndDate rdf:type rdf:Property ;
    rdfs:label 'Seasonal End Date' ;
    rdfs:comment 'End date of the seasonal period during which this charge applies. Null if not seasonal or if seasonal_flag is False.' ;
    rdfs:domain ind:AccessorialCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seasonalFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Flag' ;
    rdfs:comment 'Indicates whether this accessorial charge is seasonal or temporary (e.g., peak season surcharge, holiday delivery fee). True if seasonal, False if year-round.' ;
    rdfs:domain ind:AccessorialCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seasonalStartDate rdf:type rdf:Property ;
    rdfs:label 'Seasonal Start Date' ;
    rdfs:comment 'Start date of the seasonal period during which this charge applies. Null if not seasonal or if seasonal_flag is False.' ;
    rdfs:domain ind:AccessorialCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxableFlag rdf:type rdf:Property ;
    rdfs:label 'Taxable Flag' ;
    rdfs:comment 'Indicates whether the accessorial charge is subject to sales tax, VAT, or GST. True if taxable, False if exempt.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeThresholdApplicable rdf:type rdf:Property ;
    rdfs:label 'Volume Threshold Applicable' ;
    rdfs:comment 'Indicates whether volume-based discounts or thresholds apply to this accessorial charge. True if charge amount varies based on shipment volume or customer commitment levels.' ;
    rdfs:domain ind:AccessorialCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waivableFlag rdf:type rdf:Property ;
    rdfs:label 'Waivable Flag' ;
    rdfs:comment 'Indicates whether this accessorial charge can be waived or discounted at the discretion of sales or operations staff. True if waivable, False if mandatory.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Waiver Approval Required' ;
    rdfs:comment 'Indicates whether waiving this charge requires managerial or executive approval. True if approval is required, False if staff can waive without escalation.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:zoneApplicable rdf:type rdf:Property ;
    rdfs:label 'Zone Applicable' ;
    rdfs:comment 'Comma-separated list of delivery zones or postal code zones to which this accessorial charge applies (e.g., remote_area, extended_delivery, urban, rural). Empty if not zone-specific.' ;
    rdfs:domain ind:AccessorialCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByRuleDimWeightRuleId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rule Dim Weight Rule Id' ;
    rdfs:comment 'Reference to the dimensional weight rule that replaces this rule when it expires or is superseded, enabling rule version tracking.' ;
    rdfs:domain ind:DimWeightRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DimWeightRule .

ind:appliesToReturns rdf:type rdf:Property ;
    rdfs:label 'Applies To Returns' ;
    rdfs:comment 'Boolean flag indicating whether this dimensional weight rule applies to return shipments (RMA) or only to forward shipments.' ;
    rdfs:domain ind:DimWeightRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dimFactor rdf:type rdf:Property ;
    rdfs:label 'Dim Factor' ;
    rdfs:comment 'Volumetric divisor used to calculate dimensional weight from package dimensions. Common values: 5000 for air freight (cm³/kg), 6000 for express (cm³/kg), 4000 for premium express. Formula: DIM Weight = (Length × Width × Height) / DIM Factor.' ;
    rdfs:domain ind:DimWeightRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDefaultRule rdf:type rdf:Property ;
    rdfs:label 'Is Default Rule' ;
    rdfs:comment 'Boolean flag indicating whether this is the default dimensional weight rule applied when no more specific rule matches the shipment criteria.' ;
    rdfs:domain ind:DimWeightRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lengthUnit rdf:type rdf:Property ;
    rdfs:label 'Length Unit' ;
    rdfs:comment 'Unit of measure for package length dimension used in the dimensional weight calculation (centimeters, inches, or meters).' ;
    rdfs:domain ind:DimWeightRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumChargeableWeight rdf:type rdf:Property ;
    rdfs:label 'Maximum Chargeable Weight' ;
    rdfs:comment 'Maximum weight threshold above which the dimensional weight rule does not apply or special handling is required, expressed in the weight unit of measure.' ;
    rdfs:domain ind:DimWeightRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumChargeableWeight rdf:type rdf:Property ;
    rdfs:label 'Minimum Chargeable Weight' ;
    rdfs:comment 'Minimum weight threshold below which the dimensional weight rule does not apply or a floor chargeable weight is enforced, expressed in the weight unit of measure.' ;
    rdfs:domain ind:DimWeightRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingType rdf:type rdf:Property ;
    rdfs:label 'Packaging Type' ;
    rdfs:comment 'Type of packaging to which this rule applies (e.g., parcel, pallet, container, crate, envelope), as packaging affects dimensional weight applicability.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roundingMethod rdf:type rdf:Property ;
    rdfs:label 'Rounding Method' ;
    rdfs:comment 'Method used to round the calculated dimensional weight to determine chargeable weight (round up to next whole unit, round down, round to nearest, or round half up).' ;
    rdfs:domain ind:DimWeightRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roundingPrecision rdf:type rdf:Property ;
    rdfs:label 'Rounding Precision' ;
    rdfs:comment 'Precision to which the dimensional weight is rounded (e.g., 0.5 for half-kilogram increments, 1.0 for whole kilogram increments).' ;
    rdfs:domain ind:DimWeightRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Business identifier code for the dimensional weight rule, used for external reference and system integration.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleDescription rdf:type rdf:Property ;
    rdfs:label 'Rule Description' ;
    rdfs:comment 'Detailed explanation of the dimensional weight calculation rule, including business context and application scenarios.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Descriptive name of the dimensional weight rule for business user identification and reporting purposes.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current lifecycle status of the dimensional weight rule indicating whether it is actively applied in pricing calculations.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitSystem rdf:type rdf:Property ;
    rdfs:label 'Unit System' ;
    rdfs:comment 'Measurement system used for dimensional weight calculation: metric (centimeters and kilograms) or imperial (inches and pounds).' ;
    rdfs:domain ind:DimWeightRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqId rdf:type rdf:Property ;
    rdfs:label 'Rfq Id' ;
    rdfs:comment 'Foreign key linking to procurement.rfq. Business justification: Spot quotes for non-contracted lanes often originate from RFQ processes. Business need: procurement analytics track quote-to-RFQ conversion rates and sourcing event effectiveness for capacity planning' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rfq .

ind:supplierQuoteId rdf:type rdf:Property ;
    rdfs:label 'Supplier Quote Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier_quote. Business justification: Links customer-facing spot quotes to supplier quotes received during procurement. Business need: margin analysis compares sell-side pricing to buy-side costs; quote comparison reports for pricing stra' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierQuote .

ind:baseFreightRate rdf:type rdf:Property ;
    rdfs:label 'Base Freight Rate' ;
    rdfs:comment 'Core transportation charge per unit (per kg, per TEU, per shipment) before surcharges and accessorial fees. Foundation of the all-in quoted rate.' ;
    rdfs:domain ind:SpotQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsClearanceFee rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Fee' ;
    rdfs:comment 'Fee for customs brokerage services including declaration preparation, duty calculation, and regulatory filings (AMS, ISF). Applicable for cross-border shipments.' ;
    rdfs:domain ind:SpotQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentationFee rdf:type rdf:Property ;
    rdfs:label 'Documentation Fee' ;
    rdfs:comment 'Administrative charge for preparation and processing of shipping documents including AWB (Air Waybill), BOL (Bill of Lading), commercial invoice, packing list, and certificate of origin.' ;
    rdfs:domain ind:SpotQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedTransitDays rdf:type rdf:Property ;
    rdfs:label 'Estimated Transit Days' ;
    rdfs:comment 'Expected number of calendar days from origin pickup to destination delivery. Used for customer planning and SLA (Service Level Agreement) commitments.' ;
    rdfs:domain ind:SpotQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:insurancePremium rdf:type rdf:Property ;
    rdfs:label 'Insurance Premium' ;
    rdfs:comment 'Optional cargo insurance premium to cover loss or damage during transit. Typically calculated as a percentage of declared cargo value.' ;
    rdfs:domain ind:SpotQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickupDate rdf:type rdf:Property ;
    rdfs:label 'Pickup Date' ;
    rdfs:comment 'Requested or scheduled date for cargo pickup at origin. Used for capacity planning and operational scheduling.' ;
    rdfs:domain ind:SpotQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quoteIssuedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Quote Issued Timestamp' ;
    rdfs:comment 'Date and time when the spot quote was formally issued to the customer. Marks the start of the validity period and SLA (Service Level Agreement) measurement for quote response time.' ;
    rdfs:domain ind:SpotQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quoteNumber rdf:type rdf:Property ;
    rdfs:label 'Quote Number' ;
    rdfs:comment 'Externally-visible unique business identifier for the spot quote, typically formatted as SQ followed by numeric sequence. Used for customer communication and reference.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteRequestDate rdf:type rdf:Property ;
    rdfs:label 'Quote Request Date' ;
    rdfs:comment 'Date when the customer or prospect submitted the request for quotation. Used to track response time and quote aging.' ;
    rdfs:domain ind:SpotQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quoteSource rdf:type rdf:Property ;
    rdfs:label 'Quote Source' ;
    rdfs:comment 'Channel or system through which the quote request was received. Used for channel effectiveness analysis and digital transformation tracking.' ;
    rdfs:domain ind:SpotQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteStatus rdf:type rdf:Property ;
    rdfs:label 'Quote Status' ;
    rdfs:comment 'Current lifecycle status of the spot quote. Tracks progression from draft through issuance to final disposition (accepted, expired, rejected, or cancelled).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteValidFromDate rdf:type rdf:Property ;
    rdfs:label 'Quote Valid From Date' ;
    rdfs:comment 'Start date of the quote validity period. The quoted rates are guaranteed from this date.' ;
    rdfs:domain ind:SpotQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quoteValidUntilDate rdf:type rdf:Property ;
    rdfs:label 'Quote Valid Until Date' ;
    rdfs:comment 'Expiration date of the quote validity period. After this date, the quoted rates are no longer guaranteed and the quote status typically transitions to expired.' ;
    rdfs:domain ind:SpotQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesOfficeCode rdf:type rdf:Property ;
    rdfs:label 'Sales Office Code' ;
    rdfs:comment 'Code identifying the sales office or branch that issued the quote. Used for regional performance reporting and revenue allocation.' ;
    rdfs:domain ind:SpotQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securitySurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Security Surcharge Amount' ;
    rdfs:comment 'Charge to cover security screening, compliance programs (C-TPAT, AEO), and regulatory security requirements. Common in air and ocean freight.' ;
    rdfs:domain ind:SpotQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminalHandlingCharge rdf:type rdf:Property ;
    rdfs:label 'Terminal Handling Charge' ;
    rdfs:comment 'Fee for cargo handling at the origin or destination terminal, including loading, unloading, and container yard operations. Common in ocean freight.' ;
    rdfs:domain ind:SpotQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalQuotedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Quoted Amount' ;
    rdfs:comment 'All-in total price quoted to the customer, including base freight, all surcharges, accessorial fees, and applicable taxes. This is the final amount the customer will pay if the quote is accepted.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spotQuoteLineId rdf:type rdf:Property ;
    rdfs:label 'Spot Quote Line Id' ;
    rdfs:comment 'Unique identifier for the spot quote line item. Primary key.' ;
    rdfs:domain ind:SpotQuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commodityCode rdf:type rdf:Property ;
    rdfs:label 'Commodity Code' ;
    rdfs:comment 'Harmonized System (HS) code or other commodity classification code relevant to this charge. Used for customs duties, tariff classification, and regulatory compliance. Applicable when the charge is commodity-specific.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationParty rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Party' ;
    rdfs:comment 'Party responsible for paying this charge as per the Incoterm and contract terms. Identifies whether the shipper, consignee, carrier, a third party, or shared responsibility applies to this charge line.' ;
    rdfs:domain ind:SpotQuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimWeightFactor rdf:type rdf:Property ;
    rdfs:label 'Dim Weight Factor' ;
    rdfs:comment 'Dimensional weight factor applied to calculate chargeable weight for this line. Commonly 5000 or 6000 for air freight (dividing volume in cubic centimeters by this factor to get kg). Used when dimensional weight exceeds actual weight.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:includedInAllInRateFlag rdf:type rdf:Property ;
    rdfs:label 'Included In All In Rate Flag' ;
    rdfs:comment 'Boolean flag indicating whether this charge is included in the all-in quoted rate (True) or quoted separately as an additional charge (False). Enables transparency in pricing structure and supports itemized billing reconciliation.' ;
    rdfs:domain ind:SpotQuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Net amount for this charge line after applying discounts and taxes. Calculated as line_amount minus discount_amount plus tax_amount. Represents the final billable amount for this line.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Rate Effective Date' ;
    rdfs:comment 'Date from which the rate for this charge line is effective. Supports rate versioning and ensures correct pricing based on quote date.' ;
    rdfs:domain ind:SpotQuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Rate Expiry Date' ;
    rdfs:comment 'Date until which the rate for this charge line is valid. After this date, the rate may change or require re-negotiation. Null if the rate has no expiry.' ;
    rdfs:domain ind:SpotQuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateSource rdf:type rdf:Property ;
    rdfs:label 'Rate Source' ;
    rdfs:comment 'Source of the rate applied to this charge line. Indicates whether the rate comes from a contract, tariff, spot market, negotiated agreement, published rate card, or market rate. Supports audit and pricing transparency.' ;
    rdfs:domain ind:SpotQuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseRate rdf:type rdf:Property ;
    rdfs:label 'Base Rate' ;
    rdfs:comment 'Negotiated base rate amount per unit as defined by rate_basis, excluding surcharges and accessorial charges.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviationFlag rdf:type rdf:Property ;
    rdfs:label 'Deviation Flag' ;
    rdfs:comment 'Indicates whether this rate represents a deviation from standard pricing policy (e.g., below-floor approval, emergency rate, special commodity exception).' ;
    rdfs:domain ind:ContractRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviationReason rdf:type rdf:Property ;
    rdfs:label 'Deviation Reason' ;
    rdfs:comment 'Business justification for rate deviation, including reason code and narrative explanation (e.g., competitive match, strategic account, volume commitment, market conditions).' ;
    rdfs:domain ind:ContractRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorRate rdf:type rdf:Property ;
    rdfs:label 'Floor Rate' ;
    rdfs:comment 'Minimum allowable rate threshold below which special approval is required. Used for deviation tracking and margin protection.' ;
    rdfs:domain ind:ContractRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateCode rdf:type rdf:Property ;
    rdfs:label 'Rate Code' ;
    rdfs:comment 'Business identifier for the contract rate, used for billing and operational reference.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateName rdf:type rdf:Property ;
    rdfs:label 'Rate Name' ;
    rdfs:comment 'Descriptive name of the contract rate for business user identification.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Status' ;
    rdfs:comment 'Current lifecycle status of the contract rate (draft, pending approval, active, suspended, expired, terminated).' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCommitmentMin rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Min' ;
    rdfs:comment 'Minimum volume commitment (in units defined by rate_basis) that the customer must meet to qualify for this contract rate.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightBreakMax rdf:type rdf:Property ;
    rdfs:label 'Weight Break Max' ;
    rdfs:comment 'Maximum weight threshold (in kilograms or pounds) for which this rate applies, used in tiered pricing structures.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightBreakMin rdf:type rdf:Property ;
    rdfs:label 'Weight Break Min' ;
    rdfs:comment 'Minimum weight threshold (in kilograms or pounds) for which this rate applies, used in tiered pricing structures.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateRuleId rdf:type rdf:Property ;
    rdfs:label 'Rate Rule Id' ;
    rdfs:comment 'Primary key for rate_rule' ;
    rdfs:domain ind:RateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentCurrency rdf:type rdf:Property ;
    rdfs:label 'Adjustment Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for flat amount adjustments. Null for percentage and multiplier adjustment types.' ;
    rdfs:domain ind:RateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Method by which the rule modifies the base rate: flat amount (fixed currency value), percentage (of base rate), tiered (stepped based on volume/weight), or multiplier (factor applied to base).' ;
    rdfs:domain ind:RateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentValue rdf:type rdf:Property ;
    rdfs:label 'Adjustment Value' ;
    rdfs:comment 'Numeric value defining the magnitude of the rate adjustment. Interpretation depends on adjustment_type: currency amount for flat, percentage for percentage, multiplier for multiplier.' ;
    rdfs:domain ind:RateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicableIncoterm rdf:type rdf:Property ;
    rdfs:label 'Applicable Incoterm' ;
    rdfs:comment 'Incoterms to which this rule applies, controlling charge allocation between shipper and consignee. Pipe-separated if multiple. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — promote to reference product]' ;
    rdfs:domain ind:RateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableServiceMode rdf:type rdf:Property ;
    rdfs:label 'Applicable Service Mode' ;
    rdfs:comment 'Transportation mode(s) to which this rule applies. Pipe-separated list if multiple. [ENUM-REF-CANDIDATE: air|ocean|road|rail|intermodal|express_parcel|LTL|FTL|FCL|LCL — promote to reference product]' ;
    rdfs:domain ind:RateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableTradeLane rdf:type rdf:Property ;
    rdfs:label 'Applicable Trade Lane' ;
    rdfs:comment 'Geographic trade lane or route corridor to which this rule applies (e.g., \'Asia-Europe\', \'Transpacific Eastbound\', \'US Domestic\'). Null if rule is global.' ;
    rdfs:domain ind:RateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessJustification rdf:type rdf:Property ;
    rdfs:label 'Business Justification' ;
    rdfs:comment 'Rationale for creating this pricing rule, including market conditions, competitive positioning, cost recovery objectives, or strategic customer retention goals.' ;
    rdfs:domain ind:RateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityHsCode rdf:type rdf:Property ;
    rdfs:label 'Commodity Hs Code' ;
    rdfs:comment 'Harmonized System tariff classification code for commodities to which this rule applies. Used for commodity-specific surcharges (e.g., hazardous materials, refrigerated cargo). Null if rule is commodity-agnostic.' ;
    rdfs:domain ind:RateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compoundRuleFlag rdf:type rdf:Property ;
    rdfs:label 'Compound Rule Flag' ;
    rdfs:comment 'Indicates whether this rule can be combined with other rules (true) or is mutually exclusive (false). Controls rule stacking behavior in the rating engine.' ;
    rdfs:domain ind:RateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalRuleCode rdf:type rdf:Property ;
    rdfs:label 'External Rule Code' ;
    rdfs:comment 'Unique identifier for this pricing rule in the source operational system. Used for data lineage and reconciliation with SAP TM or Oracle TMS.' ;
    rdfs:domain ind:RateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Maximum Threshold Value' ;
    rdfs:comment 'Upper bound value beyond which the rule no longer applies or transitions to next tier. Used for tiered pricing structures.' ;
    rdfs:domain ind:RateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Threshold Value' ;
    rdfs:comment 'Lower bound value that must be met for the rule to apply. Used for volume discounts (minimum TEU, CBM, weight) or minimum charge thresholds.' ;
    rdfs:domain ind:RateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorityOrder rdf:type rdf:Property ;
    rdfs:label 'Priority Order' ;
    rdfs:comment 'Execution sequence number determining the order in which multiple applicable rules are evaluated and applied. Lower numbers execute first. Critical for cascading discount and surcharge logic.' ;
    rdfs:domain ind:RateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prorationMethod rdf:type rdf:Property ;
    rdfs:label 'Proration Method' ;
    rdfs:comment 'Method for prorating charges when rule is applied mid-period or to partial volumes. Used for contract pricing and subscription-based logistics services.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleType rdf:type rdf:Property ;
    rdfs:label 'Rule Type' ;
    rdfs:comment 'Classification of the pricing rule defining the category of rate adjustment logic applied. Determines which calculation engine module processes the rule in SAP TM.' ;
    rdfs:domain ind:RateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Threshold Unit' ;
    rdfs:comment 'Unit of measure for minimum and maximum threshold values. Aligns with standard logistics units: TEU (Twenty-foot Equivalent Unit), CBM (Cubic Meter), weight units, or shipment count.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerCondition rdf:type rdf:Property ;
    rdfs:label 'Trigger Condition' ;
    rdfs:comment 'Business logic expression defining when the rule is applicable. May reference shipment attributes (weight, volume, TEU, origin, destination, service level, customer tier, commodity HS code). Evaluated by SAP TM rules engine.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneRateZoneId rdf:type rdf:Property ;
    rdfs:label 'Lane Rate Zone Id' ;
    rdfs:comment 'Unique identifier for the lane rate zone definition. Primary key.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LaneRateZone .

ind:distanceFromHubKm rdf:type rdf:Property ;
    rdfs:label 'Distance From Hub Km' ;
    rdfs:comment 'Average distance in kilometers from the primary distribution hub or gateway to locations within this zone. Used for distance-based pricing calculations.' ;
    rdfs:domain ind:LaneRateZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelSurchargeRegion rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Region' ;
    rdfs:comment 'Code identifying the fuel surcharge region this zone belongs to. Links to fuel index tables for Bunker Adjustment Factor (BAF) and fuel surcharge calculations.' ;
    rdfs:domain ind:LaneRateZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatRestrictedFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Restricted Flag' ;
    rdfs:comment 'Indicates whether this zone has restrictions on hazardous materials shipments, affecting service availability and surcharge applicability.' ;
    rdfs:domain ind:LaneRateZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incotermDefault rdf:type rdf:Property ;
    rdfs:label 'Incoterm Default' ;
    rdfs:comment 'Default International Commercial Term (Incoterm) applied to shipments in this zone, affecting charge allocation between shipper and consignee (e.g., DDP, DAP, FOB, CIF, EXW).' ;
    rdfs:domain ind:LaneRateZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCodePattern rdf:type rdf:Property ;
    rdfs:label 'Postal Code Pattern' ;
    rdfs:comment 'Regular expression or wildcard pattern defining the postal codes included in this zone (e.g., \'10***\' for all codes starting with 10). Enables efficient postal code to zone resolution.' ;
    rdfs:domain ind:LaneRateZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCodeRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Postal Code Range End' ;
    rdfs:comment 'Ending postal code in a contiguous range included in this zone. Used with postal_code_range_start for range-based zone matching.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCodeRangeStart rdf:type rdf:Property ;
    rdfs:label 'Postal Code Range Start' ;
    rdfs:comment 'Starting postal code in a contiguous range included in this zone. Used with postal_code_range_end for range-based zone matching.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteAreaFlag rdf:type rdf:Property ;
    rdfs:label 'Remote Area Flag' ;
    rdfs:comment 'Indicates whether this zone is classified as a remote or extended delivery area, which typically incurs additional surcharges.' ;
    rdfs:domain ind:LaneRateZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:zoneHierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Zone Hierarchy Level' ;
    rdfs:comment 'Numeric level in the zone hierarchy structure. Level 1 is the broadest (e.g., continent), higher numbers represent finer granularity (e.g., postal code).' ;
    rdfs:domain ind:LaneRateZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chargeCodeId rdf:type rdf:Property ;
    rdfs:label 'Charge Code Id' ;
    rdfs:comment 'Primary key for charge_code' ;
    rdfs:domain ind:ChargeCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByChargeCodeId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Charge Code Id' ;
    rdfs:comment 'Reference to the newer charge code that replaces this one when this charge is deprecated or superseded. Supports charge code version lineage tracking.' ;
    rdfs:domain ind:ChargeCode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChargeCode .

ind:applicableTransportModes rdf:type rdf:Property ;
    rdfs:label 'Applicable Transport Modes' ;
    rdfs:comment 'Comma-separated list of transport modes to which this charge applies (e.g., air, ocean, road, rail, multimodal).' ;
    rdfs:domain ind:ChargeCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeCode rdf:type rdf:Property ;
    rdfs:label 'Charge Code' ;
    rdfs:comment 'Standardized alphanumeric code uniquely identifying the charge type (e.g., FRT for freight, FSC for fuel surcharge, THC for terminal handling charge). Used across billing, rating, and EDI transactions.' ;
    rdfs:domain ind:ChargeCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeSubcategory rdf:type rdf:Property ;
    rdfs:label 'Charge Subcategory' ;
    rdfs:comment 'Granular classification within the charge category (e.g., under surcharge: fuel, currency, security, peak season; under accessorial: liftgate, inside delivery, residential).' ;
    rdfs:domain ind:ChargeCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAccountCode rdf:type rdf:Property ;
    rdfs:label 'Cost Account Code' ;
    rdfs:comment 'General Ledger (GL) cost account code for expense allocation when this charge represents a pass-through or cost recovery item.' ;
    rdfs:domain ind:ChargeCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsHsCodeApplicable rdf:type rdf:Property ;
    rdfs:label 'Customs Hs Code Applicable' ;
    rdfs:comment 'Indicates whether this charge requires Harmonized System (HS) code classification for customs declaration and duty calculation purposes.' ;
    rdfs:domain ind:ChargeCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:edifactChargeCode rdf:type rdf:Property ;
    rdfs:label 'Edifact Charge Code' ;
    rdfs:comment 'UN/EDIFACT standard charge code used in electronic data interchange (EDI) messages for freight and logistics (e.g., IFTMIN, IFTMBC, INVOIC).' ;
    rdfs:domain ind:ChargeCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataChargeCode rdf:type rdf:Property ;
    rdfs:label 'Iata Charge Code' ;
    rdfs:comment 'Two-letter IATA standard charge code used in air waybill (AWB) and cargo-IMP messaging (e.g., MY for miscellaneous charge due carrier, PP for prepaid, CC for collect).' ;
    rdfs:domain ind:ChargeCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueAccountCode rdf:type rdf:Property ;
    rdfs:label 'Revenue Account Code' ;
    rdfs:comment 'General Ledger (GL) revenue account code to which this charge type posts. Used for financial reporting and revenue recognition per IFRS 15.' ;
    rdfs:domain ind:ChargeCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Tax Category Code' ;
    rdfs:comment 'Tax classification code for this charge type (e.g., standard rate, reduced rate, exempt, zero-rated). Used for automated tax calculation.' ;
    rdfs:domain ind:ChargeCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByRateCarrierBuyRateId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rate Carrier Buy Rate Id' ;
    rdfs:comment 'Reference to the newer buy rate that replaces this one. Used to maintain rate lineage and history.' ;
    rdfs:domain ind:CarrierBuyRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarrierBuyRate .

ind:buyRateAmount rdf:type rdf:Property ;
    rdfs:label 'Buy Rate Amount' ;
    rdfs:comment 'The cost amount Transport Shipping pays to the carrier per unit. This is the base buy-side rate before surcharges.' ;
    rdfs:domain ind:CarrierBuyRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marginFloorPercentage rdf:type rdf:Property ;
    rdfs:label 'Margin Floor Percentage' ;
    rdfs:comment 'Minimum margin percentage that must be maintained when pricing sell-side rates based on this buy rate. Used for margin management and pricing guardrails.' ;
    rdfs:domain ind:CarrierBuyRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeCommitmentMax rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Max' ;
    rdfs:comment 'Maximum volume commitment (in rate basis units) covered by this buy rate. Exceeding this may trigger renegotiation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aeoCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Aeo Certification Number' ;
    rdfs:comment 'The unique AEO certification identifier issued by the customs authority.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiry Date' ;
    rdfs:comment 'The date on which the current master service agreement or contract with the supplier expires. Used for contract renewal planning and supplier relationship management.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ctpatCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Ctpat Certification Number' ;
    rdfs:comment 'The unique C-TPAT certification identifier issued by US Customs and Border Protection.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dbaName rdf:type rdf:Property ;
    rdfs:label 'Dba Name' ;
    rdfs:comment 'Trade name or doing-business-as name if different from legal name.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverage rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes representing the geographic regions where the supplier can provide services or deliver goods. Used for carrier and logistics service provider selection.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso14001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Certified' ;
    rdfs:comment 'Indicates whether the supplier holds ISO 14001 certification for environmental management systems, relevant for sustainability and emissions reduction initiatives.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso9001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Certified' ;
    rdfs:comment 'Indicates whether the supplier holds ISO 9001 certification for quality management systems.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minorityOwned rdf:type rdf:Property ;
    rdfs:label 'Minority Owned' ;
    rdfs:comment 'Indicates whether the supplier is certified as a minority-owned business enterprise (MBE). Used for diversity and inclusion reporting and supplier diversity programs.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredSupplier rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier' ;
    rdfs:comment 'Indicates whether the supplier has been designated as a preferred or strategic supplier based on performance, pricing, reliability, or strategic partnership agreements. Preferred suppliers receive priority consideration in sourcing decisions.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskTier rdf:type rdf:Property ;
    rdfs:label 'Risk Tier' ;
    rdfs:comment 'Risk classification based on financial stability, compliance history, geographic location, criticality to operations, and exposure to sanctions or trade restrictions. Critical tier requires enhanced due diligence and monitoring.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCapabilities rdf:type rdf:Property ;
    rdfs:label 'Service Capabilities' ;
    rdfs:comment 'Comma-separated list of service capabilities the supplier can provide, such as air_freight, ocean_freight, road_transport, rail_transport, warehousing, customs_brokerage, last_mile_delivery, cold_chain, hazmat_handling, cross_border_shipping. Used for carrier and 3PL selection.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smallBusiness rdf:type rdf:Property ;
    rdfs:label 'Small Business' ;
    rdfs:comment 'Indicates whether the supplier is certified as a small business according to the applicable jurisdiction\'s definition (e.g., US SBA size standards). Used for small business procurement programs and reporting.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierCategory rdf:type rdf:Property ;
    rdfs:label 'Supplier Category' ;
    rdfs:comment 'Spend category classification. Direct suppliers provide goods/services directly tied to core logistics operations (carriers, fuel, packaging). Indirect suppliers provide operational support (IT, facilities, office supplies). Capital suppliers provide long-term assets (vehicles, equipment, infrastructure).' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierName rdf:type rdf:Property ;
    rdfs:label 'Supplier Name' ;
    rdfs:comment 'The full legal name of the supplier organization as registered with governing authorities.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Number' ;
    rdfs:comment 'Externally-known unique business identifier for the supplier, typically assigned during onboarding. Used in purchase orders, invoices, and contracts.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierStatus rdf:type rdf:Property ;
    rdfs:label 'Supplier Status' ;
    rdfs:comment 'Current lifecycle status of the supplier relationship. Active: approved and transacting. Inactive: approved but not currently transacting. Suspended: temporarily blocked due to performance or compliance issues. Pending approval: onboarding in progress. Blocked: prohibited from new transactions. Terminated: relationship ended.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierType rdf:type rdf:Property ;
    rdfs:label 'Supplier Type' ;
    rdfs:comment 'Primary classification of the supplier based on the goods or services provided. Carrier includes air, ocean, road, rail freight carriers; fuel supplier provides bunker fuel, diesel, jet fuel; IT vendor provides software, hardware, telecom; facility lessor provides warehouse, office, terminal leases; equipment provider supplies vehicles, containers, handling equipment; professional services includes consulting, legal, audit.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'The supplier\'s tax identification number issued by the tax authority in their country of registration. In the US this is the EIN (Employer Identification Number) or SSN for sole proprietors; in the EU this is the VAT number.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:womanOwned rdf:type rdf:Property ;
    rdfs:label 'Woman Owned' ;
    rdfs:comment 'Indicates whether the supplier is certified as a woman-owned business enterprise (WBE). Used for diversity and inclusion reporting and supplier diversity programs.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierSiteId rdf:type rdf:Property ;
    rdfs:label 'Supplier Site Id' ;
    rdfs:comment 'Unique identifier for the supplier site. Primary key.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierSite .

ind:bankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number' ;
    rdfs:comment 'Bank account number associated with this supplier site for payment remittance. Used for Accounts Payable (AP) processing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankBranchCode rdf:type rdf:Property ;
    rdfs:label 'Bank Branch Code' ;
    rdfs:comment 'Branch code or routing number for the supplier site\'s bank account, used for electronic funds transfer.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'Name of the financial institution holding the supplier site\'s bank account.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPersonName rdf:type rdf:Property ;
    rdfs:label 'Contact Person Name' ;
    rdfs:comment 'Full name of the primary contact person at the supplier site for procurement and operational matters.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPersonTitle rdf:type rdf:Property ;
    rdfs:label 'Contact Person Title' ;
    rdfs:comment 'Job title or role of the primary contact person at the supplier site (e.g., Site Manager, Procurement Coordinator, Operations Director).' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary email address for the supplier site, used for purchase order transmission, invoice submission, and operational correspondence.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'Fax number for the supplier site, if applicable for document transmission.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iban rdf:type rdf:Property ;
    rdfs:label 'Iban' ;
    rdfs:comment 'International Bank Account Number for the supplier site, used for cross-border payments in SEPA and other international payment systems.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimarySite rdf:type rdf:Property ;
    rdfs:label 'Is Primary Site' ;
    rdfs:comment 'Flag indicating whether this is the primary or default site for the supplier. True if this is the main operational site; false for secondary or regional sites.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRemitToSite rdf:type rdf:Property ;
    rdfs:label 'Is Remit To Site' ;
    rdfs:comment 'Flag indicating whether this site is designated as a remit-to address for payment processing. True if payments should be sent to this site\'s bank account.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumOrderValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Value' ;
    rdfs:comment 'Minimum order value required for purchases from this supplier site, in the site\'s payment currency. Orders below this threshold may incur additional fees or be rejected.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingHours rdf:type rdf:Property ;
    rdfs:label 'Operating Hours' ;
    rdfs:comment 'Standard operating hours for the supplier site (e.g., \'08:00-17:00 Mon-Fri\', \'24/7\'). Used for scheduling deliveries, pickups, and service appointments.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Payment Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for payments to this supplier site (e.g., USD, EUR, GBP, CNY). Site-level currency may differ from supplier-level default.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary contact phone number for the supplier site, used for operational communication and order coordination.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCode rdf:type rdf:Property ;
    rdfs:label 'Site Code' ;
    rdfs:comment 'Externally-known unique code or identifier for the site, used in procurement documents and purchase orders.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteName rdf:type rdf:Property ;
    rdfs:label 'Site Name' ;
    rdfs:comment 'Human-readable name or label for the supplier site (e.g., \'Regional Hub - Chicago\', \'Fuel Depot - Rotterdam\', \'Equipment Warehouse - Singapore\').' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteStatus rdf:type rdf:Property ;
    rdfs:label 'Site Status' ;
    rdfs:comment 'Current lifecycle status of the supplier site. Active sites are available for procurement transactions; inactive or suspended sites are temporarily unavailable; closed sites are permanently retired.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteType rdf:type rdf:Property ;
    rdfs:label 'Site Type' ;
    rdfs:comment 'Classification of the site\'s operational purpose: remit-to (payment address), ship-from (origin for goods), order-from (procurement contact point), bill-to (invoicing address), service-location (on-site service delivery), or warehouse (storage facility).' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swiftCode rdf:type rdf:Property ;
    rdfs:label 'Swift Code' ;
    rdfs:comment 'Society for Worldwide Interbank Financial Telecommunication (SWIFT) code for international wire transfers to the supplier site\'s bank account.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierQualificationId rdf:type rdf:Property ;
    rdfs:label 'Supplier Qualification Id' ;
    rdfs:comment 'Unique identifier for the supplier qualification record. Primary key.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aeoCertificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Aeo Certificate Expiry Date' ;
    rdfs:comment 'Expiration date of the AEO certification. Must be monitored to maintain customs compliance and trade facilitation benefits.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aeoCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Aeo Certification Status' ;
    rdfs:comment 'Status of Authorized Economic Operator certification, a customs compliance program that provides trade facilitation benefits. Critical for international freight forwarders and customs brokers.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentScore rdf:type rdf:Property ;
    rdfs:label 'Assessment Score' ;
    rdfs:comment 'Composite numerical score from the qualification assessment, typically on a 0-100 scale. Aggregates performance across multiple evaluation criteria including quality, delivery, financial health, and compliance.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctpatCertificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Ctpat Certificate Expiry Date' ;
    rdfs:comment 'Expiration date of the C-TPAT certification. Critical for maintaining supply chain security compliance for US-bound shipments.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ctpatCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Ctpat Certification Status' ;
    rdfs:comment 'Status of C-TPAT certification, a US Customs and Border Protection voluntary supply chain security program. Provides benefits for US import operations.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deniedPartyScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Denied Party Screening Date' ;
    rdfs:comment 'Date when the most recent denied party screening was performed. Must be refreshed periodically per trade compliance policies.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dueDiligenceCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Due Diligence Completed Flag' ;
    rdfs:comment 'Indicates whether comprehensive due diligence checks (financial, legal, operational, reputational) have been completed for this qualification event. True when all required checks are finalized.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dueDiligenceCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Due Diligence Completion Date' ;
    rdfs:comment 'Date when all due diligence activities were completed. Marks readiness for final qualification decision.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:euSanctionsScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Eu Sanctions Screening Result' ;
    rdfs:comment 'Result of screening against European Union consolidated sanctions lists. Critical for suppliers involved in EU trade lanes.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialHealthScore rdf:type rdf:Property ;
    rdfs:label 'Financial Health Score' ;
    rdfs:comment 'Quantitative assessment of supplier financial stability derived from credit reports, financial statements, and payment history. Scale 0-100 where higher indicates stronger financial position.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceCertificateStatus rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Status' ;
    rdfs:comment 'Status of supplier liability insurance certificate. Valid indicates current coverage meeting minimum requirements; insufficient coverage indicates policy limits below contract thresholds.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Amount' ;
    rdfs:comment 'Total liability coverage amount in the supplier insurance policy. Must meet or exceed contract-specified minimum coverage thresholds.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isoCertificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Iso Certificate Expiry Date' ;
    rdfs:comment 'Expiration date of the supplier ISO certification. Triggers re-certification requirements and compliance monitoring.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isoCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Iso Certification Status' ;
    rdfs:comment 'Status of supplier ISO certifications (e.g., ISO 9001 Quality Management, ISO 14001 Environmental Management, ISO 28000 Supply Chain Security). Indicates whether valid certifications are on file.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ofacScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Ofac Screening Result' ;
    rdfs:comment 'Specific result of screening against US OFAC sanctions lists. Pass indicates no match; fail indicates positive match requiring immediate action; review required indicates potential match needing manual investigation.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Completion Date' ;
    rdfs:comment 'Date when the qualification process was finalized with a decision (approved or rejected). Null if still in progress.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Expiry Date' ;
    rdfs:comment 'Date when the qualification approval expires and re-qualification is required. Critical for compliance monitoring and supplier lifecycle management.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationNotes rdf:type rdf:Property ;
    rdfs:label 'Qualification Notes' ;
    rdfs:comment 'Free-text field capturing assessor observations, special conditions, remediation requirements, or other contextual information relevant to the qualification decision. Used for audit trails and future reference.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationNumber rdf:type rdf:Property ;
    rdfs:label 'Qualification Number' ;
    rdfs:comment 'Business identifier for the qualification event. Externally visible reference number used in communications and audit trails.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationStartDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Start Date' ;
    rdfs:comment 'Date when the qualification process was initiated. Marks the beginning of the assessment lifecycle.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Status' ;
    rdfs:comment 'Current lifecycle state of the qualification: pending (awaiting initiation), in progress (under review), approved (passed all checks), rejected (failed qualification), suspended (temporarily halted), or expired (validity period ended).' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationType rdf:type rdf:Property ;
    rdfs:label 'Qualification Type' ;
    rdfs:comment 'Category of qualification event: initial onboarding for new suppliers, periodic review for scheduled reassessments, re-qualification after suspension, ad-hoc audit triggered by incidents, compliance verification for regulatory changes, or risk assessment for high-value contracts.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Overall risk classification assigned to the supplier based on financial stability, operational capacity, compliance history, and geopolitical factors. Drives procurement approval thresholds and monitoring frequency.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardedSupplierId rdf:type rdf:Property ;
    rdfs:label 'Awarded Supplier Id' ;
    rdfs:comment 'Identifier of the supplier who was awarded the business as a result of this RFQ. Null if RFQ is not yet awarded or was cancelled.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:awardDate rdf:type rdf:Property ;
    rdfs:label 'Award Date' ;
    rdfs:comment 'The date when the supplier award decision was made and communicated. Null if RFQ is not yet awarded.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awardedAmount rdf:type rdf:Property ;
    rdfs:label 'Awarded Amount' ;
    rdfs:comment 'The total contract value awarded to the winning supplier. Null if RFQ is not yet awarded.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'Data classification level for this RFQ and its associated documents. Determines access controls and sharing restrictions.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLocation rdf:type rdf:Property ;
    rdfs:label 'Delivery Location' ;
    rdfs:comment 'The facility, warehouse, or site where goods should be delivered or where services should be performed.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryWeightPercentage rdf:type rdf:Property ;
    rdfs:label 'Delivery Weight Percentage' ;
    rdfs:comment 'The percentage weight assigned to delivery time and reliability in the overall evaluation scoring model.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Spend Amount' ;
    rdfs:comment 'The estimated total monetary value of this procurement, used for budget planning and approval routing. May be shared with suppliers or kept confidential depending on sourcing strategy.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationCriteria rdf:type rdf:Property ;
    rdfs:label 'Evaluation Criteria' ;
    rdfs:comment 'The criteria and weighting that will be used to evaluate and score supplier quotations. May include price, quality, delivery time, service level, sustainability, financial stability, and past performance.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMultiRound rdf:type rdf:Property ;
    rdfs:label 'Is Multi Round' ;
    rdfs:comment 'Indicates whether this RFQ involves multiple rounds of bidding (e.g., initial submission followed by best-and-final-offer round). True = multi-round; False = single-round.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReverseAuction rdf:type rdf:Property ;
    rdfs:label 'Is Reverse Auction' ;
    rdfs:comment 'Indicates whether this RFQ includes a reverse auction phase where suppliers can see competitor pricing and submit lower bids in real-time. True = includes reverse auction; False = sealed bid only.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Issuing Business Unit' ;
    rdfs:comment 'The business unit, division, or department within Transport Shipping that is requesting the goods or services and issuing this RFQ.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingLocation rdf:type rdf:Property ;
    rdfs:label 'Issuing Location' ;
    rdfs:comment 'The geographic location, facility, or site that is the origin of this RFQ request.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceWeightPercentage rdf:type rdf:Property ;
    rdfs:label 'Price Weight Percentage' ;
    rdfs:comment 'The percentage weight assigned to price in the overall evaluation scoring model. Typically ranges from 30% to 70% depending on procurement strategy.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityWeightPercentage rdf:type rdf:Property ;
    rdfs:label 'Quality Weight Percentage' ;
    rdfs:comment 'The percentage weight assigned to quality criteria in the overall evaluation scoring model.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Required Delivery Date' ;
    rdfs:comment 'The date by which the requested goods or services must be delivered or available for use. Critical for supplier capacity planning and bid evaluation.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseCount rdf:type rdf:Property ;
    rdfs:label 'Response Count' ;
    rdfs:comment 'The number of suppliers who submitted quotations in response to this RFQ.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfqCategory rdf:type rdf:Property ;
    rdfs:label 'Rfq Category' ;
    rdfs:comment 'Classification of the procurement category for this RFQ. Determines routing, approval workflow, and evaluation criteria. Categories include carrier services (3PL, freight forwarding), fuel (diesel, aviation fuel), warehouse equipment (forklifts, racking), IT (hardware, software, services), facilities (maintenance, construction), fleet vehicles, and professional services. [ENUM-REF-CANDIDATE: carrier_services|fuel|warehouse_equipment|it_hardware|it_software|facilities|fleet_vehicles|professional_services — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqDescription rdf:type rdf:Property ;
    rdfs:label 'Rfq Description' ;
    rdfs:comment 'Detailed description of the goods or services being requested, including specifications, requirements, and scope of work.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqNumber rdf:type rdf:Property ;
    rdfs:label 'Rfq Number' ;
    rdfs:comment 'Externally-known business identifier for the RFQ, used in communications with suppliers and internal stakeholders. Typically follows format RFQ-YYYYMMDD-NNNN.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqStatus rdf:type rdf:Property ;
    rdfs:label 'Rfq Status' ;
    rdfs:comment 'Current lifecycle status of the RFQ. Draft = being prepared; Issued/Open = sent to suppliers and accepting responses; Closed = submission deadline passed, under evaluation; Awarded = supplier(s) selected and notified; Cancelled = RFQ withdrawn; Expired = deadline passed with no award. [ENUM-REF-CANDIDATE: draft|issued|open|closed|awarded|cancelled|expired — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingEventType rdf:type rdf:Property ;
    rdfs:label 'Sourcing Event Type' ;
    rdfs:comment 'Classification of the sourcing event complexity and strategic importance. Spot = one-time immediate need; Tactical = recurring operational procurement; Strategic = high-value, long-term, complex sourcing.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'More granular classification within the procurement category, providing additional detail on the type of goods or services being sourced.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Submission Deadline' ;
    rdfs:comment 'The date and time by which suppliers must submit their quotations. No late submissions are typically accepted after this timestamp.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supplierCount rdf:type rdf:Property ;
    rdfs:label 'Supplier Count' ;
    rdfs:comment 'The number of suppliers invited to participate in this RFQ. Influences competition level and response rate.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Brief descriptive title summarizing the goods or services being requested in this RFQ.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardStatus rdf:type rdf:Property ;
    rdfs:label 'Award Status' ;
    rdfs:comment 'Indicates whether this quote was awarded a purchase order or contract.' ;
    rdfs:domain ind:SupplierQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertification rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification' ;
    rdfs:comment 'Certifications or compliance declarations provided by the supplier, such as ISO 9001, C-TPAT, AEO, or industry-specific standards.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsDutyEstimate rdf:type rdf:Property ;
    rdfs:label 'Customs Duty Estimate' ;
    rdfs:comment 'Estimated customs duties or tariffs applicable to the quoted goods, if included by the supplier.' ;
    rdfs:domain ind:SupplierQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryTerms rdf:type rdf:Property ;
    rdfs:label 'Delivery Terms' ;
    rdfs:comment 'Incoterms or delivery terms specified in the quote, such as FOB, CIF, DDP, DAP, EXW.' ;
    rdfs:domain ind:SupplierQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationLocation rdf:type rdf:Property ;
    rdfs:label 'Destination Location' ;
    rdfs:comment 'Delivery destination or port specified in the quote.' ;
    rdfs:domain ind:SupplierQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationScore rdf:type rdf:Property ;
    rdfs:label 'Evaluation Score' ;
    rdfs:comment 'Composite score assigned during quote evaluation based on price, quality, delivery, and other criteria.' ;
    rdfs:domain ind:SupplierQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCharges rdf:type rdf:Property ;
    rdfs:label 'Freight Charges' ;
    rdfs:comment 'Freight or shipping charges included in or added to the quote.' ;
    rdfs:domain ind:SupplierQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handlingCharges rdf:type rdf:Property ;
    rdfs:label 'Handling Charges' ;
    rdfs:comment 'Handling or packaging charges specified in the quote.' ;
    rdfs:domain ind:SupplierQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceCharges rdf:type rdf:Property ;
    rdfs:label 'Insurance Charges' ;
    rdfs:comment 'Insurance charges included in the quote for shipment coverage.' ;
    rdfs:domain ind:SupplierQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Quantity' ;
    rdfs:comment 'Maximum order quantity the supplier can fulfill under this quote.' ;
    rdfs:domain ind:SupplierQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'Minimum order quantity required by the supplier for this quote to be valid.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Quote Reference Number' ;
    rdfs:comment 'External reference number assigned by the supplier to this quotation. Used for supplier correspondence and tracking.' ;
    rdfs:domain ind:SupplierQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteType rdf:type rdf:Property ;
    rdfs:label 'Quote Type' ;
    rdfs:comment 'Classification of the quote based on pricing structure or sourcing context.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rank rdf:type rdf:Property ;
    rdfs:label 'Rank' ;
    rdfs:comment 'Ranking of this quote relative to other quotes received for the same RFQ, with 1 being the best.' ;
    rdfs:domain ind:SupplierQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shippingPoint rdf:type rdf:Property ;
    rdfs:label 'Shipping Point' ;
    rdfs:comment 'Origin location or port from which the supplier will ship the goods.' ;
    rdfs:domain ind:SupplierQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityRating rdf:type rdf:Property ;
    rdfs:label 'Sustainability Rating' ;
    rdfs:comment 'Sustainability or environmental rating of the supplier or quoted goods, supporting green procurement initiatives.' ;
    rdfs:domain ind:SupplierQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAmountIncludingTax rdf:type rdf:Property ;
    rdfs:label 'Total Amount Including Tax' ;
    rdfs:comment 'Grand total of the quote including all taxes and charges.' ;
    rdfs:domain ind:SupplierQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'Start date from which the quoted prices and terms are effective.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validUntilDate rdf:type rdf:Property ;
    rdfs:label 'Valid Until Date' ;
    rdfs:comment 'Expiration date after which the quoted prices and terms are no longer binding.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:warrantyTerms rdf:type rdf:Property ;
    rdfs:label 'Warranty Terms' ;
    rdfs:comment 'Warranty or guarantee terms offered by the supplier for the quoted goods or services.' ;
    rdfs:domain ind:SupplierQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inboundLaneId rdf:type rdf:Property ;
    rdfs:label 'Inbound Lane Id' ;
    rdfs:comment 'Foreign key linking to route.lane. Business justification: Inbound POs from suppliers require lane assignment for contracted routing, rate application, and transit time commitment. Procurement teams select lanes when planning supplier deliveries. The existing' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lane .

ind:acknowledgementReceivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Received Timestamp' ;
    rdfs:comment 'Date and time when the supplier acknowledged receipt and acceptance of the purchase order.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:budgetCode rdf:type rdf:Property ;
    rdfs:label 'Budget Code' ;
    rdfs:comment 'Budget line or project code against which this purchase order is charged for budget tracking and control.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expenditureType rdf:type rdf:Property ;
    rdfs:label 'Expenditure Type' ;
    rdfs:comment 'Classification of purchase order as Capital Expenditure (CAPEX) for long-term assets or Operating Expenditure (OPEX) for operational costs.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightTerm rdf:type rdf:Property ;
    rdfs:label 'Freight Term' ;
    rdfs:comment 'Freight payment responsibility: prepaid (supplier pays), collect (buyer pays), third-party (designated carrier), FOB origin, FOB destination.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poDate rdf:type rdf:Property ;
    rdfs:label 'Po Date' ;
    rdfs:comment 'Date when the purchase order was created and issued. Principal business event timestamp for this transaction.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'Externally-known unique purchase order number issued to supplier. Business identifier for procurement transactions.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poStatus rdf:type rdf:Property ;
    rdfs:label 'Po Status' ;
    rdfs:comment 'Current lifecycle status of the purchase order in the procurement workflow. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|sent|acknowledged|partially_received|fully_received|closed|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poType rdf:type rdf:Property ;
    rdfs:label 'Po Type' ;
    rdfs:comment 'Classification of purchase order type: standard (one-time purchase), blanket (recurring purchases against agreement), planned (scheduled delivery), contract-release (release against master contract), spot (ad-hoc), emergency (urgent procurement).' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementCategory rdf:type rdf:Property ;
    rdfs:label 'Procurement Category' ;
    rdfs:comment 'High-level procurement category or commodity classification (e.g., Fleet & Vehicles, IT Equipment, Warehouse Supplies, Professional Services, Fuel & Energy).' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promisedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Promised Delivery Date' ;
    rdfs:comment 'Date confirmed by the supplier for delivery of goods or completion of services.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sentToSupplierTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sent To Supplier Timestamp' ;
    rdfs:comment 'Date and time when the purchase order was transmitted to the supplier via EDI, email, or portal.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shippingMethod rdf:type rdf:Property ;
    rdfs:label 'Shipping Method' ;
    rdfs:comment 'Preferred or required shipping method for delivery (e.g., air freight, ocean freight, ground, courier).' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemId rdf:type rdf:Property ;
    rdfs:label 'Item Id' ;
    rdfs:comment 'Reference to the master item or material being procured. Links to the product/service catalog entry.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Item .

ind:purchaseRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Purchase Requisition Id' ;
    rdfs:comment 'Reference to the originating purchase requisition line that triggered this PO line. Provides traceability from demand to procurement.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseRequisition .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'The fixed asset number if this line item represents the procurement of a capital asset. Used for asset capitalization and depreciation tracking.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityCategory rdf:type rdf:Property ;
    rdfs:label 'Commodity Category' ;
    rdfs:comment 'Classification of the item into a procurement commodity category for spend analysis and sourcing strategy. Examples include Fleet Vehicles, Warehouse Equipment, IT Hardware, Professional Services, Fuel, Packaging Materials.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoicedQuantity rdf:type rdf:Property ;
    rdfs:label 'Invoiced Quantity' ;
    rdfs:comment 'The cumulative quantity that has been invoiced by the supplier for this line item. Used for invoice matching and payment processing.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCapitalExpenditure rdf:type rdf:Property ;
    rdfs:label 'Is Capital Expenditure' ;
    rdfs:comment 'Flag indicating whether this line item represents a capital expenditure (CAPEX) rather than an operating expenditure (OPEX). Determines accounting treatment and approval workflow.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isServices rdf:type rdf:Property ;
    rdfs:label 'Is Services' ;
    rdfs:comment 'Flag indicating whether this line item represents services rather than goods. Affects receipt processing and invoice matching rules.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineNotes rdf:type rdf:Property ;
    rdfs:label 'Line Notes' ;
    rdfs:comment 'Free-text notes or special instructions specific to this line item. May include delivery instructions, quality requirements, or handling notes.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierPartNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Part Number' ;
    rdfs:comment 'The suppliers own part number or SKU for the item being procured. Used for supplier catalog matching and order communication.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElement rdf:type rdf:Property ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'The project work breakdown structure element for capital projects or project-based procurement. Used for project cost tracking and CAPEX management.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Unique identifier for the goods receipt record. Primary key.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:acceptedQuantity rdf:type rdf:Property ;
    rdfs:label 'Accepted Quantity' ;
    rdfs:comment 'The quantity of goods that passed inspection and were accepted into inventory or for use. Used for three-way match with purchase order and invoice.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Manufacturer or supplier batch/lot number for traceability, quality control, and recall management. Critical for regulated materials and perishables.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Note Number' ;
    rdfs:comment 'Supplier-provided delivery note, packing slip, or dispatch advice number accompanying the shipment. Used for cross-referencing and dispute resolution.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Expected Delivery Date' ;
    rdfs:comment 'The date on which the goods were originally scheduled to arrive per the purchase order, used to measure supplier on-time delivery performance.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grNumber rdf:type rdf:Property ;
    rdfs:label 'Gr Number' ;
    rdfs:comment 'Business-facing unique identifier for the goods receipt, typically system-generated and used in communications with suppliers and internal stakeholders.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Certificate Number' ;
    rdfs:comment 'Reference number of the quality inspection certificate or test report issued for the received goods, required for regulated or critical materials.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Date' ;
    rdfs:comment 'Date on which the quality inspection was performed, which may differ from the receipt date if inspection is deferred or requires specialized testing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:matchToleranceExceededFlag rdf:type rdf:Property ;
    rdfs:label 'Match Tolerance Exceeded Flag' ;
    rdfs:comment 'Indicates whether the variance between ordered and received quantity exceeds the acceptable tolerance threshold defined in procurement policy, triggering manual review.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentClearedFlag rdf:type rdf:Property ;
    rdfs:label 'Payment Cleared Flag' ;
    rdfs:comment 'Indicates whether the supplier invoice associated with this goods receipt has been paid, completing the procure-to-pay cycle.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Timestamp' ;
    rdfs:comment 'Precise date and time when the goods receipt was recorded in the system, used for audit trail and time-sensitive matching processes.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receiptValueAmount rdf:type rdf:Property ;
    rdfs:label 'Receipt Value Amount' ;
    rdfs:comment 'Total monetary value of the accepted goods based on purchase order price, used for accrual accounting and inventory valuation.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivingDock rdf:type rdf:Property ;
    rdfs:label 'Receiving Dock' ;
    rdfs:comment 'Specific dock, bay, or receiving area within the location where the goods were unloaded and inspected.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionNotes rdf:type rdf:Property ;
    rdfs:label 'Rejection Notes' ;
    rdfs:comment 'Free-text detailed explanation of the rejection, including specific defects observed, photos taken, and actions required from the supplier.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Return Authorization Number' ;
    rdfs:comment 'RMA number issued by the supplier authorizing the return of rejected goods, used to track the reverse logistics process and credit issuance.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeWayMatchStatus rdf:type rdf:Property ;
    rdfs:label 'Three Way Match Status' ;
    rdfs:comment 'Status of the three-way match process comparing purchase order, goods receipt, and supplier invoice: matched (all align within tolerance), quantity variance (receipt quantity differs), price variance (invoice price differs), not matched (significant discrepancies), or pending (invoice not yet received).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReferenceUrl rdf:type rdf:Property ;
    rdfs:label 'Document Reference Url' ;
    rdfs:comment 'URL or file path to the original invoice document (PDF, image, EDI file). Used for document retrieval and audit purposes.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total invoice amount before tax and adjustments. Sum of all line item amounts.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDescription rdf:type rdf:Property ;
    rdfs:label 'Invoice Description' ;
    rdfs:comment 'Free-text description of the invoice purpose or contents. Provides business context for the invoice.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchExceptionAmount rdf:type rdf:Property ;
    rdfs:label 'Match Exception Amount' ;
    rdfs:comment 'Monetary value of the discrepancy identified in three-way match. Null if no exception or exception is non-monetary.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchExceptionResolution rdf:type rdf:Property ;
    rdfs:label 'Match Exception Resolution' ;
    rdfs:comment 'Description of how the match exception was resolved. Examples: supplier credit issued, PO amended, goods receipt corrected, management override. Null if exception is unresolved.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchExceptionType rdf:type rdf:Property ;
    rdfs:label 'Match Exception Type' ;
    rdfs:comment 'Type of discrepancy identified during three-way match. Examples: price variance, quantity variance, tax variance, missing PO, missing goods receipt. Null if no exception. [ENUM-REF-CANDIDATE: price_variance|quantity_variance|tax_variance|missing_po|missing_gr|duplicate_invoice|unauthorized_charge — promote to reference product]' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'Date the invoice was received by the organization. Used for processing SLA tracking and aging analysis.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'Channel through which the supplier submitted the invoice. EDI for Electronic Data Interchange, email for scanned/PDF invoices, portal for supplier self-service, paper for physical mail, API for system-to-system integration.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction' ;
    rdfs:comment 'Tax jurisdiction or authority under which tax is calculated and remitted. Examples: US-CA (California), GB-VAT (UK VAT), EU-VAT. Critical for tax compliance and reporting.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementInvoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Procurement Invoice Line Id' ;
    rdfs:comment 'Unique identifier for the procurement invoice line item. Primary key for this entity.' ;
    rdfs:domain ind:ProcurementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:itemCategory rdf:type rdf:Property ;
    rdfs:label 'Item Category' ;
    rdfs:comment 'Classification of the invoiced item type. Distinguishes between goods, services, freight, fuel, maintenance, capital equipment, software, and consulting services. [ENUM-REF-CANDIDATE: goods|services|freight|fuel|maintenance|capital_equipment|software|consulting — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProcurementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemDescription rdf:type rdf:Property ;
    rdfs:label 'Item Description' ;
    rdfs:comment 'Detailed textual description of the goods or services invoiced on this line. May include specifications, model numbers, or service details.' ;
    rdfs:domain ind:ProcurementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialCode rdf:type rdf:Property ;
    rdfs:label 'Material Code' ;
    rdfs:comment 'Internal material or service master code. Links to the organization\'s master data catalog for goods or services.' ;
    rdfs:domain ind:ProcurementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netLineAmount rdf:type rdf:Property ;
    rdfs:label 'Net Line Amount' ;
    rdfs:comment 'Net amount for this invoice line after discounts and taxes. Represents the final payable amount for this line item.' ;
    rdfs:domain ind:ProcurementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Price Variance Amount' ;
    rdfs:comment 'Difference between invoiced unit price and PO unit price multiplied by invoiced quantity. Positive values indicate invoice price exceeds PO price.' ;
    rdfs:domain ind:ProcurementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityVariance rdf:type rdf:Property ;
    rdfs:label 'Quantity Variance' ;
    rdfs:comment 'Difference between invoiced quantity and goods receipt quantity. Positive values indicate invoice quantity exceeds received quantity.' ;
    rdfs:domain ind:ProcurementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:servicePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Service Period End Date' ;
    rdfs:comment 'End date of the service period for this invoice line. Used for accrual accounting and service period reconciliation.' ;
    rdfs:domain ind:ProcurementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:servicePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Service Period Start Date' ;
    rdfs:comment 'Start date of the service period for this invoice line. Applicable for recurring services, subscriptions, or time-based billing.' ;
    rdfs:domain ind:ProcurementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:withholdingTaxCode rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Code' ;
    rdfs:comment 'Tax code for withholding tax calculation. Determines the applicable withholding tax rate and reporting requirements.' ;
    rdfs:domain ind:ProcurementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredSupplierId rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier Id' ;
    rdfs:comment 'Identifier of the supplier preferred by the requestor for fulfilling this requisition.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:approvalLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Level' ;
    rdfs:comment 'Current approval level in the multi-tier approval hierarchy (e.g., 1 for manager, 2 for director, 3 for VP).' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Check Status' ;
    rdfs:comment 'Result of the budget availability check performed against the cost center and GL account at requisition submission.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Budget Check Timestamp' ;
    rdfs:comment 'Date and time when the budget availability check was performed.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:conversionOutcome rdf:type rdf:Property ;
    rdfs:label 'Conversion Outcome' ;
    rdfs:comment 'Outcome of the requisition after approval, indicating whether it was converted to a purchase order, routed to a sourcing event, or cancelled.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAddress rdf:type rdf:Property ;
    rdfs:label 'Delivery Address' ;
    rdfs:comment 'Full delivery address for the requisitioned goods or services, including street, city, state, and postal code.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Amount' ;
    rdfs:comment 'Total estimated cost of the requisition, calculated as quantity requested multiplied by estimated unit price.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Estimated Unit Price' ;
    rdfs:comment 'Estimated price per unit of the item or service being requisitioned, used for budget validation.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:justification rdf:type rdf:Property ;
    rdfs:label 'Justification' ;
    rdfs:comment 'Business rationale and justification provided by the requestor for the purchase requisition.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityRequested rdf:type rdf:Property ;
    rdfs:label 'Quantity Requested' ;
    rdfs:comment 'Quantity of the item or service being requisitioned.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rejected Timestamp' ;
    rdfs:comment 'Date and time when the requisition was rejected by an approver.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Requisition Number' ;
    rdfs:comment 'Business-facing unique identifier for the purchase requisition, typically system-generated and used in communications and approvals.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Requisition Status' ;
    rdfs:comment 'Current lifecycle status of the purchase requisition in the approval and procurement workflow. [ENUM-REF-CANDIDATE: draft|submitted|pending_approval|approved|rejected|cancelled|converted_to_po — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionType rdf:type rdf:Property ;
    rdfs:label 'Requisition Type' ;
    rdfs:comment 'Classification of the purchase requisition based on the nature of goods or services being requested.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted Timestamp' ;
    rdfs:comment 'Date and time when the requisition was submitted for approval by the requestor.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:merchantCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Merchant Customer Account Id' ;
    rdfs:comment 'Reference to the merchant or customer account that originated this fulfillment order.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:procurementPurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Procurement Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_order. Business justification: Fulfillment orders for internal logistics supplies (packaging materials, labels, consumables) are procured via purchase orders. Enables supply chain cost allocation and inventory replenishment trackin' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:carrierServiceProviderCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Service Provider Code' ;
    rdfs:comment 'The code identifying the carrier or third-party logistics (3PL) provider selected for last-mile delivery.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codFlag rdf:type rdf:Property ;
    rdfs:label 'Cod Flag' ;
    rdfs:comment 'Indicates whether this order requires cash-on-delivery collection at the time of delivery (True = COD required, False = prepaid).' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivered Timestamp' ;
    rdfs:comment 'The date and time when the order was successfully delivered to the recipient and proof of delivery (POD) was captured.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fulfillmentMode rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Mode' ;
    rdfs:comment 'The operational fulfillment method used to execute this order (warehouse pick, dropship, cross-dock, etc.).' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationMessageCode rdf:type rdf:Property ;
    rdfs:label 'Integration Message Code' ;
    rdfs:comment 'The unique identifier of the EDI or API message that transmitted this order, used for omnichannel integration traceability.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantOrderReference rdf:type rdf:Property ;
    rdfs:label 'Merchant Order Reference' ;
    rdfs:comment 'The merchant\'s original order reference number or identifier from their e-commerce platform.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalOrderReference rdf:type rdf:Property ;
    rdfs:label 'Original Order Reference' ;
    rdfs:comment 'For return or exchange orders, the reference to the original fulfillment order being returned or exchanged.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnFlag rdf:type rdf:Property ;
    rdfs:label 'Return Flag' ;
    rdfs:comment 'Indicates whether this order is a return merchandise authorization (RMA) order (True = return, False = forward shipment).' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rmaNumber rdf:type rdf:Property ;
    rdfs:label 'Rma Number' ;
    rdfs:comment 'The return merchandise authorization number issued for return orders, linking back to the original order.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaWindowEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Window End Timestamp' ;
    rdfs:comment 'The end of the promised delivery time window for SLA compliance tracking.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaWindowStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Window Start Timestamp' ;
    rdfs:comment 'The start of the promised delivery time window for SLA compliance tracking.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceChannel rdf:type rdf:Property ;
    rdfs:label 'Source Channel' ;
    rdfs:comment 'The technical channel through which the order was received (EDI, API, web portal, mobile app, manual entry).' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPackageCount rdf:type rdf:Property ;
    rdfs:label 'Total Package Count' ;
    rdfs:comment 'The total number of packages or parcels created for this order during the packing process.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validated Timestamp' ;
    rdfs:comment 'The date and time when the order passed validation checks (inventory availability, address verification, payment authorization).' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:valueAmount rdf:type rdf:Property ;
    rdfs:label 'Value Amount' ;
    rdfs:comment 'The total declared value of goods in this fulfillment order, used for insurance and customs purposes.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Value Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the order value amount.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backOrderExpectedDate rdf:type rdf:Property ;
    rdfs:label 'Back Order Expected Date' ;
    rdfs:comment 'Expected date when back-ordered inventory will be available for fulfillment. Used for customer communication and inventory planning.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Back Order Flag' ;
    rdfs:comment 'Indicates whether this line item is on back order due to insufficient inventory. True if the item will be fulfilled in a subsequent shipment.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:binLocation rdf:type rdf:Property ;
    rdfs:label 'Bin Location' ;
    rdfs:comment 'Specific bin, shelf, or slot location within the warehouse where the SKU is stored. Used by WMS for pick path optimization and inventory accuracy.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredValue rdf:type rdf:Property ;
    rdfs:label 'Declared Value' ;
    rdfs:comment 'Declared monetary value of the line item for insurance, customs declaration, and liability purposes. Used for cargo insurance and claims processing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dimensionUom rdf:type rdf:Property ;
    rdfs:label 'Dimension Uom' ;
    rdfs:comment 'Unit of measure for length, width, and height dimensions. Common values include CM (centimeter), IN (inch), M (meter), FT (foot).' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftWrapFlag rdf:type rdf:Property ;
    rdfs:label 'Gift Wrap Flag' ;
    rdfs:comment 'Indicates whether gift wrapping service was requested for this line item. Triggers special handling instructions during packing operations.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalSku rdf:type rdf:Property ;
    rdfs:label 'Original Sku' ;
    rdfs:comment 'The originally ordered SKU if this line represents a substitution. Null if no substitution occurred. Used for customer communication and substitution analytics.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Timestamp' ;
    rdfs:comment 'Date and time when the line item was packed and prepared for shipment. Used for pack productivity analysis and order cycle time measurement.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pick Timestamp' ;
    rdfs:comment 'Date and time when the line item was picked from warehouse inventory. Used for pick productivity analysis and SLA tracking.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'Human-readable name or description of the product being fulfilled on this line. Used for pick-pack documentation and customer communication.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityUom rdf:type rdf:Property ;
    rdfs:label 'Quantity Uom' ;
    rdfs:comment 'Unit of measure for the ordered quantity. Common values include EA (each), CS (case), PK (pack), BX (box), PL (pallet), KG (kilogram), LB (pound), LT (liter), GL (gallon). [ENUM-REF-CANDIDATE: EA|CS|PK|BX|PL|KG|LB|LT|GL — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ship Timestamp' ;
    rdfs:comment 'Date and time when the line item was dispatched from the fulfillment center. Used for carrier handoff tracking and delivery ETA calculation.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sku rdf:type rdf:Property ;
    rdfs:label 'Sku' ;
    rdfs:comment 'Unique product identifier representing the specific item to be fulfilled. Used for inventory lookup, pick instructions, and product master reference.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionFlag rdf:type rdf:Property ;
    rdfs:label 'Substitution Flag' ;
    rdfs:comment 'Indicates whether this line item is a substitution for an out-of-stock SKU. True if a substitute product was picked instead of the originally ordered SKU.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitHeight rdf:type rdf:Property ;
    rdfs:label 'Unit Height' ;
    rdfs:comment 'Height dimension of a single unit of the SKU. Used for dimensional weight calculations and warehouse slotting optimization.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitLength rdf:type rdf:Property ;
    rdfs:label 'Unit Length' ;
    rdfs:comment 'Length dimension of a single unit of the SKU. Used for dimensional weight (DIM weight) calculations and packaging optimization.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitWeight rdf:type rdf:Property ;
    rdfs:label 'Unit Weight' ;
    rdfs:comment 'Weight of a single unit of the SKU. Used for dimensional weight calculations, carrier selection, and freight cost estimation.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitWidth rdf:type rdf:Property ;
    rdfs:label 'Unit Width' ;
    rdfs:comment 'Width dimension of a single unit of the SKU. Used for dimensional weight calculations and carton selection during packing.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warehouseLocationCode rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location Code' ;
    rdfs:comment 'Code identifying the warehouse or fulfillment center location where this line item is being processed. Used for inventory allocation and pick routing.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingSupplierId rdf:type rdf:Property ;
    rdfs:label 'Packaging Supplier Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier. Business justification: Tracks packaging material supplier for each parcel. Critical for quality control, cost analysis, and supplier performance evaluation in logistics operations. Enables root cause analysis when packaging' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:carrierServiceCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Service Code' ;
    rdfs:comment 'Specific service level selected for parcel delivery (e.g., express, standard, economy, next_day, two_day). Determines transit time and service level agreement (SLA).' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierServiceName rdf:type rdf:Property ;
    rdfs:label 'Carrier Service Name' ;
    rdfs:comment 'Human-readable name of the carrier service (e.g., FedEx Priority Overnight, UPS Ground, DHL Express Worldwide).' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationLatitude rdf:type rdf:Property ;
    rdfs:label 'Destination Latitude' ;
    rdfs:comment 'Latitude coordinate of the delivery address. Used for GPS-based route optimization and real-time tracking.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationLongitude rdf:type rdf:Property ;
    rdfs:label 'Destination Longitude' ;
    rdfs:comment 'Longitude coordinate of the delivery address. Used for GPS-based route optimization and real-time tracking.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatUnNumber rdf:type rdf:Property ;
    rdfs:label 'Hazmat Un Number' ;
    rdfs:comment 'Four-digit UN number identifying the dangerous goods substance (e.g., UN1203 for gasoline). Required for hazmat compliance and carrier acceptance.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manifest Timestamp' ;
    rdfs:comment 'Date and time when the parcel was manifested and handed over to the carrier. Used for carrier billing and service level agreement (SLA) tracking.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originFacilityCode rdf:type rdf:Property ;
    rdfs:label 'Origin Facility Code' ;
    rdfs:comment 'Code of the warehouse or fulfillment center where the parcel was packed and dispatched. Used for operational reporting and network optimization.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingMaterial rdf:type rdf:Property ;
    rdfs:label 'Packaging Material' ;
    rdfs:comment 'Primary material used in the packaging. Relevant for sustainability reporting and greenhouse gas (GHG) emissions tracking.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parcelStatus rdf:type rdf:Property ;
    rdfs:label 'Parcel Status' ;
    rdfs:comment 'Current lifecycle status of the parcel in the pick-pack-ship and last-mile delivery workflow. [ENUM-REF-CANDIDATE: packed|manifested|dispatched|in_transit|out_for_delivery|delivered|failed_delivery|returned|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientContactEmail rdf:type rdf:Property ;
    rdfs:label 'Recipient Contact Email' ;
    rdfs:comment 'Email address of the recipient for delivery notifications and electronic proof of delivery (ePOD) transmission.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientContactPhone rdf:type rdf:Property ;
    rdfs:label 'Recipient Contact Phone' ;
    rdfs:comment 'Phone number of the recipient for delivery coordination and failed delivery notifications.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetDeliveryTimeWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Sla Target Delivery Time Window End' ;
    rdfs:comment 'End of the committed delivery time window for time-definite services (e.g., 12:00 PM for morning delivery).' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaTargetDeliveryTimeWindowStart rdf:type rdf:Property ;
    rdfs:label 'Sla Target Delivery Time Window Start' ;
    rdfs:comment 'Start of the committed delivery time window for time-definite services (e.g., 9:00 AM for morning delivery).' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consolidationTplProviderId rdf:type rdf:Property ;
    rdfs:label 'Consolidation Tpl Provider Id' ;
    rdfs:comment 'Foreign key linking to network.tpl_provider. Business justification: Manifests are often consolidated by 3PLs for linehaul before final carrier delivery. Tracking which 3PL handled manifest sortation/consolidation is required for cost allocation, performance tracking, ' ;
    rdfs:domain ind:ParcelManifest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TplProvider .

ind:manifestDriverProfileId rdf:type rdf:Property ;
    rdfs:label 'Manifest Driver Profile Id' ;
    rdfs:comment 'Foreign key linking to fleet.driver_profile. Business justification: Manifest handoff and carrier tender require driver identification with license validation, HOS compliance verification, and certification checks (hazmat, dangerous goods). Existing driver_employee_id ' ;
    rdfs:domain ind:ParcelManifest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DriverProfile .

ind:carrierAcknowledgementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Carrier Acknowledgement Timestamp' ;
    rdfs:comment 'Date and time when the carrier acknowledged receipt of the manifest via EDI 997 functional acknowledgement or API response.' ;
    rdfs:domain ind:ParcelManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:containsHazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Contains Hazmat Flag' ;
    rdfs:comment 'Indicates whether this manifest contains any parcels with hazardous materials requiring special handling and regulatory compliance.' ;
    rdfs:domain ind:ParcelManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containsHighValueFlag rdf:type rdf:Property ;
    rdfs:label 'Contains High Value Flag' ;
    rdfs:comment 'Indicates whether this manifest contains parcels exceeding the high-value threshold requiring enhanced security and insurance.' ;
    rdfs:domain ind:ParcelManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediTransmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Edi Transmission Status' ;
    rdfs:comment 'Status of EDI manifest transmission to the carrier system. Tracks whether manifest data has been successfully communicated via EDI 214, 315, or API.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTransmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Edi Transmission Timestamp' ;
    rdfs:comment 'Date and time when the manifest was transmitted to the carrier via EDI or API.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Timestamp' ;
    rdfs:comment 'Predicted date and time when the manifest will arrive at the destination zone or carrier hub. May be updated in real-time via carrier tracking systems.' ;
    rdfs:domain ind:ParcelManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manifestType rdf:type rdf:Property ;
    rdfs:label 'Manifest Type' ;
    rdfs:comment 'Classification of the manifest based on its operational purpose. Outbound: customer deliveries; Inbound: returns; Transfer: inter-facility; Return: RMA; Cross-dock: direct transfer.' ;
    rdfs:domain ind:ParcelManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Timestamp' ;
    rdfs:comment 'Date and time when the manifest reconciliation process was completed.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:routeCode rdf:type rdf:Property ;
    rdfs:label 'Route Code' ;
    rdfs:comment 'Identifier of the delivery route or service lane assigned to this manifest for network optimization and performance tracking.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCodAmount rdf:type rdf:Property ;
    rdfs:label 'Total Cod Amount' ;
    rdfs:comment 'Sum of all COD collection amounts for parcels in this manifest. Carrier is responsible for collecting and remitting these funds.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDeclaredValueAmount rdf:type rdf:Property ;
    rdfs:label 'Total Declared Value Amount' ;
    rdfs:comment 'Sum of declared values of all parcels in the manifest. Used for insurance coverage and liability determination.' ;
    rdfs:domain ind:ParcelManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalParcelCount rdf:type rdf:Property ;
    rdfs:label 'Total Parcel Count' ;
    rdfs:comment 'Total number of individual parcels included in this manifest. Used for carrier handover verification and freight audit.' ;
    rdfs:domain ind:ParcelManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVolumetricWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Volumetric Weight Kg' ;
    rdfs:comment 'Total dimensional weight (DIM weight) of all parcels calculated using carrier-specific volumetric divisor. Used for freight rating when volumetric weight exceeds actual weight.' ;
    rdfs:domain ind:ParcelManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accessCode rdf:type rdf:Property ;
    rdfs:label 'Access Code' ;
    rdfs:comment 'Building or gate access code provided to enable delivery agent entry to restricted premises. Confidential information for delivery execution.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attemptDate rdf:type rdf:Property ;
    rdfs:label 'Attempt Date' ;
    rdfs:comment 'Calendar date on which this delivery attempt occurred. Used for daily delivery performance reporting.' ;
    rdfs:domain ind:DeliveryAttempt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:attemptLatitude rdf:type rdf:Property ;
    rdfs:label 'Attempt Latitude' ;
    rdfs:comment 'GPS latitude coordinate captured at the moment of delivery attempt. Used for geolocation verification and route optimization analysis.' ;
    rdfs:domain ind:DeliveryAttempt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attemptLongitude rdf:type rdf:Property ;
    rdfs:label 'Attempt Longitude' ;
    rdfs:comment 'GPS longitude coordinate captured at the moment of delivery attempt. Used for geolocation verification and route optimization analysis.' ;
    rdfs:domain ind:DeliveryAttempt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attemptNumber rdf:type rdf:Property ;
    rdfs:label 'Attempt Number' ;
    rdfs:comment 'Sequential number of this delivery attempt for the consignment (1 for first attempt, 2 for second, etc.). Used to track re-delivery attempts.' ;
    rdfs:domain ind:DeliveryAttempt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attemptOutcomeCode rdf:type rdf:Property ;
    rdfs:label 'Attempt Outcome Code' ;
    rdfs:comment 'Standardized code indicating the result of the delivery attempt. Core field for OTD and OTIF KPI calculation. [ENUM-REF-CANDIDATE: delivered|failed|refused|no_access|redirected|damaged|address_incorrect — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeliveryAttempt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attemptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Attempt Timestamp' ;
    rdfs:comment 'Precise date and time when the delivery agent arrived at the delivery location and initiated the attempt. Primary business event timestamp for SLA calculation.' ;
    rdfs:domain ind:DeliveryAttempt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:codPaymentMethod rdf:type rdf:Property ;
    rdfs:label 'Cod Payment Method' ;
    rdfs:comment 'Method used by recipient to pay the COD amount (cash, credit card, mobile payment, check). Null if COD was not collected.' ;
    rdfs:domain ind:DeliveryAttempt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depotLocationCode rdf:type rdf:Property ;
    rdfs:label 'Depot Location Code' ;
    rdfs:comment 'Code identifying the depot or distribution center from which this delivery attempt was dispatched. Used for operational reporting and network analysis.' ;
    rdfs:domain ind:DeliveryAttempt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epodReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Epod Reference Number' ;
    rdfs:comment 'Unique reference number linking to the electronic proof of delivery record (signature, photo, barcode scan). Null if delivery was not completed.' ;
    rdfs:domain ind:DeliveryAttempt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureReasonCode rdf:type rdf:Property ;
    rdfs:label 'Failure Reason Code' ;
    rdfs:comment 'Detailed reason code explaining why a delivery attempt failed (e.g., recipient_not_home, business_closed, access_denied, incorrect_address). Null if attempt was successful. [ENUM-REF-CANDIDATE: recipient_not_home|business_closed|access_denied|incorrect_address|security_restriction|weather_delay|vehicle_breakdown — promote to reference product]' ;
    rdfs:domain ind:DeliveryAttempt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Failure Reason Description' ;
    rdfs:comment 'Free-text description providing additional context about the delivery failure. Captured by delivery agent for customer service follow-up.' ;
    rdfs:domain ind:DeliveryAttempt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextActionInstruction rdf:type rdf:Property ;
    rdfs:label 'Next Action Instruction' ;
    rdfs:comment 'Instruction code indicating the next step to be taken following this attempt (e.g., schedule re-attempt, hold at depot, return to sender). Drives workflow automation.' ;
    rdfs:domain ind:DeliveryAttempt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reattemptScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Reattempt Scheduled Date' ;
    rdfs:comment 'Date on which the next delivery re-attempt is scheduled. Null if no re-attempt is planned or if delivery was successful.' ;
    rdfs:domain ind:DeliveryAttempt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recipientRelationship rdf:type rdf:Property ;
    rdfs:label 'Recipient Relationship' ;
    rdfs:comment 'Relationship of the actual recipient to the consignee (e.g., consignee themselves, family member, neighbor, building security). Used for delivery authorization validation.' ;
    rdfs:domain ind:DeliveryAttempt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeAtLocationMinutes rdf:type rdf:Property ;
    rdfs:label 'Time At Location Minutes' ;
    rdfs:comment 'Duration in minutes that the delivery agent spent at the delivery location during this attempt. Used for productivity analysis and route optimization.' ;
    rdfs:domain ind:DeliveryAttempt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weatherConditionCode rdf:type rdf:Property ;
    rdfs:label 'Weather Condition Code' ;
    rdfs:comment 'Weather condition at the time of delivery attempt. Used to analyze weather impact on delivery success rates and SLA performance. [ENUM-REF-CANDIDATE: clear|rain|snow|fog|storm|extreme_heat|extreme_cold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeliveryAttempt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentCarrierAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Carrier Assignment Id' ;
    rdfs:comment 'Unique identifier for the carrier assignment record. Primary key for this entity.' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Account Number' ;
    rdfs:comment 'The specific carrier account number or contract identifier under which this shipment is being tendered, used for billing reconciliation and rate application.' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedPickupTimestamp rdf:type rdf:Property ;
    rdfs:label 'Estimated Pickup Timestamp' ;
    rdfs:comment 'The estimated date and time when the carrier is expected to pick up the shipment from the fulfillment center or origin location.' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedTransitTimeHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Transit Time Hours' ;
    rdfs:comment 'The estimated transit time in hours from pickup to delivery as quoted by the carrier or calculated by the TMS at the time of assignment.' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:integrationReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Integration Reference Code' ;
    rdfs:comment 'External reference identifier from the source system or integration layer, used to trace this record back to the originating transaction in SAP TM, Oracle TMS, or other operational systems.' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelGeneratedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Label Generated Timestamp' ;
    rdfs:comment 'The date and time when the shipping label was generated for this carrier assignment. Null if label has not yet been generated.' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:masterTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Master Tracking Number' ;
    rdfs:comment 'The master tracking number or Master Air Waybill (MAWB) / Master Bill of Lading (MBL) number when this shipment is part of a consolidated load. May be null for direct shipments.' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideFlag rdf:type rdf:Property ;
    rdfs:label 'Override Flag' ;
    rdfs:comment 'Boolean indicator of whether this carrier assignment was a manual override of the system-recommended carrier selection, requiring additional justification and audit.' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideReasonCode rdf:type rdf:Property ;
    rdfs:label 'Override Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for manual override of the carrier selection (e.g., customer_request, capacity_constraint, service_failure, cost_exception, regulatory_requirement). Populated only when override_flag is true. [ENUM-REF-CANDIDATE: customer_request|capacity_constraint|service_failure|cost_exception|regulatory_requirement|quality_issue|strategic_partnership — promote to reference product]' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Override Reason Description' ;
    rdfs:comment 'Free-text description providing additional context and justification for the manual override of carrier selection. Populated only when override_flag is true.' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotedRateAmount rdf:type rdf:Property ;
    rdfs:label 'Quoted Rate Amount' ;
    rdfs:comment 'The freight rate amount quoted by the carrier for this shipment at the time of assignment, used for cost estimation and freight audit reconciliation.' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotedRateCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Quoted Rate Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the quoted rate amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectionPriorityScore rdf:type rdf:Property ;
    rdfs:label 'Selection Priority Score' ;
    rdfs:comment 'Numerical score calculated by the carrier selection algorithm representing the priority or ranking of this carrier for this shipment, used for optimization and decision audit.' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:selectionRuleApplied rdf:type rdf:Property ;
    rdfs:label 'Selection Rule Applied' ;
    rdfs:comment 'The specific carrier selection rule or optimization criterion that was applied to choose this carrier (e.g., lowest_cost, fastest_transit, sla_compliant, preferred_carrier, customer_specified, zone_based).' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Compliant Flag' ;
    rdfs:comment 'Boolean indicator of whether the selected carrier and service level are expected to meet the SLA target delivery timestamp based on estimated transit time.' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tenderStatus rdf:type rdf:Property ;
    rdfs:label 'Tender Status' ;
    rdfs:comment 'Status of the carrier tender process indicating whether the shipment has been tendered to the carrier and the carriers response (not tendered, tendered, accepted, rejected).' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenderTimestamp rdf:type rdf:Property ;
    rdfs:label 'Tender Timestamp' ;
    rdfs:comment 'The date and time when the shipment was tendered to the carrier via EDI, API, or manual process. Null if not yet tendered.' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:courierDriverProfileId rdf:type rdf:Property ;
    rdfs:label 'Courier Driver Profile Id' ;
    rdfs:comment 'Foreign key linking to fleet.driver_profile. Business justification: Courier assignment for last-mile dispatch runs requires driver profile validation including license type, HOS compliance status, performance rating, and certification eligibility (hazmat, temperature-' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DriverProfile .

ind:actualDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Actual Distance Km' ;
    rdfs:comment 'The actual total distance traveled in kilometers during this dispatch run, captured from GPS or vehicle telematics.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Minutes' ;
    rdfs:comment 'The actual total duration in minutes for this dispatch run, calculated from dispatch timestamp to return timestamp.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualStopCount rdf:type rdf:Property ;
    rdfs:label 'Actual Stop Count' ;
    rdfs:comment 'The actual number of delivery stops completed during this dispatch run, which may differ from planned due to failed deliveries or route changes.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:codCollectionCount rdf:type rdf:Property ;
    rdfs:label 'Cod Collection Count' ;
    rdfs:comment 'The number of Cash on Delivery transactions collected during this dispatch run.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispatchNotes rdf:type rdf:Property ;
    rdfs:label 'Dispatch Notes' ;
    rdfs:comment 'Free-text operational notes or special instructions for this dispatch run, used for communication between dispatch coordinators and couriers.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchType rdf:type rdf:Property ;
    rdfs:label 'Dispatch Type' ;
    rdfs:comment 'The type or service level of this dispatch run, indicating the delivery speed and priority classification.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epodCaptureCount rdf:type rdf:Property ;
    rdfs:label 'Epod Capture Count' ;
    rdfs:comment 'The number of electronic proof of delivery records captured during this dispatch run, including signatures and photos.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failedDeliveryCount rdf:type rdf:Property ;
    rdfs:label 'Failed Delivery Count' ;
    rdfs:comment 'The number of parcels that could not be delivered during this dispatch run due to recipient unavailability, address issues, or other delivery exceptions.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:manifestReconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Manifest Reconciliation Status' ;
    rdfs:comment 'The status of manifest reconciliation indicating whether all parcels loaded have been accounted for through delivery, return, or exception processing.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Planned Distance Km' ;
    rdfs:comment 'The planned total distance in kilometers for this dispatch run based on route optimization.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Planned Duration Minutes' ;
    rdfs:comment 'The planned total duration in minutes for this dispatch run based on route optimization and historical performance.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedStopCount rdf:type rdf:Property ;
    rdfs:label 'Planned Stop Count' ;
    rdfs:comment 'The number of delivery stops planned for this dispatch run based on route optimization and order allocation.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:returnTimestamp rdf:type rdf:Property ;
    rdfs:label 'Return Timestamp' ;
    rdfs:comment 'The actual date and time when the dispatch run returned to the origin depot or facility, marking the completion of the last-mile delivery route.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:returnedParcelCount rdf:type rdf:Property ;
    rdfs:label 'Returned Parcel Count' ;
    rdfs:comment 'The number of parcels returned to the depot at the end of this dispatch run due to failed delivery attempts or customer refusal.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runDate rdf:type rdf:Property ;
    rdfs:label 'Run Date' ;
    rdfs:comment 'The scheduled date for this dispatch run, representing the business day on which the last-mile delivery route is planned to execute.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:runNumber rdf:type rdf:Property ;
    rdfs:label 'Run Number' ;
    rdfs:comment 'Business-facing unique identifier or manifest number for the dispatch run, used for operational tracking and carrier handover documentation.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runStatus rdf:type rdf:Property ;
    rdfs:label 'Run Status' ;
    rdfs:comment 'Current lifecycle status of the dispatch run indicating its operational state in the last-mile delivery workflow.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetCompletionTime rdf:type rdf:Property ;
    rdfs:label 'Sla Target Completion Time' ;
    rdfs:comment 'The target completion timestamp for this dispatch run based on service level agreements and operational commitments.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalParcelsDelivered rdf:type rdf:Property ;
    rdfs:label 'Total Parcels Delivered' ;
    rdfs:comment 'The total number of parcels successfully delivered during this dispatch run, representing successful last-mile completions.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalParcelsLoaded rdf:type rdf:Property ;
    rdfs:label 'Total Parcels Loaded' ;
    rdfs:comment 'The total number of parcels loaded onto the vehicle or assigned to the courier for this dispatch run at departure.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vehicleUtilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Vehicle Utilization Percentage' ;
    rdfs:comment 'The percentage of vehicle capacity utilized by this dispatch run, calculated based on weight, volume, or parcel count constraints.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnCarrierId rdf:type rdf:Property ;
    rdfs:label 'Return Carrier Id' ;
    rdfs:comment 'Foreign key linking to network.carrier. Business justification: Returns are shipped via carriers. Business process: reverse logistics carrier selection, return carrier performance tracking, return shipping cost allocation. Role-prefixed to distinguish from potenti' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:returnConsignmentId rdf:type rdf:Property ;
    rdfs:label 'Return Consignment Id' ;
    rdfs:comment 'Foreign key linking to shipment.consignment. Business justification: An RMA generates a return consignment for physical goods movement back to the warehouse. Linking rma to the return consignment enables return shipment tracking, customs documentation for returned good' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Consignment .

ind:returnCustomsDeclarationId rdf:type rdf:Property ;
    rdfs:label 'Return Customs Declaration Id' ;
    rdfs:comment 'Foreign key linking to customs.declaration. Business justification: International returns require customs declarations for re-import processing. Supports reverse logistics customs clearance tracking, duty drawback claims, and RMA processing timelines that depend on cu' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Declaration .

ind:returnHsClassificationId rdf:type rdf:Property ;
    rdfs:label 'Return Hs Classification Id' ;
    rdfs:comment 'Foreign key linking to customs.hs_classification. Business justification: Returns of imported goods require HS classification for duty drawback claims, re-export declarations, and customs valuation. Enables automated return customs documentation generation, duty recovery pr' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HsClassification .

ind:returnParcelId rdf:type rdf:Property ;
    rdfs:label 'Return Parcel Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.parcel. Business justification: An RMA (Return Merchandise Authorization) involves the physical return of goods in a parcel. The rma table has return_tracking_number (a string) but no FK to the parcel entity that represents the retu' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Parcel .

ind:returnRateCardId rdf:type rdf:Property ;
    rdfs:label 'Return Rate Card Id' ;
    rdfs:comment 'Foreign key linking to pricing.rate_card. Business justification: RMAs require rate card reference for return shipping cost calculation, customer refund amount determination, restocking fee application, and reverse logistics billing in returns management operations.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateCard .

ind:vendorSupplierId rdf:type rdf:Property ;
    rdfs:label 'Vendor Supplier Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier. Business justification: RMA processing may involve supplier coordination for defective goods, warranty claims, or vendor returns. Enables vendor return authorization tracking and supplier quality issue escalation.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:actualReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Actual Receipt Date' ;
    rdfs:comment 'Actual date when the returned merchandise was physically received at the return processing facility. Nullable if not yet received.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualReceiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Receipt Timestamp' ;
    rdfs:comment 'Precise date and time when the returned merchandise was scanned into the warehouse management system upon receipt.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:conditionAssessmentCode rdf:type rdf:Property ;
    rdfs:label 'Condition Assessment Code' ;
    rdfs:comment 'Assessment of the physical condition of the returned merchandise upon inspection. Determines disposition and restocking eligibility.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionAssessmentNotes rdf:type rdf:Property ;
    rdfs:label 'Condition Assessment Notes' ;
    rdfs:comment 'Free-text notes from the warehouse inspector describing the condition of the returned merchandise in detail.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionInstruction rdf:type rdf:Property ;
    rdfs:label 'Disposition Instruction' ;
    rdfs:comment 'Instruction for how the returned merchandise should be handled. Determines the next step in the reverse logistics workflow. [ENUM-REF-CANDIDATE: restock|destroy|return_to_merchant|liquidate|donate|repair|quarantine — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedReturnDate rdf:type rdf:Property ;
    rdfs:label 'Expected Return Date' ;
    rdfs:comment 'Estimated date when the returned merchandise is expected to arrive at the return processing facility or merchant location.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalRmaReference rdf:type rdf:Property ;
    rdfs:label 'External Rma Reference' ;
    rdfs:comment 'External reference number from the merchant or e-commerce platform system. Used for cross-system reconciliation.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Merchant Approved Flag' ;
    rdfs:comment 'Indicates whether the merchant has approved the return request. True if approved, False if rejected or pending.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refundAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Amount' ;
    rdfs:comment 'Monetary amount to be refunded to the customer or credited to the merchant. May differ from original order value based on restocking fees or partial returns.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Refund Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the refund amount. Examples: USD, EUR, GBP.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundMethod rdf:type rdf:Property ;
    rdfs:label 'Refund Method' ;
    rdfs:comment 'Method by which the refund will be issued to the customer. Typically matches the original payment method.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundProcessedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Refund Processed Timestamp' ;
    rdfs:comment 'Date and time when the refund was successfully processed and funds were released. Nullable if refund not yet processed.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:refundTriggerStatus rdf:type rdf:Property ;
    rdfs:label 'Refund Trigger Status' ;
    rdfs:comment 'Status of the refund or credit process triggered by this RMA. Tracks whether financial settlement has been initiated and completed.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Timestamp' ;
    rdfs:comment 'Date and time when the customer or merchant initiated the return request. Marks the beginning of the RMA lifecycle.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:restockedFlag rdf:type rdf:Property ;
    rdfs:label 'Restocked Flag' ;
    rdfs:comment 'Indicates whether the returned merchandise has been restocked into sellable inventory. True if restocked, False otherwise.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restockedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Restocked Timestamp' ;
    rdfs:comment 'Date and time when the returned merchandise was restocked into inventory. Nullable if not restocked.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:restockingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Restocking Fee Amount' ;
    rdfs:comment 'Fee charged to the customer or merchant for processing the return. Deducted from the refund amount.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnLabelGeneratedFlag rdf:type rdf:Property ;
    rdfs:label 'Return Label Generated Flag' ;
    rdfs:comment 'Indicates whether a return shipping label has been generated for the customer. True if label has been created and provided to the customer.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnLabelGeneratedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Return Label Generated Timestamp' ;
    rdfs:comment 'Date and time when the return shipping label was generated. Nullable if label has not yet been created.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:returnPolicyCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Return Policy Compliant Flag' ;
    rdfs:comment 'Indicates whether the return request complies with the applicable return policy terms. True if compliant, False if exception or policy violation.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Return Reason Description' ;
    rdfs:comment 'Free-text description providing additional details about the reason for the return. Captures customer or merchant comments.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnServiceLevel rdf:type rdf:Property ;
    rdfs:label 'Return Service Level' ;
    rdfs:comment 'Service level selected for the return shipment. Determines transit time and cost for the return.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnWarehouseLocationCode rdf:type rdf:Property ;
    rdfs:label 'Return Warehouse Location Code' ;
    rdfs:comment 'Code identifying the warehouse or return processing center where the merchandise was received. Links to facility master data.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnWindowDays rdf:type rdf:Property ;
    rdfs:label 'Return Window Days' ;
    rdfs:comment 'Number of days from original delivery within which the return was initiated. Used to validate compliance with return policy.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rmaStatus rdf:type rdf:Property ;
    rdfs:label 'Rma Status' ;
    rdfs:comment 'Current lifecycle status of the return authorization. Tracks the return from initial request through final disposition. [ENUM-REF-CANDIDATE: requested|approved|rejected|label_generated|in_transit|received|inspected|completed|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetProcessingDays rdf:type rdf:Property ;
    rdfs:label 'Sla Target Processing Days' ;
    rdfs:comment 'Target number of days within which the return should be processed from receipt to disposition. Defined by service level agreement.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierServiceLevel rdf:type rdf:Property ;
    rdfs:label 'Carrier Service Level' ;
    rdfs:comment 'Service level selected for delivery (e.g., express, standard, economy, same-day).' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemQuantityPacked rdf:type rdf:Property ;
    rdfs:label 'Item Quantity Packed' ;
    rdfs:comment 'Total number of individual items or Stock Keeping Units packed into this parcel.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Pack Duration Seconds' ;
    rdfs:comment 'Total time in seconds taken to complete the pack task, calculated from start to completion timestamp.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packMethod rdf:type rdf:Property ;
    rdfs:label 'Pack Method' ;
    rdfs:comment 'Method used for packing: manual by employee, semi-automated with assistance, fully automated, or robotic.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packStationCode rdf:type rdf:Property ;
    rdfs:label 'Pack Station Code' ;
    rdfs:comment 'Identifier of the physical pack station or workstation where the packing activity occurred.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packTaskNumber rdf:type rdf:Property ;
    rdfs:label 'Pack Task Number' ;
    rdfs:comment 'Human-readable business identifier for the pack task, typically system-generated or barcode-scanned.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packTaskStatus rdf:type rdf:Property ;
    rdfs:label 'Pack Task Status' ;
    rdfs:comment 'Current lifecycle status of the pack task in the warehouse management system workflow.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packZoneCode rdf:type rdf:Property ;
    rdfs:label 'Pack Zone Code' ;
    rdfs:comment 'Code identifying the specific packing zone or area within the warehouse.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingMaterialCode rdf:type rdf:Property ;
    rdfs:label 'Packaging Material Code' ;
    rdfs:comment 'Code identifying the type of packaging material used (box, envelope, poly mailer, etc.).' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingMaterialSku rdf:type rdf:Property ;
    rdfs:label 'Packaging Material Sku' ;
    rdfs:comment 'Stock Keeping Unit identifier for the specific packaging material used from inventory.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingSlipIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Packing Slip Included Flag' ;
    rdfs:comment 'Boolean indicator whether a packing slip or invoice document was included in the parcel.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parcelWeightKg rdf:type rdf:Property ;
    rdfs:label 'Parcel Weight Kg' ;
    rdfs:comment 'Actual weight of the packed parcel measured at the pack station in kilograms.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityCheckPassedFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Check Passed Flag' ;
    rdfs:comment 'Boolean indicator whether the packed parcel passed the quality inspection criteria.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityCheckPerformedFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Check Performed Flag' ;
    rdfs:comment 'Boolean indicator whether a quality inspection was performed on the packed parcel before dispatch.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnLabelIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Return Label Included Flag' ;
    rdfs:comment 'Boolean indicator whether a prepaid return label was included in the parcel for Return Merchandise Authorization.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shippingLabelNumber rdf:type rdf:Property ;
    rdfs:label 'Shipping Label Number' ;
    rdfs:comment 'Tracking number or barcode printed on the shipping label for carrier scanning and tracking.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingLabelPrintedFlag rdf:type rdf:Property ;
    rdfs:label 'Shipping Label Printed Flag' ;
    rdfs:comment 'Boolean indicator whether the shipping label was successfully printed at the pack station.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:voidFillType rdf:type rdf:Property ;
    rdfs:label 'Void Fill Type' ;
    rdfs:comment 'Type of void fill or cushioning material used to protect items during transit.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiKeyHash rdf:type rdf:Property ;
    rdfs:label 'Api Key Hash' ;
    rdfs:comment 'Hashed API authentication key for merchants using API integration channel. Stored as hash for security; actual key provided to merchant separately.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageDailyOrderVolume rdf:type rdf:Property ;
    rdfs:label 'Average Daily Order Volume' ;
    rdfs:comment 'The merchant\'s average number of fulfillment orders processed per day, used for capacity planning and service tier assignment.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Business Address Line1' ;
    rdfs:comment 'First line of the merchant\'s registered business address including street number and street name.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Business Address Line2' ;
    rdfs:comment 'Second line of the merchant\'s business address for additional address details such as suite, floor, or building name.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessCity rdf:type rdf:Property ;
    rdfs:label 'Business City' ;
    rdfs:comment 'City or municipality of the merchant\'s registered business address.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessCountryCode rdf:type rdf:Property ;
    rdfs:label 'Business Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the merchant\'s business address country.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessPostalCode rdf:type rdf:Property ;
    rdfs:label 'Business Postal Code' ;
    rdfs:comment 'Postal code or ZIP code of the merchant\'s business address.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessStateProvince rdf:type rdf:Property ;
    rdfs:label 'Business State Province' ;
    rdfs:comment 'State, province, or administrative region of the merchant\'s business address.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Cod Enabled Flag' ;
    rdfs:comment 'Indicates whether the merchant is enabled for COD (Cash on Delivery) payment collection at the point of delivery. True if COD is available for this merchant\'s orders.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'The scheduled end date of the merchant\'s fulfillment services contract. Null for open-ended or evergreen contracts.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'The effective start date of the merchant\'s fulfillment services contract with Transport Shipping.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'Maximum credit limit extended to the merchant for fulfillment services before payment is required. Used for financial risk management.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditLimitCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the credit limit amount.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBrokerRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Broker Required Flag' ;
    rdfs:comment 'Indicates whether the merchant\'s shipments require customs brokerage services for cross-border fulfillment. True if customs broker assignment is mandatory.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defaultServiceLevel rdf:type rdf:Property ;
    rdfs:label 'Default Service Level' ;
    rdfs:comment 'The default delivery service level applied to merchant orders unless otherwise specified: standard (3-5 days), express (1-2 days), same_day, next_day, economy (5-7 days).' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediIdentifier rdf:type rdf:Property ;
    rdfs:label 'Edi Identifier' ;
    rdfs:comment 'Unique EDI interchange identifier (ISA ID) assigned to the merchant for EDI transaction routing and acknowledgment.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationChannel rdf:type rdf:Property ;
    rdfs:label 'Integration Channel' ;
    rdfs:comment 'The technical channel through which the merchant integrates with Transport Shipping fulfillment systems: EDI (Electronic Data Interchange), API (Application Programming Interface), portal (web-based), SFTP (Secure File Transfer Protocol), or manual entry.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantCode rdf:type rdf:Property ;
    rdfs:label 'Merchant Code' ;
    rdfs:comment 'Externally-facing unique alphanumeric code assigned to the merchant for identification in fulfillment operations, manifests, and integration channels.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantStatus rdf:type rdf:Property ;
    rdfs:label 'Merchant Status' ;
    rdfs:comment 'Current lifecycle status of the merchant relationship: active (operational), inactive (temporarily paused), suspended (compliance hold), onboarding (setup in progress), terminated (contract ended).' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantTier rdf:type rdf:Property ;
    rdfs:label 'Merchant Tier' ;
    rdfs:comment 'Classification of merchant based on business size and volume: enterprise (large corporate), SME (small-medium enterprise), marketplace (multi-vendor platform), startup (emerging business).' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peakSeasonMultiplier rdf:type rdf:Property ;
    rdfs:label 'Peak Season Multiplier' ;
    rdfs:comment 'Multiplier factor representing the merchant\'s order volume increase during peak seasons (e.g., 2.5 means 250% of average volume). Used for capacity forecasting.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformType rdf:type rdf:Property ;
    rdfs:label 'Platform Type' ;
    rdfs:comment 'The e-commerce platform technology used by the merchant to manage their online store and order processing. [ENUM-REF-CANDIDATE: shopify|magento|woocommerce|custom|sap_commerce|salesforce_commerce|bigcommerce — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnsEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Returns Enabled Flag' ;
    rdfs:comment 'Indicates whether the merchant has returns processing (RMA - Return Merchandise Authorization) enabled through Transport Shipping fulfillment services.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnsPolicyCode rdf:type rdf:Property ;
    rdfs:label 'Returns Policy Code' ;
    rdfs:comment 'Reference code to the merchant\'s returns policy configuration defining return windows, conditions, and processing rules.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Termination Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for merchant relationship termination: contract_expiry, mutual_agreement, breach (contract violation), non_payment, business_closure, migration (moved to another provider).' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantIntegrationId rdf:type rdf:Property ;
    rdfs:label 'Merchant Integration Id' ;
    rdfs:comment 'Unique identifier for the merchant integration configuration record. Primary key.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'Date when the integration channel was first activated and began processing live transactions.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:apiEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Api Endpoint Url' ;
    rdfs:comment 'Base URL or endpoint address for REST/SOAP API integration. Contains the target server address for API calls.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiVersion rdf:type rdf:Property ;
    rdfs:label 'Api Version' ;
    rdfs:comment 'Version identifier of the API specification being used (e.g., v1, v2.1, 2023-Q4). Ensures compatibility between systems.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationCredential rdf:type rdf:Property ;
    rdfs:label 'Authentication Credential' ;
    rdfs:comment 'Encrypted or hashed authentication credential (API key, token, certificate reference) used to authenticate with the merchant platform. Stored securely.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationMethod rdf:type rdf:Property ;
    rdfs:label 'Authentication Method' ;
    rdfs:comment 'Security authentication mechanism used to establish identity and authorize access to the integration endpoint.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageResponseTimeMs rdf:type rdf:Property ;
    rdfs:label 'Average Response Time Ms' ;
    rdfs:comment 'Average response time in milliseconds for API calls or message exchanges through this integration channel. Performance metric.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:batchProcessingEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Batch Processing Enabled Flag' ;
    rdfs:comment 'Indicates whether messages are processed in batches rather than individually. Improves throughput for high-volume integrations.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:batchSizeLimit rdf:type rdf:Property ;
    rdfs:label 'Batch Size Limit' ;
    rdfs:comment 'Maximum number of messages or records that can be included in a single batch transmission. Applicable when batch processing is enabled.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compressionEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Compression Enabled Flag' ;
    rdfs:comment 'Indicates whether message payloads are compressed before transmission to reduce bandwidth usage.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cumulativeErrorCount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Error Count' ;
    rdfs:comment 'Total number of integration errors or failures since activation. Used for reliability metrics and trend analysis.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataEncryptionEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Data Encryption Enabled Flag' ;
    rdfs:comment 'Indicates whether data transmitted through this integration channel is encrypted in transit (TLS/SSL).' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Date when the integration channel was deactivated or suspended. Null if currently active.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ediQualifier rdf:type rdf:Property ;
    rdfs:label 'Edi Qualifier' ;
    rdfs:comment 'EDI interchange ID qualifier code identifying the type of sender/receiver identifier (e.g., ZZ for mutually defined, 01 for DUNS number). Used in ISA segment.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTransactionSet rdf:type rdf:Property ;
    rdfs:label 'Edi Transaction Set' ;
    rdfs:comment 'Comma-separated list of supported EDI transaction set codes (e.g., 204 for Motor Carrier Load Tender, 856 for Advanced Shipping Notice, 997 for Functional Acknowledgment). Applicable only when integration_type is EDI.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorCount24h rdf:type rdf:Property ;
    rdfs:label 'Error Count 24h' ;
    rdfs:comment 'Number of integration errors or failed synchronization attempts in the last 24 hours. Used for health monitoring and alerting.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:integrationName rdf:type rdf:Property ;
    rdfs:label 'Integration Name' ;
    rdfs:comment 'Business-friendly name or label for this integration channel, used for identification and reporting purposes.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationStatus rdf:type rdf:Property ;
    rdfs:label 'Integration Status' ;
    rdfs:comment 'Current operational status of the integration channel. Determines whether messages are processed or queued.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationType rdf:type rdf:Property ;
    rdfs:label 'Integration Type' ;
    rdfs:comment 'Technical protocol or method used for data exchange with the merchant platform. Determines message format and connectivity requirements.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastErrorCode rdf:type rdf:Property ;
    rdfs:label 'Last Error Code' ;
    rdfs:comment 'Error code or identifier for the most recent integration failure. Used for diagnostics and root cause analysis.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastErrorMessage rdf:type rdf:Property ;
    rdfs:label 'Last Error Message' ;
    rdfs:comment 'Detailed error message or description for the most recent integration failure. Provides context for troubleshooting.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastErrorTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Error Timestamp' ;
    rdfs:comment 'Timestamp when the most recent integration error or failure occurred.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastSuccessfulSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Successful Sync Timestamp' ;
    rdfs:comment 'Timestamp of the most recent successful data synchronization or message exchange through this integration channel.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastSyncAttemptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Sync Attempt Timestamp' ;
    rdfs:comment 'Timestamp of the most recent synchronization attempt, regardless of success or failure. Used for monitoring and troubleshooting.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxRetryAttempts rdf:type rdf:Property ;
    rdfs:label 'Max Retry Attempts' ;
    rdfs:comment 'Maximum number of automatic retry attempts for failed synchronization before escalating to manual intervention.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:messageFormat rdf:type rdf:Property ;
    rdfs:label 'Message Format' ;
    rdfs:comment 'Data serialization format used for message payloads exchanged through this integration channel.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageFormatVersion rdf:type rdf:Property ;
    rdfs:label 'Message Format Version' ;
    rdfs:comment 'Version identifier of the message format specification or schema being used (e.g., 1.0, 4010 for EDI X12).' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pollingFrequencyMinutes rdf:type rdf:Property ;
    rdfs:label 'Polling Frequency Minutes' ;
    rdfs:comment 'Interval in minutes at which the system polls or checks the integration endpoint for new messages or data. Null for push-based integrations.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateLimitRequestsPerMinute rdf:type rdf:Property ;
    rdfs:label 'Rate Limit Requests Per Minute' ;
    rdfs:comment 'Maximum number of API requests or message transmissions allowed per minute. Prevents overloading the merchant platform.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retryPolicy rdf:type rdf:Property ;
    rdfs:label 'Retry Policy' ;
    rdfs:comment 'Strategy for retrying failed integration attempts. Defines timing and behavior for automatic retry logic.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sftpDirectoryPath rdf:type rdf:Property ;
    rdfs:label 'Sftp Directory Path' ;
    rdfs:comment 'Remote directory path on SFTP server where files are exchanged (inbound and outbound).' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sftpHost rdf:type rdf:Property ;
    rdfs:label 'Sftp Host' ;
    rdfs:comment 'SFTP server hostname or IP address for file-based integration. Applicable when integration_type is SFTP.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sftpPort rdf:type rdf:Property ;
    rdfs:label 'Sftp Port' ;
    rdfs:comment 'TCP port number for SFTP connection. Standard port is 22.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:successRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Success Rate Percentage' ;
    rdfs:comment 'Percentage of successful synchronization attempts over a defined measurement period. Key performance indicator for integration reliability.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportedTransactionTypes rdf:type rdf:Property ;
    rdfs:label 'Supported Transaction Types' ;
    rdfs:comment 'Comma-separated list of business transaction types supported by this integration (e.g., ORDER_INGEST, ASN_OUTBOUND, SHIPMENT_STATUS, INVENTORY_SYNC, RMA_NOTIFICATION).' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeoutThresholdSeconds rdf:type rdf:Property ;
    rdfs:label 'Timeout Threshold Seconds' ;
    rdfs:comment 'Maximum time in seconds to wait for a response from the integration endpoint before timing out and marking the attempt as failed.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:webhookCallbackUrl rdf:type rdf:Property ;
    rdfs:label 'Webhook Callback Url' ;
    rdfs:comment 'URL endpoint on the fulfillment platform that receives push notifications from the merchant system. Applicable when integration_type is WEBHOOK.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Address Validation Status' ;
    rdfs:comment 'Status of address validation process: validated (confirmed accurate), unvalidated (not yet checked), corrected (modified by validation service), or failed (could not be validated).' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternateContactPhone rdf:type rdf:Property ;
    rdfs:label 'Alternate Contact Phone' ;
    rdfs:comment 'Secondary contact phone number for the consignee. Used when primary contact is unavailable or for escalation during delivery attempts.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blacklistFlag rdf:type rdf:Property ;
    rdfs:label 'Blacklist Flag' ;
    rdfs:comment 'Indicates whether this consignee is blacklisted due to fraud, repeated delivery failures, abusive behavior, or security concerns. True if blacklisted, false otherwise.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blacklistReason rdf:type rdf:Property ;
    rdfs:label 'Blacklist Reason' ;
    rdfs:comment 'Explanation of why the consignee was blacklisted (e.g., fraud, repeated refusal to accept delivery, security threat, denied party screening match).' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessHoursEnd rdf:type rdf:Property ;
    rdfs:label 'Business Hours End' ;
    rdfs:comment 'End time of business hours for commercial consignees in HH:MM format (24-hour clock). Used for scheduling delivery attempts during operating hours.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessHoursStart rdf:type rdf:Property ;
    rdfs:label 'Business Hours Start' ;
    rdfs:comment 'Start time of business hours for commercial consignees in HH:MM format (24-hour clock). Used for scheduling delivery attempts during operating hours.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Cod Eligible Flag' ;
    rdfs:comment 'Indicates whether this consignee is eligible to receive COD (Cash on Delivery) shipments. True if COD is permitted, false if COD is restricted due to payment history or risk assessment.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:codPaymentMethodPreference rdf:type rdf:Property ;
    rdfs:label 'Cod Payment Method Preference' ;
    rdfs:comment 'Preferred payment method for COD (Cash on Delivery) collections: cash, card (credit/debit), mobile_payment (digital wallet), or bank_transfer.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsIdNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Id Number' ;
    rdfs:comment 'Customs-specific identifier for the consignee (e.g., importer of record number, customs registration number). Used for cross-border shipments and customs declarations.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPreferenceLeaveAtDoor rdf:type rdf:Property ;
    rdfs:label 'Delivery Preference Leave At Door' ;
    rdfs:comment 'Indicates whether the consignee permits unattended delivery at the door. True if leave-at-door is acceptable, false if recipient presence is required.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryPreferenceNeighborDelivery rdf:type rdf:Property ;
    rdfs:label 'Delivery Preference Neighbor Delivery' ;
    rdfs:comment 'Indicates whether the consignee permits delivery to a neighbor if the primary recipient is unavailable. True if neighbor delivery is acceptable.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryPreferenceSafePlace rdf:type rdf:Property ;
    rdfs:label 'Delivery Preference Safe Place' ;
    rdfs:comment 'Free-text instructions specifying a safe place to leave the parcel if the consignee is not present (e.g., back porch, garage, with building concierge).' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPreferenceSignatureRequired rdf:type rdf:Property ;
    rdfs:label 'Delivery Preference Signature Required' ;
    rdfs:comment 'Indicates whether the consignee requires a signature for delivery confirmation. True if signature is mandatory, false if signature can be waived.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryTimeWindowPreference rdf:type rdf:Property ;
    rdfs:label 'Delivery Time Window Preference' ;
    rdfs:comment 'Preferred time window for delivery attempts: morning (before noon), afternoon (noon to 5pm), evening (after 5pm), business_hours (9am-5pm weekdays), or anytime (no preference).' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failedDeliveryHistoryFlag rdf:type rdf:Property ;
    rdfs:label 'Failed Delivery History Flag' ;
    rdfs:comment 'Indicates whether this consignee has a history of failed delivery attempts. True if previous deliveries have failed, false otherwise. Used for risk assessment and route planning.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geocodeAccuracy rdf:type rdf:Property ;
    rdfs:label 'Geocode Accuracy' ;
    rdfs:comment 'Precision level of the geocoded coordinates: rooftop (exact building), street (street-level), postal_code (postal code centroid), city (city centroid), or region (regional approximation).' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geocodeLatitude rdf:type rdf:Property ;
    rdfs:label 'Geocode Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the delivery address in decimal degrees. Used for route optimization and GPS (Global Positioning System) navigation.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geocodeLongitude rdf:type rdf:Property ;
    rdfs:label 'Geocode Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the delivery address in decimal degrees. Used for route optimization and GPS (Global Positioning System) navigation.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'Two-letter ISO language code for the consignee\'s preferred communication language (e.g., en, es, fr, de, zh). Used for delivery notifications and customer communications.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationPreferenceEmail rdf:type rdf:Property ;
    rdfs:label 'Notification Preference Email' ;
    rdfs:comment 'Indicates whether the consignee has opted in to receive delivery notifications via email. True if email notifications are enabled.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationPreferencePush rdf:type rdf:Property ;
    rdfs:label 'Notification Preference Push' ;
    rdfs:comment 'Indicates whether the consignee has opted in to receive delivery notifications via mobile app push notifications. True if push notifications are enabled.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationPreferenceSms rdf:type rdf:Property ;
    rdfs:label 'Notification Preference Sms' ;
    rdfs:comment 'Indicates whether the consignee has opted in to receive delivery notifications via SMS text message. True if SMS notifications are enabled.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residentialCommercialIndicator rdf:type rdf:Property ;
    rdfs:label 'Residential Commercial Indicator' ;
    rdfs:comment 'Classification of the delivery location as residential (home address), commercial (business address), or mixed_use (building with both residential and commercial units). Affects delivery routing and surcharges.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:centerId rdf:type rdf:Property ;
    rdfs:label 'Center Id' ;
    rdfs:comment 'Primary key for center' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Center .

ind:mroSupplierId rdf:type rdf:Property ;
    rdfs:label 'Mro Supplier Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier. Business justification: Fulfillment centers procure MRO supplies, equipment, and consumables from suppliers. Tracks primary supplier relationship for facility operations, enabling spend analysis and supplier performance mana' ;
    rdfs:domain ind:Center ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:operatorTradePartyId rdf:type rdf:Property ;
    rdfs:label 'Operator Trade Party Id' ;
    rdfs:comment 'Foreign key linking to customs.trade_party. Business justification: Fulfillment centers operating as importers/exporters, bonded warehouses, or FTZ operators are registered trade parties. Enables facility-level customs compliance tracking, AEO certification management' ;
    rdfs:domain ind:Center ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeParty .

ind:servicingDepotId rdf:type rdf:Property ;
    rdfs:label 'Servicing Depot Id' ;
    rdfs:comment 'Foreign key linking to fleet.depot. Business justification: Fulfillment centers are operationally served by a fleet depot for vehicle staging, dispatch, and returns. This FK enables fleet capacity planning relative to fulfillment throughput and is a standard o' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:annualThroughputCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Annual Throughput Capacity Units' ;
    rdfs:comment 'Maximum annual throughput capacity of the fulfillment center measured in units (SKUs) that can be processed per year, representing operational capacity for planning purposes.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:automationLevel rdf:type rdf:Property ;
    rdfs:label 'Automation Level' ;
    rdfs:comment 'Classification of the degree of automation deployed in the fulfillment center operations, ranging from manual labor-intensive to fully robotic systems.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBondedWarehouseFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Bonded Warehouse Flag' ;
    rdfs:comment 'Indicates whether the fulfillment center operates as a customs bonded warehouse, allowing storage of imported goods before customs duties are paid.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goLiveDate rdf:type rdf:Property ;
    rdfs:label 'Go Live Date' ;
    rdfs:comment 'Date when the fulfillment center commenced operational activities and began processing orders.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hazmatCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified Flag' ;
    rdfs:comment 'Indicates whether the fulfillment center is certified to handle and store hazardous materials according to IMDG, IATA, and local regulations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborWorkforceSize rdf:type rdf:Property ;
    rdfs:label 'Labor Workforce Size' ;
    rdfs:comment 'Total workforce size at the fulfillment center measured in Full-Time Equivalent (FTE) employees, including permanent and temporary staff.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastMileZoneCoverage rdf:type rdf:Property ;
    rdfs:label 'Last Mile Zone Coverage' ;
    rdfs:comment 'Comma-separated list of last-mile delivery zone codes or postal code prefixes that this fulfillment center serves, defining its geographic service area for direct delivery.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiry Date' ;
    rdfs:comment 'Date when the lease agreement for the fulfillment center facility expires, applicable for leased or 3PL/4PL facilities. Null for owned facilities.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingDaysPerWeek rdf:type rdf:Property ;
    rdfs:label 'Operating Days Per Week' ;
    rdfs:comment 'Number of days per week the fulfillment center operates, typically ranging from 5 (weekdays only) to 7 (continuous operations).' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:palletPositions rdf:type rdf:Property ;
    rdfs:label 'Pallet Positions' ;
    rdfs:comment 'Total number of pallet storage positions available in the fulfillment center, representing discrete storage locations for palletized inventory.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:peakDailyOrderCapacity rdf:type rdf:Property ;
    rdfs:label 'Peak Daily Order Capacity' ;
    rdfs:comment 'Maximum number of orders the fulfillment center can process in a single day during peak periods, used for capacity planning and load balancing.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityCertification rdf:type rdf:Property ;
    rdfs:label 'Quality Certification' ;
    rdfs:comment 'Quality management certifications held by the fulfillment center (e.g., ISO 9001, Six Sigma), demonstrating adherence to quality standards. [ENUM-REF-CANDIDATE: iso_9001|six_sigma|lean|tqm|gmp|haccp|brc — promote to reference product]' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityCertification rdf:type rdf:Property ;
    rdfs:label 'Security Certification' ;
    rdfs:comment 'Security certifications held by the fulfillment center (e.g., C-TPAT, AEO, ISO 28000), demonstrating compliance with supply chain security standards. [ENUM-REF-CANDIDATE: c_tpat|aeo|iso_28000|tapa_a|tapa_b|tapa_c|pip — promote to reference product]' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedServiceTypes rdf:type rdf:Property ;
    rdfs:label 'Supported Service Types' ;
    rdfs:comment 'Comma-separated list of service types supported by this fulfillment center (e.g., standard_delivery, express_delivery, same_day, next_day, cod, returns_processing). [ENUM-REF-CANDIDATE: standard_delivery|express_delivery|same_day|next_day|two_day|cod|returns_processing|gift_wrapping|kitting — promote to reference product]' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityCertification rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certification' ;
    rdfs:comment 'Environmental and sustainability certifications held by the fulfillment center (e.g., LEED, ISO 14001, carbon neutral), demonstrating commitment to environmental responsibility.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wmsSystemCode rdf:type rdf:Property ;
    rdfs:label 'Wms System Code' ;
    rdfs:comment 'Identifier for the WMS system instance deployed at this fulfillment center. Used to route integration messages and identify the source system for inventory and order data.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hubFulfillmentCenterId rdf:type rdf:Property ;
    rdfs:label 'Hub Fulfillment Center Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.center. Business justification: Delivery zones are served by specific fulfillment centers (hubs). The hub_location_code STRING should be normalized to FK referencing center.fulfillment_center_id. This enables proper zone-to-hub assi' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Center .

ind:averageDeliveryAttempts rdf:type rdf:Property ;
    rdfs:label 'Average Delivery Attempts' ;
    rdfs:comment 'Historical average number of delivery attempts required to successfully complete deliveries in this zone. Used for operational planning.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierCoverageLevel rdf:type rdf:Property ;
    rdfs:label 'Carrier Coverage Level' ;
    rdfs:comment 'Level of carrier network coverage available in this zone. Affects service availability and delivery reliability.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codServiceAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Cod Service Available Flag' ;
    rdfs:comment 'Indicates whether Cash on Delivery (COD) service is available for deliveries in this zone based on carrier capabilities and risk assessment.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryCutoffTime rdf:type rdf:Property ;
    rdfs:label 'Delivery Cutoff Time' ;
    rdfs:comment 'Local time cutoff for same-day or next-day delivery eligibility in this zone. Format HH:MM in 24-hour notation.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:epodRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Epod Required Flag' ;
    rdfs:comment 'Indicates whether electronic Proof of Delivery (ePOD) capture is mandatory for deliveries in this zone.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expressTransitDays rdf:type rdf:Property ;
    rdfs:label 'Express Transit Days' ;
    rdfs:comment 'Number of business days for express delivery service to this zone from the fulfillment center. Used for expedited SLA promise calculation.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelSurchargeApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Applicable Flag' ;
    rdfs:comment 'Indicates whether fuel surcharge (Bunker Adjustment Factor - BAF) applies to shipments in this zone.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holidayDeliveryAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Holiday Delivery Available Flag' ;
    rdfs:comment 'Indicates whether delivery service is available on public holidays in this zone.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxParcelDimensionsCm rdf:type rdf:Property ;
    rdfs:label 'Max Parcel Dimensions Cm' ;
    rdfs:comment 'Maximum parcel dimensions (length x width x height) in centimeters that can be delivered to this zone. Format: LxWxH.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxParcelWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Parcel Weight Kg' ;
    rdfs:comment 'Maximum parcel weight in kilograms that can be delivered to this zone based on carrier and infrastructure constraints.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextDayEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Next Day Eligible Flag' ;
    rdfs:comment 'Indicates whether this zone is eligible for next-day delivery service based on cutoff times and carrier network coverage.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remoteAreaSurchargeFlag rdf:type rdf:Property ;
    rdfs:label 'Remote Area Surcharge Flag' ;
    rdfs:comment 'Indicates whether a remote area surcharge applies to deliveries in this zone due to distance or accessibility constraints.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residentialSurchargeFlag rdf:type rdf:Property ;
    rdfs:label 'Residential Surcharge Flag' ;
    rdfs:comment 'Indicates whether residential delivery surcharge applies to addresses in this zone.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictedGoodsAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Restricted Goods Allowed Flag' ;
    rdfs:comment 'Indicates whether restricted or regulated goods (e.g., hazardous materials, alcohol, pharmaceuticals) can be delivered to this zone based on local regulations.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sameDayEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Same Day Eligible Flag' ;
    rdfs:comment 'Indicates whether this zone is eligible for same-day delivery service based on proximity to fulfillment centers and carrier availability.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceableFlag rdf:type rdf:Property ;
    rdfs:label 'Serviceable Flag' ;
    rdfs:comment 'Indicates whether this delivery zone is currently serviceable for deliveries. False indicates zone is temporarily or permanently out of service.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeZoneCode rdf:type rdf:Property ;
    rdfs:label 'Time Zone Code' ;
    rdfs:comment 'IANA time zone identifier for this delivery zone. Used for scheduling delivery windows and cutoff time calculations.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weekendDeliveryAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Weekend Delivery Available Flag' ;
    rdfs:comment 'Indicates whether Saturday and Sunday delivery service is available in this zone.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:zoneCentroidLatitude rdf:type rdf:Property ;
    rdfs:label 'Zone Centroid Latitude' ;
    rdfs:comment 'Latitude coordinate of the geographic centroid of the delivery zone. Used for distance calculations and route optimization.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zoneCentroidLongitude rdf:type rdf:Property ;
    rdfs:label 'Zone Centroid Longitude' ;
    rdfs:comment 'Longitude coordinate of the geographic centroid of the delivery zone. Used for distance calculations and route optimization.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zonePriorityRank rdf:type rdf:Property ;
    rdfs:label 'Zone Priority Rank' ;
    rdfs:comment 'Priority ranking of this zone for resource allocation and route sequencing. Lower numbers indicate higher priority.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetTypeId rdf:type rdf:Property ;
    rdfs:label 'Asset Type Id' ;
    rdfs:comment 'Foreign key linking to fleet.asset_type. Business justification: transport_asset currently has asset_type (STRING) and asset_subtype (STRING) storing the asset classification as free text. The asset_type reference table provides the authoritative taxonomy with asse' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetType .

ind:assignedDepotId rdf:type rdf:Property ;
    rdfs:label 'Assigned Depot Id' ;
    rdfs:comment 'Identifier of the depot, hub, or facility where the transport asset is currently based or assigned for operational purposes.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'Capital expenditure (CAPEX) value of the transport asset at the time of acquisition. Recorded in the organization\'s base currency for financial reporting and depreciation calculation.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'Date when the transport asset was acquired, purchased, or leased by the organization. Used for depreciation and lifecycle tracking.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetName rdf:type rdf:Property ;
    rdfs:label 'Asset Name' ;
    rdfs:comment 'Human-readable name or designation of the transport asset for operational identification and reporting purposes.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:co2EmissionRateGPerKm rdf:type rdf:Property ;
    rdfs:label 'Co2 Emission Rate G Per Km' ;
    rdfs:comment 'Carbon dioxide equivalent (CO2e) emission rate in grams per kilometer. Used for greenhouse gas (GHG) reporting and sustainability KPI (Key Performance Indicator) tracking.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentLocation rdf:type rdf:Property ;
    rdfs:label 'Current Location' ;
    rdfs:comment 'Real-time or last known location of the transport asset. Updated via GPS telematics or manual check-in for visibility and tracking.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'Date when the transport asset was retired from active service or decommissioned. Marks the end of the asset\'s operational lifecycle.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalDate rdf:type rdf:Property ;
    rdfs:label 'Disposal Date' ;
    rdfs:comment 'Date when the transport asset was sold, scrapped, or otherwise disposed of. Used for final financial accounting and asset register closure.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalValue rdf:type rdf:Property ;
    rdfs:label 'Disposal Value' ;
    rdfs:comment 'Salvage or resale value realized when the transport asset was disposed of. Used for capital expenditure (CAPEX) recovery tracking and financial reporting.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionStandard rdf:type rdf:Property ;
    rdfs:label 'Emission Standard' ;
    rdfs:comment 'Environmental emission standard or certification that the transport asset complies with (e.g., Euro 6, EPA Tier 4). Required for regulatory compliance and sustainability reporting.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enginePowerKw rdf:type rdf:Property ;
    rdfs:label 'Engine Power Kw' ;
    rdfs:comment 'Engine power output measured in kilowatts. Indicates performance capability and operational efficiency of the transport asset.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engineType rdf:type rdf:Property ;
    rdfs:label 'Engine Type' ;
    rdfs:comment 'Engine model or type specification for the transport asset. Used for maintenance planning, parts sourcing, and performance tracking.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelCapacityLiters rdf:type rdf:Property ;
    rdfs:label 'Fuel Capacity Liters' ;
    rdfs:comment 'Maximum fuel tank capacity in liters. Used for range calculation and refueling planning.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:heightMeters rdf:type rdf:Property ;
    rdfs:label 'Height Meters' ;
    rdfs:comment 'Physical height of the transport asset in meters. Critical for bridge clearance, tunnel access, and loading dock compatibility.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:homeLocation rdf:type rdf:Property ;
    rdfs:label 'Home Location' ;
    rdfs:comment 'Primary base location or home terminal for the transport asset. Used for route planning and operational assignment.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Number' ;
    rdfs:comment 'Insurance policy number covering the transport asset for liability, damage, and loss. Required for risk management and claims processing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date when the most recent scheduled or unscheduled maintenance was performed on the transport asset. Used for maintenance interval tracking.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lengthMeters rdf:type rdf:Property ;
    rdfs:label 'Length Meters' ;
    rdfs:comment 'Physical length of the transport asset in meters. Used for parking allocation, route clearance, and infrastructure compatibility.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:model rdf:type rdf:Property ;
    rdfs:label 'Model' ;
    rdfs:comment 'Manufacturer\'s model designation or series name for the transport asset. Identifies specific design and capability specifications.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMaintenanceDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Due Date' ;
    rdfs:comment 'Scheduled date for the next preventive maintenance service on the transport asset. Critical for operational planning and compliance with safety regulations.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:odometerReading rdf:type rdf:Property ;
    rdfs:label 'Odometer Reading' ;
    rdfs:comment 'Current odometer or mileage reading for road vehicles, or equivalent usage metric (flight hours for aircraft, engine hours for vessels). Used for maintenance scheduling and utilization tracking.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Legal ownership or control arrangement for the transport asset. Determines financial treatment and operational flexibility.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payloadCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Payload Capacity Kg' ;
    rdfs:comment 'Maximum weight capacity in kilograms that the transport asset can carry. Critical for load planning and compliance with weight regulations.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registrationCountry rdf:type rdf:Property ;
    rdfs:label 'Registration Country' ;
    rdfs:comment 'Three-letter ISO country code where the transport asset is registered. Determines applicable regulatory jurisdiction and compliance requirements.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Registration Expiry Date' ;
    rdfs:comment 'Date when the current registration or license for the transport asset expires. Used for compliance tracking and renewal scheduling.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'Government-issued registration or license plate number for the transport asset. Required for legal operation and regulatory compliance (DOT, ICAO, IMO).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidTag rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag' ;
    rdfs:comment 'RFID (Radio Frequency Identification) tag identifier attached to the transport asset for automated identification, access control, and yard management.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:telematicsDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Telematics Device Code' ;
    rdfs:comment 'Unique identifier of the GPS (Global Positioning System) telematics device installed on the transport asset for real-time tracking, route monitoring, and IoT (Internet of Things) sensor data collection.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizationRatePercent rdf:type rdf:Property ;
    rdfs:label 'Utilization Rate Percent' ;
    rdfs:comment 'Percentage of time the transport asset is actively deployed in operations versus idle or available time. Key performance indicator (KPI) for fleet efficiency and return on investment (ROI).' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vinSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Vin Serial Number' ;
    rdfs:comment 'Unique vehicle identification number (VIN) for road vehicles or manufacturer serial number for aircraft, vessels, and rail units. Used for registration, insurance, and theft prevention.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:widthMeters rdf:type rdf:Property ;
    rdfs:label 'Width Meters' ;
    rdfs:comment 'Physical width of the transport asset in meters. Used for route clearance and infrastructure compatibility assessment.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yearOfManufacture rdf:type rdf:Property ;
    rdfs:label 'Year Of Manufacture' ;
    rdfs:comment 'Calendar year when the transport asset was manufactured or built. Used for age-based maintenance scheduling and regulatory compliance.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentDepotId rdf:type rdf:Property ;
    rdfs:label 'Current Depot Id' ;
    rdfs:comment 'Foreign key linking to fleet.depot. Business justification: Containers have a current location (current_location_type, current_location_code). When a container is at a fleet depot, this FK provides a structured link. Nullable because containers can be at ports' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:currentLocationNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Current Location Network Node Id' ;
    rdfs:comment 'Foreign key linking to route.network_node. Business justification: container_unit.current_location_code is a denormalized plain-text field. Normalizing to network_node enables container tracking, node-level inventory reporting, and repositioning optimization — core c' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:availabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Availability Status' ;
    rdfs:comment 'Current operational status of the container. Available for booking, in use on a shipment, in transit empty, under repair/maintenance, retired from service, or lost/missing. Critical for inventory management and booking systems.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionGrade rdf:type rdf:Property ;
    rdfs:label 'Condition Grade' ;
    rdfs:comment 'Physical condition assessment of the container. Grade A (excellent, cargo-worthy), B (good, minor wear), C (fair, requires monitoring), D (poor, repair needed), Scrap (end of life). Determines suitability for cargo types and repair priority.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cscCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Csc Certification Date' ;
    rdfs:comment 'Date the current CSC safety certification was issued. Used to track certification validity and schedule re-inspection.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cscCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Csc Certification Number' ;
    rdfs:comment 'Unique certification number issued under the International Convention for Safe Containers (CSC). Certifies the container meets structural safety standards for international transport.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cscExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Csc Expiry Date' ;
    rdfs:comment 'Expiration date of the CSC safety certification. Containers must be re-inspected and re-certified before this date to remain in service. Non-compliance prevents international movement.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentBookValue rdf:type rdf:Property ;
    rdfs:label 'Current Book Value' ;
    rdfs:comment 'Current accounting book value of the container after depreciation. Updated periodically based on depreciation schedule. Used for financial reporting and asset disposal decisions.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentLocationCountry rdf:type rdf:Property ;
    rdfs:label 'Current Location Country' ;
    rdfs:comment 'Three-letter ISO country code of the containers current location. Used for geographic fleet distribution analysis and repositioning planning.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentLocationType rdf:type rdf:Property ;
    rdfs:label 'Current Location Type' ;
    rdfs:comment 'Type of facility or mode where the container is currently located. Depot (storage yard), port (marine terminal), vessel (on ship), rail yard, customer site, or in transit between locations.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodGradeCertified rdf:type rdf:Property ;
    rdfs:label 'Food Grade Certified' ;
    rdfs:comment 'Indicates whether the container is certified for transporting food products, meeting hygiene and contamination prevention standards. True if food-grade certified, false otherwise.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gpsEnabled rdf:type rdf:Property ;
    rdfs:label 'Gps Enabled' ;
    rdfs:comment 'Indicates whether the container is equipped with GPS tracking device for real-time location monitoring. True if GPS-enabled, false otherwise.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:heightFt rdf:type rdf:Property ;
    rdfs:label 'Height Ft' ;
    rdfs:comment 'External height of the container in feet. Standard height is 8.5 feet; high-cube containers are 9.5 feet. Determines stacking compatibility and clearance requirements.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Internal Volume Cbm' ;
    rdfs:comment 'Internal cargo capacity of the container in cubic meters (CBM). Used for volumetric load planning and dimensional weight calculations.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'Date of the most recent physical inspection of the container. Inspections verify structural integrity, door seals, flooring, and compliance with safety standards.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lengthFt rdf:type rdf:Property ;
    rdfs:label 'Length Ft' ;
    rdfs:comment 'External length of the container in feet. Standard sizes are 10, 20, 40, 45, 48, or 53 feet. Critical for transport planning, stacking, and terminal slot allocation.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxGrossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Gross Weight Kg' ;
    rdfs:comment 'Maximum permissible combined weight of the container and its cargo in kilograms. Enforced for safety, regulatory compliance (SOLAS VGM), and transport mode restrictions.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxPayloadKg rdf:type rdf:Property ;
    rdfs:label 'Max Payload Kg' ;
    rdfs:comment 'Maximum cargo weight the container can carry, calculated as max gross weight minus tare weight. Used for load planning and customer quoting.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due Date' ;
    rdfs:comment 'Scheduled date for the next mandatory inspection. Used for preventive maintenance planning and compliance tracking.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownerCode rdf:type rdf:Property ;
    rdfs:label 'Owner Code' ;
    rdfs:comment 'Four-letter code identifying the container owner or operator, as registered with the Bureau International des Containers (BIC). First three letters identify the owner; fourth letter is the equipment category (U for freight container).' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reeferCapable rdf:type rdf:Property ;
    rdfs:label 'Reefer Capable' ;
    rdfs:comment 'Indicates whether the container has refrigeration capability for temperature-controlled cargo. True for reefer containers, false for dry and other non-refrigerated types.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'Date the container was retired from active service. Null if the container is still in service. Used for fleet lifecycle management and disposal tracking.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tareWeightKg rdf:type rdf:Property ;
    rdfs:label 'Tare Weight Kg' ;
    rdfs:comment 'Empty weight of the container in kilograms, excluding cargo. Used to calculate net cargo weight and verify compliance with gross weight limits.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:teuSize rdf:type rdf:Property ;
    rdfs:label 'Teu Size' ;
    rdfs:comment 'Container size expressed in TEU (Twenty-foot Equivalent Unit). Standard values: 1.0 for 20ft, 2.0 for 40ft, 2.25 for 45ft. Used for capacity planning and vessel/terminal utilization calculations.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Total Distance Km' ;
    rdfs:comment 'Cumulative distance the container has traveled in kilometers since acquisition. Used for wear analysis, maintenance scheduling, and asset performance evaluation.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTripsCompleted rdf:type rdf:Property ;
    rdfs:label 'Total Trips Completed' ;
    rdfs:comment 'Cumulative count of completed shipment trips (loaded movements) the container has performed since acquisition. Used for utilization analysis and lifecycle tracking.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:widthFt rdf:type rdf:Property ;
    rdfs:label 'Width Ft' ;
    rdfs:comment 'External width of the container in feet. Standard width is 8.0 feet; high-cube and specialized containers may be 8.5 feet.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Asset Assignment Id' ;
    rdfs:comment 'Unique identifier for the asset assignment record. Primary key for the asset assignment transaction.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetAssignment .

ind:destinationDepotId rdf:type rdf:Property ;
    rdfs:label 'Destination Depot Id' ;
    rdfs:comment 'Reference to the depot, terminal, or facility where the assignment is scheduled to end. The ending location for the asset assignment. Null for open-ended assignments such as depot standby. Links to warehouse or facility master data.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:pickupFacilityId rdf:type rdf:Property ;
    rdfs:label 'Pickup Facility Id' ;
    rdfs:comment 'Foreign key linking to warehouse.facility. Business justification: Asset assignments for warehouse pickup/delivery operations must reference the specific warehouse facility being serviced. This enables facility-level fleet utilization reporting, dock capacity plannin' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:actualEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual End Datetime' ;
    rdfs:comment 'Actual date and time when the asset assignment ended. Captured from GPS telematics, RFID tag reads, or manual check-out. Used for On-Time In-Full (OTIF) performance measurement and variance analysis against planned end. Null for in-progress assignments.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Datetime' ;
    rdfs:comment 'Actual date and time when the asset assignment began. Captured from GPS telematics, RFID tag reads, or manual check-in. Used for On-Time Departure (OTD) performance measurement and variance analysis against planned start.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentCostAmount rdf:type rdf:Property ;
    rdfs:label 'Assignment Cost Amount' ;
    rdfs:comment 'Total operational cost incurred for this assignment including fuel, driver wages, tolls, and maintenance. Used for OPEX tracking, profitability analysis, and cost-per-kilometer KPI calculation. Captured in the companys base currency.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentDurationHours rdf:type rdf:Property ;
    rdfs:label 'Assignment Duration Hours' ;
    rdfs:comment 'Planned or actual duration of the assignment in hours. Used for fleet utilization KPI calculation, driver hours-of-service compliance, and asset availability forecasting. Calculated from start and end datetimes.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:co2EmissionsKg rdf:type rdf:Property ;
    rdfs:label 'Co2 Emissions Kg' ;
    rdfs:comment 'Total greenhouse gas emissions in kilograms of CO2 equivalent produced during this assignment. Calculated from fuel consumption using emission factors. Used for sustainability reporting, EU Emissions Trading System (EU ETS) compliance, and Carbon Offsetting and Reduction Scheme for International Aviation (CORSIA) reporting.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Check Status' ;
    rdfs:comment 'Status of regulatory compliance checks for this assignment including DOT inspections, ICAO airworthiness, IMO safety checks, and customs pre-clearance. Passed indicates all checks cleared, failed for violations, pending for in-progress checks, not required for exempt assignments, waived for authorized exceptions.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossBorderIndicator rdf:type rdf:Property ;
    rdfs:label 'Cross Border Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the assignment involves crossing international borders requiring customs clearance and trade compliance. True for international assignments, false for domestic.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fuelConsumedLiters rdf:type rdf:Property ;
    rdfs:label 'Fuel Consumed Liters' ;
    rdfs:comment 'Actual fuel consumed during the assignment in liters. Captured from vehicle telematics, fuel card transactions, or manual fuel logs. Used for OPEX tracking, Carbon Dioxide Equivalent (CO2e) emissions calculation, and fuel efficiency KPIs.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Gps Tracking Enabled' ;
    rdfs:comment 'Boolean flag indicating whether real-time GPS tracking is enabled for this assignment. True if telematics data is being captured, false otherwise. Used for real-time visibility and predictive ETA calculation.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incidentReportedIndicator rdf:type rdf:Property ;
    rdfs:label 'Incident Reported Indicator' ;
    rdfs:comment 'Boolean flag indicating whether any incident (accident, breakdown, delay, cargo damage, security breach) was reported during this assignment. True if an incident occurred, false otherwise. Links to incident or claims management systems.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loadUtilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Load Utilization Percentage' ;
    rdfs:comment 'Percentage of the assets maximum capacity utilized during this assignment. Calculated as (actual cargo weight or volume / maximum capacity) * 100. Key performance indicator for fleet efficiency and load optimization.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Planned End Datetime' ;
    rdfs:comment 'Scheduled date and time when the asset assignment is planned to end. Used for capacity planning and turnaround time calculation. Corresponds to Estimated Time of Arrival (ETA) for route assignments. Null for open-ended assignments.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Planned Start Datetime' ;
    rdfs:comment 'Scheduled date and time when the asset assignment is planned to begin. Used for capacity planning and resource scheduling. Corresponds to Estimated Time of Departure (ETD) for route assignments.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:telematicsEventId rdf:type rdf:Property ;
    rdfs:label 'Telematics Event Id' ;
    rdfs:comment 'Unique identifier for the telematics event record. Primary key for the telematics event stream.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:altitudeM rdf:type rdf:Property ;
    rdfs:label 'Altitude M' ;
    rdfs:comment 'Altitude of the asset above sea level in meters at the time of the event. Particularly relevant for aircraft and mountainous terrain routing.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batteryVoltage rdf:type rdf:Property ;
    rdfs:label 'Battery Voltage' ;
    rdfs:comment 'Voltage level of the asset battery in volts. Used for predictive maintenance and device health monitoring.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Flag' ;
    rdfs:comment 'Indicator of the data quality and reliability of the event. Suspect or invalid flags may indicate GPS signal loss, sensor malfunction, or data transmission errors.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diagnosticTroubleCode rdf:type rdf:Property ;
    rdfs:label 'Diagnostic Trouble Code' ;
    rdfs:comment 'Standardized engine diagnostic trouble code reported by the onboard diagnostics system. Used for predictive maintenance and fleet health monitoring.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineHours rdf:type rdf:Property ;
    rdfs:label 'Engine Hours' ;
    rdfs:comment 'Cumulative engine operating hours as reported by the asset. Used for maintenance scheduling based on usage rather than calendar time.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engineRpm rdf:type rdf:Property ;
    rdfs:label 'Engine Rpm' ;
    rdfs:comment 'Engine speed in revolutions per minute at the time of the event. Used for fuel efficiency analysis and engine health monitoring.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelLevelPercent rdf:type rdf:Property ;
    rdfs:label 'Fuel Level Percent' ;
    rdfs:comment 'Remaining fuel level as a percentage of tank capacity (0-100). Used for fuel consumption tracking, refueling planning, and OPEX analysis.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geofenceEventType rdf:type rdf:Property ;
    rdfs:label 'Geofence Event Type' ;
    rdfs:comment 'Indicates whether the event represents entry into or exit from a geofence zone. Used for automated proof of delivery and dwell time analysis.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsAccuracyM rdf:type rdf:Property ;
    rdfs:label 'Gps Accuracy M' ;
    rdfs:comment 'Estimated horizontal accuracy of the GPS position in meters. Lower values indicate higher precision.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsSatelliteCount rdf:type rdf:Property ;
    rdfs:label 'Gps Satellite Count' ;
    rdfs:comment 'Number of GPS satellites used to calculate the position fix. Higher counts indicate better position accuracy.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:harshAccelerationFlag rdf:type rdf:Property ;
    rdfs:label 'Harsh Acceleration Flag' ;
    rdfs:comment 'Boolean indicator (True/False) that a harsh acceleration event was detected based on acceleration threshold. Used for driver behavior scoring and fuel efficiency analysis.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:harshBrakingFlag rdf:type rdf:Property ;
    rdfs:label 'Harsh Braking Flag' ;
    rdfs:comment 'Boolean indicator (True/False) that a harsh braking event was detected based on deceleration threshold. Used for driver behavior scoring and safety analysis.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:headingDegrees rdf:type rdf:Property ;
    rdfs:label 'Heading Degrees' ;
    rdfs:comment 'Compass heading of the asset in degrees (0-360), where 0/360 is North, 90 is East, 180 is South, and 270 is West. Used for route deviation detection.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ignitionState rdf:type rdf:Property ;
    rdfs:label 'Ignition State' ;
    rdfs:comment 'Current state of the asset ignition system. Used to distinguish active operation from idle or parked states.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingestion Timestamp' ;
    rdfs:comment 'Date and time when the event was received and ingested into the FourKites platform, in format yyyy-MM-ddTHH:mm:ss.SSSXXX. Used to calculate transmission latency and data freshness.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:networkType rdf:type rdf:Property ;
    rdfs:label 'Network Type' ;
    rdfs:comment 'Type of network connection used by the telematics device to transmit the event. Impacts data latency and coverage in remote areas.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:odometerKm rdf:type rdf:Property ;
    rdfs:label 'Odometer Km' ;
    rdfs:comment 'Cumulative distance traveled by the asset in kilometers as reported by the onboard odometer. Used for maintenance scheduling and asset utilization tracking.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payloadJson rdf:type rdf:Property ;
    rdfs:label 'Payload Json' ;
    rdfs:comment 'Raw JSON payload from the telematics device containing additional vendor-specific sensor data and metadata not parsed into structured fields. Retained for audit and advanced analytics.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalStrength rdf:type rdf:Property ;
    rdfs:label 'Signal Strength' ;
    rdfs:comment 'Network signal strength indicator (typically in dBm or percentage). Used to assess connectivity quality and predict data transmission reliability.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:speedKmh rdf:type rdf:Property ;
    rdfs:label 'Speed Kmh' ;
    rdfs:comment 'Instantaneous speed of the asset in kilometers per hour at the time of the event. Used for route optimization, ETA prediction, and driver behavior scoring.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureC rdf:type rdf:Property ;
    rdfs:label 'Temperature C' ;
    rdfs:comment 'Temperature reading in degrees Celsius from onboard sensor. Critical for refrigerated (reefer) units transporting temperature-sensitive cargo such as pharmaceuticals or perishables.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureSetpointC rdf:type rdf:Property ;
    rdfs:label 'Temperature Setpoint C' ;
    rdfs:comment 'Target temperature setting for refrigerated units in degrees Celsius. Used to detect temperature excursions and compliance violations.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsTradePartyId rdf:type rdf:Property ;
    rdfs:label 'Customs Trade Party Id' ;
    rdfs:comment 'Foreign key linking to customs.trade_party. Business justification: Drivers (especially owner-operators or contractors) may be registered as customs trade parties with their own importer/exporter numbers, C-TPAT certifications, or AEO status. Supports driver-level cus' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeParty .

ind:homeFleetDepotId rdf:type rdf:Property ;
    rdfs:label 'Home Fleet Depot Id' ;
    rdfs:comment 'FK to fleet.fleet_depot' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:backgroundCheckDate rdf:type rdf:Property ;
    rdfs:label 'Background Check Date' ;
    rdfs:comment 'Date the most recent background check was completed for the driver. Required for C-TPAT, AEO, and other security programs.' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backgroundCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Background Check Status' ;
    rdfs:comment 'Result status of the most recent background check. Cleared: passed all checks. Pending: in progress. Failed: did not meet security criteria. Expired: check is outdated and must be renewed.' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disciplinaryFlag rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Flag' ;
    rdfs:comment 'Indicates whether the driver has active disciplinary actions or compliance violations on record. True if disciplinary action exists, False otherwise. Used for assignment restrictions and compliance monitoring.' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:driverName rdf:type rdf:Property ;
    rdfs:label 'Driver Name' ;
    rdfs:comment 'Full legal name of the driver as it appears on their commercial driver license or operating permit.' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugTestDate rdf:type rdf:Property ;
    rdfs:label 'Drug Test Date' ;
    rdfs:comment 'Date of the most recent drug and alcohol screening test. Required for DOT-regulated drivers in the United States.' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drugTestResult rdf:type rdf:Property ;
    rdfs:label 'Drug Test Result' ;
    rdfs:comment 'Result of the most recent drug and alcohol screening test. Negative: passed. Positive: failed. Pending: awaiting results. Refused: driver refused to test.' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactName rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Name' ;
    rdfs:comment 'Full name of the driver\'s designated emergency contact person.' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Phone' ;
    rdfs:comment 'Phone number of the driver\'s designated emergency contact person.' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentType rdf:type rdf:Property ;
    rdfs:label 'Employment Type' ;
    rdfs:comment 'Classification of the driver\'s employment relationship with Transport Shipping. Determines payroll, benefits, liability, and compliance obligations.' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Gps Device Code' ;
    rdfs:comment 'Identifier of the GPS telematics device currently assigned to the driver for real-time location tracking and route monitoring. Null if no device assigned.' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'Date the driver was hired or contracted by Transport Shipping. Used for tenure calculation, anniversary tracking, and retention analytics.' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:languageProficiency rdf:type rdf:Property ;
    rdfs:label 'Language Proficiency' ;
    rdfs:comment 'Comma-separated list of languages the driver is proficient in, using ISO 639-1 two-letter codes (e.g., EN, ES, FR, DE). Used for customer-facing delivery roles and cross-border operations.' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPerformanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Performance Review Date' ;
    rdfs:comment 'Date of the most recent formal performance review for the driver.' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseCategories rdf:type rdf:Property ;
    rdfs:label 'License Categories' ;
    rdfs:comment 'Comma-separated list of vehicle categories or endorsements the driver is authorized to operate (e.g., H-Hazmat, N-Tank, P-Passenger, T-Double/Triple Trailers for road; type ratings for aviation; vessel types for maritime).' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'License Expiry Date' ;
    rdfs:comment 'Date the driver license expires and must be renewed. Critical for compliance monitoring and driver assignment eligibility.' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseIssueDate rdf:type rdf:Property ;
    rdfs:label 'License Issue Date' ;
    rdfs:comment 'Date the current driver license was issued by the licensing authority.' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseIssuingCountry rdf:type rdf:Property ;
    rdfs:label 'License Issuing Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the authority that issued the driver license.' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseIssuingState rdf:type rdf:Property ;
    rdfs:label 'License Issuing State' ;
    rdfs:comment 'State, province, or regional authority within the issuing country that issued the driver license. Applicable for federal jurisdictions like USA, Canada, Australia.' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleTypeAuthorization rdf:type rdf:Property ;
    rdfs:label 'Vehicle Type Authorization' ;
    rdfs:comment 'Comma-separated list of vehicle types the driver is authorized and trained to operate (e.g., tractor_trailer, straight_truck, cargo_van, aircraft, vessel). Derived from license class, endorsements, and internal training records.' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearsOfExperience rdf:type rdf:Property ;
    rdfs:label 'Years Of Experience' ;
    rdfs:comment 'Total years of professional driving experience in commercial transport operations. Used for risk assessment, insurance rating, and assignment to high-value or complex routes.' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:driverAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Driver Assignment Id' ;
    rdfs:comment 'Unique identifier for the driver assignment record. Primary key.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationLocationFleetDepotId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Fleet Depot Id' ;
    rdfs:comment 'Reference to the ending location for this driver assignment (depot, warehouse, terminal, customer site). Links to the location master.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:primaryFleetAssetTransportAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Fleet Asset Transport Asset Id' ;
    rdfs:comment 'Reference to the transport asset (vehicle, truck, aircraft, vessel) assigned for this run. Links to the fleet asset master.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransportAsset .

ind:primaryFleetDepotId rdf:type rdf:Property ;
    rdfs:label 'Primary Fleet Depot Id' ;
    rdfs:comment 'Reference to the starting location for this driver assignment (depot, warehouse, terminal). Links to the location master.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:primaryFleetDriverProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Fleet Driver Profile Id' ;
    rdfs:comment 'Reference to the driver assigned to this transport run. Links to the driver master profile.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DriverProfile .

ind:serviceAgreementId rdf:type rdf:Property ;
    rdfs:label 'Service Agreement Id' ;
    rdfs:comment 'Foreign key linking to contract.agreement. Business justification: Driver assignments execute service commitments under customer/carrier agreements. Operations verifies driver qualifications (certifications, endorsements, background checks) match contract requirement' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:actualReturnDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Return Datetime' ;
    rdfs:comment 'Actual date and time when the driver returned and completed the assignment. Captured from GPS telematics or driver check-out. Used for on-time completion KPI tracking.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentOutcome rdf:type rdf:Property ;
    rdfs:label 'Assignment Outcome' ;
    rdfs:comment 'Final outcome status of the driver assignment. Captures whether the assignment was completed successfully, cancelled, or suspended, and the reason. Used for driver performance evaluation and operational analytics. [ENUM-REF-CANDIDATE: completed_on_time|completed_late|cancelled_by_ops|cancelled_by_driver|suspended_hos|suspended_mechanical|no_show — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerFeedbackScore rdf:type rdf:Property ;
    rdfs:label 'Customer Feedback Score' ;
    rdfs:comment 'Customer satisfaction score for this assignment, typically on a scale of 1-5. Captured from customer surveys or delivery feedback. Used for service quality monitoring.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispatchDatetime rdf:type rdf:Property ;
    rdfs:label 'Dispatch Datetime' ;
    rdfs:comment 'Date and time when the assignment was dispatched to the driver by the operations team. Marks the transition from scheduled to active status.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:distanceActualKm rdf:type rdf:Property ;
    rdfs:label 'Distance Actual Km' ;
    rdfs:comment 'Actual total distance traveled during this assignment in kilometers, captured from GPS telematics. Used for fuel consumption analysis and route optimization.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distancePlannedKm rdf:type rdf:Property ;
    rdfs:label 'Distance Planned Km' ;
    rdfs:comment 'Planned total distance for this assignment in kilometers, based on route planning. Used for fuel budgeting and driver scheduling.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:driverRating rdf:type rdf:Property ;
    rdfs:label 'Driver Rating' ;
    rdfs:comment 'Performance rating assigned to the driver for this assignment, typically on a scale of 1-5. Based on factors such as on-time performance, fuel efficiency, safety, and customer feedback. Used for driver performance management.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drivingHours rdf:type rdf:Property ;
    rdfs:label 'Driving Hours' ;
    rdfs:comment 'Total hours spent actively driving during this assignment. Captured from GPS telematics or electronic logging device (ELD). Used for HOS compliance and driver productivity analysis.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hosCounterAtEnd rdf:type rdf:Property ;
    rdfs:label 'Hos Counter At End' ;
    rdfs:comment 'Cumulative hours of service logged by the driver at the end of this assignment. Used for DOT hours-of-service compliance tracking and fatigue management.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hosCounterAtStart rdf:type rdf:Property ;
    rdfs:label 'Hos Counter At Start' ;
    rdfs:comment 'Cumulative hours of service logged by the driver at the start of this assignment. Used for DOT hours-of-service compliance tracking and fatigue management.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hosViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Hos Violation Flag' ;
    rdfs:comment 'Boolean flag indicating whether this assignment resulted in a DOT hours-of-service violation. True if violation occurred, False otherwise. Used for compliance monitoring and driver safety management.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hosViolationType rdf:type rdf:Property ;
    rdfs:label 'Hos Violation Type' ;
    rdfs:comment 'Description of the type of HOS violation that occurred (e.g., exceeded 11-hour driving limit, insufficient rest break, exceeded 14-hour on-duty limit). Populated when hos_violation_flag is True.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedReturnDatetime rdf:type rdf:Property ;
    rdfs:label 'Planned Return Datetime' ;
    rdfs:comment 'Scheduled date and time when the driver is expected to return and complete the assignment. Used for shift planning and asset availability forecasting.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:restBreakHours rdf:type rdf:Property ;
    rdfs:label 'Rest Break Hours' ;
    rdfs:comment 'Total hours spent on mandatory rest breaks during this assignment. Used for DOT compliance verification and fatigue management.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyIncidentDescription rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Description' ;
    rdfs:comment 'Free-text description of the safety incident that occurred during this assignment. Populated when safety_incident_flag is True.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyIncidentFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Flag' ;
    rdfs:comment 'Boolean flag indicating whether a safety incident (accident, near-miss, traffic violation) occurred during this assignment. True if incident occurred, False otherwise. Used for driver safety scoring and risk management.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:depotId rdf:type rdf:Property ;
    rdfs:label 'Depot Id' ;
    rdfs:comment 'Reference to the internal workshop or facility location where the maintenance work is being performed, applicable when maintenance_provider_type is internal_workshop.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:maintenanceFacilityId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Facility Id' ;
    rdfs:comment 'Foreign key linking to warehouse.facility. Business justification: Fleet maintenance performed at warehouse/distribution center facilities requires linking maintenance orders to the facility for compliance auditing, facility cost allocation, and AEO/CTPAT certificati' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:maintenanceScheduleId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Schedule Id' ;
    rdfs:comment 'Foreign key linking to fleet.maintenance_schedule. Business justification: Maintenance orders can be auto-generated from maintenance schedules (maintenance_schedule has auto_generate_order_flag). This FK tracks which preventive maintenance schedule triggered the work order. ' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenanceSchedule .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'The actual date and time when maintenance work physically commenced, used for labor tracking and performance analysis against scheduled start.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downtimeHours rdf:type rdf:Property ;
    rdfs:label 'Downtime Hours' ;
    rdfs:comment 'Total number of hours the asset was out of service due to this maintenance activity, calculated from the time the asset was taken offline until it was returned to operational status, used for availability KPIs and operational impact analysis.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalServiceCost rdf:type rdf:Property ;
    rdfs:label 'External Service Cost' ;
    rdfs:comment 'Cost charged by external vendors or service providers for maintenance work, applicable when maintenance is outsourced, representing third-party service fees in maintenance OPEX.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:faultCode rdf:type rdf:Property ;
    rdfs:label 'Fault Code' ;
    rdfs:comment 'Standardized diagnostic trouble code or fault identifier from the asset\'s onboard diagnostic system or maintenance taxonomy, used for root cause analysis and trend identification.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faultDescription rdf:type rdf:Property ;
    rdfs:label 'Fault Description' ;
    rdfs:comment 'Detailed narrative description of the fault, defect, or maintenance requirement that triggered this work order, including symptoms, error codes, and operator observations.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Expiry Date' ;
    rdfs:comment 'Date when the regulatory inspection certificate expires and the asset requires re-inspection to maintain compliance and operational authorization.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:laborCost rdf:type rdf:Property ;
    rdfs:label 'Labor Cost' ;
    rdfs:comment 'Total cost of labor for this maintenance order, calculated from labor hours and applicable labor rates (internal or vendor), representing the direct labor component of maintenance OPEX.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborHours rdf:type rdf:Property ;
    rdfs:label 'Labor Hours' ;
    rdfs:comment 'Total number of labor hours expended on this maintenance order, including technician time for diagnosis, repair, testing, and documentation, used for cost calculation and productivity analysis.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceCategory rdf:type rdf:Property ;
    rdfs:label 'Maintenance Category' ;
    rdfs:comment 'Technical category of the maintenance work, indicating the system or component area being serviced (e.g., mechanical, electrical, hydraulic, structural, avionics, engine, transmission, brakes, tires, body, interior, safety systems). [ENUM-REF-CANDIDATE: mechanical|electrical|hydraulic|structural|avionics|engine|transmission|brakes|tires|body|interior|safety_systems — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Maintenance Order Status' ;
    rdfs:comment 'Current lifecycle state of the maintenance order: draft (being prepared), scheduled (approved and planned), in_progress (work underway), on_hold (temporarily suspended), completed (work finished and asset released), cancelled (order voided).' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceProviderType rdf:type rdf:Property ;
    rdfs:label 'Maintenance Provider Type' ;
    rdfs:comment 'Classification of the entity performing the maintenance work: internal_workshop (company-owned facility), external_vendor (third-party service provider), oem_service_center (original equipment manufacturer facility), authorized_dealer (franchised service location).' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceType rdf:type rdf:Property ;
    rdfs:label 'Maintenance Type' ;
    rdfs:comment 'Classification of the maintenance work order by its nature: preventive (scheduled routine maintenance), corrective (repair of known defect), statutory_inspection (regulatory compliance inspection such as DOT annual inspection or ICAO airworthiness check), or breakdown (emergency unplanned repair).' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsCost rdf:type rdf:Property ;
    rdfs:label 'Parts Cost' ;
    rdfs:comment 'Total cost of parts and materials consumed in this maintenance order, representing the direct material component of maintenance OPEX.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partsReplacedList rdf:type rdf:Property ;
    rdfs:label 'Parts Replaced List' ;
    rdfs:comment 'Comma-separated or structured list of part numbers and descriptions for components replaced during the maintenance activity, used for inventory management and warranty tracking.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postMaintenanceStatus rdf:type rdf:Property ;
    rdfs:label 'Post Maintenance Status' ;
    rdfs:comment 'Operational status of the asset immediately following completion of maintenance work: operational (fully serviceable), limited_service (operational with restrictions), out_of_service (not cleared for use), pending_inspection (awaiting final certification), scrapped (asset retired).' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryInspectionType rdf:type rdf:Property ;
    rdfs:label 'Regulatory Inspection Type' ;
    rdfs:comment 'Type of regulatory or statutory inspection performed as part of this maintenance order: dot_annual (DOT annual vehicle inspection), icao_airworthiness (ICAO airworthiness check), maritime_survey (vessel classification survey), emissions_test (environmental compliance test), safety_certification (safety system certification), none (not a regulatory inspection).' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Completion Date' ;
    rdfs:comment 'The planned date when maintenance work is expected to be completed and the asset returned to service, used for operational planning and customer commitments.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'The planned date when maintenance work is scheduled to begin, used for resource planning and asset availability forecasting.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalMaintenanceCost rdf:type rdf:Property ;
    rdfs:label 'Total Maintenance Cost' ;
    rdfs:comment 'Total cost of the maintenance order including parts, labor, external services, and any other direct costs, representing the complete OPEX impact of this maintenance event for financial reporting and asset lifecycle costing.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Flag' ;
    rdfs:comment 'Boolean indicator whether this maintenance order is associated with a warranty claim against the asset manufacturer or component supplier, used for cost recovery tracking.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warrantyClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Number' ;
    rdfs:comment 'Reference number for the associated warranty claim submitted to the manufacturer or supplier, applicable when warranty_claim_flag is true.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'Externally-known unique business identifier for the maintenance work order, used for tracking and reference across systems and with external vendors.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPerformedDescription rdf:type rdf:Property ;
    rdfs:label 'Work Performed Description' ;
    rdfs:comment 'Detailed narrative of the actual maintenance work performed, including procedures followed, parts replaced, adjustments made, and test results, completed upon work order closure.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoGenerateOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Generate Order Flag' ;
    rdfs:comment 'Indicates whether the system should automatically generate a maintenance work order when the schedule trigger conditions are met (True) or require manual creation (False).' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceMandatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Mandatory Flag' ;
    rdfs:comment 'Indicates whether this maintenance schedule is mandated by regulatory compliance requirements (True) or is discretionary preventive maintenance (False).' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:downtimeRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Downtime Required Flag' ;
    rdfs:comment 'Indicates whether the asset must be taken out of service (True) or can remain operational during maintenance (False).' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost' ;
    rdfs:comment 'Estimated total cost in base currency for completing this scheduled maintenance service, including labor and parts.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedDurationHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Hours' ;
    rdfs:comment 'Estimated time in hours required to complete this maintenance service.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intervalUnit rdf:type rdf:Property ;
    rdfs:label 'Interval Unit' ;
    rdfs:comment 'Unit of measure for the maintenance interval value (miles, kilometers, engine hours, calendar days, operating cycles).' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intervalValue rdf:type rdf:Property ;
    rdfs:label 'Interval Value' ;
    rdfs:comment 'Numeric value of the maintenance interval (e.g., 5000 for 5000 miles, 100 for 100 engine hours, 365 for 365 days).' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Last Completed Date' ;
    rdfs:comment 'The date when this maintenance service was last completed for the asset.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastCompletedHours rdf:type rdf:Property ;
    rdfs:label 'Last Completed Hours' ;
    rdfs:comment 'The engine hour meter reading when this maintenance service was last completed. Null if not applicable.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastCompletedMileage rdf:type rdf:Property ;
    rdfs:label 'Last Completed Mileage' ;
    rdfs:comment 'The odometer mileage reading when this maintenance service was last completed. Null if not applicable.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Due Date' ;
    rdfs:comment 'The calendar date by which the next scheduled maintenance service must be completed. Null if trigger basis is not calendar-based.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextDueHours rdf:type rdf:Property ;
    rdfs:label 'Next Due Hours' ;
    rdfs:comment 'The engine hour meter reading at which the next scheduled maintenance service is due. Null if trigger basis is not engine hours or flight hours.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextDueMileage rdf:type rdf:Property ;
    rdfs:label 'Next Due Mileage' ;
    rdfs:comment 'The odometer mileage reading at which the next scheduled maintenance service is due. Null if trigger basis is not mileage.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partsRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Parts Required Flag' ;
    rdfs:comment 'Indicates whether replacement parts or consumables are required for this maintenance service (True) or if it is inspection/labor only (False).' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulationReference rdf:type rdf:Property ;
    rdfs:label 'Regulation Reference' ;
    rdfs:comment 'Specific regulation, code section, or standard that mandates this maintenance schedule (e.g., 49 CFR 396.17, ICAO Annex 6 Part I, IMO SOLAS Chapter II-1).' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBody rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body' ;
    rdfs:comment 'The governing regulatory body that mandates this maintenance requirement (DOT, ICAO, IMO, FAA, FMCSA, EASA, IATA). Null if not compliance-driven. [ENUM-REF-CANDIDATE: DOT|ICAO|IMO|FAA|FMCSA|EASA|IATA — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Schedule Effective Date' ;
    rdfs:comment 'The date from which this maintenance schedule becomes active and applicable to the asset.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Schedule Expiry Date' ;
    rdfs:comment 'The date on which this maintenance schedule is no longer applicable (e.g., asset retirement, schedule superseded by new regulation). Null for open-ended schedules.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceDescription rdf:type rdf:Property ;
    rdfs:label 'Service Description' ;
    rdfs:comment 'Detailed description of the maintenance service activities and scope of work included in this schedule.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceAfterDays rdf:type rdf:Property ;
    rdfs:label 'Tolerance After Days' ;
    rdfs:comment 'Number of days after the due date that the maintenance service may be performed late before the asset is considered non-compliant or overdue.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:toleranceBeforeDays rdf:type rdf:Property ;
    rdfs:label 'Tolerance Before Days' ;
    rdfs:comment 'Number of days before the due date that the maintenance service may be performed early without resetting the schedule interval.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:triggerBasis rdf:type rdf:Property ;
    rdfs:label 'Trigger Basis' ;
    rdfs:comment 'The measurement basis that triggers this maintenance service (mileage interval, engine hours, calendar days, flight hours, operating cycles).' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelTransactionId rdf:type rdf:Property ;
    rdfs:label 'Fuel Transaction Id' ;
    rdfs:comment 'Unique identifier for the fuel transaction record. Primary key.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelAgreementId rdf:type rdf:Property ;
    rdfs:label 'Fuel Agreement Id' ;
    rdfs:comment 'Foreign key linking to contract.agreement. Business justification: Fuel purchases may be governed by fuel supply agreements with negotiated rates and volume commitments. Procurement validates transaction pricing against contracted fuel rates, surcharge schedules, and' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:fuelCardNumber rdf:type rdf:Property ;
    rdfs:label 'Fuel Card Number' ;
    rdfs:comment 'Fuel card or fleet card number used for the transaction. Masked or tokenized for security. Used for reconciliation with supplier invoices.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelCardProvider rdf:type rdf:Property ;
    rdfs:label 'Fuel Card Provider' ;
    rdfs:comment 'Name of the fuel card provider or fleet card issuer (e.g., Shell Fleet, BP Fuel Card, WEX).' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelEfficiency rdf:type rdf:Property ;
    rdfs:label 'Fuel Efficiency' ;
    rdfs:comment 'Calculated fuel efficiency for this transaction (e.g., km per litre, miles per gallon). Derived from odometer change and fuel quantity. Used for fleet performance KPIs.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelGrade rdf:type rdf:Property ;
    rdfs:label 'Fuel Grade' ;
    rdfs:comment 'Grade or quality specification of the fuel (e.g., premium, regular, ultra-low sulfur diesel). Used for asset maintenance and performance tracking.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelStationCode rdf:type rdf:Property ;
    rdfs:label 'Fuel Station Code' ;
    rdfs:comment 'Reference to the fuel station, depot, or charging station where the transaction occurred. Links to location or supplier facility master data.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelStationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Fuel Station Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code where the fuel station is located. Used for tax and regulatory compliance reporting.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelStationLocation rdf:type rdf:Property ;
    rdfs:label 'Fuel Station Location' ;
    rdfs:comment 'Geographic location description of the fuel station (city, region, or address). Used for route analysis and cost allocation.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelStationName rdf:type rdf:Property ;
    rdfs:label 'Fuel Station Name' ;
    rdfs:comment 'Name of the fuel station, depot, or charging facility where the transaction took place.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generalLedgerAccount rdf:type rdf:Property ;
    rdfs:label 'General Ledger Account' ;
    rdfs:comment 'General ledger account code for fuel expense posting. Used for financial accounting and P&L reporting.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEmergencyRefuel rdf:type rdf:Property ;
    rdfs:label 'Is Emergency Refuel' ;
    rdfs:comment 'Flag indicating whether this was an emergency or unplanned refueling event outside of normal depot operations. Used for exception analysis.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReconciled rdf:type rdf:Property ;
    rdfs:label 'Is Reconciled' ;
    rdfs:comment 'Flag indicating whether this transaction has been reconciled with supplier invoices and financial records.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:odometerUnit rdf:type rdf:Property ;
    rdfs:label 'Odometer Unit' ;
    rdfs:comment 'Unit of measure for the odometer reading (kilometers, miles, or operating hours for aircraft/vessels).' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Invoice Number' ;
    rdfs:comment 'Invoice number issued by the fuel supplier for this transaction. Used for accounts payable reconciliation.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionDatetime rdf:type rdf:Property ;
    rdfs:label 'Transaction Datetime' ;
    rdfs:comment 'The date and time when the fuel uplift or energy charge event occurred. Principal business event timestamp.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'Externally-known unique transaction number or receipt number issued by the fuel supplier or fuel card provider.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current lifecycle status of the fuel transaction. Indicates whether the transaction has been completed, is pending reconciliation, disputed, cancelled, or reversed.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsComplianceProgramId rdf:type rdf:Property ;
    rdfs:label 'Customs Compliance Program Id' ;
    rdfs:comment 'Foreign key linking to customs.compliance_program. Business justification: Asset inspections (security seals, container integrity, GPS functionality) are mandatory for customs compliance programs (C-TPAT, AEO). Inspection certificates must be maintained as evidence of progra' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceProgram .

ind:inspectionFacilityId rdf:type rdf:Property ;
    rdfs:label 'Inspection Facility Id' ;
    rdfs:comment 'Foreign key linking to warehouse.facility. Business justification: Vehicle inspections conducted at warehouse/DC facilities must be linked to the facility for CTPAT/AEO compliance audits, facility safety reporting, and regulatory filing. inspection_location plain att' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:inspectionNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Inspection Network Node Id' ;
    rdfs:comment 'Foreign key linking to route.network_node. Business justification: Inspections at border crossings, ports, and hubs are a regulatory compliance requirement (port state control, customs). Normalizing inspection_location to network_node enables node-level compliance re' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:certificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Expiry Date' ;
    rdfs:comment 'The date on which the issued regulatory certificate expires, triggering the need for a subsequent inspection to maintain compliance.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateIssueDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Issue Date' ;
    rdfs:comment 'The date the regulatory certificate or compliance document was officially issued following successful inspection.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionDeadline rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Deadline' ;
    rdfs:comment 'The date by which all required corrective actions must be completed to maintain regulatory compliance and operational status.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionsRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Required' ;
    rdfs:comment 'Detailed description of corrective actions, repairs, or remediation work required to address identified defects and achieve compliance.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalDefectsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Defects Count' ;
    rdfs:comment 'Number of critical or safety-related defects that require immediate corrective action and may result in asset being placed out of service.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectsDescription rdf:type rdf:Property ;
    rdfs:label 'Defects Description' ;
    rdfs:comment 'Detailed narrative description of all defects, non-conformances, and observations identified during the inspection. Includes severity classification and affected components.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectsIdentifiedCount rdf:type rdf:Property ;
    rdfs:label 'Defects Identified Count' ;
    rdfs:comment 'Total number of defects, non-conformances, or discrepancies identified during the inspection. Zero indicates no issues found.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionChecklistReference rdf:type rdf:Property ;
    rdfs:label 'Inspection Checklist Reference' ;
    rdfs:comment 'Reference identifier for the standardized inspection checklist or procedure document used to conduct this inspection.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCost rdf:type rdf:Property ;
    rdfs:label 'Inspection Cost' ;
    rdfs:comment 'Total cost incurred for conducting the inspection, including labor, materials, third-party fees, and administrative overhead.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Inspection Cost Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the inspection cost amount.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Inspection Document Url' ;
    rdfs:comment 'URL or file path to the digital inspection report, certificate scan, or supporting documentation stored in the document management system.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionEndTime rdf:type rdf:Property ;
    rdfs:label 'Inspection End Time' ;
    rdfs:comment 'Precise timestamp when the inspection was completed. Used to calculate inspection duration and resource utilization.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionLocationCountry rdf:type rdf:Property ;
    rdfs:label 'Inspection Location Country' ;
    rdfs:comment 'Three-letter ISO country code of the jurisdiction where the inspection took place. Critical for determining applicable regulatory framework.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionNotes rdf:type rdf:Property ;
    rdfs:label 'Inspection Notes' ;
    rdfs:comment 'Additional free-text notes, observations, or comments recorded by the inspector that provide context beyond structured fields.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Number' ;
    rdfs:comment 'Externally-known unique identifier or reference number for this inspection event, often used for regulatory reporting and audit trails.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionOutcome rdf:type rdf:Property ;
    rdfs:label 'Inspection Outcome' ;
    rdfs:comment 'Overall result of the inspection. Pass indicates full compliance; fail indicates critical defects requiring immediate action; conditional pass indicates minor defects with corrective action required within a specified timeframe.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStartTime rdf:type rdf:Property ;
    rdfs:label 'Inspection Start Time' ;
    rdfs:comment 'Precise timestamp when the inspection commenced. Used for operational tracking and labor cost allocation.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Current lifecycle state of the inspection event. Tracks progression from scheduling through completion or cancellation.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorAuthority rdf:type rdf:Property ;
    rdfs:label 'Inspector Authority' ;
    rdfs:comment 'The organization or regulatory body under whose authority the inspection was conducted (e.g., DOT, ICAO, IMO, internal fleet safety team, third-party auditor).' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Inspector Certification Number' ;
    rdfs:comment 'Official certification or license number of the inspector, required for regulatory inspections to validate inspector qualifications.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorName rdf:type rdf:Property ;
    rdfs:label 'Inspector Name' ;
    rdfs:comment 'Full name of the individual who conducted the inspection. May be an internal employee or external regulatory authority representative.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:odometerReadingAtInspection rdf:type rdf:Property ;
    rdfs:label 'Odometer Reading At Inspection' ;
    rdfs:comment 'Odometer or usage meter reading (kilometers, miles, flight hours, engine hours) recorded at the time of inspection. Used for maintenance interval tracking.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outOfServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Out Of Service Flag' ;
    rdfs:comment 'Indicates whether the asset was placed out of service as a result of this inspection due to critical safety defects or regulatory non-compliance.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outOfServiceStartDate rdf:type rdf:Property ;
    rdfs:label 'Out Of Service Start Date' ;
    rdfs:comment 'The date the asset was officially placed out of service following the inspection. Null if asset was not taken out of service.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryCertificateIssued rdf:type rdf:Property ;
    rdfs:label 'Regulatory Certificate Issued' ;
    rdfs:comment 'Name or type of regulatory certificate, permit, or compliance document issued as a result of passing this inspection (e.g., DOT Annual Inspection Certificate, ICAO Certificate of Airworthiness, IMO Safety Equipment Certificate).' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Reinspection Due Date' ;
    rdfs:comment 'The date by which the reinspection must be conducted to verify corrective action completion. Null if no reinspection is required.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reinspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Reinspection Required Flag' ;
    rdfs:comment 'Indicates whether a follow-up reinspection is required to verify that corrective actions have been completed and defects resolved.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assetLicenceId rdf:type rdf:Property ;
    rdfs:label 'Asset Licence Id' ;
    rdfs:comment 'Unique identifier for the asset licence record. Primary key.' ;
    rdfs:domain ind:AssetLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endorsements rdf:type rdf:Property ;
    rdfs:label 'Endorsements' ;
    rdfs:comment 'Additional endorsements, restrictions, or special conditions attached to the licence (e.g., hazmat endorsement, night flight restriction, coastal waters only). Free-text field for regulatory notes.' ;
    rdfs:domain ind:AssetLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionAuthority rdf:type rdf:Property ;
    rdfs:label 'Inspection Authority' ;
    rdfs:comment 'Name of the agency or third-party organization authorized to conduct inspections for this licence (e.g., FAA Designated Airworthiness Representative, Port State Control Inspector).' ;
    rdfs:domain ind:AssetLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Inspection Required Flag' ;
    rdfs:comment 'Indicates whether a physical inspection or audit by the regulatory authority is required as part of the licence issuance or renewal process. True = inspection required; False = no inspection required.' ;
    rdfs:domain ind:AssetLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'Specific jurisdiction, state, province, or region within the issuing country where the licence is valid (e.g., California, Ontario, Bavaria). Null if the licence is valid nationwide.' ;
    rdfs:domain ind:AssetLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenceCategory rdf:type rdf:Property ;
    rdfs:label 'Licence Category' ;
    rdfs:comment 'Sub-classification or category code within the licence type (e.g., for vehicle registration: commercial, private, heavy goods; for airworthiness: transport category, restricted category).' ;
    rdfs:domain ind:AssetLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenceClass rdf:type rdf:Property ;
    rdfs:label 'Licence Class' ;
    rdfs:comment 'Class designation within the licence category, defining specific operational limits or capabilities (e.g., Class 1 for heavy trucks, Class A for multi-engine aircraft).' ;
    rdfs:domain ind:AssetLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenceFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Licence Fee Amount' ;
    rdfs:comment 'Total fee paid to the issuing authority for the issuance or renewal of this licence. Excludes taxes and processing charges.' ;
    rdfs:domain ind:AssetLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:licenceFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Licence Fee Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the licence fee amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:AssetLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenceNumber rdf:type rdf:Property ;
    rdfs:label 'Licence Number' ;
    rdfs:comment 'The official licence, permit, or certificate number issued by the regulatory authority. This is the externally-known unique identifier for the licence.' ;
    rdfs:domain ind:AssetLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenceType rdf:type rdf:Property ;
    rdfs:label 'Licence Type' ;
    rdfs:comment 'Classification of the licence or permit. Defines the regulatory purpose and scope of the licence (e.g., vehicle registration for road use, airworthiness certificate for aircraft operation, dangerous goods permit for hazardous cargo transport). [ENUM-REF-CANDIDATE: vehicle_registration|operating_licence|airworthiness_certificate|vessel_class_certificate|dangerous_goods_permit|oversize_overweight_permit|cross_border_transit_permit|emission_certificate|insurance_certificate|roadworthiness_certificate — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssetLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Citation of the specific regulation, statute, or legal framework under which this licence is issued (e.g., 49 CFR Part 383, ICAO Annex 8, SOLAS Chapter II-1).' ;
    rdfs:domain ind:AssetLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalReminderDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Reminder Days' ;
    rdfs:comment 'Number of days before expiry_date when automated renewal reminders should be triggered to fleet managers and compliance officers.' ;
    rdfs:domain ind:AssetLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validityStatus rdf:type rdf:Property ;
    rdfs:label 'Validity Status' ;
    rdfs:comment 'Current validity state of the licence. Indicates whether the asset is legally compliant to operate under this licence. Valid = currently active and compliant; Expired = past expiry date; Suspended = temporarily invalid; Revoked = permanently cancelled; Pending Renewal = renewal application submitted; Pending Approval = initial application under review.' ;
    rdfs:domain ind:AssetLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetDamageCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Asset Damage Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the asset damage estimated cost (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetDamageEstimatedCost rdf:type rdf:Property ;
    rdfs:label 'Asset Damage Estimated Cost' ;
    rdfs:comment 'Estimated cost of damage to the transport asset (vehicle, aircraft, vessel, container) in the incident currency. Includes repair or replacement costs.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoDamageCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cargo Damage Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the cargo damage estimated cost (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoDamageEstimatedCost rdf:type rdf:Property ;
    rdfs:label 'Cargo Damage Estimated Cost' ;
    rdfs:comment 'Estimated cost of damage to cargo or goods in the incident currency. Used for cargo claim processing.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoDamageFlag rdf:type rdf:Property ;
    rdfs:label 'Cargo Damage Flag' ;
    rdfs:comment 'Indicates whether cargo or goods being transported were damaged in the incident. True if cargo damaged, False otherwise.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Detailed description of corrective actions taken or planned to prevent recurrence, including training, maintenance, policy changes, or process improvements.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required Flag' ;
    rdfs:comment 'Indicates whether corrective actions are required to prevent recurrence of similar incidents. True if corrective actions required, False otherwise.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionStatus rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Status' ;
    rdfs:comment 'Current status of corrective actions identified for this incident. Not_required: no actions needed. Pending: actions identified but not started. In_progress: actions being implemented. Completed: all actions finished. Overdue: actions past due date.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:datetime rdf:type rdf:Property ;
    rdfs:label 'Datetime' ;
    rdfs:comment 'The date and time when the incident occurred in the field. This is the real-world event timestamp, distinct from when the incident was reported or recorded in the system.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dotReportSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Dot Report Submitted Date' ;
    rdfs:comment 'Date when the DOT accident report was submitted to the regulatory authority (if applicable).' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dotReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Dot Reportable Flag' ;
    rdfs:comment 'Indicates whether this incident meets the US Department of Transportation (DOT) criteria for mandatory accident reporting. True if DOT reportable, False otherwise.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fatalityCount rdf:type rdf:Property ;
    rdfs:label 'Fatality Count' ;
    rdfs:comment 'Total number of fatalities resulting from the incident.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incidentNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Number' ;
    rdfs:comment 'Externally-visible unique incident reference number used for tracking and reporting. Format: INC-XXXXXXXXXX.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentStatus rdf:type rdf:Property ;
    rdfs:label 'Incident Status' ;
    rdfs:comment 'Current lifecycle status of the incident record. Reported: initial notification received. Under_investigation: active investigation in progress. Pending_review: investigation complete, awaiting management review. Closed: incident resolved and closed. Reopened: closed incident reopened for additional investigation.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentType rdf:type rdf:Property ;
    rdfs:label 'Incident Type' ;
    rdfs:comment 'Classification of the incident: accident (collision or crash), near_miss (potential accident avoided), breakdown (mechanical failure), cargo_damage (damage to goods), security_incident (unauthorized access or threat), theft (asset or cargo stolen).' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuriesReportedFlag rdf:type rdf:Property ;
    rdfs:label 'Injuries Reported Flag' ;
    rdfs:comment 'Indicates whether any injuries (to driver, passengers, or third parties) were reported as a result of the incident. True if injuries reported, False otherwise.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:injuryCount rdf:type rdf:Property ;
    rdfs:label 'Injury Count' ;
    rdfs:comment 'Total number of individuals injured in the incident, including driver, passengers, and third parties.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:investigationAssignedTo rdf:type rdf:Property ;
    rdfs:label 'Investigation Assigned To' ;
    rdfs:comment 'Name or identifier of the safety officer, manager, or team assigned to investigate this incident.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Completed Date' ;
    rdfs:comment 'Date when the incident investigation was completed and findings documented.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationAddress rdf:type rdf:Property ;
    rdfs:label 'Location Address' ;
    rdfs:comment 'Human-readable street address or location description where the incident occurred. May include route number, mile marker, or landmark.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policeDepartment rdf:type rdf:Property ;
    rdfs:label 'Police Department' ;
    rdfs:comment 'Name of the law enforcement agency or police department that responded to the incident.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policeReportFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Police Report Filed Flag' ;
    rdfs:comment 'Indicates whether a police report was filed for this incident. True if police report filed, False otherwise.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policeReportNumber rdf:type rdf:Property ;
    rdfs:label 'Police Report Number' ;
    rdfs:comment 'Official police report or case number assigned by law enforcement agency (if applicable).' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedDatetime rdf:type rdf:Property ;
    rdfs:label 'Reported Datetime' ;
    rdfs:comment 'The date and time when the incident was first reported to the fleet management system or control center.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Severity classification of the incident based on impact to personnel, asset, cargo, and operations. Minor: no injuries, minimal damage. Moderate: minor injuries, moderate damage. Major: serious injuries, significant damage. Critical: fatalities or catastrophic damage.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyContact rdf:type rdf:Property ;
    rdfs:label 'Third Party Contact' ;
    rdfs:comment 'Contact phone number or email address for the third party involved in the incident.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyInsuranceProvider rdf:type rdf:Property ;
    rdfs:label 'Third Party Insurance Provider' ;
    rdfs:comment 'Name of the insurance company covering the third party involved in the incident.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyInvolvedFlag rdf:type rdf:Property ;
    rdfs:label 'Third Party Involved Flag' ;
    rdfs:comment 'Indicates whether a third party (another vehicle, pedestrian, property owner, or external entity) was involved in the incident. True if third party involved, False otherwise.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdPartyName rdf:type rdf:Property ;
    rdfs:label 'Third Party Name' ;
    rdfs:comment 'Name of the third party individual or organization involved in the incident (if applicable).' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyPolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Third Party Policy Number' ;
    rdfs:comment 'Insurance policy number of the third party involved in the incident.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetUtilisationId rdf:type rdf:Property ;
    rdfs:label 'Asset Utilisation Id' ;
    rdfs:comment 'Unique identifier for the asset utilisation record. Primary key for this operational snapshot.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeCommitmentId rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Id' ;
    rdfs:comment 'Foreign key linking to contract.contract_volume_commitment. Business justification: Volume commitment tracking: fleet utilisation records (actual TEUs, weight, trips) are the source data for measuring attainment against contracted volume commitments. This link enables automated short' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VolumeCommitment .

ind:actualPayloadKg rdf:type rdf:Property ;
    rdfs:label 'Actual Payload Kg' ;
    rdfs:comment 'Total actual payload weight carried by the asset during the reporting period, measured in kilograms.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Regulatory compliance status of the asset during the reporting period. Indicates whether the asset met Department of Transportation (DOT), International Civil Aviation Organization (ICAO), International Maritime Organization (IMO), or other applicable regulatory requirements.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distanceTravelledKm rdf:type rdf:Property ;
    rdfs:label 'Distance Travelled Km' ;
    rdfs:comment 'Total distance travelled by the asset during the reporting period, measured in kilometers. Captured from GPS (Global Positioning System) telematics or odometer readings.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distanceTravelledMiles rdf:type rdf:Property ;
    rdfs:label 'Distance Travelled Miles' ;
    rdfs:comment 'Total distance travelled by the asset during the reporting period, measured in miles. Provided for regions using imperial units.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelEfficiencyLitersPer100km rdf:type rdf:Property ;
    rdfs:label 'Fuel Efficiency Liters Per 100km' ;
    rdfs:comment 'Fuel efficiency metric representing liters consumed per 100 kilometers travelled. Key operational expense (OPEX) and sustainability metric.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelEfficiencyMpg rdf:type rdf:Property ;
    rdfs:label 'Fuel Efficiency Mpg' ;
    rdfs:comment 'Fuel efficiency metric representing miles per gallon (MPG). Provided for regions using imperial units.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loadFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Load Factor Percent' ;
    rdfs:comment 'Percentage representing the ratio of actual payload to maximum payload capacity. Key performance indicator (KPI) for asset efficiency.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfTrips rdf:type rdf:Property ;
    rdfs:label 'Number Of Trips' ;
    rdfs:comment 'Total count of completed trips or delivery runs performed by the asset during the reporting period.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onTimeDeliveryRatePercent rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Rate Percent' ;
    rdfs:comment 'Percentage of trips completed on time during the reporting period. Key service level agreement (SLA) metric for customer satisfaction.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingCost rdf:type rdf:Property ;
    rdfs:label 'Operating Cost' ;
    rdfs:comment 'Total operating expenditure (OPEX) incurred by the asset during the reporting period, including fuel, maintenance, tolls, and driver costs.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingPeriodDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Date' ;
    rdfs:comment 'The date for which this utilisation snapshot is recorded. Represents the business event date for daily or weekly operational reporting.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueGenerated rdf:type rdf:Property ;
    rdfs:label 'Revenue Generated' ;
    rdfs:comment 'Total revenue generated by the asset during the reporting period. Used for profitability and return on investment (ROI) analysis.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyIncidentsCount rdf:type rdf:Property ;
    rdfs:label 'Safety Incidents Count' ;
    rdfs:comment 'Total number of safety incidents or accidents involving the asset during the reporting period. Critical for risk management and insurance reporting.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:telematicsDataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Telematics Data Quality Score' ;
    rdfs:comment 'Quality score (0-100) representing the completeness and accuracy of GPS (Global Positioning System) telematics and Internet of Things (IoT) sensor data captured during the reporting period. Used to assess data reliability for analytics.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAvailableHours rdf:type rdf:Property ;
    rdfs:label 'Total Available Hours' ;
    rdfs:comment 'Total number of hours the asset was available for operational use during the reporting period, excluding scheduled downtime.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalBreakdownHours rdf:type rdf:Property ;
    rdfs:label 'Total Breakdown Hours' ;
    rdfs:comment 'Total number of hours the asset was unavailable due to unplanned breakdowns or failures during the reporting period.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDowntimeHours rdf:type rdf:Property ;
    rdfs:label 'Total Downtime Hours' ;
    rdfs:comment 'Total number of hours the asset was out of service during the reporting period, combining maintenance and breakdown hours.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalIdleHours rdf:type rdf:Property ;
    rdfs:label 'Total Idle Hours' ;
    rdfs:comment 'Total number of hours the asset was idle (available but not in use) during the reporting period.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalMaintenanceHours rdf:type rdf:Property ;
    rdfs:label 'Total Maintenance Hours' ;
    rdfs:comment 'Total number of hours the asset was undergoing scheduled or preventive maintenance during the reporting period.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOperationalHours rdf:type rdf:Property ;
    rdfs:label 'Total Operational Hours' ;
    rdfs:comment 'Total number of hours the asset was actively in operation (moving, transporting cargo, or performing its primary function) during the reporting period.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilisationRatePercent rdf:type rdf:Property ;
    rdfs:label 'Utilisation Rate Percent' ;
    rdfs:comment 'Overall utilisation rate calculated as the ratio of operational hours to available hours, expressed as a percentage. Primary KPI for fleet management decisions.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeUtilisedCbm rdf:type rdf:Property ;
    rdfs:label 'Volume Utilised Cbm' ;
    rdfs:comment 'Total cargo volume utilised during the reporting period, measured in cubic meters (CBM). Relevant for container and warehouse assets.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissioningDate rdf:type rdf:Property ;
    rdfs:label 'Commissioning Date' ;
    rdfs:comment 'Date when the depot was officially commissioned and began operational service for fleet management activities.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:containerCapacityTeu rdf:type rdf:Property ;
    rdfs:label 'Container Capacity Teu' ;
    rdfs:comment 'Maximum container storage capacity expressed in TEU (Twenty-foot Equivalent Units), applicable for container yards and ICDs.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coveredAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Covered Area Sqm' ;
    rdfs:comment 'Total covered or indoor area of the depot measured in square meters, including maintenance workshops, warehouses, and covered parking structures.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsBondedFacilityFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Bonded Facility Flag' ;
    rdfs:comment 'Indicates whether this depot is a customs-bonded facility authorized to store goods under customs supervision without immediate duty payment. Applicable for ICDs and container yards handling international freight.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decommissioningDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioning Date' ;
    rdfs:comment 'Date when the depot was or is planned to be decommissioned and removed from active operational service.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depotCode rdf:type rdf:Property ;
    rdfs:label 'Depot Code' ;
    rdfs:comment 'Unique business identifier code for the depot used across operational systems and documentation. Typically a short alphanumeric code assigned by the business.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depotName rdf:type rdf:Property ;
    rdfs:label 'Depot Name' ;
    rdfs:comment 'Full business name of the fleet depot, vehicle yard, maintenance workshop, or staging area.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depotType rdf:type rdf:Property ;
    rdfs:label 'Depot Type' ;
    rdfs:comment 'Classification of the depot based on its primary operational function. Vehicle depot for fleet parking and assignment, maintenance workshop for repairs and servicing, fuel station for refueling operations, container yard for container storage, inland container depot (ICD) for customs clearance and container handling, or staging area for temporary asset holding.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electricChargingStations rdf:type rdf:Property ;
    rdfs:label 'Electric Charging Stations' ;
    rdfs:comment 'Number of electric vehicle charging stations available at this depot for electric and hybrid fleet assets.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:environmentalCertification rdf:type rdf:Property ;
    rdfs:label 'Environmental Certification' ;
    rdfs:comment 'Environmental management system certification held by the depot (e.g., ISO 14001, LEED certification) demonstrating compliance with sustainability and environmental protection standards.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelTypesAvailable rdf:type rdf:Property ;
    rdfs:label 'Fuel Types Available' ;
    rdfs:comment 'Comma-separated list of fuel types available at this depot for refueling operations (e.g., diesel, petrol, CNG, LNG, electric charging).' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceBays rdf:type rdf:Property ;
    rdfs:label 'Maintenance Bays' ;
    rdfs:comment 'Number of maintenance bays or service stations available at this depot for vehicle and equipment servicing and repairs.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managingBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Managing Business Unit' ;
    rdfs:comment 'Name or code of the business unit, division, or department responsible for managing and operating this depot.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operates247Flag rdf:type rdf:Property ;
    rdfs:label 'Operates 24 7 Flag' ;
    rdfs:comment 'Indicates whether the depot operates continuously 24 hours a day, 7 days a week. True for round-the-clock operations, False for limited operating hours.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Business-defined geographic region or territory to which this depot belongs for organizational reporting and management purposes.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Total Area Sqm' ;
    rdfs:comment 'Total land area of the depot facility measured in square meters, including parking areas, buildings, maintenance bays, and storage yards.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleCapacity rdf:type rdf:Property ;
    rdfs:label 'Vehicle Capacity' ;
    rdfs:comment 'Maximum number of vehicles (trucks, vans, cars) that can be parked or stored at this depot simultaneously.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetCategory rdf:type rdf:Property ;
    rdfs:label 'Asset Category' ;
    rdfs:comment 'High-level classification of the asset type: road vehicle, aircraft, vessel, rail unit, container, Unit Load Device (ULD), or handling equipment. [ENUM-REF-CANDIDATE: road_vehicle|aircraft|vessel|rail_unit|container|uld|handling_equipment — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetSubcategory rdf:type rdf:Property ;
    rdfs:label 'Asset Subcategory' ;
    rdfs:comment 'Detailed subcategory within the asset category (e.g., rigid truck, articulated truck, cargo aircraft, container ship, flatcar, dry container, reefer container). [ENUM-REF-CANDIDATE: rigid_truck|articulated_truck|van|cargo_aircraft|passenger_aircraft|container_ship|bulk_carrier|tanker|flatcar|boxcar|dry_container|reefer_container|tank_container|flat_rack|open_top|pallet|igloo_uld|forklift|reach_stacker — promote to reference product]' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTypeCode rdf:type rdf:Property ;
    rdfs:label 'Asset Type Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the asset type (e.g., TRUCK-RIG, CARGO-AC, CONT-20FT). Used as business identifier across systems.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Type Description' ;
    rdfs:comment 'Detailed description of the asset type, including technical specifications, typical use cases, and operational characteristics.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTypeName rdf:type rdf:Property ;
    rdfs:label 'Asset Type Name' ;
    rdfs:comment 'Full descriptive name of the asset type (e.g., Rigid Truck, Cargo Aircraft, Twenty-Foot Container).' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTypeStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Type Status' ;
    rdfs:comment 'Current lifecycle status of this asset type classification: active (in use), inactive (no longer procured but existing assets remain), deprecated (phased out), or under review.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageAcquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Average Acquisition Cost' ;
    rdfs:comment 'Average acquisition cost for this asset type in the base currency, used for budgeting and Capital Expenditure (CAPEX) planning.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationIntervalMonths rdf:type rdf:Property ;
    rdfs:label 'Certification Interval Months' ;
    rdfs:comment 'Standard interval in months between required certifications for this asset type (e.g., 60 months for CSC container certification).' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Required Flag' ;
    rdfs:comment 'Indicates whether this asset type requires periodic regulatory certification (e.g., CSC for containers, airworthiness for aircraft).' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:depreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method' ;
    rdfs:comment 'Standard depreciation method applied to this asset type for financial reporting: straight-line, declining balance, units of production, or not applicable.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Dot Classification Code' ;
    rdfs:comment 'US DOT standard classification code for road vehicles and rail units, used for regulatory compliance and safety reporting.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Date on which this asset type classification was retired or deprecated. Null for active asset types.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fuelTypeStandard rdf:type rdf:Property ;
    rdfs:label 'Fuel Type Standard' ;
    rdfs:comment 'Standard fuel or energy type used by this asset type: diesel, gasoline, electric, hybrid, Liquefied Natural Gas (LNG), Compressed Natural Gas (CNG), hydrogen, or jet fuel. [ENUM-REF-CANDIDATE: diesel|gasoline|electric|hybrid|lng|cng|hydrogen|jet_fuel — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Capable Flag' ;
    rdfs:comment 'Indicates whether this asset type is certified and equipped to transport hazardous materials under IMDG Code or ICAO Technical Instructions.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iataClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Iata Classification Code' ;
    rdfs:comment 'IATA standard classification code for aircraft and ULD types, used for air freight operations and regulatory compliance.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imoClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Imo Classification Code' ;
    rdfs:comment 'IMO standard classification code for vessel types, used for maritime operations and regulatory compliance.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoContainerCode rdf:type rdf:Property ;
    rdfs:label 'Iso Container Code' ;
    rdfs:comment 'ISO 6346 standard container type code (e.g., 22G1 for 20ft dry container, 45R1 for 40ft reefer).' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Maintenance Interval Days' ;
    rdfs:comment 'Typical scheduled maintenance interval in days for this asset type under normal operating conditions.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenanceIntervalHours rdf:type rdf:Property ;
    rdfs:label 'Maintenance Interval Hours' ;
    rdfs:comment 'Typical scheduled maintenance interval in operating hours for this asset type (primarily for aircraft and vessels).' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenanceIntervalKm rdf:type rdf:Property ;
    rdfs:label 'Maintenance Interval Km' ;
    rdfs:comment 'Typical scheduled maintenance interval in kilometers or nautical miles for this asset type.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownershipModel rdf:type rdf:Property ;
    rdfs:label 'Ownership Model' ;
    rdfs:comment 'Typical ownership model for this asset type: owned (company-owned), leased (operating or finance lease), mixed, or third-party (contracted).' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'Primary regulatory framework governing this asset type: Department of Transportation (DOT), International Civil Aviation Organization (ICAO), International Maritime Organization (IMO), ISO standards, Federal Maritime Commission (FMC), or mixed.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidTaggingStandardFlag rdf:type rdf:Property ;
    rdfs:label 'Rfid Tagging Standard Flag' ;
    rdfs:comment 'Indicates whether this asset type is standardly equipped with RFID tags for automated identification and tracking.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardHeightM rdf:type rdf:Property ;
    rdfs:label 'Standard Height M' ;
    rdfs:comment 'Standard height dimension in meters for this asset type.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardLengthM rdf:type rdf:Property ;
    rdfs:label 'Standard Length M' ;
    rdfs:comment 'Standard length dimension in meters for this asset type.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardPayloadCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Standard Payload Capacity Kg' ;
    rdfs:comment 'Standard maximum payload capacity in kilograms for this asset type under normal operating conditions.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardTemperatureRangeMaxC rdf:type rdf:Property ;
    rdfs:label 'Standard Temperature Range Max C' ;
    rdfs:comment 'Maximum temperature in Celsius that this asset type can maintain (for temperature-controlled assets).' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardTemperatureRangeMinC rdf:type rdf:Property ;
    rdfs:label 'Standard Temperature Range Min C' ;
    rdfs:comment 'Minimum temperature in Celsius that this asset type can maintain (for temperature-controlled assets).' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardTeuCapacity rdf:type rdf:Property ;
    rdfs:label 'Standard Teu Capacity' ;
    rdfs:comment 'Standard capacity measured in Twenty-foot Equivalent Units (TEU), primarily used for vessels and rail units.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardUsefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Standard Useful Life Years' ;
    rdfs:comment 'Standard useful life in years for this asset type, used for depreciation and Capital Expenditure (CAPEX) planning.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardVolumeCapacityCbm rdf:type rdf:Property ;
    rdfs:label 'Standard Volume Capacity Cbm' ;
    rdfs:comment 'Standard internal volume capacity in cubic meters (CBM) for cargo storage.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardWidthM rdf:type rdf:Property ;
    rdfs:label 'Standard Width M' ;
    rdfs:comment 'Standard width dimension in meters for this asset type.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:telematicsCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Telematics Capable Flag' ;
    rdfs:comment 'Indicates whether this asset type is typically equipped with GPS telematics and IoT sensor capabilities for real-time tracking.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentAgreementId rdf:type rdf:Property ;
    rdfs:label 'Parent Agreement Id' ;
    rdfs:comment 'Reference to the parent or master agreement if this is a subsidiary or regional agreement. Enables hierarchical agreement structures and consolidated reporting.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known unique business identifier for the agreement, used in communications and documentation. Typically alphanumeric code assigned at contract creation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle state of the agreement. Controls whether the agreement is enforceable and governs operational behavior in pricing, billing, and service execution systems. [ENUM-REF-CANDIDATE: draft|pending_approval|active|suspended|terminated|expired|renewed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractTier rdf:type rdf:Property ;
    rdfs:label 'Contract Tier' ;
    rdfs:comment 'Classification tier indicating the strategic importance, service level, or pricing category of the agreement. Influences service level agreement (SLA) thresholds, priority handling, and discount structures.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Jurisdiction' ;
    rdfs:comment 'Three-letter ISO country code representing the legal jurisdiction under which the agreement is governed. Determines applicable laws, dispute resolution mechanisms, and regulatory compliance requirements.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveClauseDescription rdf:type rdf:Property ;
    rdfs:label 'Incentive Clause Description' ;
    rdfs:comment 'Textual description of incentive terms applicable when service level agreement (SLA) targets are exceeded or volume commitments are surpassed. Defines rewards, rebates, or preferential terms.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermDays rdf:type rdf:Property ;
    rdfs:label 'Payment Term Days' ;
    rdfs:comment 'Number of days allowed for payment after invoice date as per agreement terms. Used for accounts receivable (AR) and accounts payable (AP) management, cash flow forecasting, and dunning processes.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:penaltyClauseDescription rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause Description' ;
    rdfs:comment 'Textual description of penalty terms applicable when service level agreement (SLA) thresholds are not met or volume commitments are breached. Defines financial or operational consequences.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalCount rdf:type rdf:Property ;
    rdfs:label 'Renewal Count' ;
    rdfs:comment 'Number of times the agreement has been renewed. Indicates relationship longevity and stability, used for customer lifetime value (LTV) analysis and retention metrics.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signatoryPartyCounterparty rdf:type rdf:Property ;
    rdfs:label 'Signatory Party Counterparty' ;
    rdfs:comment 'Name of the counterparty signatory representing the customer, carrier, vendor, or partner organization in the agreement.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryPartyPrimary rdf:type rdf:Property ;
    rdfs:label 'Signatory Party Primary' ;
    rdfs:comment 'Name of the primary signatory party representing Transport Shipping in the agreement. Typically an authorized officer or legal representative.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaOtdTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Sla Otd Target Percent' ;
    rdfs:comment 'Target percentage for on-time delivery (OTD) key performance indicator (KPI) as committed in the agreement. Measured against actual delivery performance for compliance and penalty/incentive calculations.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaOtifTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Sla Otif Target Percent' ;
    rdfs:comment 'Target percentage for on-time in-full (OTIF) key performance indicator (KPI) as committed in the agreement. Combines delivery timeliness and order completeness for comprehensive service measurement.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeCommitmentTeu rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Teu' ;
    rdfs:comment 'Committed volume in twenty-foot equivalent units (TEU) for ocean freight agreements. Used for capacity planning, rate negotiation, and performance tracking against commitments.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeCommitmentWeightKg rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Weight Kg' ;
    rdfs:comment 'Committed volume in kilograms for air freight or road freight agreements. Basis for rate calculations, capacity allocation, and incentive/penalty clause evaluation.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supersededByVersionAgreementVersionId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Version Agreement Version Id' ;
    rdfs:comment 'Reference to the newer agreement version that replaced this version. Nullable for the current active version. Enables version chain navigation.' ;
    rdfs:domain ind:AgreementVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AgreementVersion .

ind:amendmentType rdf:type rdf:Property ;
    rdfs:label 'Amendment Type' ;
    rdfs:comment 'Classification of the version change: initial (first version), renewal (contract renewal), addendum (supplemental terms), amendment (modification), termination (contract end), extension (time extension).' ;
    rdfs:domain ind:AgreementVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalAction rdf:type rdf:Property ;
    rdfs:label 'Approval Action' ;
    rdfs:comment 'Action taken by the approver at the current workflow stage: approved (authorized to proceed), rejected (denied), returned (sent back for revision), pending (awaiting decision).' ;
    rdfs:domain ind:AgreementVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalComments rdf:type rdf:Property ;
    rdfs:label 'Approval Comments' ;
    rdfs:comment 'Free-text comments or notes provided by the approver during the review process. Captures feedback, conditions, or reasons for approval/rejection.' ;
    rdfs:domain ind:AgreementVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedApprover rdf:type rdf:Property ;
    rdfs:label 'Assigned Approver' ;
    rdfs:comment 'Name or identifier of the individual or role currently responsible for reviewing and approving this version at the current workflow stage. May be a user ID, email, or role name.' ;
    rdfs:domain ind:AgreementVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedSignatory rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory' ;
    rdfs:comment 'Name or identifier of the individual with legal authority to sign and execute this version on behalf of the organization. Must have appropriate delegation of authority.' ;
    rdfs:domain ind:AgreementVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReason rdf:type rdf:Property ;
    rdfs:label 'Change Reason' ;
    rdfs:comment 'Business justification or trigger for creating this version: regulatory compliance update, rate adjustment, scope expansion, customer request, General Rate Increase (GRI), Bunker Adjustment Factor (BAF) change, or other commercial reasons.' ;
    rdfs:domain ind:AgreementVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeSummary rdf:type rdf:Property ;
    rdfs:label 'Change Summary' ;
    rdfs:comment 'High-level description of what changed in this version compared to the previous version. Captures key modifications, additions, or deletions to terms, rates, Service Level Agreement (SLA) thresholds, or scope.' ;
    rdfs:domain ind:AgreementVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Date' ;
    rdfs:comment 'Date when compliance review was completed for this version. Nullable if review is not required or still pending.' ;
    rdfs:domain ind:AgreementVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Required' ;
    rdfs:comment 'Indicates whether this version requires formal compliance review due to regulatory impact, cross-border terms, Customs-Trade Partnership Against Terrorism (C-TPAT) requirements, or Authorized Economic Operator (AEO) obligations.' ;
    rdfs:domain ind:AgreementVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceReviewer rdf:type rdf:Property ;
    rdfs:label 'Compliance Reviewer' ;
    rdfs:comment 'Name or identifier of the compliance officer or team who reviewed this version for regulatory adherence.' ;
    rdfs:domain ind:AgreementVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Counterparty Execution Date' ;
    rdfs:comment 'Date when the counterparty signed this version. May differ from internal execution date in sequential signing workflows.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:counterpartySignatory rdf:type rdf:Property ;
    rdfs:label 'Counterparty Signatory' ;
    rdfs:comment 'Name or identifier of the authorized representative from the counterparty (customer, carrier, Third-Party Logistics (3PL), vendor) who signed this version.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentFormat rdf:type rdf:Property ;
    rdfs:label 'Document Format' ;
    rdfs:comment 'File format of the contract document: PDF, Word (DOCX), XML, Electronic Data Interchange (EDI) message, scanned image, or other format.' ;
    rdfs:domain ind:AgreementVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'Date when this version was fully executed (signed by all parties). Marks the transition from approved to legally binding status.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationDate rdf:type rdf:Property ;
    rdfs:label 'Notification Date' ;
    rdfs:comment 'Date when notification of this version change was sent to stakeholders. Nullable if notification is not required or not yet sent.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:soxAuthorizationControl rdf:type rdf:Property ;
    rdfs:label 'Sox Authorization Control' ;
    rdfs:comment 'SOX-compliant authorization control identifier or audit trail reference ensuring segregation of duties and proper financial controls for contract approvals. Required for contracts with financial impact.' ;
    rdfs:domain ind:AgreementVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededDate rdf:type rdf:Property ;
    rdfs:label 'Superseded Date' ;
    rdfs:comment 'Date when this version was superseded by a newer version and ceased to be the active version. Nullable for current active version.' ;
    rdfs:domain ind:AgreementVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:versionHash rdf:type rdf:Property ;
    rdfs:label 'Version Hash' ;
    rdfs:comment 'Cryptographic hash or checksum of the contract document for this version. Ensures document integrity and detects unauthorized modifications.' ;
    rdfs:domain ind:AgreementVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionStatus rdf:type rdf:Property ;
    rdfs:label 'Version Status' ;
    rdfs:comment 'Current lifecycle status of this agreement version: draft (being prepared), pending_review (under review), approved (authorized but not signed), executed (signed and active), superseded (replaced by newer version), cancelled (voided).' ;
    rdfs:domain ind:AgreementVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowStage rdf:type rdf:Property ;
    rdfs:label 'Workflow Stage' ;
    rdfs:comment 'Current stage in the approval workflow: draft (initial preparation), legal_review (legal department review), commercial_review (business unit review), finance_review (financial approval), executive_approval (C-level sign-off), executed (fully signed and active).' ;
    rdfs:domain ind:AgreementVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineValue rdf:type rdf:Property ;
    rdfs:label 'Baseline Value' ;
    rdfs:comment 'The historical or initial baseline performance value used as a reference point for improvement targets. Nullable if no baseline is established.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceTrackingFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Tracking Flag' ;
    rdfs:comment 'Indicates whether this SLA commitment is actively tracked for compliance and reporting (True) or is informational only (False).' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractSlaCommitmentStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Sla Commitment Status' ;
    rdfs:comment 'Current lifecycle status of the SLA commitment: active (in force), inactive (not currently enforced), suspended (temporarily paused), expired (past effective-to date), superseded (replaced by newer commitment), or draft (not yet finalized).' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationProcedure rdf:type rdf:Property ;
    rdfs:label 'Escalation Procedure' ;
    rdfs:comment 'Description of the escalation process or contact procedure when SLA thresholds are breached. Free-text field.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveAmount rdf:type rdf:Property ;
    rdfs:label 'Incentive Amount' ;
    rdfs:comment 'The financial incentive or bonus amount awarded per occurrence or period when the SLA target is exceeded. Nullable if no incentive applies.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentiveClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Incentive Clause Flag' ;
    rdfs:comment 'Indicates whether an incentive or bonus clause is associated with exceeding this SLA commitment (True) or not (False).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kpiMetric rdf:type rdf:Property ;
    rdfs:label 'Kpi Metric' ;
    rdfs:comment 'The specific KPI metric being measured: on-time delivery percentage, on-time in-full percentage, transit time in hours, pickup response time in minutes, claims resolution time in days, customer service response time in hours, delivery accuracy percentage, or customs clearance time in hours. [ENUM-REF-CANDIDATE: on_time_delivery_pct|on_time_in_full_pct|transit_time_hours|pickup_response_minutes|claims_resolution_days|service_response_hours|delivery_accuracy_pct|customs_clearance_hours — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementFrequency rdf:type rdf:Property ;
    rdfs:label 'Measurement Frequency' ;
    rdfs:comment 'How often the SLA performance is measured and reported: daily, weekly, monthly, quarterly, annually, per shipment, or continuous real-time monitoring. [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|annually|per_shipment|continuous — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause Flag' ;
    rdfs:comment 'Indicates whether a penalty clause is associated with failure to meet this SLA commitment (True) or not (False).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Reporting Period' ;
    rdfs:comment 'The time window over which SLA performance is aggregated for reporting: calendar month, rolling 30 days, calendar quarter, rolling 90 days, calendar year, contract year, weekly, or daily. [ENUM-REF-CANDIDATE: calendar_month|rolling_30_days|calendar_quarter|rolling_90_days|calendar_year|contract_year|weekly|daily — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaCode rdf:type rdf:Property ;
    rdfs:label 'Sla Code' ;
    rdfs:comment 'Business identifier or code for the SLA commitment, used for external reference and reporting.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaName rdf:type rdf:Property ;
    rdfs:label 'Sla Name' ;
    rdfs:comment 'Human-readable name or title of the SLA commitment (e.g., \'Express Delivery OTD Target\', \'Freight Transit Time Guarantee\').' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaType rdf:type rdf:Property ;
    rdfs:label 'Sla Type' ;
    rdfs:comment 'Category of SLA commitment: OTD (On-Time Delivery), OTIF (On-Time In-Full), transit time guarantee, pickup window, claims resolution time, customer service response time, delivery window, customs clearance time, or proof of delivery turnaround. [ENUM-REF-CANDIDATE: otd|otif|transit_time|pickup_window|claims_resolution|customer_service_response|delivery_window|customs_clearance|proof_of_delivery — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'The committed target value for the KPI metric (e.g., 95.0 for 95% OTD, 48.0 for 48-hour transit time).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdValue rdf:type rdf:Property ;
    rdfs:label 'Threshold Value' ;
    rdfs:comment 'The minimum acceptable threshold value below which penalties or escalations may apply. Nullable if no threshold is defined.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Sla Performance Id' ;
    rdfs:comment 'Unique identifier for the SLA performance measurement record.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaPerformance .

ind:serviceLaneId rdf:type rdf:Property ;
    rdfs:label 'Service Lane Id' ;
    rdfs:comment 'Reference to the specific service lane or route for which this SLA performance is measured (e.g., USA-EUR air express, Asia-USA ocean FCL).' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lane .

ind:actualValue rdf:type rdf:Property ;
    rdfs:label 'Actual Value' ;
    rdfs:comment 'The actual value achieved during this measurement period (e.g., 92.5 for 92.5% OTD achieved, 9500 for 9,500 TEU delivered).' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attainmentPercentage rdf:type rdf:Property ;
    rdfs:label 'Attainment Percentage' ;
    rdfs:comment 'The percentage of target achieved, calculated as (actual_value / target_value) * 100. Values above 100 indicate over-achievement.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachFlag rdf:type rdf:Property ;
    rdfs:label 'Breach Flag' ;
    rdfs:comment 'Indicates whether the SLA was breached (True) or met (False) during this measurement period. True if actual performance fell below the committed threshold.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breachSeverity rdf:type rdf:Property ;
    rdfs:label 'Breach Severity' ;
    rdfs:comment 'The severity level of the SLA breach, if any. none = no breach, minor = slight miss, moderate = noticeable shortfall, major = significant breach, critical = severe breach triggering penalties.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compliantShipmentCount rdf:type rdf:Property ;
    rdfs:label 'Compliant Shipment Count' ;
    rdfs:comment 'The number of shipments that met the SLA criteria during this measurement period. Used as the numerator for percentage-based SLA calculations.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incentiveApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Incentive Applicable Flag' ;
    rdfs:comment 'Indicates whether a contractual incentive or bonus is applicable for exceeding the SLA target (True) or not (False).' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementCategory rdf:type rdf:Property ;
    rdfs:label 'Measurement Category' ;
    rdfs:comment 'High-level category of the measurement: service_level (OTD, OTIF, transit time), volume_attainment (TEU, kg, CBM, shipment count), quality (damage rate, accuracy), compliance (regulatory adherence).' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Measurement Source System' ;
    rdfs:comment 'The system or platform used to capture and calculate this SLA performance measurement (e.g., SAP TM, Oracle TMS, FourKites, internal BI platform).' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementType rdf:type rdf:Property ;
    rdfs:label 'Measurement Type' ;
    rdfs:comment 'The type of SLA or commitment being measured. OTD = On-Time Delivery, OTIF = On-Time In-Full, transit_time = delivery speed commitment, volume_commitment = shipment count target, weight_commitment = weight volume target, teu_commitment = TEU volume target.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonCompliantShipmentCount rdf:type rdf:Property ;
    rdfs:label 'Non Compliant Shipment Count' ;
    rdfs:comment 'The number of shipments that failed to meet the SLA criteria during this measurement period.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:penaltyApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Applicable Flag' ;
    rdfs:comment 'Indicates whether a contractual penalty is applicable for this SLA breach (True) or not (False). Penalties are typically triggered when performance falls below a defined threshold.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shipmentCountInScope rdf:type rdf:Property ;
    rdfs:label 'Shipment Count In Scope' ;
    rdfs:comment 'The total number of shipments included in this SLA performance measurement period. Used as the denominator for percentage-based SLA calculations.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:variance rdf:type rdf:Property ;
    rdfs:label 'Variance' ;
    rdfs:comment 'The difference between actual and target values (actual_value - target_value). Negative values indicate shortfall; positive values indicate over-achievement.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationZone rdf:type rdf:Property ;
    rdfs:label 'Destination Zone' ;
    rdfs:comment 'Geographic zone or region code for the destination, used in zone-based pricing structures. May represent postal zones, service areas, or custom-defined geographic segments.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distanceBreakMax rdf:type rdf:Property ;
    rdfs:label 'Distance Break Max' ;
    rdfs:comment 'Maximum distance threshold for this rate tier in distance-based pricing structures. Defines the upper bound of the distance bracket.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distanceBreakMin rdf:type rdf:Property ;
    rdfs:label 'Distance Break Min' ;
    rdfs:comment 'Minimum distance threshold for this rate tier in distance-based pricing structures. Rates may vary based on distance brackets.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distanceUom rdf:type rdf:Property ;
    rdfs:label 'Distance Uom' ;
    rdfs:comment 'Unit of measure for distance-based rate calculations. Common units include kilometers (km), miles (mi), or nautical miles (nmi).' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSurchargeRate rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Rate' ;
    rdfs:comment 'Fuel surcharge rate as a percentage or fixed amount applied to the base rate. Commonly known as Bunker Adjustment Factor (BAF) for ocean freight.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originZone rdf:type rdf:Property ;
    rdfs:label 'Origin Zone' ;
    rdfs:comment 'Geographic zone or region code for the origin, used in zone-based pricing structures. May represent postal zones, service areas, or custom-defined geographic segments.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peakSeasonSurchargeRate rdf:type rdf:Property ;
    rdfs:label 'Peak Season Surcharge Rate' ;
    rdfs:comment 'Peak season surcharge rate as a percentage or fixed amount applied during designated peak periods.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateValidityPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Rate Validity Period Days' ;
    rdfs:comment 'Number of days for which this rate schedule remains valid from the effective start date. Used for time-bound promotional rates or short-term agreements.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduleType rdf:type rdf:Property ;
    rdfs:label 'Schedule Type' ;
    rdfs:comment 'Classification of the rate schedule structure, indicating the basis for rate calculation such as lane-level, zone-level, weight-based, volume-based, distance-based, or flat rate.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securitySurchargeRate rdf:type rdf:Property ;
    rdfs:label 'Security Surcharge Rate' ;
    rdfs:comment 'Security surcharge rate as a percentage or fixed amount applied to the base rate.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeBreakMax rdf:type rdf:Property ;
    rdfs:label 'Volume Break Max' ;
    rdfs:comment 'Maximum volume threshold for this rate tier in volume-based pricing structures. Defines the upper bound of the volume bracket.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeBreakMin rdf:type rdf:Property ;
    rdfs:label 'Volume Break Min' ;
    rdfs:comment 'Minimum volume threshold for this rate tier in volume-based pricing structures. Rates may vary based on volume brackets.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supersedesScheduleContractSurchargeScheduleId rdf:type rdf:Property ;
    rdfs:label 'Supersedes Schedule Contract Surcharge Schedule Id' ;
    rdfs:comment 'Reference to the previous surcharge schedule that this version replaces or supersedes. Null if this is the first version.' ;
    rdfs:domain ind:ContractSurchargeSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractSurchargeSchedule .

ind:adjustmentFrequency rdf:type rdf:Property ;
    rdfs:label 'Adjustment Frequency' ;
    rdfs:comment 'Frequency at which the surcharge rate is reviewed and adjusted. Weekly = every week, biweekly = every two weeks, monthly = every month, quarterly = every quarter, annually = once per year, event_driven = adjusted based on specific triggers or market events.' ;
    rdfs:domain ind:ContractSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicabilityCondition rdf:type rdf:Property ;
    rdfs:label 'Applicability Condition' ;
    rdfs:comment 'Business rules or conditions under which this surcharge applies (e.g., specific service types, lanes, origin/destination pairs, shipment characteristics, weight thresholds, or seasonal periods).' ;
    rdfs:domain ind:ContractSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compoundingAllowed rdf:type rdf:Property ;
    rdfs:label 'Compounding Allowed' ;
    rdfs:comment 'Indicates whether this surcharge can be compounded with other surcharges (true) or must be applied independently (false).' ;
    rdfs:domain ind:ContractSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exemptionCriteria rdf:type rdf:Property ;
    rdfs:label 'Exemption Criteria' ;
    rdfs:comment 'Conditions under which shipments are exempt from this surcharge (e.g., specific customer segments, promotional periods, volume commitments, or contractual waivers).' ;
    rdfs:domain ind:ContractSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexReference rdf:type rdf:Property ;
    rdfs:label 'Index Reference' ;
    rdfs:comment 'External index or benchmark used for index-based surcharge calculations (e.g., Platts Bunker Index, DOE Fuel Price Index, market commodity indices). Specifies the source and identifier of the index.' ;
    rdfs:domain ind:ContractSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationLeadDays rdf:type rdf:Property ;
    rdfs:label 'Notification Lead Days' ;
    rdfs:comment 'Number of days in advance that customers must be notified before this surcharge takes effect or is adjusted. Null if notification_required is false.' ;
    rdfs:domain ind:ContractSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationRequired rdf:type rdf:Property ;
    rdfs:label 'Notification Required' ;
    rdfs:comment 'Indicates whether customers must be notified in advance when this surcharge is applied or adjusted (true) or if notification is not required (false).' ;
    rdfs:domain ind:ContractSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryBasis rdf:type rdf:Property ;
    rdfs:label 'Regulatory Basis' ;
    rdfs:comment 'Legal or regulatory framework that mandates or governs this surcharge (e.g., IMO regulations for BAF, government-imposed security fees, environmental levies, or customs-related charges).' ;
    rdfs:domain ind:ContractSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeRate rdf:type rdf:Property ;
    rdfs:label 'Surcharge Rate' ;
    rdfs:comment 'The rate or percentage value used in surcharge calculation. For percentage-based surcharges, this represents the percentage (e.g., 5.5 for 5.5%). For flat or per-unit rates, this represents the monetary amount.' ;
    rdfs:domain ind:ContractSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeThresholdMax rdf:type rdf:Property ;
    rdfs:label 'Volume Threshold Max' ;
    rdfs:comment 'Maximum shipment volume (in CBM or cubic feet) for this surcharge to apply. Null indicates no maximum threshold.' ;
    rdfs:domain ind:ContractSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeThresholdMin rdf:type rdf:Property ;
    rdfs:label 'Volume Threshold Min' ;
    rdfs:comment 'Minimum shipment volume (in CBM or cubic feet) for this surcharge to apply. Null indicates no minimum threshold.' ;
    rdfs:domain ind:ContractSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightThresholdMax rdf:type rdf:Property ;
    rdfs:label 'Weight Threshold Max' ;
    rdfs:comment 'Maximum shipment weight (in the unit specified by weight_threshold_unit) for this surcharge to apply. Null indicates no maximum threshold.' ;
    rdfs:domain ind:ContractSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightThresholdMin rdf:type rdf:Property ;
    rdfs:label 'Weight Threshold Min' ;
    rdfs:comment 'Minimum shipment weight (in the unit specified by weight_threshold_unit) for this surcharge to apply. Null indicates no minimum threshold.' ;
    rdfs:domain ind:ContractSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightThresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Weight Threshold Unit' ;
    rdfs:comment 'Unit of measure for weight thresholds. kg = kilogram, lb = pound, ton = US ton (2000 lbs), metric_ton = metric tonne (1000 kg).' ;
    rdfs:domain ind:ContractSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualVolume rdf:type rdf:Property ;
    rdfs:label 'Actual Volume' ;
    rdfs:comment 'Actual volume utilized or booked against this commitment during the current measurement period. Updated periodically as shipments are executed.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autoRenewFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renew Flag' ;
    rdfs:comment 'Indicates whether this volume commitment automatically renews for the next period upon expiration. True if auto-renewal is enabled, False otherwise.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commitmentCode rdf:type rdf:Property ;
    rdfs:label 'Commitment Code' ;
    rdfs:comment 'Business identifier or code for this volume commitment, used for external reference and reporting.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentNotes rdf:type rdf:Property ;
    rdfs:label 'Commitment Notes' ;
    rdfs:comment 'Free-text notes or comments providing additional context, special conditions, or clarifications regarding this volume commitment.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentPartyType rdf:type rdf:Property ;
    rdfs:label 'Commitment Party Type' ;
    rdfs:comment 'Type of party to whom this volume commitment applies: customer (shipper/consignee), carrier (transport provider), 3PL (Third-Party Logistics provider), 4PL (Fourth-Party Logistics provider), or vendor.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentPeriod rdf:type rdf:Property ;
    rdfs:label 'Commitment Period' ;
    rdfs:comment 'Measurement period for evaluating volume commitment performance: daily, weekly, monthly, quarterly, annual, or over the entire contract term.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentStatus rdf:type rdf:Property ;
    rdfs:label 'Commitment Status' ;
    rdfs:comment 'Current lifecycle status of the volume commitment: active (in force), suspended (temporarily paused), expired (past validity period), fulfilled (target met), breached (obligation not met), or pending (awaiting activation).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentType rdf:type rdf:Property ;
    rdfs:label 'Commitment Type' ;
    rdfs:comment 'Classification of the volume commitment: minimum volume guarantee (MVG), maximum volume cap, capacity allocation, shipment count commitment, weight-based commitment, TEU (Twenty-foot Equivalent Unit) commitment for ocean freight, or lane-specific allocation. [ENUM-REF-CANDIDATE: minimum_volume_guarantee|maximum_volume_cap|capacity_allocation|shipment_count|weight_based|teu_based|lane_specific — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excessIncentiveCurrency rdf:type rdf:Property ;
    rdfs:label 'Excess Incentive Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the excess incentive amount.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excessIncentiveRate rdf:type rdf:Property ;
    rdfs:label 'Excess Incentive Rate' ;
    rdfs:comment 'Incentive rate or rebate amount per unit of volume exceeding the target commitment. Rewards customers or carriers for exceeding volume targets.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastMeasuredDate rdf:type rdf:Property ;
    rdfs:label 'Last Measured Date' ;
    rdfs:comment 'Date when the actual volume utilization was last calculated and updated for this commitment.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumVolume rdf:type rdf:Property ;
    rdfs:label 'Maximum Volume' ;
    rdfs:comment 'Maximum volume or capacity cap that can be utilized during the commitment period. Represents the ceiling limit.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumVolume rdf:type rdf:Property ;
    rdfs:label 'Minimum Volume' ;
    rdfs:comment 'Minimum volume or capacity that must be utilized or booked during the commitment period to avoid penalties. Represents the floor obligation.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rolloverAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Rollover Allowed Flag' ;
    rdfs:comment 'Indicates whether unused volume from one commitment period can be rolled over to the next period. True if rollover is permitted, False otherwise.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rolloverVolume rdf:type rdf:Property ;
    rdfs:label 'Rollover Volume' ;
    rdfs:comment 'Volume carried over from the previous commitment period, if rollover is allowed. Added to the current period\'s commitment.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shortfallPenaltyCurrency rdf:type rdf:Property ;
    rdfs:label 'Shortfall Penalty Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the shortfall penalty amount.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortfallPenaltyRate rdf:type rdf:Property ;
    rdfs:label 'Shortfall Penalty Rate' ;
    rdfs:comment 'Penalty rate or amount per unit of volume shortfall if the minimum commitment is not met. May be a fixed amount or percentage of the shortfall value.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetVolume rdf:type rdf:Property ;
    rdfs:label 'Target Volume' ;
    rdfs:comment 'Target or expected volume for the commitment period, often used as a benchmark for incentive calculations.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeActualsId rdf:type rdf:Property ;
    rdfs:label 'Volume Actuals Id' ;
    rdfs:comment 'Unique identifier for the volume actuals record. Primary key for tracking actual shipped volumes against contracted commitments.' ;
    rdfs:domain ind:VolumeActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualVolumeShipped rdf:type rdf:Property ;
    rdfs:label 'Actual Volume Shipped' ;
    rdfs:comment 'The actual volume shipped during the measurement period, expressed in the unit of measure specified in volume_unit. This is the primary metric for contract compliance and penalty/incentive calculations.' ;
    rdfs:domain ind:VolumeActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:committedVolume rdf:type rdf:Property ;
    rdfs:label 'Committed Volume' ;
    rdfs:comment 'The contracted volume commitment for this measurement period, expressed in the same unit of measure as actual volume. Represents the baseline for attainment calculation.' ;
    rdfs:domain ind:VolumeActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentiveTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Incentive Triggered Flag' ;
    rdfs:comment 'Indicates whether this volume surplus has triggered a contractual incentive or rebate clause. True if incentive conditions are met, False otherwise.' ;
    rdfs:domain ind:VolumeActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Triggered Flag' ;
    rdfs:comment 'Indicates whether this volume shortfall has triggered a contractual penalty clause. True if penalty conditions are met, False otherwise.' ;
    rdfs:domain ind:VolumeActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'The current status of this volume actuals record in its lifecycle. Draft indicates preliminary calculation, final indicates approved and locked, revised indicates correction applied, voided indicates record is no longer valid.' ;
    rdfs:domain ind:VolumeActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortfallFlag rdf:type rdf:Property ;
    rdfs:label 'Shortfall Flag' ;
    rdfs:comment 'Indicates whether the actual volume shipped fell short of the committed volume for this period. True if actual < committed, False otherwise.' ;
    rdfs:domain ind:VolumeActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surplusFlag rdf:type rdf:Property ;
    rdfs:label 'Surplus Flag' ;
    rdfs:comment 'Indicates whether the actual volume shipped exceeded the committed volume for this period. True if actual > committed, False otherwise.' ;
    rdfs:domain ind:VolumeActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeVariance rdf:type rdf:Property ;
    rdfs:label 'Volume Variance' ;
    rdfs:comment 'The difference between actual volume shipped and committed volume (actual minus committed). Positive values indicate surplus, negative values indicate shortfall.' ;
    rdfs:domain ind:VolumeActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accrualMethod rdf:type rdf:Property ;
    rdfs:label 'Accrual Method' ;
    rdfs:comment 'Accounting method for recognizing the penalty or incentive (e.g., immediate upon trigger, at period end, on invoice date, upon settlement).' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliesToParty rdf:type rdf:Property ;
    rdfs:label 'Applies To Party' ;
    rdfs:comment 'The party to whom this penalty or incentive clause applies (e.g., customer, carrier, vendor, 3PL, 4PL, customs broker).' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseCategory rdf:type rdf:Property ;
    rdfs:label 'Clause Category' ;
    rdfs:comment 'Specific category of the penalty or incentive clause (e.g., SLA breach penalty, volume shortfall penalty, late payment penalty, service failure deduction, volume rebate, performance bonus for exceeding OTD/OTIF targets, loyalty discount, early payment incentive).' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseDescription rdf:type rdf:Property ;
    rdfs:label 'Clause Description' ;
    rdfs:comment 'Detailed textual description of the penalty or incentive clause, including business rationale, calculation examples, and any special conditions.' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseNumber rdf:type rdf:Property ;
    rdfs:label 'Clause Number' ;
    rdfs:comment 'The externally-known clause identifier or section number within the contract document (e.g., Section 7.3, Clause P-001).' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseStatus rdf:type rdf:Property ;
    rdfs:label 'Clause Status' ;
    rdfs:comment 'Current lifecycle status of the penalty or incentive clause within the contract.' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseType rdf:type rdf:Property ;
    rdfs:label 'Clause Type' ;
    rdfs:comment 'Classification of the clause as a penalty (financial deduction for non-performance) or incentive/rebate (financial reward for exceeding targets).' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Cure Period Days' ;
    rdfs:comment 'Number of days allowed to remedy the breach or non-performance before the penalty is applied. Null if no cure period is granted.' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Allowed Flag' ;
    rdfs:comment 'Indicates whether the affected party is allowed to dispute the penalty or incentive calculation and trigger the escalation path.' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationPath rdf:type rdf:Property ;
    rdfs:label 'Escalation Path' ;
    rdfs:comment 'Defined escalation or dispute resolution process if the penalty or incentive calculation is contested (e.g., escalate to account manager, arbitration, executive review).' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentivePercentage rdf:type rdf:Property ;
    rdfs:label 'Incentive Percentage' ;
    rdfs:comment 'Percentage rate applied to calculate the incentive or rebate (e.g., 3.0 for 3.0% volume rebate). Null if calculation is fixed-fee based.' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legalReference rdf:type rdf:Property ;
    rdfs:label 'Legal Reference' ;
    rdfs:comment 'Reference to the specific section, article, or clause number in the legal contract document where this penalty or incentive is formally documented.' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumLiabilityCap rdf:type rdf:Property ;
    rdfs:label 'Maximum Liability Cap' ;
    rdfs:comment 'Maximum cumulative penalty amount that can be assessed under this clause within a defined period (in contract currency). Protects against unlimited liability exposure.' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumPayoutCap rdf:type rdf:Property ;
    rdfs:label 'Maximum Payout Cap' ;
    rdfs:comment 'Maximum cumulative incentive or rebate amount that can be awarded under this clause within a defined period (in contract currency). Limits total incentive exposure.' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Required Flag' ;
    rdfs:comment 'Indicates whether the affected party must be notified in advance before a penalty is applied or an incentive is awarded.' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Payment Frequency' ;
    rdfs:comment 'Frequency at which penalties are assessed or incentives are paid out (e.g., per occurrence, monthly, quarterly, annually, upon final settlement).' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyPercentage rdf:type rdf:Property ;
    rdfs:label 'Penalty Percentage' ;
    rdfs:comment 'Percentage rate applied to calculate the penalty or incentive (e.g., 2.5 for 2.5% of invoice value). Null if calculation is fixed-fee based.' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyEventId rdf:type rdf:Property ;
    rdfs:label 'Penalty Event Id' ;
    rdfs:comment 'Unique identifier for the penalty or incentive event. Primary key for the penalty event transaction.' ;
    rdfs:domain ind:PenaltyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baseAmount rdf:type rdf:Property ;
    rdfs:label 'Base Amount' ;
    rdfs:comment 'The base monetary value used in the penalty or incentive calculation (e.g., shipment value, contract value, invoice amount).' ;
    rdfs:domain ind:PenaltyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculatedAmount rdf:type rdf:Property ;
    rdfs:label 'Calculated Amount' ;
    rdfs:comment 'The computed penalty or incentive amount before any adjustments, caps, or approvals.' ;
    rdfs:domain ind:PenaltyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:detectionDate rdf:type rdf:Property ;
    rdfs:label 'Detection Date' ;
    rdfs:comment 'The date on which the penalty or incentive event was detected and recorded in the system.' ;
    rdfs:domain ind:PenaltyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'The date on which the triggering event occurred (e.g., the date of SLA breach, the end of the measurement period for volume shortfall).' ;
    rdfs:domain ind:PenaltyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventNumber rdf:type rdf:Property ;
    rdfs:label 'Event Number' ;
    rdfs:comment 'Human-readable business identifier for the penalty event, used for tracking and reference in communications and billing documents.' ;
    rdfs:domain ind:PenaltyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'External Reference Number' ;
    rdfs:comment 'External reference number or identifier from the source system or partner system for cross-system reconciliation.' ;
    rdfs:domain ind:PenaltyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalAmount rdf:type rdf:Property ;
    rdfs:label 'Final Amount' ;
    rdfs:comment 'The final approved penalty or incentive amount to be applied to billing, after all adjustments and approvals.' ;
    rdfs:domain ind:PenaltyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyEventStatus rdf:type rdf:Property ;
    rdfs:label 'Penalty Event Status' ;
    rdfs:comment 'Current lifecycle status of the penalty event in the approval and settlement workflow.' ;
    rdfs:domain ind:PenaltyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyRate rdf:type rdf:Property ;
    rdfs:label 'Penalty Rate' ;
    rdfs:comment 'The rate or percentage applied to calculate the penalty or incentive amount (e.g., 5% of shipment value, $50 per day).' ;
    rdfs:domain ind:PenaltyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaMetricCode rdf:type rdf:Property ;
    rdfs:label 'Sla Metric Code' ;
    rdfs:comment 'Code identifying the specific SLA metric that was breached or exceeded (e.g., OTD, OTIF, transit time, damage rate). Null if event is not SLA-related.' ;
    rdfs:domain ind:PenaltyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerCategory rdf:type rdf:Property ;
    rdfs:label 'Trigger Category' ;
    rdfs:comment 'High-level category of the triggering event that caused the penalty or incentive to be applied.' ;
    rdfs:domain ind:PenaltyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerDescription rdf:type rdf:Property ;
    rdfs:label 'Trigger Description' ;
    rdfs:comment 'Detailed narrative description of the specific event or condition that triggered the penalty or incentive, including relevant context and supporting details.' ;
    rdfs:domain ind:PenaltyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waivedBy rdf:type rdf:Property ;
    rdfs:label 'Waived By' ;
    rdfs:comment 'Name or identifier of the person who authorized the waiver of this penalty event.' ;
    rdfs:domain ind:PenaltyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Date' ;
    rdfs:comment 'Date on which the penalty was waived.' ;
    rdfs:domain ind:PenaltyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:carrierRateCardId rdf:type rdf:Property ;
    rdfs:label 'Carrier Rate Card Id' ;
    rdfs:comment 'Foreign key linking to pricing.rate_card. Business justification: Carrier agreements govern buy-side pricing structures. Linking to carrier rate cards enables buy-rate governance, margin analysis, and supports carrier rate change impact assessment across carrier agr' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateCard .

ind:agreementTier rdf:type rdf:Property ;
    rdfs:label 'Agreement Tier' ;
    rdfs:comment 'Classification of the carrier agreement tier indicating priority and relationship level (preferred, approved, spot, strategic, tactical, backup).' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Required' ;
    rdfs:comment 'Indicates whether the carrier must maintain compliance certifications such as C-TPAT, AEO, ISO 28000 under this agreement.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractTermMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Term Months' ;
    rdfs:comment 'Duration of the carrier agreement in months from effective date to expiration.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractedCapacityCbm rdf:type rdf:Property ;
    rdfs:label 'Contracted Capacity Cbm' ;
    rdfs:comment 'Committed volumetric capacity in cubic meters (CBM) for freight under this agreement.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Contracted Capacity Kg' ;
    rdfs:comment 'Committed weight capacity in kilograms for air or road freight under this agreement.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ediConnectivityRequired rdf:type rdf:Property ;
    rdfs:label 'Edi Connectivity Required' ;
    rdfs:comment 'Indicates whether Electronic Data Interchange (EDI) connectivity is required for shipment booking and tracking under this agreement.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediStandard rdf:type rdf:Property ;
    rdfs:label 'Edi Standard' ;
    rdfs:comment 'EDI standard or protocol used for electronic communication with the carrier (EDIFACT, ANSI X12, XML, API, proprietary).' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nvoccFlag rdf:type rdf:Property ;
    rdfs:label 'Nvocc Flag' ;
    rdfs:comment 'Indicates whether the carrier is a Non-Vessel Operating Common Carrier (NVOCC) rather than a direct vessel operator.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateValidityEndDate rdf:type rdf:Property ;
    rdfs:label 'Rate Validity End Date' ;
    rdfs:comment 'End date for the validity period of contracted rates, after which rates may be renegotiated.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateValidityStartDate rdf:type rdf:Property ;
    rdfs:label 'Rate Validity Start Date' ;
    rdfs:comment 'Start date for the validity period of contracted rates under this carrier agreement.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of days advance notice required by either party to terminate the carrier agreement.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeCommitmentType rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Type' ;
    rdfs:comment 'Type of volume commitment specified in the agreement (minimum, maximum, target, flexible).' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingLeadTimeHours rdf:type rdf:Property ;
    rdfs:label 'Booking Lead Time Hours' ;
    rdfs:comment 'Minimum advance notice in hours required to book capacity on this lane.' ;
    rdfs:domain ind:LaneCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityCommitmentQuantity rdf:type rdf:Property ;
    rdfs:label 'Capacity Commitment Quantity' ;
    rdfs:comment 'Contracted capacity allocation for the lane per commitment period (e.g., weekly or monthly volume).' ;
    rdfs:domain ind:LaneCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityUnit rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit' ;
    rdfs:comment 'Unit of measure for the capacity commitment (TEU, FEU, kg, ton, CBM, pallet, truckload, flight). [ENUM-REF-CANDIDATE: TEU|FEU|kg|ton|cbm|pallet|truckload|flight — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LaneCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveThresholdQuantity rdf:type rdf:Property ;
    rdfs:label 'Incentive Threshold Quantity' ;
    rdfs:comment 'Volume threshold that must be exceeded to trigger incentive payments or rebates.' ;
    rdfs:domain ind:LaneCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumBookingQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Booking Quantity' ;
    rdfs:comment 'Maximum volume that can be booked per commitment period under this lane commitment.' ;
    rdfs:domain ind:LaneCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumBookingQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Booking Quantity' ;
    rdfs:comment 'Minimum volume that must be booked per commitment period to meet contractual obligations and avoid penalties.' ;
    rdfs:domain ind:LaneCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rolloverExpiryPeriods rdf:type rdf:Property ;
    rdfs:label 'Rollover Expiry Periods' ;
    rdfs:comment 'Number of commitment periods after which rolled-over capacity expires if not utilized.' ;
    rdfs:domain ind:LaneCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rolloverLimitQuantity rdf:type rdf:Property ;
    rdfs:label 'Rollover Limit Quantity' ;
    rdfs:comment 'Maximum quantity of unused capacity that can be rolled over to the next period, if rollover is allowed.' ;
    rdfs:domain ind:LaneCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:codAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Cod Allowed Flag' ;
    rdfs:comment 'Indicates whether cash on delivery (COD) payment collection is allowed under this service scope.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsClearanceIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Included Flag' ;
    rdfs:comment 'Indicates whether customs brokerage and clearance services are included in this service scope.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dimensionLimitCbm rdf:type rdf:Property ;
    rdfs:label 'Dimension Limit Cbm' ;
    rdfs:comment 'Maximum dimensional limit per shipment or unit under this service scope, measured in cubic meters (CBM).' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightType rdf:type rdf:Property ;
    rdfs:label 'Freight Type' ;
    rdfs:comment 'Freight load type for road/rail services: Full Truckload (FTL), Less than Truckload (LTL), or not applicable for non-trucking services.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Included Flag' ;
    rdfs:comment 'Indicates whether cargo insurance is included in this service scope.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packagingIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Packaging Included Flag' ;
    rdfs:comment 'Indicates whether packaging, crating, or palletization services are included in this service scope.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceExclusions rdf:type rdf:Property ;
    rdfs:label 'Service Exclusions' ;
    rdfs:comment 'Specific exclusions, restrictions, or limitations applicable to this service scope (e.g., prohibited commodities, excluded geographies, restricted handling).' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceName rdf:type rdf:Property ;
    rdfs:label 'Service Name' ;
    rdfs:comment 'Human-readable name of the logistics service included in the contract scope (e.g., Express Parcel Delivery, Air Freight Forwarding, Ocean Full Container Load).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceScopeStatus rdf:type rdf:Property ;
    rdfs:label 'Service Scope Status' ;
    rdfs:comment 'Current lifecycle status of this service scope (active, inactive, suspended, pending, expired).' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTier rdf:type rdf:Property ;
    rdfs:label 'Service Tier' ;
    rdfs:comment 'Service level tier indicating speed, priority, and handling quality (premium, standard, economy, basic).' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehousingIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Warehousing Included Flag' ;
    rdfs:comment 'Indicates whether warehousing, storage, or distribution services are included in this service scope.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weightLimitKg rdf:type rdf:Property ;
    rdfs:label 'Weight Limit Kg' ;
    rdfs:comment 'Maximum weight limit per shipment or unit under this service scope, measured in kilograms.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctpatNumber rdf:type rdf:Property ;
    rdfs:label 'Ctpat Number' ;
    rdfs:comment 'C-TPAT certification number if the party is certified under the U.S. Customs-Trade Partnership Against Terrorism program.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBrokerLicense rdf:type rdf:Property ;
    rdfs:label 'Customs Broker License' ;
    rdfs:comment 'Customs broker license number if the party is authorized to conduct customs clearance activities.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guarantorFlag rdf:type rdf:Property ;
    rdfs:label 'Guarantor Flag' ;
    rdfs:comment 'Indicates whether this party serves as a guarantor for contract obligations (True/False).' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalEntityName rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name' ;
    rdfs:comment 'The full legal name of the party as registered with governing authorities, used for contract execution and compliance.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityCapAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Cap Amount' ;
    rdfs:comment 'Maximum liability amount for this party under the contract terms, if applicable.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liabilityCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Liability Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the liability cap amount.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationPreference rdf:type rdf:Property ;
    rdfs:label 'Notification Preference' ;
    rdfs:comment 'Preferred method for contract-related notifications and communications (email, phone, postal mail, EDI, API).' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nvoccLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Nvocc License Number' ;
    rdfs:comment 'NVOCC license number issued by the Federal Maritime Commission if the party operates as a non-vessel operating common carrier.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentResponsibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Payment Responsibility Flag' ;
    rdfs:comment 'Indicates whether this party has payment responsibility under the contract (True/False). Relevant for identifying payers vs. service recipients.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryContactFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Flag' ;
    rdfs:comment 'Indicates whether this party is the primary contact for contract administration and communication (True/False).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registrationJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Registration Jurisdiction' ;
    rdfs:comment 'The country or jurisdiction where the party is legally registered (ISO 3166-1 alpha-3 country code).' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scacCode rdf:type rdf:Property ;
    rdfs:label 'Scac Code' ;
    rdfs:comment 'Standard Carrier Alpha Code for ocean and intermodal carriers, used for shipment identification and EDI transactions.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryEmail rdf:type rdf:Property ;
    rdfs:label 'Signatory Email' ;
    rdfs:comment 'Email address of the authorized signatory for contract correspondence and notifications.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryName rdf:type rdf:Property ;
    rdfs:label 'Signatory Name' ;
    rdfs:comment 'Full name of the individual authorized to sign the contract on behalf of this party.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryPhone rdf:type rdf:Property ;
    rdfs:label 'Signatory Phone' ;
    rdfs:comment 'Contact phone number of the authorized signatory.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Signatory Title' ;
    rdfs:comment 'Job title or position of the authorized signatory (e.g., Chief Executive Officer, Director of Operations, Authorized Representative).' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureLocation rdf:type rdf:Property ;
    rdfs:label 'Signature Location' ;
    rdfs:comment 'City and country where the contract was signed by this party.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureMethod rdf:type rdf:Property ;
    rdfs:label 'Signature Method' ;
    rdfs:comment 'The method by which the contract was signed (wet signature, electronic signature, digital signature, notarized).' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCarrierId rdf:type rdf:Property ;
    rdfs:label 'Parent Carrier Id' ;
    rdfs:comment 'Self-referencing FK on carrier (parent_carrier_id)' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:countryOfRegistration rdf:type rdf:Property ;
    rdfs:label 'Country Of Registration' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code where the carrier is legally registered and holds its primary operating license.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBrokerageService rdf:type rdf:Property ;
    rdfs:label 'Customs Brokerage Service' ;
    rdfs:comment 'Indicates whether the carrier provides in-house customs brokerage services for import/export clearance, or if third-party brokers must be engaged.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fiataCertified rdf:type rdf:Property ;
    rdfs:label 'Fiata Certified' ;
    rdfs:comment 'Indicates whether the carrier holds FIATA certification, demonstrating compliance with international freight forwarding standards.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialStanding rdf:type rdf:Property ;
    rdfs:label 'Financial Standing' ;
    rdfs:comment 'Assessment of the carrier\'s financial health and creditworthiness based on credit ratings, financial statements, and payment history. Used for risk management and credit limit decisions.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddress rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address' ;
    rdfs:comment 'Full street address of the carrier\'s corporate headquarters, including street, city, state/province, and postal code.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountry rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code where the carrier\'s headquarters is located.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataCertified rdf:type rdf:Property ;
    rdfs:label 'Iata Certified' ;
    rdfs:comment 'Indicates whether the carrier holds valid IATA certification for air cargo operations. Required for participation in IATA cargo agency programs.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso28000Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 28000 Certified' ;
    rdfs:comment 'Indicates whether the carrier holds ISO 28000 certification for supply chain security management systems.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onboardingStage rdf:type rdf:Property ;
    rdfs:label 'Onboarding Stage' ;
    rdfs:comment 'Current stage in the carrier onboarding lifecycle, from initial prospect through active operations to potential offboarding.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otdPercentage rdf:type rdf:Property ;
    rdfs:label 'Otd Percentage' ;
    rdfs:comment 'Percentage of shipments delivered on or before the committed delivery date over the last 12 months. Key performance indicator for carrier reliability.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredCarrierFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Carrier Flag' ;
    rdfs:comment 'Indicates whether this carrier has preferred status in Transport Shipping\'s network, receiving priority allocation and preferential rates due to strategic partnership or superior performance.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceScope rdf:type rdf:Property ;
    rdfs:label 'Service Scope' ;
    rdfs:comment 'Geographic reach of the carrier\'s service network: domestic (single country), regional (multi-country region), international (cross-border), or global (worldwide coverage).' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportModes rdf:type rdf:Property ;
    rdfs:label 'Transport Modes' ;
    rdfs:comment 'Comma-separated list of transport modes the carrier operates: air, ocean, road, rail, multimodal. Indicates the carrier\'s operational capabilities across different freight modes.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Primary website URL of the carrier for tracking, service information, and customer support.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierProfileId rdf:type rdf:Property ;
    rdfs:label 'Carrier Profile Id' ;
    rdfs:comment 'Unique identifier for the carrier operational capability profile. Primary key.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarrierProfile .

ind:supersededCarrierProfileId rdf:type rdf:Property ;
    rdfs:label 'Superseded Carrier Profile Id' ;
    rdfs:comment 'Self-referencing FK on carrier_profile (superseded_carrier_profile_id)' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarrierProfile .

ind:apiIntegrationAvailable rdf:type rdf:Property ;
    rdfs:label 'Api Integration Available' ;
    rdfs:comment 'Indicates whether the carrier provides API (Application Programming Interface) integration for real-time booking, tracking, and rate queries.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:apiProtocol rdf:type rdf:Property ;
    rdfs:label 'Api Protocol' ;
    rdfs:comment 'Type of API protocol supported by the carrier: REST, SOAP, GraphQL, proprietary, or none if no API available.' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageTransitTimeDays rdf:type rdf:Property ;
    rdfs:label 'Average Transit Time Days' ;
    rdfs:comment 'Average transit time in days for shipments handled by this carrier profile, calculated from historical data.' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonReportingAvailable rdf:type rdf:Property ;
    rdfs:label 'Carbon Reporting Available' ;
    rdfs:comment 'Indicates whether the carrier provides CO2e (Carbon Dioxide Equivalent) emissions reporting for shipments.' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:claimsRatioPercentage rdf:type rdf:Property ;
    rdfs:label 'Claims Ratio Percentage' ;
    rdfs:comment 'Historical cargo claims ratio as a percentage of total shipments (0.00 to 100.00). Lower is better.' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countriesServed rdf:type rdf:Property ;
    rdfs:label 'Countries Served' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where carrier provides service (e.g., USA, CAN, MEX, GBR, DEU, CHN).' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossBorderCapable rdf:type rdf:Property ;
    rdfs:label 'Cross Border Capable' ;
    rdfs:comment 'Indicates whether the carrier handles cross-border international shipments including customs clearance coordination.' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsBrokerageIncluded rdf:type rdf:Property ;
    rdfs:label 'Customs Brokerage Included' ;
    rdfs:comment 'Indicates whether the carrier provides in-house customs brokerage services as part of their offering.' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dgClassesHandled rdf:type rdf:Property ;
    rdfs:label 'Dg Classes Handled' ;
    rdfs:comment 'Comma-separated list of UN dangerous goods classes the carrier is certified to handle (e.g., Class 1 Explosives, Class 3 Flammable Liquids, Class 8 Corrosives). Null if not DG certified.' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentTypes rdf:type rdf:Property ;
    rdfs:label 'Equipment Types' ;
    rdfs:comment 'Comma-separated list of equipment types operated: dry_van, reefer, flatbed, tanker, container_20ft, container_40ft, container_40ft_hc, aircraft_freighter, rail_car, barge. [ENUM-REF-CANDIDATE: dry_van|reefer|flatbed|tanker|container_20ft|container_40ft|container_40ft_hc|aircraft_freighter|rail_car|barge|lowboy|chassis — promote to reference product]' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverageScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage Scope' ;
    rdfs:comment 'Overall geographic reach of the carrier: global (worldwide), regional (multi-country region), national (single country), local (city/metro), or trade-lane-specific (dedicated corridors).' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCoverageAvailable rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Available' ;
    rdfs:comment 'Indicates whether the carrier offers cargo insurance coverage as part of their service or through a partner.' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMileCapable rdf:type rdf:Property ;
    rdfs:label 'Last Mile Capable' ;
    rdfs:comment 'Indicates whether the carrier provides last-mile delivery services to final consignee addresses (residential or commercial).' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxInsuranceValueUsd rdf:type rdf:Property ;
    rdfs:label 'Max Insurance Value Usd' ;
    rdfs:comment 'Maximum cargo value in USD that can be insured per shipment. Null if insurance not available.' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceTier rdf:type rdf:Property ;
    rdfs:label 'Performance Tier' ;
    rdfs:comment 'Internal performance tier classification based on OTD (On-Time Delivery), claims ratio, and service quality: platinum (best), gold, silver, bronze, or standard.' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileCode rdf:type rdf:Property ;
    rdfs:label 'Profile Code' ;
    rdfs:comment 'Unique business identifier code for this carrier profile used in operational systems and partner integrations.' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileName rdf:type rdf:Property ;
    rdfs:label 'Profile Name' ;
    rdfs:comment 'Business-friendly name for this carrier operational profile (e.g., \'Global Express Air\', \'Regional LTL Network\').' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCertifications rdf:type rdf:Property ;
    rdfs:label 'Quality Certifications' ;
    rdfs:comment 'Comma-separated list of quality and compliance certifications held by the carrier (e.g., ISO 9001, C-TPAT, AEO, TAPA, GDP).' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:realTimeTrackingAvailable rdf:type rdf:Property ;
    rdfs:label 'Real Time Tracking Available' ;
    rdfs:comment 'Indicates whether the carrier provides real-time GPS or milestone-based shipment tracking visibility.' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regionsServed rdf:type rdf:Property ;
    rdfs:label 'Regions Served' ;
    rdfs:comment 'Comma-separated list of geographic regions where carrier operates (e.g., North America, Europe, Asia Pacific, Middle East, Latin America, Africa).' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityRating rdf:type rdf:Property ;
    rdfs:label 'Security Rating' ;
    rdfs:comment 'Security risk rating assigned to the carrier based on compliance, incident history, and certifications: high (best), medium, low, or not rated.' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTypes rdf:type rdf:Property ;
    rdfs:label 'Service Types' ;
    rdfs:comment 'Comma-separated list of service types offered: FTL (Full Truckload), LTL (Less Than Truckload), FCL (Full Container Load), LCL (Less Than Container Load), express, economy, standard, same_day, next_day, deferred. [ENUM-REF-CANDIDATE: ftl|ltl|fcl|lcl|express|economy|standard|same_day|next_day|deferred|white_glove — promote to reference product]' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityCertified rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certified' ;
    rdfs:comment 'Indicates whether the carrier holds sustainability or environmental certifications (e.g., SmartWay, ISO 14001, carbon neutral).' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trackingGranularity rdf:type rdf:Property ;
    rdfs:label 'Tracking Granularity' ;
    rdfs:comment 'Level of tracking detail provided: real-time GPS, milestone-based (pickup/in-transit/delivery), daily update, manual, or none.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeLanesCovered rdf:type rdf:Property ;
    rdfs:label 'Trade Lanes Covered' ;
    rdfs:comment 'Comma-separated list of major trade lanes or corridors served (e.g., Transpacific, Transatlantic, Asia-Europe, Intra-Asia, US-Mexico).' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAgentId rdf:type rdf:Property ;
    rdfs:label 'Parent Agent Id' ;
    rdfs:comment 'Self-referencing FK on agent (parent_agent_id)' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:agentStatus rdf:type rdf:Property ;
    rdfs:label 'Agent Status' ;
    rdfs:comment 'The current lifecycle status of the agent relationship. Active agents are authorized to conduct business; inactive agents are temporarily not operating; suspended agents have had privileges revoked pending review; pending approval agents are undergoing onboarding; terminated agents have had their relationship permanently ended.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agentType rdf:type rdf:Property ;
    rdfs:label 'Agent Type' ;
    rdfs:comment 'Classification of the agent based on their primary operational role in the logistics network. Freight agents represent carriers for cargo booking; GSAs (General Sales Agents) represent airlines for sales and marketing; handling agents provide ground services at airports/ports; customs agents facilitate trade compliance; co-loaders consolidate shipments; ground handling agents provide airport ramp and terminal services.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondAmount rdf:type rdf:Property ;
    rdfs:label 'Bond Amount' ;
    rdfs:comment 'The monetary value of the customs bond or financial guarantee held by the agent, expressed in the agent\'s local currency. Represents the maximum liability coverage for customs duties and taxes.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bondCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Bond Currency Code' ;
    rdfs:comment 'The ISO 4217 three-letter currency code for the bond amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondingStatus rdf:type rdf:Property ;
    rdfs:label 'Bonding Status' ;
    rdfs:comment 'Indicates whether the agent holds a valid customs bond or financial guarantee required for handling in-bond cargo movements and customs clearance activities. Bonded status is mandatory for customs agents.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionStructureType rdf:type rdf:Property ;
    rdfs:label 'Commission Structure Type' ;
    rdfs:comment 'The method by which the agent earns compensation for services rendered. Percentage commissions are based on shipment value or freight charges; flat fees are fixed per transaction; tiered structures vary by volume thresholds; hybrid combines multiple methods.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiataMember rdf:type rdf:Property ;
    rdfs:label 'Fiata Member' ;
    rdfs:comment 'Indicates whether the agent is a member of FIATA, the global representative body for freight forwarders and logistics providers, which provides industry standards and advocacy.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iataAgentCode rdf:type rdf:Property ;
    rdfs:label 'Iata Agent Code' ;
    rdfs:comment 'The unique numeric code assigned by IATA to accredited cargo and passenger sales agents, typically 7 or 8 digits. Required for agents handling air waybills (AWBs) and airline bookings.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Insurance Currency Code' ;
    rdfs:comment 'The ISO 4217 three-letter currency code for the insurance coverage amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Due Date' ;
    rdfs:comment 'The scheduled date for the next periodic audit of the agent\'s operations and compliance status, typically conducted annually or biennially.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nvoccLicensed rdf:type rdf:Property ;
    rdfs:label 'Nvocc Licensed' ;
    rdfs:comment 'Indicates whether the agent holds a valid NVOCC license, allowing them to issue house bills of lading (HBLs) and operate as a carrier without owning vessels.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationalScope rdf:type rdf:Property ;
    rdfs:label 'Operational Scope' ;
    rdfs:comment 'The geographic reach of the agent\'s service capabilities. Local agents serve a single city or metro area; regional agents cover multiple cities or provinces; national agents operate across an entire country; international agents have cross-border capabilities.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:principalCarrierRelationships rdf:type rdf:Property ;
    rdfs:label 'Principal Carrier Relationships' ;
    rdfs:comment 'Comma-separated list of carrier names or IATA/SCAC codes for which this agent acts as an authorized representative or sales agent. Defines the agent\'s network affiliations and booking authority.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCommissionRate rdf:type rdf:Property ;
    rdfs:label 'Standard Commission Rate' ;
    rdfs:comment 'The default commission percentage or flat fee amount applied to transactions handled by the agent, expressed as a percentage (e.g., 5.00 for 5%) or monetary value depending on commission structure type.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportModesSupported rdf:type rdf:Property ;
    rdfs:label 'Transport Modes Supported' ;
    rdfs:comment 'Comma-separated list of transport modes the agent is authorized and equipped to handle (e.g., air, ocean, road, rail, multimodal). Indicates the agent\'s operational versatility across different freight types.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agentAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Agent Appointment Id' ;
    rdfs:comment 'Unique identifier for the agent appointment record. Primary key for the agent appointment entity.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appointedAgentId rdf:type rdf:Property ;
    rdfs:label 'Appointed Agent Id' ;
    rdfs:comment 'Identifier of the freight agent or General Sales Agent (GSA) being appointed to act on behalf of the appointing party.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:renewedAgentAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Renewed Agent Appointment Id' ;
    rdfs:comment 'Self-referencing FK on agent_appointment (renewed_agent_appointment_id)' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AgentAppointment .

ind:aeoCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Aeo Certification Flag' ;
    rdfs:comment 'Indicates whether the agent holds Authorized Economic Operator (AEO) certification, demonstrating secure and compliant supply chain practices. True means certified; False means not certified.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appointmentEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Appointment Effective Date' ;
    rdfs:comment 'Date when the agent appointment becomes active and the agent is authorized to begin operations on behalf of the appointing party.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appointmentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Appointment Expiry Date' ;
    rdfs:comment 'Date when the agent appointment expires and the agent authority terminates. Nullable for open-ended appointments subject to termination notice.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appointmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Appointment Reference Number' ;
    rdfs:comment 'External business reference number for the agent appointment, used in contracts and communications with the appointed agent.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentTermMonths rdf:type rdf:Property ;
    rdfs:label 'Appointment Term Months' ;
    rdfs:comment 'Duration of the appointment term expressed in months. Used for fixed-term appointments. Null for indefinite appointments.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizedServiceLines rdf:type rdf:Property ;
    rdfs:label 'Authorized Service Lines' ;
    rdfs:comment 'Semicolon-separated list of service lines the agent is authorized to sell or manage. May include express parcel, air freight, ocean freight, road freight, rail freight, customs brokerage, warehousing, last-mile delivery, e-commerce fulfillment.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedTransportModes rdf:type rdf:Property ;
    rdfs:label 'Authorized Transport Modes' ;
    rdfs:comment 'Semicolon-separated list of transport modes the agent is authorized to handle. May include air, ocean, road, rail, multimodal.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionBasis rdf:type rdf:Property ;
    rdfs:label 'Commission Basis' ;
    rdfs:comment 'Basis on which the commission is calculated. Gross revenue includes all charges; net revenue excludes certain pass-through costs; margin is based on profit; per-shipment is fixed fee per transaction; tiered varies by volume thresholds.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Commission Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which commission payments are denominated.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Percent' ;
    rdfs:comment 'Percentage commission rate paid to the agent on revenue generated within their territory and service scope. Expressed as percentage (e.g., 5.50 for 5.5%).' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Contract Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the formal contract or agreement document governing this agent appointment. May link to document management system.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctpatCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Ctpat Certification Flag' ;
    rdfs:comment 'Indicates whether the agent holds C-TPAT certification, a US Customs and Border Protection program for supply chain security. True means certified; False means not certified.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsBrokerLicenseFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Broker License Flag' ;
    rdfs:comment 'Indicates whether the agent holds a valid customs broker license, required for handling customs clearance and trade compliance services. True means licensed; False means not licensed.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Flag' ;
    rdfs:comment 'Indicates whether the agent has exclusive rights to represent the appointing party in the defined territory. True means no other agents may be appointed in the same territory for the same services; False allows multiple agents.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iataAccreditationFlag rdf:type rdf:Property ;
    rdfs:label 'Iata Accreditation Flag' ;
    rdfs:comment 'Indicates whether the agent holds valid IATA accreditation, required for handling air freight and issuing Air Waybills (AWB). True means accredited; False means not accredited.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceCoverageCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the insurance coverage amount is denominated.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCoverageRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Required Flag' ;
    rdfs:comment 'Indicates whether the agent is required to maintain liability insurance coverage as a condition of the appointment. True requires insurance; False does not.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumRevenueCommitment rdf:type rdf:Property ;
    rdfs:label 'Minimum Revenue Commitment' ;
    rdfs:comment 'Minimum revenue the agent commits to generate during the appointment term. Failure to meet this may trigger penalties or termination. Null if no minimum is specified.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumRevenueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Minimum Revenue Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the minimum revenue commitment is denominated.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nvoccLicenseFlag rdf:type rdf:Property ;
    rdfs:label 'Nvocc License Flag' ;
    rdfs:comment 'Indicates whether the agent holds a valid NVOCC license, required for ocean freight consolidation and issuing House Bills of Lading (HBL). True means licensed; False means not licensed.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceBondAmount rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Amount' ;
    rdfs:comment 'Monetary value of the performance bond or financial guarantee required from the agent, if applicable. Null if no bond is required.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceBondCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the performance bond amount is denominated.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceBondRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Required Flag' ;
    rdfs:comment 'Indicates whether the agent is required to post a performance bond or financial guarantee as a condition of the appointment. True requires bond; False does not.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalOption rdf:type rdf:Property ;
    rdfs:label 'Renewal Option' ;
    rdfs:comment 'Terms under which the appointment may be renewed at expiry. Automatic renews unless terminated; mutual consent requires both parties to agree; appointing party option allows appointing party to renew unilaterally; agent option allows agent to renew; no renewal means appointment ends at expiry.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code defining the geographic territory where the agent is authorized to operate.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryRegion rdf:type rdf:Property ;
    rdfs:label 'Territory Region' ;
    rdfs:comment 'Specific region, state, province, or sub-national area within the country where the agent appointment is valid. May include multiple regions separated by semicolons.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryScope rdf:type rdf:Property ;
    rdfs:label 'Territory Scope' ;
    rdfs:comment 'Granularity level of the geographic territory covered by the appointment. National covers entire country; regional covers specific provinces/states; city/port/airport/station covers specific locations.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerCarrierId rdf:type rdf:Property ;
    rdfs:label 'Partner Carrier Id' ;
    rdfs:comment 'Reference to the partner carrier organization with whom this interline agreement is established.' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:renewedInterlineAgreementId rdf:type rdf:Property ;
    rdfs:label 'Renewed Interline Agreement Id' ;
    rdfs:comment 'Self-referencing FK on interline_agreement (renewed_interline_agreement_id)' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InterlineAgreement .

ind:awbPrefixAllocation rdf:type rdf:Property ;
    rdfs:label 'Awb Prefix Allocation' ;
    rdfs:comment 'IATA-assigned three-digit AWB prefix(es) that may be used under this interline agreement for through-billing. Applicable to air cargo agreements.' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Clause Flag' ;
    rdfs:comment 'Indicates whether the agreement includes a confidentiality or non-disclosure clause restricting the sharing of agreement terms.' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'Legal jurisdiction and governing law under which this interline agreement is executed and disputes are resolved (e.g., \'New York, USA\', \'England and Wales\', \'Singapore\').' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataProrateRuleReference rdf:type rdf:Property ;
    rdfs:label 'Iata Prorate Rule Reference' ;
    rdfs:comment 'Reference to specific IATA Resolution 780 prorate rule or tariff provision governing revenue allocation for air cargo interline agreements.' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequirement rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirement' ;
    rdfs:comment 'Type of insurance coverage required or provided under this interline agreement for cargo in transit.' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityLimitCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Liability Limit Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the liability limit amount.' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyForNonCompliance rdf:type rdf:Property ;
    rdfs:label 'Penalty For Non Compliance' ;
    rdfs:comment 'Description of financial or operational penalties applied if either party fails to meet volume commitments or SLA targets. Confidential commercial term.' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceReviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Performance Review Frequency' ;
    rdfs:comment 'Frequency at which the parties conduct formal performance reviews of the interline agreement against SLA commitments and volume targets.' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prorateMethodology rdf:type rdf:Property ;
    rdfs:label 'Prorate Methodology' ;
    rdfs:comment 'Method used to allocate revenue between carriers for through-shipments. IATA standard refers to IATA Resolution 780 prorate rules.' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Period Days' ;
    rdfs:comment 'Number of days prior to expiry that either party must provide notice if they wish to terminate or renegotiate the agreement.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueSplitPercentage rdf:type rdf:Property ;
    rdfs:label 'Revenue Split Percentage' ;
    rdfs:comment 'Percentage of total revenue allocated to Transport Shipping under this agreement. Remaining percentage goes to partner carrier. Confidential commercial term.' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementFrequency rdf:type rdf:Property ;
    rdfs:label 'Settlement Frequency' ;
    rdfs:comment 'Frequency at which interline revenue settlements are calculated and exchanged between Transport Shipping and the partner carrier.' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaOnTimeDeliveryTargetPct rdf:type rdf:Property ;
    rdfs:label 'Sla On Time Delivery Target Pct' ;
    rdfs:comment 'Target percentage for on-time delivery performance that both carriers commit to achieve under this interline agreement.' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:throughBillingEnabled rdf:type rdf:Property ;
    rdfs:label 'Through Billing Enabled' ;
    rdfs:comment 'Indicates whether this agreement permits through-billing, where a single AWB or BOL covers the entire journey across both carriers\' networks.' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeCommitmentUnit rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Unit' ;
    rdfs:comment 'Unit of measure for the minimum volume commitment. TEU = Twenty-foot Equivalent Unit, CBM = Cubic Meter.' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentTplProviderId rdf:type rdf:Property ;
    rdfs:label 'Parent Tpl Provider Id' ;
    rdfs:comment 'Self-referencing FK on tpl_provider (parent_tpl_provider_id)' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TplProvider .

ind:coldChainCapability rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Capability' ;
    rdfs:comment 'Indicates whether the provider has temperature-controlled logistics capabilities for perishable or pharmaceutical goods.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsBrokerageCapability rdf:type rdf:Property ;
    rdfs:label 'Customs Brokerage Capability' ;
    rdfs:comment 'Indicates whether the provider offers customs brokerage and trade compliance services for cross-border shipments.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distributionCapability rdf:type rdf:Property ;
    rdfs:label 'Distribution Capability' ;
    rdfs:comment 'Indicates whether the provider offers distribution and order fulfillment services.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediCapability rdf:type rdf:Property ;
    rdfs:label 'Edi Capability' ;
    rdfs:comment 'Indicates whether the provider supports Electronic Data Interchange (EDI) for automated transaction processing and data exchange.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialRating rdf:type rdf:Property ;
    rdfs:label 'Financial Rating' ;
    rdfs:comment 'Credit or financial strength rating assigned to the provider by a recognized rating agency or internal risk assessment. [ENUM-REF-CANDIDATE: AAA|AA|A|BBB|BB|B|CCC|CC|C|D|not_rated — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdpCertified rdf:type rdf:Property ;
    rdfs:label 'Gdp Certified' ;
    rdfs:comment 'Indicates whether the provider holds Good Distribution Practice (GDP) certification for pharmaceutical and healthcare logistics.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:haccpCertified rdf:type rdf:Property ;
    rdfs:label 'Haccp Certified' ;
    rdfs:comment 'Indicates whether the provider holds HACCP (Hazard Analysis and Critical Control Points) certification for food safety and cold chain management.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:headquartersAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line1' ;
    rdfs:comment 'First line of the provider\'s headquarters street address including building number and street name.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'City where the provider\'s headquarters is located.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountryCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the provider\'s headquarters location.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersPostalCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the provider\'s headquarters address.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersStateProvince rdf:type rdf:Property ;
    rdfs:label 'Headquarters State Province' ;
    rdfs:comment 'State, province, or administrative region where the provider\'s headquarters is located.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMileDeliveryCapability rdf:type rdf:Property ;
    rdfs:label 'Last Mile Delivery Capability' ;
    rdfs:comment 'Indicates whether the provider offers last-mile delivery services to end customers or consignees.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredProviderFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Provider Flag' ;
    rdfs:comment 'Indicates whether the provider has been designated as a preferred or strategic partner based on performance, capabilities, and relationship strength.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:providerCode rdf:type rdf:Property ;
    rdfs:label 'Provider Code' ;
    rdfs:comment 'Externally-known unique business identifier code for the 3PL/4PL provider, used in operational systems and partner communications.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerType rdf:type rdf:Property ;
    rdfs:label 'Provider Type' ;
    rdfs:comment 'Classification of the logistics provider based on service model: 3PL (Third-Party Logistics), 4PL (Fourth-Party Logistics), co-packer, value-added logistics provider, freight forwarder, or NVOCC (Non-Vessel Operating Common Carrier).' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reverseLogisticsCapability rdf:type rdf:Property ;
    rdfs:label 'Reverse Logistics Capability' ;
    rdfs:comment 'Indicates whether the provider offers reverse logistics services including returns management and RMA (Return Merchandise Authorization) processing.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tmsPlatform rdf:type rdf:Property ;
    rdfs:label 'Tms Platform' ;
    rdfs:comment 'Name and version of the Transportation Management System (TMS) platform used by the provider for shipment execution and freight management.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalWarehouseSqft rdf:type rdf:Property ;
    rdfs:label 'Total Warehouse Sqft' ;
    rdfs:comment 'Total warehouse and distribution center space in square feet managed by the provider across all facilities.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valueAddedServices rdf:type rdf:Property ;
    rdfs:label 'Value Added Services' ;
    rdfs:comment 'Comma-separated list of value-added logistics services offered by the provider such as kitting, labeling, packaging, assembly, quality inspection, or co-packing.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehousingCapability rdf:type rdf:Property ;
    rdfs:label 'Warehousing Capability' ;
    rdfs:comment 'Indicates whether the provider offers warehousing and storage services as part of their operational capabilities.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wmsPlatform rdf:type rdf:Property ;
    rdfs:label 'Wms Platform' ;
    rdfs:comment 'Name and version of the Warehouse Management System (WMS) platform used by the provider for inventory control and order fulfillment.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentPartnerId rdf:type rdf:Property ;
    rdfs:label 'Parent Partner Id' ;
    rdfs:comment 'Self-referencing FK on partner (parent_partner_id)' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:aeoCertification rdf:type rdf:Property ;
    rdfs:label 'Aeo Certification' ;
    rdfs:comment 'AEO certification number indicating the partner has been certified as a secure and compliant supply chain participant.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondedWarehouseLicense rdf:type rdf:Property ;
    rdfs:label 'Bonded Warehouse License' ;
    rdfs:comment 'License number issued by customs authorities authorizing the partner to operate a bonded warehouse facility.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctpatCertification rdf:type rdf:Property ;
    rdfs:label 'Ctpat Certification' ;
    rdfs:comment 'C-TPAT certification number indicating the partner has been certified under the US CBP security program.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingCapacity rdf:type rdf:Property ;
    rdfs:label 'Handling Capacity' ;
    rdfs:comment 'Description of the partner\'s handling capacity, such as TEU capacity for container facilities or tonnage capacity for freight stations.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icaoCode rdf:type rdf:Property ;
    rdfs:label 'Icao Code' ;
    rdfs:comment 'Four-letter ICAO code assigned to the partner if they are an airport or aviation facility.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoCertification rdf:type rdf:Property ;
    rdfs:label 'Iso Certification' ;
    rdfs:comment 'ISO certification numbers held by the partner, such as ISO 9001 (Quality Management) or ISO 28000 (Supply Chain Security).' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkParticipationDate rdf:type rdf:Property ;
    rdfs:label 'Network Participation Date' ;
    rdfs:comment 'Date when the partner was onboarded and began participating in the Transport Shipping logistics network.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partnerCategory rdf:type rdf:Property ;
    rdfs:label 'Partner Category' ;
    rdfs:comment 'Classification of the partner type within the logistics network. Defines the operational role and service scope of the partner.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerStatus rdf:type rdf:Property ;
    rdfs:label 'Partner Status' ;
    rdfs:comment 'Current lifecycle status of the partner relationship within the network.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Assessed risk level of the partner based on financial stability, compliance history, operational performance, and security factors.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceModes rdf:type rdf:Property ;
    rdfs:label 'Service Modes' ;
    rdfs:comment 'Transport modes and service types supported by the partner (e.g., air, ocean, road, rail, multimodal).' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerCertificationId rdf:type rdf:Property ;
    rdfs:label 'Partner Certification Id' ;
    rdfs:comment 'Unique identifier for the partner certification record. Primary key.' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewedPartnerCertificationId rdf:type rdf:Property ;
    rdfs:label 'Renewed Partner Certification Id' ;
    rdfs:comment 'Self-referencing FK on partner_certification (renewed_partner_certification_id)' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerCertification .

ind:accreditationBody rdf:type rdf:Property ;
    rdfs:label 'Accreditation Body' ;
    rdfs:comment 'The name of the accreditation body that accredited the issuing authority or certification body (e.g., UKAS, ANAB, DAkkS). Applicable primarily to ISO certifications where the certification body itself must be accredited.' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Certification Document Url' ;
    rdfs:comment 'URL or file path to the digital copy of the certification certificate or official documentation stored in the document management system.' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'The unique certificate or registration number issued by the certifying authority. This is the externally-known identifier for the certification.' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Current lifecycle status of the certification. Indicates whether the certification is valid and in good standing. Values: active (valid and current), expired (past expiry date), suspended (temporarily invalid), pending_renewal (renewal application submitted), revoked (permanently invalidated), under_review (initial application or audit in progress).' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'The type or category of certification held by the partner. Indicates the regulatory, industry, or quality standard framework. Values: IATA (International Air Transport Association), AEO (Authorized Economic Operator), C-TPAT (Customs-Trade Partnership Against Terrorism), ISO_9001 (Quality Management System), GDP (Good Distribution Practice), TAPA (Transported Asset Protection Association), SmartWay (EPA environmental certification), FIATA (International Federation of Freight Forwarders Associations). [ENUM-REF-CANDIDATE: IATA|AEO|C-TPAT|ISO_9001|GDP|TAPA|SmartWay|FIATA — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceLevel rdf:type rdf:Property ;
    rdfs:label 'Compliance Level' ;
    rdfs:comment 'The tier, level, or grade of certification achieved, if the certification framework has multiple levels (e.g., AEO has different tiers in some jurisdictions; TAPA has Class A, B, C security levels). Nullable if certification has no levels.' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryForCommodityTypes rdf:type rdf:Property ;
    rdfs:label 'Mandatory For Commodity Types' ;
    rdfs:comment 'Comma-separated list of commodity types or HS Code (Harmonized System Code) categories for which this certification is required. Used to ensure only certified partners handle regulated goods (e.g., GDP for pharmaceuticals, IATA for dangerous goods).' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryForTradeLanes rdf:type rdf:Property ;
    rdfs:label 'Mandatory For Trade Lanes' ;
    rdfs:comment 'Comma-separated list of trade lane codes or route identifiers for which this certification is mandatory. Used to enforce compliance rules in partner selection and shipment routing (e.g., US_IMPORT requires C-TPAT, EU_EXPORT requires AEO).' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Notes' ;
    rdfs:comment 'Free-text notes documenting any non-compliance findings, audit observations, corrective action requests, or conditions attached to the certification. Used for compliance tracking and partner performance management.' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinstatementDate rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Date' ;
    rdfs:comment 'The date on which a previously suspended or revoked certification was reinstated to active status. Nullable if never reinstated. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalNotificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Notification Sent Flag' ;
    rdfs:comment 'Indicates whether a renewal reminder notification has been sent to the partner or internal compliance team. True if notification sent, False otherwise.' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Detailed description of the scope of the certification, including covered activities, services, locations, or product categories. For example, ISO 9001 scope may specify freight forwarding services at specific facilities; AEO may cover customs clearance and warehousing.' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Partner Performance Id' ;
    rdfs:comment 'Unique identifier for the partner performance evaluation record. Primary key.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorPartnerPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Prior Partner Performance Id' ;
    rdfs:comment 'Self-referencing FK on partner_performance (prior_partner_performance_id)' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerPerformance .

ind:capacityFulfillmentActualPct rdf:type rdf:Property ;
    rdfs:label 'Capacity Fulfillment Actual Pct' ;
    rdfs:comment 'Actual percentage of requested capacity that the partner was able to fulfill during the evaluation period.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityFulfillmentTargetPct rdf:type rdf:Property ;
    rdfs:label 'Capacity Fulfillment Target Pct' ;
    rdfs:comment 'Target percentage for capacity fulfillment as per partner agreement.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimsRateActualPct rdf:type rdf:Property ;
    rdfs:label 'Claims Rate Actual Pct' ;
    rdfs:comment 'Actual percentage of shipments resulting in claims (loss, damage, delay) during the evaluation period.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimsRateTargetPct rdf:type rdf:Property ;
    rdfs:label 'Claims Rate Target Pct' ;
    rdfs:comment 'Maximum acceptable claims rate threshold as per partner agreement.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compositeScore rdf:type rdf:Property ;
    rdfs:label 'Composite Score' ;
    rdfs:comment 'Weighted composite score aggregating all performance dimensions into a single overall performance rating (0-100 scale).' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Due Date' ;
    rdfs:comment 'Date by which the partner must submit or complete corrective action plan if required.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:damageRateActualPct rdf:type rdf:Property ;
    rdfs:label 'Damage Rate Actual Pct' ;
    rdfs:comment 'Actual percentage of shipments with damage incidents during the evaluation period.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:damageRateTargetPct rdf:type rdf:Property ;
    rdfs:label 'Damage Rate Target Pct' ;
    rdfs:comment 'Maximum acceptable damage rate threshold as per partner agreement.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentationAccuracyActualPct rdf:type rdf:Property ;
    rdfs:label 'Documentation Accuracy Actual Pct' ;
    rdfs:comment 'Actual percentage of shipments with accurate and complete documentation (AWB, BOL, customs paperwork) during the evaluation period.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentationAccuracyTargetPct rdf:type rdf:Property ;
    rdfs:label 'Documentation Accuracy Target Pct' ;
    rdfs:comment 'Target percentage for documentation accuracy as per partner agreement.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Completed Date' ;
    rdfs:comment 'Date when the performance evaluation was completed and finalized.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationFrequency rdf:type rdf:Property ;
    rdfs:label 'Evaluation Frequency' ;
    rdfs:comment 'Frequency at which this partner performance evaluation is conducted.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period End Date' ;
    rdfs:comment 'End date of the measurement period for this performance evaluation.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Start Date' ;
    rdfs:comment 'Start date of the measurement period for this performance evaluation.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:otdRateActualPct rdf:type rdf:Property ;
    rdfs:label 'Otd Rate Actual Pct' ;
    rdfs:comment 'Actual on-time delivery rate achieved by the partner during the evaluation period, expressed as a percentage.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otdRateTargetPct rdf:type rdf:Property ;
    rdfs:label 'Otd Rate Target Pct' ;
    rdfs:comment 'Target on-time delivery rate contracted with the partner, expressed as a percentage.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewNotes rdf:type rdf:Property ;
    rdfs:label 'Review Notes' ;
    rdfs:comment 'Detailed notes and commentary from the performance review, including strengths, weaknesses, and improvement actions.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Review Outcome' ;
    rdfs:comment 'Business decision outcome resulting from this performance evaluation (continue partnership, renew contract, place on probation, terminate, escalate for executive review).' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalShipmentsEvaluated rdf:type rdf:Property ;
    rdfs:label 'Total Shipments Evaluated' ;
    rdfs:comment 'Total number of shipments handled by the partner during the evaluation period that were included in this performance assessment.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVolumeTeu rdf:type rdf:Property ;
    rdfs:label 'Total Volume Teu' ;
    rdfs:comment 'Total volume handled by the partner during the evaluation period, measured in TEU for ocean freight partners.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transitTimeComplianceActualPct rdf:type rdf:Property ;
    rdfs:label 'Transit Time Compliance Actual Pct' ;
    rdfs:comment 'Actual percentage of shipments meeting contracted transit time commitments during the evaluation period.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transitTimeComplianceTargetPct rdf:type rdf:Property ;
    rdfs:label 'Transit Time Compliance Target Pct' ;
    rdfs:comment 'Target percentage for transit time compliance as per partner agreement.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trendDirection rdf:type rdf:Property ;
    rdfs:label 'Trend Direction' ;
    rdfs:comment 'Overall performance trend direction compared to the previous evaluation period.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityAllocationId rdf:type rdf:Property ;
    rdfs:label 'Capacity Allocation Id' ;
    rdfs:comment 'Unique identifier for the capacity allocation record. Primary key for the capacity allocation entity.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractAgreementId rdf:type rdf:Property ;
    rdfs:label 'Contract Agreement Id' ;
    rdfs:comment 'Reference to the master carrier agreement or partnership contract under which this capacity allocation is governed.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:revisedCapacityAllocationId rdf:type rdf:Property ;
    rdfs:label 'Revised Capacity Allocation Id' ;
    rdfs:comment 'Self-referencing FK on capacity_allocation (revised_capacity_allocation_id)' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapacityAllocation .

ind:tradeLaneId rdf:type rdf:Property ;
    rdfs:label 'Trade Lane Id' ;
    rdfs:comment 'Reference to the trade lane (origin-destination corridor) for which capacity is allocated.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lane .

ind:allocatedCapacityPalletPositions rdf:type rdf:Property ;
    rdfs:label 'Allocated Capacity Pallet Positions' ;
    rdfs:comment 'Total pallet position capacity allocated by the carrier or partner for the specified period and trade lane. Applicable to road and rail freight.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedCapacityTeu rdf:type rdf:Property ;
    rdfs:label 'Allocated Capacity Teu' ;
    rdfs:comment 'Total container capacity allocated by the carrier for the specified period and trade lane, measured in TEU. Applicable to ocean freight (FCL shipments).' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocatedCapacityVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Allocated Capacity Volume Cbm' ;
    rdfs:comment 'Total volume capacity allocated by the carrier or partner for the specified period and trade lane, measured in cubic meters. Applicable to all transport modes.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocatedCapacityWeightKg rdf:type rdf:Property ;
    rdfs:label 'Allocated Capacity Weight Kg' ;
    rdfs:comment 'Total weight capacity allocated by the carrier or partner for the specified period and trade lane, measured in kilograms. Applicable primarily to air and road freight.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Allocation Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for any financial terms associated with the capacity allocation (e.g., minimum commitment charges, overage fees).' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationEndDate rdf:type rdf:Property ;
    rdfs:label 'Allocation End Date' ;
    rdfs:comment 'The date when the capacity allocation expires or is no longer available for booking. Nullable for open-ended allocations.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationPeriodType rdf:type rdf:Property ;
    rdfs:label 'Allocation Period Type' ;
    rdfs:comment 'Frequency or granularity of the capacity allocation period: daily, weekly, monthly, quarterly, or annual allocation cycle.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Reference Number' ;
    rdfs:comment 'External business identifier for the capacity allocation, typically provided by the carrier or partner for tracking and reconciliation purposes.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationStartDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Start Date' ;
    rdfs:comment 'The date when the capacity allocation becomes effective and available for booking.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bookingCutoffHours rdf:type rdf:Property ;
    rdfs:label 'Booking Cutoff Hours' ;
    rdfs:comment 'Number of hours before departure or shipment date by which bookings must be made to utilize this capacity allocation.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityFillRatePercent rdf:type rdf:Property ;
    rdfs:label 'Capacity Fill Rate Percent' ;
    rdfs:comment 'Percentage of allocated capacity that has been utilized during the period, calculated as (utilized / allocated) * 100. Key performance indicator for capacity procurement efficiency.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacitySourceType rdf:type rdf:Property ;
    rdfs:label 'Capacity Source Type' ;
    rdfs:comment 'Type of capacity procurement arrangement: blocked space agreement (BSA), allotment, spot market purchase, long-term contract, or ad-hoc allocation.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityRestriction rdf:type rdf:Property ;
    rdfs:label 'Commodity Restriction' ;
    rdfs:comment 'Restrictions on commodity types that can be shipped using this capacity allocation (e.g., general cargo only, no hazardous materials, perishables only). Nullable if no restrictions apply.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumCommitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Commitment Amount' ;
    rdfs:comment 'Minimum financial commitment or guaranteed payment amount for the capacity allocation, regardless of utilization. Nullable if no minimum commitment exists.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overageRatePerUnit rdf:type rdf:Property ;
    rdfs:label 'Overage Rate Per Unit' ;
    rdfs:comment 'Additional charge per unit (kg, TEU, CBM, pallet) if utilization exceeds the allocated capacity. Nullable if overage is not permitted or not charged.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizedCapacityPalletPositions rdf:type rdf:Property ;
    rdfs:label 'Utilized Capacity Pallet Positions' ;
    rdfs:comment 'Actual pallet position capacity utilized or booked against the allocation during the period.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:utilizedCapacityTeu rdf:type rdf:Property ;
    rdfs:label 'Utilized Capacity Teu' ;
    rdfs:comment 'Actual container capacity utilized or booked against the allocation during the period, measured in TEU.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizedCapacityVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Utilized Capacity Volume Cbm' ;
    rdfs:comment 'Actual volume capacity utilized or booked against the allocation during the period, measured in cubic meters.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizedCapacityWeightKg rdf:type rdf:Property ;
    rdfs:label 'Utilized Capacity Weight Kg' ;
    rdfs:comment 'Actual weight capacity utilized or booked against the allocation during the period, measured in kilograms.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewedBlockedSpaceAgreementId rdf:type rdf:Property ;
    rdfs:label 'Renewed Blocked Space Agreement Id' ;
    rdfs:comment 'Self-referencing FK on blocked_space_agreement (renewed_blocked_space_agreement_id)' ;
    rdfs:domain ind:BlockedSpaceAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BlockedSpaceAgreement .

ind:agreementReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Reference Number' ;
    rdfs:comment 'The externally-known business identifier or contract number for this blocked space agreement, used in communications with the carrier and internal stakeholders.' ;
    rdfs:domain ind:BlockedSpaceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationFrequency rdf:type rdf:Property ;
    rdfs:label 'Allocation Frequency' ;
    rdfs:comment 'The frequency at which the guaranteed capacity is allocated or refreshed (e.g., weekly allocation of 100 TEU, monthly allocation of 50,000 kg).' ;
    rdfs:domain ind:BlockedSpaceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseRatePerUnit rdf:type rdf:Property ;
    rdfs:label 'Base Rate Per Unit' ;
    rdfs:comment 'The base freight rate per unit of capacity (per TEU, per kg, per CBM) agreed in this blocked space agreement. Subject to surcharges and adjustments.' ;
    rdfs:domain ind:BlockedSpaceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blockedSpaceAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Blocked Space Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the blocked space agreement. Draft indicates under negotiation; Active indicates in force; Suspended indicates temporarily paused; Expired indicates past end date; Terminated indicates cancelled before expiry; Pending Renewal indicates approaching expiry with renewal in progress.' ;
    rdfs:domain ind:BlockedSpaceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit Of Measure' ;
    rdfs:comment 'Primary unit of measure used to express the guaranteed capacity in this agreement: TEU for ocean containers, kg or CBM for air freight, or pallets for specialized services.' ;
    rdfs:domain ind:BlockedSpaceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forceMajeureClause rdf:type rdf:Property ;
    rdfs:label 'Force Majeure Clause' ;
    rdfs:comment 'Summary of the force majeure provisions that excuse performance under extraordinary circumstances (e.g., natural disasters, war, strikes, pandemics).' ;
    rdfs:domain ind:BlockedSpaceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteedCapacityCbm rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Capacity Cbm' ;
    rdfs:comment 'Total volume capacity guaranteed to Transport Shipping measured in cubic meters. Applicable to both ocean LCL and air freight agreements.' ;
    rdfs:domain ind:BlockedSpaceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteedCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Capacity Kg' ;
    rdfs:comment 'Total weight capacity guaranteed to Transport Shipping measured in kilograms for air freight agreements. Null for ocean agreements.' ;
    rdfs:domain ind:BlockedSpaceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteedCapacityTeu rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Capacity Teu' ;
    rdfs:comment 'Total capacity guaranteed to Transport Shipping measured in TEU (Twenty-foot Equivalent Units) for ocean agreements. Null for air freight agreements.' ;
    rdfs:domain ind:BlockedSpaceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumUtilizationCommitmentAbsolute rdf:type rdf:Property ;
    rdfs:label 'Minimum Utilization Commitment Absolute' ;
    rdfs:comment 'The minimum absolute quantity of capacity (in the agreement\'s unit of measure) that Transport Shipping commits to utilize. Alternative or complementary to percentage-based commitment.' ;
    rdfs:domain ind:BlockedSpaceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumUtilizationCommitmentPercent rdf:type rdf:Property ;
    rdfs:label 'Minimum Utilization Commitment Percent' ;
    rdfs:comment 'The minimum percentage of guaranteed capacity that Transport Shipping commits to utilize over the agreement period. Failure to meet this threshold may trigger penalties.' ;
    rdfs:domain ind:BlockedSpaceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyForUnderutilization rdf:type rdf:Property ;
    rdfs:label 'Penalty For Underutilization' ;
    rdfs:comment 'Description of the financial or operational penalty imposed if Transport Shipping fails to meet the minimum utilization commitment (e.g., payment for unused capacity, rate adjustment, loss of priority).' ;
    rdfs:domain ind:BlockedSpaceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rolloverLimitPercent rdf:type rdf:Property ;
    rdfs:label 'Rollover Limit Percent' ;
    rdfs:comment 'Maximum percentage of unused capacity that can be rolled over to the next allocation period, if rollover is allowed. Null if no limit or rollover not allowed.' ;
    rdfs:domain ind:BlockedSpaceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:signedByCarrier rdf:type rdf:Property ;
    rdfs:label 'Signed By Carrier' ;
    rdfs:comment 'Name and title of the carrier authorized signatory who executed this agreement.' ;
    rdfs:domain ind:BlockedSpaceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signedByTransportShipping rdf:type rdf:Property ;
    rdfs:label 'Signed By Transport Shipping' ;
    rdfs:comment 'Name and title of the Transport Shipping authorized signatory who executed this agreement.' ;
    rdfs:domain ind:BlockedSpaceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'The date on which this blocked space agreement was formally executed by both Transport Shipping and the carrier.' ;
    rdfs:domain ind:BlockedSpaceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:connectingCarrierServiceId rdf:type rdf:Property ;
    rdfs:label 'Connecting Carrier Service Id' ;
    rdfs:comment 'Self-referencing FK on carrier_service (connecting_carrier_service_id)' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarrierService .

ind:carbonNeutralCertified rdf:type rdf:Property ;
    rdfs:label 'Carbon Neutral Certified' ;
    rdfs:comment 'Indicates whether this service is certified as carbon-neutral through offsets or sustainable fuel programs.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cutoffDayOffset rdf:type rdf:Property ;
    rdfs:label 'Cutoff Day Offset' ;
    rdfs:comment 'The number of days before departure that the cutoff time applies (0 = same day, 1 = one day before, etc.).' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cutoffTimeLocal rdf:type rdf:Property ;
    rdfs:label 'Cutoff Time Local' ;
    rdfs:comment 'The local time by which cargo must be delivered to the carrier facility to be accepted for this service (format: HH:MM).' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dangerousGoodsCapable rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Capable' ;
    rdfs:comment 'Indicates whether this service is certified to handle dangerous goods (DG) or hazardous materials (HAZMAT).' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dgClassesSupported rdf:type rdf:Property ;
    rdfs:label 'Dg Classes Supported' ;
    rdfs:comment 'Comma-separated list of UN dangerous goods classes supported by this service (e.g., 1, 2.1, 3, 4.1, 5.1, 6.1, 8, 9).' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationCutoffTime rdf:type rdf:Property ;
    rdfs:label 'Documentation Cutoff Time' ;
    rdfs:comment 'The local time by which shipping documentation (AWB, BOL, customs declarations) must be submitted (format: HH:MM).' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:doorToDoorAvailable rdf:type rdf:Property ;
    rdfs:label 'Door To Door Available' ;
    rdfs:comment 'Indicates whether this service includes door-to-door pickup and delivery, or is port-to-port / terminal-to-terminal only.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentTypesSupported rdf:type rdf:Property ;
    rdfs:label 'Equipment Types Supported' ;
    rdfs:comment 'Comma-separated list of equipment types supported by this service (e.g., 20GP, 40HC, 45HC for ocean; ULD types for air; truck types for road).' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightServiceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Flight Service Identifier' ;
    rdfs:comment 'The carrier-assigned flight number or air service identifier (for air freight).' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsSupported rdf:type rdf:Property ;
    rdfs:label 'Incoterms Supported' ;
    rdfs:comment 'Comma-separated list of Incoterms (International Commercial Terms) supported by this service (e.g., FOB, CIF, DDP, DAP, EXW).' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceAvailable rdf:type rdf:Property ;
    rdfs:label 'Insurance Available' ;
    rdfs:comment 'Indicates whether cargo insurance is available or included with this service.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liveAnimalCapable rdf:type rdf:Property ;
    rdfs:label 'Live Animal Capable' ;
    rdfs:comment 'Indicates whether this service is certified to transport live animals.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oversizedCargoCapable rdf:type rdf:Property ;
    rdfs:label 'Oversized Cargo Capable' ;
    rdfs:comment 'Indicates whether this service can handle oversized or out-of-gauge cargo that exceeds standard equipment dimensions.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:perishableCargoCapable rdf:type rdf:Property ;
    rdfs:label 'Perishable Cargo Capable' ;
    rdfs:comment 'Indicates whether this service supports perishable cargo requiring time-sensitive handling.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceStatus rdf:type rdf:Property ;
    rdfs:label 'Service Status' ;
    rdfs:comment 'The current operational status of this carrier service: active (available for booking), suspended (temporarily unavailable), discontinued (permanently ended), seasonal (operates during specific periods), or planned (future service).' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingAvailable rdf:type rdf:Property ;
    rdfs:label 'Tracking Available' ;
    rdfs:comment 'Indicates whether real-time or milestone-based shipment tracking is available for this service.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainServiceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Train Service Identifier' ;
    rdfs:comment 'The carrier-assigned train service number or rail service identifier (for rail freight).' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselServiceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Vessel Service Identifier' ;
    rdfs:comment 'The carrier-assigned identifier for the vessel service string (for ocean freight) or vessel rotation code.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierContactId rdf:type rdf:Property ;
    rdfs:label 'Carrier Contact Id' ;
    rdfs:comment 'Unique identifier for the carrier contact record. Primary key.' ;
    rdfs:domain ind:CarrierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportsToCarrierContactId rdf:type rdf:Property ;
    rdfs:label 'Reports To Carrier Contact Id' ;
    rdfs:comment 'Self-referencing FK on carrier_contact (reports_to_carrier_contact_id)' ;
    rdfs:domain ind:CarrierContact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarrierContact .

ind:activeStatus rdf:type rdf:Property ;
    rdfs:label 'Active Status' ;
    rdfs:comment 'Current status of the contact indicating whether they are actively available for communication and liaison activities.' ;
    rdfs:domain ind:CarrierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactFirstName rdf:type rdf:Property ;
    rdfs:label 'Contact First Name' ;
    rdfs:comment 'Given name of the contact person.' ;
    rdfs:domain ind:CarrierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactFullName rdf:type rdf:Property ;
    rdfs:label 'Contact Full Name' ;
    rdfs:comment 'Full legal name of the individual contact at the carrier or partner organization.' ;
    rdfs:domain ind:CarrierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactLastName rdf:type rdf:Property ;
    rdfs:label 'Contact Last Name' ;
    rdfs:comment 'Family name or surname of the contact person.' ;
    rdfs:domain ind:CarrierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactFlag rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Flag' ;
    rdfs:comment 'Indicates whether this contact should be reached for emergency or critical operational issues requiring immediate attention.' ;
    rdfs:domain ind:CarrierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Contact Date' ;
    rdfs:comment 'Date of the most recent communication or interaction with this contact.' ;
    rdfs:domain ind:CarrierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mobileNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Number' ;
    rdfs:comment 'Mobile or cellular phone number for the contact, used for urgent or after-hours communication.' ;
    rdfs:domain ind:CarrierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeLocation rdf:type rdf:Property ;
    rdfs:label 'Office Location' ;
    rdfs:comment 'Physical office location or branch where the contact is based (e.g., city, country, or facility name).' ;
    rdfs:domain ind:CarrierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommunicationChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Channel' ;
    rdfs:comment 'The contact\'s preferred method of communication for routine business interactions.' ;
    rdfs:domain ind:CarrierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedAirports rdf:type rdf:Property ;
    rdfs:label 'Affected Airports' ;
    rdfs:comment 'Comma-separated list of IATA airport codes affected by this network event (e.g., JFK, PVG, AMS).' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedCountries rdf:type rdf:Property ;
    rdfs:label 'Affected Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes for countries impacted by this network event.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedPorts rdf:type rdf:Property ;
    rdfs:label 'Affected Ports' ;
    rdfs:comment 'Comma-separated list of port codes or names affected by this network event (e.g., USNYC, CNSHA, NLRTM).' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedRegions rdf:type rdf:Property ;
    rdfs:label 'Affected Regions' ;
    rdfs:comment 'Comma-separated list of geographic regions impacted by this network event (e.g., APAC, EMEA, Americas).' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedTradeLanes rdf:type rdf:Property ;
    rdfs:label 'Affected Trade Lanes' ;
    rdfs:comment 'Comma-separated list of trade lanes or shipping routes impacted by this network event (e.g., Asia-Europe, Trans-Pacific, North Atlantic).' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedTransportModes rdf:type rdf:Property ;
    rdfs:label 'Affected Transport Modes' ;
    rdfs:comment 'Comma-separated list of transport modes impacted by this event (e.g., air, ocean, road, rail).' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeCarrierEngaged rdf:type rdf:Property ;
    rdfs:label 'Alternative Carrier Engaged' ;
    rdfs:comment 'Indicates whether alternative carriers have been engaged to provide substitute capacity during this network event.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alternativeRoutingAvailable rdf:type rdf:Property ;
    rdfs:label 'Alternative Routing Available' ;
    rdfs:comment 'Indicates whether alternative routing options are available to bypass the affected network segment.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerNotificationDatetime rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Datetime' ;
    rdfs:comment 'Date and time when customer notifications were sent regarding this network event.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerNotificationSent rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Sent' ;
    rdfs:comment 'Indicates whether affected customers have been notified about this network event and its impact on their shipments.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endDatetime rdf:type rdf:Property ;
    rdfs:label 'End Datetime' ;
    rdfs:comment 'Date and time when the network disruption or event was resolved and operations returned to normal. Null if event is ongoing.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:escalationDatetime rdf:type rdf:Property ;
    rdfs:label 'Escalation Datetime' ;
    rdfs:comment 'Date and time when this network event was escalated to higher management levels.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:escalationRequired rdf:type rdf:Property ;
    rdfs:label 'Escalation Required' ;
    rdfs:comment 'Indicates whether this network event requires escalation to senior management or executive leadership.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedCapacityLossTeu rdf:type rdf:Property ;
    rdfs:label 'Estimated Capacity Loss Teu' ;
    rdfs:comment 'Estimated loss of container capacity measured in TEU resulting from this network event.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedDelayHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Delay Hours' ;
    rdfs:comment 'Estimated average delay in hours to shipments affected by this network event.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedShipmentsAffected rdf:type rdf:Property ;
    rdfs:label 'Estimated Shipments Affected' ;
    rdfs:comment 'Estimated number of active shipments impacted by this network event.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventCode rdf:type rdf:Property ;
    rdfs:label 'Event Code' ;
    rdfs:comment 'Unique business identifier code assigned to this network event for external reference and tracking.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactEstimatedUsd rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Estimated Usd' ;
    rdfs:comment 'Estimated financial impact of this network event in USD, including revenue loss, additional costs, and penalties.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lessonsLearned rdf:type rdf:Property ;
    rdfs:label 'Lessons Learned' ;
    rdfs:comment 'Documentation of lessons learned and recommendations for preventing similar network events in the future.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationActionsTaken rdf:type rdf:Property ;
    rdfs:label 'Mitigation Actions Taken' ;
    rdfs:comment 'Detailed description of mitigation actions and contingency measures implemented to minimize the impact of this network event.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalImpactDescription rdf:type rdf:Property ;
    rdfs:label 'Operational Impact Description' ;
    rdfs:comment 'Detailed description of the operational impact on service delivery, capacity, transit times, and customer commitments resulting from this network event.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Name' ;
    rdfs:comment 'Name of the regulatory authority or governing body notified about this network event (e.g., IMO, IATA, FMC, DOT).' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityNotified rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Notified' ;
    rdfs:comment 'Indicates whether relevant regulatory authorities have been notified about this network event as required by compliance obligations.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionDescription rdf:type rdf:Property ;
    rdfs:label 'Resolution Description' ;
    rdfs:comment 'Detailed description of how the network event was resolved and operations were restored to normal.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDetails rdf:type rdf:Property ;
    rdfs:label 'Root Cause Details' ;
    rdfs:comment 'Detailed explanation of the root cause analysis findings for this network event.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachCount rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Count' ;
    rdfs:comment 'Number of SLA breaches resulting from this network event across affected customer contracts.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:startDatetime rdf:type rdf:Property ;
    rdfs:label 'Start Datetime' ;
    rdfs:comment 'Date and time when the network disruption or event began affecting operations.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:partnerOnboardingId rdf:type rdf:Property ;
    rdfs:label 'Partner Onboarding Id' ;
    rdfs:comment 'Unique identifier for the partner onboarding record. Primary key for tracking the end-to-end onboarding lifecycle of a network partner from initial qualification through activation.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reactivationPartnerOnboardingId rdf:type rdf:Property ;
    rdfs:label 'Reactivation Partner Onboarding Id' ;
    rdfs:comment 'Self-referencing FK on partner_onboarding (reactivation_partner_onboarding_id)' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerOnboarding .

ind:actualActivationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Activation Date' ;
    rdfs:comment 'Actual date when the partner was activated and began operational activities. Nullable until activation is completed.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Verification Status' ;
    rdfs:comment 'Status of industry certification verification (ISO, AEO, C-TPAT, dangerous goods, etc.). Confirms partner holds required certifications.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Certification Verified Date' ;
    rdfs:comment 'Date when required certifications were verified.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Contract Execution Date' ;
    rdfs:comment 'Date when the partnership contract was formally executed by all parties. Marks legal commitment.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dueDiligenceCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Due Diligence Completed Date' ;
    rdfs:comment 'Date when comprehensive due diligence checks (financial, operational, compliance) were completed and approved.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ediIntegrationStatus rdf:type rdf:Property ;
    rdfs:label 'Edi Integration Status' ;
    rdfs:comment 'Status of EDI connectivity setup and testing. Tracks technical integration for automated data exchange.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Financial Assessment Date' ;
    rdfs:comment 'Date when the financial assessment was completed.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialAssessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Financial Assessment Status' ;
    rdfs:comment 'Status of the financial viability and creditworthiness assessment. Evaluates partner financial stability and risk.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicScopeAuthorized rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope Authorized' ;
    rdfs:comment 'Geographic regions or countries the partner is authorized to operate in. Defines territorial scope of the partnership.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedDate rdf:type rdf:Property ;
    rdfs:label 'Initiated Date' ;
    rdfs:comment 'Date when the onboarding process was formally initiated. Marks the beginning of the partner onboarding lifecycle.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Insurance Verification Status' ;
    rdfs:comment 'Status of insurance coverage verification. Confirms partner has adequate liability, cargo, and other required insurance.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Verified Date' ;
    rdfs:comment 'Date when insurance coverage was verified and approved.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Kyc Check Status' ;
    rdfs:comment 'Status of the Know Your Customer compliance check. Verifies partner identity, ownership structure, and legitimacy.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Completed Date' ;
    rdfs:comment 'Date when the KYC compliance check was completed and approved.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingDurationDays rdf:type rdf:Property ;
    rdfs:label 'Onboarding Duration Days' ;
    rdfs:comment 'Total number of calendar days from initiation to activation. Used for process performance measurement and continuous improvement.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onboardingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Onboarding Reference Number' ;
    rdfs:comment 'Externally-known unique business identifier for this onboarding case. Used for tracking and communication with the partner and internal stakeholders.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingType rdf:type rdf:Property ;
    rdfs:label 'Onboarding Type' ;
    rdfs:comment 'Type of onboarding activity. Distinguishes between new partner onboarding, expansion of existing partner capabilities, or reactivation of dormant partnerships.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalReadinessScore rdf:type rdf:Property ;
    rdfs:label 'Operational Readiness Score' ;
    rdfs:comment 'Composite score (0-100) assessing the partner readiness across all onboarding dimensions. Used for go/no-go decision making.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preQualificationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Pre Qualification Completed Date' ;
    rdfs:comment 'Date when the pre-qualification stage was completed. Indicates the partner met initial screening criteria.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sanctionsScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Date' ;
    rdfs:comment 'Date when sanctions screening was performed and cleared.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sanctionsScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Status' ;
    rdfs:comment 'Status of sanctions and denied party screening. Ensures partner is not on restricted or prohibited lists.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceModesAuthorized rdf:type rdf:Property ;
    rdfs:label 'Service Modes Authorized' ;
    rdfs:comment 'Comma-separated list of transport modes the partner is authorized to operate (air, ocean, road, rail, multimodal). Defines operational scope.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemIntegrationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'System Integration Completed Date' ;
    rdfs:comment 'Date when technical system integration (EDI, API, TMS connectivity) was completed and tested successfully.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetActivationDate rdf:type rdf:Property ;
    rdfs:label 'Target Activation Date' ;
    rdfs:comment 'Planned date for the partner to go live and begin operational activities. Used for project planning and stakeholder communication.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tmsIntegrationStatus rdf:type rdf:Property ;
    rdfs:label 'Tms Integration Status' ;
    rdfs:comment 'Status of TMS system integration. Tracks connectivity to core transportation management platform for order and shipment processing.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerSettlementId rdf:type rdf:Property ;
    rdfs:label 'Partner Settlement Id' ;
    rdfs:comment 'Unique identifier for the partner settlement transaction. Primary key for the partner settlement record.' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reversedPartnerSettlementId rdf:type rdf:Property ;
    rdfs:label 'Reversed Partner Settlement Id' ;
    rdfs:comment 'Self-referencing FK on partner_settlement (reversed_partner_settlement_id)' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerSettlement .

ind:actualPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Actual Payment Date' ;
    rdfs:comment 'Actual date on which payment was successfully made to the partner, as confirmed by the payment system.' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awbCount rdf:type rdf:Property ;
    rdfs:label 'Awb Count' ;
    rdfs:comment 'Number of air waybills included in this settlement period for interline traffic settlements.' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deductionAmount rdf:type rdf:Property ;
    rdfs:label 'Deduction Amount' ;
    rdfs:comment 'Total amount of deductions applied to the gross settlement, including penalties, chargebacks, claims offsets, and other adjustments.' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossSettlementAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Settlement Amount' ;
    rdfs:comment 'Total settlement amount before any deductions, adjustments, or withholdings are applied.' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Original Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code of the original transaction currency before any currency conversion was applied.' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Payment Date' ;
    rdfs:comment 'Target date on which payment is scheduled to be made to the partner based on payment terms and approval date.' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementMethod rdf:type rdf:Property ;
    rdfs:label 'Settlement Method' ;
    rdfs:comment 'Payment mechanism used to settle the financial obligation with the partner. CASS refers to IATA Cargo Accounts Settlement System. [ENUM-REF-CANDIDATE: cass|bank_transfer|wire_transfer|ach|netting|offset|check — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Period End Date' ;
    rdfs:comment 'End date of the period covered by this settlement (e.g., end of the month or billing cycle).' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Period Start Date' ;
    rdfs:comment 'Start date of the period covered by this settlement (e.g., beginning of the month or billing cycle).' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Settlement Reference Number' ;
    rdfs:comment 'Externally visible unique reference number for this settlement transaction, used for partner communication and reconciliation.' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxWithholdingAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Withholding Amount' ;
    rdfs:comment 'Amount of tax withheld at source as required by local tax regulations or international tax treaties.' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supersededPartnerSlaId rdf:type rdf:Property ;
    rdfs:label 'Superseded Partner Sla Id' ;
    rdfs:comment 'Self-referencing FK on partner_sla (superseded_partner_sla_id)' ;
    rdfs:domain ind:PartnerSla ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerSla .

ind:breachThreshold rdf:type rdf:Property ;
    rdfs:label 'Breach Threshold' ;
    rdfs:comment 'Performance level at which the SLA is considered breached, triggering penalties or remediation actions.' ;
    rdfs:domain ind:PartnerSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentiveClauseReference rdf:type rdf:Property ;
    rdfs:label 'Incentive Clause Reference' ;
    rdfs:comment 'Reference to the contract clause or document section that defines incentives or bonuses for exceeding SLA targets.' ;
    rdfs:domain ind:PartnerSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Incentive Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the incentive amount.' ;
    rdfs:domain ind:PartnerSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Days' ;
    rdfs:comment 'Number of days over which performance is aggregated for SLA evaluation (e.g., rolling 30-day average).' ;
    rdfs:domain ind:PartnerSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementUnit rdf:type rdf:Property ;
    rdfs:label 'Measurement Unit' ;
    rdfs:comment 'Unit of measure for the performance metric (e.g., percentage, hours, days, count).' ;
    rdfs:domain ind:PartnerSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyClauseReference rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause Reference' ;
    rdfs:comment 'Reference to the contract clause or document section that defines penalties for SLA breach.' ;
    rdfs:domain ind:PartnerSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceMetric rdf:type rdf:Property ;
    rdfs:label 'Performance Metric' ;
    rdfs:comment 'Specific metric or Key Performance Indicator (KPI) being measured under this SLA (e.g., on-time delivery percentage, average transit days, documentation error rate).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'Frequency at which SLA performance reports are provided to stakeholders (e.g., daily, weekly, monthly, quarterly).' ;
    rdfs:domain ind:PartnerSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sla Reference Number' ;
    rdfs:comment 'Externally-known unique reference number or code for this partner SLA commitment.' ;
    rdfs:domain ind:PartnerSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warningThreshold rdf:type rdf:Property ;
    rdfs:label 'Warning Threshold' ;
    rdfs:comment 'Performance level that triggers a warning notification before a full SLA breach occurs. Allows proactive intervention.' ;
    rdfs:domain ind:PartnerSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ediConnectionId rdf:type rdf:Property ;
    rdfs:label 'Edi Connection Id' ;
    rdfs:comment 'Unique identifier for the EDI or API integration connection record. Primary key.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fallbackEdiConnectionId rdf:type rdf:Property ;
    rdfs:label 'Fallback Edi Connection Id' ;
    rdfs:comment 'Self-referencing FK on edi_connection (fallback_edi_connection_id)' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EdiConnection .

ind:acknowledgmentRequired rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Required' ;
    rdfs:comment 'Indicates whether the partner is required to send functional acknowledgments (e.g., CONTRL, 997) for messages received through this connection.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:averageDailyMessageVolume rdf:type rdf:Property ;
    rdfs:label 'Average Daily Message Volume' ;
    rdfs:comment 'Average number of messages exchanged per day through this connection, used for capacity planning and performance monitoring.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compressionEnabled rdf:type rdf:Property ;
    rdfs:label 'Compression Enabled' ;
    rdfs:comment 'Indicates whether message compression is enabled to reduce bandwidth usage and improve transmission efficiency.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:connectionHealthStatus rdf:type rdf:Property ;
    rdfs:label 'Connection Health Status' ;
    rdfs:comment 'Current health status of the EDI connection based on recent transmission success rates, latency, and error patterns. Used for proactive monitoring and alerting.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectionName rdf:type rdf:Property ;
    rdfs:label 'Connection Name' ;
    rdfs:comment 'Human-readable name or label for the EDI connection, typically including partner name and connection type for easy identification.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Connection Reference Number' ;
    rdfs:comment 'Business-assigned unique reference number or code for this EDI connection, used for operational tracking and support.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectionStatus rdf:type rdf:Property ;
    rdfs:label 'Connection Status' ;
    rdfs:comment 'Overall lifecycle status of the EDI connection. Reflects the current operational state from initial setup through active use to eventual termination.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectionType rdf:type rdf:Property ;
    rdfs:label 'Connection Type' ;
    rdfs:comment 'Type of electronic integration connection established with the partner. Includes traditional EDI standards (TRADACOMS, EDIFACT, X12) and modern API protocols (REST, SOAP) as well as file transfer methods (SFTP, AS2, FTP). [ENUM-REF-CANDIDATE: EDI_TRADACOMS|EDI_EDIFACT|EDI_X12|API_REST|API_SOAP|SFTP|AS2|FTP|FTPS — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionEnabled rdf:type rdf:Property ;
    rdfs:label 'Encryption Enabled' ;
    rdfs:comment 'Indicates whether message encryption is enabled for this connection to protect data in transit.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:encryptionProtocol rdf:type rdf:Property ;
    rdfs:label 'Encryption Protocol' ;
    rdfs:comment 'Encryption protocol or standard used to secure messages transmitted through this connection (e.g., TLS 1.2, TLS 1.3, PGP, S/MIME).' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointHost rdf:type rdf:Property ;
    rdfs:label 'Endpoint Host' ;
    rdfs:comment 'Hostname or IP address of the partner\'s EDI or API server. Confidential business integration detail.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointPort rdf:type rdf:Property ;
    rdfs:label 'Endpoint Port' ;
    rdfs:comment 'Network port number used for the EDI or API connection (e.g., 443 for HTTPS, 22 for SFTP).' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endpointUrl rdf:type rdf:Property ;
    rdfs:label 'Endpoint Url' ;
    rdfs:comment 'The URL or network address of the partner\'s EDI or API endpoint where messages are sent or received. Confidential business integration detail.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interchangeControlReferencePrefix rdf:type rdf:Property ;
    rdfs:label 'Interchange Control Reference Prefix' ;
    rdfs:comment 'Prefix or pattern used for generating unique interchange control numbers in EDI message headers for this connection.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastFailedTransmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Failed Transmission Timestamp' ;
    rdfs:comment 'Timestamp of the most recent failed message transmission attempt, used for troubleshooting and alerting.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastHealthCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Health Check Timestamp' ;
    rdfs:comment 'Timestamp of the most recent automated health check performed on this connection.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastSuccessfulTransmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Successful Transmission Timestamp' ;
    rdfs:comment 'Timestamp of the most recent successful message transmission through this connection, used for health monitoring.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:messageDirection rdf:type rdf:Property ;
    rdfs:label 'Message Direction' ;
    rdfs:comment 'Indicates whether this connection is used for sending messages to the partner (outbound), receiving messages from the partner (inbound), or both (bidirectional).' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageTypesSupported rdf:type rdf:Property ;
    rdfs:label 'Message Types Supported' ;
    rdfs:comment 'Comma-separated list of message types or transaction sets supported by this connection (e.g., IFTMBF booking confirmation, IFTSTA status update, AWB data, manifest, invoice, DESADV despatch advice).' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peakMessageVolume rdf:type rdf:Property ;
    rdfs:label 'Peak Message Volume' ;
    rdfs:comment 'Maximum number of messages processed in a single day through this connection, representing peak capacity utilization.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productionEnvironmentStatus rdf:type rdf:Property ;
    rdfs:label 'Production Environment Status' ;
    rdfs:comment 'Current operational status of the production environment connection. Indicates whether the connection is actively processing live business transactions.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolVersion rdf:type rdf:Property ;
    rdfs:label 'Protocol Version' ;
    rdfs:comment 'Version of the EDI standard or API protocol being used for this connection (e.g., EDIFACT D.96A, X12 4010, REST API v2.1).' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiverIdentifier rdf:type rdf:Property ;
    rdfs:label 'Receiver Identifier' ;
    rdfs:comment 'EDI receiver identification code or qualifier assigned to the partner for inbound messages (e.g., partner\'s SCAC code, IATA code, GLN, DUNS number).' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderIdentifier rdf:type rdf:Property ;
    rdfs:label 'Sender Identifier' ;
    rdfs:comment 'EDI sender identification code or qualifier used by Transport Shipping in outbound messages to this partner (e.g., SCAC code, IATA code, GLN, DUNS number).' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResponseTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Sla Response Time Seconds' ;
    rdfs:comment 'Maximum response time in seconds agreed with the partner for message acknowledgment or processing, as defined in the integration SLA.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaUptimePercentage rdf:type rdf:Property ;
    rdfs:label 'Sla Uptime Percentage' ;
    rdfs:comment 'Minimum uptime percentage committed for this connection as defined in the integration SLA (e.g., 99.9%).' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicalContactEmail rdf:type rdf:Property ;
    rdfs:label 'Technical Contact Email' ;
    rdfs:comment 'Email address of the primary technical contact at the partner organization for EDI support and troubleshooting.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalContactName rdf:type rdf:Property ;
    rdfs:label 'Technical Contact Name' ;
    rdfs:comment 'Name of the primary technical contact at the partner organization responsible for this EDI connection.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalContactPhone rdf:type rdf:Property ;
    rdfs:label 'Technical Contact Phone' ;
    rdfs:comment 'Phone number of the primary technical contact at the partner organization for urgent EDI issues.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testEnvironmentEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Test Environment Endpoint Url' ;
    rdfs:comment 'The URL or network address of the partner\'s test/sandbox EDI or API endpoint used for integration testing before production go-live.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testEnvironmentStatus rdf:type rdf:Property ;
    rdfs:label 'Test Environment Status' ;
    rdfs:comment 'Current status of the test/sandbox environment connection for this partner integration. Indicates whether test connectivity and message exchange have been successfully validated.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeoutSeconds rdf:type rdf:Property ;
    rdfs:label 'Timeout Seconds' ;
    rdfs:comment 'Maximum time in seconds to wait for a response from the partner endpoint before considering the transmission failed.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requestorContactId rdf:type rdf:Property ;
    rdfs:label 'Requestor Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: Quotes are requested by and issued to a specific contact person. Commercial teams track quote acceptance, follow-up, and conversion by contact. Role-prefixed \'requestor_contact_id\' to identify the con' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:revisedQuoteId rdf:type rdf:Property ;
    rdfs:label 'Revised Quote Id' ;
    rdfs:comment 'Self-referencing FK on quote (revised_quote_id)' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Quote .

ind:baseFreightChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Base Freight Charge Amount' ;
    rdfs:comment 'Base freight charge amount quoted for the transportation service, excluding surcharges and accessorial fees.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentPerformanceObligationId rdf:type rdf:Property ;
    rdfs:label 'Parent Performance Obligation Id' ;
    rdfs:comment 'Self-referencing FK on performance_obligation (parent_performance_obligation_id)' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformanceObligation .

ind:billedAmount rdf:type rdf:Property ;
    rdfs:label 'Billed Amount' ;
    rdfs:comment 'Cumulative amount invoiced against the performance obligation.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingCycle rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle' ;
    rdfs:comment 'Frequency or trigger for invoicing the obligation.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionMethod rdf:type rdf:Property ;
    rdfs:label 'Collection Method' ;
    rdfs:comment 'Method used to collect payment for the obligation.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionStatus rdf:type rdf:Property ;
    rdfs:label 'Collection Status' ;
    rdfs:comment 'Current status of cash collection for the obligation.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountType rdf:type rdf:Property ;
    rdfs:label 'Discount Type' ;
    rdfs:comment 'Method by which the discount is applied.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPartialObligation rdf:type rdf:Property ;
    rdfs:label 'Is Partial Obligation' ;
    rdfs:comment 'True if the obligation represents a portion of a larger contract obligation.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:metricActualValue rdf:type rdf:Property ;
    rdfs:label 'Metric Actual Value' ;
    rdfs:comment 'Actual measured value of the performance metric to date.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metricTargetValue rdf:type rdf:Property ;
    rdfs:label 'Metric Target Value' ;
    rdfs:comment 'Target value for the performance metric that triggers revenue recognition.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metricUnit rdf:type rdf:Property ;
    rdfs:label 'Metric Unit' ;
    rdfs:comment 'Unit of measure for the performance metric.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationNumber rdf:type rdf:Property ;
    rdfs:label 'Obligation Number' ;
    rdfs:comment 'External identifier assigned to the performance obligation by the billing system.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationType rdf:type rdf:Property ;
    rdfs:label 'Obligation Type' ;
    rdfs:comment 'Category of the promised deliverable underlying the obligation.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceObligationDescription rdf:type rdf:Property ;
    rdfs:label 'Performance Obligation Description' ;
    rdfs:comment 'Free-form text describing the goods or services promised.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceObligationStatus rdf:type rdf:Property ;
    rdfs:label 'Performance Obligation Status' ;
    rdfs:comment 'Current lifecycle state of the performance obligation.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unbilledAmount rdf:type rdf:Property ;
    rdfs:label 'Unbilled Amount' ;
    rdfs:comment 'Remaining monetary value of the obligation that has not yet been invoiced.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:representedByClaimantId rdf:type rdf:Property ;
    rdfs:label 'Represented By Claimant Id' ;
    rdfs:comment 'Self-referencing FK on claimant (represented_by_claimant_id)' ;
    rdfs:domain ind:Claimant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Claimant .

ind:amlFlag rdf:type rdf:Property ;
    rdfs:label 'Aml Flag' ;
    rdfs:comment 'Indicates whether the claimant is flagged for AML review.' ;
    rdfs:domain ind:Claimant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:claimCount rdf:type rdf:Property ;
    rdfs:label 'Claim Count' ;
    rdfs:comment 'Total count of claims filed by the claimant.' ;
    rdfs:domain ind:Claimant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimantCategory rdf:type rdf:Property ;
    rdfs:label 'Claimant Category' ;
    rdfs:comment 'Business classification of the claimant for claim processing.' ;
    rdfs:domain ind:Claimant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantStatus rdf:type rdf:Property ;
    rdfs:label 'Claimant Status' ;
    rdfs:comment 'Current lifecycle status of the claimant record.' ;
    rdfs:domain ind:Claimant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantType rdf:type rdf:Property ;
    rdfs:label 'Claimant Type' ;
    rdfs:comment 'Category of claimant indicating legal form or role.' ;
    rdfs:domain ind:Claimant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'Birth date of an individual claimant; null for corporate entities.' ;
    rdfs:domain ind:Claimant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nationalIdNumber rdf:type rdf:Property ;
    rdfs:label 'National Id Number' ;
    rdfs:comment 'Government-issued personal identifier (e.g., SSN, passport number).' ;
    rdfs:domain ind:Claimant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Method' ;
    rdfs:comment 'Claimant\'s preferred channel for communications.' ;
    rdfs:domain ind:Claimant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsListed rdf:type rdf:Property ;
    rdfs:label 'Sanctions Listed' ;
    rdfs:comment 'True if the claimant appears on any international sanctions list.' ;
    rdfs:domain ind:Claimant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:state rdf:type rdf:Property ;
    rdfs:label 'State' ;
    rdfs:comment 'State or province component of the claimant\'s address.' ;
    rdfs:domain ind:Claimant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalClaimsAmount rdf:type rdf:Property ;
    rdfs:label 'Total Claims Amount' ;
    rdfs:comment 'Cumulative monetary value of all claims submitted by the claimant.' ;
    rdfs:domain ind:Claimant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnTripId rdf:type rdf:Property ;
    rdfs:label 'Return Trip Id' ;
    rdfs:comment 'Self-referencing FK on trip (return_trip_id)' ;
    rdfs:domain ind:Trip ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Trip .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'Real end time when the vehicle arrived at the destination.' ;
    rdfs:domain ind:Trip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:averageSpeedKmh rdf:type rdf:Property ;
    rdfs:label 'Average Speed Kmh' ;
    rdfs:comment 'Average speed of the vehicle over the trip.' ;
    rdfs:domain ind:Trip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoType rdf:type rdf:Property ;
    rdfs:label 'Cargo Type' ;
    rdfs:comment 'Classification of cargo being moved.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-form notes or remarks about the trip.' ;
    rdfs:domain ind:Trip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionsKgCo2 rdf:type rdf:Property ;
    rdfs:label 'Emissions Kg Co2' ;
    rdfs:comment 'Estimated carbon dioxide emissions for the trip.' ;
    rdfs:domain ind:Trip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isExpedited rdf:type rdf:Property ;
    rdfs:label 'Is Expedited' ;
    rdfs:comment 'Indicates whether the trip was expedited (true) or standard (false).' ;
    rdfs:domain ind:Trip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordAuditCreated rdf:type rdf:Property ;
    rdfs:label 'Record Audit Created' ;
    rdfs:comment 'Timestamp when the trip record was first created in the system.' ;
    rdfs:domain ind:Trip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordAuditUpdated rdf:type rdf:Property ;
    rdfs:label 'Record Audit Updated' ;
    rdfs:comment 'Timestamp of the most recent update to the trip record.' ;
    rdfs:domain ind:Trip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Timestamp' ;
    rdfs:comment 'Planned end time of the trip as per the schedule.' ;
    rdfs:domain ind:Trip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Timestamp' ;
    rdfs:comment 'Planned start time of the trip as per the schedule.' ;
    rdfs:domain ind:Trip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tripNumber rdf:type rdf:Property ;
    rdfs:label 'Trip Number' ;
    rdfs:comment 'Business-assigned alphanumeric identifier for the trip, used in operational systems and customer communications.' ;
    rdfs:domain ind:Trip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tripStatus rdf:type rdf:Property ;
    rdfs:label 'Trip Status' ;
    rdfs:comment 'Current lifecycle status of the trip.' ;
    rdfs:domain ind:Trip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentItemId rdf:type rdf:Property ;
    rdfs:label 'Parent Item Id' ;
    rdfs:comment 'Self-referencing FK on item (parent_item_id)' ;
    rdfs:domain ind:Item ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Item .

ind:parentHandlingUnitId rdf:type rdf:Property ;
    rdfs:label 'Parent Handling Unit Id' ;
    rdfs:comment 'Identifier of the parent handling unit when this unit is nested within a larger unit (e.g., cartons on a pallet), enabling hierarchical tracking of nested packaging structures.' ;
    rdfs:domain ind:HandlingUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HandlingUnit .

ind:customsStatus rdf:type rdf:Property ;
    rdfs:label 'Customs Status' ;
    rdfs:comment 'Current customs clearance status of the handling unit contents, determining whether goods can be released for domestic distribution or must remain in bonded storage.' ;
    rdfs:domain ind:HandlingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionCode rdf:type rdf:Property ;
    rdfs:label 'Disposition Code' ;
    rdfs:comment 'Inventory disposition classification indicating the intended action or salability status of the handling unit contents, driving returns management and write-off workflows.' ;
    rdfs:domain ind:HandlingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Handling Instructions' ;
    rdfs:comment 'Special handling instructions for this unit such as fragile, this-side-up, keep dry, or forklift-only requirements, communicated to warehouse operatives during movement tasks.' ;
    rdfs:domain ind:HandlingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingUnitStatus rdf:type rdf:Property ;
    rdfs:label 'Handling Unit Status' ;
    rdfs:comment 'Current lifecycle status of the handling unit indicating its availability and condition within warehouse operations.' ;
    rdfs:domain ind:HandlingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMixedSku rdf:type rdf:Property ;
    rdfs:label 'Is Mixed Sku' ;
    rdfs:comment 'Indicates whether this handling unit contains multiple different SKUs (mixed) versus a single SKU (homogeneous), affecting picking strategy and inventory allocation logic.' ;
    rdfs:domain ind:HandlingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReturnable rdf:type rdf:Property ;
    rdfs:label 'Is Returnable' ;
    rdfs:comment 'Indicates whether this handling unit (e.g., pallet, tote) is a returnable/reusable asset that must be tracked for reverse logistics and asset pool management.' ;
    rdfs:domain ind:HandlingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStackable rdf:type rdf:Property ;
    rdfs:label 'Is Stackable' ;
    rdfs:comment 'Indicates whether this handling unit can be safely stacked upon by other units during storage or transport, affecting warehouse slotting and load planning decisions.' ;
    rdfs:domain ind:HandlingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemCount rdf:type rdf:Property ;
    rdfs:label 'Item Count' ;
    rdfs:comment 'Total number of individual items or SKUs contained within this handling unit, used for inventory reconciliation and pick verification.' ;
    rdfs:domain ind:HandlingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastMovementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Movement Timestamp' ;
    rdfs:comment 'Timestamp of the most recent physical movement of this handling unit within the warehouse (putaway, replenishment, pick, or relocation), used for dwell time analysis.' ;
    rdfs:domain ind:HandlingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loadUnitNumber rdf:type rdf:Property ;
    rdfs:label 'Load Unit Number' ;
    rdfs:comment 'Reference number of the outbound load or shipment this handling unit is assigned to for dispatch, linking warehouse operations to transportation execution.' ;
    rdfs:domain ind:HandlingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Max Temperature C' ;
    rdfs:comment 'Maximum allowable storage temperature in degrees Celsius for temperature-sensitive contents, used for cold chain compliance monitoring and alert thresholds.' ;
    rdfs:domain ind:HandlingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Min Temperature C' ;
    rdfs:comment 'Minimum allowable storage temperature in degrees Celsius for temperature-sensitive contents, used for cold chain compliance monitoring.' ;
    rdfs:domain ind:HandlingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sscc rdf:type rdf:Property ;
    rdfs:label 'Sscc' ;
    rdfs:comment 'The 18-digit GS1 Serial Shipping Container Code that uniquely identifies this handling unit across the global supply chain for tracking and traceability.' ;
    rdfs:domain ind:HandlingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitType rdf:type rdf:Property ;
    rdfs:label 'Unit Type' ;
    rdfs:comment 'Classification of the physical packaging type of the handling unit, determining storage requirements, handling equipment needs, and slotting optimization rules.' ;
    rdfs:domain ind:HandlingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidatedCargoId rdf:type rdf:Property ;
    rdfs:label 'Consolidated Cargo Id' ;
    rdfs:comment 'Self-referencing FK on cargo (consolidated_cargo_id)' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cargo .

ind:cargoStatus rdf:type rdf:Property ;
    rdfs:label 'Cargo Status' ;
    rdfs:comment 'Current lifecycle status of the cargo master record indicating whether it is available for booking and operational use.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportLicenseRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Export License Required Flag' ;
    rdfs:comment 'Indicates whether an export license or permit is required for this cargo based on its classification and destination restrictions.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatPackingGroup rdf:type rdf:Property ;
    rdfs:label 'Hazmat Packing Group' ;
    rdfs:comment 'Packing group (I, II, or III) indicating the degree of danger for hazardous cargo, determining packaging and handling requirements.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marksAndNumbers rdf:type rdf:Property ;
    rdfs:label 'Marks And Numbers' ;
    rdfs:comment 'Shipping marks, labels, and identification numbers physically applied to the cargo packages for identification during handling and delivery.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Max Temperature Celsius' ;
    rdfs:comment 'Maximum allowable temperature for temperature-sensitive cargo during transport and storage, measured in degrees Celsius.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Min Temperature Celsius' ;
    rdfs:comment 'Minimum allowable temperature for temperature-sensitive cargo during transport and storage, measured in degrees Celsius.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplyAgreementId rdf:type rdf:Property ;
    rdfs:label 'Supply Agreement Id' ;
    rdfs:comment 'Unique identifier for this supply agreement record. Primary key.' ;
    rdfs:domain ind:SupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractPrice rdf:type rdf:Property ;
    rdfs:label 'Contract Price' ;
    rdfs:comment 'The contracted price for this item from this supplier, which may differ from the current unit_price due to volume discounts or promotional pricing. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:SupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Flag' ;
    rdfs:comment 'Indicates whether this supplier is the preferred source for this specific item. An item may have multiple approved suppliers but only one preferred. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:SupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manifestLineId rdf:type rdf:Property ;
    rdfs:label 'Manifest Line Id' ;
    rdfs:comment 'Unique identifier for this manifest line record. Primary key.' ;
    rdfs:domain ind:ManifestLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:handlingUnitType rdf:type rdf:Property ;
    rdfs:label 'Handling Unit Type' ;
    rdfs:comment 'Type of handling unit used for this consignment on this manifest (e.g., pallet, cage, loose, container). Relevant for load planning and warehouse operations.' ;
    rdfs:domain ind:ManifestLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Line Sequence Number' ;
    rdfs:comment 'Sequential line number indicating the order in which this consignment was loaded onto the manifest. Used for load planning and unload sequencing.' ;
    rdfs:domain ind:ManifestLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loadedPieces rdf:type rdf:Property ;
    rdfs:label 'Loaded Pieces' ;
    rdfs:comment 'Number of pieces from this consignment actually loaded onto this manifest. May differ from consignment total pieces in multi-leg scenarios where a consignment is split across manifests.' ;
    rdfs:domain ind:ManifestLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loadedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Loaded Timestamp' ;
    rdfs:comment 'Date and time when this consignment was physically loaded onto the manifest. Captured from WMS or TMS scan events.' ;
    rdfs:domain ind:ManifestLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loadedVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Loaded Volume Cbm' ;
    rdfs:comment 'Actual volume in cubic meters (CBM) of this consignment loaded onto this manifest. Used for load optimization and capacity planning.' ;
    rdfs:domain ind:ManifestLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loadedWeightKg rdf:type rdf:Property ;
    rdfs:label 'Loaded Weight Kg' ;
    rdfs:comment 'Actual weight in kilograms of this consignment loaded onto this manifest. Used for load reconciliation and carrier billing.' ;
    rdfs:domain ind:ManifestLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unloadedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Unloaded Timestamp' ;
    rdfs:comment 'Date and time when this consignment was unloaded from the manifest at the destination facility. Captured from WMS or TMS scan events.' ;
    rdfs:domain ind:ManifestLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:allocationId rdf:type rdf:Property ;
    rdfs:label 'Allocation Id' ;
    rdfs:comment 'Primary key uniquely identifying each merchant-center allocation record' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:percentage rdf:type rdf:Property ;
    rdfs:label 'Percentage' ;
    rdfs:comment 'Percentage of the merchant\'s total order volume or inventory allocated to this specific fulfillment center. Used for load balancing and capacity planning across multi-center merchants.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceTypesEnabled rdf:type rdf:Property ;
    rdfs:label 'Service Types Enabled' ;
    rdfs:comment 'Comma-separated list of fulfillment service types enabled for this merchant at this center (e.g., \'standard_fulfillment,express_fulfillment,COD,returns_processing\'). Service type availability varies by merchant-center combination based on contract terms and center capabilities.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageAllocationCbm rdf:type rdf:Property ;
    rdfs:label 'Storage Allocation Cbm' ;
    rdfs:comment 'Cubic meters of storage capacity allocated to this merchant at this fulfillment center. Used for capacity planning, billing, and inventory placement decisions.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:declarationComplianceBenefitId rdf:type rdf:Property ;
    rdfs:label 'Declaration Compliance Benefit Id' ;
    rdfs:comment 'Unique identifier for this declaration-compliance program benefit application record. Primary key.' ;
    rdfs:domain ind:DeclarationComplianceBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benefitApplicationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Benefit Application Timestamp' ;
    rdfs:comment 'Precise timestamp when the compliance program benefit was applied to this declaration in the customs processing system' ;
    rdfs:domain ind:DeclarationComplianceBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:benefitAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Benefit Applied Flag' ;
    rdfs:comment 'Indicates whether the compliance program benefit was successfully applied to this declaration during customs processing' ;
    rdfs:domain ind:DeclarationComplianceBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:benefitClaimedBy rdf:type rdf:Property ;
    rdfs:label 'Benefit Claimed By' ;
    rdfs:comment 'Name or identifier of the party (importer, broker, carrier) that claimed the compliance program benefit on this declaration' ;
    rdfs:domain ind:DeclarationComplianceBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Benefit Effective Date' ;
    rdfs:comment 'Date when the compliance program benefit was applied or became effective for this declaration' ;
    rdfs:domain ind:DeclarationComplianceBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customsVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Customs Verification Status' ;
    rdfs:comment 'Status of customs authority verification that the compliance program benefit was validly claimed and applied (verified, pending, rejected, not_applicable)' ;
    rdfs:domain ind:DeclarationComplianceBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expeditedReleaseApplied rdf:type rdf:Property ;
    rdfs:label 'Expedited Release Applied' ;
    rdfs:comment 'Indicates whether expedited customs release processing was granted based on this compliance program membership' ;
    rdfs:domain ind:DeclarationComplianceBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programBenefitType rdf:type rdf:Property ;
    rdfs:label 'Program Benefit Type' ;
    rdfs:comment 'Type of compliance program benefit applied to this declaration (e.g., expedited_release, reduced_examination, priority_processing, dedicated_lane, fee_reduction)' ;
    rdfs:domain ind:DeclarationComplianceBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reducedExaminationApplied rdf:type rdf:Property ;
    rdfs:label 'Reduced Examination Applied' ;
    rdfs:comment 'Indicates whether reduced physical examination rate was applied to this declaration based on compliance program membership' ;
    rdfs:domain ind:DeclarationComplianceBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .
